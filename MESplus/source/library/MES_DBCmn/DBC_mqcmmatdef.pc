/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mqcmmatdef(int sel_type, struct MQCMMATDEF_TAG *MQCMMATDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MQCMMATDEF_N_TAG MQCMMATDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    
    DBC_add_null_mqcmmatdef(&MQCMMATDEF_N, MQCMMATDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MQCMMATDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    TOTAL_INSP,
                    AUTO_FINAL,
                    SKIP_RESULT_RECORD,
                    ADD_SAMPLE,
                    MAX_QTY,
                    IQC_FLAG,
                    IQC_INSP_SET_ID,
                    PQC_FLAG,
                    PQC_INSP_SET_ID,
                    OQC_FLAG,
                    OQC_INSP_SET_ID,
                    RMA_FLAG,
                    RMA_INSP_SET_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MQCMMATDEF
                WHERE FACTORY = :MQCMMATDEF_N.FACTORY
                    AND 
                       ( (MAT_ID > :MQCMMATDEF_N.MAT_ID)
                         OR
                         (MAT_ID = :MQCMMATDEF_N.MAT_ID AND MAT_VER >= :MQCMMATDEF_N.MAT_VER)
                       )
                ORDER BY FACTORY ASC,
                    MAT_ID ASC,
                    MAT_VER ASC;
            EXEC SQL OPEN DBC_MQCMMATDEF_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mqcmmatdef", sel_type);
}


