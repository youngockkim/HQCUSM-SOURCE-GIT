            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mspcoochis(&MSPCOOCHIS_N, MSPCOOCHIS);
    }
    DB_stop_query_timer("DBC_fetch_mspcoochis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mspcoochis(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MSPCOOCHIS_CUR_1;
            break;
        case 2:
            EXEC SQL CLOSE DBC_MSPCOOCHIS_CUR_2;
            break;
        case 3:
            EXEC SQL CLOSE DBC_MSPCOOCHIS_CUR_3;
            break;
        case 4:
            EXEC SQL CLOSE DBC_MSPCOOCHIS_CUR_4;
            break;    


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mspcoochis", sel_type);
}


/* Initialize Function */
void DBC_init_mspcoochis(struct MSPCOOCHIS_TAG *MSPCOOCHIS)
{
    /* memset by Space */
    memset(MSPCOOCHIS, ' ', sizeof(struct MSPCOOCHIS_TAG));
    
    MSPCOOCHIS->HIST_SEQ = 0;
    MSPCOOCHIS->EDC_HIST_SEQ = 0;
    MSPCOOCHIS->EDC_UNIT_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mspcoochis(struct MSPCOOCHIS_N_TAG *MSPCOOCHIS_N, struct MSPCOOCHIS_TAG *MSPCOOCHIS)
{
    /* memset by NULL */
    memset(MSPCOOCHIS_N, '\0', sizeof(struct MSPCOOCHIS_N_TAG));
    
    MEMCPY_AN(MSPCOOCHIS_N->FACTORY, MSPCOOCHIS->FACTORY, sizeof(MSPCOOCHIS->FACTORY));
    MEMCPY_AN(MSPCOOCHIS_N->CHART_ID, MSPCOOCHIS->CHART_ID, sizeof(MSPCOOCHIS->CHART_ID));
    MSPCOOCHIS_N->HIST_SEQ = MSPCOOCHIS->HIST_SEQ;
    MEMCPY_AN(MSPCOOCHIS_N->TRAN_TIME, MSPCOOCHIS->TRAN_TIME, sizeof(MSPCOOCHIS->TRAN_TIME));
    MSPCOOCHIS_N->LOT_RES_FLAG[0] = MSPCOOCHIS->LOT_RES_FLAG;
    MSPCOOCHIS_N->OOC_TYPE[0] = MSPCOOCHIS->OOC_TYPE;
    MSPCOOCHIS_N->OOC_TYPE2[0] = MSPCOOCHIS->OOC_TYPE2;
    MEMCPY_AN(MSPCOOCHIS_N->TRB_CODE, MSPCOOCHIS->TRB_CODE, sizeof(MSPCOOCHIS->TRB_CODE));
    MEMCPY_AN(MSPCOOCHIS_N->TRB_USER, MSPCOOCHIS->TRB_USER, sizeof(MSPCOOCHIS->TRB_USER));
    MEMCPY_AN(MSPCOOCHIS_N->TRB_TIME, MSPCOOCHIS->TRB_TIME, sizeof(MSPCOOCHIS->TRB_TIME));
    MEMCPY_AN(MSPCOOCHIS_N->TRB_COMMENT, MSPCOOCHIS->TRB_COMMENT, sizeof(MSPCOOCHIS->TRB_COMMENT));
    MEMCPY_AN(MSPCOOCHIS_N->ACT_CODE, MSPCOOCHIS->ACT_CODE, sizeof(MSPCOOCHIS->ACT_CODE));
    MEMCPY_AN(MSPCOOCHIS_N->ACT_USER, MSPCOOCHIS->ACT_USER, sizeof(MSPCOOCHIS->ACT_USER));
    MEMCPY_AN(MSPCOOCHIS_N->ACT_TIME, MSPCOOCHIS->ACT_TIME, sizeof(MSPCOOCHIS->ACT_TIME));
    MEMCPY_AN(MSPCOOCHIS_N->ACT_COMMENT, MSPCOOCHIS->ACT_COMMENT, sizeof(MSPCOOCHIS->ACT_COMMENT));
    MEMCPY_AN(MSPCOOCHIS_N->INSPECTOR, MSPCOOCHIS->INSPECTOR, sizeof(MSPCOOCHIS->INSPECTOR));
    MSPCOOCHIS_N->DELETE_FLAG[0] = MSPCOOCHIS->DELETE_FLAG;
    MEMCPY_AN(MSPCOOCHIS_N->DELETE_COMMENT, MSPCOOCHIS->DELETE_COMMENT, sizeof(MSPCOOCHIS->DELETE_COMMENT));
    MSPCOOCHIS_N->EDC_HIST_SEQ = MSPCOOCHIS->EDC_HIST_SEQ;
    MSPCOOCHIS_N->EDC_UNIT_SEQ = MSPCOOCHIS->EDC_UNIT_SEQ;
    MEMCPY_AN(MSPCOOCHIS_N->CREATE_USER_ID, MSPCOOCHIS->CREATE_USER_ID, sizeof(MSPCOOCHIS->CREATE_USER_ID));
    MEMCPY_AN(MSPCOOCHIS_N->CREATE_TIME, MSPCOOCHIS->CREATE_TIME, sizeof(MSPCOOCHIS->CREATE_TIME));
    MEMCPY_AN(MSPCOOCHIS_N->UPDATE_USER_ID, MSPCOOCHIS->UPDATE_USER_ID, sizeof(MSPCOOCHIS->UPDATE_USER_ID));
    MEMCPY_AN(MSPCOOCHIS_N->UPDATE_TIME, MSPCOOCHIS->UPDATE_TIME, sizeof(MSPCOOCHIS->UPDATE_TIME));
    MEMCPY_AN(MSPCOOCHIS_N->RESV_FIELD1, MSPCOOCHIS->RESV_FIELD1, sizeof(MSPCOOCHIS->RESV_FIELD1));
    MEMCPY_AN(MSPCOOCHIS_N->RESV_FIELD2, MSPCOOCHIS->RESV_FIELD2, sizeof(MSPCOOCHIS->RESV_FIELD2));
    MEMCPY_AN(MSPCOOCHIS_N->RESV_FIELD3, MSPCOOCHIS->RESV_FIELD3, sizeof(MSPCOOCHIS->RESV_FIELD3));
    MEMCPY_AN(MSPCOOCHIS_N->RESV_FIELD4, MSPCOOCHIS->RESV_FIELD4, sizeof(MSPCOOCHIS->RESV_FIELD4));
    MEMCPY_AN(MSPCOOCHIS_N->RESV_FIELD5, MSPCOOCHIS->RESV_FIELD5, sizeof(MSPCOOCHIS->RESV_FIELD5));
}


/* Del Null Function */
void DBC_del_null_mspcoochis(struct MSPCOOCHIS_N_TAG *MSPCOOCHIS_N, struct MSPCOOCHIS_TAG *MSPCOOCHIS)
{
    MEMCPY_DN(MSPCOOCHIS->FACTORY, MSPCOOCHIS_N->FACTORY, sizeof(MSPCOOCHIS->FACTORY));
    MEMCPY_DN(MSPCOOCHIS->CHART_ID, MSPCOOCHIS_N->CHART_ID, sizeof(MSPCOOCHIS->CHART_ID));
    MSPCOOCHIS->HIST_SEQ = MSPCOOCHIS_N->HIST_SEQ;
    MEMCPY_DN(MSPCOOCHIS->TRAN_TIME, MSPCOOCHIS_N->TRAN_TIME, sizeof(MSPCOOCHIS->TRAN_TIME));
    MSPCOOCHIS->LOT_RES_FLAG = MSPCOOCHIS_N->LOT_RES_FLAG[0];
    MSPCOOCHIS->OOC_TYPE = MSPCOOCHIS_N->OOC_TYPE[0];
    MSPCOOCHIS->OOC_TYPE2 = MSPCOOCHIS_N->OOC_TYPE2[0];
    MEMCPY_DN(MSPCOOCHIS->TRB_CODE, MSPCOOCHIS_N->TRB_CODE, sizeof(MSPCOOCHIS->TRB_CODE));
    MEMCPY_DN(MSPCOOCHIS->TRB_USER, MSPCOOCHIS_N->TRB_USER, sizeof(MSPCOOCHIS->TRB_USER));
    MEMCPY_DN(MSPCOOCHIS->TRB_TIME, MSPCOOCHIS_N->TRB_TIME, sizeof(MSPCOOCHIS->TRB_TIME));
    MEMCPY_DN(MSPCOOCHIS->TRB_COMMENT, MSPCOOCHIS_N->TRB_COMMENT, sizeof(MSPCOOCHIS->TRB_COMMENT));
    MEMCPY_DN(MSPCOOCHIS->ACT_CODE, MSPCOOCHIS_N->ACT_CODE, sizeof(MSPCOOCHIS->ACT_CODE));
    MEMCPY_DN(MSPCOOCHIS->ACT_USER, MSPCOOCHIS_N->ACT_USER, sizeof(MSPCOOCHIS->ACT_USER));
    MEMCPY_DN(MSPCOOCHIS->ACT_TIME, MSPCOOCHIS_N->ACT_TIME, sizeof(MSPCOOCHIS->ACT_TIME));
    MEMCPY_DN(MSPCOOCHIS->ACT_COMMENT, MSPCOOCHIS_N->ACT_COMMENT, sizeof(MSPCOOCHIS->ACT_COMMENT));
