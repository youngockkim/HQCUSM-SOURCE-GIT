            break;
        case 3:
            EXEC SQL FETCH DBC_MSPCOOCHIS_CUR_3 INTO 
                                                    :MSPCOOCHIS_N.FACTORY,
                                                    :MSPCOOCHIS_N.CHART_ID,
                                                    :MSPCOOCHIS_N.HIST_SEQ,
                                                    :MSPCOOCHIS_N.TRAN_TIME,
