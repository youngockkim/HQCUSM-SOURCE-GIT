                    INSPECTOR = :MSPCOOCHIS_N.INSPECTOR,
                    DELETE_FLAG = :MSPCOOCHIS_N.DELETE_FLAG,
                    DELETE_COMMENT = :MSPCOOCHIS_N.DELETE_COMMENT,
                    CREATE_USER_ID = :MSPCOOCHIS_N.CREATE_USER_ID,
                    CREATE_TIME = :MSPCOOCHIS_N.CREATE_TIME,
                    UPDATE_USER_ID = :MSPCOOCHIS_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MSPCOOCHIS_N.UPDATE_TIME,
                    RESV_FIELD1 = :MSPCOOCHIS_N.RESV_FIELD1,
                    RESV_FIELD2 = :MSPCOOCHIS_N.RESV_FIELD2,
                    RESV_FIELD3 = :MSPCOOCHIS_N.RESV_FIELD3,
                    RESV_FIELD4 = :MSPCOOCHIS_N.RESV_FIELD4,
                    RESV_FIELD5 = :MSPCOOCHIS_N.RESV_FIELD5
                WHERE FACTORY = :MSPCOOCHIS_N.FACTORY
                    AND CHART_ID = :MSPCOOCHIS_N.CHART_ID
                    AND HIST_SEQ = :MSPCOOCHIS_N.HIST_SEQ
                    AND EDC_HIST_SEQ = :MSPCOOCHIS_N.EDC_HIST_SEQ
                    AND EDC_UNIT_SEQ = :MSPCOOCHIS_N.EDC_UNIT_SEQ
                    AND DELETE_FLAG = 'Y';
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mspcoochis", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mspcoochis(int sel_type, struct MSPCOOCHIS_TAG *MSPCOOCHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSPCOOCHIS_N_TAG MSPCOOCHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    
    DBC_add_null_mspcoochis(&MSPCOOCHIS_N, MSPCOOCHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSPCOOCHIS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    OOC_TYPE,
                    OOC_TYPE2,
                    TRB_CODE,
                    TRB_USER,
                    TRB_TIME,
                    TRB_COMMENT,
                    ACT_CODE,
                    ACT_USER,
                    ACT_TIME,
                    ACT_COMMENT,
                    INSPECTOR,
                    DELETE_FLAG,
                    DELETE_COMMENT,
                    EDC_HIST_SEQ,
                    EDC_UNIT_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                FROM MSPCOOCHIS
                ORDER BY FACTORY ASC,
                    CHART_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MSPCOOCHIS_CUR_1;
            break;
        case 2:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N); 
            EXEC SQL DECLARE DBC_MSPCOOCHIS_CUR_2 CURSOR FOR
                SELECT
                           A.FACTORY,
                           A.CHART_ID,
                           A.HIST_SEQ,
                           A.TRAN_TIME,
                           A.LOT_RES_FLAG,
                           A.OOC_TYPE,
                           A.OOC_TYPE2,
                           A.TRB_CODE,
                           A.TRB_USER,
                           A.TRB_TIME,
                           A.TRB_COMMENT,
                           A.ACT_CODE,
                           A.ACT_USER,
                           A.ACT_TIME,
                           A.ACT_COMMENT,
                           A.INSPECTOR,
                           A.DELETE_FLAG,
                           A.DELETE_COMMENT,
                           A.EDC_HIST_SEQ,
                           A.EDC_UNIT_SEQ,
                           A.CREATE_USER_ID,
                           A.CREATE_TIME,
                           A.UPDATE_USER_ID,
                           A.UPDATE_TIME,
                           A.RESV_FIELD1,
                           A.RESV_FIELD2,
                           A.RESV_FIELD3,
                           A.RESV_FIELD4,
                           A.RESV_FIELD5
                FROM MSPCOOCHIS A, MSPCCHTDEF B
                WHERE A.FACTORY = :MSPCOOCHIS_N.FACTORY
                    AND A.FACTORY = B.FACTORY
                    AND A.CHART_ID = B.CHART_ID
                    AND B.DELETE_FLAG <> :MSPCOOCHIS_N.LOT_RES_FLAG
                    AND ((A.CHART_ID > :MSPCOOCHIS_N.CHART_ID) OR (A.CHART_ID = :MSPCOOCHIS_N.CHART_ID AND A.HIST_SEQ <= :MSPCOOCHIS_N.HIST_SEQ))
                    AND A.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME 
                    AND A.TRAN_TIME < :DBC_Q_COND_N.TO_TIME
                    AND A.DELETE_FLAG <> : MSPCOOCHIS_N.DELETE_FLAG
                ORDER BY A.CHART_ID ASC, A.HIST_SEQ DESC;
            EXEC SQL OPEN DBC_MSPCOOCHIS_CUR_2;                 
            break;
            
            
        case 3:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N); 
            EXEC SQL DECLARE DBC_MSPCOOCHIS_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    OOC_TYPE,
                    OOC_TYPE2,
                    TRB_CODE,
                    TRB_USER,
                    TRB_TIME,
                    TRB_COMMENT,
                    ACT_CODE,
                    ACT_USER,
                    ACT_TIME,
                    ACT_COMMENT,
                    INSPECTOR,
                    DELETE_FLAG,
                    DELETE_COMMENT,
                    EDC_HIST_SEQ,
                    EDC_UNIT_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                FROM MSPCOOCHIS
                WHERE FACTORY = :MSPCOOCHIS_N.FACTORY
                    AND CHART_ID = :MSPCOOCHIS_N.CHART_ID
                    AND HIST_SEQ <= :MSPCOOCHIS_N.HIST_SEQ
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME 
                    AND TRAN_TIME < :DBC_Q_COND_N.TO_TIME
                    AND DELETE_FLAG <> : MSPCOOCHIS_N.DELETE_FLAG
                ORDER BY HIST_SEQ DESC;
            EXEC SQL OPEN DBC_MSPCOOCHIS_CUR_3;                 
            break;
         
         case 4:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N); 
            EXEC SQL DECLARE DBC_MSPCOOCHIS_CUR_4 CURSOR FOR
                SELECT
                           A.FACTORY,
                           A.CHART_ID,
                           A.HIST_SEQ,
                           A.TRAN_TIME,
                           A.LOT_RES_FLAG,
                           A.OOC_TYPE,
                           A.OOC_TYPE2,
                           A.TRB_CODE,
                           A.TRB_USER,
                           A.TRB_TIME,
                           A.TRB_COMMENT,
                           A.ACT_CODE,
                           A.ACT_USER,
                           A.ACT_TIME,
                           A.ACT_COMMENT,
                           A.INSPECTOR,
                           A.DELETE_FLAG,
                           A.DELETE_COMMENT,
                           A.EDC_HIST_SEQ,
                           A.EDC_UNIT_SEQ,
                           A.CREATE_USER_ID,
                           A.CREATE_TIME,
                           A.UPDATE_USER_ID,
                           A.UPDATE_TIME,
                           A.RESV_FIELD1,
                           A.RESV_FIELD2,
                           A.RESV_FIELD3,
                           A.RESV_FIELD4,
                           A.RESV_FIELD5
                FROM MSPCOOCHIS A, MSPCCHTDEF B
                WHERE A.FACTORY = :MSPCOOCHIS_N.FACTORY
                    AND A.FACTORY = B.FACTORY
                    AND A.CHART_ID = B.CHART_ID
                    AND A.CHART_ID IN (SELECT CHART_ID FROM MSPCCHTSET WHERE FACTORY = :MSPCOOCHIS_N.FACTORY AND CHART_SET_ID = :DBC_Q_COND_N.KEY_1 AND CHART_ID >= :MSPCOOCHIS_N.CHART_ID)
                    AND B.DELETE_FLAG <> :MSPCOOCHIS_N.LOT_RES_FLAG
                    AND ((A.CHART_ID > :MSPCOOCHIS_N.CHART_ID) 
                    OR (A.CHART_ID = :MSPCOOCHIS_N.CHART_ID AND A.HIST_SEQ <= :MSPCOOCHIS_N.HIST_SEQ))
                    AND A.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME 
                    AND A.TRAN_TIME < :DBC_Q_COND_N.TO_TIME
                    AND A.DELETE_FLAG <> : MSPCOOCHIS_N.DELETE_FLAG
                ORDER BY A.CHART_ID ASC, A.HIST_SEQ DESC;
            EXEC SQL OPEN DBC_MSPCOOCHIS_CUR_4;                 
            break;   
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mspcoochis", sel_type);
}


