void DBC_open_mwipcytdef(int sel_type, struct MWIPCYTDEF_TAG *MWIPCYTDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPCYTDEF_N_TAG MWIPCYTDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipcytdef(&MWIPCYTDEF_N, MWIPCYTDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPCYTDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    OPT_LEVEL,
                    QUEUE_TIME,
                    PROC_TIME,
                    HPU_FLAG,
                    HPU_PROC_TIME,
                    UPH_FLAG,
                    UPH_PROC_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPCYTDEF
                WHERE FACTORY = :MWIPCYTDEF_N.FACTORY
                    AND MAT_ID = :MWIPCYTDEF_N.MAT_ID
                    AND MAT_VER = :MWIPCYTDEF_N.MAT_VER
                    AND FLOW = :MWIPCYTDEF_N.FLOW
                    AND FLOW_SEQ_NUM = :MWIPCYTDEF_N.FLOW_SEQ_NUM
                ORDER BY OPER ASC;
            EXEC SQL OPEN DBC_MWIPCYTDEF_CUR_1;
            break;

        case 2:
            /* Use material version up */
            EXEC SQL DECLARE DBC_MWIPCYTDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    OPT_LEVEL,
                    QUEUE_TIME,
                    PROC_TIME,
                    HPU_FLAG,
                    HPU_PROC_TIME,
                    UPH_FLAG,
                    UPH_PROC_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPCYTDEF
                WHERE FACTORY = :MWIPCYTDEF_N.FACTORY
                    AND MAT_ID = :MWIPCYTDEF_N.MAT_ID
                    AND MAT_VER = :MWIPCYTDEF_N.MAT_VER;
            EXEC SQL OPEN DBC_MWIPCYTDEF_CUR_2;
            break;
        case 3:
            EXEC SQL DECLARE DBC_MWIPCYTDEF_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    OPT_LEVEL,
                    QUEUE_TIME,
                    PROC_TIME,
                    HPU_FLAG,
                    HPU_PROC_TIME,
                    UPH_FLAG,
                    UPH_PROC_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPCYTDEF
                WHERE FACTORY = :MWIPCYTDEF_N.FACTORY
                    AND MAT_ID = ' '
                    AND MAT_VER = 0
                    AND FLOW = :MWIPCYTDEF_N.FLOW;
            EXEC SQL OPEN DBC_MWIPCYTDEF_CUR_3;
            break;
        case 4:
            EXEC SQL DECLARE DBC_MWIPCYTDEF_CUR_4 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    OPT_LEVEL,
                    QUEUE_TIME,
                    PROC_TIME,
                    HPU_FLAG,
                    HPU_PROC_TIME,
                    UPH_FLAG,
                    UPH_PROC_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPCYTDEF
                WHERE FACTORY = :MWIPCYTDEF_N.FACTORY
                    AND MAT_ID = ' '
                    AND MAT_VER = 0
                    AND FLOW = ' '
                    AND OPER = :MWIPCYTDEF_N.OPER;
            EXEC SQL OPEN DBC_MWIPCYTDEF_CUR_4;
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipcytdef", sel_type);
}


