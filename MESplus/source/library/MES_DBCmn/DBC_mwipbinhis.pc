                    RES_TYPE = :MWIPBINHIS_N.RES_TYPE,
                    RESG_ID = :MWIPBINHIS_N.RESG_ID,
                    QTY_1 = :MWIPBINHIS_N.QTY_1,
                    QTY_2 = :MWIPBINHIS_N.QTY_2,
