/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrastolevn(int sel_type, struct MRASTOLEVN_TAG *MRASTOLEVN)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASTOLEVN_N_TAG MRASTOLEVN_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrastolevn(&MRASTOLEVN_N, MRASTOLEVN);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRASTOLEVN_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    TOOL_ID,
                    TOOL_TYPE,
                    TOOL_EVENT_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRASTOLEVN
                WHERE FACTORY = :MRASTOLEVN_N.FACTORY 
                    AND TOOL_TYPE = :MRASTOLEVN_N.TOOL_TYPE
                    AND TOOL_ID = :MRASTOLEVN_N.TOOL_ID
                    AND TOOL_EVENT_ID >= :MRASTOLEVN_N.TOOL_EVENT_ID
                ORDER BY FACTORY ASC,
                    TOOL_TYPE ASC,
                    TOOL_ID ASC,
                    TOOL_EVENT_ID ASC;
            EXEC SQL OPEN DBC_MRASTOLEVN_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MRASTOLEVN_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    TOOL_ID,
                    TOOL_TYPE,
                    TOOL_EVENT_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRASTOLEVN
                WHERE FACTORY = :MRASTOLEVN_N.FACTORY 
                    AND TOOL_TYPE = :MRASTOLEVN_N.TOOL_TYPE
                    AND TOOL_EVENT_ID = :MRASTOLEVN_N.TOOL_EVENT_ID
                    AND TOOL_ID >= :MRASTOLEVN_N.TOOL_ID
                ORDER BY FACTORY ASC,
                    TOOL_TYPE ASC,
                    TOOL_EVENT_ID ASC,
                    TOOL_ID ASC;
            EXEC SQL OPEN DBC_MRASTOLEVN_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrastolevn", sel_type);
}


