    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(DISTINCT TEV.TOOL_ID) 
                INTO :d_value
                FROM MRASTOLEVN TEV, MRASTOLDEF TOL
                WHERE TEV.FACTORY = :MRASTOLEVN_N.FACTORY
                    AND TEV.TOOL_TYPE = :MRASTOLEVN_N.TOOL_TYPE
                    AND TEV.TOOL_EVENT_ID = :MRASTOLEVN_N.TOOL_EVENT_ID
                    AND TEV.FACTORY = TOL.FACTORY
                    AND TEV.TOOL_ID = TOL.TOOL_ID
                    AND TOL.DELETE_FLAG = ' ';
            break;

        case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                  FROM MRASTOLEVN E, MRASTEVDEF T
                  WHERE E.FACTORY = :MRASTOLEVN_N.FACTORY
                  AND E.TOOL_TYPE = :MRASTOLEVN_N.TOOL_TYPE
                  AND E.TOOL_ID = :MRASTOLEVN_N.TOOL_ID
                  AND E.FACTORY = T.FACTORY
                  AND E.TOOL_EVENT_ID = T.TOOL_EVENT_ID
                  AND E.TOOL_TYPE = T.TOOL_TYPE
                  AND T.SYSTEM_FLAG <> 'Y';
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
