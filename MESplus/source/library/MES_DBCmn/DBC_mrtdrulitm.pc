/* Add Null Function */
void DBC_add_null_mrtdrulitm(struct MRTDRULITM_N_TAG *MRTDRULITM_N, struct MRTDRULITM_TAG *MRTDRULITM)
{
    /* memset by NULL */
    memset(MRTDRULITM_N, '\0', sizeof(struct MRTDRULITM_N_TAG));
    
    MEMCPY_AN(MRTDRULITM_N->FACTORY, MRTDRULITM->FACTORY, sizeof(MRTDRULITM->FACTORY));
    MEMCPY_AN(MRTDRULITM_N->RULE_ID, MRTDRULITM->RULE_ID, sizeof(MRTDRULITM->RULE_ID));
    MRTDRULITM_N->RULE_TYPE[0] = MRTDRULITM->RULE_TYPE;
    MRTDRULITM_N->PRIO_LEVEL = MRTDRULITM->PRIO_LEVEL;
    MEMCPY_AN(MRTDRULITM_N->PRIO_KEY, MRTDRULITM->PRIO_KEY, sizeof(MRTDRULITM->PRIO_KEY));
    MRTDRULITM_N->SORTING_TYPE[0] = MRTDRULITM->SORTING_TYPE;
    MRTDRULITM_N->CLASS_TYPE[0] = MRTDRULITM->CLASS_TYPE;
    MEMCPY_AN(MRTDRULITM_N->KEY_VALUE_1, MRTDRULITM->KEY_VALUE_1, sizeof(MRTDRULITM->KEY_VALUE_1));
    MEMCPY_AN(MRTDRULITM_N->KEY_VALUE_2, MRTDRULITM->KEY_VALUE_2, sizeof(MRTDRULITM->KEY_VALUE_2));
    MRTDRULITM_N->KEY_POINT = MRTDRULITM->KEY_POINT;
    MRTDRULITM_N->LOT_TYPE[0] = MRTDRULITM->LOT_TYPE;
    MRTDRULITM_N->UNSELECT_FLAG[0] = MRTDRULITM->UNSELECT_FLAG;

    MRTDRULITM_N->CAPABLE_FLAG[0] = MRTDRULITM->CAPABLE_FLAG;
    
    MEMCPY_AN(MRTDRULITM_N->CREATE_USER_ID, MRTDRULITM->CREATE_USER_ID, sizeof(MRTDRULITM->CREATE_USER_ID));
    MEMCPY_AN(MRTDRULITM_N->CREATE_TIME, MRTDRULITM->CREATE_TIME, sizeof(MRTDRULITM->CREATE_TIME));
    MEMCPY_AN(MRTDRULITM_N->UPDATE_USER_ID, MRTDRULITM->UPDATE_USER_ID, sizeof(MRTDRULITM->UPDATE_USER_ID));
    MEMCPY_AN(MRTDRULITM_N->UPDATE_TIME, MRTDRULITM->UPDATE_TIME, sizeof(MRTDRULITM->UPDATE_TIME));
	MEMCPY_AN(MRTDRULITM_N->RULE_ITEM_DESC, MRTDRULITM->RULE_ITEM_DESC, sizeof(MRTDRULITM->RULE_ITEM_DESC));
}


/* Del Null Function */
void DBC_del_null_mrtdrulitm(struct MRTDRULITM_N_TAG *MRTDRULITM_N, struct MRTDRULITM_TAG *MRTDRULITM)
{
    MEMCPY_DN(MRTDRULITM->FACTORY, MRTDRULITM_N->FACTORY, sizeof(MRTDRULITM->FACTORY));
    MEMCPY_DN(MRTDRULITM->RULE_ID, MRTDRULITM_N->RULE_ID, sizeof(MRTDRULITM->RULE_ID));
    MRTDRULITM->RULE_TYPE = MRTDRULITM_N->RULE_TYPE[0];
    MRTDRULITM->PRIO_LEVEL = MRTDRULITM_N->PRIO_LEVEL;
    MEMCPY_DN(MRTDRULITM->PRIO_KEY, MRTDRULITM_N->PRIO_KEY, sizeof(MRTDRULITM->PRIO_KEY));
    MRTDRULITM->SORTING_TYPE = MRTDRULITM_N->SORTING_TYPE[0];
    MRTDRULITM->CLASS_TYPE = MRTDRULITM_N->CLASS_TYPE[0];
    MEMCPY_DN(MRTDRULITM->KEY_VALUE_1, MRTDRULITM_N->KEY_VALUE_1, sizeof(MRTDRULITM->KEY_VALUE_1));
    MEMCPY_DN(MRTDRULITM->KEY_VALUE_2, MRTDRULITM_N->KEY_VALUE_2, sizeof(MRTDRULITM->KEY_VALUE_2));
    MRTDRULITM->KEY_POINT = MRTDRULITM_N->KEY_POINT;
    MRTDRULITM->LOT_TYPE = MRTDRULITM_N->LOT_TYPE[0];
    MRTDRULITM->UNSELECT_FLAG = MRTDRULITM_N->UNSELECT_FLAG[0];
    
    MRTDRULITM->CAPABLE_FLAG = MRTDRULITM_N->CAPABLE_FLAG[0];
    
    MEMCPY_DN(MRTDRULITM->CREATE_USER_ID, MRTDRULITM_N->CREATE_USER_ID, sizeof(MRTDRULITM->CREATE_USER_ID));
    MEMCPY_DN(MRTDRULITM->CREATE_TIME, MRTDRULITM_N->CREATE_TIME, sizeof(MRTDRULITM->CREATE_TIME));
    MEMCPY_DN(MRTDRULITM->UPDATE_USER_ID, MRTDRULITM_N->UPDATE_USER_ID, sizeof(MRTDRULITM->UPDATE_USER_ID));
    MEMCPY_DN(MRTDRULITM->UPDATE_TIME, MRTDRULITM_N->UPDATE_TIME, sizeof(MRTDRULITM->UPDATE_TIME));
	MEMCPY_DN(MRTDRULITM->RULE_ITEM_DESC, MRTDRULITM_N->RULE_ITEM_DESC, sizeof(MRTDRULITM->RULE_ITEM_DESC));
}


