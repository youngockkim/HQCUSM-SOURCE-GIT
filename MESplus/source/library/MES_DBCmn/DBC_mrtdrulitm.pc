/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrtdrulitm(int sel_type, struct MRTDRULITM_TAG *MRTDRULITM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRTDRULITM_N_TAG MRTDRULITM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrtdrulitm(&MRTDRULITM_N, MRTDRULITM);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRTDRULITM_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RULE_ID,
                    RULE_TYPE,
                    PRIO_LEVEL,
                    PRIO_KEY,
                    SORTING_TYPE,
                    CLASS_TYPE,
                    KEY_VALUE_1,
                    KEY_VALUE_2,
                    KEY_POINT,
                    LOT_TYPE,
                    UNSELECT_FLAG,
                    CAPABLE_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
					RULE_ITEM_DESC
                FROM MRTDRULITM
                WHERE FACTORY = :MRTDRULITM_N.FACTORY
                    AND RULE_ID = :MRTDRULITM_N.RULE_ID
                    AND RULE_TYPE = :MRTDRULITM_N.RULE_TYPE
                    AND (PRIO_LEVEL > :MRTDRULITM_N.PRIO_LEVEL
                    OR (PRIO_LEVEL = :MRTDRULITM_N.PRIO_LEVEL
                    AND KEY_POINT <= :MRTDRULITM_N.KEY_POINT))
                ORDER BY PRIO_LEVEL ASC,
                    KEY_POINT DESC;
            EXEC SQL OPEN DBC_MRTDRULITM_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MRTDRULITM_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    RULE_ID,
                    RULE_TYPE,
                    PRIO_LEVEL,
                    PRIO_KEY,
                    SORTING_TYPE,
                    CLASS_TYPE,
                    KEY_VALUE_1,
                    KEY_VALUE_2,
                    KEY_POINT,
                    LOT_TYPE,
                    UNSELECT_FLAG,
                    CAPABLE_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
					RULE_ITEM_DESC
                FROM MRTDRULITM
                WHERE FACTORY = :MRTDRULITM_N.FACTORY
                    AND RULE_ID = :MRTDRULITM_N.RULE_ID;
            EXEC SQL OPEN DBC_MRTDRULITM_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrtdrulitm", sel_type);
}


