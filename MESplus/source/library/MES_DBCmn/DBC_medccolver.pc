    MEMCPY_DN(MEDCCOLVER->RELEASE_USER_ID, MEDCCOLVER_N->RELEASE_USER_ID, sizeof(MEDCCOLVER->RELEASE_USER_ID));
    MEMCPY_DN(MEDCCOLVER->RELEASE_TIME, MEDCCOLVER_N->RELEASE_TIME, sizeof(MEDCCOLVER->RELEASE_TIME));
    MEMCPY_DN(MEDCCOLVER->CREATE_USER_ID, MEDCCOLVER_N->CREATE_USER_ID, sizeof(MEDCCOLVER->CREATE_USER_ID));
    MEMCPY_DN(MEDCCOLVER->CREATE_TIME, MEDCCOLVER_N->CREATE_TIME, sizeof(MEDCCOLVER->CREATE_TIME));
    MEMCPY_DN(MEDCCOLVER->UPDATE_USER_ID, MEDCCOLVER_N->UPDATE_USER_ID, sizeof(MEDCCOLVER->UPDATE_USER_ID));
    MEMCPY_DN(MEDCCOLVER->UPDATE_TIME, MEDCCOLVER_N->UPDATE_TIME, sizeof(MEDCCOLVER->UPDATE_TIME));
}



