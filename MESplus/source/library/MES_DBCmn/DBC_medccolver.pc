/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_medccolver(int sel_type, struct MEDCCOLVER_TAG *MEDCCOLVER)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MEDCCOLVER_N_TAG MEDCCOLVER_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_medccolver(&MEDCCOLVER_N, MEDCCOLVER);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MEDCCOLVER_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    APPLY_START_TIME,
                    APPLY_END_TIME,
                    APPROVAL_FLAG,
                    APPROVAL_USER_ID,
                    APPROVAL_TIME,
                    RELEASE_FLAG,
                    RELEASE_USER_ID,
                    RELEASE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MEDCCOLVER
                WHERE FACTORY = :MEDCCOLVER_N.FACTORY
                    AND COL_SET_ID = :MEDCCOLVER_N.COL_SET_ID 
                    AND COL_SET_VERSION >= :MEDCCOLVER_N.COL_SET_VERSION                    
                ORDER BY FACTORY, COL_SET_ID, COL_SET_VERSION ASC;
            EXEC SQL OPEN DBC_MEDCCOLVER_CUR_1;
            break;
     
        case 2:
            EXEC SQL DECLARE DBC_MEDCCOLVER_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    APPLY_START_TIME,
                    APPLY_END_TIME,
                    APPROVAL_FLAG,
                    APPROVAL_USER_ID,
                    APPROVAL_TIME,
                    RELEASE_FLAG,
                    RELEASE_USER_ID,
                    RELEASE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MEDCCOLVER
                WHERE FACTORY = :MEDCCOLVER_N.FACTORY
                    AND COL_SET_ID = :MEDCCOLVER_N.COL_SET_ID 
                    AND COL_SET_VERSION <= :MEDCCOLVER_N.COL_SET_VERSION                    
                ORDER BY COL_SET_VERSION DESC;
            EXEC SQL OPEN DBC_MEDCCOLVER_CUR_2;
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_medccolver", sel_type);
}


