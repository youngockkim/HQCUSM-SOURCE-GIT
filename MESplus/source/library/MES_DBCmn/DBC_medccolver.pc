/* Add Null Function */
void DBC_add_null_medccolver(struct MEDCCOLVER_N_TAG *MEDCCOLVER_N, struct MEDCCOLVER_TAG *MEDCCOLVER)
{
    /* memset by NULL */
    memset(MEDCCOLVER_N, '\0', sizeof(struct MEDCCOLVER_N_TAG));
    
    MEMCPY_AN(MEDCCOLVER_N->FACTORY, MEDCCOLVER->FACTORY, sizeof(MEDCCOLVER->FACTORY));
    MEMCPY_AN(MEDCCOLVER_N->COL_SET_ID, MEDCCOLVER->COL_SET_ID, sizeof(MEDCCOLVER->COL_SET_ID));
    MEDCCOLVER_N->COL_SET_VERSION = MEDCCOLVER->COL_SET_VERSION;
    MEMCPY_AN(MEDCCOLVER_N->APPLY_START_TIME, MEDCCOLVER->APPLY_START_TIME, sizeof(MEDCCOLVER->APPLY_START_TIME));
    MEMCPY_AN(MEDCCOLVER_N->APPLY_END_TIME, MEDCCOLVER->APPLY_END_TIME, sizeof(MEDCCOLVER->APPLY_END_TIME));
    MEDCCOLVER_N->APPROVAL_FLAG[0] = MEDCCOLVER->APPROVAL_FLAG;
    MEMCPY_AN(MEDCCOLVER_N->APPROVAL_USER_ID, MEDCCOLVER->APPROVAL_USER_ID, sizeof(MEDCCOLVER->APPROVAL_USER_ID));
    MEMCPY_AN(MEDCCOLVER_N->APPROVAL_TIME, MEDCCOLVER->APPROVAL_TIME, sizeof(MEDCCOLVER->APPROVAL_TIME));
    MEDCCOLVER_N->RELEASE_FLAG[0] = MEDCCOLVER->RELEASE_FLAG;
    MEMCPY_AN(MEDCCOLVER_N->RELEASE_USER_ID, MEDCCOLVER->RELEASE_USER_ID, sizeof(MEDCCOLVER->RELEASE_USER_ID));
    MEMCPY_AN(MEDCCOLVER_N->RELEASE_TIME, MEDCCOLVER->RELEASE_TIME, sizeof(MEDCCOLVER->RELEASE_TIME));
    MEMCPY_AN(MEDCCOLVER_N->CREATE_USER_ID, MEDCCOLVER->CREATE_USER_ID, sizeof(MEDCCOLVER->CREATE_USER_ID));
    MEMCPY_AN(MEDCCOLVER_N->CREATE_TIME, MEDCCOLVER->CREATE_TIME, sizeof(MEDCCOLVER->CREATE_TIME));
    MEMCPY_AN(MEDCCOLVER_N->UPDATE_USER_ID, MEDCCOLVER->UPDATE_USER_ID, sizeof(MEDCCOLVER->UPDATE_USER_ID));
    MEMCPY_AN(MEDCCOLVER_N->UPDATE_TIME, MEDCCOLVER->UPDATE_TIME, sizeof(MEDCCOLVER->UPDATE_TIME));
}


