                    RESV_FIELD_8, 
                    RESV_FIELD_9, 
                    RESV_FIELD_10, 
                    QA_PASS_COUNT, 
                    QA_SKIP_COUNT, 
                    QA_FAIL_COUNT, 
                    QA_TOTAL_COUNT, 
                    QA_TEST_COUNT
         ) 
        VALUES (
                    :MQCGMFOREL_N.FACTORY,
                    :MQCGMFOREL_N.MAT_ID,
                    :MQCGMFOREL_N.MAT_VER,
                    :MQCGMFOREL_N.FLOW,
                    :MQCGMFOREL_N.FLOW_SEQ,
                    :MQCGMFOREL_N.OPER,
                    :MQCGMFOREL_N.RES_ID,
                    :MQCGMFOREL_N.SUB_RES_ID,
                    :MQCGMFOREL_N.REL_TYPE,
                    :MQCGMFOREL_N.RULE_ID,
                    :MQCGMFOREL_N.RESV_FIELD_1,
                    :MQCGMFOREL_N.RESV_FIELD_2,
                    :MQCGMFOREL_N.RESV_FIELD_3,
                    :MQCGMFOREL_N.RESV_FIELD_4,
                    :MQCGMFOREL_N.RESV_FIELD_5,
                    :MQCGMFOREL_N.RESV_FIELD_6,
                    :MQCGMFOREL_N.RESV_FIELD_7,
                    :MQCGMFOREL_N.RESV_FIELD_8,
                    :MQCGMFOREL_N.RESV_FIELD_9,
                    :MQCGMFOREL_N.RESV_FIELD_10,
                    :MQCGMFOREL_N.QA_PASS_COUNT,
                    :MQCGMFOREL_N.QA_SKIP_COUNT,
                    :MQCGMFOREL_N.QA_FAIL_COUNT,
                    :MQCGMFOREL_N.QA_TOTAL_COUNT,
                    :MQCGMFOREL_N.QA_TEST_COUNT
         );
    DB_stop_query_timer("DBC_insert_mqcgmforel", 0);
}


/* SQL UPDATE Function */
void DBC_update_mqcgmforel(int sel_type, struct MQCGMFOREL_TAG *MQCGMFOREL)
{
    EXEC SQL BEGIN DECLARE SECTION;
    struct MQCGMFOREL_N_TAG MQCGMFOREL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mqcgmforel(&MQCGMFOREL_N, MQCGMFOREL);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MQCGMFOREL SET
                    RESV_FIELD_1 = :MQCGMFOREL_N.RESV_FIELD_1,
                    RESV_FIELD_2 = :MQCGMFOREL_N.RESV_FIELD_2,
                    RESV_FIELD_3 = :MQCGMFOREL_N.RESV_FIELD_3,
                    RESV_FIELD_4 = :MQCGMFOREL_N.RESV_FIELD_4,
                    RESV_FIELD_5 = :MQCGMFOREL_N.RESV_FIELD_5,
                    RESV_FIELD_6 = :MQCGMFOREL_N.RESV_FIELD_6,
                    RESV_FIELD_7 = :MQCGMFOREL_N.RESV_FIELD_7,
                    RESV_FIELD_8 = :MQCGMFOREL_N.RESV_FIELD_8,
                    RESV_FIELD_9 = :MQCGMFOREL_N.RESV_FIELD_9,
                    RESV_FIELD_10 = :MQCGMFOREL_N.RESV_FIELD_10,
                    QA_PASS_COUNT = :MQCGMFOREL_N.QA_PASS_COUNT,
                    QA_SKIP_COUNT = :MQCGMFOREL_N.QA_SKIP_COUNT,
                    QA_FAIL_COUNT = :MQCGMFOREL_N.QA_FAIL_COUNT,
                    QA_TOTAL_COUNT = :MQCGMFOREL_N.QA_TOTAL_COUNT,
                    QA_TEST_COUNT = :MQCGMFOREL_N.QA_TEST_COUNT
                WHERE FACTORY = :MQCGMFOREL_N.FACTORY
                    AND MAT_ID = :MQCGMFOREL_N.MAT_ID
                    AND MAT_VER = :MQCGMFOREL_N.MAT_VER
                    AND FLOW = :MQCGMFOREL_N.FLOW
                    AND FLOW_SEQ = :MQCGMFOREL_N.FLOW_SEQ
                    AND OPER = :MQCGMFOREL_N.OPER
                    AND RES_ID = :MQCGMFOREL_N.RES_ID
                    AND SUB_RES_ID = :MQCGMFOREL_N.SUB_RES_ID
                    AND REL_TYPE = :MQCGMFOREL_N.REL_TYPE
                    AND RULE_ID = :MQCGMFOREL_N.RULE_ID;
            break;

			case 2:
            EXEC SQL UPDATE MQCGMFOREL SET
                    QA_PASS_COUNT = :MQCGMFOREL_N.QA_PASS_COUNT,
                    QA_SKIP_COUNT = :MQCGMFOREL_N.QA_SKIP_COUNT,
                    QA_FAIL_COUNT = :MQCGMFOREL_N.QA_FAIL_COUNT,
                    QA_TOTAL_COUNT = :MQCGMFOREL_N.QA_TOTAL_COUNT,
					QA_TEST_COUNT = :MQCGMFOREL_N.QA_TEST_COUNT
                  WHERE FACTORY = :MQCGMFOREL_N.FACTORY
                    AND RULE_ID = :MQCGMFOREL_N.RULE_ID;
            break;
			

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mqcgmforel", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mqcgmforel(int sel_type, struct MQCGMFOREL_TAG *MQCGMFOREL)
{
    EXEC SQL BEGIN DECLARE SECTION;
    struct MQCGMFOREL_N_TAG MQCGMFOREL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mqcgmforel(&MQCGMFOREL_N, MQCGMFOREL);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MQCGMFOREL_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ,
                    OPER,
                    RES_ID,
                    SUB_RES_ID,
                    REL_TYPE,
                    RULE_ID,
                    RESV_FIELD_1,
                    RESV_FIELD_2,
                    RESV_FIELD_3,
                    RESV_FIELD_4,
                    RESV_FIELD_5,
                    RESV_FIELD_6,
                    RESV_FIELD_7,
                    RESV_FIELD_8,
                    RESV_FIELD_9,
                    RESV_FIELD_10,
                    QA_PASS_COUNT,
                    QA_SKIP_COUNT,
                    QA_FAIL_COUNT,
                    QA_TOTAL_COUNT,
                    QA_TEST_COUNT
                FROM MQCGMFOREL
                ORDER BY FACTORY ASC,
                    MAT_ID ASC,
                    MAT_VER ASC,
                    FLOW ASC,
                    FLOW_SEQ ASC,
                    OPER ASC,
                    RES_ID ASC,
                    SUB_RES_ID ASC,
                    REL_TYPE ASC,
                    RULE_ID ASC;
            EXEC SQL OPEN DBC_MQCGMFOREL_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MQCGMFOREL_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ,
                    OPER,
                    RES_ID,
                    SUB_RES_ID,
                    REL_TYPE,
                    RULE_ID,
                    RESV_FIELD_1,
                    RESV_FIELD_2,
                    RESV_FIELD_3,
                    RESV_FIELD_4,
                    RESV_FIELD_5,
                    RESV_FIELD_6,
                    RESV_FIELD_7,
                    RESV_FIELD_8,
                    RESV_FIELD_9,
                    RESV_FIELD_10,
                    QA_PASS_COUNT,
                    QA_SKIP_COUNT,
                    QA_FAIL_COUNT,
                    QA_TOTAL_COUNT,
                    QA_TEST_COUNT
                FROM MQCGMFOREL
                WHERE
					MAT_ID = :MQCGMFOREL_N.MAT_ID
                    AND MAT_VER = :MQCGMFOREL_N.MAT_VER
                    AND FLOW = :MQCGMFOREL_N.FLOW
                    AND FLOW_SEQ = :MQCGMFOREL_N.FLOW_SEQ
                    AND OPER = :MQCGMFOREL_N.OPER
                    AND RES_ID = :MQCGMFOREL_N.RES_ID
                    AND SUB_RES_ID = :MQCGMFOREL_N.SUB_RES_ID
                    AND REL_TYPE = :MQCGMFOREL_N.REL_TYPE
                    AND RULE_ID >= :MQCGMFOREL_N.RULE_ID
                ORDER BY FACTORY ASC,
                    MAT_ID ASC,
                    MAT_VER ASC,
                    FLOW ASC,
                    FLOW_SEQ ASC,
                    OPER ASC,
                    RES_ID ASC,
                    SUB_RES_ID ASC,
                    REL_TYPE ASC,
                    RULE_ID ASC;
            EXEC SQL OPEN DBC_MQCGMFOREL_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mqcgmforel", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mqcgmforel(int sel_type, struct MQCGMFOREL_TAG *MQCGMFOREL)
{
    EXEC SQL BEGIN DECLARE SECTION;
    struct MQCGMFOREL_N_TAG MQCGMFOREL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MQCGMFOREL_CUR_1 INTO
                :MQCGMFOREL_N.FACTORY,
                :MQCGMFOREL_N.MAT_ID,
                :MQCGMFOREL_N.MAT_VER,
                :MQCGMFOREL_N.FLOW,
                :MQCGMFOREL_N.FLOW_SEQ,
                :MQCGMFOREL_N.OPER,
                :MQCGMFOREL_N.RES_ID,
                :MQCGMFOREL_N.SUB_RES_ID,
                :MQCGMFOREL_N.REL_TYPE,
                :MQCGMFOREL_N.RULE_ID,
                :MQCGMFOREL_N.RESV_FIELD_1,
                :MQCGMFOREL_N.RESV_FIELD_2,
                :MQCGMFOREL_N.RESV_FIELD_3,
                :MQCGMFOREL_N.RESV_FIELD_4,
                :MQCGMFOREL_N.RESV_FIELD_5,
                :MQCGMFOREL_N.RESV_FIELD_6,
                :MQCGMFOREL_N.RESV_FIELD_7,
                :MQCGMFOREL_N.RESV_FIELD_8,
                :MQCGMFOREL_N.RESV_FIELD_9,
                :MQCGMFOREL_N.RESV_FIELD_10,
                :MQCGMFOREL_N.QA_PASS_COUNT,
                :MQCGMFOREL_N.QA_SKIP_COUNT,
                :MQCGMFOREL_N.QA_FAIL_COUNT,
                :MQCGMFOREL_N.QA_TOTAL_COUNT,
                :MQCGMFOREL_N.QA_TEST_COUNT;
            break;

        case 2:
            EXEC SQL FETCH DBC_MQCGMFOREL_CUR_2 INTO :MQCGMFOREL_N;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mqcgmforel(&MQCGMFOREL_N, MQCGMFOREL);
    }
    DB_stop_query_timer("DBC_fetch_mqcgmforel", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mqcgmforel(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MQCGMFOREL_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MQCGMFOREL_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mqcgmforel", sel_type);
}


/* Initialize Function */
void DBC_init_mqcgmforel(struct MQCGMFOREL_TAG *MQCGMFOREL)
{
    /* memset by Space */
    memset(MQCGMFOREL, ' ', sizeof(struct MQCGMFOREL_TAG));
    
    MQCGMFOREL->MAT_VER = 0;
    MQCGMFOREL->FLOW_SEQ = 0;
	MQCGMFOREL->QA_PASS_COUNT = 0;
    MQCGMFOREL->QA_SKIP_COUNT = 0;
    MQCGMFOREL->QA_FAIL_COUNT = 0;
    MQCGMFOREL->QA_TOTAL_COUNT = 0;
	MQCGMFOREL->QA_TEST_COUNT = 0;
}


/* Add Null Function */
void DBC_add_null_mqcgmforel(struct MQCGMFOREL_N_TAG *MQCGMFOREL_N, struct MQCGMFOREL_TAG *MQCGMFOREL)
{
    /* memset by NULL */
    memset(MQCGMFOREL_N, '\0', sizeof(struct MQCGMFOREL_N_TAG));
    
    MEMCPY_AN(MQCGMFOREL_N->FACTORY, MQCGMFOREL->FACTORY, sizeof(MQCGMFOREL->FACTORY));
    MEMCPY_AN(MQCGMFOREL_N->MAT_ID, MQCGMFOREL->MAT_ID, sizeof(MQCGMFOREL->MAT_ID));
    MQCGMFOREL_N->MAT_VER = MQCGMFOREL->MAT_VER;
    MEMCPY_AN(MQCGMFOREL_N->FLOW, MQCGMFOREL->FLOW, sizeof(MQCGMFOREL->FLOW));
    MQCGMFOREL_N->FLOW_SEQ = MQCGMFOREL->FLOW_SEQ;
    MEMCPY_AN(MQCGMFOREL_N->OPER, MQCGMFOREL->OPER, sizeof(MQCGMFOREL->OPER));
    MEMCPY_AN(MQCGMFOREL_N->RES_ID, MQCGMFOREL->RES_ID, sizeof(MQCGMFOREL->RES_ID));
    MEMCPY_AN(MQCGMFOREL_N->SUB_RES_ID, MQCGMFOREL->SUB_RES_ID, sizeof(MQCGMFOREL->SUB_RES_ID));
    MEMCPY_AN(MQCGMFOREL_N->REL_TYPE, MQCGMFOREL->REL_TYPE, sizeof(MQCGMFOREL->REL_TYPE));
    MEMCPY_AN(MQCGMFOREL_N->RULE_ID, MQCGMFOREL->RULE_ID, sizeof(MQCGMFOREL->RULE_ID));
    MEMCPY_AN(MQCGMFOREL_N->RESV_FIELD_1, MQCGMFOREL->RESV_FIELD_1, sizeof(MQCGMFOREL->RESV_FIELD_1));
    MEMCPY_AN(MQCGMFOREL_N->RESV_FIELD_2, MQCGMFOREL->RESV_FIELD_2, sizeof(MQCGMFOREL->RESV_FIELD_2));
    MEMCPY_AN(MQCGMFOREL_N->RESV_FIELD_3, MQCGMFOREL->RESV_FIELD_3, sizeof(MQCGMFOREL->RESV_FIELD_3));
    MEMCPY_AN(MQCGMFOREL_N->RESV_FIELD_4, MQCGMFOREL->RESV_FIELD_4, sizeof(MQCGMFOREL->RESV_FIELD_4));
    MEMCPY_AN(MQCGMFOREL_N->RESV_FIELD_5, MQCGMFOREL->RESV_FIELD_5, sizeof(MQCGMFOREL->RESV_FIELD_5));
    MEMCPY_AN(MQCGMFOREL_N->RESV_FIELD_6, MQCGMFOREL->RESV_FIELD_6, sizeof(MQCGMFOREL->RESV_FIELD_6));
    MEMCPY_AN(MQCGMFOREL_N->RESV_FIELD_7, MQCGMFOREL->RESV_FIELD_7, sizeof(MQCGMFOREL->RESV_FIELD_7));
    MEMCPY_AN(MQCGMFOREL_N->RESV_FIELD_8, MQCGMFOREL->RESV_FIELD_8, sizeof(MQCGMFOREL->RESV_FIELD_8));
    MEMCPY_AN(MQCGMFOREL_N->RESV_FIELD_9, MQCGMFOREL->RESV_FIELD_9, sizeof(MQCGMFOREL->RESV_FIELD_9));
    MEMCPY_AN(MQCGMFOREL_N->RESV_FIELD_10, MQCGMFOREL->RESV_FIELD_10, sizeof(MQCGMFOREL->RESV_FIELD_10));
	MQCGMFOREL_N->QA_PASS_COUNT = MQCGMFOREL->QA_PASS_COUNT;
    MQCGMFOREL_N->QA_SKIP_COUNT = MQCGMFOREL->QA_SKIP_COUNT;
    MQCGMFOREL_N->QA_FAIL_COUNT = MQCGMFOREL->QA_FAIL_COUNT;
    MQCGMFOREL_N->QA_TOTAL_COUNT = MQCGMFOREL->QA_TOTAL_COUNT;
	MQCGMFOREL_N->QA_TEST_COUNT = MQCGMFOREL->QA_TEST_COUNT;
}


/* Del Null Function */
void DBC_del_null_mqcgmforel(struct MQCGMFOREL_N_TAG *MQCGMFOREL_N, struct MQCGMFOREL_TAG *MQCGMFOREL)
{
    MEMCPY_DN(MQCGMFOREL->FACTORY, MQCGMFOREL_N->FACTORY, sizeof(MQCGMFOREL->FACTORY));
    MEMCPY_DN(MQCGMFOREL->MAT_ID, MQCGMFOREL_N->MAT_ID, sizeof(MQCGMFOREL->MAT_ID));
    MQCGMFOREL->MAT_VER = MQCGMFOREL_N->MAT_VER;
    MEMCPY_DN(MQCGMFOREL->FLOW, MQCGMFOREL_N->FLOW, sizeof(MQCGMFOREL->FLOW));
    MQCGMFOREL->FLOW_SEQ = MQCGMFOREL_N->FLOW_SEQ;
