    MEMCPY_DN(MQCGMFOREL->RESV_FIELD_3, MQCGMFOREL_N->RESV_FIELD_3, sizeof(MQCGMFOREL->RESV_FIELD_3));
    MEMCPY_DN(MQCGMFOREL->RESV_FIELD_4, MQCGMFOREL_N->RESV_FIELD_4, sizeof(MQCGMFOREL->RESV_FIELD_4));
    MEMCPY_DN(MQCGMFOREL->RESV_FIELD_5, MQCGMFOREL_N->RESV_FIELD_5, sizeof(MQCGMFOREL->RESV_FIELD_5));
    MEMCPY_DN(MQCGMFOREL->RESV_FIELD_6, MQCGMFOREL_N->RESV_FIELD_6, sizeof(MQCGMFOREL->RESV_FIELD_6));
    MEMCPY_DN(MQCGMFOREL->RESV_FIELD_7, MQCGMFOREL_N->RESV_FIELD_7, sizeof(MQCGMFOREL->RESV_FIELD_7));
    MEMCPY_DN(MQCGMFOREL->RESV_FIELD_8, MQCGMFOREL_N->RESV_FIELD_8, sizeof(MQCGMFOREL->RESV_FIELD_8));
    MEMCPY_DN(MQCGMFOREL->RESV_FIELD_9, MQCGMFOREL_N->RESV_FIELD_9, sizeof(MQCGMFOREL->RESV_FIELD_9));
    MEMCPY_DN(MQCGMFOREL->RESV_FIELD_10, MQCGMFOREL_N->RESV_FIELD_10, sizeof(MQCGMFOREL->RESV_FIELD_10));
    MQCGMFOREL->QA_PASS_COUNT = MQCGMFOREL_N->QA_PASS_COUNT;
    MQCGMFOREL->QA_SKIP_COUNT = MQCGMFOREL_N->QA_SKIP_COUNT;
    MQCGMFOREL->QA_FAIL_COUNT = MQCGMFOREL_N->QA_FAIL_COUNT;
    MQCGMFOREL->QA_TOTAL_COUNT = MQCGMFOREL_N->QA_TOTAL_COUNT;
	MQCGMFOREL->QA_TEST_COUNT = MQCGMFOREL_N->QA_TEST_COUNT;
