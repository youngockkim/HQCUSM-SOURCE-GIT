    MEMCPY_DN(MQCGMFOREL->RES_ID, MQCGMFOREL_N->RES_ID, sizeof(MQCGMFOREL->RES_ID));
    MEMCPY_DN(MQCGMFOREL->SUB_RES_ID, MQCGMFOREL_N->SUB_RES_ID, sizeof(MQCGMFOREL->SUB_RES_ID));
