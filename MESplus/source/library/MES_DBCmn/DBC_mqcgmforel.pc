    struct MQCGMFOREL_N_TAG MQCGMFOREL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mqcgmforel(&MQCGMFOREL_N, MQCGMFOREL);
    DB_error_code = 0;

    EXEC SQL INSERT INTO MQCGMFOREL( 
                    FACTORY, 
                    MAT_ID, 
                    MAT_VER, 
                    FLOW, 
                    FLOW_SEQ, 
                    OPER, 
                    RES_ID, 
                    SUB_RES_ID, 
