    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPRSHLOT_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
