                    TRANSIT_OPER,
                    CRR_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPRSHLOT
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MWIPRSHLOT_CUR_1;
