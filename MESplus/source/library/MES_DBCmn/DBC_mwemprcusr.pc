/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwemprcusr(int sel_type, struct MWEMPRCUSR_TAG *MWEMPRCUSR)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWEMPRCUSR_N_TAG MWEMPRCUSR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwemprcusr(&MWEMPRCUSR_N, MWEMPRCUSR);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWEMPRCUSR_CUR_1 CURSOR FOR
                SELECT 
                    CREATE_TIME,
                    CREATE_USER_ID,
                    UPDATE_TIME,
                    UPDATE_USER_ID,
                    FACTORY,
                    WORK_PROC_TYPE,
                    PROC_ID,
                    STEP_ID,
                    USER_TYPE,
                    USER_ID,
                    ASSIGN_OPTION
                FROM MWEMPRCUSR
                WHERE FACTORY = :MWEMPRCUSR_N.FACTORY
                    AND WORK_PROC_TYPE = :MWEMPRCUSR_N.WORK_PROC_TYPE
                    AND PROC_ID = :MWEMPRCUSR_N.PROC_ID
                    AND STEP_ID = :MWEMPRCUSR_N.STEP_ID
                    AND ((USER_TYPE = :MWEMPRCUSR_N.USER_TYPE AND USER_ID >= :MWEMPRCUSR_N.USER_ID) OR USER_TYPE > :MWEMPRCUSR_N.USER_TYPE)
                ORDER BY USER_TYPE ASC, USER_ID ASC;
            EXEC SQL OPEN DBC_MWEMPRCUSR_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWEMPRCUSR_CUR_2 CURSOR FOR
                SELECT RECV.USER_ID
                FROM (
                        SELECT USER_ID
                        FROM MWEMPRCUSR
                        WHERE FACTORY = :MWEMPRCUSR_N.FACTORY
                            AND WORK_PROC_TYPE = :MWEMPRCUSR_N.WORK_PROC_TYPE
                            AND PROC_ID = :MWEMPRCUSR_N.PROC_ID
                            AND STEP_ID = :MWEMPRCUSR_N.STEP_ID
                            AND USER_TYPE = 'U'
                            AND ASSIGN_OPTION LIKE '_Y%'
                    UNION
                        SELECT UD.USER_ID
                        FROM MWEMPRCUSR PU, MSECUSRDEF UD
                        WHERE PU.FACTORY = :MWEMPRCUSR_N.FACTORY
                            AND PU.WORK_PROC_TYPE = :MWEMPRCUSR_N.WORK_PROC_TYPE
                            AND PU.PROC_ID = :MWEMPRCUSR_N.PROC_ID
                            AND PU.STEP_ID = :MWEMPRCUSR_N.STEP_ID
                            AND PU.USER_TYPE = 'S'
                            AND PU.ASSIGN_OPTION LIKE '_Y%'
                            AND PU.FACTORY = UD.FACTORY
                            AND PU.USER_ID = UD.SEC_GRP_ID
                    UNION
                        SELECT PR.USER_ID
                        FROM MWEMPRCUSR PU, MSECPRVUSR PR
                        WHERE PU.FACTORY = :MWEMPRCUSR_N.FACTORY
                            AND PU.WORK_PROC_TYPE = :MWEMPRCUSR_N.WORK_PROC_TYPE
                            AND PU.PROC_ID = :MWEMPRCUSR_N.PROC_ID
                            AND PU.STEP_ID = :MWEMPRCUSR_N.STEP_ID
                            AND PU.USER_TYPE = 'P'
                            AND PU.ASSIGN_OPTION LIKE '_Y%'
                            AND PU.FACTORY = PR.FACTORY
                            AND PU.USER_ID = PR.PRV_GRP_ID
                    ) RECV
                ORDER BY RECV.USER_ID ASC;
            EXEC SQL OPEN DBC_MWEMPRCUSR_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MWEMPRCUSR_CUR_3 CURSOR FOR
                SELECT 
                    CREATE_TIME,
                    CREATE_USER_ID,
                    UPDATE_TIME,
                    UPDATE_USER_ID,
                    FACTORY,
                    WORK_PROC_TYPE,
                    PROC_ID,
                    STEP_ID,
                    USER_TYPE,
                    USER_ID,
                    ASSIGN_OPTION
                FROM MWEMPRCUSR
                WHERE FACTORY = :MWEMPRCUSR_N.FACTORY
                    AND WORK_PROC_TYPE = :MWEMPRCUSR_N.WORK_PROC_TYPE
                    AND PROC_ID = :MWEMPRCUSR_N.PROC_ID
                ORDER BY STEP_ID ASC, USER_TYPE ASC, USER_ID ASC;
            EXEC SQL OPEN DBC_MWEMPRCUSR_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mwemprcusr", sel_type);
}


