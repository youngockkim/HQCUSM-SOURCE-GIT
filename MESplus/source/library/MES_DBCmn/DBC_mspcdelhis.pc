        struct MSPCDELHIS_N_TAG MSPCDELHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mspcdelhis(&MSPCDELHIS_N, MSPCDELHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSPCDELHIS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    UNIT_SEQ,
                    TRAN_TIME,
                    TRAN_FLAG,
                    TRAN_COMMENT,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                FROM MSPCDELHIS
                ORDER BY FACTORY ASC,
                    CHART_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MSPCDELHIS_CUR_1;
            break;
      
        case 2:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N); 
            EXEC SQL DECLARE DBC_MSPCDELHIS_CUR_2 CURSOR FOR
                SELECT
                           A.FACTORY,
                           A.CHART_ID,
                           A.HIST_SEQ,
                           A.UNIT_SEQ,
                           A.TRAN_TIME,
                           A.TRAN_FLAG,
                           A.TRAN_COMMENT,
                           A.CREATE_USER_ID,
                           A.CREATE_TIME,
                           A.RESV_FIELD1,
                           A.RESV_FIELD2,
                           A.RESV_FIELD3,
                           A.RESV_FIELD4,
                           A.RESV_FIELD5
                FROM MSPCDELHIS A, MSPCCHTDEF B
                WHERE A.FACTORY = :MSPCDELHIS_N.FACTORY
                    AND A.FACTORY = B.FACTORY
                    AND A.CHART_ID = B.CHART_ID
                    AND B.DELETE_FLAG <> 'Y'
                    AND ((A.CHART_ID > :MSPCDELHIS_N.CHART_ID) OR (A.CHART_ID = :MSPCDELHIS_N.CHART_ID AND A.HIST_SEQ < :MSPCDELHIS_N.HIST_SEQ)
                        OR (A.CHART_ID = :MSPCDELHIS_N.CHART_ID AND A.HIST_SEQ = :MSPCDELHIS_N.HIST_SEQ AND A.UNIT_SEQ <= :MSPCDELHIS_N.UNIT_SEQ))
                    AND A.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME 
                    AND A.TRAN_TIME < :DBC_Q_COND_N.TO_TIME
                    AND A.TRAN_FLAG <> : MSPCDELHIS_N.TRAN_FLAG
                ORDER BY A.CHART_ID ASC, A.CHART_ID ASC, A.HIST_SEQ DESC, A.UNIT_SEQ DESC;
            EXEC SQL OPEN DBC_MSPCDELHIS_CUR_2;                 
            break;
            
            
        case 3:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N); 
            EXEC SQL DECLARE DBC_MSPCDELHIS_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    UNIT_SEQ,
                    TRAN_TIME,
                    TRAN_FLAG,
                    TRAN_COMMENT,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                FROM MSPCDELHIS
                WHERE FACTORY = :MSPCDELHIS_N.FACTORY
                    AND CHART_ID = :MSPCDELHIS_N.CHART_ID
                    AND ((HIST_SEQ < :MSPCDELHIS_N.HIST_SEQ) OR (HIST_SEQ = :MSPCDELHIS_N.HIST_SEQ AND UNIT_SEQ <= :MSPCDELHIS_N.UNIT_SEQ))
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME 
                    AND TRAN_TIME < :DBC_Q_COND_N.TO_TIME
                    AND TRAN_FLAG <> : MSPCDELHIS_N.TRAN_FLAG
                ORDER BY HIST_SEQ DESC, UNIT_SEQ DESC;
            EXEC SQL OPEN DBC_MSPCDELHIS_CUR_3;                 
            break;
          
          case 4:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N); 
            EXEC SQL DECLARE DBC_MSPCDELHIS_CUR_4 CURSOR FOR
                SELECT
                           A.FACTORY,
                           A.CHART_ID,
                           A.HIST_SEQ,
                           A.UNIT_SEQ,
                           A.TRAN_TIME,
                           A.TRAN_FLAG,
                           A.TRAN_COMMENT,
                           A.CREATE_USER_ID,
                           A.CREATE_TIME,
                           A.RESV_FIELD1,
                           A.RESV_FIELD2,
                           A.RESV_FIELD3,
                           A.RESV_FIELD4,
                           A.RESV_FIELD5
                FROM MSPCDELHIS A, MSPCCHTDEF B
                WHERE A.FACTORY = :MSPCDELHIS_N.FACTORY
                    AND A.FACTORY = B.FACTORY
                    AND A.CHART_ID = B.CHART_ID
                    AND A.CHART_ID IN (SELECT CHART_ID FROM MSPCCHTSET WHERE FACTORY = :MSPCDELHIS_N.FACTORY AND CHART_SET_ID = :DBC_Q_COND_N.KEY_1 AND CHART_ID >= :MSPCDELHIS_N.CHART_ID)
                    AND B.DELETE_FLAG <> 'Y'
                    AND ((A.CHART_ID > :MSPCDELHIS_N.CHART_ID) OR (A.CHART_ID = :MSPCDELHIS_N.CHART_ID AND A.HIST_SEQ < :MSPCDELHIS_N.HIST_SEQ)
                        OR (A.CHART_ID = :MSPCDELHIS_N.CHART_ID AND A.HIST_SEQ = :MSPCDELHIS_N.HIST_SEQ AND A.UNIT_SEQ <= :MSPCDELHIS_N.UNIT_SEQ))
                    AND A.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME 
                    AND A.TRAN_TIME < :DBC_Q_COND_N.TO_TIME
                    AND A.TRAN_FLAG <> : MSPCDELHIS_N.TRAN_FLAG
                ORDER BY A.CHART_ID ASC, A.CHART_ID ASC, A.HIST_SEQ DESC, A.UNIT_SEQ DESC;
            EXEC SQL OPEN DBC_MSPCDELHIS_CUR_4;                 
            break;
              

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mspcdelhis", sel_type);
}


