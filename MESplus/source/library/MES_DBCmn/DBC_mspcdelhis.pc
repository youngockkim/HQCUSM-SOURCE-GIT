    memset(MSPCDELHIS_N, '\0', sizeof(struct MSPCDELHIS_N_TAG));
    
    MEMCPY_AN(MSPCDELHIS_N->FACTORY, MSPCDELHIS->FACTORY, sizeof(MSPCDELHIS->FACTORY));
    MEMCPY_AN(MSPCDELHIS_N->CHART_ID, MSPCDELHIS->CHART_ID, sizeof(MSPCDELHIS->CHART_ID));
    MSPCDELHIS_N->HIST_SEQ = MSPCDELHIS->HIST_SEQ;
    MSPCDELHIS_N->UNIT_SEQ = MSPCDELHIS->UNIT_SEQ;
    MEMCPY_AN(MSPCDELHIS_N->TRAN_TIME, MSPCDELHIS->TRAN_TIME, sizeof(MSPCDELHIS->TRAN_TIME));
    MSPCDELHIS_N->TRAN_FLAG[0] = MSPCDELHIS->TRAN_FLAG;
    MEMCPY_AN(MSPCDELHIS_N->TRAN_COMMENT, MSPCDELHIS->TRAN_COMMENT, sizeof(MSPCDELHIS->TRAN_COMMENT));
    MEMCPY_AN(MSPCDELHIS_N->CREATE_USER_ID, MSPCDELHIS->CREATE_USER_ID, sizeof(MSPCDELHIS->CREATE_USER_ID));
    MEMCPY_AN(MSPCDELHIS_N->CREATE_TIME, MSPCDELHIS->CREATE_TIME, sizeof(MSPCDELHIS->CREATE_TIME));
    MEMCPY_AN(MSPCDELHIS_N->RESV_FIELD1, MSPCDELHIS->RESV_FIELD1, sizeof(MSPCDELHIS->RESV_FIELD1));
    MEMCPY_AN(MSPCDELHIS_N->RESV_FIELD2, MSPCDELHIS->RESV_FIELD2, sizeof(MSPCDELHIS->RESV_FIELD2));
    MEMCPY_AN(MSPCDELHIS_N->RESV_FIELD3, MSPCDELHIS->RESV_FIELD3, sizeof(MSPCDELHIS->RESV_FIELD3));
    MEMCPY_AN(MSPCDELHIS_N->RESV_FIELD4, MSPCDELHIS->RESV_FIELD4, sizeof(MSPCDELHIS->RESV_FIELD4));
    MEMCPY_AN(MSPCDELHIS_N->RESV_FIELD5, MSPCDELHIS->RESV_FIELD5, sizeof(MSPCDELHIS->RESV_FIELD5));
}


/* Del Null Function */
void DBC_del_null_mspcdelhis(struct MSPCDELHIS_N_TAG *MSPCDELHIS_N, struct MSPCDELHIS_TAG *MSPCDELHIS)
{
    MEMCPY_DN(MSPCDELHIS->FACTORY, MSPCDELHIS_N->FACTORY, sizeof(MSPCDELHIS->FACTORY));
    MEMCPY_DN(MSPCDELHIS->CHART_ID, MSPCDELHIS_N->CHART_ID, sizeof(MSPCDELHIS->CHART_ID));
    MSPCDELHIS->HIST_SEQ = MSPCDELHIS_N->HIST_SEQ;
    MSPCDELHIS->UNIT_SEQ = MSPCDELHIS_N->UNIT_SEQ;
    MEMCPY_DN(MSPCDELHIS->TRAN_TIME, MSPCDELHIS_N->TRAN_TIME, sizeof(MSPCDELHIS->TRAN_TIME));
    MSPCDELHIS->TRAN_FLAG = MSPCDELHIS_N->TRAN_FLAG[0];
    MEMCPY_DN(MSPCDELHIS->TRAN_COMMENT, MSPCDELHIS_N->TRAN_COMMENT, sizeof(MSPCDELHIS->TRAN_COMMENT));
    MEMCPY_DN(MSPCDELHIS->CREATE_USER_ID, MSPCDELHIS_N->CREATE_USER_ID, sizeof(MSPCDELHIS->CREATE_USER_ID));
    MEMCPY_DN(MSPCDELHIS->CREATE_TIME, MSPCDELHIS_N->CREATE_TIME, sizeof(MSPCDELHIS->CREATE_TIME));
    MEMCPY_DN(MSPCDELHIS->RESV_FIELD1, MSPCDELHIS_N->RESV_FIELD1, sizeof(MSPCDELHIS->RESV_FIELD1));
    MEMCPY_DN(MSPCDELHIS->RESV_FIELD2, MSPCDELHIS_N->RESV_FIELD2, sizeof(MSPCDELHIS->RESV_FIELD2));
    MEMCPY_DN(MSPCDELHIS->RESV_FIELD3, MSPCDELHIS_N->RESV_FIELD3, sizeof(MSPCDELHIS->RESV_FIELD3));
    MEMCPY_DN(MSPCDELHIS->RESV_FIELD4, MSPCDELHIS_N->RESV_FIELD4, sizeof(MSPCDELHIS->RESV_FIELD4));
    MEMCPY_DN(MSPCDELHIS->RESV_FIELD5, MSPCDELHIS_N->RESV_FIELD5, sizeof(MSPCDELHIS->RESV_FIELD5));
}


