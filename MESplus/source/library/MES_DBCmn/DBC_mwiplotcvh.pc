    MEMCPY_DN(MWIPLOTCVH->RES_ID, MWIPLOTCVH_N->RES_ID, sizeof(MWIPLOTCVH->RES_ID));
    MEMCPY_DN(MWIPLOTCVH->CAUSE_FLOW, MWIPLOTCVH_N->CAUSE_FLOW, sizeof(MWIPLOTCVH->CAUSE_FLOW));
    MEMCPY_DN(MWIPLOTCVH->CAUSE_OPER, MWIPLOTCVH_N->CAUSE_OPER, sizeof(MWIPLOTCVH->CAUSE_OPER));
    MEMCPY_DN(MWIPLOTCVH->CAUSE_RES_ID, MWIPLOTCVH_N->CAUSE_RES_ID, sizeof(MWIPLOTCVH->CAUSE_RES_ID));
    MWIPLOTCVH->NEW_QTY = MWIPLOTCVH_N->NEW_QTY;
    MWIPLOTCVH->OLD_QTY = MWIPLOTCVH_N->OLD_QTY;
    MWIPLOTCVH->TOTAL_CV_QTY = MWIPLOTCVH_N->TOTAL_CV_QTY;
    MEMCPY_DN(MWIPLOTCVH->CV_COMMENT_1, MWIPLOTCVH_N->CV_COMMENT_1, sizeof(MWIPLOTCVH->CV_COMMENT_1));
    MEMCPY_DN(MWIPLOTCVH->CV_COMMENT_2, MWIPLOTCVH_N->CV_COMMENT_2, sizeof(MWIPLOTCVH->CV_COMMENT_2));
    MEMCPY_DN(MWIPLOTCVH->CV_COMMENT_3, MWIPLOTCVH_N->CV_COMMENT_3, sizeof(MWIPLOTCVH->CV_COMMENT_3));
}


