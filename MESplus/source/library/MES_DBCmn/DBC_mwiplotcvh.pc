/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwiplotcvh(int sel_type, struct MWIPLOTCVH_TAG *MWIPLOTCVH)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTCVH_N_TAG MWIPLOTCVH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplotcvh(&MWIPLOTCVH_N, MWIPLOTCVH);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPLOTCVH_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    QTY_FLAG,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_ID,
                    CAUSE_FLOW,
                    CAUSE_OPER,
                    CAUSE_RES_ID,
                    NEW_QTY,
                    OLD_QTY,
                    TOTAL_CV_QTY,
                    CV_COMMENT_1,
                    CV_COMMENT_2,
                    CV_COMMENT_3
                FROM MWIPLOTCVH
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC,
                    QTY_FLAG ASC;
            EXEC SQL OPEN DBC_MWIPLOTCVH_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwiplotcvh", sel_type);
}


