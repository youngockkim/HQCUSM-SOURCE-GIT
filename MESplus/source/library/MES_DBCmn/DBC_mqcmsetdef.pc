/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mqcmsetdef(int sel_type, struct MQCMSETDEF_TAG *MQCMSETDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MQCMSETDEF_N_TAG MQCMSETDEF_N;
        char   sql[5120];
        char   ts1[100];
        char   ts2[100];
        char   ts3[100];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mqcmsetdef(&MQCMSETDEF_N, MQCMSETDEF);
    DB_error_code = 0;
    
    memset( ts1, 0x00, sizeof(ts1));
    memset( ts2, 0x00, sizeof(ts2));
    memset( ts3, 0x00, sizeof(ts3));

    switch(sel_type)
    {
        case 1:            
            if(strcmp(MQCMSETDEF_N.INSP_SET_DESC, " ") == 0)
                MQCMSETDEF_N.INSP_SET_DESC[0] = '%';
            else
                strcat(MQCMSETDEF_N.INSP_SET_DESC, "%");
        
            memset( sql, 0x00, sizeof(sql));
            sprintf(sql,               "SELECT INSP_SET_ID, INSP_SET_DESC FROM MQCMSETDEF WHERE ");

            make_valid_quote(ts1, MQCMSETDEF_N.FACTORY);
            make_valid_quote(ts2, MQCMSETDEF_N.INSP_SET_ID);
            make_valid_quote(ts3, MQCMSETDEF_N.INSP_SET_DESC);

            sprintf(sql + strlen(sql), "FACTORY = '%s' AND INSP_SET_ID >= '%s' AND INSP_SET_ID LIKE '%s' ",
                ts1, ts2, ts3);
                
            if(ISSPACE(MQCMSETDEF->INSP_TYPE, sizeof(MQCMSETDEF->INSP_TYPE)) == DB_FALSE)
            {
                memset( ts1, 0x00, sizeof(ts1));
                make_valid_quote(ts1, MQCMSETDEF_N.INSP_TYPE);
                sprintf(sql + strlen(sql), "AND INSP_TYPE = '%s'  ", ts1);
            }
            if(MQCMSETDEF->ACTIVE_FLAG == 'Y' ||
                MQCMSETDEF->ACTIVE_FLAG == 'N')
            {
                sprintf(sql + strlen(sql), "AND ACTIVE_FLAG = '%s' ", MQCMSETDEF_N.ACTIVE_FLAG);
            }
            sprintf(sql + strlen(sql), "ORDER BY INSP_SET_ID ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MQCMSETDEF_CUR_1 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MQCMSETDEF_CUR_1;    
             
            /*LOG_head("DB");
            LOG_add("len", 1, strlen(sql));
            LOG_add("sql", 4, strlen(sql), sql);
            COM_log_write('I', 'S' , 'S');*/
                        
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mqcmsetdef", sel_type);
}


