    memset(MQCMSETDEF_N, '\0', sizeof(struct MQCMSETDEF_N_TAG));
    
    MEMCPY_AN(MQCMSETDEF_N->FACTORY, MQCMSETDEF->FACTORY, sizeof(MQCMSETDEF->FACTORY));
    MEMCPY_AN(MQCMSETDEF_N->INSP_SET_ID, MQCMSETDEF->INSP_SET_ID, sizeof(MQCMSETDEF->INSP_SET_ID));
    MEMCPY_AN(MQCMSETDEF_N->INSP_SET_DESC, MQCMSETDEF->INSP_SET_DESC, sizeof(MQCMSETDEF->INSP_SET_DESC));
    MQCMSETDEF_N->ACTIVE_FLAG[0] = MQCMSETDEF->ACTIVE_FLAG;
    MEMCPY_AN(MQCMSETDEF_N->INSP_TYPE, MQCMSETDEF->INSP_TYPE, sizeof(MQCMSETDEF->INSP_TYPE));
    MEMCPY_AN(MQCMSETDEF_N->INSP_METHOD, MQCMSETDEF->INSP_METHOD, sizeof(MQCMSETDEF->INSP_METHOD));
    MEMCPY_AN(MQCMSETDEF_N->SAMPLE_PROC, MQCMSETDEF->SAMPLE_PROC, sizeof(MQCMSETDEF->SAMPLE_PROC));
    MQCMSETDEF_N->ITEM_CHECK_FLAG[0] = MQCMSETDEF->ITEM_CHECK_FLAG;
    MQCMSETDEF_N->MAX_QTY = MQCMSETDEF->MAX_QTY;
