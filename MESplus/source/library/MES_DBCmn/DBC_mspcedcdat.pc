                           A.PROC_RES_ID,
                           A.EVENT,
                           A.CHAR_ID,
                           A.UNIT_ID,
                           A.UNIT_SEQ,
                           A.VALUE_TYPE,
                           A.VALUE_SEQ,
                           A.VALUE_COUNT,
                           A.VALUE_1,
                           A.VALUE_2,
                           A.VALUE_3,
                           A.VALUE_4,
                           A.VALUE_5,
                           A.VALUE_6,
                           A.VALUE_7,
                           A.VALUE_8,
                           A.VALUE_9,
                           A.VALUE_10,
                           A.VALUE_11,
                           A.VALUE_12,
                           A.VALUE_13,
                           A.VALUE_14,
                           A.VALUE_15,
                           A.VALUE_16,
                           A.VALUE_17,
                           A.VALUE_18,
                           A.VALUE_19,
                           A.VALUE_20,
                           A.VALUE_21,
                           A.VALUE_22,
                           A.VALUE_23,
                           A.VALUE_24,
                           A.VALUE_25,
                           A.NOMINAL,
                           A.PROCESS_SIGMA,
                           A.EDC_COMMENT,
                           A.EDC_HIST_SEQ,
                           A.EDC_CHAR_SEQ,
                           A.EDC_UNIT_SEQ,
                           A.CREATE_USER_ID,
                           A.CREATE_TIME,
                           A.UPDATE_USER_ID,
                           A.UPDATE_TIME,
                           A.RESV_FIELD1,
                           A.RESV_FIELD2,
                           A.RESV_FIELD3,
                           A.RESV_FIELD4,
                           A.RESV_FIELD5
                FROM MSPCEDCDAT A, MSPCCALDAT B
                WHERE A.FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND A.FACTORY = B.FACTORY
                    AND A.CHART_ID = B.CHART_ID
                    AND A.HIST_SEQ = B.HIST_SEQ
                    AND A.UNIT_SEQ = B.UNIT_SEQ
                    AND B.EXCLUDE_FLAG <> 'Y'
                    AND A.CHART_ID = :MSPCEDCDAT_N.CHART_ID
                    AND (A.HIST_SEQ > :MSPCEDCDAT_N.HIST_SEQ
                    OR (A.HIST_SEQ = :MSPCEDCDAT_N.HIST_SEQ
                    AND A.UNIT_SEQ > :MSPCEDCDAT_N.UNIT_SEQ)
                    OR (A.HIST_SEQ = :MSPCEDCDAT_N.HIST_SEQ AND A.UNIT_SEQ = :MSPCEDCDAT_N.UNIT_SEQ AND A.VALUE_SEQ >= :MSPCEDCDAT_N.VALUE_SEQ))
                    AND A.TRAN_TIME <= :DBC_Q_COND_N.TO_TIME AND A.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                    ORDER BY A.HIST_SEQ ASC, A.UNIT_SEQ ASC, A.VALUE_SEQ ASC;
            EXEC SQL OPEN DBC_MSPCEDCDAT_CUR_4;
            break;
     
        case 5:
            EXEC SQL DECLARE DBC_MSPCEDCDAT_CUR_5 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    UNIT_SEQ,
                    VALUE_SEQ 
                FROM MSPCEDCDAT
                WHERE FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND CHART_ID = :MSPCEDCDAT_N.CHART_ID
                    AND HIST_SEQ = :MSPCEDCDAT_N.HIST_SEQ
                    AND UNIT_SEQ = :MSPCEDCDAT_N.UNIT_SEQ
                ORDER BY VALUE_SEQ ASC;
            EXEC SQL OPEN DBC_MSPCEDCDAT_CUR_5;
            break;
            
        case 6:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N); 
            EXEC SQL DECLARE DBC_MSPCEDCDAT_CUR_6 CURSOR FOR
                SELECT
                           A.FACTORY,
                           A.CHART_ID,
                           A.HIST_SEQ,
                           A.TRAN_TIME,
                           A.LOT_RES_FLAG,
                           A.LOT_ID,
                           A.MAT_ID,
                           A.MAT_VER,
                           A.FLOW,
                           A.FLOW_SEQ_NUM,
