                    NOMINAL,
                    PROCESS_SIGMA,
                    EDC_COMMENT,
                    EDC_HIST_SEQ,
                    EDC_CHAR_SEQ,
                    EDC_UNIT_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                FROM MSPCEDCDAT
                WHERE FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND CHART_ID = :MSPCEDCDAT_N.CHART_ID
                    AND HIST_SEQ = :MSPCEDCDAT_N.HIST_SEQ
                ORDER BY UNIT_SEQ ASC,
                    VALUE_SEQ ASC;
            EXEC SQL OPEN DBC_MSPCEDCDAT_CUR_2;
            break;
        case 3:
            EXEC SQL DECLARE DBC_MSPCEDCDAT_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    LOT_ID,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    PROC_OPER,
                    RES_ID,
                    PROC_RES_ID,
                    EVENT,
                    CHAR_ID,
                    UNIT_ID,
                    UNIT_SEQ,
                    VALUE_TYPE,
                    VALUE_SEQ,
                    VALUE_COUNT,
                    VALUE_1,
                    VALUE_2,
                    VALUE_3,
                    VALUE_4,
                    VALUE_5,
                    VALUE_6,
                    VALUE_7,
                    VALUE_8,
                    VALUE_9,
                    VALUE_10,
                    VALUE_11,
                    VALUE_12,
                    VALUE_13,
                    VALUE_14,
                    VALUE_15,
                    VALUE_16,
                    VALUE_17,
                    VALUE_18,
                    VALUE_19,
