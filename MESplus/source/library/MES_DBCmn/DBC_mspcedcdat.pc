                    VALUE_25,
                    NOMINAL,
                    PROCESS_SIGMA,
                    EDC_COMMENT,
                    EDC_HIST_SEQ,
                    EDC_CHAR_SEQ,
                    EDC_UNIT_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                FROM MSPCEDCDAT
                WHERE FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND CHART_ID = :MSPCEDCDAT_N.CHART_ID
                    AND HIST_SEQ = :MSPCEDCDAT_N.HIST_SEQ
                    AND UNIT_SEQ = :MSPCEDCDAT_N.UNIT_SEQ
                ORDER BY VALUE_SEQ ASC;
            EXEC SQL OPEN DBC_MSPCEDCDAT_CUR_3;
            break;
        case 4:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N); 
            EXEC SQL DECLARE DBC_MSPCEDCDAT_CUR_4 CURSOR FOR
                SELECT
                           A.FACTORY,
                           A.CHART_ID,
                           A.HIST_SEQ,
                           A.TRAN_TIME,
                           A.LOT_RES_FLAG,
                           A.LOT_ID,
