/* SQL CURSOR CLOSE Function */
void DBC_close_mspcedcdat(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MSPCEDCDAT_CUR_1;
            break;
        case 2:
            EXEC SQL CLOSE DBC_MSPCEDCDAT_CUR_2;
            break;
        case 3:
            EXEC SQL CLOSE DBC_MSPCEDCDAT_CUR_3;
            break;
        case 4:
            EXEC SQL CLOSE DBC_MSPCEDCDAT_CUR_4;
            break;
        case 5:
            EXEC SQL CLOSE DBC_MSPCEDCDAT_CUR_5;
            break;
        case 6:
            EXEC SQL CLOSE DBC_MSPCEDCDAT_CUR_6;
            break;
        
        case 7:
            EXEC SQL CLOSE DBC_MSPCEDCDAT_CUR_7;
            break;     


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mspcedcdat", sel_type);
}


/* Initialize Function */
void DBC_init_mspcedcdat(struct MSPCEDCDAT_TAG *MSPCEDCDAT)
{
    /* memset by Space */
    memset(MSPCEDCDAT, ' ', sizeof(struct MSPCEDCDAT_TAG));
    
    MSPCEDCDAT->HIST_SEQ = 0;
    MSPCEDCDAT->MAT_VER = 0;
    MSPCEDCDAT->FLOW_SEQ_NUM = 0;
    MSPCEDCDAT->UNIT_SEQ = 0;
    MSPCEDCDAT->VALUE_SEQ = 0;
    MSPCEDCDAT->VALUE_COUNT = 0;
    MSPCEDCDAT->EDC_HIST_SEQ = 0;
    MSPCEDCDAT->EDC_CHAR_SEQ = 0;
    MSPCEDCDAT->EDC_UNIT_SEQ = 0;
}


