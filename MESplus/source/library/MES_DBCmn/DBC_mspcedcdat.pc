/* SQL UPDATE Function */
void DBC_update_mspcedcdat(int sel_type, struct MSPCEDCDAT_TAG *MSPCEDCDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSPCEDCDAT_N_TAG MSPCEDCDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mspcedcdat(&MSPCEDCDAT_N, MSPCEDCDAT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MSPCEDCDAT SET
                    TRAN_TIME = :MSPCEDCDAT_N.TRAN_TIME,
                    LOT_RES_FLAG = :MSPCEDCDAT_N.LOT_RES_FLAG,
                    LOT_ID = :MSPCEDCDAT_N.LOT_ID,
                    MAT_ID = :MSPCEDCDAT_N.MAT_ID,
                    MAT_VER = :MSPCEDCDAT_N.MAT_VER,
                    FLOW = :MSPCEDCDAT_N.FLOW,
                    FLOW_SEQ_NUM = :MSPCEDCDAT_N.FLOW_SEQ_NUM,
                    OPER = :MSPCEDCDAT_N.OPER,
                    PROC_OPER = :MSPCEDCDAT_N.PROC_OPER,
                    RES_ID = :MSPCEDCDAT_N.RES_ID,
                    PROC_RES_ID = :MSPCEDCDAT_N.PROC_RES_ID,
                    EVENT = :MSPCEDCDAT_N.EVENT,
                    CHAR_ID = :MSPCEDCDAT_N.CHAR_ID,
                    UNIT_ID = :MSPCEDCDAT_N.UNIT_ID,
                    VALUE_TYPE = :MSPCEDCDAT_N.VALUE_TYPE,
                    VALUE_COUNT = :MSPCEDCDAT_N.VALUE_COUNT,
                    VALUE_1 = :MSPCEDCDAT_N.VALUE_1,
                    VALUE_2 = :MSPCEDCDAT_N.VALUE_2,
                    VALUE_3 = :MSPCEDCDAT_N.VALUE_3,
                    VALUE_4 = :MSPCEDCDAT_N.VALUE_4,
                    VALUE_5 = :MSPCEDCDAT_N.VALUE_5,
                    VALUE_6 = :MSPCEDCDAT_N.VALUE_6,
                    VALUE_7 = :MSPCEDCDAT_N.VALUE_7,
                    VALUE_8 = :MSPCEDCDAT_N.VALUE_8,
                    VALUE_9 = :MSPCEDCDAT_N.VALUE_9,
                    VALUE_10 = :MSPCEDCDAT_N.VALUE_10,
                    VALUE_11 = :MSPCEDCDAT_N.VALUE_11,
                    VALUE_12 = :MSPCEDCDAT_N.VALUE_12,
                    VALUE_13 = :MSPCEDCDAT_N.VALUE_13,
                    VALUE_14 = :MSPCEDCDAT_N.VALUE_14,
                    VALUE_15 = :MSPCEDCDAT_N.VALUE_15,
                    VALUE_16 = :MSPCEDCDAT_N.VALUE_16,
                    VALUE_17 = :MSPCEDCDAT_N.VALUE_17,
                    VALUE_18 = :MSPCEDCDAT_N.VALUE_18,
                    VALUE_19 = :MSPCEDCDAT_N.VALUE_19,
                    VALUE_20 = :MSPCEDCDAT_N.VALUE_20,
                    VALUE_21 = :MSPCEDCDAT_N.VALUE_21,
                    VALUE_22 = :MSPCEDCDAT_N.VALUE_22,
                    VALUE_23 = :MSPCEDCDAT_N.VALUE_23,
                    VALUE_24 = :MSPCEDCDAT_N.VALUE_24,
                    VALUE_25 = :MSPCEDCDAT_N.VALUE_25,
                    NOMINAL = :MSPCEDCDAT_N.NOMINAL,
                    PROCESS_SIGMA = :MSPCEDCDAT_N.PROCESS_SIGMA,
                    EDC_COMMENT = :MSPCEDCDAT_N.EDC_COMMENT,
                    EDC_HIST_SEQ = :MSPCEDCDAT_N.EDC_HIST_SEQ,
                    EDC_CHAR_SEQ = :MSPCEDCDAT_N.EDC_CHAR_SEQ,
                    EDC_UNIT_SEQ = :MSPCEDCDAT_N.EDC_UNIT_SEQ,
                    CREATE_USER_ID = :MSPCEDCDAT_N.CREATE_USER_ID,
                    CREATE_TIME = :MSPCEDCDAT_N.CREATE_TIME,
                    UPDATE_USER_ID = :MSPCEDCDAT_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MSPCEDCDAT_N.UPDATE_TIME,
                    RESV_FIELD1 = :MSPCEDCDAT_N.RESV_FIELD1,
                    RESV_FIELD2 = :MSPCEDCDAT_N.RESV_FIELD2,
                    RESV_FIELD3 = :MSPCEDCDAT_N.RESV_FIELD3,
                    RESV_FIELD4 = :MSPCEDCDAT_N.RESV_FIELD4,
                    RESV_FIELD5 = :MSPCEDCDAT_N.RESV_FIELD5
                WHERE FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND CHART_ID = :MSPCEDCDAT_N.CHART_ID
                    AND HIST_SEQ = :MSPCEDCDAT_N.HIST_SEQ
                    AND UNIT_SEQ = :MSPCEDCDAT_N.UNIT_SEQ
                    AND VALUE_SEQ = :MSPCEDCDAT_N.VALUE_SEQ;
            break;
  
        case 2:
            EXEC SQL UPDATE MSPCEDCDAT SET
                    HIST_SEQ = HIST_SEQ + 1
                WHERE FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND CHART_ID = :MSPCEDCDAT_N.CHART_ID
                    AND HIST_SEQ > :MSPCEDCDAT_N.HIST_SEQ;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mspcedcdat", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mspcedcdat(int sel_type, struct MSPCEDCDAT_TAG *MSPCEDCDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSPCEDCDAT_N_TAG MSPCEDCDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mspcedcdat(&MSPCEDCDAT_N, MSPCEDCDAT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSPCEDCDAT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    LOT_ID,
                    MAT_ID,
                    MAT_VER,
