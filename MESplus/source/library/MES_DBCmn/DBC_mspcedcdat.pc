                    EDC_COMMENT,
                    EDC_HIST_SEQ,
                    EDC_CHAR_SEQ,
                    EDC_UNIT_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                FROM MSPCEDCDAT
                ORDER BY FACTORY ASC,
                    CHART_ID ASC,
                    HIST_SEQ ASC,
                    UNIT_SEQ ASC,
                    VALUE_SEQ ASC;
            EXEC SQL OPEN DBC_MSPCEDCDAT_CUR_1;
            break;
        case 2:
            EXEC SQL DECLARE DBC_MSPCEDCDAT_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    LOT_RES_FLAG,
