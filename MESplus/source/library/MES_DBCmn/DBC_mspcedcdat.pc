                           A.NOMINAL,
                           A.PROCESS_SIGMA,
                           A.EDC_COMMENT,
                           A.EDC_HIST_SEQ,
                           A.EDC_CHAR_SEQ,
                           A.EDC_UNIT_SEQ,
                           A.CREATE_USER_ID,
                           A.CREATE_TIME,
                           A.UPDATE_USER_ID,
                           A.UPDATE_TIME,
                           A.RESV_FIELD1,
                           A.RESV_FIELD2,
                           A.RESV_FIELD3,
                           A.RESV_FIELD4,
                           A.RESV_FIELD5
                FROM MSPCEDCDAT A, MSPCCALDAT B
                WHERE A.FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND A.FACTORY = B.FACTORY
                    AND A.CHART_ID = B.CHART_ID
                    AND A.HIST_SEQ = B.HIST_SEQ
                    AND B.EXCLUDE_FLAG <> 'Y'
                    AND A.CHART_ID = :MSPCEDCDAT_N.CHART_ID
                    AND (A.HIST_SEQ > :MSPCEDCDAT_N.HIST_SEQ
                    OR (A.HIST_SEQ = :MSPCEDCDAT_N.HIST_SEQ
                    AND A.UNIT_SEQ > :MSPCEDCDAT_N.UNIT_SEQ)
                    OR (A.HIST_SEQ = :MSPCEDCDAT_N.HIST_SEQ AND A.UNIT_SEQ = :MSPCEDCDAT_N.UNIT_SEQ AND A.VALUE_SEQ >= :MSPCEDCDAT_N.VALUE_SEQ))
                    AND A.TRAN_TIME <= :DBC_Q_COND_N.TO_TIME AND A.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                    ORDER BY A.HIST_SEQ ASC, A.UNIT_SEQ ASC, A.VALUE_SEQ ASC;
            EXEC SQL OPEN DBC_MSPCEDCDAT_CUR_6;
            break;
        
        case 7:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N); 
            EXEC SQL DECLARE DBC_MSPCEDCDAT_CUR_7 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    LOT_ID,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    PROC_OPER,
                    RES_ID,
                    PROC_RES_ID,
                    EVENT,
                    CHAR_ID,
                    UNIT_ID,
                    UNIT_SEQ,
                    VALUE_TYPE,
                    VALUE_SEQ,
                    VALUE_COUNT,
                    VALUE_1,
                    VALUE_2,
                    VALUE_3,
                    VALUE_4,
                    VALUE_5,
                    VALUE_6,
                    VALUE_7,
                    VALUE_8,
                    VALUE_9,
                    VALUE_10,
                    VALUE_11,
                    VALUE_12,
                    VALUE_13,
                    VALUE_14,
                    VALUE_15,
                    VALUE_16,
                    VALUE_17,
                    VALUE_18,
                    VALUE_19,
                    VALUE_20,
                    VALUE_21,
                    VALUE_22,
                    VALUE_23,
                    VALUE_24,
                    VALUE_25,
                    NOMINAL,
                    PROCESS_SIGMA,
                    EDC_COMMENT,
                    EDC_HIST_SEQ,
                    EDC_CHAR_SEQ,
                    EDC_UNIT_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                    FROM MSPCEDCDAT
                    WHERE FACTORY = :MSPCEDCDAT_N.FACTORY
                        AND CHART_ID = :MSPCEDCDAT_N.CHART_ID
                        AND (HIST_SEQ < :MSPCEDCDAT_N.HIST_SEQ
                        OR (HIST_SEQ = :MSPCEDCDAT_N.HIST_SEQ
                        AND UNIT_SEQ < :MSPCEDCDAT_N.UNIT_SEQ)
                        OR (HIST_SEQ = :MSPCEDCDAT_N.HIST_SEQ AND UNIT_SEQ = :MSPCEDCDAT_N.UNIT_SEQ AND VALUE_SEQ >= :MSPCEDCDAT_N.VALUE_SEQ))
                        AND TRAN_TIME <= :DBC_Q_COND_N.TO_TIME AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                    ORDER BY HIST_SEQ DESC, UNIT_SEQ DESC, VALUE_SEQ ASC;
            EXEC SQL OPEN DBC_MSPCEDCDAT_CUR_7;
            break;            
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mspcedcdat", sel_type);
}


