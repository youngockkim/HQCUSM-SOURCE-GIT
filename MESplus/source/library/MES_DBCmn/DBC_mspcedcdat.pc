    MEMCPY_DN(MSPCEDCDAT->RESV_FIELD4, MSPCEDCDAT_N->RESV_FIELD4, sizeof(MSPCEDCDAT->RESV_FIELD4));
    MEMCPY_DN(MSPCEDCDAT->RESV_FIELD5, MSPCEDCDAT_N->RESV_FIELD5, sizeof(MSPCEDCDAT->RESV_FIELD5));
}


