/* SQL SELECT_SCALAR Function */
double DBC_select_mspcedcdat_scalar(int sel_type, struct MSPCEDCDAT_TAG *MSPCEDCDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSPCEDCDAT_N_TAG MSPCEDCDAT_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    

    DBC_add_null_mspcedcdat(&MSPCEDCDAT_N, MSPCEDCDAT);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MSPCEDCDAT
                WHERE FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND CHART_ID = :MSPCEDCDAT_N.CHART_ID
                    AND HIST_SEQ = :MSPCEDCDAT_N.HIST_SEQ
                    AND UNIT_SEQ = :MSPCEDCDAT_N.UNIT_SEQ
                    AND VALUE_SEQ = :MSPCEDCDAT_N.VALUE_SEQ;
            break;
        case 2:
            EXEC SQL SELECT NVL(MAX(HIST_SEQ),0) 
                INTO :d_value
                FROM MSPCEDCDAT
                WHERE FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND CHART_ID = :MSPCEDCDAT_N.CHART_ID;
            break;    
      
        case 3:
            EXEC SQL SELECT /*+ INDEX_DESC(DAT MSPCEDCDAT_PK ) */ NVL(MAX(HIST_SEQ),0) 
                INTO :d_value
                FROM MSPCEDCDAT DAT
                WHERE FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND CHART_ID = :MSPCEDCDAT_N.CHART_ID
                    AND TRAN_TIME <= :MSPCEDCDAT_N.TRAN_TIME
					AND ROWNUM <= 1;
            break;     
            
        case 4:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT count(*)
                INTO :d_value
                FROM 
                    (SELECT A.LOT_ID FROM MSPCEDCDAT A, MSPCCALDAT B
                    WHERE A.FACTORY = B.FACTORY
                        AND A.CHART_ID = B.CHART_ID
                        AND A.HIST_SEQ = B.HIST_SEQ
                        AND A.UNIT_SEQ = B.UNIT_SEQ
                        AND A.FACTORY= :MSPCEDCDAT_N.FACTORY 
                        AND A.CHART_ID= :MSPCEDCDAT_N.CHART_ID
                        AND A.LOT_RES_FLAG= 'L'
                        AND A.TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                        AND A.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                        AND A.LOT_ID <> ' '
                        AND B.EXCLUDE_FLAG <> 'Y'
                        GROUP BY A.LOT_ID);
            break;  
            
         case 5:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT count(*)
                INTO :d_value
                FROM 
                    (SELECT A.RES_ID FROM MSPCEDCDAT A, MSPCCALDAT B
                    WHERE A.FACTORY = B.FACTORY
                        AND A.CHART_ID = B.CHART_ID
                        AND A.HIST_SEQ = B.HIST_SEQ
                        AND A.UNIT_SEQ = B.UNIT_SEQ
                        AND A.FACTORY= :MSPCEDCDAT_N.FACTORY 
                        AND A.CHART_ID= :MSPCEDCDAT_N.CHART_ID
                        AND A.LOT_RES_FLAG= 'R'
                        AND A.TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                        AND A.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                        AND A.RES_ID <> ' '
                        AND B.EXCLUDE_FLAG <> 'Y'
                        GROUP BY A.RES_ID);
            break;     
            
        case 6:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT SUM(TO_NUMBER(VALUE_2))
                INTO :d_value
                FROM MSPCEDCDAT A, MSPCCALDAT B
                WHERE A.FACTORY = B.FACTORY
                    AND A.CHART_ID = B.CHART_ID
                    AND A.HIST_SEQ = B.HIST_SEQ
                    AND A.UNIT_SEQ = B.UNIT_SEQ
                    AND A.FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND A.CHART_ID = :MSPCEDCDAT_N.CHART_ID
                    AND B.EXCLUDE_FLAG <> 'Y'
                    AND A.TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                    AND A.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME;
            break;     
        
        case 7:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT SUM(TO_NUMBER(VALUE_1))
                INTO :d_value
                FROM MSPCEDCDAT A, MSPCCALDAT B
                WHERE A.FACTORY = B.FACTORY
                    AND A.CHART_ID = B.CHART_ID
                    AND A.HIST_SEQ = B.HIST_SEQ
                    AND A.UNIT_SEQ = B.UNIT_SEQ
                    AND A.FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND A.CHART_ID = :MSPCEDCDAT_N.CHART_ID
                    AND B.EXCLUDE_FLAG <> 'Y'
                    AND A.TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                    AND A.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME;
            break; 
            
        case 8:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT AVG(TO_NUMBER(VALUE_1))
                INTO :d_value
                FROM MSPCEDCDAT A, MSPCCALDAT B
                WHERE A.FACTORY = B.FACTORY
                    AND A.CHART_ID = B.CHART_ID
                    AND A.HIST_SEQ = B.HIST_SEQ
                    AND A.UNIT_SEQ = B.UNIT_SEQ
                    AND A.FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND A.CHART_ID = :MSPCEDCDAT_N.CHART_ID
                    AND B.EXCLUDE_FLAG <> 'Y'
                    AND A.TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                    AND A.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME;
            break;         
 
        case 9:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT count(*)
                INTO :d_value
                FROM 
                    (SELECT A.LOT_ID FROM MSPCEDCDAT A, MSPCCALDAT B
                    WHERE A.FACTORY = B.FACTORY
                        AND A.CHART_ID = B.CHART_ID
                        AND A.HIST_SEQ = B.HIST_SEQ
                        AND B.UNIT_SEQ = 0
                        AND A.FACTORY= :MSPCEDCDAT_N.FACTORY 
                        AND A.CHART_ID= :MSPCEDCDAT_N.CHART_ID
                        AND A.LOT_RES_FLAG= 'L'
                        AND A.TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                        AND A.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                        AND A.LOT_ID <> ' '
                        AND B.EXCLUDE_FLAG <> 'Y'
                        GROUP BY A.LOT_ID);
            break;  
        
        case 10:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT count(*)
                INTO :d_value
                FROM 
                    (SELECT A.RES_ID FROM MSPCEDCDAT A, MSPCCALDAT B
                    WHERE A.FACTORY = B.FACTORY
                        AND A.CHART_ID = B.CHART_ID
                        AND A.HIST_SEQ = B.HIST_SEQ
                        AND B.UNIT_SEQ = 0
                        AND A.FACTORY= :MSPCEDCDAT_N.FACTORY 
                        AND A.CHART_ID= :MSPCEDCDAT_N.CHART_ID
                        AND A.LOT_RES_FLAG= 'R'
                        AND A.TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                        AND A.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                        AND A.RES_ID <> ' '
                        AND B.EXCLUDE_FLAG <> 'Y'
                        GROUP BY A.RES_ID);
            break;                                 
            
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mspcedcdat_scalar", sel_type);
    return d_value;
}


/* SQL DELETE Function */
void DBC_delete_mspcedcdat(int sel_type, struct MSPCEDCDAT_TAG *MSPCEDCDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSPCEDCDAT_N_TAG MSPCEDCDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mspcedcdat(&MSPCEDCDAT_N, MSPCEDCDAT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM MSPCEDCDAT
                WHERE FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND CHART_ID = :MSPCEDCDAT_N.CHART_ID
                    AND HIST_SEQ = :MSPCEDCDAT_N.HIST_SEQ
                    AND UNIT_SEQ = :MSPCEDCDAT_N.UNIT_SEQ
                    AND VALUE_SEQ = :MSPCEDCDAT_N.VALUE_SEQ;
            break;

        case 2:
            EXEC SQL DELETE FROM MSPCEDCDAT
                WHERE FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND CHART_ID = :MSPCEDCDAT_N.CHART_ID
                    AND HIST_SEQ = :MSPCEDCDAT_N.HIST_SEQ;
            break;
        
        case 3:
            EXEC SQL DELETE FROM MSPCEDCDAT
                WHERE FACTORY = :MSPCEDCDAT_N.FACTORY
                    AND CHART_ID = :MSPCEDCDAT_N.CHART_ID
                    AND HIST_SEQ = :MSPCEDCDAT_N.HIST_SEQ
                    AND UNIT_SEQ = :MSPCEDCDAT_N.UNIT_SEQ;
            break;   
             

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_delete_mspcedcdat", sel_type);
}


