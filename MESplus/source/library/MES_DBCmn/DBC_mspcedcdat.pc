{
    /* memset by NULL */
    memset(MSPCEDCDAT_N, '\0', sizeof(struct MSPCEDCDAT_N_TAG));
    
    MEMCPY_AN(MSPCEDCDAT_N->FACTORY, MSPCEDCDAT->FACTORY, sizeof(MSPCEDCDAT->FACTORY));
    MEMCPY_AN(MSPCEDCDAT_N->CHART_ID, MSPCEDCDAT->CHART_ID, sizeof(MSPCEDCDAT->CHART_ID));
