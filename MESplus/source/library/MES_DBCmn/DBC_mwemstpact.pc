}


/* Add Null Function */
void DBC_add_null_mwemstpact(struct MWEMSTPACT_N_TAG *MWEMSTPACT_N, struct MWEMSTPACT_TAG *MWEMSTPACT)
{
    /* memset by NULL */
    memset(MWEMSTPACT_N, '\0', sizeof(struct MWEMSTPACT_N_TAG));
    
    MEMCPY_AN(MWEMSTPACT_N->CREATE_TIME, MWEMSTPACT->CREATE_TIME, sizeof(MWEMSTPACT->CREATE_TIME));
    MEMCPY_AN(MWEMSTPACT_N->CREATE_USER_ID, MWEMSTPACT->CREATE_USER_ID, sizeof(MWEMSTPACT->CREATE_USER_ID));
    MEMCPY_AN(MWEMSTPACT_N->UPDATE_TIME, MWEMSTPACT->UPDATE_TIME, sizeof(MWEMSTPACT->UPDATE_TIME));
    MEMCPY_AN(MWEMSTPACT_N->UPDATE_USER_ID, MWEMSTPACT->UPDATE_USER_ID, sizeof(MWEMSTPACT->UPDATE_USER_ID));
    MEMCPY_AN(MWEMSTPACT_N->FACTORY, MWEMSTPACT->FACTORY, sizeof(MWEMSTPACT->FACTORY));
    MEMCPY_AN(MWEMSTPACT_N->WORK_PROC_TYPE, MWEMSTPACT->WORK_PROC_TYPE, sizeof(MWEMSTPACT->WORK_PROC_TYPE));
    MEMCPY_AN(MWEMSTPACT_N->STEP_ID, MWEMSTPACT->STEP_ID, sizeof(MWEMSTPACT->STEP_ID));
    MEMCPY_AN(MWEMSTPACT_N->ACTION_ID, MWEMSTPACT->ACTION_ID, sizeof(MWEMSTPACT->ACTION_ID));
    MEMCPY_AN(MWEMSTPACT_N->PARENT_PATH, MWEMSTPACT->PARENT_PATH, sizeof(MWEMSTPACT->PARENT_PATH));
    MWEMSTPACT_N->ACT_DEPTH = MWEMSTPACT->ACT_DEPTH;
    MWEMSTPACT_N->ACT_SEQ = MWEMSTPACT->ACT_SEQ;
    MWEMSTPACT_N->POINT_TYPE[0] = MWEMSTPACT->POINT_TYPE;
    MWEMSTPACT_N->CONTINUE_TYPE[0] = MWEMSTPACT->CONTINUE_TYPE;
}


/* Del Null Function */
void DBC_del_null_mwemstpact(struct MWEMSTPACT_N_TAG *MWEMSTPACT_N, struct MWEMSTPACT_TAG *MWEMSTPACT)
{
    MEMCPY_DN(MWEMSTPACT->CREATE_TIME, MWEMSTPACT_N->CREATE_TIME, sizeof(MWEMSTPACT->CREATE_TIME));
    MEMCPY_DN(MWEMSTPACT->CREATE_USER_ID, MWEMSTPACT_N->CREATE_USER_ID, sizeof(MWEMSTPACT->CREATE_USER_ID));
    MEMCPY_DN(MWEMSTPACT->UPDATE_TIME, MWEMSTPACT_N->UPDATE_TIME, sizeof(MWEMSTPACT->UPDATE_TIME));
