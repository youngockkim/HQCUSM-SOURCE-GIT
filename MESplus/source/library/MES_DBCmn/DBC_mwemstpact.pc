    MEMCPY_DN(MWEMSTPACT->STEP_ID, MWEMSTPACT_N->STEP_ID, sizeof(MWEMSTPACT->STEP_ID));
    MEMCPY_DN(MWEMSTPACT->ACTION_ID, MWEMSTPACT_N->ACTION_ID, sizeof(MWEMSTPACT->ACTION_ID));
    MEMCPY_DN(MWEMSTPACT->PARENT_PATH, MWEMSTPACT_N->PARENT_PATH, sizeof(MWEMSTPACT->PARENT_PATH));
