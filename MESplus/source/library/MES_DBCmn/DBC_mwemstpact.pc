/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwemstpact(int sel_type, struct MWEMSTPACT_TAG *MWEMSTPACT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWEMSTPACT_N_TAG MWEMSTPACT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwemstpact(&MWEMSTPACT_N, MWEMSTPACT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWEMSTPACT_CUR_1 CURSOR FOR
                SELECT 
                    CREATE_TIME,
                    CREATE_USER_ID,
                    UPDATE_TIME,
                    UPDATE_USER_ID,
                    FACTORY,
                    WORK_PROC_TYPE,
                    STEP_ID,
                    POINT_TYPE,
                    ACTION_ID,
                    PARENT_PATH,
                    ACT_DEPTH,
                    ACT_SEQ,
                    CONTINUE_TYPE
                FROM MWEMSTPACT
                WHERE FACTORY = :MWEMSTPACT_N.FACTORY
                    AND WORK_PROC_TYPE = :MWEMSTPACT_N.WORK_PROC_TYPE
                    AND STEP_ID = :MWEMSTPACT_N.STEP_ID
                    AND POINT_TYPE = :MWEMSTPACT_N.POINT_TYPE
                    AND PARENT_PATH = :MWEMSTPACT_N.PARENT_PATH
                    AND ACTION_ID >= :MWEMSTPACT_N.ACTION_ID
                ORDER BY ACTION_ID ASC;
            EXEC SQL OPEN DBC_MWEMSTPACT_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWEMSTPACT_CUR_2 CURSOR FOR
                SELECT 
                    CREATE_TIME,
                    CREATE_USER_ID,
                    UPDATE_TIME,
                    UPDATE_USER_ID,
                    FACTORY,
                    WORK_PROC_TYPE,
                    STEP_ID,
                    POINT_TYPE,
                    ACTION_ID,
                    PARENT_PATH,
                    ACT_DEPTH,
                    ACT_SEQ,
                    CONTINUE_TYPE
                FROM MWEMSTPACT
                WHERE FACTORY = :MWEMSTPACT_N.FACTORY
                    AND WORK_PROC_TYPE = :MWEMSTPACT_N.WORK_PROC_TYPE
                    AND STEP_ID = :MWEMSTPACT_N.STEP_ID
                ORDER BY POINT_TYPE ASC, PARENT_PATH ASC, ACT_SEQ ASC;
            EXEC SQL OPEN DBC_MWEMSTPACT_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MWEMSTPACT_CUR_3 CURSOR FOR
                SELECT ACT.ACTION_ID
                FROM (
                    SELECT 
                        STA.ACTION_ID, STA.CONTINUE_TYPE, COUNT(CND.ACTION_ID) AS COND_COUNT
                    FROM MWEMSTPACT STA, MWEMACTCND CND
                    WHERE STA.FACTORY = :MWEMSTPACT_N.FACTORY
                        AND STA.WORK_PROC_TYPE = :MWEMSTPACT_N.WORK_PROC_TYPE
                        AND STA.STEP_ID = :MWEMSTPACT_N.STEP_ID
                        AND STA.POINT_TYPE = :MWEMSTPACT_N.POINT_TYPE
                        AND STA.PARENT_PATH = :MWEMSTPACT_N.PARENT_PATH
                        AND (STA.CONTINUE_TYPE = 'A' OR STA.CONTINUE_TYPE = :MWEMSTPACT_N.CONTINUE_TYPE)
                        AND STA.FACTORY = CND.FACTORY
                        AND STA.WORK_PROC_TYPE = CND.WORK_PROC_TYPE
                        AND STA.ACTION_ID = CND.ACTION_ID
                    GROUP BY STA.ACTION_ID, STA.CONTINUE_TYPE
                ) ACT
                ORDER BY ACT.CONTINUE_TYPE DESC, ACT.COND_COUNT DESC, ACT.ACTION_ID ASC;
            EXEC SQL OPEN DBC_MWEMSTPACT_CUR_3;
            break;

        case 4:
            EXEC SQL DECLARE DBC_MWEMSTPACT_CUR_4 CURSOR FOR
                SELECT 
                    ACTION_ID
                FROM MWEMSTPACT
                WHERE FACTORY = :MWEMSTPACT_N.FACTORY
                    AND WORK_PROC_TYPE = :MWEMSTPACT_N.WORK_PROC_TYPE
                    AND STEP_ID = :MWEMSTPACT_N.STEP_ID
                    AND POINT_TYPE = :MWEMSTPACT_N.POINT_TYPE
                    AND PARENT_PATH = :MWEMSTPACT_N.PARENT_PATH
                    AND (CONTINUE_TYPE = 'A' OR CONTINUE_TYPE = :MWEMSTPACT_N.CONTINUE_TYPE)
                    AND ACTION_ID NOT IN (
                        SELECT DISTINCT ACTION_ID 
                        FROM MWEMACTCND
                        WHERE FACTORY = :MWEMSTPACT_N.FACTORY
                            AND WORK_PROC_TYPE = :MWEMSTPACT_N.WORK_PROC_TYPE
                    )
                ORDER BY CONTINUE_TYPE DESC, ACTION_ID ASC;
            EXEC SQL OPEN DBC_MWEMSTPACT_CUR_4;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mwemstpact", sel_type);
}


