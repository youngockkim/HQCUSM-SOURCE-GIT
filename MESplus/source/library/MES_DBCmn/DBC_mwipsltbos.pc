/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipsltbos(int sel_type, struct MWIPSLTBOS_TAG *MWIPSLTBOS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSLTBOS_N_TAG MWIPSLTBOS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipsltbos(&MWIPSLTBOS_N, MWIPSLTBOS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPSLTBOS_CUR_1 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    LOT_ID,
                    HIST_SEQ,
                    LOT_HIST_SEQ,
                    QTY_FLAG,
                    BONUS_CODE,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_ID,
                    CAUSE_FLOW,
                    CAUSE_OPER,
                    CAUSE_RES_ID,
                    BONUS_QTY
                FROM MWIPSLTBOS
                ORDER BY SUBLOT_ID ASC,
                    LOT_ID ASC,
                    HIST_SEQ ASC,
                    QTY_FLAG ASC,
                    BONUS_CODE ASC;
            EXEC SQL OPEN DBC_MWIPSLTBOS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mwipsltbos", sel_type);
}


