    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MRASPMSSTS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MRASPMSSTS_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MRASPMSSTS_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MRASPMSSTS_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MRASPMSSTS_CUR_5;
            break;

        case 6:
            EXEC SQL CLOSE DBC_MRASPMSSTS_CUR_6;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mraspmssts", sel_type);
}


/* Initialize Function */
void DBC_init_mraspmssts(struct MRASPMSSTS_TAG *MRASPMSSTS)
{
    /* memset by Space */
    memset(MRASPMSSTS, ' ', sizeof(struct MRASPMSSTS_TAG));
    
    MRASPMSSTS->PM_ACT_HIST_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mraspmssts(struct MRASPMSSTS_N_TAG *MRASPMSSTS_N, struct MRASPMSSTS_TAG *MRASPMSSTS)
{
    /* memset by NULL */
    memset(MRASPMSSTS_N, '\0', sizeof(struct MRASPMSSTS_N_TAG));
    
    MEMCPY_AN(MRASPMSSTS_N->FACTORY, MRASPMSSTS->FACTORY, sizeof(MRASPMSSTS->FACTORY));
    MEMCPY_AN(MRASPMSSTS_N->RES_ID, MRASPMSSTS->RES_ID, sizeof(MRASPMSSTS->RES_ID));
    MEMCPY_AN(MRASPMSSTS_N->PM_PLAN_DATE, MRASPMSSTS->PM_PLAN_DATE, sizeof(MRASPMSSTS->PM_PLAN_DATE));
    MEMCPY_AN(MRASPMSSTS_N->PM_PERIOD, MRASPMSSTS->PM_PERIOD, sizeof(MRASPMSSTS->PM_PERIOD));
    MEMCPY_AN(MRASPMSSTS_N->PM_PLAN_USER_ID, MRASPMSSTS->PM_PLAN_USER_ID, sizeof(MRASPMSSTS->PM_PLAN_USER_ID));
    MEMCPY_AN(MRASPMSSTS_N->PM_PLAN_TIME, MRASPMSSTS->PM_PLAN_TIME, sizeof(MRASPMSSTS->PM_PLAN_TIME));
    MEMCPY_AN(MRASPMSSTS_N->PM_EVENT_ID, MRASPMSSTS->PM_EVENT_ID, sizeof(MRASPMSSTS->PM_EVENT_ID));
    MRASPMSSTS_N->PM_ACT_FLAG[0] = MRASPMSSTS->PM_ACT_FLAG;
    MRASPMSSTS_N->PM_ACT_HIST_SEQ = MRASPMSSTS->PM_ACT_HIST_SEQ;
    MEMCPY_AN(MRASPMSSTS_N->PM_ACT_USER_ID, MRASPMSSTS->PM_ACT_USER_ID, sizeof(MRASPMSSTS->PM_ACT_USER_ID));
    MEMCPY_AN(MRASPMSSTS_N->PM_ACT_TIME, MRASPMSSTS->PM_ACT_TIME, sizeof(MRASPMSSTS->PM_ACT_TIME));
    MEMCPY_AN(MRASPMSSTS_N->PM_COMMENT, MRASPMSSTS->PM_COMMENT, sizeof(MRASPMSSTS->PM_COMMENT));
    MEMCPY_AN(MRASPMSSTS_N->UPDATE_USER_ID, MRASPMSSTS->UPDATE_USER_ID, sizeof(MRASPMSSTS->UPDATE_USER_ID));
    MEMCPY_AN(MRASPMSSTS_N->UPDATE_TIME, MRASPMSSTS->UPDATE_TIME, sizeof(MRASPMSSTS->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mraspmssts(struct MRASPMSSTS_N_TAG *MRASPMSSTS_N, struct MRASPMSSTS_TAG *MRASPMSSTS)
{
    MEMCPY_DN(MRASPMSSTS->FACTORY, MRASPMSSTS_N->FACTORY, sizeof(MRASPMSSTS->FACTORY));
    MEMCPY_DN(MRASPMSSTS->RES_ID, MRASPMSSTS_N->RES_ID, sizeof(MRASPMSSTS->RES_ID));
    MEMCPY_DN(MRASPMSSTS->PM_PLAN_DATE, MRASPMSSTS_N->PM_PLAN_DATE, sizeof(MRASPMSSTS->PM_PLAN_DATE));
    MEMCPY_DN(MRASPMSSTS->PM_PERIOD, MRASPMSSTS_N->PM_PERIOD, sizeof(MRASPMSSTS->PM_PERIOD));
    MEMCPY_DN(MRASPMSSTS->PM_PLAN_USER_ID, MRASPMSSTS_N->PM_PLAN_USER_ID, sizeof(MRASPMSSTS->PM_PLAN_USER_ID));
    MEMCPY_DN(MRASPMSSTS->PM_PLAN_TIME, MRASPMSSTS_N->PM_PLAN_TIME, sizeof(MRASPMSSTS->PM_PLAN_TIME));
    MEMCPY_DN(MRASPMSSTS->PM_EVENT_ID, MRASPMSSTS_N->PM_EVENT_ID, sizeof(MRASPMSSTS->PM_EVENT_ID));
    MRASPMSSTS->PM_ACT_FLAG = MRASPMSSTS_N->PM_ACT_FLAG[0];
    MRASPMSSTS->PM_ACT_HIST_SEQ = MRASPMSSTS_N->PM_ACT_HIST_SEQ;
    MEMCPY_DN(MRASPMSSTS->PM_ACT_USER_ID, MRASPMSSTS_N->PM_ACT_USER_ID, sizeof(MRASPMSSTS->PM_ACT_USER_ID));
    MEMCPY_DN(MRASPMSSTS->PM_ACT_TIME, MRASPMSSTS_N->PM_ACT_TIME, sizeof(MRASPMSSTS->PM_ACT_TIME));
    MEMCPY_DN(MRASPMSSTS->PM_COMMENT, MRASPMSSTS_N->PM_COMMENT, sizeof(MRASPMSSTS->PM_COMMENT));
    MEMCPY_DN(MRASPMSSTS->UPDATE_USER_ID, MRASPMSSTS_N->UPDATE_USER_ID, sizeof(MRASPMSSTS->UPDATE_USER_ID));
    MEMCPY_DN(MRASPMSSTS->UPDATE_TIME, MRASPMSSTS_N->UPDATE_TIME, sizeof(MRASPMSSTS->UPDATE_TIME));
}


