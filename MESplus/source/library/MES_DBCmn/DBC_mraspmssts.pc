                ORDER BY STS.FACTORY ASC,
                    STS.PM_PLAN_DATE ASC,
                    STS.RES_ID ASC;
            EXEC SQL OPEN DBC_MRASPMSSTS_CUR_6;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mraspmssts", sel_type);
}


