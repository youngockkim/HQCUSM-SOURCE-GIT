            sprintf(sql + strlen(sql),   "RES.LAST_EVENT_ID, ");
            sprintf(sql + strlen(sql),   "RES.LAST_EVENT_TIME, ");
            sprintf(sql + strlen(sql),   "RES.LAST_ACTIVE_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "RES.LAST_HIST_SEQ, ");
			sprintf(sql + strlen(sql),   "RES.RES_SHORT_DESC ");
            sprintf(sql + strlen(sql), "FROM MRASRESDEF RES, ( ");
            sprintf(sql + strlen(sql),  "   SELECT DISTINCT FACTORY, RES_ID FROM MRASRESMFO  ");
            make_valid_quote(ts, MRASRESDEF_N.FACTORY);
            sprintf(sql + strlen(sql), " WHERE FACTORY = '%s' ", ts);
            
            if(ISSPACE(MRASRESDEF->RES_CMF_1, sizeof(MRASRESDEF->RES_CMF_1)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASRESDEF_N.RES_CMF_1);
                sprintf(sql + strlen(sql), " AND RESG_ID = '%s' ", ts);
            }
            
            if(ISSPACE(MRASRESDEF->RES_CMF_2, sizeof(MRASRESDEF->RES_CMF_2)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASRESDEF_N.RES_CMF_2);
                sprintf(sql + strlen(sql), " AND MAT_ID = '%s' ", ts);
            }
            
            sprintf(sql + strlen(sql), " AND MAT_VER= %d ", MRASRESDEF_N.PROC_COUNT);
            
            if(ISSPACE(MRASRESDEF->RES_CMF_3, sizeof(MRASRESDEF->RES_CMF_3)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASRESDEF_N.RES_CMF_3);
                sprintf(sql + strlen(sql), " AND FLOW = '%s' ", ts);
            }
            
            if(ISSPACE(MRASRESDEF->RES_CMF_4, sizeof(MRASRESDEF->RES_CMF_4)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASRESDEF_N.RES_CMF_4);
                sprintf(sql + strlen(sql), " AND OPER = '%s' ", ts);
            }
            
            if(ISSPACE(MRASRESDEF->RES_CMF_5, sizeof(MRASRESDEF->RES_CMF_5)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASRESDEF_N.RES_CMF_5);
                sprintf(sql + strlen(sql), " AND REL_LEVEL = '%s' ", ts);
            }
            
            sprintf(sql + strlen(sql), "  ) MFO ");
            
            make_valid_quote(ts, MRASRESDEF_N.FACTORY);
            sprintf(sql + strlen(sql), "  WHERE RES.FACTORY = '%s' ", ts);
            
            make_valid_quote(ts, MRASRESDEF_N.RES_ID);
            sprintf(sql + strlen(sql), " AND RES.RES_ID >= '%s' ", ts);
            
            make_valid_quote(ts, MRASRESDEF_N.RES_DESC);
            sprintf(sql + strlen(sql), " AND RES.RES_ID LIKE '%s' ", ts);
            
            if(ISSPACE(MRASRESDEF->RES_TYPE, sizeof(MRASRESDEF->RES_TYPE)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASRESDEF_N.RES_TYPE);
                sprintf(sql + strlen(sql), " AND RES.RES_TYPE = '%s' ", ts);
            }
            
            if(ISSPACE(MRASRESDEF->AREA_ID, sizeof(MRASRESDEF->AREA_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASRESDEF_N.AREA_ID);
                sprintf(sql + strlen(sql), " AND RES.AREA_ID = '%s' ", ts);
            }
            
            if(ISSPACE(MRASRESDEF->SUB_AREA_ID, sizeof(MRASRESDEF->SUB_AREA_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASRESDEF_N.SUB_AREA_ID);
                sprintf(sql + strlen(sql), " AND RES.SUB_AREA_ID = '%s' ", ts);
            }
            
            if(MRASRESDEF->DELETE_FLAG != ' ')
            {
                  sprintf(sql + strlen(sql), " AND RES.DELETE_FLAG LIKE '%c' ", MRASRESDEF_N.DELETE_FLAG[0]);
            }
            
            sprintf(sql + strlen(sql), " AND RES.FACTORY = MFO.FACTORY ");
            sprintf(sql + strlen(sql), " AND RES.RES_ID = MFO.RES_ID ");
            sprintf(sql + strlen(sql), " ORDER BY RES.RES_ID ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MRASRESDEF_CUR_11 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MRASRESDEF_CUR_11;                 
            break;
            
        case 12:
            EXEC SQL DECLARE DBC_MRASRESDEF_CUR_12 CURSOR FOR
                SELECT RES_ID, RES_DESC, DELETE_FLAG, RES_UP_DOWN_FLAG, RES_SHORT_DESC
                FROM MRASRESDEF
                WHERE FACTORY = :MRASRESDEF_N.FACTORY
                    AND RES_ID >= :MRASRESDEF_N.RES_ID
                    AND RES_ID LIKE :MRASRESDEF_N.RES_DESC
                    AND RES_TYPE LIKE :MRASRESDEF_N.RES_TYPE
                    AND AREA_ID LIKE :MRASRESDEF_N.AREA_ID
                    AND SUB_AREA_ID LIKE :MRASRESDEF_N.SUB_AREA_ID
                    AND DELETE_FLAG LIKE :MRASRESDEF_N.DELETE_FLAG
                    AND SEC_CHK_FLAG = :MRASRESDEF_N.SEC_CHK_FLAG
                ORDER BY RES_ID ASC;
            EXEC SQL OPEN DBC_MRASRESDEF_CUR_12;
            break;
		case 13:
            EXEC SQL DECLARE DBC_MRASRESDEF_CUR_13 CURSOR FOR
                SELECT DISTINCT RES.RES_TYPE
                FROM MRASRESDEF RES,(
                    SELECT DISTINCT FACTORY, RES_ID 
                    FROM MRASRESMFO
                    WHERE FACTORY = :MRASRESDEF_N.FACTORY
                        AND MAT_ID LIKE :MRASRESDEF_N.RES_CMF_2
                        AND MAT_VER LIKE :MRASRESDEF_N.RES_CMF_6
                        AND FLOW LIKE :MRASRESDEF_N.RES_CMF_3
                        AND OPER LIKE :MRASRESDEF_N.RES_CMF_4
                    ) MFO
                WHERE RES.FACTORY = :MRASRESDEF_N.FACTORY
                    AND RES.FACTORY = MFO.FACTORY
                    AND RES.RES_ID = MFO.RES_ID
                ORDER BY RES.RES_TYPE ASC;
            EXEC SQL OPEN DBC_MRASRESDEF_CUR_13;
            break;

