/* SQL SELECT_SCALAR Function */
double DBC_select_mrasresdef_scalar(int sel_type, struct MRASRESDEF_TAG *MRASRESDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASRESDEF_N_TAG MRASRESDEF_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrasresdef(&MRASRESDEF_N, MRASRESDEF);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MRASRESDEF
                WHERE FACTORY = :MRASRESDEF_N.FACTORY
                    AND RES_ID = :MRASRESDEF_N.RES_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mrasresdef_scalar", sel_type);
    return d_value;
}


