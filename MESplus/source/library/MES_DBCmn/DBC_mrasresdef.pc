                    :MRASRESDEF_N.BATCH_COND_2,
                    :MRASRESDEF_N.PM_SCH_ENABLE_FLAG,
                    :MRASRESDEF_N.UNIT_BASE_ST_FLAG,
                    :MRASRESDEF_N.SEC_CHK_FLAG,
                    :MRASRESDEF_N.GATHER_ALARM_FLAG,
                    :MRASRESDEF_N.DELETE_FLAG,
                    :MRASRESDEF_N.DELETE_USER_ID,
                    :MRASRESDEF_N.DELETE_TIME,
                    :MRASRESDEF_N.CREATE_USER_ID,
                    :MRASRESDEF_N.CREATE_TIME,
                    :MRASRESDEF_N.UPDATE_USER_ID,
                    :MRASRESDEF_N.UPDATE_TIME,
                    :MRASRESDEF_N.RES_UP_DOWN_FLAG,
                    :MRASRESDEF_N.RES_PRI_STS,
                    :MRASRESDEF_N.RES_STS_1,
                    :MRASRESDEF_N.RES_STS_2,
                    :MRASRESDEF_N.RES_STS_3,
                    :MRASRESDEF_N.RES_STS_4,
                    :MRASRESDEF_N.RES_STS_5,
                    :MRASRESDEF_N.RES_STS_6,
                    :MRASRESDEF_N.RES_STS_7,
                    :MRASRESDEF_N.RES_STS_8,
                    :MRASRESDEF_N.RES_STS_9,
                    :MRASRESDEF_N.RES_STS_10,
                    :MRASRESDEF_N.LOT_ID,
                    :MRASRESDEF_N.SUBLOT_ID,
                    :MRASRESDEF_N.CRR_ID,
                    :MRASRESDEF_N.RES_CTRL_MODE,
                    :MRASRESDEF_N.RES_PROC_MODE,
                    :MRASRESDEF_N.LAST_RECIPE_ID,
                    :MRASRESDEF_N.PROC_COUNT,
                    :MRASRESDEF_N.LAST_START_TIME,
                    :MRASRESDEF_N.LAST_END_TIME,
                    :MRASRESDEF_N.LAST_DOWN_TIME,
                    :MRASRESDEF_N.LAST_DOWN_HIST_SEQ,
                    :MRASRESDEF_N.LAST_EVENT_ID,
                    :MRASRESDEF_N.LAST_EVENT_TIME,
                    :MRASRESDEF_N.LAST_ACTIVE_HIST_SEQ,
                    :MRASRESDEF_N.LAST_HIST_SEQ,
					:MRASRESDEF_N.RES_SHORT_DESC
        );
    DB_stop_query_timer("DBC_insert_mrasresdef", 0);
}


/* SQL UPDATE Function */
void DBC_update_mrasresdef(int sel_type, struct MRASRESDEF_TAG *MRASRESDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASRESDEF_N_TAG MRASRESDEF_N;
        struct MRASRESDEF_TAG   MRASRESDEF_S;

        char sql[10000];
        char ts[1000];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrasresdef(&MRASRESDEF_N, MRASRESDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MRASRESDEF SET
                    RES_DESC = :MRASRESDEF_N.RES_DESC,
                    RES_TYPE = :MRASRESDEF_N.RES_TYPE,
                    RES_GRP_1 = :MRASRESDEF_N.RES_GRP_1,
                    RES_GRP_2 = :MRASRESDEF_N.RES_GRP_2,
                    RES_GRP_3 = :MRASRESDEF_N.RES_GRP_3,
                    RES_GRP_4 = :MRASRESDEF_N.RES_GRP_4,
                    RES_GRP_5 = :MRASRESDEF_N.RES_GRP_5,
                    RES_GRP_6 = :MRASRESDEF_N.RES_GRP_6,
                    RES_GRP_7 = :MRASRESDEF_N.RES_GRP_7,
                    RES_GRP_8 = :MRASRESDEF_N.RES_GRP_8,
                    RES_GRP_9 = :MRASRESDEF_N.RES_GRP_9,
                    RES_GRP_10 = :MRASRESDEF_N.RES_GRP_10,
                    USE_FAC_PRT_FLAG = :MRASRESDEF_N.USE_FAC_PRT_FLAG,
                    RES_STS_PRT_1 = :MRASRESDEF_N.RES_STS_PRT_1,
                    RES_STS_PRT_2 = :MRASRESDEF_N.RES_STS_PRT_2,
                    RES_STS_PRT_3 = :MRASRESDEF_N.RES_STS_PRT_3,
                    RES_STS_PRT_4 = :MRASRESDEF_N.RES_STS_PRT_4,
                    RES_STS_PRT_5 = :MRASRESDEF_N.RES_STS_PRT_5,
                    RES_STS_PRT_6 = :MRASRESDEF_N.RES_STS_PRT_6,
                    RES_STS_PRT_7 = :MRASRESDEF_N.RES_STS_PRT_7,
                    RES_STS_PRT_8 = :MRASRESDEF_N.RES_STS_PRT_8,
                    RES_STS_PRT_9 = :MRASRESDEF_N.RES_STS_PRT_9,
                    RES_STS_PRT_10 = :MRASRESDEF_N.RES_STS_PRT_10,
                    RES_CMF_1 = :MRASRESDEF_N.RES_CMF_1,
                    RES_CMF_2 = :MRASRESDEF_N.RES_CMF_2,
                    RES_CMF_3 = :MRASRESDEF_N.RES_CMF_3,
                    RES_CMF_4 = :MRASRESDEF_N.RES_CMF_4,
                    RES_CMF_5 = :MRASRESDEF_N.RES_CMF_5,
                    RES_CMF_6 = :MRASRESDEF_N.RES_CMF_6,
                    RES_CMF_7 = :MRASRESDEF_N.RES_CMF_7,
                    RES_CMF_8 = :MRASRESDEF_N.RES_CMF_8,
                    RES_CMF_9 = :MRASRESDEF_N.RES_CMF_9,
                    RES_CMF_10 = :MRASRESDEF_N.RES_CMF_10,
                    RES_CMF_11 = :MRASRESDEF_N.RES_CMF_11,
                    RES_CMF_12 = :MRASRESDEF_N.RES_CMF_12,
                    RES_CMF_13 = :MRASRESDEF_N.RES_CMF_13,
                    RES_CMF_14 = :MRASRESDEF_N.RES_CMF_14,
                    RES_CMF_15 = :MRASRESDEF_N.RES_CMF_15,
                    RES_CMF_16 = :MRASRESDEF_N.RES_CMF_16,
                    RES_CMF_17 = :MRASRESDEF_N.RES_CMF_17,
                    RES_CMF_18 = :MRASRESDEF_N.RES_CMF_18,
                    RES_CMF_19 = :MRASRESDEF_N.RES_CMF_19,
                    RES_CMF_20 = :MRASRESDEF_N.RES_CMF_20,
                    AREA_ID = :MRASRESDEF_N.AREA_ID,
                    SUB_AREA_ID = :MRASRESDEF_N.SUB_AREA_ID,
                    RES_LOCATION = :MRASRESDEF_N.RES_LOCATION,
                    PROC_RULE = :MRASRESDEF_N.PROC_RULE,
                    MAX_PROC_COUNT = :MRASRESDEF_N.MAX_PROC_COUNT,
                    BATCH_COND_1 = :MRASRESDEF_N.BATCH_COND_1,
                    BATCH_COND_2 = :MRASRESDEF_N.BATCH_COND_2,
                    PM_SCH_ENABLE_FLAG = :MRASRESDEF_N.PM_SCH_ENABLE_FLAG,
                    UNIT_BASE_ST_FLAG = :MRASRESDEF_N.UNIT_BASE_ST_FLAG,
                    SEC_CHK_FLAG = :MRASRESDEF_N.SEC_CHK_FLAG,
                    GATHER_ALARM_FLAG = :MRASRESDEF_N.GATHER_ALARM_FLAG,
                    DELETE_FLAG = :MRASRESDEF_N.DELETE_FLAG,
                    DELETE_USER_ID = :MRASRESDEF_N.DELETE_USER_ID,
                    DELETE_TIME = :MRASRESDEF_N.DELETE_TIME,
                    CREATE_USER_ID = :MRASRESDEF_N.CREATE_USER_ID,
                    CREATE_TIME = :MRASRESDEF_N.CREATE_TIME,
                    UPDATE_USER_ID = :MRASRESDEF_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MRASRESDEF_N.UPDATE_TIME,
                    RES_UP_DOWN_FLAG = :MRASRESDEF_N.RES_UP_DOWN_FLAG,
                    RES_PRI_STS = :MRASRESDEF_N.RES_PRI_STS,
                    RES_STS_1 = :MRASRESDEF_N.RES_STS_1,
                    RES_STS_2 = :MRASRESDEF_N.RES_STS_2,
                    RES_STS_3 = :MRASRESDEF_N.RES_STS_3,
                    RES_STS_4 = :MRASRESDEF_N.RES_STS_4,
                    RES_STS_5 = :MRASRESDEF_N.RES_STS_5,
                    RES_STS_6 = :MRASRESDEF_N.RES_STS_6,
                    RES_STS_7 = :MRASRESDEF_N.RES_STS_7,
                    RES_STS_8 = :MRASRESDEF_N.RES_STS_8,
                    RES_STS_9 = :MRASRESDEF_N.RES_STS_9,
                    RES_STS_10 = :MRASRESDEF_N.RES_STS_10,
                    LOT_ID = :MRASRESDEF_N.LOT_ID,
                    SUBLOT_ID = :MRASRESDEF_N.SUBLOT_ID,
                    CRR_ID = :MRASRESDEF_N.CRR_ID,
                    RES_CTRL_MODE = :MRASRESDEF_N.RES_CTRL_MODE,
                    RES_PROC_MODE = :MRASRESDEF_N.RES_PROC_MODE,
                    LAST_RECIPE_ID = :MRASRESDEF_N.LAST_RECIPE_ID,
                    PROC_COUNT = :MRASRESDEF_N.PROC_COUNT,
                    LAST_START_TIME = :MRASRESDEF_N.LAST_START_TIME,
                    LAST_END_TIME = :MRASRESDEF_N.LAST_END_TIME,
                    LAST_DOWN_TIME = :MRASRESDEF_N.LAST_DOWN_TIME,
                    LAST_DOWN_HIST_SEQ = :MRASRESDEF_N.LAST_DOWN_HIST_SEQ,
                    LAST_EVENT_ID = :MRASRESDEF_N.LAST_EVENT_ID,
                    LAST_EVENT_TIME = :MRASRESDEF_N.LAST_EVENT_TIME,
                    LAST_ACTIVE_HIST_SEQ = :MRASRESDEF_N.LAST_ACTIVE_HIST_SEQ,
                    LAST_HIST_SEQ = :MRASRESDEF_N.LAST_HIST_SEQ,
					RES_SHORT_DESC = :MRASRESDEF_N.RES_SHORT_DESC
                 WHERE FACTORY = :MRASRESDEF_N.FACTORY
                    AND RES_ID = :MRASRESDEF_N.RES_ID;
            break;

        case 2:
            EXEC SQL UPDATE MRASRESDEF SET
                    RES_UP_DOWN_FLAG = :MRASRESDEF_N.RES_UP_DOWN_FLAG,
                    RES_PRI_STS = :MRASRESDEF_N.RES_PRI_STS,
                    RES_STS_1 = :MRASRESDEF_N.RES_STS_1,
                    RES_STS_2 = :MRASRESDEF_N.RES_STS_2,
                    RES_STS_3 = :MRASRESDEF_N.RES_STS_3,
                    RES_STS_4 = :MRASRESDEF_N.RES_STS_4,
                    RES_STS_5 = :MRASRESDEF_N.RES_STS_5,
                    RES_STS_6 = :MRASRESDEF_N.RES_STS_6,
                    RES_STS_7 = :MRASRESDEF_N.RES_STS_7,
                    RES_STS_8 = :MRASRESDEF_N.RES_STS_8,
                    RES_STS_9 = :MRASRESDEF_N.RES_STS_9,
                    RES_STS_10 = :MRASRESDEF_N.RES_STS_10,
                    LOT_ID = :MRASRESDEF_N.LOT_ID,
                    SUBLOT_ID = :MRASRESDEF_N.SUBLOT_ID,
                    CRR_ID = :MRASRESDEF_N.CRR_ID,
                    RES_CTRL_MODE = :MRASRESDEF_N.RES_CTRL_MODE,
                    RES_PROC_MODE = :MRASRESDEF_N.RES_PROC_MODE,
                    LAST_RECIPE_ID = :MRASRESDEF_N.LAST_RECIPE_ID,
                    PROC_COUNT = :MRASRESDEF_N.PROC_COUNT,
                    LAST_START_TIME = :MRASRESDEF_N.LAST_START_TIME,
                    LAST_END_TIME = :MRASRESDEF_N.LAST_END_TIME,
                    LAST_DOWN_TIME = :MRASRESDEF_N.LAST_DOWN_TIME,
                    LAST_DOWN_HIST_SEQ = :MRASRESDEF_N.LAST_DOWN_HIST_SEQ,
                    LAST_EVENT_ID = :MRASRESDEF_N.LAST_EVENT_ID,
                    LAST_EVENT_TIME = :MRASRESDEF_N.LAST_EVENT_TIME,
                    LAST_ACTIVE_HIST_SEQ = :MRASRESDEF_N.LAST_ACTIVE_HIST_SEQ,
                    LAST_HIST_SEQ = :MRASRESDEF_N.LAST_HIST_SEQ
                WHERE FACTORY = :MRASRESDEF_N.FACTORY
                    AND RES_ID = :MRASRESDEF_N.RES_ID;
            break;

        case 3:
            EXEC SQL UPDATE MRASRESDEF SET
                    LOT_ID = :MRASRESDEF_N.LOT_ID
                WHERE FACTORY = :MRASRESDEF_N.FACTORY
                    AND RES_ID = :MRASRESDEF_N.RES_ID;
            break;

        case 4:
            EXEC SQL UPDATE MRASRESDEF SET
                    RES_PRI_STS = :MRASRESDEF_N.RES_PRI_STS,
                    PROC_COUNT = :MRASRESDEF_N.PROC_COUNT
                WHERE FACTORY = :MRASRESDEF_N.FACTORY
                    AND RES_ID = :MRASRESDEF_N.RES_ID;
            break;

        case 5:
            EXEC SQL UPDATE MRASRESDEF SET
                    LAST_RECIPE_ID = :MRASRESDEF_N.LAST_RECIPE_ID
                WHERE FACTORY = :MRASRESDEF_N.FACTORY
                    AND RES_ID = :MRASRESDEF_N.RES_ID;
            break;

        case 101:
            EXEC SQL UPDATE MRASRESDEF SET
                    RES_CTRL_MODE = :MRASRESDEF_N.RES_CTRL_MODE
                WHERE FACTORY = :MRASRESDEF_N.FACTORY
                    AND RES_ID = :MRASRESDEF_N.RES_ID;
            break;
		
		case 102:
            EXEC SQL UPDATE MRASRESDEF SET
                    RES_CMF_9 = :MRASRESDEF_N.RES_CMF_9
                WHERE FACTORY = :MRASRESDEF_N.FACTORY
                    AND RES_ID = :MRASRESDEF_N.RES_ID;
            break;

		case 103:
            EXEC SQL UPDATE MRASRESDEF SET
                    RES_CTRL_MODE = :MRASRESDEF_N.RES_CTRL_MODE,
					RES_CMF_18 = :MRASRESDEF_N.RES_CMF_18,
					RES_CMF_19 = :MRASRESDEF_N.RES_CMF_19,
					RES_CMF_20 = :MRASRESDEF_N.RES_CMF_20
                WHERE FACTORY = :MRASRESDEF_N.FACTORY
                    AND RES_ID = :MRASRESDEF_N.RES_ID;
            break;
		case 104:
            EXEC SQL UPDATE MRASRESDEF SET
                    RES_STS_7 = :MRASRESDEF_N.RES_STS_7,
                    RES_STS_8 = :MRASRESDEF_N.RES_STS_8
                WHERE FACTORY = :MRASRESDEF_N.FACTORY
                    AND RES_ID = :MRASRESDEF_N.RES_ID;
            break;
		
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mrasresdef", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrasresdef(int sel_type, struct MRASRESDEF_TAG *MRASRESDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASRESDEF_N_TAG MRASRESDEF_N;
        char sql[5120];
        char ts[1024];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrasresdef(&MRASRESDEF_N, MRASRESDEF);
    DB_error_code = 0;
    memset( sql, 0x00, sizeof(sql));
    memset( ts, 0x00, sizeof(ts));

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRASRESDEF_CUR_1 CURSOR FOR
                SELECT RES_ID, RES_DESC, DELETE_FLAG, RES_UP_DOWN_FLAG, RES_SHORT_DESC
                FROM MRASRESDEF
                WHERE FACTORY = :MRASRESDEF_N.FACTORY
                    AND RES_ID >= :MRASRESDEF_N.RES_ID
                    AND RES_ID LIKE :MRASRESDEF_N.RES_DESC
                    AND RES_TYPE LIKE :MRASRESDEF_N.RES_TYPE
                    AND AREA_ID LIKE :MRASRESDEF_N.AREA_ID
                    AND SUB_AREA_ID LIKE :MRASRESDEF_N.SUB_AREA_ID
                    AND DELETE_FLAG LIKE :MRASRESDEF_N.DELETE_FLAG
                ORDER BY RES_ID ASC;
            EXEC SQL OPEN DBC_MRASRESDEF_CUR_1;
            break;

        case 2:
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "FACTORY, ");
            sprintf(sql + strlen(sql),   "RES_ID, ");
            sprintf(sql + strlen(sql),   "RES_DESC, ");
            sprintf(sql + strlen(sql),   "RES_TYPE, ");
            sprintf(sql + strlen(sql),   "RES_GRP_1, ");
            sprintf(sql + strlen(sql),   "RES_GRP_2, ");
            sprintf(sql + strlen(sql),   "RES_GRP_3, ");
            sprintf(sql + strlen(sql),   "RES_GRP_4, ");
            sprintf(sql + strlen(sql),   "RES_GRP_5, ");
            sprintf(sql + strlen(sql),   "RES_GRP_6, ");
            sprintf(sql + strlen(sql),   "RES_GRP_7, ");
            sprintf(sql + strlen(sql),   "RES_GRP_8, ");
            sprintf(sql + strlen(sql),   "RES_GRP_9, ");
            sprintf(sql + strlen(sql),   "RES_GRP_10, ");
            sprintf(sql + strlen(sql),   "USE_FAC_PRT_FLAG, ");
            sprintf(sql + strlen(sql),   "RES_STS_PRT_1, ");
            sprintf(sql + strlen(sql),   "RES_STS_PRT_2, ");
            sprintf(sql + strlen(sql),   "RES_STS_PRT_3, ");
            sprintf(sql + strlen(sql),   "RES_STS_PRT_4, ");
            sprintf(sql + strlen(sql),   "RES_STS_PRT_5, ");
            sprintf(sql + strlen(sql),   "RES_STS_PRT_6, ");
            sprintf(sql + strlen(sql),   "RES_STS_PRT_7, ");
            sprintf(sql + strlen(sql),   "RES_STS_PRT_8, ");
            sprintf(sql + strlen(sql),   "RES_STS_PRT_9, ");
            sprintf(sql + strlen(sql),   "RES_STS_PRT_10, ");
            sprintf(sql + strlen(sql),   "RES_CMF_1, ");
            sprintf(sql + strlen(sql),   "RES_CMF_2, ");
            sprintf(sql + strlen(sql),   "RES_CMF_3, ");
            sprintf(sql + strlen(sql),   "RES_CMF_4, ");
            sprintf(sql + strlen(sql),   "RES_CMF_5, ");
            sprintf(sql + strlen(sql),   "RES_CMF_6, ");
            sprintf(sql + strlen(sql),   "RES_CMF_7, ");
            sprintf(sql + strlen(sql),   "RES_CMF_8, ");
            sprintf(sql + strlen(sql),   "RES_CMF_9, ");
            sprintf(sql + strlen(sql),   "RES_CMF_10, ");
            sprintf(sql + strlen(sql),   "RES_CMF_11, ");
            sprintf(sql + strlen(sql),   "RES_CMF_12, ");
            sprintf(sql + strlen(sql),   "RES_CMF_13, ");
            sprintf(sql + strlen(sql),   "RES_CMF_14, ");
            sprintf(sql + strlen(sql),   "RES_CMF_15, ");
            sprintf(sql + strlen(sql),   "RES_CMF_16, ");
            sprintf(sql + strlen(sql),   "RES_CMF_17, ");
            sprintf(sql + strlen(sql),   "RES_CMF_18, ");
            sprintf(sql + strlen(sql),   "RES_CMF_19, ");
            sprintf(sql + strlen(sql),   "RES_CMF_20, ");
            sprintf(sql + strlen(sql),   "AREA_ID, ");
            sprintf(sql + strlen(sql),   "SUB_AREA_ID, ");
            sprintf(sql + strlen(sql),   "RES_LOCATION, ");
            sprintf(sql + strlen(sql),   "PROC_RULE, ");
            sprintf(sql + strlen(sql),   "MAX_PROC_COUNT, ");
            sprintf(sql + strlen(sql),   "BATCH_COND_1, ");
            sprintf(sql + strlen(sql),   "BATCH_COND_2, ");
            sprintf(sql + strlen(sql),   "PM_SCH_ENABLE_FLAG, ");
            sprintf(sql + strlen(sql),   "UNIT_BASE_ST_FLAG, ");
            sprintf(sql + strlen(sql),   "SEC_CHK_FLAG, ");
            sprintf(sql + strlen(sql),   "GATHER_ALARM_FLAG, ");
            sprintf(sql + strlen(sql),   "DELETE_FLAG, ");
            sprintf(sql + strlen(sql),   "DELETE_USER_ID, ");
            sprintf(sql + strlen(sql),   "DELETE_TIME, ");
            sprintf(sql + strlen(sql),   "CREATE_USER_ID, ");
            sprintf(sql + strlen(sql),   "CREATE_TIME, ");
            sprintf(sql + strlen(sql),   "UPDATE_USER_ID, ");
            sprintf(sql + strlen(sql),   "UPDATE_TIME, ");
            sprintf(sql + strlen(sql),   "RES_UP_DOWN_FLAG, ");
            sprintf(sql + strlen(sql),   "RES_PRI_STS, ");
            sprintf(sql + strlen(sql),   "RES_STS_1, ");
            sprintf(sql + strlen(sql),   "RES_STS_2, ");
            sprintf(sql + strlen(sql),   "RES_STS_3, ");
            sprintf(sql + strlen(sql),   "RES_STS_4, ");
            sprintf(sql + strlen(sql),   "RES_STS_5, ");
            sprintf(sql + strlen(sql),   "RES_STS_6, ");
            sprintf(sql + strlen(sql),   "RES_STS_7, ");
            sprintf(sql + strlen(sql),   "RES_STS_8, ");
            sprintf(sql + strlen(sql),   "RES_STS_9, ");
            sprintf(sql + strlen(sql),   "RES_STS_10, ");
            sprintf(sql + strlen(sql),   "LOT_ID, ");
            sprintf(sql + strlen(sql),   "SUBLOT_ID, ");
            sprintf(sql + strlen(sql),   "CRR_ID, ");
            sprintf(sql + strlen(sql),   "RES_CTRL_MODE, ");
            sprintf(sql + strlen(sql),   "RES_PROC_MODE, ");
            sprintf(sql + strlen(sql),   "LAST_RECIPE_ID, ");
            sprintf(sql + strlen(sql),   "PROC_COUNT, ");
            sprintf(sql + strlen(sql),   "LAST_START_TIME, ");
            sprintf(sql + strlen(sql),   "LAST_END_TIME, ");
            sprintf(sql + strlen(sql),   "LAST_DOWN_TIME, ");
            sprintf(sql + strlen(sql),   "LAST_DOWN_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "LAST_EVENT_ID, ");
            sprintf(sql + strlen(sql),   "LAST_EVENT_TIME, ");
            sprintf(sql + strlen(sql),   "LAST_ACTIVE_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "LAST_HIST_SEQ, ");
			sprintf(sql + strlen(sql),   "RES_SHORT_DESC ");
            sprintf(sql + strlen(sql), "FROM MRASRESDEF WHERE ");

            make_valid_quote(ts, MRASRESDEF_N.FACTORY);
            sprintf(sql + strlen(sql), "FACTORY = '%s' ", ts);
            make_valid_quote(ts, MRASRESDEF_N.RES_ID);
            sprintf(sql + strlen(sql), "AND RES_ID >= '%s' ", ts);
            
            if(ISSPACE(MRASRESDEF->RES_TYPE, sizeof(MRASRESDEF->RES_TYPE)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASRESDEF_N.RES_TYPE);
                sprintf(sql + strlen(sql), "AND RES_TYPE = '%s' ", ts);
            }
            
            sprintf(sql + strlen(sql), "AND DELETE_FLAG<>'Y' ORDER BY RES_ID ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MRASRESDEF_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MRASRESDEF_CUR_2;                 
            break;
            
        case 3:
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "A.FACTORY, ");
            sprintf(sql + strlen(sql),   "A.RES_ID, ");
            sprintf(sql + strlen(sql),   "A.RES_DESC, ");
            sprintf(sql + strlen(sql),   "A.RES_TYPE, ");
            sprintf(sql + strlen(sql),   "A.RES_GRP_1, ");
            sprintf(sql + strlen(sql),   "A.RES_GRP_2, ");
            sprintf(sql + strlen(sql),   "A.RES_GRP_3, ");
            sprintf(sql + strlen(sql),   "A.RES_GRP_4, ");
            sprintf(sql + strlen(sql),   "A.RES_GRP_5, ");
            sprintf(sql + strlen(sql),   "A.RES_GRP_6, ");
            sprintf(sql + strlen(sql),   "A.RES_GRP_7, ");
            sprintf(sql + strlen(sql),   "A.RES_GRP_8, ");
            sprintf(sql + strlen(sql),   "A.RES_GRP_9, ");
            sprintf(sql + strlen(sql),   "A.RES_GRP_10, ");
            sprintf(sql + strlen(sql),   "A.USE_FAC_PRT_FLAG, ");
            sprintf(sql + strlen(sql),   "A.RES_STS_PRT_1, ");
            sprintf(sql + strlen(sql),   "A.RES_STS_PRT_2, ");
            sprintf(sql + strlen(sql),   "A.RES_STS_PRT_3, ");
            sprintf(sql + strlen(sql),   "A.RES_STS_PRT_4, ");
            sprintf(sql + strlen(sql),   "A.RES_STS_PRT_5, ");
            sprintf(sql + strlen(sql),   "A.RES_STS_PRT_6, ");
            sprintf(sql + strlen(sql),   "A.RES_STS_PRT_7, ");
            sprintf(sql + strlen(sql),   "A.RES_STS_PRT_8, ");
            sprintf(sql + strlen(sql),   "A.RES_STS_PRT_9, ");
            sprintf(sql + strlen(sql),   "A.RES_STS_PRT_10, ");
            sprintf(sql + strlen(sql),   "A.RES_CMF_1, ");
            sprintf(sql + strlen(sql),   "A.RES_CMF_2, ");
            sprintf(sql + strlen(sql),   "A.RES_CMF_3, ");
            sprintf(sql + strlen(sql),   "A.RES_CMF_4, ");
            sprintf(sql + strlen(sql),   "A.RES_CMF_5, ");
