/* SQL CURSOR CLOSE Function */
void DBC_close_mrasresdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_1;
            break;
        case 2:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_2;
            break;            
        case 3:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_3;
            break;            
        case 4:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_4;
            break;
        case 5:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_5;
            break;
        case 6:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_6;
            break;
        case 7:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_7;
            break;
        case 8:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_8;
            break;
        case 9:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_9;
            break;  
        case 10:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_10;
            break;  
        case 11:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_11;
            break;  
        case 12:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_12;
            break;
		case 13:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_13;
            break;
      
	  case 101:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_101;
            break;

	  case 102:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_102;
            break;

	  case 103:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_103;
            break;

	  case 104:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_104;
            break;

	  case 105:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_105;
            break;

	  case 106:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_106;
            break;

	  case 107:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_107;
            break;

	  case 108:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_108;
            break;

	  case 201:
            EXEC SQL CLOSE DBC_MRASRESDEF_CUR_201;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mrasresdef", sel_type);
}

/* Initialize Function */
void DBC_init_mrasresdef(struct MRASRESDEF_TAG *MRASRESDEF)
{
    /* memset by Space */
    memset(MRASRESDEF, ' ', sizeof(struct MRASRESDEF_TAG));
    
    MRASRESDEF->MAX_PROC_COUNT = 0;
    MRASRESDEF->PROC_COUNT = 0;
    MRASRESDEF->LAST_DOWN_HIST_SEQ = 0;
    MRASRESDEF->LAST_ACTIVE_HIST_SEQ = 0;
    MRASRESDEF->LAST_HIST_SEQ = 0;
}


