    MRASRESDEF_N->LAST_HIST_SEQ = MRASRESDEF->LAST_HIST_SEQ;
    MEMCPY_AN(MRASRESDEF_N->RES_SHORT_DESC, MRASRESDEF->RES_SHORT_DESC, sizeof(MRASRESDEF->RES_SHORT_DESC));
}


