        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mrasresdef(&MRASRESDEF_N, MRASRESDEF);
    }
    DB_stop_query_timer("DBC_fetch_mrasresdef", sel_type);
