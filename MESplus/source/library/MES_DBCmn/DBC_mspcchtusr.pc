/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mspcchtusr(int sel_type, struct MSPCCHTUSR_TAG *MSPCCHTUSR)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSPCCHTUSR_N_TAG MSPCCHTUSR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mspcchtusr(&MSPCCHTUSR_N, MSPCCHTUSR);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSPCCHTUSR_CUR_1 CURSOR FOR
                SELECT USER_ID, USER_DESC, SEC_GRP_ID, EMAIL_ID 
                FROM MSPCCHTUSR
                WHERE FACTORY = :MSPCCHTUSR_N.FACTORY
                    AND CHART_ID = :MSPCCHTUSR_N.CHART_ID
                    AND USER_ID >= :MSPCCHTUSR_N.USER_ID
                ORDER BY USER_ID ASC;
            EXEC SQL OPEN DBC_MSPCCHTUSR_CUR_1;
            break;
  
       case 2:
            EXEC SQL DECLARE DBC_MSPCCHTUSR_CUR_2 CURSOR FOR
                SELECT A.CHART_ID, B.CHART_DESC
                FROM MSPCCHTUSR A, MSPCCHTDEF B
                WHERE A.FACTORY = :MSPCCHTUSR_N.FACTORY
                    AND A.USER_ID = :MSPCCHTUSR_N.USER_ID
                    AND A.FACTORY = B.FACTORY
                    AND A.CHART_ID = B.CHART_ID
                    AND B.DELETE_FLAG <> 'Y'
                    AND A.CHART_ID >= :MSPCCHTUSR_N.CHART_ID
                ORDER BY A.CHART_ID ASC;
            EXEC SQL OPEN DBC_MSPCCHTUSR_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mspcchtusr", sel_type);
}


