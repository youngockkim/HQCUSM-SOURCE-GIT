    MEMCPY_AN(MRCPMFODEF_N->SUBRES_ID, MRCPMFODEF->SUBRES_ID, sizeof(MRCPMFODEF->SUBRES_ID));
    MRCPMFODEF_N->OPT_LEVEL[0] = MRCPMFODEF->OPT_LEVEL;
    MEMCPY_AN(MRCPMFODEF_N->RECIPE, MRCPMFODEF->RECIPE, sizeof(MRCPMFODEF->RECIPE));
    MEMCPY_AN(MRCPMFODEF_N->CREATE_USER_ID, MRCPMFODEF->CREATE_USER_ID, sizeof(MRCPMFODEF->CREATE_USER_ID));
    MEMCPY_AN(MRCPMFODEF_N->CREATE_TIME, MRCPMFODEF->CREATE_TIME, sizeof(MRCPMFODEF->CREATE_TIME));
    MEMCPY_AN(MRCPMFODEF_N->UPDATE_USER_ID, MRCPMFODEF->UPDATE_USER_ID, sizeof(MRCPMFODEF->UPDATE_USER_ID));
    MEMCPY_AN(MRCPMFODEF_N->UPDATE_TIME, MRCPMFODEF->UPDATE_TIME, sizeof(MRCPMFODEF->UPDATE_TIME));
