            break;
            
        case 4:
            EXEC SQL FETCH DBC_MQCMSETITM_CUR_4 INTO :MQCMSETITM_N.INSP_SET_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mqcmsetitm(&MQCMSETITM_N, MQCMSETITM);
    }
    DB_stop_query_timer("DBC_fetch_mqcmsetitm", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mqcmsetitm(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MQCMSETITM_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_MQCMSETITM_CUR_2;
            break;
            
        case 3:
            EXEC SQL CLOSE DBC_MQCMSETITM_CUR_3;
            break;
            
        case 4:
            EXEC SQL CLOSE DBC_MQCMSETITM_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mqcmsetitm", sel_type);
}


/* Initialize Function */
void DBC_init_mqcmsetitm(struct MQCMSETITM_TAG *MQCMSETITM)
{
    /* memset by Space */
    memset(MQCMSETITM, ' ', sizeof(struct MQCMSETITM_TAG));
    
    MQCMSETITM->INSP_SET_VERSION = 0;
    MQCMSETITM->SEQ_NUM = 0;
}


/* Add Null Function */
void DBC_add_null_mqcmsetitm(struct MQCMSETITM_N_TAG *MQCMSETITM_N, struct MQCMSETITM_TAG *MQCMSETITM)
{
    /* memset by NULL */
    memset(MQCMSETITM_N, '\0', sizeof(struct MQCMSETITM_N_TAG));
    
    MEMCPY_AN(MQCMSETITM_N->FACTORY, MQCMSETITM->FACTORY, sizeof(MQCMSETITM->FACTORY));
