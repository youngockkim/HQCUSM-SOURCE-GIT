/* SQL UPDATE Function */
void DBC_update_mfmbresloc(int sel_type, struct MFMBRESLOC_TAG *MFMBRESLOC)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MFMBRESLOC_N_TAG MFMBRESLOC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mfmbresloc(&MFMBRESLOC_N, MFMBRESLOC);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MFMBRESLOC SET
                    SEQ = :MFMBRESLOC_N.SEQ,
                    LOC_X = :MFMBRESLOC_N.LOC_X,
                    LOC_Y = :MFMBRESLOC_N.LOC_Y,
                    LOC_WIDTH = :MFMBRESLOC_N.LOC_WIDTH,
                    LOC_HEIGHT = :MFMBRESLOC_N.LOC_HEIGHT,
                    TEXT = :MFMBRESLOC_N.TEXT,
                    TEXT_SIZE = :MFMBRESLOC_N.TEXT_SIZE,
                    TEXT_COLOR = :MFMBRESLOC_N.TEXT_COLOR,
                    TEXT_STYLE = :MFMBRESLOC_N.TEXT_STYLE,
                    TAG_TYPE = :MFMBRESLOC_N.TAG_TYPE,
                    BACK_COLOR = :MFMBRESLOC_N.BACK_COLOR,
                    CREATE_USER_ID = :MFMBRESLOC_N.CREATE_USER_ID,
                    CREATE_TIME = :MFMBRESLOC_N.CREATE_TIME,
                    UPDATE_USER_ID = :MFMBRESLOC_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MFMBRESLOC_N.UPDATE_TIME,
                    NO_MOUSE_EVENT = :MFMBRESLOC_N.NO_MOUSE_EVENT,
                    SIGNAL_FLAG = :MFMBRESLOC_N.SIGNAL_FLAG,
                    ANGLE = :MFMBRESLOC_N.ANGLE,
                    RES_SHAPE = :MFMBRESLOC_N.RES_SHAPE
                WHERE FACTORY = :MFMBRESLOC_N.FACTORY
                    AND RES_ID = :MFMBRESLOC_N.RES_ID
                    AND RES_TYPE = :MFMBRESLOC_N.RES_TYPE
                    AND LAYOUT_ID = :MFMBRESLOC_N.LAYOUT_ID;
            break;

        case 2:
            EXEC SQL UPDATE MFMBRESLOC SET
                    SEQ = :MFMBRESLOC_N.SEQ,
                    LAYOUT_ID = :MFMBRESLOC_N.LAYOUT_ID,
                    LOC_X = :MFMBRESLOC_N.LOC_X,
                    LOC_Y = :MFMBRESLOC_N.LOC_Y,
                    LOC_WIDTH = :MFMBRESLOC_N.LOC_WIDTH,
                    LOC_HEIGHT = :MFMBRESLOC_N.LOC_HEIGHT,
                    TEXT = :MFMBRESLOC_N.TEXT,
                    TEXT_SIZE = :MFMBRESLOC_N.TEXT_SIZE,
                    TEXT_COLOR = :MFMBRESLOC_N.TEXT_COLOR,
                    TEXT_STYLE = :MFMBRESLOC_N.TEXT_STYLE,
                    TAG_TYPE = :MFMBRESLOC_N.TAG_TYPE,
                    BACK_COLOR = :MFMBRESLOC_N.BACK_COLOR,
                    CREATE_USER_ID = :MFMBRESLOC_N.CREATE_USER_ID,
                    CREATE_TIME = :MFMBRESLOC_N.CREATE_TIME,
                    UPDATE_USER_ID = :MFMBRESLOC_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MFMBRESLOC_N.UPDATE_TIME,
                    NO_MOUSE_EVENT = :MFMBRESLOC_N.NO_MOUSE_EVENT,
                    SIGNAL_FLAG = :MFMBRESLOC_N.SIGNAL_FLAG,
                    ANGLE = :MFMBRESLOC_N.ANGLE,
                    RES_SHAPE = :MFMBRESLOC_N.RES_SHAPE
                WHERE FACTORY = :MFMBRESLOC_N.FACTORY
                    AND RES_ID = :MFMBRESLOC_N.RES_ID
                    AND RES_TYPE = :MFMBRESLOC_N.RES_TYPE;
            break;
     
        case 3:
            EXEC SQL UPDATE MFMBRESLOC SET
                    LOC_X = :MFMBRESLOC_N.LOC_WIDTH - LOC_WIDTH
                WHERE FACTORY = :MFMBRESLOC_N.FACTORY
                    AND LAYOUT_ID = :MFMBRESLOC_N.LAYOUT_ID
                    AND LOC_X + LOC_WIDTH > :MFMBRESLOC_N.LOC_WIDTH;
            break;            

        case 4:
            EXEC SQL UPDATE MFMBRESLOC SET
                    LOC_Y = :MFMBRESLOC_N.LOC_HEIGHT - LOC_HEIGHT
                WHERE FACTORY = :MFMBRESLOC_N.FACTORY
                    AND LAYOUT_ID = :MFMBRESLOC_N.LAYOUT_ID
                    AND LOC_Y + LOC_HEIGHT > :MFMBRESLOC_N.LOC_HEIGHT;
            break; 
      
        case 5:
            EXEC SQL UPDATE MFMBRESLOC SET
                    SEQ = SEQ - 1
                WHERE FACTORY = :MFMBRESLOC_N.FACTORY
                    AND LAYOUT_ID = :MFMBRESLOC_N.LAYOUT_ID
                    AND SEQ > :MFMBRESLOC_N.SEQ;
            break; 
      
        case 6:
            EXEC SQL UPDATE MFMBRESLOC SET
                    SEQ = SEQ + 1
                WHERE FACTORY = :MFMBRESLOC_N.FACTORY
                    AND LAYOUT_ID = :MFMBRESLOC_N.LAYOUT_ID
                    AND SEQ < :MFMBRESLOC_N.SEQ;
            break;             
            
       case 7:
            EXEC SQL UPDATE MFMBRESLOC SET
                    SEQ = :MFMBRESLOC_N.SEQ,
                    LAYOUT_ID = :MFMBRESLOC_N.LAYOUT_ID,
                    LOC_X = :MFMBRESLOC_N.LOC_X,
                    LOC_Y = :MFMBRESLOC_N.LOC_Y,
                    LOC_WIDTH = :MFMBRESLOC_N.LOC_WIDTH,
                    LOC_HEIGHT = :MFMBRESLOC_N.LOC_HEIGHT,
                    TEXT = :MFMBRESLOC_N.TEXT,
                    TEXT_SIZE = :MFMBRESLOC_N.TEXT_SIZE,
                    TEXT_COLOR = :MFMBRESLOC_N.TEXT_COLOR,
                    TEXT_STYLE = :MFMBRESLOC_N.TEXT_STYLE,
                    TAG_TYPE = :MFMBRESLOC_N.TAG_TYPE,
                    BACK_COLOR = :MFMBRESLOC_N.BACK_COLOR,
                    CREATE_USER_ID = :MFMBRESLOC_N.CREATE_USER_ID,
                    CREATE_TIME = :MFMBRESLOC_N.CREATE_TIME,
                    UPDATE_USER_ID = :MFMBRESLOC_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MFMBRESLOC_N.UPDATE_TIME,
                    NO_MOUSE_EVENT = :MFMBRESLOC_N.NO_MOUSE_EVENT,
                    SIGNAL_FLAG = :MFMBRESLOC_N.SIGNAL_FLAG,
                    ANGLE = :MFMBRESLOC_N.ANGLE,
                    RES_SHAPE = :MFMBRESLOC_N.RES_SHAPE
                WHERE FACTORY = :MFMBRESLOC_N.FACTORY
                    AND RES_ID = :MFMBRESLOC_N.RES_ID
                    AND RES_TYPE = :MFMBRESLOC_N.RES_TYPE
                    AND MOTHER_RES_ID = :MFMBRESLOC_N.MOTHER_RES_ID;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mfmbresloc", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mfmbresloc(int sel_type, struct MFMBRESLOC_TAG *MFMBRESLOC)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MFMBRESLOC_N_TAG MFMBRESLOC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mfmbresloc(&MFMBRESLOC_N, MFMBRESLOC);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
             EXEC SQL DECLARE DBC_MFMBRESLOC_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    RES_TYPE,
                    LAYOUT_ID,
                    SEQ,
                    LOC_X,
                    LOC_Y,
                    LOC_WIDTH,
                    LOC_HEIGHT,
                    TEXT,
                    TEXT_SIZE,
                    TEXT_COLOR,
                    TEXT_STYLE,
                    TAG_TYPE,
                    BACK_COLOR,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    NO_MOUSE_EVENT,
                    SIGNAL_FLAG,
                    MOTHER_RES_ID,
                    ANGLE,
                    RES_SHAPE
                FROM MFMBRESLOC
                WHERE FACTORY = :MFMBRESLOC_N.FACTORY
                AND LAYOUT_ID =  :MFMBRESLOC_N.LAYOUT_ID
                AND RES_ID >= :MFMBRESLOC_N.RES_ID
                AND RES_TYPE = 'T' 
                ORDER BY SEQ;
            EXEC SQL OPEN DBC_MFMBRESLOC_CUR_1;
            break;
        
        case 2:
             EXEC SQL DECLARE DBC_MFMBRESLOC_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    RES_TYPE,
                    LAYOUT_ID,
                    SEQ,
                    LOC_X,
                    LOC_Y,
                    LOC_WIDTH,
                    LOC_HEIGHT,
                    TEXT,
                    TEXT_SIZE,
                    TEXT_COLOR,
                    TEXT_STYLE,
                    TAG_TYPE,
                    BACK_COLOR,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    NO_MOUSE_EVENT,
                    SIGNAL_FLAG,
                    MOTHER_RES_ID,
                    ANGLE,
                    RES_SHAPE
                FROM MFMBRESLOC
                WHERE FACTORY = :MFMBRESLOC_N.FACTORY
                AND LAYOUT_ID =  :MFMBRESLOC_N.LAYOUT_ID
                AND RES_ID >= :MFMBRESLOC_N.RES_ID
                AND RES_TYPE = 'R' 
                ORDER BY RES_ID;
            EXEC SQL OPEN DBC_MFMBRESLOC_CUR_2;
            break;
           
        case 3:
             EXEC SQL DECLARE DBC_MFMBRESLOC_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    RES_TYPE,
                    LAYOUT_ID,
                    SEQ,
                    LOC_X,
                    LOC_Y,
                    LOC_WIDTH,
                    LOC_HEIGHT,
                    TEXT,
                    TEXT_SIZE,
                    TEXT_COLOR,
                    TEXT_STYLE,
                    TAG_TYPE,
                    BACK_COLOR,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    NO_MOUSE_EVENT,
                    SIGNAL_FLAG,
                    MOTHER_RES_ID,
                    ANGLE,
                    RES_SHAPE
                FROM MFMBRESLOC
                WHERE FACTORY = :MFMBRESLOC_N.FACTORY
                AND LAYOUT_ID =  :MFMBRESLOC_N.LAYOUT_ID
                AND RES_ID >= :MFMBRESLOC_N.RES_ID
                AND RES_TYPE = :MFMBRESLOC_N.RES_TYPE
                ORDER BY RES_ID;
            EXEC SQL OPEN DBC_MFMBRESLOC_CUR_3;
            break;
            
         case 4:
             EXEC SQL DECLARE DBC_MFMBRESLOC_CUR_4 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    RES_TYPE,
                    LAYOUT_ID,
                    SEQ,
                    LOC_X,
                    LOC_Y,
                    LOC_WIDTH,
                    LOC_HEIGHT,
                    TEXT,
                    TEXT_SIZE,
                    TEXT_COLOR,
                    TEXT_STYLE,
                    TAG_TYPE,
                    BACK_COLOR,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    NO_MOUSE_EVENT,
                    SIGNAL_FLAG,
                    MOTHER_RES_ID,
                    ANGLE,
                    RES_SHAPE
                FROM MFMBRESLOC
                WHERE FACTORY = :MFMBRESLOC_N.FACTORY
                AND LAYOUT_ID =  :MFMBRESLOC_N.LAYOUT_ID
                AND RES_ID >= :MFMBRESLOC_N.RES_ID
                AND RES_TYPE = :MFMBRESLOC_N.RES_TYPE
                AND MOTHER_RES_ID NOT IN (SELECT RES_ID FROM MFMBRESLOC WHERE FACTORY = :MFMBRESLOC_N.FACTORY AND RES_TYPE = 'R' AND LAYOUT_ID = :MFMBRESLOC_N.LAYOUT_ID)
                ORDER BY RES_ID;
            EXEC SQL OPEN DBC_MFMBRESLOC_CUR_4;
            break;
                                          

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mfmbresloc", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mfmbresloc(int sel_type, struct MFMBRESLOC_TAG *MFMBRESLOC)
{
    EXEC SQL BEGIN DECLARE SECTION;
