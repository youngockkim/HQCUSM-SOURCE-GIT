    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mfmbresloc(&MFMBRESLOC_N, MFMBRESLOC);
    }
    DB_stop_query_timer("DBC_fetch_mfmbresloc", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mfmbresloc(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MFMBRESLOC_CUR_1;
            break;
        case 2:
            EXEC SQL CLOSE DBC_MFMBRESLOC_CUR_2;
            break;
        case 3:
            EXEC SQL CLOSE DBC_MFMBRESLOC_CUR_3;
            break;    
        case 4:
            EXEC SQL CLOSE DBC_MFMBRESLOC_CUR_4;
            break; 


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mfmbresloc", sel_type);
}


/* Initialize Function */
void DBC_init_mfmbresloc(struct MFMBRESLOC_TAG *MFMBRESLOC)
{
    /* memset by Space */
    memset(MFMBRESLOC, ' ', sizeof(struct MFMBRESLOC_TAG));
    
    MFMBRESLOC->SEQ = 0;
    MFMBRESLOC->LOC_X = 0;
    MFMBRESLOC->LOC_Y = 0;
    MFMBRESLOC->LOC_WIDTH = 0;
    MFMBRESLOC->LOC_HEIGHT = 0;
    MFMBRESLOC->TEXT_SIZE = 0;
    MFMBRESLOC->TEXT_COLOR = 0;
    MFMBRESLOC->TAG_TYPE = 0;
    MFMBRESLOC->BACK_COLOR = 0;
    MFMBRESLOC->ANGLE = 0;
}


/* Add Null Function */
void DBC_add_null_mfmbresloc(struct MFMBRESLOC_N_TAG *MFMBRESLOC_N, struct MFMBRESLOC_TAG *MFMBRESLOC)
{
    /* memset by NULL */
    memset(MFMBRESLOC_N, '\0', sizeof(struct MFMBRESLOC_N_TAG));
    
    MEMCPY_AN(MFMBRESLOC_N->FACTORY, MFMBRESLOC->FACTORY, sizeof(MFMBRESLOC->FACTORY));
    MEMCPY_AN(MFMBRESLOC_N->RES_ID, MFMBRESLOC->RES_ID, sizeof(MFMBRESLOC->RES_ID));
    MFMBRESLOC_N->RES_TYPE[0] = MFMBRESLOC->RES_TYPE;
    MEMCPY_AN(MFMBRESLOC_N->LAYOUT_ID, MFMBRESLOC->LAYOUT_ID, sizeof(MFMBRESLOC->LAYOUT_ID));
    MFMBRESLOC_N->SEQ = MFMBRESLOC->SEQ;
    MFMBRESLOC_N->LOC_X = MFMBRESLOC->LOC_X;
    MFMBRESLOC_N->LOC_Y = MFMBRESLOC->LOC_Y;
    MFMBRESLOC_N->LOC_WIDTH = MFMBRESLOC->LOC_WIDTH;
    MFMBRESLOC_N->LOC_HEIGHT = MFMBRESLOC->LOC_HEIGHT;
    MEMCPY_AN(MFMBRESLOC_N->TEXT, MFMBRESLOC->TEXT, sizeof(MFMBRESLOC->TEXT));
    MFMBRESLOC_N->TEXT_SIZE = MFMBRESLOC->TEXT_SIZE;
    MFMBRESLOC_N->TEXT_COLOR = MFMBRESLOC->TEXT_COLOR;
    MFMBRESLOC_N->TEXT_STYLE[0] = MFMBRESLOC->TEXT_STYLE;
    MFMBRESLOC_N->TAG_TYPE = MFMBRESLOC->TAG_TYPE;
    MFMBRESLOC_N->BACK_COLOR = MFMBRESLOC->BACK_COLOR;
    MEMCPY_AN(MFMBRESLOC_N->CREATE_USER_ID, MFMBRESLOC->CREATE_USER_ID, sizeof(MFMBRESLOC->CREATE_USER_ID));
    MEMCPY_AN(MFMBRESLOC_N->CREATE_TIME, MFMBRESLOC->CREATE_TIME, sizeof(MFMBRESLOC->CREATE_TIME));
    MEMCPY_AN(MFMBRESLOC_N->UPDATE_USER_ID, MFMBRESLOC->UPDATE_USER_ID, sizeof(MFMBRESLOC->UPDATE_USER_ID));
    MEMCPY_AN(MFMBRESLOC_N->UPDATE_TIME, MFMBRESLOC->UPDATE_TIME, sizeof(MFMBRESLOC->UPDATE_TIME));
    MFMBRESLOC_N->NO_MOUSE_EVENT[0] = MFMBRESLOC->NO_MOUSE_EVENT;
    MFMBRESLOC_N->SIGNAL_FLAG[0] = MFMBRESLOC->SIGNAL_FLAG;
    MEMCPY_AN(MFMBRESLOC_N->MOTHER_RES_ID, MFMBRESLOC->MOTHER_RES_ID, sizeof(MFMBRESLOC->MOTHER_RES_ID));
    MFMBRESLOC_N->ANGLE = MFMBRESLOC->ANGLE;
    MFMBRESLOC_N->RES_SHAPE[0] = MFMBRESLOC->RES_SHAPE;
}


/* Del Null Function */
void DBC_del_null_mfmbresloc(struct MFMBRESLOC_N_TAG *MFMBRESLOC_N, struct MFMBRESLOC_TAG *MFMBRESLOC)
{
    MEMCPY_DN(MFMBRESLOC->FACTORY, MFMBRESLOC_N->FACTORY, sizeof(MFMBRESLOC->FACTORY));
    MEMCPY_DN(MFMBRESLOC->RES_ID, MFMBRESLOC_N->RES_ID, sizeof(MFMBRESLOC->RES_ID));
    MFMBRESLOC->RES_TYPE = MFMBRESLOC_N->RES_TYPE[0];
    MEMCPY_DN(MFMBRESLOC->LAYOUT_ID, MFMBRESLOC_N->LAYOUT_ID, sizeof(MFMBRESLOC->LAYOUT_ID));
    MFMBRESLOC->SEQ = MFMBRESLOC_N->SEQ;
    MFMBRESLOC->LOC_X = MFMBRESLOC_N->LOC_X;
    MFMBRESLOC->LOC_Y = MFMBRESLOC_N->LOC_Y;
    MFMBRESLOC->LOC_WIDTH = MFMBRESLOC_N->LOC_WIDTH;
    MFMBRESLOC->LOC_HEIGHT = MFMBRESLOC_N->LOC_HEIGHT;
    MEMCPY_DN(MFMBRESLOC->TEXT, MFMBRESLOC_N->TEXT, sizeof(MFMBRESLOC->TEXT));
    MFMBRESLOC->TEXT_SIZE = MFMBRESLOC_N->TEXT_SIZE;
    MFMBRESLOC->TEXT_COLOR = MFMBRESLOC_N->TEXT_COLOR;
    MFMBRESLOC->TEXT_STYLE = MFMBRESLOC_N->TEXT_STYLE[0];
    MFMBRESLOC->TAG_TYPE = MFMBRESLOC_N->TAG_TYPE;
    MFMBRESLOC->BACK_COLOR = MFMBRESLOC_N->BACK_COLOR;
    MEMCPY_DN(MFMBRESLOC->CREATE_USER_ID, MFMBRESLOC_N->CREATE_USER_ID, sizeof(MFMBRESLOC->CREATE_USER_ID));
    MEMCPY_DN(MFMBRESLOC->CREATE_TIME, MFMBRESLOC_N->CREATE_TIME, sizeof(MFMBRESLOC->CREATE_TIME));
    MEMCPY_DN(MFMBRESLOC->UPDATE_USER_ID, MFMBRESLOC_N->UPDATE_USER_ID, sizeof(MFMBRESLOC->UPDATE_USER_ID));
    MEMCPY_DN(MFMBRESLOC->UPDATE_TIME, MFMBRESLOC_N->UPDATE_TIME, sizeof(MFMBRESLOC->UPDATE_TIME));
    MFMBRESLOC->NO_MOUSE_EVENT = MFMBRESLOC_N->NO_MOUSE_EVENT[0];
    MFMBRESLOC->SIGNAL_FLAG = MFMBRESLOC_N->SIGNAL_FLAG[0];
    MEMCPY_DN(MFMBRESLOC->MOTHER_RES_ID, MFMBRESLOC_N->MOTHER_RES_ID, sizeof(MFMBRESLOC->MOTHER_RES_ID));
    MFMBRESLOC->ANGLE = MFMBRESLOC_N->ANGLE;
    MFMBRESLOC->RES_SHAPE = MFMBRESLOC_N->RES_SHAPE[0];
}


