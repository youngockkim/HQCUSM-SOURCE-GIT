/* SQL SELECT_SCALAR Function */
double DBC_select_mfmbresloc_scalar(int sel_type, struct MFMBRESLOC_TAG *MFMBRESLOC)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MFMBRESLOC_N_TAG MFMBRESLOC_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mfmbresloc(&MFMBRESLOC_N, MFMBRESLOC);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MFMBRESLOC
                WHERE FACTORY = :MFMBRESLOC_N.FACTORY
                    AND LAYOUT_ID = :MFMBRESLOC_N.LAYOUT_ID;
            break;

        case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MFMBRESLOC
                WHERE FACTORY = :MFMBRESLOC_N.FACTORY
                    AND LAYOUT_ID = :MFMBRESLOC_N.LAYOUT_ID
                    AND (LOC_X+LOC_WIDTH > :MFMBRESLOC_N.LOC_WIDTH 
                    OR   LOC_Y+LOC_HEIGHT > :MFMBRESLOC_N.LOC_HEIGHT);
            break;

        case 3:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MFMBRESLOC
                WHERE FACTORY = :MFMBRESLOC_N.FACTORY
                    AND RES_ID = :MFMBRESLOC_N.RES_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mfmbresloc_scalar", sel_type);
    return d_value;
}


