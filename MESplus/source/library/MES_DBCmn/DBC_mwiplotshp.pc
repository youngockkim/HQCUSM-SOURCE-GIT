/* Add Null Function */
void DBC_add_null_mwiplotshp(struct MWIPLOTSHP_N_TAG *MWIPLOTSHP_N, struct MWIPLOTSHP_TAG *MWIPLOTSHP)
{
    /* memset by NULL */
    memset(MWIPLOTSHP_N, '\0', sizeof(struct MWIPLOTSHP_N_TAG));
    
    MEMCPY_AN(MWIPLOTSHP_N->LOT_ID, MWIPLOTSHP->LOT_ID, sizeof(MWIPLOTSHP->LOT_ID));
    MWIPLOTSHP_N->HIST_SEQ = MWIPLOTSHP->HIST_SEQ;
    MEMCPY_AN(MWIPLOTSHP_N->TRAN_TIME, MWIPLOTSHP->TRAN_TIME, sizeof(MWIPLOTSHP->TRAN_TIME));
    MWIPLOTSHP_N->HIST_DEL_FLAG[0] = MWIPLOTSHP->HIST_DEL_FLAG;
    MEMCPY_AN(MWIPLOTSHP_N->FACTORY, MWIPLOTSHP->FACTORY, sizeof(MWIPLOTSHP->FACTORY));
    MEMCPY_AN(MWIPLOTSHP_N->MAT_ID, MWIPLOTSHP->MAT_ID, sizeof(MWIPLOTSHP->MAT_ID));
    MWIPLOTSHP_N->MAT_VER = MWIPLOTSHP->MAT_VER;
    MEMCPY_AN(MWIPLOTSHP_N->FLOW, MWIPLOTSHP->FLOW, sizeof(MWIPLOTSHP->FLOW));
    MWIPLOTSHP_N->FLOW_SEQ_NUM = MWIPLOTSHP->FLOW_SEQ_NUM;
