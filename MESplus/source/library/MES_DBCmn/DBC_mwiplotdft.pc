                                                    :MWIPLOTDFT_N.CELL_X,
                                                    :MWIPLOTDFT_N.CELL_Y,
                                                    :MWIPLOTDFT_N.CELL_Z,
                                                    :MWIPLOTDFT_N.LOC_X,
                                                    :MWIPLOTDFT_N.LOC_Y,
                                                    :MWIPLOTDFT_N.LOC_Z,
                                                    :MWIPLOTDFT_N.TRAN_TIME,
                                                    :MWIPLOTDFT_N.SYS_TRAN_TIME,
                                                    :MWIPLOTDFT_N.TRAN_USER_ID,
                                                    :MWIPLOTDFT_N.CLEAN_FLAG,
                                                    :MWIPLOTDFT_N.CLEAN_HIST_SEQ,
                                                    :MWIPLOTDFT_N.CLEAN_USER_ID,
                                                    :MWIPLOTDFT_N.CLEAN_TIME,
                                                    :MWIPLOTDFT_N.MAT_ID,
                                                    :MWIPLOTDFT_N.MAT_VER,
                                                    :MWIPLOTDFT_N.FLOW,
                                                    :MWIPLOTDFT_N.OPER,
                                                    :MWIPLOTDFT_N.RES_ID,
                                                    :MWIPLOTDFT_N.SUBRES_ID,
                                                    :MWIPLOTDFT_N.CAUSE_FLOW,
                                                    :MWIPLOTDFT_N.CAUSE_OPER,
                                                    :MWIPLOTDFT_N.CAUSE_RES_ID,
                                                    :MWIPLOTDFT_N.CAUSE_SUBRES_ID,
                                                    :MWIPLOTDFT_N.CHK_USER_ID_1,
                                                    :MWIPLOTDFT_N.CHK_USER_ID_2,
                                                    :MWIPLOTDFT_N.ATTACH_FILE_1,
                                                    :MWIPLOTDFT_N.ATTACH_FILE_2,
                                                    :MWIPLOTDFT_N.ATTACH_FILE_3,
                                                    :MWIPLOTDFT_N.ATTACH_FILE_4,
                                                    :MWIPLOTDFT_N.ATTACH_FILE_5,
                                                    :MWIPLOTDFT_N.DEFECT_COMMENT;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwiplotdft(&MWIPLOTDFT_N, MWIPLOTDFT);
    }
    DB_stop_query_timer("DBC_fetch_mwiplotdft", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwiplotdft(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPLOTDFT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwiplotdft", sel_type);
}


/* Initialize Function */
void DBC_init_mwiplotdft(struct MWIPLOTDFT_TAG *MWIPLOTDFT)
{
    /* memset by Space */
    memset(MWIPLOTDFT, ' ', sizeof(struct MWIPLOTDFT_TAG));
    
    MWIPLOTDFT->HIST_SEQ = 0;
    MWIPLOTDFT->SEQ_NUM = 0;
    MWIPLOTDFT->DEFECT_QTY = 0;
    MWIPLOTDFT->CELL_X = 0;
    MWIPLOTDFT->CELL_Y = 0;
    MWIPLOTDFT->CELL_Z = 0;
    MWIPLOTDFT->LOC_X = 0;
    MWIPLOTDFT->LOC_Y = 0;
    MWIPLOTDFT->LOC_Z = 0;
    MWIPLOTDFT->CLEAN_HIST_SEQ = 0;
    MWIPLOTDFT->MAT_VER = 0;
}


/* Add Null Function */
void DBC_add_null_mwiplotdft(struct MWIPLOTDFT_N_TAG *MWIPLOTDFT_N, struct MWIPLOTDFT_TAG *MWIPLOTDFT)
{
    /* memset by NULL */
    memset(MWIPLOTDFT_N, '\0', sizeof(struct MWIPLOTDFT_N_TAG));
    
    MEMCPY_AN(MWIPLOTDFT_N->LOT_ID, MWIPLOTDFT->LOT_ID, sizeof(MWIPLOTDFT->LOT_ID));
    MEMCPY_AN(MWIPLOTDFT_N->SUBLOT_ID, MWIPLOTDFT->SUBLOT_ID, sizeof(MWIPLOTDFT->SUBLOT_ID));
