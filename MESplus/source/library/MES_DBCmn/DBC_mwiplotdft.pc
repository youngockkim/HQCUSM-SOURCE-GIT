    MWIPLOTDFT_N->LOC_Y = MWIPLOTDFT->LOC_Y;
    MWIPLOTDFT_N->LOC_Z = MWIPLOTDFT->LOC_Z;
    MEMCPY_AN(MWIPLOTDFT_N->TRAN_TIME, MWIPLOTDFT->TRAN_TIME, sizeof(MWIPLOTDFT->TRAN_TIME));
    MEMCPY_AN(MWIPLOTDFT_N->SYS_TRAN_TIME, MWIPLOTDFT->SYS_TRAN_TIME, sizeof(MWIPLOTDFT->SYS_TRAN_TIME));
    MEMCPY_AN(MWIPLOTDFT_N->TRAN_USER_ID, MWIPLOTDFT->TRAN_USER_ID, sizeof(MWIPLOTDFT->TRAN_USER_ID));
    MWIPLOTDFT_N->CLEAN_FLAG[0] = MWIPLOTDFT->CLEAN_FLAG;
    MWIPLOTDFT_N->CLEAN_HIST_SEQ = MWIPLOTDFT->CLEAN_HIST_SEQ;
    MEMCPY_AN(MWIPLOTDFT_N->CLEAN_USER_ID, MWIPLOTDFT->CLEAN_USER_ID, sizeof(MWIPLOTDFT->CLEAN_USER_ID));
    MEMCPY_AN(MWIPLOTDFT_N->CLEAN_TIME, MWIPLOTDFT->CLEAN_TIME, sizeof(MWIPLOTDFT->CLEAN_TIME));
    MEMCPY_AN(MWIPLOTDFT_N->MAT_ID, MWIPLOTDFT->MAT_ID, sizeof(MWIPLOTDFT->MAT_ID));
    MWIPLOTDFT_N->MAT_VER = MWIPLOTDFT->MAT_VER;
    MEMCPY_AN(MWIPLOTDFT_N->FLOW, MWIPLOTDFT->FLOW, sizeof(MWIPLOTDFT->FLOW));
    MEMCPY_AN(MWIPLOTDFT_N->OPER, MWIPLOTDFT->OPER, sizeof(MWIPLOTDFT->OPER));
    MEMCPY_AN(MWIPLOTDFT_N->RES_ID, MWIPLOTDFT->RES_ID, sizeof(MWIPLOTDFT->RES_ID));
    MEMCPY_AN(MWIPLOTDFT_N->SUBRES_ID, MWIPLOTDFT->SUBRES_ID, sizeof(MWIPLOTDFT->SUBRES_ID));
    MEMCPY_AN(MWIPLOTDFT_N->CAUSE_FLOW, MWIPLOTDFT->CAUSE_FLOW, sizeof(MWIPLOTDFT->CAUSE_FLOW));
    MEMCPY_AN(MWIPLOTDFT_N->CAUSE_OPER, MWIPLOTDFT->CAUSE_OPER, sizeof(MWIPLOTDFT->CAUSE_OPER));
    MEMCPY_AN(MWIPLOTDFT_N->CAUSE_RES_ID, MWIPLOTDFT->CAUSE_RES_ID, sizeof(MWIPLOTDFT->CAUSE_RES_ID));
    MEMCPY_AN(MWIPLOTDFT_N->CAUSE_SUBRES_ID, MWIPLOTDFT->CAUSE_SUBRES_ID, sizeof(MWIPLOTDFT->CAUSE_SUBRES_ID));
    MEMCPY_AN(MWIPLOTDFT_N->CHK_USER_ID_1, MWIPLOTDFT->CHK_USER_ID_1, sizeof(MWIPLOTDFT->CHK_USER_ID_1));
    MEMCPY_AN(MWIPLOTDFT_N->CHK_USER_ID_2, MWIPLOTDFT->CHK_USER_ID_2, sizeof(MWIPLOTDFT->CHK_USER_ID_2));
