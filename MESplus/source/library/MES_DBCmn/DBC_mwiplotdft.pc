/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwiplotdft(int sel_type, struct MWIPLOTDFT_TAG *MWIPLOTDFT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTDFT_N_TAG MWIPLOTDFT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplotdft(&MWIPLOTDFT_N, MWIPLOTDFT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPLOTDFT_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    SUBLOT_ID,
                    FACTORY,
                    HIST_SEQ,
                    SEQ_NUM,
                    HIST_DEL_FLAG,
                    DEFECT_CODE,
                    DEFECT_QTY,
                    CELL_X,
                    CELL_Y,
                    CELL_Z,
                    LOC_X,
                    LOC_Y,
                    LOC_Z,
                    TRAN_TIME,
                    SYS_TRAN_TIME,
                    TRAN_USER_ID,
                    CLEAN_FLAG,
                    CLEAN_HIST_SEQ,
                    CLEAN_USER_ID,
                    CLEAN_TIME,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RES_ID,
                    SUBRES_ID,
                    CAUSE_FLOW,
                    CAUSE_OPER,
                    CAUSE_RES_ID,
                    CAUSE_SUBRES_ID,
                    CHK_USER_ID_1,
                    CHK_USER_ID_2,
                    ATTACH_FILE_1,
                    ATTACH_FILE_2,
                    ATTACH_FILE_3,
                    ATTACH_FILE_4,
                    ATTACH_FILE_5,
                    DEFECT_COMMENT
                FROM MWIPLOTDFT
                WHERE LOT_ID = :MWIPLOTDFT_N.LOT_ID
                   AND (HIST_SEQ > :MWIPLOTDFT_N.HIST_SEQ
                         OR (HIST_SEQ = :MWIPLOTDFT_N.HIST_SEQ AND SEQ_NUM > :MWIPLOTDFT_N.SEQ_NUM)
                       )
                ORDER BY 
                    HIST_SEQ ASC,
                    SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPLOTDFT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwiplotdft", sel_type);
}


