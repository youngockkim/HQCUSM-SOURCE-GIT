                    RES_ID,
                    RESG_ID,
                    RES_TYPE,
                    CRT_RULE_ID,
                    GEN_RULE_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    CONFIRM_FLAG,
                    BATCH_COMMENT
                FROM MWIPBATDEF
                WHERE FACTORY = :MWIPBATDEF_N.FACTORY
                    AND BATCH_ID = :MWIPBATDEF_N.BATCH_ID
                ORDER BY SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPBATDEF_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPBATDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    BATCH_ID,
                    ITEM_ID,
                    SEQ_NUM,
                    ITEM_TYPE,
                    OPER,
                    REL_LEVEL,
                    RES_ID,
                    RESG_ID,
                    RES_TYPE,
                    CRT_RULE_ID,
                    GEN_RULE_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    CONFIRM_FLAG,
                    BATCH_COMMENT
                FROM MWIPBATDEF
                WHERE FACTORY = :MWIPBATDEF_N.FACTORY
                    AND BATCH_ID = :MWIPBATDEF_N.BATCH_ID
                    AND ITEM_TYPE <> 'N'
                ORDER BY SEQ_NUM DESC;
            EXEC SQL OPEN DBC_MWIPBATDEF_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MWIPBATDEF_CUR_3 CURSOR FOR
                SELECT OPER, REL_LEVEL, RES_ID, RESG_ID, RES_TYPE
                FROM MWIPBATDEF
                WHERE FACTORY = :MWIPBATDEF_N.FACTORY
                    AND BATCH_ID = :MWIPBATDEF_N.BATCH_ID
                GROUP BY OPER, REL_LEVEL, RES_ID, RESG_ID, RES_TYPE;
            EXEC SQL OPEN DBC_MWIPBATDEF_CUR_3;
            break;
                    

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipbatdef", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mwipbatdef(int sel_type, struct MWIPBATDEF_TAG *MWIPBATDEF)
{
   
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPBATDEF_N_TAG MWIPBATDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MWIPBATDEF_CUR_1 INTO 
                                                    :MWIPBATDEF_N.FACTORY,
                                                    :MWIPBATDEF_N.BATCH_ID,
                                                    :MWIPBATDEF_N.ITEM_ID,
                                                    :MWIPBATDEF_N.SEQ_NUM,
                                                    :MWIPBATDEF_N.ITEM_TYPE,
                                                    :MWIPBATDEF_N.OPER,
                                                    :MWIPBATDEF_N.REL_LEVEL,
                                                    :MWIPBATDEF_N.RES_ID,
                                                    :MWIPBATDEF_N.RESG_ID,
                                                    :MWIPBATDEF_N.RES_TYPE,
                                                    :MWIPBATDEF_N.CRT_RULE_ID,
                                                    :MWIPBATDEF_N.GEN_RULE_ID,
                                                    :MWIPBATDEF_N.CREATE_USER_ID,
                                                    :MWIPBATDEF_N.CREATE_TIME,
                                                    :MWIPBATDEF_N.UPDATE_USER_ID,
                                                    :MWIPBATDEF_N.UPDATE_TIME,
                                                    :MWIPBATDEF_N.CONFIRM_FLAG,
                                                    :MWIPBATDEF_N.BATCH_COMMENT;
            break;

        case 2:
            EXEC SQL FETCH DBC_MWIPBATDEF_CUR_2 INTO 
                                                    :MWIPBATDEF_N.FACTORY,
                                                    :MWIPBATDEF_N.BATCH_ID,
                                                    :MWIPBATDEF_N.ITEM_ID,
                                                    :MWIPBATDEF_N.SEQ_NUM,
                                                    :MWIPBATDEF_N.ITEM_TYPE,
                                                    :MWIPBATDEF_N.OPER,
                                                    :MWIPBATDEF_N.REL_LEVEL,
                                                    :MWIPBATDEF_N.RES_ID,
                                                    :MWIPBATDEF_N.RESG_ID,
                                                    :MWIPBATDEF_N.RES_TYPE,
                                                    :MWIPBATDEF_N.CRT_RULE_ID,
                                                    :MWIPBATDEF_N.GEN_RULE_ID,
                                                    :MWIPBATDEF_N.CREATE_USER_ID,
                                                    :MWIPBATDEF_N.CREATE_TIME,
                                                    :MWIPBATDEF_N.UPDATE_USER_ID,
                                                    :MWIPBATDEF_N.UPDATE_TIME,
                                                    :MWIPBATDEF_N.CONFIRM_FLAG,
                                                    :MWIPBATDEF_N.BATCH_COMMENT;
            break;

        case 3:
            EXEC SQL FETCH DBC_MWIPBATDEF_CUR_3 INTO :MWIPBATDEF_N.OPER, :MWIPBATDEF_N.REL_LEVEL, :MWIPBATDEF_N.RES_ID, :MWIPBATDEF_N.RESG_ID, :MWIPBATDEF_N.RES_TYPE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwipbatdef(&MWIPBATDEF_N, MWIPBATDEF);
    }
    DB_stop_query_timer("DBC_fetch_mwipbatdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwipbatdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPBATDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWIPBATDEF_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MWIPBATDEF_CUR_3;
            break;

            
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipbatdef", sel_type);
}


/* Initialize Function */
void DBC_init_mwipbatdef(struct MWIPBATDEF_TAG *MWIPBATDEF)
{
    /* memset by Space */
    memset(MWIPBATDEF, ' ', sizeof(struct MWIPBATDEF_TAG));
    
    MWIPBATDEF->SEQ_NUM = 0;
}


/* Add Null Function */
void DBC_add_null_mwipbatdef(struct MWIPBATDEF_N_TAG *MWIPBATDEF_N, struct MWIPBATDEF_TAG *MWIPBATDEF)
{
    /* memset by NULL */
    memset(MWIPBATDEF_N, '\0', sizeof(struct MWIPBATDEF_N_TAG));
    
    MEMCPY_AN(MWIPBATDEF_N->FACTORY, MWIPBATDEF->FACTORY, sizeof(MWIPBATDEF->FACTORY));
    MEMCPY_AN(MWIPBATDEF_N->BATCH_ID, MWIPBATDEF->BATCH_ID, sizeof(MWIPBATDEF->BATCH_ID));
    MEMCPY_AN(MWIPBATDEF_N->ITEM_ID, MWIPBATDEF->ITEM_ID, sizeof(MWIPBATDEF->ITEM_ID));
    MWIPBATDEF_N->SEQ_NUM = MWIPBATDEF->SEQ_NUM;
    MWIPBATDEF_N->ITEM_TYPE[0] = MWIPBATDEF->ITEM_TYPE;
    MEMCPY_AN(MWIPBATDEF_N->OPER, MWIPBATDEF->OPER, sizeof(MWIPBATDEF->OPER));
    MWIPBATDEF_N->REL_LEVEL[0] = MWIPBATDEF->REL_LEVEL;
    MEMCPY_AN(MWIPBATDEF_N->RES_ID, MWIPBATDEF->RES_ID, sizeof(MWIPBATDEF->RES_ID));
    MEMCPY_AN(MWIPBATDEF_N->RESG_ID, MWIPBATDEF->RESG_ID, sizeof(MWIPBATDEF->RESG_ID));
    MEMCPY_AN(MWIPBATDEF_N->RES_TYPE, MWIPBATDEF->RES_TYPE, sizeof(MWIPBATDEF->RES_TYPE));
    MEMCPY_AN(MWIPBATDEF_N->CRT_RULE_ID, MWIPBATDEF->CRT_RULE_ID, sizeof(MWIPBATDEF->CRT_RULE_ID));
    MEMCPY_AN(MWIPBATDEF_N->GEN_RULE_ID, MWIPBATDEF->GEN_RULE_ID, sizeof(MWIPBATDEF->GEN_RULE_ID));
    MEMCPY_AN(MWIPBATDEF_N->CREATE_USER_ID, MWIPBATDEF->CREATE_USER_ID, sizeof(MWIPBATDEF->CREATE_USER_ID));
    MEMCPY_AN(MWIPBATDEF_N->CREATE_TIME, MWIPBATDEF->CREATE_TIME, sizeof(MWIPBATDEF->CREATE_TIME));
    MEMCPY_AN(MWIPBATDEF_N->UPDATE_USER_ID, MWIPBATDEF->UPDATE_USER_ID, sizeof(MWIPBATDEF->UPDATE_USER_ID));
    MEMCPY_AN(MWIPBATDEF_N->UPDATE_TIME, MWIPBATDEF->UPDATE_TIME, sizeof(MWIPBATDEF->UPDATE_TIME));
    MWIPBATDEF_N->CONFIRM_FLAG[0] = MWIPBATDEF->CONFIRM_FLAG;
    MEMCPY_AN(MWIPBATDEF_N->BATCH_COMMENT, MWIPBATDEF->BATCH_COMMENT, sizeof(MWIPBATDEF->BATCH_COMMENT));
}


/* Del Null Function */
void DBC_del_null_mwipbatdef(struct MWIPBATDEF_N_TAG *MWIPBATDEF_N, struct MWIPBATDEF_TAG *MWIPBATDEF)
{
    MEMCPY_DN(MWIPBATDEF->FACTORY, MWIPBATDEF_N->FACTORY, sizeof(MWIPBATDEF->FACTORY));
    MEMCPY_DN(MWIPBATDEF->BATCH_ID, MWIPBATDEF_N->BATCH_ID, sizeof(MWIPBATDEF->BATCH_ID));
    MEMCPY_DN(MWIPBATDEF->ITEM_ID, MWIPBATDEF_N->ITEM_ID, sizeof(MWIPBATDEF->ITEM_ID));
    MWIPBATDEF->SEQ_NUM = MWIPBATDEF_N->SEQ_NUM;
    MWIPBATDEF->ITEM_TYPE = MWIPBATDEF_N->ITEM_TYPE[0];
    MEMCPY_DN(MWIPBATDEF->OPER, MWIPBATDEF_N->OPER, sizeof(MWIPBATDEF->OPER));
    MWIPBATDEF->REL_LEVEL = MWIPBATDEF_N->REL_LEVEL[0];
    MEMCPY_DN(MWIPBATDEF->RES_ID, MWIPBATDEF_N->RES_ID, sizeof(MWIPBATDEF->RES_ID));
    MEMCPY_DN(MWIPBATDEF->RESG_ID, MWIPBATDEF_N->RESG_ID, sizeof(MWIPBATDEF->RESG_ID));
    MEMCPY_DN(MWIPBATDEF->RES_TYPE, MWIPBATDEF_N->RES_TYPE, sizeof(MWIPBATDEF->RES_TYPE));
    MEMCPY_DN(MWIPBATDEF->CRT_RULE_ID, MWIPBATDEF_N->CRT_RULE_ID, sizeof(MWIPBATDEF->CRT_RULE_ID));
    MEMCPY_DN(MWIPBATDEF->GEN_RULE_ID, MWIPBATDEF_N->GEN_RULE_ID, sizeof(MWIPBATDEF->GEN_RULE_ID));
    MEMCPY_DN(MWIPBATDEF->CREATE_USER_ID, MWIPBATDEF_N->CREATE_USER_ID, sizeof(MWIPBATDEF->CREATE_USER_ID));
    MEMCPY_DN(MWIPBATDEF->CREATE_TIME, MWIPBATDEF_N->CREATE_TIME, sizeof(MWIPBATDEF->CREATE_TIME));
    MEMCPY_DN(MWIPBATDEF->UPDATE_USER_ID, MWIPBATDEF_N->UPDATE_USER_ID, sizeof(MWIPBATDEF->UPDATE_USER_ID));
    MEMCPY_DN(MWIPBATDEF->UPDATE_TIME, MWIPBATDEF_N->UPDATE_TIME, sizeof(MWIPBATDEF->UPDATE_TIME));
    MWIPBATDEF->CONFIRM_FLAG = MWIPBATDEF_N->CONFIRM_FLAG[0];
    MEMCPY_DN(MWIPBATDEF->BATCH_COMMENT, MWIPBATDEF_N->BATCH_COMMENT, sizeof(MWIPBATDEF->BATCH_COMMENT));
}


