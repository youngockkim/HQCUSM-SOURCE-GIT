    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();


    DBC_add_null_mwipbatdef(&MWIPBATDEF_N, MWIPBATDEF);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPBATDEF
                WHERE FACTORY = :MWIPBATDEF_N.FACTORY
                    AND BATCH_ID = :MWIPBATDEF_N.BATCH_ID
                    AND ITEM_ID = :MWIPBATDEF_N.ITEM_ID;
            break;
            
        case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPBATDEF
                WHERE FACTORY = :MWIPBATDEF_N.FACTORY
                    AND BATCH_ID = :MWIPBATDEF_N.BATCH_ID;
            break;

        case 3:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPBATDEF
                WHERE FACTORY = :MWIPBATDEF_N.FACTORY
                    AND ITEM_ID = :MWIPBATDEF_N.ITEM_ID
                    AND ITEM_TYPE = :MWIPBATDEF_N.ITEM_TYPE;
            break;

        case 4:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPBATDEF
                WHERE FACTORY = :MWIPBATDEF_N.FACTORY
                    AND BATCH_ID = :MWIPBATDEF_N.BATCH_ID
                    AND ITEM_TYPE = :MWIPBATDEF_N.ITEM_TYPE;
            break;

        case 5:
            EXEC SQL SELECT count(LOT.LOT_ID) 
                INTO :d_value
                FROM MWIPBATDEF BAT, MWIPLOTSTS LOT
                WHERE BAT.FACTORY = :MWIPBATDEF_N.FACTORY
                    AND BAT.BATCH_ID = :MWIPBATDEF_N.BATCH_ID
                    AND BAT.ITEM_TYPE = :MWIPBATDEF_N.ITEM_TYPE
                    AND BAT.FACTORY = LOT.FACTORY
                    AND BAT.ITEM_ID = LOT.LOT_ID
                    AND LOT.LOT_DEL_FLAG = ' '
                    AND LOT.START_FLAG = 'Y';
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mwipbatdef_scalar", sel_type);
    return d_value;
}


