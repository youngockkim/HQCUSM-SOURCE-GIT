    MEMCPY_DN(MWIPBINFML->TARGET_VALUE, MWIPBINFML_N->TARGET_VALUE, sizeof(MWIPBINFML->TARGET_VALUE));
    MEMCPY_DN(MWIPBINFML->R_BRACKET, MWIPBINFML_N->R_BRACKET, sizeof(MWIPBINFML->R_BRACKET));
}


