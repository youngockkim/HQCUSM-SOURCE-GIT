                    :MGCMTBLDAT_N.DATA_10,
                    :MGCMTBLDAT_N.CREATE_USER_ID,
                    :MGCMTBLDAT_N.CREATE_TIME,
                    :MGCMTBLDAT_N.UPDATE_USER_ID,
                    :MGCMTBLDAT_N.UPDATE_TIME
                 FROM MGCMTBLDAT
                WHERE FACTORY = :MGCMTBLDAT_N.FACTORY
                AND TABLE_NAME = :MGCMTBLDAT_N.TABLE_NAME
				AND KEY_1 =  :MGCMTBLDAT_N.KEY_1
				AND DATA_2 = :MGCMTBLDAT_N.DATA_2
				AND ROWNUM = 1;

            break;

		case 104:
            EXEC SQL SELECT 
                    KEY_1,
                    KEY_1 || '|' || DATA_4
                INTO 
                    :MGCMTBLDAT_N.KEY_1,
                    :MGCMTBLDAT_N.DATA_4
                FROM MGCMTBLDAT
                WHERE FACTORY = :MGCMTBLDAT_N.FACTORY
                AND TABLE_NAME = :MGCMTBLDAT_N.TABLE_NAME
                AND KEY_1 = :MGCMTBLDAT_N.KEY_1
                AND KEY_2 = :MGCMTBLDAT_N.KEY_2;
            break;

		case 105:
            EXEC SQL SELECT 
                         FACTORY,
                         TABLE_NAME,
                         KEY_1,
                         KEY_2,
                         KEY_3,
                         KEY_4,
                         KEY_5,
                         KEY_6,
                         KEY_7,
                         KEY_8,
                         KEY_9,
                         KEY_10,
                         DATA_1,
                         DATA_2,
                         DATA_3,
                         DATA_4,
                         DATA_5,
                         DATA_6,
                         DATA_7,
                         DATA_8,
                         DATA_9,
                         DATA_10,
                         CREATE_USER_ID,
                         CREATE_TIME,
                         UPDATE_USER_ID,
                         UPDATE_TIME
                INTO 
                    :MGCMTBLDAT_N.FACTORY,
                    :MGCMTBLDAT_N.TABLE_NAME,
                    :MGCMTBLDAT_N.KEY_1,
                    :MGCMTBLDAT_N.KEY_2,
                    :MGCMTBLDAT_N.KEY_3,
                    :MGCMTBLDAT_N.KEY_4,
                    :MGCMTBLDAT_N.KEY_5,
                    :MGCMTBLDAT_N.KEY_6,
                    :MGCMTBLDAT_N.KEY_7,
                    :MGCMTBLDAT_N.KEY_8,
                    :MGCMTBLDAT_N.KEY_9,
                    :MGCMTBLDAT_N.KEY_10,
                    :MGCMTBLDAT_N.DATA_1,
                    :MGCMTBLDAT_N.DATA_2,
                    :MGCMTBLDAT_N.DATA_3,
                    :MGCMTBLDAT_N.DATA_4,
                    :MGCMTBLDAT_N.DATA_5,
                    :MGCMTBLDAT_N.DATA_6,
                    :MGCMTBLDAT_N.DATA_7,
                    :MGCMTBLDAT_N.DATA_8,
                    :MGCMTBLDAT_N.DATA_9,
                    :MGCMTBLDAT_N.DATA_10,
                    :MGCMTBLDAT_N.CREATE_USER_ID,
                    :MGCMTBLDAT_N.CREATE_TIME,
                    :MGCMTBLDAT_N.UPDATE_USER_ID,
                    :MGCMTBLDAT_N.UPDATE_TIME
                 FROM MGCMTBLDAT
                WHERE FACTORY = :MGCMTBLDAT_N.FACTORY
                AND TABLE_NAME = :MGCMTBLDAT_N.TABLE_NAME
				AND KEY_1 =  :MGCMTBLDAT_N.KEY_1
				AND KEY_2 = :MGCMTBLDAT_N.KEY_2
				AND ROWNUM = 1;
            break;

		case 106:
            EXEC SQL SELECT 
                         FACTORY,
                         TABLE_NAME,
                         KEY_1,
                         KEY_2,
                         KEY_3,
                         KEY_4,
                         KEY_5,
                         KEY_6,
                         KEY_7,
                         KEY_8,
                         KEY_9,
                         KEY_10,
                         DATA_1,
                         DATA_2,
                         DATA_3,
                         DATA_4,
                         DATA_5,
                         DATA_6,
                         DATA_7,
                         DATA_8,
                         DATA_9,
                         DATA_10,
                         CREATE_USER_ID,
                         CREATE_TIME,
                         UPDATE_USER_ID,
                         UPDATE_TIME
                INTO 
                    :MGCMTBLDAT_N.FACTORY,
                    :MGCMTBLDAT_N.TABLE_NAME,
                    :MGCMTBLDAT_N.KEY_1,
                    :MGCMTBLDAT_N.KEY_2,
                    :MGCMTBLDAT_N.KEY_3,
                    :MGCMTBLDAT_N.KEY_4,
                    :MGCMTBLDAT_N.KEY_5,
                    :MGCMTBLDAT_N.KEY_6,
                    :MGCMTBLDAT_N.KEY_7,
                    :MGCMTBLDAT_N.KEY_8,
                    :MGCMTBLDAT_N.KEY_9,
                    :MGCMTBLDAT_N.KEY_10,
                    :MGCMTBLDAT_N.DATA_1,
                    :MGCMTBLDAT_N.DATA_2,
                    :MGCMTBLDAT_N.DATA_3,
                    :MGCMTBLDAT_N.DATA_4,
                    :MGCMTBLDAT_N.DATA_5,
                    :MGCMTBLDAT_N.DATA_6,
                    :MGCMTBLDAT_N.DATA_7,
                    :MGCMTBLDAT_N.DATA_8,
                    :MGCMTBLDAT_N.DATA_9,
                    :MGCMTBLDAT_N.DATA_10,
                    :MGCMTBLDAT_N.CREATE_USER_ID,
                    :MGCMTBLDAT_N.CREATE_TIME,
                    :MGCMTBLDAT_N.UPDATE_USER_ID,
                    :MGCMTBLDAT_N.UPDATE_TIME
                 FROM MGCMTBLDAT
                WHERE FACTORY = :MGCMTBLDAT_N.FACTORY
                AND TABLE_NAME = :MGCMTBLDAT_N.TABLE_NAME
				AND KEY_1 =  :MGCMTBLDAT_N.KEY_1
				AND KEY_2 =  :MGCMTBLDAT_N.KEY_2
				AND KEY_3 = :MGCMTBLDAT_N.KEY_3
				AND ROWNUM = 1;
            break;

		case 107:
            EXEC SQL SELECT 
                         FACTORY,
                         TABLE_NAME,
                         KEY_1,
                         KEY_2,
                         KEY_3,
                         KEY_4,
                         KEY_5,
                         KEY_6,
                         KEY_7,
                         KEY_8,
                         KEY_9,
                         KEY_10,
                         DATA_1,
                         DATA_2,
                         DATA_3,
                         DATA_4,
                         DATA_5,
                         DATA_6,
                         DATA_7,
                         DATA_8,
                         DATA_9,
                         DATA_10,
                         CREATE_USER_ID,
                         CREATE_TIME,
                         UPDATE_USER_ID,
                         UPDATE_TIME
                INTO 
                    :MGCMTBLDAT_N.FACTORY,
                    :MGCMTBLDAT_N.TABLE_NAME,
                    :MGCMTBLDAT_N.KEY_1,
                    :MGCMTBLDAT_N.KEY_2,
                    :MGCMTBLDAT_N.KEY_3,
                    :MGCMTBLDAT_N.KEY_4,
                    :MGCMTBLDAT_N.KEY_5,
                    :MGCMTBLDAT_N.KEY_6,
                    :MGCMTBLDAT_N.KEY_7,
                    :MGCMTBLDAT_N.KEY_8,
                    :MGCMTBLDAT_N.KEY_9,
                    :MGCMTBLDAT_N.KEY_10,
                    :MGCMTBLDAT_N.DATA_1,
                    :MGCMTBLDAT_N.DATA_2,
                    :MGCMTBLDAT_N.DATA_3,
                    :MGCMTBLDAT_N.DATA_4,
                    :MGCMTBLDAT_N.DATA_5,
                    :MGCMTBLDAT_N.DATA_6,
                    :MGCMTBLDAT_N.DATA_7,
                    :MGCMTBLDAT_N.DATA_8,
                    :MGCMTBLDAT_N.DATA_9,
                    :MGCMTBLDAT_N.DATA_10,
                    :MGCMTBLDAT_N.CREATE_USER_ID,
                    :MGCMTBLDAT_N.CREATE_TIME,
                    :MGCMTBLDAT_N.UPDATE_USER_ID,
                    :MGCMTBLDAT_N.UPDATE_TIME
                FROM
                (
                    SELECT
                        *
                    FROM
                    (
                        SELECT
                            1 AS RK,
                            A.*
                         FROM MGCMTBLDAT A
                        WHERE FACTORY = :MGCMTBLDAT_N.FACTORY
                        AND TABLE_NAME = :MGCMTBLDAT_N.TABLE_NAME
				        AND KEY_1 =  :MGCMTBLDAT_N.KEY_1
				        AND KEY_2 =  :MGCMTBLDAT_N.KEY_2
				        AND KEY_3 = :MGCMTBLDAT_N.KEY_3
                        AND DATA_1 = :MGCMTBLDAT_N.DATA_1
                        UNION 
                        SELECT
                            2 AS RK,
                            A.*
                         FROM MGCMTBLDAT A
                        WHERE FACTORY = :MGCMTBLDAT_N.FACTORY
                        AND TABLE_NAME = :MGCMTBLDAT_N.TABLE_NAME
				        AND KEY_1 =  :MGCMTBLDAT_N.KEY_1
				        AND KEY_2 =  :MGCMTBLDAT_N.KEY_2
				        AND KEY_3 = :MGCMTBLDAT_N.KEY_3
                        AND DATA_1 = ' '
                    ) WHERE 1 = 1
                    ORDER BY RK
                ) WHERE 1 = 1
                AND ROWNUM = 1 ;
            break;



        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;

			
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mgcmtbldat(&MGCMTBLDAT_N, MGCMTBLDAT);
    }
    DB_stop_query_timer("DBC_select_mgcmtbldat", sel_type);
}


