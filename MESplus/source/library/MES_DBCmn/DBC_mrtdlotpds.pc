    MRTDLOTPDS->LOT_RESV_FLAG = MRTDLOTPDS_N->LOT_RESV_FLAG[0];
    MEMCPY_DN(MRTDLOTPDS->LOT_RESV_TIME, MRTDLOTPDS_N->LOT_RESV_TIME, sizeof(MRTDLOTPDS->LOT_RESV_TIME));
    MRTDLOTPDS->CAPABLE_FLAG = MRTDLOTPDS_N->CAPABLE_FLAG[0];
    MRTDLOTPDS->PRI_ADJUST_FLAG = MRTDLOTPDS_N->PRI_ADJUST_FLAG[0];
    MEMCPY_DN(MRTDLOTPDS->PRIORITY_SCORE, MRTDLOTPDS_N->PRIORITY_SCORE, sizeof(MRTDLOTPDS->PRIORITY_SCORE));
