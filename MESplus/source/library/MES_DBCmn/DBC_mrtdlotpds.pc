    MRTDLOTPDS->HIST_SEQ = MRTDLOTPDS_N->HIST_SEQ;
    MEMCPY_DN(MRTDLOTPDS->PRI_ADJUST_REASON, MRTDLOTPDS_N->PRI_ADJUST_REASON, sizeof(MRTDLOTPDS->PRI_ADJUST_REASON));
    MEMCPY_DN(MRTDLOTPDS->TRIGGER_BY, MRTDLOTPDS_N->TRIGGER_BY, sizeof(MRTDLOTPDS->TRIGGER_BY));
    MEMCPY_DN(MRTDLOTPDS->DSP_REASON, MRTDLOTPDS_N->DSP_REASON, sizeof(MRTDLOTPDS->DSP_REASON));
    MEMCPY_DN(MRTDLOTPDS->UNSELECT_REASON, MRTDLOTPDS_N->UNSELECT_REASON, sizeof(MRTDLOTPDS->UNSELECT_REASON));
    MEMCPY_DN(MRTDLOTPDS->CAPABLE_REASON, MRTDLOTPDS_N->CAPABLE_REASON, sizeof(MRTDLOTPDS->CAPABLE_REASON));
    MEMCPY_DN(MRTDLOTPDS->PDS_CMF_1, MRTDLOTPDS_N->PDS_CMF_1, sizeof(MRTDLOTPDS->PDS_CMF_1));
    MEMCPY_DN(MRTDLOTPDS->PDS_CMF_2, MRTDLOTPDS_N->PDS_CMF_2, sizeof(MRTDLOTPDS->PDS_CMF_2));
    MEMCPY_DN(MRTDLOTPDS->PDS_CMF_3, MRTDLOTPDS_N->PDS_CMF_3, sizeof(MRTDLOTPDS->PDS_CMF_3));
    MEMCPY_DN(MRTDLOTPDS->PDS_CMF_4, MRTDLOTPDS_N->PDS_CMF_4, sizeof(MRTDLOTPDS->PDS_CMF_4));
    MEMCPY_DN(MRTDLOTPDS->PDS_CMF_5, MRTDLOTPDS_N->PDS_CMF_5, sizeof(MRTDLOTPDS->PDS_CMF_5));
    MEMCPY_DN(MRTDLOTPDS->PDS_CMF_6, MRTDLOTPDS_N->PDS_CMF_6, sizeof(MRTDLOTPDS->PDS_CMF_6));
    MEMCPY_DN(MRTDLOTPDS->PDS_CMF_7, MRTDLOTPDS_N->PDS_CMF_7, sizeof(MRTDLOTPDS->PDS_CMF_7));
    MEMCPY_DN(MRTDLOTPDS->PDS_CMF_8, MRTDLOTPDS_N->PDS_CMF_8, sizeof(MRTDLOTPDS->PDS_CMF_8));
    MEMCPY_DN(MRTDLOTPDS->PDS_CMF_9, MRTDLOTPDS_N->PDS_CMF_9, sizeof(MRTDLOTPDS->PDS_CMF_9));
    MEMCPY_DN(MRTDLOTPDS->PDS_CMF_10, MRTDLOTPDS_N->PDS_CMF_10, sizeof(MRTDLOTPDS->PDS_CMF_10));
    MEMCPY_DN(MRTDLOTPDS->CREATE_USER_ID, MRTDLOTPDS_N->CREATE_USER_ID, sizeof(MRTDLOTPDS->CREATE_USER_ID));
    MEMCPY_DN(MRTDLOTPDS->CREATE_TIME, MRTDLOTPDS_N->CREATE_TIME, sizeof(MRTDLOTPDS->CREATE_TIME));
    MEMCPY_DN(MRTDLOTPDS->UPDATE_USER_ID, MRTDLOTPDS_N->UPDATE_USER_ID, sizeof(MRTDLOTPDS->UPDATE_USER_ID));
    MEMCPY_DN(MRTDLOTPDS->UPDATE_TIME, MRTDLOTPDS_N->UPDATE_TIME, sizeof(MRTDLOTPDS->UPDATE_TIME));
}


