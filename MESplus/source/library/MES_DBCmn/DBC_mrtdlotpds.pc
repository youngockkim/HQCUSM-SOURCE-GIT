/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrtdlotpds(int sel_type, struct MRTDLOTPDS_TAG *MRTDLOTPDS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRTDLOTPDS_N_TAG MRTDLOTPDS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrtdlotpds(&MRTDLOTPDS_N, MRTDLOTPDS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRTDLOTPDS_CUR_1 CURSOR FOR
                SELECT * FROM ( 
                    SELECT ROWNUM ROWSEQ, PD.* FROM (
                        SELECT 
                            FACTORY,
                            RES_OPER_FLAG,
                            RES_OPER_ID,
                            LOT_ID,
                            SET_OPER,
                            SET_RESG_ID,
                            SET_RES_ID,
                            DSP_ID,
                            RULE_ID,
                            TEMP_BATCH_ID,
                            TEMP_BATCH_SEQ,
                            CUR_OPER,
                            REFERENCE_OPER,
                            UNSELECTED_FLAG,
                            LOT_RESV_FLAG,
                            LOT_RESV_TIME,
                            CAPABLE_FLAG,
                            PRI_ADJUST_FLAG,
                            PRIORITY_SCORE,
                            PRIORITY_SUPPORT,
                            HIST_SEQ,
                            PRI_ADJUST_REASON,
                            TRIGGER_BY,
                            DSP_REASON,
                            UNSELECT_REASON,
                            CAPABLE_REASON,
                            PDS_CMF_1,
                            PDS_CMF_2,
                            PDS_CMF_3,
                            PDS_CMF_4,
                            PDS_CMF_5,
                            PDS_CMF_6,
                            PDS_CMF_7,
                            PDS_CMF_8,
                            PDS_CMF_9,
                            PDS_CMF_10,
                            CREATE_USER_ID,
                            CREATE_TIME,
                            UPDATE_USER_ID,
                            UPDATE_TIME
                        FROM MRTDLOTPDS
                         WHERE FACTORY = :MRTDLOTPDS_N.FACTORY
                            AND RES_OPER_FLAG = :MRTDLOTPDS_N.RES_OPER_FLAG
                            AND RES_OPER_ID = :MRTDLOTPDS_N.RES_OPER_ID
                            AND UNSELECTED_FLAG <> :MRTDLOTPDS_N.UNSELECTED_FLAG
                        ORDER BY PRIORITY_SCORE DESC, LOT_ID ASC
                    ) PD
                )
                WHERE ROWSEQ >= :DBC_Q_COND_N.FROM_SEQ
                ORDER BY ROWSEQ ASC;
            EXEC SQL OPEN DBC_MRTDLOTPDS_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MRTDLOTPDS_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_OPER_FLAG,
                    RES_OPER_ID,
                    LOT_ID,
                    SET_OPER,
                    SET_RESG_ID,
                    SET_RES_ID,
                    DSP_ID,
                    RULE_ID,
                    TEMP_BATCH_ID,
                    TEMP_BATCH_SEQ,
                    CUR_OPER,
                    REFERENCE_OPER,
                    UNSELECTED_FLAG,
                    LOT_RESV_FLAG,
                    LOT_RESV_TIME,
                    CAPABLE_FLAG,
                    PRI_ADJUST_FLAG,
                    PRIORITY_SCORE,
                    PRIORITY_SUPPORT,
                    HIST_SEQ,
                    PRI_ADJUST_REASON,
                    TRIGGER_BY,
                    DSP_REASON,
                    UNSELECT_REASON,
                    CAPABLE_REASON,
                    PDS_CMF_1,
                    PDS_CMF_2,
                    PDS_CMF_3,
                    PDS_CMF_4,
                    PDS_CMF_5,
                    PDS_CMF_6,
                    PDS_CMF_7,
                    PDS_CMF_8,
                    PDS_CMF_9,
                    PDS_CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRTDLOTPDS
                WHERE  LOT_ID = :MRTDLOTPDS_N.LOT_ID
				ORDER BY RES_OPER_ID ASC;
            EXEC SQL OPEN DBC_MRTDLOTPDS_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrtdlotpds", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mrtdlotpds(int sel_type, struct MRTDLOTPDS_TAG *MRTDLOTPDS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRTDLOTPDS_N_TAG MRTDLOTPDS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MRTDLOTPDS_CUR_1 INTO :DBC_Q_COND_N.FROM_SEQ, 
                                                    :MRTDLOTPDS_N.FACTORY,
                                                    :MRTDLOTPDS_N.RES_OPER_FLAG,
                                                    :MRTDLOTPDS_N.RES_OPER_ID,
                                                    :MRTDLOTPDS_N.LOT_ID,
                                                    :MRTDLOTPDS_N.SET_OPER,
                                                    :MRTDLOTPDS_N.SET_RESG_ID,
                                                    :MRTDLOTPDS_N.SET_RES_ID,
                                                    :MRTDLOTPDS_N.DSP_ID,
                                                    :MRTDLOTPDS_N.RULE_ID,
                                                    :MRTDLOTPDS_N.TEMP_BATCH_ID,
                                                    :MRTDLOTPDS_N.TEMP_BATCH_SEQ,
                                                    :MRTDLOTPDS_N.CUR_OPER,
                                                    :MRTDLOTPDS_N.REFERENCE_OPER,
                                                    :MRTDLOTPDS_N.UNSELECTED_FLAG,
                                                    :MRTDLOTPDS_N.LOT_RESV_FLAG,
                                                    :MRTDLOTPDS_N.LOT_RESV_TIME,
                                                    :MRTDLOTPDS_N.CAPABLE_FLAG,
                                                    :MRTDLOTPDS_N.PRI_ADJUST_FLAG,
                                                    :MRTDLOTPDS_N.PRIORITY_SCORE,
                                                    :MRTDLOTPDS_N.PRIORITY_SUPPORT,
                                                    :MRTDLOTPDS_N.HIST_SEQ,
                                                    :MRTDLOTPDS_N.PRI_ADJUST_REASON,
                                                    :MRTDLOTPDS_N.TRIGGER_BY,
                                                    :MRTDLOTPDS_N.DSP_REASON,
                                                    :MRTDLOTPDS_N.UNSELECT_REASON,
                                                    :MRTDLOTPDS_N.CAPABLE_REASON,
                                                    :MRTDLOTPDS_N.PDS_CMF_1,
                                                    :MRTDLOTPDS_N.PDS_CMF_2,
                                                    :MRTDLOTPDS_N.PDS_CMF_3,
                                                    :MRTDLOTPDS_N.PDS_CMF_4,
                                                    :MRTDLOTPDS_N.PDS_CMF_5,
                                                    :MRTDLOTPDS_N.PDS_CMF_6,
                                                    :MRTDLOTPDS_N.PDS_CMF_7,
                                                    :MRTDLOTPDS_N.PDS_CMF_8,
                                                    :MRTDLOTPDS_N.PDS_CMF_9,
                                                    :MRTDLOTPDS_N.PDS_CMF_10,
                                                    :MRTDLOTPDS_N.CREATE_USER_ID,
                                                    :MRTDLOTPDS_N.CREATE_TIME,
                                                    :MRTDLOTPDS_N.UPDATE_USER_ID,
                                                    :MRTDLOTPDS_N.UPDATE_TIME;
            DB_del_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            break;

        case 2:
            EXEC SQL FETCH DBC_MRTDLOTPDS_CUR_2 INTO 
                                                    :MRTDLOTPDS_N.FACTORY,
                                                    :MRTDLOTPDS_N.RES_OPER_FLAG,
                                                    :MRTDLOTPDS_N.RES_OPER_ID,
                                                    :MRTDLOTPDS_N.LOT_ID,
                                                    :MRTDLOTPDS_N.SET_OPER,
                                                    :MRTDLOTPDS_N.SET_RESG_ID,
                                                    :MRTDLOTPDS_N.SET_RES_ID,
                                                    :MRTDLOTPDS_N.DSP_ID,
                                                    :MRTDLOTPDS_N.RULE_ID,
                                                    :MRTDLOTPDS_N.TEMP_BATCH_ID,
                                                    :MRTDLOTPDS_N.TEMP_BATCH_SEQ,
                                                    :MRTDLOTPDS_N.CUR_OPER,
                                                    :MRTDLOTPDS_N.REFERENCE_OPER,
                                                    :MRTDLOTPDS_N.UNSELECTED_FLAG,
                                                    :MRTDLOTPDS_N.LOT_RESV_FLAG,
                                                    :MRTDLOTPDS_N.LOT_RESV_TIME,
                                                    :MRTDLOTPDS_N.CAPABLE_FLAG,
                                                    :MRTDLOTPDS_N.PRI_ADJUST_FLAG,
                                                    :MRTDLOTPDS_N.PRIORITY_SCORE,
                                                    :MRTDLOTPDS_N.PRIORITY_SUPPORT,
                                                    :MRTDLOTPDS_N.HIST_SEQ,
                                                    :MRTDLOTPDS_N.PRI_ADJUST_REASON,
                                                    :MRTDLOTPDS_N.TRIGGER_BY,
                                                    :MRTDLOTPDS_N.DSP_REASON,
                                                    :MRTDLOTPDS_N.UNSELECT_REASON,
                                                    :MRTDLOTPDS_N.CAPABLE_REASON,
                                                    :MRTDLOTPDS_N.PDS_CMF_1,
                                                    :MRTDLOTPDS_N.PDS_CMF_2,
                                                    :MRTDLOTPDS_N.PDS_CMF_3,
                                                    :MRTDLOTPDS_N.PDS_CMF_4,
                                                    :MRTDLOTPDS_N.PDS_CMF_5,
                                                    :MRTDLOTPDS_N.PDS_CMF_6,
                                                    :MRTDLOTPDS_N.PDS_CMF_7,
                                                    :MRTDLOTPDS_N.PDS_CMF_8,
                                                    :MRTDLOTPDS_N.PDS_CMF_9,
                                                    :MRTDLOTPDS_N.PDS_CMF_10,
                                                    :MRTDLOTPDS_N.CREATE_USER_ID,
                                                    :MRTDLOTPDS_N.CREATE_TIME,
                                                    :MRTDLOTPDS_N.UPDATE_USER_ID,
                                                    :MRTDLOTPDS_N.UPDATE_TIME;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mrtdlotpds(&MRTDLOTPDS_N, MRTDLOTPDS);
    }
    DB_stop_query_timer("DBC_fetch_mrtdlotpds", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mrtdlotpds(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MRTDLOTPDS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MRTDLOTPDS_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mrtdlotpds", sel_type);
}


/* Initialize Function */
void DBC_init_mrtdlotpds(struct MRTDLOTPDS_TAG *MRTDLOTPDS)
{
    /* memset by Space */
    memset(MRTDLOTPDS, ' ', sizeof(struct MRTDLOTPDS_TAG));
    
    MRTDLOTPDS->TEMP_BATCH_SEQ = 0;
    MRTDLOTPDS->HIST_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mrtdlotpds(struct MRTDLOTPDS_N_TAG *MRTDLOTPDS_N, struct MRTDLOTPDS_TAG *MRTDLOTPDS)
{
    /* memset by NULL */
    memset(MRTDLOTPDS_N, '\0', sizeof(struct MRTDLOTPDS_N_TAG));
    
    MEMCPY_AN(MRTDLOTPDS_N->FACTORY, MRTDLOTPDS->FACTORY, sizeof(MRTDLOTPDS->FACTORY));
    MRTDLOTPDS_N->RES_OPER_FLAG[0] = MRTDLOTPDS->RES_OPER_FLAG;
    MEMCPY_AN(MRTDLOTPDS_N->RES_OPER_ID, MRTDLOTPDS->RES_OPER_ID, sizeof(MRTDLOTPDS->RES_OPER_ID));
    MEMCPY_AN(MRTDLOTPDS_N->LOT_ID, MRTDLOTPDS->LOT_ID, sizeof(MRTDLOTPDS->LOT_ID));
    MEMCPY_AN(MRTDLOTPDS_N->SET_OPER, MRTDLOTPDS->SET_OPER, sizeof(MRTDLOTPDS->SET_OPER));
    MEMCPY_AN(MRTDLOTPDS_N->SET_RESG_ID, MRTDLOTPDS->SET_RESG_ID, sizeof(MRTDLOTPDS->SET_RESG_ID));
    MEMCPY_AN(MRTDLOTPDS_N->SET_RES_ID, MRTDLOTPDS->SET_RES_ID, sizeof(MRTDLOTPDS->SET_RES_ID));
    MEMCPY_AN(MRTDLOTPDS_N->DSP_ID, MRTDLOTPDS->DSP_ID, sizeof(MRTDLOTPDS->DSP_ID));
    MEMCPY_AN(MRTDLOTPDS_N->RULE_ID, MRTDLOTPDS->RULE_ID, sizeof(MRTDLOTPDS->RULE_ID));
    MEMCPY_AN(MRTDLOTPDS_N->TEMP_BATCH_ID, MRTDLOTPDS->TEMP_BATCH_ID, sizeof(MRTDLOTPDS->TEMP_BATCH_ID));
    MRTDLOTPDS_N->TEMP_BATCH_SEQ = MRTDLOTPDS->TEMP_BATCH_SEQ;
    MEMCPY_AN(MRTDLOTPDS_N->CUR_OPER, MRTDLOTPDS->CUR_OPER, sizeof(MRTDLOTPDS->CUR_OPER));
    MEMCPY_AN(MRTDLOTPDS_N->REFERENCE_OPER, MRTDLOTPDS->REFERENCE_OPER, sizeof(MRTDLOTPDS->REFERENCE_OPER));
    MRTDLOTPDS_N->UNSELECTED_FLAG[0] = MRTDLOTPDS->UNSELECTED_FLAG;
    MRTDLOTPDS_N->LOT_RESV_FLAG[0] = MRTDLOTPDS->LOT_RESV_FLAG;
    MEMCPY_AN(MRTDLOTPDS_N->LOT_RESV_TIME, MRTDLOTPDS->LOT_RESV_TIME, sizeof(MRTDLOTPDS->LOT_RESV_TIME));
    MRTDLOTPDS_N->CAPABLE_FLAG[0] = MRTDLOTPDS->CAPABLE_FLAG;
    MRTDLOTPDS_N->PRI_ADJUST_FLAG[0] = MRTDLOTPDS->PRI_ADJUST_FLAG;
    MEMCPY_AN(MRTDLOTPDS_N->PRIORITY_SCORE, MRTDLOTPDS->PRIORITY_SCORE, sizeof(MRTDLOTPDS->PRIORITY_SCORE));
    MEMCPY_AN(MRTDLOTPDS_N->PRIORITY_SUPPORT, MRTDLOTPDS->PRIORITY_SUPPORT, sizeof(MRTDLOTPDS->PRIORITY_SUPPORT));
    MRTDLOTPDS_N->HIST_SEQ = MRTDLOTPDS->HIST_SEQ;
    MEMCPY_AN(MRTDLOTPDS_N->PRI_ADJUST_REASON, MRTDLOTPDS->PRI_ADJUST_REASON, sizeof(MRTDLOTPDS->PRI_ADJUST_REASON));
    MEMCPY_AN(MRTDLOTPDS_N->TRIGGER_BY, MRTDLOTPDS->TRIGGER_BY, sizeof(MRTDLOTPDS->TRIGGER_BY));
    MEMCPY_AN(MRTDLOTPDS_N->DSP_REASON, MRTDLOTPDS->DSP_REASON, sizeof(MRTDLOTPDS->DSP_REASON));
    MEMCPY_AN(MRTDLOTPDS_N->UNSELECT_REASON, MRTDLOTPDS->UNSELECT_REASON, sizeof(MRTDLOTPDS->UNSELECT_REASON));
    MEMCPY_AN(MRTDLOTPDS_N->CAPABLE_REASON, MRTDLOTPDS->CAPABLE_REASON, sizeof(MRTDLOTPDS->CAPABLE_REASON));
    MEMCPY_AN(MRTDLOTPDS_N->PDS_CMF_1, MRTDLOTPDS->PDS_CMF_1, sizeof(MRTDLOTPDS->PDS_CMF_1));
    MEMCPY_AN(MRTDLOTPDS_N->PDS_CMF_2, MRTDLOTPDS->PDS_CMF_2, sizeof(MRTDLOTPDS->PDS_CMF_2));
    MEMCPY_AN(MRTDLOTPDS_N->PDS_CMF_3, MRTDLOTPDS->PDS_CMF_3, sizeof(MRTDLOTPDS->PDS_CMF_3));
    MEMCPY_AN(MRTDLOTPDS_N->PDS_CMF_4, MRTDLOTPDS->PDS_CMF_4, sizeof(MRTDLOTPDS->PDS_CMF_4));
    MEMCPY_AN(MRTDLOTPDS_N->PDS_CMF_5, MRTDLOTPDS->PDS_CMF_5, sizeof(MRTDLOTPDS->PDS_CMF_5));
    MEMCPY_AN(MRTDLOTPDS_N->PDS_CMF_6, MRTDLOTPDS->PDS_CMF_6, sizeof(MRTDLOTPDS->PDS_CMF_6));
    MEMCPY_AN(MRTDLOTPDS_N->PDS_CMF_7, MRTDLOTPDS->PDS_CMF_7, sizeof(MRTDLOTPDS->PDS_CMF_7));
    MEMCPY_AN(MRTDLOTPDS_N->PDS_CMF_8, MRTDLOTPDS->PDS_CMF_8, sizeof(MRTDLOTPDS->PDS_CMF_8));
    MEMCPY_AN(MRTDLOTPDS_N->PDS_CMF_9, MRTDLOTPDS->PDS_CMF_9, sizeof(MRTDLOTPDS->PDS_CMF_9));
    MEMCPY_AN(MRTDLOTPDS_N->PDS_CMF_10, MRTDLOTPDS->PDS_CMF_10, sizeof(MRTDLOTPDS->PDS_CMF_10));
    MEMCPY_AN(MRTDLOTPDS_N->CREATE_USER_ID, MRTDLOTPDS->CREATE_USER_ID, sizeof(MRTDLOTPDS->CREATE_USER_ID));
    MEMCPY_AN(MRTDLOTPDS_N->CREATE_TIME, MRTDLOTPDS->CREATE_TIME, sizeof(MRTDLOTPDS->CREATE_TIME));
    MEMCPY_AN(MRTDLOTPDS_N->UPDATE_USER_ID, MRTDLOTPDS->UPDATE_USER_ID, sizeof(MRTDLOTPDS->UPDATE_USER_ID));
    MEMCPY_AN(MRTDLOTPDS_N->UPDATE_TIME, MRTDLOTPDS->UPDATE_TIME, sizeof(MRTDLOTPDS->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mrtdlotpds(struct MRTDLOTPDS_N_TAG *MRTDLOTPDS_N, struct MRTDLOTPDS_TAG *MRTDLOTPDS)
{
    MEMCPY_DN(MRTDLOTPDS->FACTORY, MRTDLOTPDS_N->FACTORY, sizeof(MRTDLOTPDS->FACTORY));
    MRTDLOTPDS->RES_OPER_FLAG = MRTDLOTPDS_N->RES_OPER_FLAG[0];
    MEMCPY_DN(MRTDLOTPDS->RES_OPER_ID, MRTDLOTPDS_N->RES_OPER_ID, sizeof(MRTDLOTPDS->RES_OPER_ID));
    MEMCPY_DN(MRTDLOTPDS->LOT_ID, MRTDLOTPDS_N->LOT_ID, sizeof(MRTDLOTPDS->LOT_ID));
    MEMCPY_DN(MRTDLOTPDS->SET_OPER, MRTDLOTPDS_N->SET_OPER, sizeof(MRTDLOTPDS->SET_OPER));
    MEMCPY_DN(MRTDLOTPDS->SET_RESG_ID, MRTDLOTPDS_N->SET_RESG_ID, sizeof(MRTDLOTPDS->SET_RESG_ID));
    MEMCPY_DN(MRTDLOTPDS->SET_RES_ID, MRTDLOTPDS_N->SET_RES_ID, sizeof(MRTDLOTPDS->SET_RES_ID));
