/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrcppraver(int sel_type, struct MRCPPRAVER_TAG *MRCPPRAVER)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRCPPRAVER_N_TAG MRCPPRAVER_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrcppraver(&MRCPPRAVER_N, MRCPPRAVER);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRCPPRAVER_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    RECIPE,
                    RECIPE_VERSION,
                    PARA_SEQ,
                    PARA_ID,
                    PARA_VALUE,
                    PARA_DESC,
                    MODIFY_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    CUS_MIN_VAL,
                    CUS_MAX_VAL,
                    CUS_UNIT,
                    CUS_CMF1,
                    CUS_CMF2,
                    CUS_CMF3,
                    CUS_CMF4,
                    CUS_CMF5
                FROM MRCPPRAVER
                WHERE FACTORY = :MRCPPRAVER_N.FACTORY
                    AND RES_ID = :MRCPPRAVER_N.RES_ID
                    AND SUBRES_ID = :MRCPPRAVER_N.SUBRES_ID
                    AND RECIPE = :MRCPPRAVER_N.RECIPE
                    AND RECIPE_VERSION = :MRCPPRAVER_N.RECIPE_VERSION
                ORDER BY
                    PARA_SEQ ASC;
            EXEC SQL OPEN DBC_MRCPPRAVER_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MRCPPRAVER_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    RECIPE,
                    RECIPE_VERSION,
                    PARA_SEQ,
                    PARA_ID,
                    PARA_VALUE,
                    PARA_DESC,
                    MODIFY_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    CUS_MIN_VAL,
                    CUS_MAX_VAL,
                    CUS_UNIT,
                    CUS_CMF1,
                    CUS_CMF2,
                    CUS_CMF3,
                    CUS_CMF4,
                    CUS_CMF5
                FROM MRCPPRAVER
                WHERE FACTORY = :MRCPPRAVER_N.FACTORY
                    AND RES_ID = :MRCPPRAVER_N.RES_ID
                    AND SUBRES_ID = :MRCPPRAVER_N.SUBRES_ID
                    AND RECIPE = :MRCPPRAVER_N.RECIPE
                    AND RECIPE_VERSION = :MRCPPRAVER_N.RECIPE_VERSION
                    AND CUS_CMF2 = ' '
                ORDER BY
                    PARA_SEQ ASC;
            EXEC SQL OPEN DBC_MRCPPRAVER_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrcppraver", sel_type);
}


