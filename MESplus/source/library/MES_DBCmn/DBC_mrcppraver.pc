/* Initialize Function */
void DBC_init_mrcppraver(struct MRCPPRAVER_TAG *MRCPPRAVER)
{
    /* memset by Space */
    memset(MRCPPRAVER, ' ', sizeof(struct MRCPPRAVER_TAG));
    
    MRCPPRAVER->RECIPE_VERSION = 0;
    MRCPPRAVER->PARA_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mrcppraver(struct MRCPPRAVER_N_TAG *MRCPPRAVER_N, struct MRCPPRAVER_TAG *MRCPPRAVER)
{
    /* memset by NULL */
    memset(MRCPPRAVER_N, '\0', sizeof(struct MRCPPRAVER_N_TAG));
    
    MEMCPY_AN(MRCPPRAVER_N->FACTORY, MRCPPRAVER->FACTORY, sizeof(MRCPPRAVER->FACTORY));
    MEMCPY_AN(MRCPPRAVER_N->RES_ID, MRCPPRAVER->RES_ID, sizeof(MRCPPRAVER->RES_ID));
    MEMCPY_AN(MRCPPRAVER_N->SUBRES_ID, MRCPPRAVER->SUBRES_ID, sizeof(MRCPPRAVER->SUBRES_ID));
    MEMCPY_AN(MRCPPRAVER_N->RECIPE, MRCPPRAVER->RECIPE, sizeof(MRCPPRAVER->RECIPE));
    MRCPPRAVER_N->RECIPE_VERSION = MRCPPRAVER->RECIPE_VERSION;
    MRCPPRAVER_N->PARA_SEQ = MRCPPRAVER->PARA_SEQ;
    MEMCPY_AN(MRCPPRAVER_N->PARA_ID, MRCPPRAVER->PARA_ID, sizeof(MRCPPRAVER->PARA_ID));
    MEMCPY_AN(MRCPPRAVER_N->PARA_VALUE, MRCPPRAVER->PARA_VALUE, sizeof(MRCPPRAVER->PARA_VALUE));
    MEMCPY_AN(MRCPPRAVER_N->PARA_DESC, MRCPPRAVER->PARA_DESC, sizeof(MRCPPRAVER->PARA_DESC));
    MRCPPRAVER_N->MODIFY_FLAG[0] = MRCPPRAVER->MODIFY_FLAG;
    MEMCPY_AN(MRCPPRAVER_N->CREATE_USER_ID, MRCPPRAVER->CREATE_USER_ID, sizeof(MRCPPRAVER->CREATE_USER_ID));
