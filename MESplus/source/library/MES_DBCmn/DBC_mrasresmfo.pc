                                                    :MRASRESMFO_N.RESG_ID,
                                                    :MRASRESMFO_N.FACTORY;
            break;

        case 2:
            EXEC SQL FETCH DBC_MRASRESMFO_CUR_2 INTO :MRASRESMFO_N.RES_ID;
            break;

        case 3:
            EXEC SQL FETCH DBC_MRASRESMFO_CUR_3 INTO 
                                                    :MRASRESMFO_N.FACTORY,
                                                    :MRASRESMFO_N.MAT_ID,
                                                    :MRASRESMFO_N.MAT_VER,
                                                    :MRASRESMFO_N.FLOW,
                                                    :MRASRESMFO_N.OPER,
                                                    :MRASRESMFO_N.RES_ID,
                                                    :MRASRESMFO_N.RESG_ID,
                                                    :MRASRESMFO_N.REL_LEVEL,
                                                    :MRASRESMFO_N.CREATE_USER_ID,
                                                    :MRASRESMFO_N.CREATE_TIME,
                                                    :MRASRESMFO_N.UPDATE_USER_ID,
                                                    :MRASRESMFO_N.UPDATE_TIME;
            break;

        case 4:
            EXEC SQL FETCH DBC_MRASRESMFO_CUR_4 INTO :MRASRESMFO_N.FACTORY, :MRASRESMFO_N.MAT_ID, :MRASRESMFO_N.MAT_VER, :MRASRESMFO_N.FLOW, :MRASRESMFO_N.OPER;
            break;

        case 5:
            EXEC SQL FETCH DBC_MRASRESMFO_CUR_5 INTO 
                                                    :MRASRESMFO_N.FACTORY,
                                                    :MRASRESMFO_N.MAT_ID,
                                                    :MRASRESMFO_N.MAT_VER,
                                                    :MRASRESMFO_N.FLOW,
                                                    :MRASRESMFO_N.OPER,
                                                    :MRASRESMFO_N.RES_ID,
                                                    :MRASRESMFO_N.RESG_ID,
                                                    :MRASRESMFO_N.REL_LEVEL,
                                                    :MRASRESMFO_N.CREATE_USER_ID,
                                                    :MRASRESMFO_N.CREATE_TIME,
                                                    :MRASRESMFO_N.UPDATE_USER_ID,
                                                    :MRASRESMFO_N.UPDATE_TIME;
            break;
        case 6:
            EXEC SQL FETCH DBC_MRASRESMFO_CUR_6 INTO 
                                                    :MRASRESMFO_N.FACTORY,
                                                    :MRASRESMFO_N.MAT_ID,
                                                    :MRASRESMFO_N.MAT_VER,
                                                    :MRASRESMFO_N.FLOW,
                                                    :MRASRESMFO_N.OPER,
                                                    :MRASRESMFO_N.RES_ID,
                                                    :MRASRESMFO_N.RESG_ID,
                                                    :MRASRESMFO_N.REL_LEVEL,
                                                    :MRASRESMFO_N.CREATE_USER_ID,
                                                    :MRASRESMFO_N.CREATE_TIME,
                                                    :MRASRESMFO_N.UPDATE_USER_ID,
                                                    :MRASRESMFO_N.UPDATE_TIME;
            break;
        case 7:
            EXEC SQL FETCH DBC_MRASRESMFO_CUR_7 INTO 
                                                    :MRASRESMFO_N.FACTORY,
                                                    :MRASRESMFO_N.MAT_ID,
                                                    :MRASRESMFO_N.MAT_VER,
                                                    :MRASRESMFO_N.FLOW,
                                                    :MRASRESMFO_N.OPER,
                                                    :MRASRESMFO_N.RES_ID,
                                                    :MRASRESMFO_N.RESG_ID,
                                                    :MRASRESMFO_N.REL_LEVEL,
                                                    :MRASRESMFO_N.CREATE_USER_ID,
                                                    :MRASRESMFO_N.CREATE_TIME,
                                                    :MRASRESMFO_N.UPDATE_USER_ID,
                                                    :MRASRESMFO_N.UPDATE_TIME;
            break;

        case 8:
            EXEC SQL FETCH DBC_MRASRESMFO_CUR_8 INTO :MRASRESMFO_N.FACTORY, :MRASRESMFO_N.MAT_ID, :MRASRESMFO_N.MAT_VER, :MRASRESMFO_N.FLOW, :MRASRESMFO_N.OPER;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mrasresmfo(&MRASRESMFO_N, MRASRESMFO);
    }
    DB_stop_query_timer("DBC_fetch_mrasresmfo", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mrasresmfo(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MRASRESMFO_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MRASRESMFO_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MRASRESMFO_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MRASRESMFO_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MRASRESMFO_CUR_5;
            break;
        case 6:
            EXEC SQL CLOSE DBC_MRASRESMFO_CUR_6;
            break;
        case 7:
            EXEC SQL CLOSE DBC_MRASRESMFO_CUR_7;
            break;
        case 8:
            EXEC SQL CLOSE DBC_MRASRESMFO_CUR_8;
            break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mrasresmfo", sel_type);
}


/* Initialize Function */
void DBC_init_mrasresmfo(struct MRASRESMFO_TAG *MRASRESMFO)
{
    /* memset by Space */
    memset(MRASRESMFO, ' ', sizeof(struct MRASRESMFO_TAG));
    
    MRASRESMFO->MAT_VER = 0;
}


/* Add Null Function */
void DBC_add_null_mrasresmfo(struct MRASRESMFO_N_TAG *MRASRESMFO_N, struct MRASRESMFO_TAG *MRASRESMFO)
{
    /* memset by NULL */
    memset(MRASRESMFO_N, '\0', sizeof(struct MRASRESMFO_N_TAG));
    
    MEMCPY_AN(MRASRESMFO_N->FACTORY, MRASRESMFO->FACTORY, sizeof(MRASRESMFO->FACTORY));
    MEMCPY_AN(MRASRESMFO_N->MAT_ID, MRASRESMFO->MAT_ID, sizeof(MRASRESMFO->MAT_ID));
    MRASRESMFO_N->MAT_VER = MRASRESMFO->MAT_VER;
    MEMCPY_AN(MRASRESMFO_N->FLOW, MRASRESMFO->FLOW, sizeof(MRASRESMFO->FLOW));
    MEMCPY_AN(MRASRESMFO_N->OPER, MRASRESMFO->OPER, sizeof(MRASRESMFO->OPER));
    MEMCPY_AN(MRASRESMFO_N->RES_ID, MRASRESMFO->RES_ID, sizeof(MRASRESMFO->RES_ID));
    MEMCPY_AN(MRASRESMFO_N->RESG_ID, MRASRESMFO->RESG_ID, sizeof(MRASRESMFO->RESG_ID));
    MRASRESMFO_N->REL_LEVEL[0] = MRASRESMFO->REL_LEVEL;
    MEMCPY_AN(MRASRESMFO_N->CREATE_USER_ID, MRASRESMFO->CREATE_USER_ID, sizeof(MRASRESMFO->CREATE_USER_ID));
    MEMCPY_AN(MRASRESMFO_N->CREATE_TIME, MRASRESMFO->CREATE_TIME, sizeof(MRASRESMFO->CREATE_TIME));
    MEMCPY_AN(MRASRESMFO_N->UPDATE_USER_ID, MRASRESMFO->UPDATE_USER_ID, sizeof(MRASRESMFO->UPDATE_USER_ID));
    MEMCPY_AN(MRASRESMFO_N->UPDATE_TIME, MRASRESMFO->UPDATE_TIME, sizeof(MRASRESMFO->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mrasresmfo(struct MRASRESMFO_N_TAG *MRASRESMFO_N, struct MRASRESMFO_TAG *MRASRESMFO)
{
    MEMCPY_DN(MRASRESMFO->FACTORY, MRASRESMFO_N->FACTORY, sizeof(MRASRESMFO->FACTORY));
    MEMCPY_DN(MRASRESMFO->MAT_ID, MRASRESMFO_N->MAT_ID, sizeof(MRASRESMFO->MAT_ID));
    MRASRESMFO->MAT_VER = MRASRESMFO_N->MAT_VER;
    MEMCPY_DN(MRASRESMFO->FLOW, MRASRESMFO_N->FLOW, sizeof(MRASRESMFO->FLOW));
    MEMCPY_DN(MRASRESMFO->OPER, MRASRESMFO_N->OPER, sizeof(MRASRESMFO->OPER));
    MEMCPY_DN(MRASRESMFO->RES_ID, MRASRESMFO_N->RES_ID, sizeof(MRASRESMFO->RES_ID));
    MEMCPY_DN(MRASRESMFO->RESG_ID, MRASRESMFO_N->RESG_ID, sizeof(MRASRESMFO->RESG_ID));
    MRASRESMFO->REL_LEVEL = MRASRESMFO_N->REL_LEVEL[0];
    MEMCPY_DN(MRASRESMFO->CREATE_USER_ID, MRASRESMFO_N->CREATE_USER_ID, sizeof(MRASRESMFO->CREATE_USER_ID));
    MEMCPY_DN(MRASRESMFO->CREATE_TIME, MRASRESMFO_N->CREATE_TIME, sizeof(MRASRESMFO->CREATE_TIME));
    MEMCPY_DN(MRASRESMFO->UPDATE_USER_ID, MRASRESMFO_N->UPDATE_USER_ID, sizeof(MRASRESMFO->UPDATE_USER_ID));
    MEMCPY_DN(MRASRESMFO->UPDATE_TIME, MRASRESMFO_N->UPDATE_TIME, sizeof(MRASRESMFO->UPDATE_TIME));
}


