                    AND SUBLOT_ID = :MWIPIDGHIS_N.SUBLOT_ID
                    AND DATETIME = :MWIPIDGHIS_N.DATETIME
                    AND KEY_1 = :MWIPIDGHIS_N.KEY_1
                    AND KEY_2 = :MWIPIDGHIS_N.KEY_2
                    AND KEY_3 = :MWIPIDGHIS_N.KEY_3
                    AND KEY_4 = :MWIPIDGHIS_N.KEY_4
                    AND KEY_5 = :MWIPIDGHIS_N.KEY_5
                    AND KEY_6 = :MWIPIDGHIS_N.KEY_6
                    AND KEY_7 = :MWIPIDGHIS_N.KEY_7
                    AND KEY_8 = :MWIPIDGHIS_N.KEY_8
                    AND KEY_9 = :MWIPIDGHIS_N.KEY_9
                    AND KEY_10 = :MWIPIDGHIS_N.KEY_10
                    AND SEQ_NUM = :MWIPIDGHIS_N.SEQ_NUM;
            break;

        case 3:
            EXEC SQL UPDATE MWIPIDGHIS SET
                    ID_USED_FLAG = :MWIPIDGHIS_N.ID_USED_FLAG
                WHERE RULE_ID = :MWIPIDGHIS_N.RULE_ID
                    AND GEN_ID = :MWIPIDGHIS_N.GEN_ID
                    AND CONFIRM_KEY = :MWIPIDGHIS_N.CONFIRM_KEY;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_update_mwipidghis", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipidghis(int sel_type, struct MWIPIDGHIS_TAG *MWIPIDGHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPIDGHIS_N_TAG MWIPIDGHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipidghis(&MWIPIDGHIS_N, MWIPIDGHIS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPIDGHIS_CUR_1 CURSOR FOR
                SELECT 
                    RULE_ID,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RES_TYPE,
                    RESG_ID,
                    RES_ID,
                    LOT_ID,
                    SUBLOT_ID,
                    DATETIME,
                    KEY_1,
                    KEY_2,
                    KEY_3,
                    KEY_4,
                    KEY_5,
                    KEY_6,
                    KEY_7,
                    KEY_8,
                    KEY_9,
                    KEY_10,
                    SEQ_NUM,
                    GEN_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    SEQ_POSITION,
                    CONFIRM_KEY,
                    ID_USED_FLAG
                FROM MWIPIDGHIS
                WHERE RULE_ID = :MWIPIDGHIS_N.RULE_ID
                   AND (CREATE_TIME < :MWIPIDGHIS_N.CREATE_TIME OR 
                       (CREATE_TIME = :MWIPIDGHIS_N.CREATE_TIME AND SEQ_NUM <= :MWIPIDGHIS_N.SEQ_NUM))
                ORDER BY CREATE_TIME DESC, SEQ_NUM DESC;
            EXEC SQL OPEN DBC_MWIPIDGHIS_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPIDGHIS_CUR_2 CURSOR FOR
                SELECT 
                    RULE_ID,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RES_TYPE,
                    RESG_ID,
                    RES_ID,
                    LOT_ID,
                    SUBLOT_ID,
                    DATETIME,
                    KEY_1,
                    KEY_2,
                    KEY_3,
                    KEY_4,
                    KEY_5,
                    KEY_6,
                    KEY_7,
                    KEY_8,
                    KEY_9,
                    KEY_10,
                    SEQ_NUM,
                    GEN_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    SEQ_POSITION,
                    CONFIRM_KEY,
                    ID_USED_FLAG
                FROM MWIPIDGHIS
                WHERE GEN_ID = :MWIPIDGHIS_N.GEN_ID
                ORDER BY SEQ_NUM DESC;
            EXEC SQL OPEN DBC_MWIPIDGHIS_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MWIPIDGHIS_CUR_3 CURSOR FOR
                SELECT 
                    RULE_ID,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RES_TYPE,
                    RESG_ID,
                    RES_ID,
                    LOT_ID,
                    SUBLOT_ID,
                    DATETIME,
                    KEY_1,
                    KEY_2,
                    KEY_3,
                    KEY_4,
                    KEY_5,
                    KEY_6,
                    KEY_7,
                    KEY_8,
                    KEY_9,
                    KEY_10,
                    SEQ_NUM,
                    GEN_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    SEQ_POSITION,
                    CONFIRM_KEY,
                    ID_USED_FLAG
                FROM MWIPIDGHIS
                WHERE RULE_ID = :MWIPIDGHIS_N.RULE_ID
                    AND FACTORY = :MWIPIDGHIS_N.FACTORY
                    AND MAT_ID = :MWIPIDGHIS_N.MAT_ID
                    AND MAT_VER = :MWIPIDGHIS_N.MAT_VER
                    AND FLOW = :MWIPIDGHIS_N.FLOW
                    AND OPER = :MWIPIDGHIS_N.OPER
                    AND RES_TYPE = :MWIPIDGHIS_N.RES_TYPE
                    AND RESG_ID = :MWIPIDGHIS_N.RESG_ID
                    AND RES_ID = :MWIPIDGHIS_N.RES_ID
                    AND LOT_ID = :MWIPIDGHIS_N.LOT_ID
                    AND SUBLOT_ID = :MWIPIDGHIS_N.SUBLOT_ID
                    AND DATETIME = :MWIPIDGHIS_N.DATETIME
                    AND KEY_1 = :MWIPIDGHIS_N.KEY_1
                    AND KEY_2 = :MWIPIDGHIS_N.KEY_2
                    AND KEY_3 = :MWIPIDGHIS_N.KEY_3
                    AND KEY_4 = :MWIPIDGHIS_N.KEY_4
                    AND KEY_5 = :MWIPIDGHIS_N.KEY_5
                    AND KEY_6 = :MWIPIDGHIS_N.KEY_6
                    AND KEY_7 = :MWIPIDGHIS_N.KEY_7
                    AND KEY_8 = :MWIPIDGHIS_N.KEY_8
                    AND KEY_9 = :MWIPIDGHIS_N.KEY_9
                    AND KEY_10 = :MWIPIDGHIS_N.KEY_10
                    AND SEQ_NUM > :MWIPIDGHIS_N.SEQ_NUM
                    AND ID_USED_FLAG = :MWIPIDGHIS_N.ID_USED_FLAG
                ORDER BY SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPIDGHIS_CUR_3;
            break;

        case 4:
            EXEC SQL DECLARE DBC_MWIPIDGHIS_CUR_4 CURSOR FOR
                SELECT 
                    RULE_ID,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RES_TYPE,
                    RESG_ID,
                    RES_ID,
                    LOT_ID,
                    SUBLOT_ID,
                    DATETIME,
                    KEY_1,
                    KEY_2,
                    KEY_3,
                    KEY_4,
                    KEY_5,
                    KEY_6,
                    KEY_7,
                    KEY_8,
                    KEY_9,
                    KEY_10,
                    SEQ_NUM,
                    GEN_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    SEQ_POSITION,
                    CONFIRM_KEY,
                    ID_USED_FLAG
                FROM MWIPIDGHIS
                WHERE RULE_ID = :MWIPIDGHIS_N.RULE_ID
                    AND FACTORY = :MWIPIDGHIS_N.FACTORY
                    AND MAT_ID = :MWIPIDGHIS_N.MAT_ID
                    AND MAT_VER = :MWIPIDGHIS_N.MAT_VER
                    AND FLOW = :MWIPIDGHIS_N.FLOW
                    AND OPER = :MWIPIDGHIS_N.OPER
                    AND RES_TYPE = :MWIPIDGHIS_N.RES_TYPE
