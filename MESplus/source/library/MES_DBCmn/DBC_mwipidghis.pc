                    AND KEY_2 = :MWIPIDGHIS_N.KEY_2
                    AND KEY_3 = :MWIPIDGHIS_N.KEY_3
                    AND KEY_4 = :MWIPIDGHIS_N.KEY_4
                    AND KEY_5 = :MWIPIDGHIS_N.KEY_5
                    AND KEY_6 = :MWIPIDGHIS_N.KEY_6
                    AND KEY_7 = :MWIPIDGHIS_N.KEY_7
                    AND KEY_8 = :MWIPIDGHIS_N.KEY_8
                    AND KEY_9 = :MWIPIDGHIS_N.KEY_9
                    AND KEY_10 = :MWIPIDGHIS_N.KEY_10
                    AND SEQ_NUM >= :MWIPIDGHIS_N.SEQ_NUM
                ORDER BY SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPIDGHIS_CUR_4;
            break;

        case 5:
            EXEC SQL DECLARE DBC_MWIPIDGHIS_CUR_5 CURSOR FOR
                SELECT 
                    RULE_ID,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RES_TYPE,
                    RESG_ID,
                    RES_ID,
                    LOT_ID,
                    SUBLOT_ID,
                    DATETIME,
                    KEY_1,
                    KEY_2,
                    KEY_3,
                    KEY_4,
                    KEY_5,
                    KEY_6,
                    KEY_7,
                    KEY_8,
                    KEY_9,
                    KEY_10,
                    SEQ_NUM,
                    GEN_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    SEQ_POSITION,
                    CONFIRM_KEY,
                    ID_USED_FLAG
                FROM MWIPIDGHIS
                WHERE GEN_ID = :MWIPIDGHIS_N.GEN_ID
                    AND CONFIRM_KEY = :MWIPIDGHIS_N.CONFIRM_KEY
                ORDER BY SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPIDGHIS_CUR_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mwipidghis", sel_type);
}


