/* SQL CURSOR CLOSE Function */
void DBC_close_mwipidghis(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPIDGHIS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWIPIDGHIS_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MWIPIDGHIS_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MWIPIDGHIS_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MWIPIDGHIS_CUR_5;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("DBC_close_mwipidghis", sel_type);
}


/* Initialize Function */
void DBC_init_mwipidghis(struct MWIPIDGHIS_TAG *MWIPIDGHIS)
{
    /* memset by Space */
    memset(MWIPIDGHIS, ' ', sizeof(struct MWIPIDGHIS_TAG));
    
    MWIPIDGHIS->MAT_VER = 0;
    MWIPIDGHIS->SEQ_NUM = 0;
}


/* Add Null Function */
void DBC_add_null_mwipidghis(struct MWIPIDGHIS_N_TAG *MWIPIDGHIS_N, struct MWIPIDGHIS_TAG *MWIPIDGHIS)
{
    /* memset by NULL */
    memset(MWIPIDGHIS_N, '\0', sizeof(struct MWIPIDGHIS_N_TAG));
    
    MEMCPY_AN(MWIPIDGHIS_N->RULE_ID, MWIPIDGHIS->RULE_ID, sizeof(MWIPIDGHIS->RULE_ID));
    MEMCPY_AN(MWIPIDGHIS_N->FACTORY, MWIPIDGHIS->FACTORY, sizeof(MWIPIDGHIS->FACTORY));
    MEMCPY_AN(MWIPIDGHIS_N->MAT_ID, MWIPIDGHIS->MAT_ID, sizeof(MWIPIDGHIS->MAT_ID));
    MWIPIDGHIS_N->MAT_VER = MWIPIDGHIS->MAT_VER;
    MEMCPY_AN(MWIPIDGHIS_N->FLOW, MWIPIDGHIS->FLOW, sizeof(MWIPIDGHIS->FLOW));
    MEMCPY_AN(MWIPIDGHIS_N->OPER, MWIPIDGHIS->OPER, sizeof(MWIPIDGHIS->OPER));
    MEMCPY_AN(MWIPIDGHIS_N->RES_TYPE, MWIPIDGHIS->RES_TYPE, sizeof(MWIPIDGHIS->RES_TYPE));
    MEMCPY_AN(MWIPIDGHIS_N->RESG_ID, MWIPIDGHIS->RESG_ID, sizeof(MWIPIDGHIS->RESG_ID));
    MEMCPY_AN(MWIPIDGHIS_N->RES_ID, MWIPIDGHIS->RES_ID, sizeof(MWIPIDGHIS->RES_ID));
    MEMCPY_AN(MWIPIDGHIS_N->LOT_ID, MWIPIDGHIS->LOT_ID, sizeof(MWIPIDGHIS->LOT_ID));
    MEMCPY_AN(MWIPIDGHIS_N->SUBLOT_ID, MWIPIDGHIS->SUBLOT_ID, sizeof(MWIPIDGHIS->SUBLOT_ID));
    MEMCPY_AN(MWIPIDGHIS_N->DATETIME, MWIPIDGHIS->DATETIME, sizeof(MWIPIDGHIS->DATETIME));
    MEMCPY_AN(MWIPIDGHIS_N->KEY_1, MWIPIDGHIS->KEY_1, sizeof(MWIPIDGHIS->KEY_1));
    MEMCPY_AN(MWIPIDGHIS_N->KEY_2, MWIPIDGHIS->KEY_2, sizeof(MWIPIDGHIS->KEY_2));
    MEMCPY_AN(MWIPIDGHIS_N->KEY_3, MWIPIDGHIS->KEY_3, sizeof(MWIPIDGHIS->KEY_3));
    MEMCPY_AN(MWIPIDGHIS_N->KEY_4, MWIPIDGHIS->KEY_4, sizeof(MWIPIDGHIS->KEY_4));
    MEMCPY_AN(MWIPIDGHIS_N->KEY_5, MWIPIDGHIS->KEY_5, sizeof(MWIPIDGHIS->KEY_5));
    MEMCPY_AN(MWIPIDGHIS_N->KEY_6, MWIPIDGHIS->KEY_6, sizeof(MWIPIDGHIS->KEY_6));
    MEMCPY_AN(MWIPIDGHIS_N->KEY_7, MWIPIDGHIS->KEY_7, sizeof(MWIPIDGHIS->KEY_7));
    MEMCPY_AN(MWIPIDGHIS_N->KEY_8, MWIPIDGHIS->KEY_8, sizeof(MWIPIDGHIS->KEY_8));
    MEMCPY_AN(MWIPIDGHIS_N->KEY_9, MWIPIDGHIS->KEY_9, sizeof(MWIPIDGHIS->KEY_9));
    MEMCPY_AN(MWIPIDGHIS_N->KEY_10, MWIPIDGHIS->KEY_10, sizeof(MWIPIDGHIS->KEY_10));
    MWIPIDGHIS_N->SEQ_NUM = MWIPIDGHIS->SEQ_NUM;
    MEMCPY_AN(MWIPIDGHIS_N->GEN_ID, MWIPIDGHIS->GEN_ID, sizeof(MWIPIDGHIS->GEN_ID));
    MEMCPY_AN(MWIPIDGHIS_N->CREATE_USER_ID, MWIPIDGHIS->CREATE_USER_ID, sizeof(MWIPIDGHIS->CREATE_USER_ID));
    MEMCPY_AN(MWIPIDGHIS_N->CREATE_TIME, MWIPIDGHIS->CREATE_TIME, sizeof(MWIPIDGHIS->CREATE_TIME));
    MEMCPY_AN(MWIPIDGHIS_N->SEQ_POSITION, MWIPIDGHIS->SEQ_POSITION, sizeof(MWIPIDGHIS->SEQ_POSITION));
    MEMCPY_AN(MWIPIDGHIS_N->CONFIRM_KEY, MWIPIDGHIS->CONFIRM_KEY, sizeof(MWIPIDGHIS->CONFIRM_KEY));
    MWIPIDGHIS_N->ID_USED_FLAG[0] = MWIPIDGHIS->ID_USED_FLAG;
}


/* Del Null Function */
void DBC_del_null_mwipidghis(struct MWIPIDGHIS_N_TAG *MWIPIDGHIS_N, struct MWIPIDGHIS_TAG *MWIPIDGHIS)
{
    MEMCPY_DN(MWIPIDGHIS->RULE_ID, MWIPIDGHIS_N->RULE_ID, sizeof(MWIPIDGHIS->RULE_ID));
    MEMCPY_DN(MWIPIDGHIS->FACTORY, MWIPIDGHIS_N->FACTORY, sizeof(MWIPIDGHIS->FACTORY));
    MEMCPY_DN(MWIPIDGHIS->MAT_ID, MWIPIDGHIS_N->MAT_ID, sizeof(MWIPIDGHIS->MAT_ID));
    MWIPIDGHIS->MAT_VER = MWIPIDGHIS_N->MAT_VER;
