                                                    :MWIPFACSHP_N.UPDATE_USER_ID,
                                                    :MWIPFACSHP_N.UPDATE_TIME;
            break;
            
        case 2:
            EXEC SQL FETCH DBC_MWIPFACSHP_CUR_2 INTO :MWIPFACSHP_N.FACTORY_TO, :MWIPFACSHP_N.TRANSIT_OPER;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwipfacshp(&MWIPFACSHP_N, MWIPFACSHP);
    }
    DB_stop_query_timer("DBC_fetch_mwipfacshp", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwipfacshp(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPFACSHP_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_MWIPFACSHP_CUR_2;
            break;        


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipfacshp", sel_type);
}


/* Initialize Function */
void DBC_init_mwipfacshp(struct MWIPFACSHP_TAG *MWIPFACSHP)
{
    /* memset by Space */
    memset(MWIPFACSHP, ' ', sizeof(struct MWIPFACSHP_TAG));
    
}


