/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipfacshp(int sel_type, struct MWIPFACSHP_TAG *MWIPFACSHP)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPFACSHP_N_TAG MWIPFACSHP_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipfacshp(&MWIPFACSHP_N, MWIPFACSHP);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPFACSHP_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY_TO,
                    FACTORY_FROM,
                    AUTO_TERM_FLAG,
                    TRANSIT_OPER,
                    REMOTE_FLAG,
                    SHIP_CMF_1,
                    SHIP_CMF_2,
                    SHIP_CMF_3,
                    SHIP_CMF_4,
                    SHIP_CMF_5,
                    SHIP_CMF_6,
                    SHIP_CMF_7,
                    SHIP_CMF_8,
                    SHIP_CMF_9,
                    SHIP_CMF_10,
                    SHIP_CMF_11,
                    SHIP_CMF_12,
                    SHIP_CMF_13,
                    SHIP_CMF_14,
                    SHIP_CMF_15,
                    SHIP_CMF_16,
                    SHIP_CMF_17,
                    SHIP_CMF_18,
                    SHIP_CMF_19,
                    SHIP_CMF_20,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPFACSHP
                WHERE FACTORY_TO = :MWIPFACSHP_N.FACTORY_TO
                ORDER BY FACTORY_FROM ASC;
            EXEC SQL OPEN DBC_MWIPFACSHP_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MWIPFACSHP_CUR_2 CURSOR FOR
                SELECT FACTORY_TO, TRANSIT_OPER
                FROM MWIPFACSHP
                WHERE FACTORY_TO >= :MWIPFACSHP_N.FACTORY_TO
                    AND FACTORY_FROM = :MWIPFACSHP_N.FACTORY_FROM
                ORDER BY FACTORY_TO ASC;
            EXEC SQL OPEN DBC_MWIPFACSHP_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipfacshp", sel_type);
}


