    MRCPLOTHIS->MODIFY_FLAG = MRCPLOTHIS_N->MODIFY_FLAG[0];
    MRCPLOTHIS->INLINE_MODIFY = MRCPLOTHIS_N->INLINE_MODIFY[0];
    MEMCPY_DN(MRCPLOTHIS->UPDATE_USER_ID, MRCPLOTHIS_N->UPDATE_USER_ID, sizeof(MRCPLOTHIS->UPDATE_USER_ID));
    MEMCPY_DN(MRCPLOTHIS->UPDATE_TIME, MRCPLOTHIS_N->UPDATE_TIME, sizeof(MRCPLOTHIS->UPDATE_TIME));
}


