/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrcplothis(int sel_type, struct MRCPLOTHIS_TAG *MRCPLOTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRCPLOTHIS_N_TAG MRCPLOTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrcplothis(&MRCPLOTHIS_N, MRCPLOTHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRCPLOTHIS_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    TRAN_CODE,
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    RECIPE,
                    RECIPE_VERSION,
                    PP_ID,
                    COAT_PP_ID,
                    RETICLE_ID,
                    COL_SET_ID,
                    PROC_TIME,
                    MODIFY_FLAG,
                    INLINE_MODIFY,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRCPLOTHIS
                ORDER BY LOT_ID ASC,
                    TRAN_TIME ASC;
            EXEC SQL OPEN DBC_MRCPLOTHIS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrcplothis", sel_type);
}


