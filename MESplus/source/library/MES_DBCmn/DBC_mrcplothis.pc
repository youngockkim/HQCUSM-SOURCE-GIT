/* Add Null Function */
void DBC_add_null_mrcplothis(struct MRCPLOTHIS_N_TAG *MRCPLOTHIS_N, struct MRCPLOTHIS_TAG *MRCPLOTHIS)
{
    /* memset by NULL */
    memset(MRCPLOTHIS_N, '\0', sizeof(struct MRCPLOTHIS_N_TAG));
    
    MEMCPY_AN(MRCPLOTHIS_N->LOT_ID, MRCPLOTHIS->LOT_ID, sizeof(MRCPLOTHIS->LOT_ID));
    MRCPLOTHIS_N->HIST_SEQ = MRCPLOTHIS->HIST_SEQ;
    MEMCPY_AN(MRCPLOTHIS_N->TRAN_TIME, MRCPLOTHIS->TRAN_TIME, sizeof(MRCPLOTHIS->TRAN_TIME));
    MEMCPY_AN(MRCPLOTHIS_N->TRAN_CODE, MRCPLOTHIS->TRAN_CODE, sizeof(MRCPLOTHIS->TRAN_CODE));
    MEMCPY_AN(MRCPLOTHIS_N->FACTORY, MRCPLOTHIS->FACTORY, sizeof(MRCPLOTHIS->FACTORY));
    MEMCPY_AN(MRCPLOTHIS_N->RES_ID, MRCPLOTHIS->RES_ID, sizeof(MRCPLOTHIS->RES_ID));
    MEMCPY_AN(MRCPLOTHIS_N->SUBRES_ID, MRCPLOTHIS->SUBRES_ID, sizeof(MRCPLOTHIS->SUBRES_ID));
    MEMCPY_AN(MRCPLOTHIS_N->RECIPE, MRCPLOTHIS->RECIPE, sizeof(MRCPLOTHIS->RECIPE));
    MRCPLOTHIS_N->RECIPE_VERSION = MRCPLOTHIS->RECIPE_VERSION;
    MEMCPY_AN(MRCPLOTHIS_N->PP_ID, MRCPLOTHIS->PP_ID, sizeof(MRCPLOTHIS->PP_ID));
    MEMCPY_AN(MRCPLOTHIS_N->COAT_PP_ID, MRCPLOTHIS->COAT_PP_ID, sizeof(MRCPLOTHIS->COAT_PP_ID));
    MEMCPY_AN(MRCPLOTHIS_N->RETICLE_ID, MRCPLOTHIS->RETICLE_ID, sizeof(MRCPLOTHIS->RETICLE_ID));
    MEMCPY_AN(MRCPLOTHIS_N->COL_SET_ID, MRCPLOTHIS->COL_SET_ID, sizeof(MRCPLOTHIS->COL_SET_ID));
    MEMCPY_AN(MRCPLOTHIS_N->PROC_TIME, MRCPLOTHIS->PROC_TIME, sizeof(MRCPLOTHIS->PROC_TIME));
    MRCPLOTHIS_N->MODIFY_FLAG[0] = MRCPLOTHIS->MODIFY_FLAG;
    MRCPLOTHIS_N->INLINE_MODIFY[0] = MRCPLOTHIS->INLINE_MODIFY;
    MEMCPY_AN(MRCPLOTHIS_N->UPDATE_USER_ID, MRCPLOTHIS->UPDATE_USER_ID, sizeof(MRCPLOTHIS->UPDATE_USER_ID));
    MEMCPY_AN(MRCPLOTHIS_N->UPDATE_TIME, MRCPLOTHIS->UPDATE_TIME, sizeof(MRCPLOTHIS->UPDATE_TIME));
}


/* Del Null Function */
