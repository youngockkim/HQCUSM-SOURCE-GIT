    MWIPSLTMVH->HIST_DEL_FLAG = MWIPSLTMVH_N->HIST_DEL_FLAG[0];
    MEMCPY_DN(MWIPSLTMVH->FACTORY, MWIPSLTMVH_N->FACTORY, sizeof(MWIPSLTMVH->FACTORY));
    MEMCPY_DN(MWIPSLTMVH->MAT_ID, MWIPSLTMVH_N->MAT_ID, sizeof(MWIPSLTMVH->MAT_ID));
    MWIPSLTMVH->MAT_VER = MWIPSLTMVH_N->MAT_VER;
    MEMCPY_DN(MWIPSLTMVH->FLOW, MWIPSLTMVH_N->FLOW, sizeof(MWIPSLTMVH->FLOW));
    MWIPSLTMVH->FLOW_SEQ_NUM = MWIPSLTMVH_N->FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPSLTMVH->OPER, MWIPSLTMVH_N->OPER, sizeof(MWIPSLTMVH->OPER));
    MEMCPY_DN(MWIPSLTMVH->START_TIME, MWIPSLTMVH_N->START_TIME, sizeof(MWIPSLTMVH->START_TIME));
    MEMCPY_DN(MWIPSLTMVH->END_TIME, MWIPSLTMVH_N->END_TIME, sizeof(MWIPSLTMVH->END_TIME));
    MEMCPY_DN(MWIPSLTMVH->OPER_IN_TIME, MWIPSLTMVH_N->OPER_IN_TIME, sizeof(MWIPSLTMVH->OPER_IN_TIME));
    MWIPSLTMVH->QUEUE_TIME = MWIPSLTMVH_N->QUEUE_TIME;
