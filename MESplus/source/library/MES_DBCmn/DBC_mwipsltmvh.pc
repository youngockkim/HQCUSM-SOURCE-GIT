/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipsltmvh(int sel_type, struct MWIPSLTMVH_TAG *MWIPSLTMVH)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSLTMVH_N_TAG MWIPSLTMVH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipsltmvh(&MWIPSLTMVH_N, MWIPSLTMVH);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPSLTMVH_CUR_1 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    TRAN_CODE,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    START_TIME,
                    END_TIME,
                    OPER_IN_TIME,
                    QUEUE_TIME,
                    PROC_TIME,
                    TOTAL_TIME
                FROM MWIPSLTMVH
                ORDER BY SUBLOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MWIPSLTMVH_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipsltmvh", sel_type);
}


