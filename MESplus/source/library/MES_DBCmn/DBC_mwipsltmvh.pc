void DBC_add_null_mwipsltmvh(struct MWIPSLTMVH_N_TAG *MWIPSLTMVH_N, struct MWIPSLTMVH_TAG *MWIPSLTMVH)
{
    /* memset by NULL */
    memset(MWIPSLTMVH_N, '\0', sizeof(struct MWIPSLTMVH_N_TAG));
    
    MEMCPY_AN(MWIPSLTMVH_N->SUBLOT_ID, MWIPSLTMVH->SUBLOT_ID, sizeof(MWIPSLTMVH->SUBLOT_ID));
    MEMCPY_AN(MWIPSLTMVH_N->LOT_ID, MWIPSLTMVH->LOT_ID, sizeof(MWIPSLTMVH->LOT_ID));
    MWIPSLTMVH_N->HIST_SEQ = MWIPSLTMVH->HIST_SEQ;
    MEMCPY_AN(MWIPSLTMVH_N->TRAN_TIME, MWIPSLTMVH->TRAN_TIME, sizeof(MWIPSLTMVH->TRAN_TIME));
    MEMCPY_AN(MWIPSLTMVH_N->TRAN_CODE, MWIPSLTMVH->TRAN_CODE, sizeof(MWIPSLTMVH->TRAN_CODE));
    MWIPSLTMVH_N->HIST_DEL_FLAG[0] = MWIPSLTMVH->HIST_DEL_FLAG;
    MEMCPY_AN(MWIPSLTMVH_N->FACTORY, MWIPSLTMVH->FACTORY, sizeof(MWIPSLTMVH->FACTORY));
    MEMCPY_AN(MWIPSLTMVH_N->MAT_ID, MWIPSLTMVH->MAT_ID, sizeof(MWIPSLTMVH->MAT_ID));
    MWIPSLTMVH_N->MAT_VER = MWIPSLTMVH->MAT_VER;
    MEMCPY_AN(MWIPSLTMVH_N->FLOW, MWIPSLTMVH->FLOW, sizeof(MWIPSLTMVH->FLOW));
    MWIPSLTMVH_N->FLOW_SEQ_NUM = MWIPSLTMVH->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPSLTMVH_N->OPER, MWIPSLTMVH->OPER, sizeof(MWIPSLTMVH->OPER));
    MEMCPY_AN(MWIPSLTMVH_N->START_TIME, MWIPSLTMVH->START_TIME, sizeof(MWIPSLTMVH->START_TIME));
    MEMCPY_AN(MWIPSLTMVH_N->END_TIME, MWIPSLTMVH->END_TIME, sizeof(MWIPSLTMVH->END_TIME));
    MEMCPY_AN(MWIPSLTMVH_N->OPER_IN_TIME, MWIPSLTMVH->OPER_IN_TIME, sizeof(MWIPSLTMVH->OPER_IN_TIME));
    MWIPSLTMVH_N->QUEUE_TIME = MWIPSLTMVH->QUEUE_TIME;
    MWIPSLTMVH_N->PROC_TIME = MWIPSLTMVH->PROC_TIME;
    MWIPSLTMVH_N->TOTAL_TIME = MWIPSLTMVH->TOTAL_TIME;
}


/* Del Null Function */
void DBC_del_null_mwipsltmvh(struct MWIPSLTMVH_N_TAG *MWIPSLTMVH_N, struct MWIPSLTMVH_TAG *MWIPSLTMVH)
{
    MEMCPY_DN(MWIPSLTMVH->SUBLOT_ID, MWIPSLTMVH_N->SUBLOT_ID, sizeof(MWIPSLTMVH->SUBLOT_ID));
    MEMCPY_DN(MWIPSLTMVH->LOT_ID, MWIPSLTMVH_N->LOT_ID, sizeof(MWIPSLTMVH->LOT_ID));
