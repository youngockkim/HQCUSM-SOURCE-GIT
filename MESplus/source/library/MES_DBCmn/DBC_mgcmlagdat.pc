                FROM MGCMLAGDAT
                WHERE FACTORY = :MGCMLAGDAT_N.FACTORY
                    AND TABLE_NAME = :MGCMLAGDAT_N.TABLE_NAME
                ORDER BY DATA_3, KEY_1;
            EXEC SQL OPEN DBC_MGCMLAGDAT_CUR_106;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
