                            (KEY_1 = :MGCMLAGDAT_N.DATA_1 AND KEY_2 = :MGCMLAGDAT_N.DATA_2 AND KEY_3 = :MGCMLAGDAT_N.DATA_3 AND KEY_4 = :MGCMLAGDAT_N.DATA_4 AND KEY_5 > :MGCMLAGDAT_N.DATA_5) OR
                            (KEY_1 = :MGCMLAGDAT_N.DATA_1 AND KEY_2 = :MGCMLAGDAT_N.DATA_2 AND KEY_3 = :MGCMLAGDAT_N.DATA_3 AND KEY_4 = :MGCMLAGDAT_N.DATA_4 AND KEY_5 = :MGCMLAGDAT_N.DATA_5 AND KEY_6 > :MGCMLAGDAT_N.DATA_6) OR
                            (KEY_1 = :MGCMLAGDAT_N.DATA_1 AND KEY_2 = :MGCMLAGDAT_N.DATA_2 AND KEY_3 = :MGCMLAGDAT_N.DATA_3 AND KEY_4 = :MGCMLAGDAT_N.DATA_4 AND KEY_5 = :MGCMLAGDAT_N.DATA_5 AND KEY_6 = :MGCMLAGDAT_N.DATA_6 AND KEY_7 > :MGCMLAGDAT_N.DATA_7) OR
