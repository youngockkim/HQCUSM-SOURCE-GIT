                    AND KEY_8  LIKE :MGCMLAGDAT_N.KEY_8
                    AND KEY_9  LIKE :MGCMLAGDAT_N.KEY_9
                    AND KEY_10 LIKE :MGCMLAGDAT_N.KEY_10
                    AND DATA_2 = :MGCMLAGDAT_N.DATA_2
                ORDER BY KEY_1, TO_NUMBER(KEY_2);
            EXEC SQL OPEN DBC_MGCMLAGDAT_CUR_105;
