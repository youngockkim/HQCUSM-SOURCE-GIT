                FROM MGCMLAGDAT
                WHERE FACTORY = :MGCMLAGDAT_N.FACTORY
                    AND TABLE_NAME = :MGCMLAGDAT_N.TABLE_NAME
                    AND KEY_1  LIKE :MGCMLAGDAT_N.KEY_1
                    AND KEY_2  LIKE :MGCMLAGDAT_N.KEY_2
