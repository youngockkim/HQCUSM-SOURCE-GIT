/* SQL CURSOR CLOSE Function */
void DBC_close_mgcmlagdat(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MGCMLAGDAT_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MGCMLAGDAT_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MGCMLAGDAT_CUR_3;
            break;

		case 101:
            EXEC SQL CLOSE DBC_MGCMLAGDAT_CUR_101;
            break;

		case 102:
            EXEC SQL CLOSE DBC_MGCMLAGDAT_CUR_102;
            break;

		case 103:
            EXEC SQL CLOSE DBC_MGCMLAGDAT_CUR_103;
            break;

		case 104:
            EXEC SQL CLOSE DBC_MGCMLAGDAT_CUR_104;
            break;

		case 105:
            EXEC SQL CLOSE DBC_MGCMLAGDAT_CUR_105;
            break;

		case 106:
            EXEC SQL CLOSE DBC_MGCMLAGDAT_CUR_106;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mgcmlagdat", sel_type);
}


/* Initialize Function */
void DBC_init_mgcmlagdat(struct MGCMLAGDAT_TAG *MGCMLAGDAT)
{
    /* memset by Space */
    memset(MGCMLAGDAT, ' ', sizeof(struct MGCMLAGDAT_TAG));
    
}


