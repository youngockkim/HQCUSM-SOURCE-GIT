                            (KEY_1 = :MGCMLAGDAT_N.DATA_1 AND KEY_2 = :MGCMLAGDAT_N.DATA_2 AND KEY_3 = :MGCMLAGDAT_N.DATA_3 AND KEY_4 = :MGCMLAGDAT_N.DATA_4 AND KEY_5 = :MGCMLAGDAT_N.DATA_5 AND KEY_6 = :MGCMLAGDAT_N.DATA_6 AND KEY_7 = :MGCMLAGDAT_N.DATA_7 AND KEY_8 = :MGCMLAGDAT_N.DATA_8 AND KEY_9 = :MGCMLAGDAT_N.DATA_9 AND KEY_10 >= :MGCMLAGDAT_N.DATA_10)
