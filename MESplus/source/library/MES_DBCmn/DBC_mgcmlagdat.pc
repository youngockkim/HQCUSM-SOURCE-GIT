                    KEY_6,
                    KEY_7,
                    KEY_8,
                    KEY_9,
                    KEY_10,
                    DATA_1,
                    DATA_2,
                    DATA_3,
                    DATA_4,
                    DATA_5,
                    DATA_6,
                    DATA_7,
                    DATA_8,
                    DATA_9,
                    DATA_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MGCMLAGDAT
                WHERE FACTORY = :MGCMLAGDAT_N.FACTORY
                    AND TABLE_NAME = :MGCMLAGDAT_N.TABLE_NAME
                    AND KEY_1 >= :MGCMLAGDAT_N.KEY_1
                ORDER BY KEY_1;
            EXEC SQL OPEN DBC_MGCMLAGDAT_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MGCMLAGDAT_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    TABLE_NAME,
                    KEY_1,
                    KEY_2,
                    KEY_3,
                    KEY_4,
                    KEY_5,
                    KEY_6,
                    KEY_7,
