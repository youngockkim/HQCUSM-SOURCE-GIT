    EXEC SQL BEGIN DECLARE SECTION;
        struct MSECLICKEY_N_TAG MSECLICKEY_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mseclickey(&MSECLICKEY_N, MSECLICKEY);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSECLICKEY_CUR_1 CURSOR FOR
                SELECT 
                    LICENSE_ID,
                    LICENSE_ID_DESC,
                    LICENSE_TIME,
                    PRODUCT,
                    CUSTOMER_COMPANY,
                    CONCURRENT_USER_LIMIT,
                    CONCURRENT_USER_LIMIT_DESC,
                    NAMED_USER_LIMIT,
                    NAMED_USER_LIMIT_DESC,
                    EXPIRE_TIME,
                    EXPIRE_TIME_DESC,
                    SERVER_IP_ADDRESS,
                    SERVER_IP_ADDRESS_DESC,
                    ENABLE_MODULE,
                    ENABLE_MODULE_DESC
                FROM MSECLICKEY
                ORDER BY LICENSE_TIME ASC;
            EXEC SQL OPEN DBC_MSECLICKEY_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mseclickey", sel_type);
}


