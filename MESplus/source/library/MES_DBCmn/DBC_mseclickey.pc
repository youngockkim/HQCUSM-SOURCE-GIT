        struct MSECLICKEY_N_TAG MSECLICKEY_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mseclickey(&MSECLICKEY_N, MSECLICKEY);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT 
                         LICENSE_ID,
                         LICENSE_ID_DESC,
                         LICENSE_TIME,
                         PRODUCT,
                         CUSTOMER_COMPANY,
                         CONCURRENT_USER_LIMIT,
                         CONCURRENT_USER_LIMIT_DESC,
                         NAMED_USER_LIMIT,
                         NAMED_USER_LIMIT_DESC,
                         EXPIRE_TIME,
                         EXPIRE_TIME_DESC,
                         SERVER_IP_ADDRESS,
                         SERVER_IP_ADDRESS_DESC,
                         ENABLE_MODULE,
                         ENABLE_MODULE_DESC
                INTO 
                    :MSECLICKEY_N.LICENSE_ID,
                    :MSECLICKEY_N.LICENSE_ID_DESC,
                    :MSECLICKEY_N.LICENSE_TIME,
                    :MSECLICKEY_N.PRODUCT,
                    :MSECLICKEY_N.CUSTOMER_COMPANY,
                    :MSECLICKEY_N.CONCURRENT_USER_LIMIT,
                    :MSECLICKEY_N.CONCURRENT_USER_LIMIT_DESC,
                    :MSECLICKEY_N.NAMED_USER_LIMIT,
                    :MSECLICKEY_N.NAMED_USER_LIMIT_DESC,
                    :MSECLICKEY_N.EXPIRE_TIME,
                    :MSECLICKEY_N.EXPIRE_TIME_DESC,
                    :MSECLICKEY_N.SERVER_IP_ADDRESS,
                    :MSECLICKEY_N.SERVER_IP_ADDRESS_DESC,
                    :MSECLICKEY_N.ENABLE_MODULE,
                    :MSECLICKEY_N.ENABLE_MODULE_DESC
                FROM MSECLICKEY
                WHERE LICENSE_TIME = ( SELECT NVL(MAX(LICENSE_TIME), ' ') 
                                       FROM MSECLICKEY
                                     );
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mseclickey(&MSECLICKEY_N, MSECLICKEY);
    }
    DB_stop_query_timer("DBC_select_mseclickey", sel_type);
}


