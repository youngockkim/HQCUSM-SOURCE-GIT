    memset(MSECPRVDEF, ' ', sizeof(struct MSECPRVDEF_TAG));
    
}


/* Add Null Function */
void DBC_add_null_msecprvdef(struct MSECPRVDEF_N_TAG *MSECPRVDEF_N, struct MSECPRVDEF_TAG *MSECPRVDEF)
{
    /* memset by NULL */
    memset(MSECPRVDEF_N, '\0', sizeof(struct MSECPRVDEF_N_TAG));
    
    MEMCPY_AN(MSECPRVDEF_N->FACTORY, MSECPRVDEF->FACTORY, sizeof(MSECPRVDEF->FACTORY));
    MEMCPY_AN(MSECPRVDEF_N->PRV_TYPE, MSECPRVDEF->PRV_TYPE, sizeof(MSECPRVDEF->PRV_TYPE));
    MEMCPY_AN(MSECPRVDEF_N->PRV_ITEM1, MSECPRVDEF->PRV_ITEM1, sizeof(MSECPRVDEF->PRV_ITEM1));
    MEMCPY_AN(MSECPRVDEF_N->PRV_ITEM2, MSECPRVDEF->PRV_ITEM2, sizeof(MSECPRVDEF->PRV_ITEM2));
    MEMCPY_AN(MSECPRVDEF_N->PRV_ITEM3, MSECPRVDEF->PRV_ITEM3, sizeof(MSECPRVDEF->PRV_ITEM3));
    MEMCPY_AN(MSECPRVDEF_N->PRV_GRP_ID, MSECPRVDEF->PRV_GRP_ID, sizeof(MSECPRVDEF->PRV_GRP_ID));
    MEMCPY_AN(MSECPRVDEF_N->CREATE_USER_ID, MSECPRVDEF->CREATE_USER_ID, sizeof(MSECPRVDEF->CREATE_USER_ID));
    MEMCPY_AN(MSECPRVDEF_N->CREATE_TIME, MSECPRVDEF->CREATE_TIME, sizeof(MSECPRVDEF->CREATE_TIME));
    MEMCPY_AN(MSECPRVDEF_N->UPDATE_USER_ID, MSECPRVDEF->UPDATE_USER_ID, sizeof(MSECPRVDEF->UPDATE_USER_ID));
    MEMCPY_AN(MSECPRVDEF_N->UPDATE_TIME, MSECPRVDEF->UPDATE_TIME, sizeof(MSECPRVDEF->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_msecprvdef(struct MSECPRVDEF_N_TAG *MSECPRVDEF_N, struct MSECPRVDEF_TAG *MSECPRVDEF)
{
    MEMCPY_DN(MSECPRVDEF->FACTORY, MSECPRVDEF_N->FACTORY, sizeof(MSECPRVDEF->FACTORY));
    MEMCPY_DN(MSECPRVDEF->PRV_TYPE, MSECPRVDEF_N->PRV_TYPE, sizeof(MSECPRVDEF->PRV_TYPE));
    MEMCPY_DN(MSECPRVDEF->PRV_ITEM1, MSECPRVDEF_N->PRV_ITEM1, sizeof(MSECPRVDEF->PRV_ITEM1));
    MEMCPY_DN(MSECPRVDEF->PRV_ITEM2, MSECPRVDEF_N->PRV_ITEM2, sizeof(MSECPRVDEF->PRV_ITEM2));
    MEMCPY_DN(MSECPRVDEF->PRV_ITEM3, MSECPRVDEF_N->PRV_ITEM3, sizeof(MSECPRVDEF->PRV_ITEM3));
    MEMCPY_DN(MSECPRVDEF->PRV_GRP_ID, MSECPRVDEF_N->PRV_GRP_ID, sizeof(MSECPRVDEF->PRV_GRP_ID));
    MEMCPY_DN(MSECPRVDEF->CREATE_USER_ID, MSECPRVDEF_N->CREATE_USER_ID, sizeof(MSECPRVDEF->CREATE_USER_ID));
    MEMCPY_DN(MSECPRVDEF->CREATE_TIME, MSECPRVDEF_N->CREATE_TIME, sizeof(MSECPRVDEF->CREATE_TIME));
    MEMCPY_DN(MSECPRVDEF->UPDATE_USER_ID, MSECPRVDEF_N->UPDATE_USER_ID, sizeof(MSECPRVDEF->UPDATE_USER_ID));
