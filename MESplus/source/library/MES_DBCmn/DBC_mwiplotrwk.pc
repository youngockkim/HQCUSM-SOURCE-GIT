                                                    :MWIPLOTRWK_N.LOT_ID,
                                                    :MWIPLOTRWK_N.HIST_SEQ,
                                                    :MWIPLOTRWK_N.TRAN_TIME,
                                                    :MWIPLOTRWK_N.HIST_DEL_FLAG,
                                                    :MWIPLOTRWK_N.FACTORY,
                                                    :MWIPLOTRWK_N.MAT_ID,
                                                    :MWIPLOTRWK_N.MAT_VER,
                                                    :MWIPLOTRWK_N.FLOW,
                                                    :MWIPLOTRWK_N.FLOW_SEQ_NUM,
                                                    :MWIPLOTRWK_N.OPER,
                                                    :MWIPLOTRWK_N.RES_ID,
                                                    :MWIPLOTRWK_N.CAUSE_FLOW,
                                                    :MWIPLOTRWK_N.CAUSE_OPER,
                                                    :MWIPLOTRWK_N.CAUSE_RES_ID,
                                                    :MWIPLOTRWK_N.QTY_1,
                                                    :MWIPLOTRWK_N.QTY_2,
                                                    :MWIPLOTRWK_N.QTY_3,
                                                    :MWIPLOTRWK_N.RWK_CODE,
                                                    :MWIPLOTRWK_N.RWK_COUNT,
                                                    :MWIPLOTRWK_N.RWK_DEPTH,
                                                    :MWIPLOTRWK_N.RWK_FLOW,
                                                    :MWIPLOTRWK_N.RWK_FLOW_SEQ_NUM,
                                                    :MWIPLOTRWK_N.RWK_OPER,
                                                    :MWIPLOTRWK_N.RWK_STOP_OPER,
                                                    :MWIPLOTRWK_N.RWK_RET_FLOW,
                                                    :MWIPLOTRWK_N.RWK_RET_FLOW_SEQ_NUM,
                                                    :MWIPLOTRWK_N.RWK_RET_OPER,
                                                    :MWIPLOTRWK_N.RWK_END_FLOW,
                                                    :MWIPLOTRWK_N.RWK_END_FLOW_SEQ_NUM,
                                                    :MWIPLOTRWK_N.RWK_END_OPER,
                                                    :MWIPLOTRWK_N.RWK_RET_CLEAR_FLAG,
                                                    :MWIPLOTRWK_N.LOCAL_REWORK_FLAG,
                                                    :MWIPLOTRWK_N.RWK_USER_ID,
                                                    :MWIPLOTRWK_N.RWK_COMMENT,
                                                    :MWIPLOTRWK_N.USER_ID_1,
                                                    :MWIPLOTRWK_N.USER_TIME_1,
                                                    :MWIPLOTRWK_N.USER_COMMENT_1,
                                                    :MWIPLOTRWK_N.USER_ID_2,
                                                    :MWIPLOTRWK_N.USER_TIME_2,
                                                    :MWIPLOTRWK_N.USER_COMMENT_2,
                                                    :MWIPLOTRWK_N.USER_ID_3,
                                                    :MWIPLOTRWK_N.USER_TIME_3,
                                                    :MWIPLOTRWK_N.USER_COMMENT_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwiplotrwk(&MWIPLOTRWK_N, MWIPLOTRWK);
    }
    DB_stop_query_timer("DBC_fetch_mwiplotrwk", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwiplotrwk(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPLOTRWK_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwiplotrwk", sel_type);
}


/* Initialize Function */
void DBC_init_mwiplotrwk(struct MWIPLOTRWK_TAG *MWIPLOTRWK)
{
    /* memset by Space */
    memset(MWIPLOTRWK, ' ', sizeof(struct MWIPLOTRWK_TAG));
    
    MWIPLOTRWK->HIST_SEQ = 0;
    MWIPLOTRWK->MAT_VER = 0;
    MWIPLOTRWK->FLOW_SEQ_NUM = 0;
    MWIPLOTRWK->QTY_1 = 0;
    MWIPLOTRWK->QTY_2 = 0;
    MWIPLOTRWK->QTY_3 = 0;
    MWIPLOTRWK->RWK_COUNT = 0;
    MWIPLOTRWK->RWK_DEPTH = 0;
    MWIPLOTRWK->RWK_FLOW_SEQ_NUM = 0;
    MWIPLOTRWK->RWK_RET_FLOW_SEQ_NUM = 0;
    MWIPLOTRWK->RWK_END_FLOW_SEQ_NUM = 0;
}


