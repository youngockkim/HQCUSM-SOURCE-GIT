    MEMCPY_AN(MWIPSTPSTS_N->STEP, MWIPSTPSTS->STEP, sizeof(MWIPSTPSTS->STEP));
    MWIPSTPSTS_N->START_FLAG[0] = MWIPSTPSTS->START_FLAG;
