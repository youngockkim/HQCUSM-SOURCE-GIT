    memset(MWIPSTPSTS_N, '\0', sizeof(struct MWIPSTPSTS_N_TAG));
    
    MEMCPY_AN(MWIPSTPSTS_N->LOT_ID, MWIPSTPSTS->LOT_ID, sizeof(MWIPSTPSTS->LOT_ID));
