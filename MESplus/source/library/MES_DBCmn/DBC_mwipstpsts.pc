/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipstpsts(int sel_type, struct MWIPSTPSTS_TAG *MWIPSTPSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSTPSTS_N_TAG MWIPSTPSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipstpsts(&MWIPSTPSTS_N, MWIPSTPSTS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPSTPSTS_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    STEP,
                    START_FLAG,
                    END_FLAG,
                    LAST_TRAN_CODE,
                    LAST_TRAN_TIME,
                    LAST_TRAN_COMMENT,
                    LAST_ACTIVE_HIST_SEQ,
                    LAST_HIST_SEQ
                FROM MWIPSTPSTS
                ORDER BY LOT_ID ASC;
            EXEC SQL OPEN DBC_MWIPSTPSTS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipstpsts", sel_type);
}


