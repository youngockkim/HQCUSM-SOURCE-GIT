    MEMCPY_AN(MWIPSTPSTS_N->LAST_TRAN_CODE, MWIPSTPSTS->LAST_TRAN_CODE, sizeof(MWIPSTPSTS->LAST_TRAN_CODE));
    MEMCPY_AN(MWIPSTPSTS_N->LAST_TRAN_TIME, MWIPSTPSTS->LAST_TRAN_TIME, sizeof(MWIPSTPSTS->LAST_TRAN_TIME));
