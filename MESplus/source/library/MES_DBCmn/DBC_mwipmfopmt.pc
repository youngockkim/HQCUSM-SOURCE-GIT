                    DATA_TBL_2,
                    DATA_TBL_3,
                    DATA_TBL_4,
                    DATA_TBL_5,
                    DATA_TBL_6,
                    DATA_TBL_7,
                    DATA_TBL_8,
                    DATA_TBL_9,
                    DATA_TBL_10,
                    DATA_TBL_11,
                    DATA_TBL_12,
                    DATA_TBL_13,
                    DATA_TBL_14,
                    DATA_TBL_15,
                    DATA_TBL_16,
                    DATA_TBL_17,
                    DATA_TBL_18,
                    DATA_TBL_19,
                    DATA_TBL_20,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPMFOPMT
                WHERE FACTORY = :MWIPMFOPMT_N.FACTORY
                    AND SYS_PMT_FLAG = :MWIPMFOPMT_N.SYS_PMT_FLAG
                ORDER BY OPTION_NAME ASC;
            EXEC SQL OPEN DBC_MWIPMFOPMT_CUR_2;
            break;



        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipmfopmt", sel_type);
}


