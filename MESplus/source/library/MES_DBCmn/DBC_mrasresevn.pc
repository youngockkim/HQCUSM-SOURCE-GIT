    DBC_add_null_mrasresevn(&MRASRESEVN_N, MRASRESEVN);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRASRESEVN_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    EVENT_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RES_TYPE
                FROM MRASRESEVN
                WHERE FACTORY = :MRASRESEVN_N.FACTORY
                    AND RES_ID = :MRASRESEVN_N.RES_ID
                    AND RES_TYPE = :MRASRESEVN_N.RES_TYPE
                ORDER BY EVENT_ID ASC;
            EXEC SQL OPEN DBC_MRASRESEVN_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MRASRESEVN_CUR_2 CURSOR FOR
                SELECT RES_ID, EVENT_ID, RES_TYPE 
                FROM MRASRESEVN
                WHERE FACTORY = :MRASRESEVN_N.FACTORY
                    AND RES_ID = :MRASRESEVN_N.RES_ID
                    AND EVENT_ID >= :MRASRESEVN_N.EVENT_ID
                    AND RES_TYPE = :MRASRESEVN_N.RES_TYPE
                ORDER BY EVENT_ID ASC;
            EXEC SQL OPEN DBC_MRASRESEVN_CUR_2;
            break;
            
        case 3:
            EXEC SQL DECLARE DBC_MRASRESEVN_CUR_3 CURSOR FOR
                SELECT RES_ID, EVENT_ID, RES_TYPE 
                FROM MRASRESEVN
                WHERE FACTORY = :MRASRESEVN_N.FACTORY
                    AND RES_ID >= :MRASRESEVN_N.RES_ID
                    AND EVENT_ID = :MRASRESEVN_N.EVENT_ID
                    AND RES_TYPE = :MRASRESEVN_N.RES_TYPE
                ORDER BY EVENT_ID ASC;
            EXEC SQL OPEN DBC_MRASRESEVN_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
