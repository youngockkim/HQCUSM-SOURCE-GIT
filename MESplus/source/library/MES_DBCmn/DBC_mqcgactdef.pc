                    RESV_FIELD_8,
                    RESV_FIELD_9,
                    RESV_FIELD_10,
                    CREATE_USER,
                    CREATE_TIME,
                    UPDATE_USER,
                    UPDATE_TIME
                FROM MQCGACTDEF
                WHERE FACTORY =:MQCGACTDEF_N.FACTORY AND
				RULE_ID >=:MQCGACTDEF_N.RULE_ID 
                ORDER BY FACTORY ASC,
                    RULE_ID ASC;
            EXEC SQL OPEN DBC_MQCGACTDEF_CUR_2;
