/* Del Null Function */
void DBC_del_null_mqcgactdef(struct MQCGACTDEF_N_TAG *MQCGACTDEF_N, struct MQCGACTDEF_TAG *MQCGACTDEF)
{
    MEMCPY_DN(MQCGACTDEF->FACTORY, MQCGACTDEF_N->FACTORY, sizeof(MQCGACTDEF->FACTORY));
    MEMCPY_DN(MQCGACTDEF->RULE_ID, MQCGACTDEF_N->RULE_ID, sizeof(MQCGACTDEF->RULE_ID));
    MEMCPY_DN(MQCGACTDEF->RULE_DESC, MQCGACTDEF_N->RULE_DESC, sizeof(MQCGACTDEF->RULE_DESC));
    MEMCPY_DN(MQCGACTDEF->PASS_FLAG, MQCGACTDEF_N->PASS_FLAG, sizeof(MQCGACTDEF->PASS_FLAG));
    MEMCPY_DN(MQCGACTDEF->ALARM_CODE, MQCGACTDEF_N->ALARM_CODE, sizeof(MQCGACTDEF->ALARM_CODE));
    MQCGACTDEF->PROTECT_END = MQCGACTDEF_N->PROTECT_END[0];
    MEMCPY_DN(MQCGACTDEF->QA_RUL_CMF_1, MQCGACTDEF_N->QA_RUL_CMF_1, sizeof(MQCGACTDEF->QA_RUL_CMF_1));
    MEMCPY_DN(MQCGACTDEF->QA_RUL_CMF_2, MQCGACTDEF_N->QA_RUL_CMF_2, sizeof(MQCGACTDEF->QA_RUL_CMF_2));
