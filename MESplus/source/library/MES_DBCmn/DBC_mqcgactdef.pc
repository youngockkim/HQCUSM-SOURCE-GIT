    MEMCPY_AN(MQCGACTDEF_N->RESV_FIELD_1, MQCGACTDEF->RESV_FIELD_1, sizeof(MQCGACTDEF->RESV_FIELD_1));
    MEMCPY_AN(MQCGACTDEF_N->RESV_FIELD_2, MQCGACTDEF->RESV_FIELD_2, sizeof(MQCGACTDEF->RESV_FIELD_2));
    MEMCPY_AN(MQCGACTDEF_N->RESV_FIELD_3, MQCGACTDEF->RESV_FIELD_3, sizeof(MQCGACTDEF->RESV_FIELD_3));
    MEMCPY_AN(MQCGACTDEF_N->RESV_FIELD_4, MQCGACTDEF->RESV_FIELD_4, sizeof(MQCGACTDEF->RESV_FIELD_4));
    MEMCPY_AN(MQCGACTDEF_N->RESV_FIELD_5, MQCGACTDEF->RESV_FIELD_5, sizeof(MQCGACTDEF->RESV_FIELD_5));
    MEMCPY_AN(MQCGACTDEF_N->RESV_FIELD_6, MQCGACTDEF->RESV_FIELD_6, sizeof(MQCGACTDEF->RESV_FIELD_6));
    MEMCPY_AN(MQCGACTDEF_N->RESV_FIELD_7, MQCGACTDEF->RESV_FIELD_7, sizeof(MQCGACTDEF->RESV_FIELD_7));
    MEMCPY_AN(MQCGACTDEF_N->RESV_FIELD_8, MQCGACTDEF->RESV_FIELD_8, sizeof(MQCGACTDEF->RESV_FIELD_8));
    MEMCPY_AN(MQCGACTDEF_N->RESV_FIELD_9, MQCGACTDEF->RESV_FIELD_9, sizeof(MQCGACTDEF->RESV_FIELD_9));
    MEMCPY_AN(MQCGACTDEF_N->RESV_FIELD_10, MQCGACTDEF->RESV_FIELD_10, sizeof(MQCGACTDEF->RESV_FIELD_10));
