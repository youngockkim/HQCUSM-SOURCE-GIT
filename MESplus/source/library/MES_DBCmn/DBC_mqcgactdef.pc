            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mqcgactdef(&MQCGACTDEF_N, MQCGACTDEF);
    }
    DB_stop_query_timer("DBC_fetch_mqcgactdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mqcgactdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MQCGACTDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MQCGACTDEF_CUR_2;
            break; 


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mqcgactdef", sel_type);
}


/* Initialize Function */
void DBC_init_mqcgactdef(struct MQCGACTDEF_TAG *MQCGACTDEF)
{
    /* memset by Space */
    memset(MQCGACTDEF, ' ', sizeof(struct MQCGACTDEF_TAG));
    
}


/* Add Null Function */
void DBC_add_null_mqcgactdef(struct MQCGACTDEF_N_TAG *MQCGACTDEF_N, struct MQCGACTDEF_TAG *MQCGACTDEF)
{
    /* memset by NULL */
    memset(MQCGACTDEF_N, '\0', sizeof(struct MQCGACTDEF_N_TAG));
    
    MEMCPY_AN(MQCGACTDEF_N->FACTORY, MQCGACTDEF->FACTORY, sizeof(MQCGACTDEF->FACTORY));
    MEMCPY_AN(MQCGACTDEF_N->RULE_ID, MQCGACTDEF->RULE_ID, sizeof(MQCGACTDEF->RULE_ID));
    MEMCPY_AN(MQCGACTDEF_N->RULE_DESC, MQCGACTDEF->RULE_DESC, sizeof(MQCGACTDEF->RULE_DESC));
