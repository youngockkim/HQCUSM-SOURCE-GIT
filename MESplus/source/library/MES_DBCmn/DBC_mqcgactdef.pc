                    RESV_FIELD_5,
                    RESV_FIELD_6,
                    RESV_FIELD_7,
                    RESV_FIELD_8,
                    RESV_FIELD_9,
                    RESV_FIELD_10,
                    CREATE_USER,
                    CREATE_TIME,
                    UPDATE_USER,
                    UPDATE_TIME
                FROM MQCGACTDEF
                ORDER BY FACTORY ASC,
                    RULE_ID ASC;
            EXEC SQL OPEN DBC_MQCGACTDEF_CUR_1;
            break;
        case 2:
            EXEC SQL DECLARE DBC_MQCGACTDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    RULE_ID,
                    RULE_DESC,
                    PASS_FLAG,
                    ALARM_CODE,
                    PROTECT_END,
                    QA_RUL_CMF_1,
