    DBC_add_null_mqcgactdef(&MQCGACTDEF_N, MQCGACTDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MQCGACTDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RULE_ID,
                    RULE_DESC,
                    PASS_FLAG,
                    ALARM_CODE,
                    PROTECT_END,
                    QA_RUL_CMF_1,
                    QA_RUL_CMF_2,
                    QA_RUL_CMF_3,
                    QA_RUL_CMF_4,
