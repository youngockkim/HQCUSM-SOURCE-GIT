    MEMCPY_DN(MQCGACTDEF->QA_RUL_CMF_7, MQCGACTDEF_N->QA_RUL_CMF_7, sizeof(MQCGACTDEF->QA_RUL_CMF_7));
    MEMCPY_DN(MQCGACTDEF->QA_RUL_CMF_8, MQCGACTDEF_N->QA_RUL_CMF_8, sizeof(MQCGACTDEF->QA_RUL_CMF_8));
    MEMCPY_DN(MQCGACTDEF->QA_RUL_CMF_9, MQCGACTDEF_N->QA_RUL_CMF_9, sizeof(MQCGACTDEF->QA_RUL_CMF_9));
    MEMCPY_DN(MQCGACTDEF->QA_RUL_CMF_10, MQCGACTDEF_N->QA_RUL_CMF_10, sizeof(MQCGACTDEF->QA_RUL_CMF_10));
    MEMCPY_DN(MQCGACTDEF->RESV_FIELD_1, MQCGACTDEF_N->RESV_FIELD_1, sizeof(MQCGACTDEF->RESV_FIELD_1));
    MEMCPY_DN(MQCGACTDEF->RESV_FIELD_2, MQCGACTDEF_N->RESV_FIELD_2, sizeof(MQCGACTDEF->RESV_FIELD_2));
    MEMCPY_DN(MQCGACTDEF->RESV_FIELD_3, MQCGACTDEF_N->RESV_FIELD_3, sizeof(MQCGACTDEF->RESV_FIELD_3));
    MEMCPY_DN(MQCGACTDEF->RESV_FIELD_4, MQCGACTDEF_N->RESV_FIELD_4, sizeof(MQCGACTDEF->RESV_FIELD_4));
    MEMCPY_DN(MQCGACTDEF->RESV_FIELD_5, MQCGACTDEF_N->RESV_FIELD_5, sizeof(MQCGACTDEF->RESV_FIELD_5));
    MEMCPY_DN(MQCGACTDEF->RESV_FIELD_6, MQCGACTDEF_N->RESV_FIELD_6, sizeof(MQCGACTDEF->RESV_FIELD_6));
    MEMCPY_DN(MQCGACTDEF->RESV_FIELD_7, MQCGACTDEF_N->RESV_FIELD_7, sizeof(MQCGACTDEF->RESV_FIELD_7));
    MEMCPY_DN(MQCGACTDEF->RESV_FIELD_8, MQCGACTDEF_N->RESV_FIELD_8, sizeof(MQCGACTDEF->RESV_FIELD_8));
