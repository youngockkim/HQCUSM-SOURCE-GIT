    MEMCPY_AN(MQCGACTDEF_N->QA_RUL_CMF_7, MQCGACTDEF->QA_RUL_CMF_7, sizeof(MQCGACTDEF->QA_RUL_CMF_7));
    MEMCPY_AN(MQCGACTDEF_N->QA_RUL_CMF_8, MQCGACTDEF->QA_RUL_CMF_8, sizeof(MQCGACTDEF->QA_RUL_CMF_8));
    MEMCPY_AN(MQCGACTDEF_N->QA_RUL_CMF_9, MQCGACTDEF->QA_RUL_CMF_9, sizeof(MQCGACTDEF->QA_RUL_CMF_9));
