    MEMCPY_AN(MQCGACTDEF_N->ALARM_CODE, MQCGACTDEF->ALARM_CODE, sizeof(MQCGACTDEF->ALARM_CODE));
    MQCGACTDEF_N->PROTECT_END[0] = MQCGACTDEF->PROTECT_END;
    MEMCPY_AN(MQCGACTDEF_N->QA_RUL_CMF_1, MQCGACTDEF->QA_RUL_CMF_1, sizeof(MQCGACTDEF->QA_RUL_CMF_1));
    MEMCPY_AN(MQCGACTDEF_N->QA_RUL_CMF_2, MQCGACTDEF->QA_RUL_CMF_2, sizeof(MQCGACTDEF->QA_RUL_CMF_2));
