/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrcplotpra(int sel_type, struct MRCPLOTPRA_TAG *MRCPLOTPRA)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRCPLOTPRA_N_TAG MRCPLOTPRA_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrcplotpra(&MRCPLOTPRA_N, MRCPLOTPRA);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRCPLOTPRA_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    RECIPE,
                    RECIPE_VERSION,
                    PARA_SEQ,
                    PARA_ID,
                    PARA_VALUE,
                    PARA_DESC,
                    MODIFY_FLAG,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRCPLOTPRA
                WHERE LOT_ID = :MRCPLOTPRA_N.LOT_ID
                ORDER BY LOT_ID ASC,
                    PARA_SEQ ASC;
            EXEC SQL OPEN DBC_MRCPLOTPRA_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrcplotpra", sel_type);
}


