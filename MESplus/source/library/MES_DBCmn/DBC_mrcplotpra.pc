    MEMCPY_AN(MRCPLOTPRA_N->PARA_ID, MRCPLOTPRA->PARA_ID, sizeof(MRCPLOTPRA->PARA_ID));
    MEMCPY_AN(MRCPLOTPRA_N->PARA_VALUE, MRCPLOTPRA->PARA_VALUE, sizeof(MRCPLOTPRA->PARA_VALUE));
