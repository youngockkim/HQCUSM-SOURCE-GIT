void DBC_del_null_mrcplotpra(struct MRCPLOTPRA_N_TAG *MRCPLOTPRA_N, struct MRCPLOTPRA_TAG *MRCPLOTPRA)
{
    MEMCPY_DN(MRCPLOTPRA->LOT_ID, MRCPLOTPRA_N->LOT_ID, sizeof(MRCPLOTPRA->LOT_ID));
