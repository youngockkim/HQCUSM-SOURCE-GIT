/* Add Null Function */
void DBC_add_null_mrcplotpra(struct MRCPLOTPRA_N_TAG *MRCPLOTPRA_N, struct MRCPLOTPRA_TAG *MRCPLOTPRA)
{
    /* memset by NULL */
