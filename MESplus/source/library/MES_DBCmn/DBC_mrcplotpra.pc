                    :MRCPLOTPRA_N.UPDATE_USER_ID,
                    :MRCPLOTPRA_N.UPDATE_TIME
                FROM MRCPLOTPRA
                WHERE LOT_ID = :MRCPLOTPRA_N.LOT_ID
                    AND PARA_SEQ = :MRCPLOTPRA_N.PARA_SEQ;
