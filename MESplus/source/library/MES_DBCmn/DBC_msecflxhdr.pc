void DBC_del_null_msecflxhdr(struct MSECFLXHDR_N_TAG *MSECFLXHDR_N, struct MSECFLXHDR_TAG *MSECFLXHDR)
{
    MEMCPY_DN(MSECFLXHDR->SERVICE_NAME, MSECFLXHDR_N->SERVICE_NAME, sizeof(MSECFLXHDR->SERVICE_NAME));
    MEMCPY_DN(MSECFLXHDR->DSP_ID, MSECFLXHDR_N->DSP_ID, sizeof(MSECFLXHDR->DSP_ID));
    MEMCPY_DN(MSECFLXHDR->USER_ID, MSECFLXHDR_N->USER_ID, sizeof(MSECFLXHDR->USER_ID));
    MSECFLXHDR->MEMBER_SEQ = MSECFLXHDR_N->MEMBER_SEQ;
    MEMCPY_DN(MSECFLXHDR->MEMBER_NAME, MSECFLXHDR_N->MEMBER_NAME, sizeof(MSECFLXHDR->MEMBER_NAME));
    MEMCPY_DN(MSECFLXHDR->MEMBER_PATH, MSECFLXHDR_N->MEMBER_PATH, sizeof(MSECFLXHDR->MEMBER_PATH));
    MEMCPY_DN(MSECFLXHDR->DISPLAY_OPT, MSECFLXHDR_N->DISPLAY_OPT, sizeof(MSECFLXHDR->DISPLAY_OPT));
    MEMCPY_DN(MSECFLXHDR->SORT_ORDER_1, MSECFLXHDR_N->SORT_ORDER_1, sizeof(MSECFLXHDR->SORT_ORDER_1));
    MEMCPY_DN(MSECFLXHDR->SORT_ORDER_2, MSECFLXHDR_N->SORT_ORDER_2, sizeof(MSECFLXHDR->SORT_ORDER_2));
    MEMCPY_DN(MSECFLXHDR->SORT_ORDER_3, MSECFLXHDR_N->SORT_ORDER_3, sizeof(MSECFLXHDR->SORT_ORDER_3));
    MEMCPY_DN(MSECFLXHDR->SORT_ORDER_4, MSECFLXHDR_N->SORT_ORDER_4, sizeof(MSECFLXHDR->SORT_ORDER_4));
    MEMCPY_DN(MSECFLXHDR->SORT_ORDER_5, MSECFLXHDR_N->SORT_ORDER_5, sizeof(MSECFLXHDR->SORT_ORDER_5));
    MEMCPY_DN(MSECFLXHDR->CREATE_USER_ID, MSECFLXHDR_N->CREATE_USER_ID, sizeof(MSECFLXHDR->CREATE_USER_ID));
    MEMCPY_DN(MSECFLXHDR->CREATE_TIME, MSECFLXHDR_N->CREATE_TIME, sizeof(MSECFLXHDR->CREATE_TIME));
    MEMCPY_DN(MSECFLXHDR->UPDATE_USER_ID, MSECFLXHDR_N->UPDATE_USER_ID, sizeof(MSECFLXHDR->UPDATE_USER_ID));
    MEMCPY_DN(MSECFLXHDR->UPDATE_TIME, MSECFLXHDR_N->UPDATE_TIME, sizeof(MSECFLXHDR->UPDATE_TIME));
}


