/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_msecflxhdr(int sel_type, struct MSECFLXHDR_TAG *MSECFLXHDR)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSECFLXHDR_N_TAG MSECFLXHDR_N;
        char sql[5120];
        char ts[1000];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_msecflxhdr(&MSECFLXHDR_N, MSECFLXHDR);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSECFLXHDR_CUR_1 CURSOR FOR
                SELECT 
                    SERVICE_NAME,
                    DSP_ID,
                    USER_ID,
                    MEMBER_SEQ,
                    MEMBER_NAME,
                    MEMBER_PATH,
                    DISPLAY_OPT,
                    SORT_ORDER_1,
                    SORT_ORDER_2,
                    SORT_ORDER_3,
                    SORT_ORDER_4,
                    SORT_ORDER_5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MSECFLXHDR
                WHERE SERVICE_NAME = :MSECFLXHDR_N.SERVICE_NAME
                    AND DSP_ID = :MSECFLXHDR_N.DSP_ID
                    AND USER_ID = :MSECFLXHDR_N.USER_ID
                    AND MEMBER_SEQ >= :MSECFLXHDR_N.MEMBER_SEQ
                ORDER BY MEMBER_SEQ ASC;
            EXEC SQL OPEN DBC_MSECFLXHDR_CUR_1;
            break;

        case 2:
            memset( sql, 0x00, sizeof(sql));
            memset( ts, 0x00, sizeof(ts));

            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "SERVICE_NAME, ");
            sprintf(sql + strlen(sql),   "DSP_ID, ");
            sprintf(sql + strlen(sql),   "USER_ID, ");
            sprintf(sql + strlen(sql),   "MEMBER_SEQ, ");
            sprintf(sql + strlen(sql),   "MEMBER_NAME, ");
            sprintf(sql + strlen(sql),   "MEMBER_PATH, ");
            sprintf(sql + strlen(sql),   "DISPLAY_OPT, ");
            sprintf(sql + strlen(sql),   "SORT_ORDER_1, ");
            sprintf(sql + strlen(sql),   "SORT_ORDER_2, ");
            sprintf(sql + strlen(sql),   "SORT_ORDER_3, ");
            sprintf(sql + strlen(sql),   "SORT_ORDER_4, ");
            sprintf(sql + strlen(sql),   "SORT_ORDER_5, ");
            sprintf(sql + strlen(sql),   "CREATE_USER_ID, ");
            sprintf(sql + strlen(sql),   "CREATE_TIME, ");
            sprintf(sql + strlen(sql),   "UPDATE_USER_ID, ");
            sprintf(sql + strlen(sql),   "UPDATE_TIME ");
            sprintf(sql + strlen(sql), "FROM MSECFLXHDR WHERE ");
            make_valid_quote(ts, MSECFLXHDR_N.SERVICE_NAME);
            sprintf(sql + strlen(sql), "SERVICE_NAME = '%s'", ts);
            make_valid_quote(ts, MSECFLXHDR_N.DSP_ID);
            sprintf(sql + strlen(sql), "    AND DSP_ID = '%s'", ts); 
            make_valid_quote(ts, MSECFLXHDR_N.USER_ID);
            sprintf(sql + strlen(sql), "    AND USER_ID = '%s'", ts); 
            sprintf(sql + strlen(sql), "    AND MEMBER_SEQ >= %d", MSECFLXHDR_N.MEMBER_SEQ); 

            if(ISSPACE(MSECFLXHDR->MEMBER_PATH, sizeof(MSECFLXHDR->MEMBER_PATH)) == DB_TRUE)
            {
                sprintf(sql + strlen(sql), "    AND MEMBER_PATH = MEMBER_NAME");
            }
            else
            {
                make_valid_quote(ts, MSECFLXHDR_N.MEMBER_PATH);
                sprintf(sql + strlen(sql), "    AND MEMBER_PATH <> '%s'", ts);
                sprintf(sql + strlen(sql), "    AND MEMBER_PATH LIKE '%s%%'", ts);
            }
            sprintf(sql + strlen(sql), " ORDER BY MEMBER_SEQ ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MSECFLXHDR_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MSECFLXHDR_CUR_2;       
            break;
            
            
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_msecflxhdr", sel_type);
}


