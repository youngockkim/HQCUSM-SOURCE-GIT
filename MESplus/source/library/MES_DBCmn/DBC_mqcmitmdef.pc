/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mqcmitmdef(int sel_type, struct MQCMITMDEF_TAG *MQCMITMDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MQCMITMDEF_N_TAG MQCMITMDEF_N;
        char   sql[5120];
        char   ts1[100];
        char   ts2[100];
        char   ts3[100];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mqcmitmdef(&MQCMITMDEF_N, MQCMITMDEF);
    DB_error_code = 0;
    
    memset( ts1, 0x00, sizeof(ts1));
    memset( ts2, 0x00, sizeof(ts2));
    memset( ts3, 0x00, sizeof(ts3));

    switch(sel_type)
    {
        case 1:            
            if(strcmp(MQCMITMDEF_N.INSP_ITEM_DESC, " ") == 0)
                MQCMITMDEF_N.INSP_ITEM_DESC[0] = '%';
            else
                strcat(MQCMITMDEF_N.INSP_ITEM_DESC, "%");
        
            memset( sql, 0x00, sizeof(sql));
            sprintf(sql,               "SELECT INSP_ITEM, INSP_ITEM_DESC FROM MQCMITMDEF WHERE ");

            make_valid_quote(ts1, MQCMITMDEF_N.FACTORY);
            make_valid_quote(ts2, MQCMITMDEF_N.INSP_ITEM);
            make_valid_quote(ts3, MQCMITMDEF_N.INSP_ITEM_DESC);

            sprintf(sql + strlen(sql), "FACTORY = '%s' AND INSP_ITEM >= '%s' AND INSP_ITEM LIKE '%s' ",
                ts1, ts2, ts3);
            
            if(ISSPACE(MQCMITMDEF->INSP_METHOD, sizeof(MQCMITMDEF->INSP_METHOD)) == DB_FALSE)
            {
                memset( ts1, 0x00, sizeof(ts1));
                make_valid_quote(ts1, MQCMITMDEF_N.INSP_METHOD);
                sprintf(sql + strlen(sql), "AND INSP_METHOD = '%s'  ", ts1);
            }
            
            if(MQCMITMDEF->ACTIVE_FLAG == 'Y' ||
                MQCMITMDEF->ACTIVE_FLAG == 'N')
            {
                sprintf(sql + strlen(sql), "AND ACTIVE_FLAG = '%s' ", MQCMITMDEF_N.ACTIVE_FLAG);
            }
            sprintf(sql + strlen(sql), "ORDER BY INSP_ITEM ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MQCMITMDEF_CUR_1 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MQCMITMDEF_CUR_1;    
             
            /*******************************
            LOG_head("DB");
            LOG_add("len", 1, strlen(sql));
            LOG_add("sql", 4, strlen(sql), sql);
            COM_log_write('I', 'S' , 'S');
            ********************************/
                        
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mqcmitmdef", sel_type);
}


