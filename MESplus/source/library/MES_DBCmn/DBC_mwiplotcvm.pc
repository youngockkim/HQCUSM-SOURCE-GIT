    MEMCPY_AN(MWIPLOTCVM_N->RES_ID, MWIPLOTCVM->RES_ID, sizeof(MWIPLOTCVM->RES_ID));
    MWIPLOTCVM_N->SEQ_NUM = MWIPLOTCVM->SEQ_NUM;
