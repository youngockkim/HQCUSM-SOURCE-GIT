                WHERE LOT_ID = :MWIPLOTCVM_N.LOT_ID
                    AND HIST_SEQ >= :MWIPLOTCVM_N.HIST_SEQ
                    AND QTY_FLAG = :MWIPLOTCVM_N.QTY_FLAG
