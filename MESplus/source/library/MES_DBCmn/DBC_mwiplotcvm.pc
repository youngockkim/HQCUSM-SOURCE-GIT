/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwiplotcvm(int sel_type, struct MWIPLOTCVM_TAG *MWIPLOTCVM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTCVM_N_TAG MWIPLOTCVM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplotcvm(&MWIPLOTCVM_N, MWIPLOTCVM);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPLOTCVM_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    QTY_FLAG,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_ID,
                    SEQ_NUM,
                    CV_CODE,
                    CV_QTY
                FROM MWIPLOTCVM
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC,
                    QTY_FLAG ASC,
                    SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPLOTCVM_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwiplotcvm", sel_type);
}


