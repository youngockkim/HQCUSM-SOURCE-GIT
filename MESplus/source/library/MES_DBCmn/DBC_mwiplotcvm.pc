/* Add Null Function */
void DBC_add_null_mwiplotcvm(struct MWIPLOTCVM_N_TAG *MWIPLOTCVM_N, struct MWIPLOTCVM_TAG *MWIPLOTCVM)
{
    /* memset by NULL */
    memset(MWIPLOTCVM_N, '\0', sizeof(struct MWIPLOTCVM_N_TAG));
    
    MEMCPY_AN(MWIPLOTCVM_N->LOT_ID, MWIPLOTCVM->LOT_ID, sizeof(MWIPLOTCVM->LOT_ID));
    MWIPLOTCVM_N->HIST_SEQ = MWIPLOTCVM->HIST_SEQ;
