/* Del Null Function */
void DBC_del_null_mwiplotcvm(struct MWIPLOTCVM_N_TAG *MWIPLOTCVM_N, struct MWIPLOTCVM_TAG *MWIPLOTCVM)
{
    MEMCPY_DN(MWIPLOTCVM->LOT_ID, MWIPLOTCVM_N->LOT_ID, sizeof(MWIPLOTCVM->LOT_ID));
