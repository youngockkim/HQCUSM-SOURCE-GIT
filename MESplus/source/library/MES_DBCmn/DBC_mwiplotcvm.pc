    MWIPLOTCVM_N->HIST_DEL_FLAG[0] = MWIPLOTCVM->HIST_DEL_FLAG;
    MEMCPY_AN(MWIPLOTCVM_N->FACTORY, MWIPLOTCVM->FACTORY, sizeof(MWIPLOTCVM->FACTORY));
