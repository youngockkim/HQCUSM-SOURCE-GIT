            EXEC SQL UPDATE MRASTOLHIS SET
                    HIST_DEL_FLAG = :MRASTOLHIS_N.HIST_DEL_FLAG,
                    HIST_DEL_TIME = :MRASTOLHIS_N.HIST_DEL_TIME,
