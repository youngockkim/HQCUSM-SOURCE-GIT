                    AND TOOL_ID = :MRASTOLHIS_N.TOOL_ID
                    AND HIST_SEQ = :MRASTOLHIS_N.HIST_SEQ;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mrastolhis", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrastolhis(int sel_type, struct MRASTOLHIS_TAG *MRASTOLHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASTOLHIS_N_TAG MRASTOLHIS_N;
        char sql[5120];
        char ts [100];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrastolhis(&MRASTOLHIS_N, MRASTOLHIS);
    DB_error_code = 0;
    memset( sql, 0x00, sizeof(sql));
    memset( ts, 0x00, sizeof(ts));

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRASTOLHIS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    TOOL_ID,
                    HIST_SEQ,
                    TOOL_TYPE,
                    TOOL_EVENT_ID,
                    TRAN_TIME,
                    SYS_TRAN_TIME,
                    TOOL_GRP,
                    TOOL_SET_ID,
                    TOOL_SET_LOCATION,
                    TOOL_STATUS,
                    LOT_ID,
                    SUBLOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    AREA_ID,
                    SUB_AREA_ID,
                    TOOL_LOCATION,
                    VENDOR_ID,
                    VENDOR_TOOL_ID,
                    CELL_COUNT_X,
                    CELL_COUNT_Y,
                    CELL_COUNT_Z,
                    CELL_SIZE_X,
                    CELL_SIZE_Y,
                    CELL_SIZE_Z,
                    GRADE,
                    TOOL_STS_1,
                    TOOL_STS_2,
                    TOOL_STS_3,
                    TOOL_STS_4,
                    TOOL_STS_5,
                    TOOL_STS_6,
                    TOOL_STS_7,
                    TOOL_STS_8,
                    TOOL_STS_9,
                    TOOL_STS_10,
                    TOOL_STS_11,
                    TOOL_STS_12,
                    TOOL_STS_13,
                    TOOL_STS_14,
                    TOOL_STS_15,
                    TOOL_STS_16,
                    TOOL_STS_17,
                    TOOL_STS_18,
                    TOOL_STS_19,
                    TOOL_STS_20,
                    TOOL_STS_21,
                    TOOL_STS_22,
                    TOOL_STS_23,
                    TOOL_STS_24,
                    TOOL_STS_25,
                    TOOL_STS_26,
                    TOOL_STS_27,
                    TOOL_STS_28,
                    TOOL_STS_29,
                    TOOL_STS_30,
                    DELETE_FLAG,
                    TOOL_COMMENT,
                    TRAN_USER_ID,
                    TRAN_COMMENT,
                    PREV_ACTIVE_HIST_SEQ,
                    HIST_DEL_FLAG,
                    HIST_DEL_TIME,
                    HIST_DEL_USER_ID,
                    HIST_DEL_COMMENT
                FROM MRASTOLHIS
                WHERE FACTORY = :MRASTOLHIS_N.FACTORY
                    AND TOOL_ID = :MRASTOLHIS_N.TOOL_ID
                    AND HIST_SEQ <= :MRASTOLHIS_N.HIST_SEQ
                ORDER BY FACTORY ASC,
                    TOOL_ID ASC,
                    HIST_SEQ DESC;
            EXEC SQL OPEN DBC_MRASTOLHIS_CUR_1;
            break;

        case 2:
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "FACTORY, ");
            sprintf(sql + strlen(sql),   "TOOL_ID, ");
            sprintf(sql + strlen(sql),   "HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "TOOL_TYPE, ");
            sprintf(sql + strlen(sql),   "TOOL_EVENT_ID, ");
            sprintf(sql + strlen(sql),   "TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "SYS_TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "TOOL_GRP, ");
            sprintf(sql + strlen(sql),   "TOOL_SET_ID, ");
            sprintf(sql + strlen(sql),   "TOOL_SET_LOCATION, ");
            sprintf(sql + strlen(sql),   "TOOL_STATUS, ");
            sprintf(sql + strlen(sql),   "LOT_ID, ");
            sprintf(sql + strlen(sql),   "SUBLOT_ID, ");
            sprintf(sql + strlen(sql),   "RES_ID, ");
            sprintf(sql + strlen(sql),   "SUBRES_ID, ");
            sprintf(sql + strlen(sql),   "MAT_ID, ");
            sprintf(sql + strlen(sql),   "MAT_VER, ");
            sprintf(sql + strlen(sql),   "FLOW, ");
            sprintf(sql + strlen(sql),   "OPER, ");
            sprintf(sql + strlen(sql),   "AREA_ID, ");
            sprintf(sql + strlen(sql),   "SUB_AREA_ID, ");
            sprintf(sql + strlen(sql),   "TOOL_LOCATION, ");
            sprintf(sql + strlen(sql),   "VENDOR_ID, ");
            sprintf(sql + strlen(sql),   "VENDOR_TOOL_ID, ");
            sprintf(sql + strlen(sql),   "CELL_COUNT_X, ");
            sprintf(sql + strlen(sql),   "CELL_COUNT_Y, ");
            sprintf(sql + strlen(sql),   "CELL_COUNT_Z, ");
            sprintf(sql + strlen(sql),   "CELL_SIZE_X, ");
            sprintf(sql + strlen(sql),   "CELL_SIZE_Y, ");
            sprintf(sql + strlen(sql),   "CELL_SIZE_Z, ");
            sprintf(sql + strlen(sql),   "GRADE, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_1, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_2, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_3, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_4, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_5, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_6, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_7, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_8, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_9, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_10, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_11, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_12, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_13, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_14, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_15, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_16, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_17, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_18, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_19, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_20, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_21, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_22, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_23, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_24, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_25, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_26, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_27, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_28, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_29, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_30, ");
            sprintf(sql + strlen(sql),   "DELETE_FLAG, ");
            sprintf(sql + strlen(sql),   "TOOL_COMMENT, ");
            sprintf(sql + strlen(sql),   "TRAN_USER_ID, ");
            sprintf(sql + strlen(sql),   "TRAN_COMMENT, ");
            sprintf(sql + strlen(sql),   "PREV_ACTIVE_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_FLAG, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_TIME, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_USER_ID, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_COMMENT ");
            sprintf(sql + strlen(sql), "FROM MRASTOLHIS WHERE ");
            make_valid_quote(ts, MRASTOLHIS_N.FACTORY);
            sprintf(sql + strlen(sql), "FACTORY = '%s' ", ts);
            make_valid_quote(ts, MRASTOLHIS_N.TOOL_ID);
            sprintf(sql + strlen(sql), "AND TOOL_ID = '%s' ", ts);
            sprintf(sql + strlen(sql), "AND HIST_SEQ <= '%d' ", MRASTOLHIS_N.HIST_SEQ);

            if(MRASTOLHIS->HIST_DEL_FLAG != 'Y')
            {
                sprintf(sql + strlen(sql), "AND HIST_DEL_FLAG = ' ' ");
            }            

            if(ISSPACE(DBC_Q_COND.FROM_TIME, sizeof(DBC_Q_COND.FROM_TIME)) == DB_FALSE)
            {
                make_valid_quote(ts, DBC_Q_COND_N.FROM_TIME);
                sprintf(sql + strlen(sql), "AND TRAN_TIME >= '%s' ", ts);
            }
            if(ISSPACE(DBC_Q_COND.TO_TIME, sizeof(DBC_Q_COND.TO_TIME)) == DB_FALSE)
            {
                make_valid_quote(ts, DBC_Q_COND_N.TO_TIME);
                sprintf(sql + strlen(sql), "AND TRAN_TIME <= '%s' ", ts);
            }
            if(ISSPACE(MRASTOLHIS->TOOL_TYPE, sizeof(MRASTOLHIS->TOOL_TYPE)) == DB_FALSE &&
               ISSPACE(MRASTOLHIS->TOOL_EVENT_ID, sizeof(MRASTOLHIS->TOOL_EVENT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLHIS_N.TOOL_TYPE);
                sprintf(sql + strlen(sql), "AND TOOL_TYPE = '%s' ", ts);
                make_valid_quote(ts, MRASTOLHIS_N.TOOL_EVENT_ID);
                sprintf(sql + strlen(sql), "AND TOOL_EVENT_ID = '%s' ", ts);
            }
            sprintf(sql + strlen(sql), "ORDER BY HIST_SEQ DESC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MRASTOLHIS_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MRASTOLHIS_CUR_2;                 
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrastolhis", sel_type);
}


