                    RANGE_MIN,
                    RANGE_MAX,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM ( 
                    SELECT ROWNUM ROWSEQ, SM.* 
