                            CREATE_TIME,
                            UPDATE_USER_ID,
                            UPDATE_TIME
                        FROM MSVMSVCMBR
                        WHERE MODULE_NAME = :MSVMSVCMBR_N.MODULE_NAME
                            AND SERVICE_NAME = :MSVMSVCMBR_N.SERVICE_NAME
                        ORDER BY DIRECTION ASC, MEMBER_DEPTH ASC, MEMBER_SEQ ASC, MEMBER_NAME ASC
                    ) SM
                )
