/* SQL CURSOR CLOSE Function */
void DBC_close_msvmsvcmbr(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MSVMSVCMBR_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_MSVMSVCMBR_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MSVMSVCMBR_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MSVMSVCMBR_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MSVMSVCMBR_CUR_5;
            break;



        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_msvmsvcmbr", sel_type);
}


/* Initialize Function */
void DBC_init_msvmsvcmbr(struct MSVMSVCMBR_TAG *MSVMSVCMBR)
{
    /* memset by Space */
    memset(MSVMSVCMBR, ' ', sizeof(struct MSVMSVCMBR_TAG));
    
    MSVMSVCMBR->MEMBER_DEPTH = 0;
    MSVMSVCMBR->MEMBER_SEQ = 0;
    MSVMSVCMBR->MEMBER_SIZE = 0;
    MSVMSVCMBR->RANGE_MIN = 0;
    MSVMSVCMBR->RANGE_MAX = 0;
}


/* Add Null Function */
void DBC_add_null_msvmsvcmbr(struct MSVMSVCMBR_N_TAG *MSVMSVCMBR_N, struct MSVMSVCMBR_TAG *MSVMSVCMBR)
{
    /* memset by NULL */
    memset(MSVMSVCMBR_N, '\0', sizeof(struct MSVMSVCMBR_N_TAG));
    
    MEMCPY_AN(MSVMSVCMBR_N->MODULE_NAME, MSVMSVCMBR->MODULE_NAME, sizeof(MSVMSVCMBR->MODULE_NAME));
    MEMCPY_AN(MSVMSVCMBR_N->SERVICE_NAME, MSVMSVCMBR->SERVICE_NAME, sizeof(MSVMSVCMBR->SERVICE_NAME));
    MEMCPY_AN(MSVMSVCMBR_N->MEMBER_PATH, MSVMSVCMBR->MEMBER_PATH, sizeof(MSVMSVCMBR->MEMBER_PATH));
    MSVMSVCMBR_N->DIRECTION[0] = MSVMSVCMBR->DIRECTION;
    MSVMSVCMBR_N->MEMBER_DEPTH = MSVMSVCMBR->MEMBER_DEPTH;
    MEMCPY_AN(MSVMSVCMBR_N->MEMBER_NAME, MSVMSVCMBR->MEMBER_NAME, sizeof(MSVMSVCMBR->MEMBER_NAME));
    MSVMSVCMBR_N->MEMBER_SEQ = MSVMSVCMBR->MEMBER_SEQ;
    MEMCPY_AN(MSVMSVCMBR_N->MEMBER_DESC_1, MSVMSVCMBR->MEMBER_DESC_1, sizeof(MSVMSVCMBR->MEMBER_DESC_1));
    MEMCPY_AN(MSVMSVCMBR_N->MEMBER_DESC_2, MSVMSVCMBR->MEMBER_DESC_2, sizeof(MSVMSVCMBR->MEMBER_DESC_2));
    MEMCPY_AN(MSVMSVCMBR_N->MEMBER_DESC_3, MSVMSVCMBR->MEMBER_DESC_3, sizeof(MSVMSVCMBR->MEMBER_DESC_3));
    MEMCPY_AN(MSVMSVCMBR_N->MEMBER_TYPE, MSVMSVCMBR->MEMBER_TYPE, sizeof(MSVMSVCMBR->MEMBER_TYPE));    
    MSVMSVCMBR_N->MEMBER_SIZE = MSVMSVCMBR->MEMBER_SIZE;
    MEMCPY_AN(MSVMSVCMBR_N->MEMBER_PRT, MSVMSVCMBR->MEMBER_PRT, sizeof(MSVMSVCMBR->MEMBER_PRT));
    MEMCPY_AN(MSVMSVCMBR_N->ARRAY_TYPE, MSVMSVCMBR->ARRAY_TYPE, sizeof(MSVMSVCMBR->ARRAY_TYPE));
    MSVMSVCMBR_N->REQ_MEMBER_FLAG[0] = MSVMSVCMBR->REQ_MEMBER_FLAG;
    MEMCPY_AN(MSVMSVCMBR_N->PARENT_MEMBER_PATH, MSVMSVCMBR->PARENT_MEMBER_PATH, sizeof(MSVMSVCMBR->PARENT_MEMBER_PATH));
    MSVMSVCMBR_N->OVERRIDE_FLAG[0] = MSVMSVCMBR->OVERRIDE_FLAG;
    MSVMSVCMBR_N->USE_RANGE_FLAG[0] = MSVMSVCMBR->USE_RANGE_FLAG;
    MSVMSVCMBR_N->RANGE_MIN = MSVMSVCMBR->RANGE_MIN;
    MSVMSVCMBR_N->RANGE_MAX = MSVMSVCMBR->RANGE_MAX;
    MEMCPY_AN(MSVMSVCMBR_N->CREATE_USER_ID, MSVMSVCMBR->CREATE_USER_ID, sizeof(MSVMSVCMBR->CREATE_USER_ID));
    MEMCPY_AN(MSVMSVCMBR_N->CREATE_TIME, MSVMSVCMBR->CREATE_TIME, sizeof(MSVMSVCMBR->CREATE_TIME));
    MEMCPY_AN(MSVMSVCMBR_N->UPDATE_USER_ID, MSVMSVCMBR->UPDATE_USER_ID, sizeof(MSVMSVCMBR->UPDATE_USER_ID));
    MEMCPY_AN(MSVMSVCMBR_N->UPDATE_TIME, MSVMSVCMBR->UPDATE_TIME, sizeof(MSVMSVCMBR->UPDATE_TIME));    
}


/* Del Null Function */
void DBC_del_null_msvmsvcmbr(struct MSVMSVCMBR_N_TAG *MSVMSVCMBR_N, struct MSVMSVCMBR_TAG *MSVMSVCMBR)
{
    MEMCPY_DN(MSVMSVCMBR->MODULE_NAME, MSVMSVCMBR_N->MODULE_NAME, sizeof(MSVMSVCMBR->MODULE_NAME));
    MEMCPY_DN(MSVMSVCMBR->SERVICE_NAME, MSVMSVCMBR_N->SERVICE_NAME, sizeof(MSVMSVCMBR->SERVICE_NAME));
    MEMCPY_DN(MSVMSVCMBR->MEMBER_PATH, MSVMSVCMBR_N->MEMBER_PATH, sizeof(MSVMSVCMBR->MEMBER_PATH));
    MSVMSVCMBR->DIRECTION = MSVMSVCMBR_N->DIRECTION[0];
    MSVMSVCMBR->MEMBER_DEPTH = MSVMSVCMBR_N->MEMBER_DEPTH;
    MEMCPY_DN(MSVMSVCMBR->MEMBER_NAME, MSVMSVCMBR_N->MEMBER_NAME, sizeof(MSVMSVCMBR->MEMBER_NAME));
    MSVMSVCMBR->MEMBER_SEQ = MSVMSVCMBR_N->MEMBER_SEQ;
    MEMCPY_DN(MSVMSVCMBR->MEMBER_DESC_1, MSVMSVCMBR_N->MEMBER_DESC_1, sizeof(MSVMSVCMBR->MEMBER_DESC_1));
    MEMCPY_DN(MSVMSVCMBR->MEMBER_DESC_2, MSVMSVCMBR_N->MEMBER_DESC_2, sizeof(MSVMSVCMBR->MEMBER_DESC_2));
    MEMCPY_DN(MSVMSVCMBR->MEMBER_DESC_3, MSVMSVCMBR_N->MEMBER_DESC_3, sizeof(MSVMSVCMBR->MEMBER_DESC_3));
    MEMCPY_DN(MSVMSVCMBR->MEMBER_TYPE, MSVMSVCMBR_N->MEMBER_TYPE, sizeof(MSVMSVCMBR->MEMBER_TYPE));    
    MSVMSVCMBR->MEMBER_SIZE = MSVMSVCMBR_N->MEMBER_SIZE;
    MEMCPY_DN(MSVMSVCMBR->MEMBER_PRT, MSVMSVCMBR_N->MEMBER_PRT, sizeof(MSVMSVCMBR->MEMBER_PRT));
    MEMCPY_DN(MSVMSVCMBR->ARRAY_TYPE, MSVMSVCMBR_N->ARRAY_TYPE, sizeof(MSVMSVCMBR->ARRAY_TYPE));
    MSVMSVCMBR->REQ_MEMBER_FLAG = MSVMSVCMBR_N->REQ_MEMBER_FLAG[0];
    MEMCPY_DN(MSVMSVCMBR->PARENT_MEMBER_PATH, MSVMSVCMBR_N->PARENT_MEMBER_PATH, sizeof(MSVMSVCMBR->PARENT_MEMBER_PATH));
    MSVMSVCMBR->OVERRIDE_FLAG = MSVMSVCMBR_N->OVERRIDE_FLAG[0];
    MSVMSVCMBR->USE_RANGE_FLAG = MSVMSVCMBR_N->USE_RANGE_FLAG[0];
    MSVMSVCMBR->RANGE_MIN = MSVMSVCMBR_N->RANGE_MIN;
    MSVMSVCMBR->RANGE_MAX = MSVMSVCMBR_N->RANGE_MAX;
    MEMCPY_DN(MSVMSVCMBR->CREATE_USER_ID, MSVMSVCMBR_N->CREATE_USER_ID, sizeof(MSVMSVCMBR->CREATE_USER_ID));
    MEMCPY_DN(MSVMSVCMBR->CREATE_TIME, MSVMSVCMBR_N->CREATE_TIME, sizeof(MSVMSVCMBR->CREATE_TIME));
    MEMCPY_DN(MSVMSVCMBR->UPDATE_USER_ID, MSVMSVCMBR_N->UPDATE_USER_ID, sizeof(MSVMSVCMBR->UPDATE_USER_ID));
    MEMCPY_DN(MSVMSVCMBR->UPDATE_TIME, MSVMSVCMBR_N->UPDATE_TIME, sizeof(MSVMSVCMBR->UPDATE_TIME));    
}


