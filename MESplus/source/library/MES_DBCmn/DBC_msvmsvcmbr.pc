            sprintf(sql + strlen(sql),   "SM.OVERRIDE_FLAG, ");
            sprintf(sql + strlen(sql),   "SM.USE_RANGE_FLAG, ");
            sprintf(sql + strlen(sql),   "SM.RANGE_MIN, ");
            sprintf(sql + strlen(sql),   "SM.RANGE_MAX, ");
            sprintf(sql + strlen(sql),   "SM.CREATE_USER_ID, ");
            sprintf(sql + strlen(sql),   "SM.CREATE_TIME, ");
            sprintf(sql + strlen(sql),   "SM.UPDATE_USER_ID, ");
            sprintf(sql + strlen(sql),   "SM.UPDATE_TIME ");
            sprintf(sql + strlen(sql), "FROM MSVMSVCMBR SM, MSVMMBRDEF MD WHERE ");
            make_valid_quote(ts1, MSVMSVCMBR_N.MODULE_NAME);
            sprintf(sql + strlen(sql), "SM.MODULE_NAME = '%s' ", ts1);
            make_valid_quote(ts1, MSVMSVCMBR_N.SERVICE_NAME);
            sprintf(sql + strlen(sql), "AND SM.SERVICE_NAME = '%s' ", ts1);
            sprintf(sql + strlen(sql), "AND SM.MEMBER_NAME = MD.MEMBER_NAME(+) ");
            sprintf(sql + strlen(sql), "AND SM.DIRECTION = '%c' ", MSVMSVCMBR_N.DIRECTION[0]);
            sprintf(sql + strlen(sql), "AND SM.MEMBER_DEPTH = %d ", MSVMSVCMBR_N.MEMBER_DEPTH);

            if(ISSPACE(MSVMSVCMBR->MEMBER_TYPE, sizeof(MSVMSVCMBR->MEMBER_TYPE)) == DB_FALSE)
            {
                make_valid_quote(ts1, MSVMSVCMBR_N.MEMBER_TYPE);
                sprintf(sql + strlen(sql), "AND (SM.MEMBER_TYPE = '%s' OR MD.MEMBER_TYPE = '%s') ", ts1, ts1);
            }
            if(MSVMSVCMBR->REQ_MEMBER_FLAG == 'N')
            {
                sprintf(sql + strlen(sql), "AND SM.MEMBER_TYPE NOT IN ('List', 'Array') ");
                sprintf(sql + strlen(sql), "AND MD.MEMBER_TYPE NOT IN ('List', 'Array') ");
            }
            if(ISSPACE(MSVMSVCMBR->PARENT_MEMBER_PATH, sizeof(MSVMSVCMBR->PARENT_MEMBER_PATH)) == DB_FALSE)
            {
                make_valid_quote(ts1, MSVMSVCMBR_N.PARENT_MEMBER_PATH);
                sprintf(sql + strlen(sql), "AND SM.PARENT_MEMBER_PATH = '%s' ", ts1);
            }

            sprintf(sql + strlen(sql), "ORDER BY SM.MEMBER_NAME ASC ");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MSVMSVCMBR_CUR_3 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MSVMSVCMBR_CUR_3;                 
            break;

        case 4:
            EXEC SQL DECLARE DBC_MSVMSVCMBR_CUR_4 CURSOR FOR
                SELECT 
                    MODULE_NAME,
                    SERVICE_NAME,
                    DIRECTION,
                    MEMBER_PATH,
                    MEMBER_DEPTH,
                    MEMBER_SEQ,
                    PARENT_MEMBER_PATH,
                    MEMBER_NAME,
                    MEMBER_DESC_1,
                    MEMBER_DESC_2,
                    MEMBER_DESC_3,
                    MEMBER_TYPE,
                    MEMBER_SIZE,
                    MEMBER_PRT,
                    ARRAY_TYPE,
                    REQ_MEMBER_FLAG,
                    OVERRIDE_FLAG,
                    USE_RANGE_FLAG,
                    RANGE_MIN,
                    RANGE_MAX,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MSVMSVCMBR
                WHERE SERVICE_NAME = :MSVMSVCMBR_N.SERVICE_NAME
                    AND DIRECTION = :MSVMSVCMBR_N.DIRECTION
                    AND PARENT_MEMBER_PATH = :MSVMSVCMBR_N.PARENT_MEMBER_PATH
                    AND MEMBER_SEQ >= :MSVMSVCMBR_N.MEMBER_SEQ
                ORDER BY MEMBER_SEQ ASC;

            EXEC SQL OPEN DBC_MSVMSVCMBR_CUR_4;
            break;

        case 5:
            EXEC SQL DECLARE DBC_MSVMSVCMBR_CUR_5 CURSOR FOR
                SELECT 
                    MODULE_NAME,
                    SERVICE_NAME,
                    DIRECTION,
                    MEMBER_PATH,
                    MEMBER_DEPTH,
                    MEMBER_SEQ,
                    PARENT_MEMBER_PATH,
                    MEMBER_NAME,
                    MEMBER_DESC_1,
                    MEMBER_DESC_2,
                    MEMBER_DESC_3,
                    MEMBER_TYPE,
                    MEMBER_SIZE,
                    MEMBER_PRT,
                    ARRAY_TYPE,
                    REQ_MEMBER_FLAG,
                    OVERRIDE_FLAG,
                    USE_RANGE_FLAG,
                    RANGE_MIN,
                    RANGE_MAX,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MSVMSVCMBR
                WHERE MODULE_NAME = :MSVMSVCMBR_N.MODULE_NAME
                  AND SERVICE_NAME = :MSVMSVCMBR_N.SERVICE_NAME
                  AND DIRECTION = :MSVMSVCMBR_N.DIRECTION
                  AND MEMBER_NAME = :MSVMSVCMBR_N.MEMBER_NAME
                ORDER BY MEMBER_SEQ ASC;
            EXEC SQL OPEN DBC_MSVMSVCMBR_CUR_5;
            break;




        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_msvmsvcmbr", sel_type);
}


