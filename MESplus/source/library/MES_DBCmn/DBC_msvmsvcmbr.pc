            EXEC SQL DECLARE DBC_MSVMSVCMBR_CUR_1 CURSOR FOR
                SELECT ROWSEQ,
                    MODULE_NAME,
                    SERVICE_NAME,
                    DIRECTION,
                    MEMBER_PATH,
                    MEMBER_DEPTH,
                    MEMBER_SEQ,
                    PARENT_MEMBER_PATH,
                    MEMBER_NAME,
                    MEMBER_DESC_1,
