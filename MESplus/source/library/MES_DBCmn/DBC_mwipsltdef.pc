/* Initialize Function */
void DBC_init_mwipsltdef(struct MWIPSLTDEF_TAG *MWIPSLTDEF)
{
    /* memset by Space */
    memset(MWIPSLTDEF, ' ', sizeof(struct MWIPSLTDEF_TAG));

    MWIPSLTDEF->MAT_VER = 0;
    
}


/* Add Null Function */
void DBC_add_null_mwipsltdef(struct MWIPSLTDEF_N_TAG *MWIPSLTDEF_N, struct MWIPSLTDEF_TAG *MWIPSLTDEF)
{
    /* memset by NULL */
    memset(MWIPSLTDEF_N, '\0', sizeof(struct MWIPSLTDEF_N_TAG));
    
    MEMCPY_AN(MWIPSLTDEF_N->FACTORY, MWIPSLTDEF->FACTORY, sizeof(MWIPSLTDEF->FACTORY));
    MEMCPY_AN(MWIPSLTDEF_N->MAT_ID, MWIPSLTDEF->MAT_ID, sizeof(MWIPSLTDEF->MAT_ID));
    MWIPSLTDEF_N->MAT_VER = MWIPSLTDEF->MAT_VER;
    MEMCPY_AN(MWIPSLTDEF_N->FLOW, MWIPSLTDEF->FLOW, sizeof(MWIPSLTDEF->FLOW));
    MEMCPY_AN(MWIPSLTDEF_N->OPER, MWIPSLTDEF->OPER, sizeof(MWIPSLTDEF->OPER));
    MWIPSLTDEF_N->OPT_LEVEL[0] = MWIPSLTDEF->OPT_LEVEL;
    MWIPSLTDEF_N->SUBLOT_TRACKING_FLAG[0] = MWIPSLTDEF->SUBLOT_TRACKING_FLAG;
    MEMCPY_AN(MWIPSLTDEF_N->CREATE_USER_ID, MWIPSLTDEF->CREATE_USER_ID, sizeof(MWIPSLTDEF->CREATE_USER_ID));
    MEMCPY_AN(MWIPSLTDEF_N->CREATE_TIME, MWIPSLTDEF->CREATE_TIME, sizeof(MWIPSLTDEF->CREATE_TIME));
    MEMCPY_AN(MWIPSLTDEF_N->UPDATE_USER_ID, MWIPSLTDEF->UPDATE_USER_ID, sizeof(MWIPSLTDEF->UPDATE_USER_ID));
    MEMCPY_AN(MWIPSLTDEF_N->UPDATE_TIME, MWIPSLTDEF->UPDATE_TIME, sizeof(MWIPSLTDEF->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mwipsltdef(struct MWIPSLTDEF_N_TAG *MWIPSLTDEF_N, struct MWIPSLTDEF_TAG *MWIPSLTDEF)
{
    MEMCPY_DN(MWIPSLTDEF->FACTORY, MWIPSLTDEF_N->FACTORY, sizeof(MWIPSLTDEF->FACTORY));
    MEMCPY_DN(MWIPSLTDEF->MAT_ID, MWIPSLTDEF_N->MAT_ID, sizeof(MWIPSLTDEF->MAT_ID));
    MWIPSLTDEF->MAT_VER = MWIPSLTDEF_N->MAT_VER;
    MEMCPY_DN(MWIPSLTDEF->FLOW, MWIPSLTDEF_N->FLOW, sizeof(MWIPSLTDEF->FLOW));
    MEMCPY_DN(MWIPSLTDEF->OPER, MWIPSLTDEF_N->OPER, sizeof(MWIPSLTDEF->OPER));
    MWIPSLTDEF->OPT_LEVEL = MWIPSLTDEF_N->OPT_LEVEL[0];
    MWIPSLTDEF->SUBLOT_TRACKING_FLAG = MWIPSLTDEF_N->SUBLOT_TRACKING_FLAG[0];
    MEMCPY_DN(MWIPSLTDEF->CREATE_USER_ID, MWIPSLTDEF_N->CREATE_USER_ID, sizeof(MWIPSLTDEF->CREATE_USER_ID));
    MEMCPY_DN(MWIPSLTDEF->CREATE_TIME, MWIPSLTDEF_N->CREATE_TIME, sizeof(MWIPSLTDEF->CREATE_TIME));
    MEMCPY_DN(MWIPSLTDEF->UPDATE_USER_ID, MWIPSLTDEF_N->UPDATE_USER_ID, sizeof(MWIPSLTDEF->UPDATE_USER_ID));
    MEMCPY_DN(MWIPSLTDEF->UPDATE_TIME, MWIPSLTDEF_N->UPDATE_TIME, sizeof(MWIPSLTDEF->UPDATE_TIME));
}


