                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPSLTDEF
                WHERE FACTORY = :MWIPSLTDEF_N.FACTORY
                    AND MAT_ID = :MWIPSLTDEF_N.MAT_ID
                    AND MAT_VER = :MWIPSLTDEF_N.MAT_VER;
            EXEC SQL OPEN DBC_MWIPSLTDEF_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MWIPSLTDEF_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    OPT_LEVEL,
                    SUBLOT_TRACKING_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPSLTDEF
                WHERE FACTORY = :MWIPSLTDEF_N.FACTORY
                    AND MAT_ID = ' '
                    AND MAT_VER = 0
                    AND FLOW = :MWIPSLTDEF_N.FLOW;
            EXEC SQL OPEN DBC_MWIPSLTDEF_CUR_3;
            break;

        case 4:
            EXEC SQL DECLARE DBC_MWIPSLTDEF_CUR_4 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    OPT_LEVEL,
                    SUBLOT_TRACKING_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPSLTDEF
                WHERE FACTORY = :MWIPSLTDEF_N.FACTORY
                    AND MAT_ID = ' '
                    AND MAT_VER = 0
                    AND FLOW = ' '
                    AND OPER = :MWIPSLTDEF_N.OPER;
            EXEC SQL OPEN DBC_MWIPSLTDEF_CUR_4;
            break;
            
            
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
