    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPSLTDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    OPT_LEVEL,
                    SUBLOT_TRACKING_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPSLTDEF
                ORDER BY FACTORY ASC,
                    MAT_ID ASC,
                    FLOW ASC,
                    OPER ASC;
            EXEC SQL OPEN DBC_MWIPSLTDEF_CUR_1;
            break;

        case 2:
            /* Use material version up */
            EXEC SQL DECLARE DBC_MWIPSLTDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    OPT_LEVEL,
