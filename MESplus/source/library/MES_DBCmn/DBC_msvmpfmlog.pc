    MSVMPFMLOG_N->CONSUME_SEC_2[index] = MSVMPFMLOG->CONSUME_SEC_2;
    MSVMPFMLOG_N->CONSUME_SEC_3[index] = MSVMPFMLOG->CONSUME_SEC_3;
