struct MSVMPFMLOG_ARR_N_TAG
{
    int           SEQ_NUM[MP_SIZE_MAX_HOST_ARRAY];
    char          TRAN_TIME[MP_SIZE_MAX_HOST_ARRAY][15];
    char          SYSTEM_NODE[MP_SIZE_MAX_HOST_ARRAY][21];
