            }
            if(ISSPACE(MSVMPFMLOG->SERVICE_NAME, sizeof(MSVMPFMLOG->SERVICE_NAME)) == DB_FALSE)
            {
                make_valid_quote(ts1, MSVMPFMLOG_N.SERVICE_NAME);
