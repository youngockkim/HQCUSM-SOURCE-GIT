            sprintf(sql + strlen(sql), "FROM MSVMPFMLOG ");
            sprintf(sql + strlen(sql), "WHERE TRAN_TIME <= TO_CHAR(TO_DATE('%s', 'YYYYMMDDHH24MISS') - (%d * INTERVAL '1' MONTH), 'YYYYMMDDHH24MISS') ", MSVMPFMLOG_N.TRAN_TIME, MSVMPFMLOG_N.SEQ_NUM);
