                WHERE TRAN_TIME = :MSVMPFMLOG_N.TRAN_TIME
                    AND SYSTEM_NODE = :MSVMPFMLOG_N.SYSTEM_NODE
                    AND SERVER_NAME = :MSVMPFMLOG_N.SERVER_NAME
