                sprintf(sql + strlen(sql), "AND SERVICE_COUNT >= %d ", MSVMPFMLOG->SERVICE_COUNT);
            }
            /* Filtering Key */
            if(ISSPACE(DBC_Q_COND.KEY_1, sizeof(DBC_Q_COND.KEY_1)) == DB_FALSE)
