    DB_start_query_timer();

    DBC_add_null_msvmpfmlog(&MSVMPFMLOG_N, MSVMPFMLOG);
    DB_error_code = 0;

    EXEC SQL INSERT INTO MSVMPFMLOG (
                    SEQ_NUM,
                    TRAN_TIME,
                    SYSTEM_NODE,
                    SERVER_NAME,
                    SUBNO,
                    SERVICE_NAME,
                    SERVICE_COUNT,
                    TOTAL_CONSUME_SEC,
                    MIN_CONSUME_SEC,
                    MAX_CONSUME_SEC,
                    PFM_CMF_1,
                    PFM_CMF_2,
