/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipbathis(int sel_type, struct MWIPBATHIS_TAG *MWIPBATHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPBATHIS_N_TAG MWIPBATHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipbathis(&MWIPBATHIS_N, MWIPBATHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPBATHIS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    BATCH_ID,
                    TRAN_TIME,
                    TRAN_CODE,
                    ITEM_ID,
                    SEQ_NUM,
                    ITEM_HIST_SEQ,
                    ITEM_TYPE,
                    OPER,
                    REL_LEVEL,
                    RES_ID,
                    RESG_ID,
                    RES_TYPE,
                    CRT_RULE_ID,
                    GEN_RULE_ID,
                    CREATE_USER_ID,
                    CONFIRM_FLAG,
                    BATCH_COMMENT
                FROM MWIPBATHIS
                WHERE FACTORY = :MWIPBATHIS_N.FACTORY
                    AND BATCH_ID = :MWIPBATHIS_N.BATCH_ID
                    AND (
                            (TRAN_TIME < :MWIPBATHIS_N.TRAN_TIME) OR 
                            (TRAN_TIME = :MWIPBATHIS_N.TRAN_TIME AND SEQ_NUM >= :MWIPBATHIS_N.SEQ_NUM)
                        )
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME AND TRAN_TIME < :DBC_Q_COND_N.TO_TIME
                ORDER BY TRAN_TIME DESC, SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPBATHIS_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPBATHIS_CUR_2 CURSOR FOR
                SELECT ITEM_ID, ITEM_HIST_SEQ, BATCH_ID
                FROM MWIPBATHIS 
                WHERE FACTORY = :MWIPBATHIS_N.FACTORY
                    AND ITEM_ID = :MWIPBATHIS_N.ITEM_ID
                    AND ITEM_HIST_SEQ < :MWIPBATHIS_N.ITEM_HIST_SEQ
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                    AND TRAN_TIME < :DBC_Q_COND_N.TO_TIME
                    AND BATCH_ID != ' '
                    AND ITEM_TYPE = :MWIPBATHIS_N.ITEM_TYPE
                GROUP BY ITEM_ID, ITEM_HIST_SEQ, BATCH_ID
                ORDER BY ITEM_HIST_SEQ DESC, BATCH_ID DESC;
            EXEC SQL OPEN DBC_MWIPBATHIS_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipbathis", sel_type);
}


