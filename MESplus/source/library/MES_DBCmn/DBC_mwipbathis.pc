/* Add Null Function */
void DBC_add_null_mwipbathis(struct MWIPBATHIS_N_TAG *MWIPBATHIS_N, struct MWIPBATHIS_TAG *MWIPBATHIS)
{
    /* memset by NULL */
    memset(MWIPBATHIS_N, '\0', sizeof(struct MWIPBATHIS_N_TAG));
    
    MEMCPY_AN(MWIPBATHIS_N->FACTORY, MWIPBATHIS->FACTORY, sizeof(MWIPBATHIS->FACTORY));
    MEMCPY_AN(MWIPBATHIS_N->BATCH_ID, MWIPBATHIS->BATCH_ID, sizeof(MWIPBATHIS->BATCH_ID));
