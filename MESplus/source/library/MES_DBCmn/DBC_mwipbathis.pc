    MEMCPY_AN(MWIPBATHIS_N->ITEM_ID, MWIPBATHIS->ITEM_ID, sizeof(MWIPBATHIS->ITEM_ID));
    MWIPBATHIS_N->SEQ_NUM = MWIPBATHIS->SEQ_NUM;
    MWIPBATHIS_N->ITEM_HIST_SEQ = MWIPBATHIS->ITEM_HIST_SEQ;
    MWIPBATHIS_N->ITEM_TYPE[0] = MWIPBATHIS->ITEM_TYPE;
    MEMCPY_AN(MWIPBATHIS_N->OPER, MWIPBATHIS->OPER, sizeof(MWIPBATHIS->OPER));
    MWIPBATHIS_N->REL_LEVEL[0] = MWIPBATHIS->REL_LEVEL;
    MEMCPY_AN(MWIPBATHIS_N->RES_ID, MWIPBATHIS->RES_ID, sizeof(MWIPBATHIS->RES_ID));
    MEMCPY_AN(MWIPBATHIS_N->RESG_ID, MWIPBATHIS->RESG_ID, sizeof(MWIPBATHIS->RESG_ID));
    MEMCPY_AN(MWIPBATHIS_N->RES_TYPE, MWIPBATHIS->RES_TYPE, sizeof(MWIPBATHIS->RES_TYPE));
    MEMCPY_AN(MWIPBATHIS_N->CRT_RULE_ID, MWIPBATHIS->CRT_RULE_ID, sizeof(MWIPBATHIS->CRT_RULE_ID));
    MEMCPY_AN(MWIPBATHIS_N->GEN_RULE_ID, MWIPBATHIS->GEN_RULE_ID, sizeof(MWIPBATHIS->GEN_RULE_ID));
    MEMCPY_AN(MWIPBATHIS_N->CREATE_USER_ID, MWIPBATHIS->CREATE_USER_ID, sizeof(MWIPBATHIS->CREATE_USER_ID));
    MWIPBATHIS_N->CONFIRM_FLAG[0] = MWIPBATHIS->CONFIRM_FLAG;
    MEMCPY_AN(MWIPBATHIS_N->BATCH_COMMENT, MWIPBATHIS->BATCH_COMMENT, sizeof(MWIPBATHIS->BATCH_COMMENT));
}


/* Del Null Function */
void DBC_del_null_mwipbathis(struct MWIPBATHIS_N_TAG *MWIPBATHIS_N, struct MWIPBATHIS_TAG *MWIPBATHIS)
