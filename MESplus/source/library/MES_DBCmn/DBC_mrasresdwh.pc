            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mrasresdwh(&MRASRESDWH_N, MRASRESDWH);
    }
    DB_stop_query_timer("DBC_fetch_mrasresdwh", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mrasresdwh(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MRASRESDWH_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MRASRESDWH_CUR_2;
            break;
            
        case 3:
            EXEC SQL CLOSE DBC_MRASRESDWH_CUR_3;
            break;    
                            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mrasresdwh", sel_type);
}


/* Initialize Function */
void DBC_init_mrasresdwh(struct MRASRESDWH_TAG *MRASRESDWH)
{
    /* memset by Space */
    memset(MRASRESDWH, ' ', sizeof(struct MRASRESDWH_TAG));
    
    MRASRESDWH->DOWN_HIST_SEQ = 0;
    MRASRESDWH->DOWN_INTERVAL = 0;
    MRASRESDWH->UP_HIST_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mrasresdwh(struct MRASRESDWH_N_TAG *MRASRESDWH_N, struct MRASRESDWH_TAG *MRASRESDWH)
{
