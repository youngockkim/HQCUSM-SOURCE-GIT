    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASRESDWH_N_TAG MRASRESDWH_N;
        char sql[5120];
        char ts[1024];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrasresdwh(&MRASRESDWH_N, MRASRESDWH);
    DB_error_code = 0;
    memset( sql, 0x00, sizeof(sql));
    memset( ts, 0x00, sizeof(ts));

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRASRESDWH_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    DOWN_HIST_SEQ,
                    DOWN_EVENT_ID,
                    DOWN_TRAN_TIME,
                    DOWN_SYS_TRAN_TIME,
                    DOWN_PRI_STS,
                    DOWN_NEW_STS_1,
                    DOWN_NEW_STS_2,
                    DOWN_NEW_STS_3,
                    DOWN_NEW_STS_4,
                    DOWN_NEW_STS_5,
                    DOWN_NEW_STS_6,
                    DOWN_NEW_STS_7,
                    DOWN_NEW_STS_8,
                    DOWN_NEW_STS_9,
                    DOWN_NEW_STS_10,
                    DOWN_TRAN_USER_ID,
                    DOWN_TRAN_COMMENT,
                    DOWN_INTERVAL,
                    UP_HIST_SEQ,
                    UP_EVENT_ID,
                    UP_TRAN_TIME,
                    UP_SYS_TRAN_TIME,
                    UP_PRI_STS,
                    UP_NEW_STS_1,
                    UP_NEW_STS_2,
                    UP_NEW_STS_3,
                    UP_NEW_STS_4,
                    UP_NEW_STS_5,
                    UP_NEW_STS_6,
                    UP_NEW_STS_7,
                    UP_NEW_STS_8,
                    UP_NEW_STS_9,
                    UP_NEW_STS_10,
                    UP_TRAN_USER_ID,
                    UP_TRAN_COMMENT,
                    USER_ID_1,
                    USER_TIME_1,
                    USER_COMMENT_1,
                    USER_ID_2,
                    USER_TIME_2,
                    USER_COMMENT_2,
                    USER_ID_3,
                    USER_TIME_3,
                    USER_COMMENT_3,
                    HIST_DEL_FLAG,
                    HIST_DEL_TIME,
                    HIST_DEL_USER_ID,
                    HIST_DEL_COMMENT
                FROM MRASRESDWH
                WHERE FACTORY = :MRASRESDWH_N.FACTORY
                    AND RES_ID = :MRASRESDWH_N.RES_ID
                ORDER BY DOWN_HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MRASRESDWH_CUR_1;
            break;

        case 2:
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "FACTORY, ");
            sprintf(sql + strlen(sql),   "RES_ID, ");
            sprintf(sql + strlen(sql),   "DOWN_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "DOWN_EVENT_ID, ");
            sprintf(sql + strlen(sql),   "DOWN_TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "DOWN_SYS_TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "DOWN_PRI_STS, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_1, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_2, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_3, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_4, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_5, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_6, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_7, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_8, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_9, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_10, ");
            sprintf(sql + strlen(sql),   "DOWN_TRAN_USER_ID, ");
            sprintf(sql + strlen(sql),   "DOWN_TRAN_COMMENT, ");
            sprintf(sql + strlen(sql),   "DOWN_INTERVAL, ");
            sprintf(sql + strlen(sql),   "UP_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "UP_EVENT_ID, ");
            sprintf(sql + strlen(sql),   "UP_TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "UP_SYS_TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "UP_PRI_STS, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_1, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_2, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_3, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_4, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_5, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_6, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_7, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_8, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_9, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_10, ");
            sprintf(sql + strlen(sql),   "UP_TRAN_USER_ID, ");
            sprintf(sql + strlen(sql),   "UP_TRAN_COMMENT, ");
            sprintf(sql + strlen(sql),   "USER_ID_1, ");
            sprintf(sql + strlen(sql),   "USER_TIME_1, ");
            sprintf(sql + strlen(sql),   "USER_COMMENT_1, ");
            sprintf(sql + strlen(sql),   "USER_ID_2, ");
            sprintf(sql + strlen(sql),   "USER_TIME_2, ");
            sprintf(sql + strlen(sql),   "USER_COMMENT_2, ");
            sprintf(sql + strlen(sql),   "USER_ID_3, ");
            sprintf(sql + strlen(sql),   "USER_TIME_3, ");
            sprintf(sql + strlen(sql),   "USER_COMMENT_3, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_FLAG, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_TIME, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_USER_ID, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_COMMENT ");
            sprintf(sql + strlen(sql), "FROM MRASRESDWH WHERE ");
            make_valid_quote(ts, MRASRESDWH_N.FACTORY);
            sprintf(sql + strlen(sql), "FACTORY = '%s' ", ts);
            make_valid_quote(ts, MRASRESDWH_N.RES_ID);
            sprintf(sql + strlen(sql), "AND ((RES_ID > '%s') OR (RES_ID = '%s' AND DOWN_HIST_SEQ <= '%d')) ", ts, ts, MRASRESDWH_N.DOWN_HIST_SEQ);
            make_valid_quote(ts, MRASRESDWH_N.USER_TIME_1);
            sprintf(sql + strlen(sql), "AND HIST_DEL_FLAG = ' ' AND DOWN_TRAN_TIME >= '%s' ", ts);
            make_valid_quote(ts, MRASRESDWH_N.USER_TIME_2);
            sprintf(sql + strlen(sql), "AND DOWN_TRAN_TIME < '%s' ", ts);
            
            if(ISSPACE(MRASRESDWH->DOWN_EVENT_ID, sizeof(MRASRESDWH->DOWN_EVENT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASRESDWH_N.DOWN_EVENT_ID);
                sprintf(sql + strlen(sql), "AND DOWN_EVENT_ID = '%s' ", ts);
            }
            if(MRASRESDWH->HIST_DEL_FLAG != ' ')
            {
                sprintf(sql + strlen(sql), "AND UP_EVENT_ID = ' ' ");
            }
            sprintf(sql + strlen(sql), "ORDER BY RES_ID ASC, DOWN_HIST_SEQ DESC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MRASRESDWH_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MRASRESDWH_CUR_2;                 
            break;
            
            
        case 3:
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "FACTORY, ");
            sprintf(sql + strlen(sql),   "RES_ID, ");
            sprintf(sql + strlen(sql),   "DOWN_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "DOWN_EVENT_ID, ");
            sprintf(sql + strlen(sql),   "DOWN_TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "DOWN_SYS_TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "DOWN_PRI_STS, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_1, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_2, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_3, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_4, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_5, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_6, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_7, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_8, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_9, ");
            sprintf(sql + strlen(sql),   "DOWN_NEW_STS_10, ");
            sprintf(sql + strlen(sql),   "DOWN_TRAN_USER_ID, ");
            sprintf(sql + strlen(sql),   "DOWN_TRAN_COMMENT, ");
            sprintf(sql + strlen(sql),   "DOWN_INTERVAL, ");
            sprintf(sql + strlen(sql),   "UP_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "UP_EVENT_ID, ");
            sprintf(sql + strlen(sql),   "UP_TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "UP_SYS_TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "UP_PRI_STS, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_1, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_2, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_3, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_4, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_5, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_6, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_7, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_8, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_9, ");
            sprintf(sql + strlen(sql),   "UP_NEW_STS_10, ");
            sprintf(sql + strlen(sql),   "UP_TRAN_USER_ID, ");
            sprintf(sql + strlen(sql),   "UP_TRAN_COMMENT, ");
            sprintf(sql + strlen(sql),   "USER_ID_1, ");
            sprintf(sql + strlen(sql),   "USER_TIME_1, ");
            sprintf(sql + strlen(sql),   "USER_COMMENT_1, ");
            sprintf(sql + strlen(sql),   "USER_ID_2, ");
            sprintf(sql + strlen(sql),   "USER_TIME_2, ");
            sprintf(sql + strlen(sql),   "USER_COMMENT_2, ");
            sprintf(sql + strlen(sql),   "USER_ID_3, ");
            sprintf(sql + strlen(sql),   "USER_TIME_3, ");
            sprintf(sql + strlen(sql),   "USER_COMMENT_3, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_FLAG, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_TIME, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_USER_ID, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_COMMENT ");
            sprintf(sql + strlen(sql), "FROM MRASRESDWH WHERE ");
            make_valid_quote(ts, MRASRESDWH_N.FACTORY);
            sprintf(sql + strlen(sql), "FACTORY = '%s' ", ts);
            make_valid_quote(ts, MRASRESDWH_N.RES_ID);
            sprintf(sql + strlen(sql), "AND RES_ID = '%s' ", ts);
            sprintf(sql + strlen(sql), "AND HIST_DEL_FLAG = ' ' AND DOWN_HIST_SEQ <= '%d' ",MRASRESDWH_N.DOWN_HIST_SEQ);
            make_valid_quote(ts, MRASRESDWH_N.USER_TIME_1);
            sprintf(sql + strlen(sql), "AND DOWN_TRAN_TIME >= '%s' ", ts);
            make_valid_quote(ts, MRASRESDWH_N.USER_TIME_2);
            sprintf(sql + strlen(sql), "AND DOWN_TRAN_TIME < '%s' ", ts);

            if(ISSPACE(MRASRESDWH->DOWN_EVENT_ID, sizeof(MRASRESDWH->DOWN_EVENT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASRESDWH_N.DOWN_EVENT_ID);
                sprintf(sql + strlen(sql), "AND DOWN_EVENT_ID = '%s' ", ts);
            }
            if(MRASRESDWH->HIST_DEL_FLAG != ' ')
            {
                sprintf(sql + strlen(sql), "AND UP_EVENT_ID = ' ' ");
            }
            sprintf(sql + strlen(sql), "ORDER BY RES_ID ASC, DOWN_HIST_SEQ DESC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MRASRESDWH_CUR_3 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MRASRESDWH_CUR_3;                 
            break;            
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrasresdwh", sel_type);
}


