/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mbomsetdef(int sel_type, struct MBOMSETDEF_TAG *MBOMSETDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBOMSETDEF_N_TAG MBOMSETDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbomsetdef(&MBOMSETDEF_N, MBOMSETDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MBOMSETDEF_CUR_1 CURSOR FOR
                SELECT BOM_SET_ID, BOM_SET_DESC, DELETE_FLAG  
                FROM MBOMSETDEF
                WHERE FACTORY = :MBOMSETDEF_N.FACTORY 
                AND BOM_SET_ID >= :MBOMSETDEF_N.BOM_SET_ID
                ORDER BY FACTORY, BOM_SET_ID ASC;
            EXEC SQL OPEN DBC_MBOMSETDEF_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MBOMSETDEF_CUR_2 CURSOR FOR
                SELECT BOM_SET_ID, BOM_SET_DESC, DELETE_FLAG  
                FROM MBOMSETDEF
                WHERE FACTORY = :MBOMSETDEF_N.FACTORY 
                AND BOM_SET_ID >= :MBOMSETDEF_N.BOM_SET_ID 
                AND DELETE_FLAG <> 'Y'
                ORDER BY FACTORY, BOM_SET_ID ASC;
            EXEC SQL OPEN DBC_MBOMSETDEF_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MBOMSETDEF_CUR_3 CURSOR FOR
                SELECT BOM_SET_ID, BOM_SET_DESC, DELETE_FLAG  
                FROM MBOMSETDEF
                WHERE FACTORY = :MBOMSETDEF_N.FACTORY 
                AND BOM_SET_ID >= :MBOMSETDEF_N.BOM_SET_ID 
                AND DELETE_FLAG <> 'Y' 
                AND MAT_OR_ORD_FLAG = :MBOMSETDEF_N.MAT_OR_ORD_FLAG
                ORDER BY FACTORY, BOM_SET_ID ASC;
            EXEC SQL OPEN DBC_MBOMSETDEF_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mbomsetdef", sel_type);
}


