    MEMCPY_AN(MRTDRULEXT_N->KEY_VALUE_1, MRTDRULEXT->KEY_VALUE_1, sizeof(MRTDRULEXT->KEY_VALUE_1));
    MEMCPY_AN(MRTDRULEXT_N->KEY_VALUE_2, MRTDRULEXT->KEY_VALUE_2, sizeof(MRTDRULEXT->KEY_VALUE_2));
