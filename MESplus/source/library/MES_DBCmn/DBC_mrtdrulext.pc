    MEMCPY_AN(MRTDRULEXT_N->TABLE_NAME, MRTDRULEXT->TABLE_NAME, sizeof(MRTDRULEXT->TABLE_NAME));
    MEMCPY_AN(MRTDRULEXT_N->CREATE_USER_ID, MRTDRULEXT->CREATE_USER_ID, sizeof(MRTDRULEXT->CREATE_USER_ID));
