                                                    :MRCPRCPVER_N.RELEASE_USER_ID,
                                                    :MRCPRCPVER_N.RELEASE_TIME,
                                                    :MRCPRCPVER_N.CREATE_USER_ID,
                                                    :MRCPRCPVER_N.CREATE_TIME,
                                                    :MRCPRCPVER_N.UPDATE_USER_ID,
                                                    :MRCPRCPVER_N.UPDATE_TIME;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mrcprcpver(&MRCPRCPVER_N, MRCPRCPVER);
    }
    DB_stop_query_timer("DBC_fetch_mrcprcpver", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mrcprcpver(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MRCPRCPVER_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mrcprcpver", sel_type);
}


/* Initialize Function */
void DBC_init_mrcprcpver(struct MRCPRCPVER_TAG *MRCPRCPVER)
{
    /* memset by Space */
    memset(MRCPRCPVER, ' ', sizeof(struct MRCPRCPVER_TAG));
    
    MRCPRCPVER->RECIPE_VERSION = 0;
}


/* Add Null Function */
void DBC_add_null_mrcprcpver(struct MRCPRCPVER_N_TAG *MRCPRCPVER_N, struct MRCPRCPVER_TAG *MRCPRCPVER)
{
    /* memset by NULL */
    memset(MRCPRCPVER_N, '\0', sizeof(struct MRCPRCPVER_N_TAG));
    
    MEMCPY_AN(MRCPRCPVER_N->FACTORY, MRCPRCPVER->FACTORY, sizeof(MRCPRCPVER->FACTORY));
    MEMCPY_AN(MRCPRCPVER_N->RES_ID, MRCPRCPVER->RES_ID, sizeof(MRCPRCPVER->RES_ID));
    MEMCPY_AN(MRCPRCPVER_N->SUBRES_ID, MRCPRCPVER->SUBRES_ID, sizeof(MRCPRCPVER->SUBRES_ID));
    MEMCPY_AN(MRCPRCPVER_N->RECIPE, MRCPRCPVER->RECIPE, sizeof(MRCPRCPVER->RECIPE));
    MRCPRCPVER_N->RECIPE_VERSION = MRCPRCPVER->RECIPE_VERSION;
    MEMCPY_AN(MRCPRCPVER_N->PP_ID, MRCPRCPVER->PP_ID, sizeof(MRCPRCPVER->PP_ID));
    MEMCPY_AN(MRCPRCPVER_N->COAT_PP_ID, MRCPRCPVER->COAT_PP_ID, sizeof(MRCPRCPVER->COAT_PP_ID));
    MEMCPY_AN(MRCPRCPVER_N->RETICLE_ID, MRCPRCPVER->RETICLE_ID, sizeof(MRCPRCPVER->RETICLE_ID));
    MEMCPY_AN(MRCPRCPVER_N->COL_SET_ID, MRCPRCPVER->COL_SET_ID, sizeof(MRCPRCPVER->COL_SET_ID));
    MEMCPY_AN(MRCPRCPVER_N->PROC_TIME, MRCPRCPVER->PROC_TIME, sizeof(MRCPRCPVER->PROC_TIME));
    MRCPRCPVER_N->MODIFY_FLAG[0] = MRCPRCPVER->MODIFY_FLAG;
    MEMCPY_AN(MRCPRCPVER_N->APPLY_START_TIME, MRCPRCPVER->APPLY_START_TIME, sizeof(MRCPRCPVER->APPLY_START_TIME));
    MEMCPY_AN(MRCPRCPVER_N->APPLY_END_TIME, MRCPRCPVER->APPLY_END_TIME, sizeof(MRCPRCPVER->APPLY_END_TIME));
    MRCPRCPVER_N->APPROVAL_FLAG[0] = MRCPRCPVER->APPROVAL_FLAG;
    MEMCPY_AN(MRCPRCPVER_N->APPROVAL_USER_ID, MRCPRCPVER->APPROVAL_USER_ID, sizeof(MRCPRCPVER->APPROVAL_USER_ID));
    MEMCPY_AN(MRCPRCPVER_N->APPROVAL_TIME, MRCPRCPVER->APPROVAL_TIME, sizeof(MRCPRCPVER->APPROVAL_TIME));
    MRCPRCPVER_N->RELEASE_FLAG[0] = MRCPRCPVER->RELEASE_FLAG;
    MEMCPY_AN(MRCPRCPVER_N->RELEASE_USER_ID, MRCPRCPVER->RELEASE_USER_ID, sizeof(MRCPRCPVER->RELEASE_USER_ID));
    MEMCPY_AN(MRCPRCPVER_N->RELEASE_TIME, MRCPRCPVER->RELEASE_TIME, sizeof(MRCPRCPVER->RELEASE_TIME));
    MEMCPY_AN(MRCPRCPVER_N->CREATE_USER_ID, MRCPRCPVER->CREATE_USER_ID, sizeof(MRCPRCPVER->CREATE_USER_ID));
    MEMCPY_AN(MRCPRCPVER_N->CREATE_TIME, MRCPRCPVER->CREATE_TIME, sizeof(MRCPRCPVER->CREATE_TIME));
    MEMCPY_AN(MRCPRCPVER_N->UPDATE_USER_ID, MRCPRCPVER->UPDATE_USER_ID, sizeof(MRCPRCPVER->UPDATE_USER_ID));
    MEMCPY_AN(MRCPRCPVER_N->UPDATE_TIME, MRCPRCPVER->UPDATE_TIME, sizeof(MRCPRCPVER->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mrcprcpver(struct MRCPRCPVER_N_TAG *MRCPRCPVER_N, struct MRCPRCPVER_TAG *MRCPRCPVER)
{
    MEMCPY_DN(MRCPRCPVER->FACTORY, MRCPRCPVER_N->FACTORY, sizeof(MRCPRCPVER->FACTORY));
    MEMCPY_DN(MRCPRCPVER->RES_ID, MRCPRCPVER_N->RES_ID, sizeof(MRCPRCPVER->RES_ID));
    MEMCPY_DN(MRCPRCPVER->SUBRES_ID, MRCPRCPVER_N->SUBRES_ID, sizeof(MRCPRCPVER->SUBRES_ID));
    MEMCPY_DN(MRCPRCPVER->RECIPE, MRCPRCPVER_N->RECIPE, sizeof(MRCPRCPVER->RECIPE));
    MRCPRCPVER->RECIPE_VERSION = MRCPRCPVER_N->RECIPE_VERSION;
    MEMCPY_DN(MRCPRCPVER->PP_ID, MRCPRCPVER_N->PP_ID, sizeof(MRCPRCPVER->PP_ID));
    MEMCPY_DN(MRCPRCPVER->COAT_PP_ID, MRCPRCPVER_N->COAT_PP_ID, sizeof(MRCPRCPVER->COAT_PP_ID));
    MEMCPY_DN(MRCPRCPVER->RETICLE_ID, MRCPRCPVER_N->RETICLE_ID, sizeof(MRCPRCPVER->RETICLE_ID));
    MEMCPY_DN(MRCPRCPVER->COL_SET_ID, MRCPRCPVER_N->COL_SET_ID, sizeof(MRCPRCPVER->COL_SET_ID));
    MEMCPY_DN(MRCPRCPVER->PROC_TIME, MRCPRCPVER_N->PROC_TIME, sizeof(MRCPRCPVER->PROC_TIME));
    MRCPRCPVER->MODIFY_FLAG = MRCPRCPVER_N->MODIFY_FLAG[0];
    MEMCPY_DN(MRCPRCPVER->APPLY_START_TIME, MRCPRCPVER_N->APPLY_START_TIME, sizeof(MRCPRCPVER->APPLY_START_TIME));
    MEMCPY_DN(MRCPRCPVER->APPLY_END_TIME, MRCPRCPVER_N->APPLY_END_TIME, sizeof(MRCPRCPVER->APPLY_END_TIME));
    MRCPRCPVER->APPROVAL_FLAG = MRCPRCPVER_N->APPROVAL_FLAG[0];
    MEMCPY_DN(MRCPRCPVER->APPROVAL_USER_ID, MRCPRCPVER_N->APPROVAL_USER_ID, sizeof(MRCPRCPVER->APPROVAL_USER_ID));
    MEMCPY_DN(MRCPRCPVER->APPROVAL_TIME, MRCPRCPVER_N->APPROVAL_TIME, sizeof(MRCPRCPVER->APPROVAL_TIME));
    MRCPRCPVER->RELEASE_FLAG = MRCPRCPVER_N->RELEASE_FLAG[0];
    MEMCPY_DN(MRCPRCPVER->RELEASE_USER_ID, MRCPRCPVER_N->RELEASE_USER_ID, sizeof(MRCPRCPVER->RELEASE_USER_ID));
    MEMCPY_DN(MRCPRCPVER->RELEASE_TIME, MRCPRCPVER_N->RELEASE_TIME, sizeof(MRCPRCPVER->RELEASE_TIME));
    MEMCPY_DN(MRCPRCPVER->CREATE_USER_ID, MRCPRCPVER_N->CREATE_USER_ID, sizeof(MRCPRCPVER->CREATE_USER_ID));
    MEMCPY_DN(MRCPRCPVER->CREATE_TIME, MRCPRCPVER_N->CREATE_TIME, sizeof(MRCPRCPVER->CREATE_TIME));
    MEMCPY_DN(MRCPRCPVER->UPDATE_USER_ID, MRCPRCPVER_N->UPDATE_USER_ID, sizeof(MRCPRCPVER->UPDATE_USER_ID));
    MEMCPY_DN(MRCPRCPVER->UPDATE_TIME, MRCPRCPVER_N->UPDATE_TIME, sizeof(MRCPRCPVER->UPDATE_TIME));
}


