/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrcprcpver(int sel_type, struct MRCPRCPVER_TAG *MRCPRCPVER)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRCPRCPVER_N_TAG MRCPRCPVER_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrcprcpver(&MRCPRCPVER_N, MRCPRCPVER);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRCPRCPVER_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    RECIPE,
                    RECIPE_VERSION,
                    PP_ID,
                    COAT_PP_ID,
                    RETICLE_ID,
                    COL_SET_ID,
                    PROC_TIME,
                    MODIFY_FLAG,
                    APPLY_START_TIME,
                    APPLY_END_TIME,
                    APPROVAL_FLAG,
                    APPROVAL_USER_ID,
                    APPROVAL_TIME,
                    RELEASE_FLAG,
                    RELEASE_USER_ID,
                    RELEASE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRCPRCPVER
                WHERE FACTORY = :MRCPRCPVER_N.FACTORY
                    AND RES_ID = :MRCPRCPVER_N.RES_ID
                    AND SUBRES_ID = :MRCPRCPVER_N.SUBRES_ID
                    AND RECIPE = :MRCPRCPVER_N.RECIPE
                    AND RECIPE_VERSION >= :MRCPRCPVER_N.RECIPE_VERSION
                ORDER BY 
                    RECIPE_VERSION ASC;
            EXEC SQL OPEN DBC_MRCPRCPVER_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrcprcpver", sel_type);
}


