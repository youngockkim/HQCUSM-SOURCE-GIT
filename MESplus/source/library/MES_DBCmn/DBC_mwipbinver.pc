/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipbinver(int sel_type, struct MWIPBINVER_TAG *MWIPBINVER)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPBINVER_N_TAG MWIPBINVER_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipbinver(&MWIPBINVER_N, MWIPBINVER);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPBINVER_CUR_1 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    BIN_ID,
                    BIN_VERSION,
                    APPLY_START_TIME,
                    APPLY_END_TIME,
                    APPROVAL_FLAG,
                    APPROVAL_USER_ID,
                    APPROVAL_TIME,
                    RELEASE_FLAG,
                    RELEASE_USER_ID,
                    RELEASE_TIME
                FROM MWIPBINVER
                WHERE FACTORY = :MWIPBINVER_N.FACTORY
                    AND BIN_ID = :MWIPBINVER_N.BIN_ID
                    AND BIN_VERSION >= :MWIPBINVER_N.BIN_VERSION
                ORDER BY BIN_VERSION ASC;
            EXEC SQL OPEN DBC_MWIPBINVER_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPBINVER_CUR_2 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    BIN_ID,
                    BIN_VERSION,
                    APPLY_START_TIME,
                    APPLY_END_TIME,
                    APPROVAL_FLAG,
                    APPROVAL_USER_ID,
                    APPROVAL_TIME,
                    RELEASE_FLAG,
                    RELEASE_USER_ID,
                    RELEASE_TIME
                FROM MWIPBINVER
                WHERE FACTORY = :MWIPBINVER_N.FACTORY
                    AND BIN_ID = :MWIPBINVER_N.BIN_ID
                    AND BIN_VERSION <= :MWIPBINVER_N.BIN_VERSION
                ORDER BY BIN_VERSION DESC;
            EXEC SQL OPEN DBC_MWIPBINVER_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mwipbinver", sel_type);
}


