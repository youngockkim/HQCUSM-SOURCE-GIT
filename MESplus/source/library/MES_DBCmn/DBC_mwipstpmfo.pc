    MEMCPY_DN(MWIPSTPMFO->CREATE_TIME, MWIPSTPMFO_N->CREATE_TIME, sizeof(MWIPSTPMFO->CREATE_TIME));
    MEMCPY_DN(MWIPSTPMFO->UPDATE_USER_ID, MWIPSTPMFO_N->UPDATE_USER_ID, sizeof(MWIPSTPMFO->UPDATE_USER_ID));
