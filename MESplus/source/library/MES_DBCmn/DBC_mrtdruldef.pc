/* Add Null Function */
void DBC_add_null_mrtdruldef(struct MRTDRULDEF_N_TAG *MRTDRULDEF_N, struct MRTDRULDEF_TAG *MRTDRULDEF)
{
    /* memset by NULL */
    memset(MRTDRULDEF_N, '\0', sizeof(struct MRTDRULDEF_N_TAG));
    
    MEMCPY_AN(MRTDRULDEF_N->FACTORY, MRTDRULDEF->FACTORY, sizeof(MRTDRULDEF->FACTORY));
    MEMCPY_AN(MRTDRULDEF_N->RULE_ID, MRTDRULDEF->RULE_ID, sizeof(MRTDRULDEF->RULE_ID));
    MEMCPY_AN(MRTDRULDEF_N->RULE_DESC, MRTDRULDEF->RULE_DESC, sizeof(MRTDRULDEF->RULE_DESC));
    MRTDRULDEF_N->RULE_TYPE[0] = MRTDRULDEF->RULE_TYPE;
    MEMCPY_AN(MRTDRULDEF_N->CREATE_USER_ID, MRTDRULDEF->CREATE_USER_ID, sizeof(MRTDRULDEF->CREATE_USER_ID));
    MEMCPY_AN(MRTDRULDEF_N->CREATE_TIME, MRTDRULDEF->CREATE_TIME, sizeof(MRTDRULDEF->CREATE_TIME));
    MEMCPY_AN(MRTDRULDEF_N->UPDATE_USER_ID, MRTDRULDEF->UPDATE_USER_ID, sizeof(MRTDRULDEF->UPDATE_USER_ID));
    MEMCPY_AN(MRTDRULDEF_N->UPDATE_TIME, MRTDRULDEF->UPDATE_TIME, sizeof(MRTDRULDEF->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mrtdruldef(struct MRTDRULDEF_N_TAG *MRTDRULDEF_N, struct MRTDRULDEF_TAG *MRTDRULDEF)
{
    MEMCPY_DN(MRTDRULDEF->FACTORY, MRTDRULDEF_N->FACTORY, sizeof(MRTDRULDEF->FACTORY));
    MEMCPY_DN(MRTDRULDEF->RULE_ID, MRTDRULDEF_N->RULE_ID, sizeof(MRTDRULDEF->RULE_ID));
    MEMCPY_DN(MRTDRULDEF->RULE_DESC, MRTDRULDEF_N->RULE_DESC, sizeof(MRTDRULDEF->RULE_DESC));
    MRTDRULDEF->RULE_TYPE = MRTDRULDEF_N->RULE_TYPE[0];
    MEMCPY_DN(MRTDRULDEF->CREATE_USER_ID, MRTDRULDEF_N->CREATE_USER_ID, sizeof(MRTDRULDEF->CREATE_USER_ID));
    MEMCPY_DN(MRTDRULDEF->CREATE_TIME, MRTDRULDEF_N->CREATE_TIME, sizeof(MRTDRULDEF->CREATE_TIME));
    MEMCPY_DN(MRTDRULDEF->UPDATE_USER_ID, MRTDRULDEF_N->UPDATE_USER_ID, sizeof(MRTDRULDEF->UPDATE_USER_ID));
    MEMCPY_DN(MRTDRULDEF->UPDATE_TIME, MRTDRULDEF_N->UPDATE_TIME, sizeof(MRTDRULDEF->UPDATE_TIME));
