/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrtdruldef(int sel_type, struct MRTDRULDEF_TAG *MRTDRULDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRTDRULDEF_N_TAG MRTDRULDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrtdruldef(&MRTDRULDEF_N, MRTDRULDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRTDRULDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RULE_ID,
                    RULE_DESC,
                    RULE_TYPE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRTDRULDEF
                WHERE FACTORY = :MRTDRULDEF_N.FACTORY
                AND RULE_ID >= :MRTDRULDEF_N.RULE_ID
                ORDER BY FACTORY ASC,
                    RULE_ID ASC;
            EXEC SQL OPEN DBC_MRTDRULDEF_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MRTDRULDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    RULE_ID,
                    RULE_DESC,
                    RULE_TYPE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRTDRULDEF
                WHERE FACTORY = :MRTDRULDEF_N.FACTORY
                  AND RULE_TYPE = :MRTDRULDEF_N.RULE_TYPE
                  AND RULE_ID >= :MRTDRULDEF_N.RULE_ID                
                ORDER BY FACTORY ASC,
                    RULE_ID ASC;
            EXEC SQL OPEN DBC_MRTDRULDEF_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrtdruldef", sel_type);
}


