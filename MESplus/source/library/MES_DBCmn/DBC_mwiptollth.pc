/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwiptollth(int sel_type, struct MWIPTOLLTH_TAG *MWIPTOLLTH)
{
    EXEC SQL BEGIN DECLARE SECTION;    
        struct MWIPTOLLTH_N_TAG MWIPTOLLTH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiptollth(&MWIPTOLLTH_N, MWIPTOLLTH);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPTOLLTH_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    HIST_DEL_FLAG,
                    FACTORY,
                    TOOL_ID,
                    TOOL_HIST_SEQ,
                    TOOL_HIST_DEL_FLAG
                FROM MWIPTOLLTH
                WHERE LOT_ID = :MWIPTOLLTH_N.LOT_ID
                    AND HIST_SEQ = :MWIPTOLLTH_N.HIST_SEQ
                    AND HIST_DEL_FLAG = :MWIPTOLLTH_N.HIST_DEL_FLAG
                ORDER BY TOOL_ID ASC,
                    TOOL_HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MWIPTOLLTH_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwiptollth", sel_type);
}


