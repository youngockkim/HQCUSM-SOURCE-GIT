}


/* Add Null Function */
void DBC_add_null_mwiptollth(struct MWIPTOLLTH_N_TAG *MWIPTOLLTH_N, struct MWIPTOLLTH_TAG *MWIPTOLLTH)
{
    /* memset by NULL */
    memset(MWIPTOLLTH_N, '\0', sizeof(struct MWIPTOLLTH_N_TAG));
    
    MEMCPY_AN(MWIPTOLLTH_N->LOT_ID, MWIPTOLLTH->LOT_ID, sizeof(MWIPTOLLTH->LOT_ID));
    MWIPTOLLTH_N->HIST_SEQ = MWIPTOLLTH->HIST_SEQ;
    MWIPTOLLTH_N->HIST_DEL_FLAG[0] = MWIPTOLLTH->HIST_DEL_FLAG;
    MEMCPY_AN(MWIPTOLLTH_N->FACTORY, MWIPTOLLTH->FACTORY, sizeof(MWIPTOLLTH->FACTORY));
    MEMCPY_AN(MWIPTOLLTH_N->TOOL_ID, MWIPTOLLTH->TOOL_ID, sizeof(MWIPTOLLTH->TOOL_ID));
    MWIPTOLLTH_N->TOOL_HIST_SEQ = MWIPTOLLTH->TOOL_HIST_SEQ;
    MWIPTOLLTH_N->TOOL_HIST_DEL_FLAG[0] = MWIPTOLLTH->TOOL_HIST_DEL_FLAG;
}


/* Del Null Function */
void DBC_del_null_mwiptollth(struct MWIPTOLLTH_N_TAG *MWIPTOLLTH_N, struct MWIPTOLLTH_TAG *MWIPTOLLTH)
{
    MEMCPY_DN(MWIPTOLLTH->LOT_ID, MWIPTOLLTH_N->LOT_ID, sizeof(MWIPTOLLTH->LOT_ID));
    MWIPTOLLTH->HIST_SEQ = MWIPTOLLTH_N->HIST_SEQ;
    MWIPTOLLTH->HIST_DEL_FLAG = MWIPTOLLTH_N->HIST_DEL_FLAG[0];
    MEMCPY_DN(MWIPTOLLTH->FACTORY, MWIPTOLLTH_N->FACTORY, sizeof(MWIPTOLLTH->FACTORY));
    MEMCPY_DN(MWIPTOLLTH->TOOL_ID, MWIPTOLLTH_N->TOOL_ID, sizeof(MWIPTOLLTH->TOOL_ID));
    MWIPTOLLTH->TOOL_HIST_SEQ = MWIPTOLLTH_N->TOOL_HIST_SEQ;
    MWIPTOLLTH->TOOL_HIST_DEL_FLAG = MWIPTOLLTH_N->TOOL_HIST_DEL_FLAG[0];
