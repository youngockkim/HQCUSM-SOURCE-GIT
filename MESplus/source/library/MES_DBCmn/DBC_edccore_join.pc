/* EDCCore_view_col_set_list_detail.c */
/* SQL CURSOR FETCH Function */
void DBC_fetch_get_colset(int sel_type, struct GET_COLSET_TAG *GET_COLSET)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct GET_COLSET_N_TAG GET_COLSET_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_GET_COLSET_CUR_1 INTO 
                :GET_COLSET_N.COL_SET_ID,
                :GET_COLSET_N.COL_SET_DESC,
                :GET_COLSET_N.SEQ_NUM,
                :GET_COLSET_N.CHAR_ID, 
                :GET_COLSET_N.CHAR_DESC, 
                :GET_COLSET_N.UNIT_COUNT,
                :GET_COLSET_N.VALUE_COUNT,
                :GET_COLSET_N.DISPLAY_PRECISION,
                :GET_COLSET_N.VALUE_TBL,
                :GET_COLSET_N.DEF_VALUE,
                :GET_COLSET_N.OPT_INPUT_FLAG,
                :GET_COLSET_N.BLANK_REC_SAVE_FLAG,
                :GET_COLSET_N.DEF_UNIT_FLAG,
                :GET_COLSET_N.DEF_UNIT_OVR_FLAG,
                :GET_COLSET_N.UNIT_TBL,
                :GET_COLSET_N.SPEC_TYPE,
                :GET_COLSET_N.SPEC_OUT_COUNT,               
                :GET_COLSET_N.TARGET_VALUE,
                :GET_COLSET_N.UPPER_SPEC_LIMIT,
                :GET_COLSET_N.LOWER_SPEC_LIMIT,
                :GET_COLSET_N.UPPER_WARN_LIMIT,
                :GET_COLSET_N.LOWER_WARN_LIMIT,
                :GET_COLSET_N.SPEC_INFO,
                :GET_COLSET_N.SPEC_OUT_ALARM,
                :GET_COLSET_N.WARN_OUT_ALARM,
                :GET_COLSET_N.DERIVED_PARAM_FLAG,
                :GET_COLSET_N.DERIVED_PARAMETER,
                :GET_COLSET_N.LOT_OR_RES_FLAG,
                :GET_COLSET_N.APPROVAL_REQUIRE_FLAG,
                :GET_COLSET_N.APPROVAL_USER_ID,
                :GET_COLSET_N.DELETE_FLAG,
                :GET_COLSET_N.DELETE_TIME,
                :GET_COLSET_N.DELETE_USER_ID,
                :GET_COLSET_N.CREATE_TIME,
                :GET_COLSET_N.CREATE_USER_ID,
                :GET_COLSET_N.UPDATE_TIME,
                :GET_COLSET_N.UPDATE_USER_ID;
                
            break;
            
        case 2:
            EXEC SQL FETCH DBC_GET_COLSET_CUR_2 INTO 
                :GET_COLSET_N.COL_SET_ID,
                :GET_COLSET_N.COL_SET_DESC,
                :GET_COLSET_N.SEQ_NUM,
                :GET_COLSET_N.CHAR_ID, 
                :GET_COLSET_N.CHAR_DESC, 
                :GET_COLSET_N.UNIT_COUNT,
                :GET_COLSET_N.VALUE_COUNT,
                :GET_COLSET_N.DISPLAY_PRECISION,
                :GET_COLSET_N.VALUE_TBL,
                :GET_COLSET_N.DEF_VALUE,
                :GET_COLSET_N.OPT_INPUT_FLAG,
                :GET_COLSET_N.BLANK_REC_SAVE_FLAG,
                :GET_COLSET_N.DEF_UNIT_FLAG,
                :GET_COLSET_N.DEF_UNIT_OVR_FLAG,
                :GET_COLSET_N.UNIT_TBL,
                :GET_COLSET_N.SPEC_TYPE,
                :GET_COLSET_N.SPEC_OUT_COUNT,               
                :GET_COLSET_N.TARGET_VALUE,
                :GET_COLSET_N.UPPER_SPEC_LIMIT,
                :GET_COLSET_N.LOWER_SPEC_LIMIT,
                :GET_COLSET_N.UPPER_WARN_LIMIT,
                :GET_COLSET_N.LOWER_WARN_LIMIT,
                :GET_COLSET_N.SPEC_INFO,
                :GET_COLSET_N.SPEC_OUT_ALARM,
                :GET_COLSET_N.WARN_OUT_ALARM,
                :GET_COLSET_N.DERIVED_PARAM_FLAG,
                :GET_COLSET_N.DERIVED_PARAMETER,
                :GET_COLSET_N.LOT_OR_RES_FLAG,
                :GET_COLSET_N.APPROVAL_REQUIRE_FLAG,
                :GET_COLSET_N.APPROVAL_USER_ID,
                :GET_COLSET_N.DELETE_FLAG,
