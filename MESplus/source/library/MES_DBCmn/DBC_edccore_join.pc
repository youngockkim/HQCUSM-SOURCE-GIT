                :GET_COLSET_N.UPDATE_TIME,
                :GET_COLSET_N.UPDATE_USER_ID;

            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    if(DB_error_code == 0)
    {
        DBC_del_null_get_colset(&GET_COLSET_N, GET_COLSET);
    }
    DB_stop_query_timer("DBC_fetch_get_colset", sel_type);
