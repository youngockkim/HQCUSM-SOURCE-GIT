/* EDCCore_view_col_set_list_detail.c */
/* SQL CURSOR CLOSE Function */
void DBC_close_get_colset(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_GET_COLSET_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_GET_COLSET_CUR_2;
            break;        
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_get_colset", sel_type);
}

/* EDCCore_view_col_set_list_detail.c */
/* Initialize Function */
void DBC_init_get_colset(struct GET_COLSET_TAG *GET_COLSET)
{
    /* memset by Space */
    memset(GET_COLSET, ' ', sizeof(struct GET_COLSET_TAG));
    
    GET_COLSET->SEQ_NUM = 0;
    GET_COLSET->UNIT_COUNT = 0;
    GET_COLSET->VALUE_COUNT = 0;
    GET_COLSET->DISPLAY_PRECISION = 0;
    GET_COLSET->SPEC_OUT_COUNT = 0;
}

/* EDCCore_view_col_set_list_detail.c */
/* Add Null Function */
void DBC_add_null_get_colset(struct GET_COLSET_N_TAG *GET_COLSET_N, struct GET_COLSET_TAG *GET_COLSET)
{ 
    /* memset by NULL */
    memset(GET_COLSET_N, '\0', sizeof(struct GET_COLSET_N_TAG));

    MEMCPY_AN(GET_COLSET_N->FACTORY, GET_COLSET->FACTORY, sizeof(GET_COLSET->FACTORY));
    MEMCPY_AN(GET_COLSET_N->COL_SET_ID, GET_COLSET->COL_SET_ID, sizeof(GET_COLSET->COL_SET_ID));
    MEMCPY_AN(GET_COLSET_N->COL_SET_DESC, GET_COLSET->COL_SET_DESC, sizeof(GET_COLSET->COL_SET_DESC));
    GET_COLSET_N->SEQ_NUM = GET_COLSET->SEQ_NUM;    
    MEMCPY_AN(GET_COLSET_N->CHAR_ID, GET_COLSET->CHAR_ID, sizeof(GET_COLSET->CHAR_ID));
    MEMCPY_AN(GET_COLSET_N->CHAR_DESC, GET_COLSET->CHAR_DESC, sizeof(GET_COLSET->CHAR_DESC));
    GET_COLSET_N->UNIT_COUNT = GET_COLSET->UNIT_COUNT;
    GET_COLSET_N->VALUE_COUNT = GET_COLSET->VALUE_COUNT;
    GET_COLSET_N->DISPLAY_PRECISION = GET_COLSET->DISPLAY_PRECISION;
    MEMCPY_AN(GET_COLSET_N->VALUE_TBL, GET_COLSET->VALUE_TBL, sizeof(GET_COLSET->VALUE_TBL));
    MEMCPY_AN(GET_COLSET_N->DEF_VALUE, GET_COLSET->DEF_VALUE, sizeof(GET_COLSET->DEF_VALUE));
    GET_COLSET_N->OPT_INPUT_FLAG[0] = GET_COLSET->OPT_INPUT_FLAG;
    GET_COLSET_N->BLANK_REC_SAVE_FLAG[0] = GET_COLSET->BLANK_REC_SAVE_FLAG;
    GET_COLSET_N->DEF_UNIT_FLAG[0] = GET_COLSET->DEF_UNIT_FLAG;
    GET_COLSET_N->DEF_UNIT_OVR_FLAG[0] = GET_COLSET->DEF_UNIT_OVR_FLAG;
    MEMCPY_AN(GET_COLSET_N->UNIT_TBL, GET_COLSET->UNIT_TBL, sizeof(GET_COLSET->UNIT_TBL));
    GET_COLSET_N->SPEC_TYPE[0] = GET_COLSET->SPEC_TYPE;
    GET_COLSET_N->SPEC_OUT_COUNT = GET_COLSET->SPEC_OUT_COUNT;
    MEMCPY_AN(GET_COLSET_N->TARGET_VALUE, GET_COLSET->TARGET_VALUE, sizeof(GET_COLSET->TARGET_VALUE));
    MEMCPY_AN(GET_COLSET_N->UPPER_SPEC_LIMIT, GET_COLSET->UPPER_SPEC_LIMIT, sizeof(GET_COLSET->UPPER_SPEC_LIMIT));
    MEMCPY_AN(GET_COLSET_N->LOWER_SPEC_LIMIT, GET_COLSET->LOWER_SPEC_LIMIT, sizeof(GET_COLSET->LOWER_SPEC_LIMIT));
