/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mbatprcdef(int sel_type, struct MBATPRCDEF_TAG *MBATPRCDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBATPRCDEF_N_TAG MBATPRCDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbatprcdef(&MBATPRCDEF_N, MBATPRCDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MBATPRCDEF_CUR_1 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    JOB_PROC_ID,
                    JOB_PROC_DESC,
                    PROC_CYCLE,
                    SERVICE_MODULE,
                    SERVICE_NAME,
                    PROC_METHOD,
                    COMPLETE_ALARM_ID,
                    JOB_PRIORITY,
                    MES_CHANNEL,
                    ACTIVATE_FLAG,
                    APPLY_START_TIME,
                    APPLY_END_TIME,
                    JOB_RUN_FLAG
                FROM MBATPRCDEF
                WHERE ACTIVATE_FLAG = :MBATPRCDEF_N.ACTIVATE_FLAG
                    AND (APPLY_START_TIME = ' ' OR APPLY_START_TIME <= :MBATPRCDEF_N.APPLY_START_TIME) 
                    AND (APPLY_END_TIME = ' ' OR APPLY_END_TIME > :MBATPRCDEF_N.APPLY_START_TIME)
                ORDER BY JOB_PRIORITY ASC, JOB_PROC_ID ASC;
            EXEC SQL OPEN DBC_MBATPRCDEF_CUR_1;
            break;

            case 2:
            EXEC SQL DECLARE DBC_MBATPRCDEF_CUR_2 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    JOB_PROC_ID,
                    JOB_PROC_DESC,
                    PROC_CYCLE,
                    SERVICE_MODULE,
                    SERVICE_NAME,
                    PROC_METHOD,
                    COMPLETE_ALARM_ID,
                    JOB_PRIORITY,
                    MES_CHANNEL,
                    ACTIVATE_FLAG,
                    APPLY_START_TIME,
                    APPLY_END_TIME,
                    JOB_RUN_FLAG
                FROM MBATPRCDEF
               WHERE JOB_PROC_ID >= :MBATPRCDEF_N.JOB_PROC_ID
                ORDER BY JOB_PROC_ID;
            EXEC SQL OPEN DBC_MBATPRCDEF_CUR_2;

            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mbatprcdef", sel_type);
}


