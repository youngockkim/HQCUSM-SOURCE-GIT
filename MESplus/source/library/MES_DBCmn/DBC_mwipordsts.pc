                                                    :MWIPORDSTS_N.BOM_SET_VERSION,
                                                    :MWIPORDSTS_N.CUSTOMER_ID,
                                                    :MWIPORDSTS_N.CUSTOMER_MAT_ID,
                                                    :MWIPORDSTS_N.WORK_DATE,
                                                    :MWIPORDSTS_N.PLAN_DUE_TIME,
