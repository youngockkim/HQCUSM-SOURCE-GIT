/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mqcmsmpdef(int sel_type, struct MQCMSMPDEF_TAG *MQCMSMPDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MQCMSMPDEF_N_TAG MQCMSMPDEF_N;
        char   sql[5120];
        char   ts1[100];
        char   ts2[100];
        char   ts3[100];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mqcmsmpdef(&MQCMSMPDEF_N, MQCMSMPDEF);
    DB_error_code = 0;
    
    memset( ts1, 0x00, sizeof(ts1));
    memset( ts2, 0x00, sizeof(ts2));
    memset( ts3, 0x00, sizeof(ts3));

    switch(sel_type)
    {
        case 1:            
            if(strcmp(MQCMSMPDEF_N.SAMPLE_PROC_DESC, " ") == 0)
                MQCMSMPDEF_N.SAMPLE_PROC_DESC[0] = '%';
            else
                strcat(MQCMSMPDEF_N.SAMPLE_PROC_DESC, "%");
        
            memset( sql, 0x00, sizeof(sql));
            sprintf(sql,               "SELECT SAMPLE_PROC, SAMPLE_PROC_DESC FROM MQCMSMPDEF WHERE ");

            make_valid_quote(ts1, MQCMSMPDEF_N.FACTORY);
            make_valid_quote(ts2, MQCMSMPDEF_N.SAMPLE_PROC);
            make_valid_quote(ts3, MQCMSMPDEF_N.SAMPLE_PROC_DESC);

            sprintf(sql + strlen(sql), "FACTORY = '%s' AND SAMPLE_PROC >= '%s' AND SAMPLE_PROC LIKE '%s' ",
                ts1, ts2, ts3);
            sprintf(sql + strlen(sql), "ORDER BY SAMPLE_PROC ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MQCMSMPDEF_CUR_1 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MQCMSMPDEF_CUR_1;    
             
            /*******************************
            LOG_head("DB");
            LOG_add("len", 1, strlen(sql));
            LOG_add("sql", 4, strlen(sql), sql);
            COM_log_write('I', 'S' , 'S');
            ********************************/
                        
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mqcmsmpdef", sel_type);
}


