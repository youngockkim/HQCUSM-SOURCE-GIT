{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPLOTYLD_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwiplotyld", sel_type);
}


/* Initialize Function */
void DBC_init_mwiplotyld(struct MWIPLOTYLD_TAG *MWIPLOTYLD)
{
    /* memset by Space */
    memset(MWIPLOTYLD, ' ', sizeof(struct MWIPLOTYLD_TAG));
    
    MWIPLOTYLD->HIST_SEQ = 0;
    MWIPLOTYLD->MAT_VER = 0;
    MWIPLOTYLD->FLOW_SEQ_NUM = 0;
    MWIPLOTYLD->QTY_1 = 0;
    MWIPLOTYLD->QTY_2 = 0;
    MWIPLOTYLD->QTY_3 = 0;
    MWIPLOTYLD->SECTION_IN_QTY_1 = 0;
    MWIPLOTYLD->SECTION_IN_QTY_2 = 0;
    MWIPLOTYLD->SECTION_IN_QTY_3 = 0;
    MWIPLOTYLD->WORKCELL_IN_QTY_1 = 0;
    MWIPLOTYLD->WORKCELL_IN_QTY_2 = 0;
    MWIPLOTYLD->WORKCELL_IN_QTY_3 = 0;
    MWIPLOTYLD->LINE_IN_QTY_1 = 0;
    MWIPLOTYLD->LINE_IN_QTY_2 = 0;
    MWIPLOTYLD->LINE_IN_QTY_3 = 0;
}


/* Add Null Function */
void DBC_add_null_mwiplotyld(struct MWIPLOTYLD_N_TAG *MWIPLOTYLD_N, struct MWIPLOTYLD_TAG *MWIPLOTYLD)
{
    /* memset by NULL */
    memset(MWIPLOTYLD_N, '\0', sizeof(struct MWIPLOTYLD_N_TAG));
    
    MEMCPY_AN(MWIPLOTYLD_N->LOT_ID, MWIPLOTYLD->LOT_ID, sizeof(MWIPLOTYLD->LOT_ID));
    MWIPLOTYLD_N->HIST_SEQ = MWIPLOTYLD->HIST_SEQ;
    MEMCPY_AN(MWIPLOTYLD_N->TRAN_TIME, MWIPLOTYLD->TRAN_TIME, sizeof(MWIPLOTYLD->TRAN_TIME));
    MEMCPY_AN(MWIPLOTYLD_N->SYS_TRAN_TIME, MWIPLOTYLD->SYS_TRAN_TIME, sizeof(MWIPLOTYLD->SYS_TRAN_TIME));
    MEMCPY_AN(MWIPLOTYLD_N->FACTORY, MWIPLOTYLD->FACTORY, sizeof(MWIPLOTYLD->FACTORY));
    MEMCPY_AN(MWIPLOTYLD_N->MAT_ID, MWIPLOTYLD->MAT_ID, sizeof(MWIPLOTYLD->MAT_ID));
    MWIPLOTYLD_N->MAT_VER = MWIPLOTYLD->MAT_VER;
    MEMCPY_AN(MWIPLOTYLD_N->FLOW, MWIPLOTYLD->FLOW, sizeof(MWIPLOTYLD->FLOW));
    MWIPLOTYLD_N->FLOW_SEQ_NUM = MWIPLOTYLD->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPLOTYLD_N->OPER, MWIPLOTYLD->OPER, sizeof(MWIPLOTYLD->OPER));
    MWIPLOTYLD_N->QTY_1 = MWIPLOTYLD->QTY_1;
    MWIPLOTYLD_N->QTY_2 = MWIPLOTYLD->QTY_2;
    MWIPLOTYLD_N->QTY_3 = MWIPLOTYLD->QTY_3;
    MWIPLOTYLD_N->SECTION_IN_QTY_1 = MWIPLOTYLD->SECTION_IN_QTY_1;
    MWIPLOTYLD_N->SECTION_IN_QTY_2 = MWIPLOTYLD->SECTION_IN_QTY_2;
    MWIPLOTYLD_N->SECTION_IN_QTY_3 = MWIPLOTYLD->SECTION_IN_QTY_3;
    MWIPLOTYLD_N->WORKCELL_IN_QTY_1 = MWIPLOTYLD->WORKCELL_IN_QTY_1;
    MWIPLOTYLD_N->WORKCELL_IN_QTY_2 = MWIPLOTYLD->WORKCELL_IN_QTY_2;
    MWIPLOTYLD_N->WORKCELL_IN_QTY_3 = MWIPLOTYLD->WORKCELL_IN_QTY_3;
    MWIPLOTYLD_N->LINE_IN_QTY_1 = MWIPLOTYLD->LINE_IN_QTY_1;
    MWIPLOTYLD_N->LINE_IN_QTY_2 = MWIPLOTYLD->LINE_IN_QTY_2;
    MWIPLOTYLD_N->LINE_IN_QTY_3 = MWIPLOTYLD->LINE_IN_QTY_3;
    MEMCPY_AN(MWIPLOTYLD_N->SECTION_ID, MWIPLOTYLD->SECTION_ID, sizeof(MWIPLOTYLD->SECTION_ID));
    MEMCPY_AN(MWIPLOTYLD_N->WORKCELL_ID, MWIPLOTYLD->WORKCELL_ID, sizeof(MWIPLOTYLD->WORKCELL_ID));
    MEMCPY_AN(MWIPLOTYLD_N->LINE_ID, MWIPLOTYLD->LINE_ID, sizeof(MWIPLOTYLD->LINE_ID));
    MEMCPY_AN(MWIPLOTYLD_N->RESV_FIELD_1, MWIPLOTYLD->RESV_FIELD_1, sizeof(MWIPLOTYLD->RESV_FIELD_1));
    MEMCPY_AN(MWIPLOTYLD_N->RESV_FIELD_2, MWIPLOTYLD->RESV_FIELD_2, sizeof(MWIPLOTYLD->RESV_FIELD_2));
    MEMCPY_AN(MWIPLOTYLD_N->RESV_FIELD_3, MWIPLOTYLD->RESV_FIELD_3, sizeof(MWIPLOTYLD->RESV_FIELD_3));
    MEMCPY_AN(MWIPLOTYLD_N->RESV_FIELD_4, MWIPLOTYLD->RESV_FIELD_4, sizeof(MWIPLOTYLD->RESV_FIELD_4));
    MEMCPY_AN(MWIPLOTYLD_N->RESV_FIELD_5, MWIPLOTYLD->RESV_FIELD_5, sizeof(MWIPLOTYLD->RESV_FIELD_5));
    MWIPLOTYLD_N->RESV_FLAG_1[0] = MWIPLOTYLD->RESV_FLAG_1;
    MWIPLOTYLD_N->RESV_FLAG_2[0] = MWIPLOTYLD->RESV_FLAG_2;
    MWIPLOTYLD_N->RESV_FLAG_3[0] = MWIPLOTYLD->RESV_FLAG_3;
    MWIPLOTYLD_N->RESV_FLAG_4[0] = MWIPLOTYLD->RESV_FLAG_4;
    MWIPLOTYLD_N->RESV_FLAG_5[0] = MWIPLOTYLD->RESV_FLAG_5;
}


