/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwiplotyld(int sel_type, struct MWIPLOTYLD_TAG *MWIPLOTYLD)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTYLD_N_TAG MWIPLOTYLD_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplotyld(&MWIPLOTYLD_N, MWIPLOTYLD);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPLOTYLD_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    SYS_TRAN_TIME,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    SECTION_IN_QTY_1,
                    SECTION_IN_QTY_2,
                    SECTION_IN_QTY_3,
                    WORKCELL_IN_QTY_1,
                    WORKCELL_IN_QTY_2,
                    WORKCELL_IN_QTY_3,
                    LINE_IN_QTY_1,
                    LINE_IN_QTY_2,
                    LINE_IN_QTY_3,
                    SECTION_ID,
                    WORKCELL_ID,
                    LINE_ID,
                    RESV_FIELD_1,
                    RESV_FIELD_2,
                    RESV_FIELD_3,
                    RESV_FIELD_4,
                    RESV_FIELD_5,
                    RESV_FLAG_1,
                    RESV_FLAG_2,
                    RESV_FLAG_3,
                    RESV_FLAG_4,
                    RESV_FLAG_5
                FROM MWIPLOTYLD
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MWIPLOTYLD_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwiplotyld", sel_type);
}


