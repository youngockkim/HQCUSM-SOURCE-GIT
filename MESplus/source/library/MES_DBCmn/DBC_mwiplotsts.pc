                make_valid_quote(bind_vars[index], MWIPLOTSTS_N.LOT_GROUP_ID_1);
                sprintf(sql + strlen(sql), ", LOT_GROUP_ID_1=:%d", index++);
            }
            if(memcmp(MWIPLOTSTS->LOT_GROUP_ID_2, MWIPLOTSTS_S.LOT_GROUP_ID_2, sizeof(MWIPLOTSTS->LOT_GROUP_ID_2)) != 0) {
                make_valid_quote(bind_vars[index], MWIPLOTSTS_N.LOT_GROUP_ID_2);
                sprintf(sql + strlen(sql), ", LOT_GROUP_ID_2=:%d", index++);
            }
            if(memcmp(MWIPLOTSTS->LOT_GROUP_ID_3, MWIPLOTSTS_S.LOT_GROUP_ID_3, sizeof(MWIPLOTSTS->LOT_GROUP_ID_3)) != 0) {
                make_valid_quote(bind_vars[index], MWIPLOTSTS_N.LOT_GROUP_ID_3);
                sprintf(sql + strlen(sql), ", LOT_GROUP_ID_3=:%d", index++);
            }
            if(MWIPLOTSTS->YIELD_1 != MWIPLOTSTS_S.YIELD_1) {
                sprintf(bind_vars[index], "%.10f\0", MWIPLOTSTS_N.YIELD_1);
                sprintf(sql + strlen(sql), ", YIELD_1=:%d", index++);
            }
            if(MWIPLOTSTS->YIELD_2 != MWIPLOTSTS_S.YIELD_2) {
                sprintf(bind_vars[index], "%.10f\0", MWIPLOTSTS_N.YIELD_2);
                sprintf(sql + strlen(sql), ", YIELD_2=:%d", index++);
            }
            if(MWIPLOTSTS->YIELD_3 != MWIPLOTSTS_S.YIELD_3) {
                sprintf(bind_vars[index], "%.10f\0", MWIPLOTSTS_N.YIELD_3);
                sprintf(sql + strlen(sql), ", YIELD_3=:%d", index++);
            }
            if(MWIPLOTSTS->GOOD_QTY != MWIPLOTSTS_S.GOOD_QTY) {
                sprintf(bind_vars[index], "%f\0", MWIPLOTSTS_N.GOOD_QTY);
                sprintf(sql + strlen(sql), ", GOOD_QTY=:%d", index++);
            }
            if(memcmp(MWIPLOTSTS->RESV_FIELD_1, MWIPLOTSTS_S.RESV_FIELD_1, sizeof(MWIPLOTSTS->RESV_FIELD_1)) != 0) {
                make_valid_quote(bind_vars[index], MWIPLOTSTS_N.RESV_FIELD_1);
                sprintf(sql + strlen(sql), ", RESV_FIELD_1=:%d", index++);
            }
            if(memcmp(MWIPLOTSTS->RESV_FIELD_2, MWIPLOTSTS_S.RESV_FIELD_2, sizeof(MWIPLOTSTS->RESV_FIELD_2)) != 0) {
                make_valid_quote(bind_vars[index], MWIPLOTSTS_N.RESV_FIELD_2);
                sprintf(sql + strlen(sql), ", RESV_FIELD_2=:%d", index++);
            }
            if(memcmp(MWIPLOTSTS->RESV_FIELD_3, MWIPLOTSTS_S.RESV_FIELD_3, sizeof(MWIPLOTSTS->RESV_FIELD_3)) != 0) {
                make_valid_quote(bind_vars[index], MWIPLOTSTS_N.RESV_FIELD_3);
                sprintf(sql + strlen(sql), ", RESV_FIELD_3=:%d", index++);
            }
            if(memcmp(MWIPLOTSTS->RESV_FIELD_4, MWIPLOTSTS_S.RESV_FIELD_4, sizeof(MWIPLOTSTS->RESV_FIELD_4)) != 0) {
                make_valid_quote(bind_vars[index], MWIPLOTSTS_N.RESV_FIELD_4);
                sprintf(sql + strlen(sql), ", RESV_FIELD_4=:%d", index++);
            }
            if(memcmp(MWIPLOTSTS->RESV_FIELD_5, MWIPLOTSTS_S.RESV_FIELD_5, sizeof(MWIPLOTSTS->RESV_FIELD_5)) != 0) {
                make_valid_quote(bind_vars[index], MWIPLOTSTS_N.RESV_FIELD_5);
                sprintf(sql + strlen(sql), ", RESV_FIELD_5=:%d", index++);
            }
            if(MWIPLOTSTS->RESV_FLAG_1 != MWIPLOTSTS_S.RESV_FLAG_1) {
                sprintf(bind_vars[index], "%c\0", MWIPLOTSTS_N.RESV_FLAG_1[0]);
                sprintf(sql + strlen(sql), ", RESV_FLAG_1=:%d", index++);
            }
            if(MWIPLOTSTS->RESV_FLAG_2 != MWIPLOTSTS_S.RESV_FLAG_2) {
                sprintf(bind_vars[index], "%c\0", MWIPLOTSTS_N.RESV_FLAG_2[0]);
                sprintf(sql + strlen(sql), ", RESV_FLAG_2=:%d", index++);
            }
            if(MWIPLOTSTS->RESV_FLAG_3 != MWIPLOTSTS_S.RESV_FLAG_3) {
                sprintf(bind_vars[index], "%c\0", MWIPLOTSTS_N.RESV_FLAG_3[0]);
                sprintf(sql + strlen(sql), ", RESV_FLAG_3=:%d", index++);
            }
            if(MWIPLOTSTS->RESV_FLAG_4 != MWIPLOTSTS_S.RESV_FLAG_4) {
                sprintf(bind_vars[index], "%c\0", MWIPLOTSTS_N.RESV_FLAG_4[0]);
                sprintf(sql + strlen(sql), ", RESV_FLAG_4=:%d", index++);
            }
            if(MWIPLOTSTS->RESV_FLAG_5 != MWIPLOTSTS_S.RESV_FLAG_5) {
                sprintf(bind_vars[index], "%c\0", MWIPLOTSTS_N.RESV_FLAG_5[0]);
                sprintf(sql + strlen(sql), ", RESV_FLAG_5=:%d", index++);
            }

            make_valid_quote(bind_vars[index], MWIPLOTSTS_N.LOT_ID); 
            sprintf(sql + strlen(sql), " WHERE LOT_ID=:%d", index++);

            DBC_execute_non_query_with_bind(sql, bind_vars, index);

            /*
            LOG_head("DB");
            LOG_add("len", 1, strlen(sql));
            LOG_add("sql", 4, strlen(sql), sql);
            COM_log_write('I', 'S' , 'S');
            */
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mwiplotsts", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwiplotsts(int sel_type, struct MWIPLOTSTS_TAG *MWIPLOTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTSTS_N_TAG MWIPLOTSTS_N;
        char   sql[10000];
        char   ts1[100];
        char   ts2[100];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();


    DBC_add_null_mwiplotsts(&MWIPLOTSTS_N, MWIPLOTSTS);
    DB_error_code = 0;
    memset( ts1, 0x00, sizeof(ts1));
    memset( ts2, 0x00, sizeof(ts2));

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPLOTSTS_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    LOT_DESC,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    CRR_ID,
                    LOT_TYPE,
                    OWNER_CODE,
                    CREATE_CODE,
                    LOT_PRIORITY,
                    LOT_STATUS,
                    HOLD_FLAG,
                    HOLD_CODE,
                    HOLD_PASSWORD,
                    HOLD_PRV_GRP_ID,
                    OPER_IN_QTY_1,
                    OPER_IN_QTY_2,
                    OPER_IN_QTY_3,
                    CREATE_QTY_1,
                    CREATE_QTY_2,
                    CREATE_QTY_3,
                    START_QTY_1,
                    START_QTY_2,
                    START_QTY_3,
                    INV_FLAG,
                    TRANSIT_FLAG,
                    UNIT_EXIST_FLAG,
                    INV_UNIT,
                    RWK_FLAG,
                    RWK_CODE,
                    RWK_COUNT,
                    RWK_RET_FLOW,
                    RWK_RET_FLOW_SEQ_NUM,
                    RWK_RET_OPER,
                    RWK_END_FLOW,
                    RWK_END_FLOW_SEQ_NUM,
                    RWK_END_OPER,
                    RWK_RET_CLEAR_FLAG,
                    RWK_TIME,
                    NSTD_FLAG,
                    NSTD_RET_FLOW,
                    NSTD_RET_FLOW_SEQ_NUM,
                    NSTD_RET_OPER,
                    NSTD_TIME,
                    REP_FLAG,
                    REP_RET_OPER,
                    STR_RET_FLOW,
                    STR_RET_FLOW_SEQ_NUM,
                    STR_RET_OPER,
                    START_FLAG,
                    START_TIME,
                    START_RES_ID,
                    END_FLAG,
                    END_TIME,
                    END_RES_ID,
                    SAMPLE_FLAG,
                    SAMPLE_WAIT_FLAG,
                    SAMPLE_RESULT,
                    FROM_TO_FLAG,
                    FROM_TO_LOT_ID,
                    SHIP_CODE,
                    SHIP_TIME,
                    ORG_DUE_TIME,
                    SCH_DUE_TIME,
                    CREATE_TIME,
                    FAC_IN_TIME,
                    FLOW_IN_TIME,
                    OPER_IN_TIME,
                    RESERVE_RES_ID,
                    PORT_ID,
                    BATCH_ID,
                    BATCH_SEQ,
                    ORDER_ID,
                    ADD_ORDER_ID_1,
                    ADD_ORDER_ID_2,
                    ADD_ORDER_ID_3,
                    LOT_LOCATION_1,
                    LOT_LOCATION_2,
                    LOT_LOCATION_3,
                    LOT_CMF_1,
                    LOT_CMF_2,
                    LOT_CMF_3,
                    LOT_CMF_4,
                    LOT_CMF_5,
                    LOT_CMF_6,
                    LOT_CMF_7,
                    LOT_CMF_8,
                    LOT_CMF_9,
                    LOT_CMF_10,
                    LOT_CMF_11,
                    LOT_CMF_12,
                    LOT_CMF_13,
                    LOT_CMF_14,
                    LOT_CMF_15,
                    LOT_CMF_16,
                    LOT_CMF_17,
                    LOT_CMF_18,
                    LOT_CMF_19,
                    LOT_CMF_20,
                    LOT_DEL_FLAG,
                    LOT_DEL_CODE,
                    LOT_DEL_TIME,
                    BOM_SET_ID,
                    BOM_SET_VERSION,
                    BOM_ACTIVE_HIST_SEQ,
                    BOM_HIST_SEQ,
                    LAST_TRAN_CODE,
                    LAST_TRAN_TIME,
                    LAST_COMMENT,
                    LAST_ACTIVE_HIST_SEQ,
                    LAST_HIST_SEQ,
                    CRITICAL_RES_ID,
                    CRITICAL_RES_GROUP_ID,
                    SAVE_RES_ID_1,
                    SAVE_RES_ID_2,
                    SUBRES_ID,
                    LOT_GROUP_ID_1,
                    LOT_GROUP_ID_2,
                    LOT_GROUP_ID_3,
                    YIELD_1,
                    YIELD_2,
                    YIELD_3,
                    GOOD_QTY,
                    RESV_FIELD_1,
                    RESV_FIELD_2,
                    RESV_FIELD_3,
                    RESV_FIELD_4,
                    RESV_FIELD_5,
                    RESV_FLAG_1,
                    RESV_FLAG_2,
                    RESV_FLAG_3,
                    RESV_FLAG_4,
                    RESV_FLAG_5
                FROM MWIPLOTSTS
                WHERE LOT_ID >= :MWIPLOTSTS_N.LOT_ID
                    AND FACTORY = :MWIPLOTSTS_N.FACTORY
                    AND ORDER_ID = :MWIPLOTSTS_N.ORDER_ID
                    AND LOT_DEL_FLAG = ' '
                ORDER BY LOT_ID ASC;
            EXEC SQL OPEN DBC_MWIPLOTSTS_CUR_1;
            break;

        case 2:
            memset( sql, 0x00, sizeof(sql));
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "LOT_ID, ");
            sprintf(sql + strlen(sql),   "LOT_DESC, ");
