            sprintf(sql + strlen(sql), "AND  LOT_ID >= '%s' ", ts1);
            sprintf(sql + strlen(sql), "ORDER BY LOT_ID ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MWIPLOTSTS_CUR_11 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MWIPLOTSTS_CUR_11;                 
