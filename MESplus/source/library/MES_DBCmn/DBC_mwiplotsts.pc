    MEMCPY_DN(MWIPLOTSTS->RESV_FIELD_3, MWIPLOTSTS_N->RESV_FIELD_3, sizeof(MWIPLOTSTS->RESV_FIELD_3));
    MEMCPY_DN(MWIPLOTSTS->RESV_FIELD_4, MWIPLOTSTS_N->RESV_FIELD_4, sizeof(MWIPLOTSTS->RESV_FIELD_4));
    MEMCPY_DN(MWIPLOTSTS->RESV_FIELD_5, MWIPLOTSTS_N->RESV_FIELD_5, sizeof(MWIPLOTSTS->RESV_FIELD_5));
    MWIPLOTSTS->RESV_FLAG_1 = MWIPLOTSTS_N->RESV_FLAG_1[0];
    MWIPLOTSTS->RESV_FLAG_2 = MWIPLOTSTS_N->RESV_FLAG_2[0];
    MWIPLOTSTS->RESV_FLAG_3 = MWIPLOTSTS_N->RESV_FLAG_3[0];
    MWIPLOTSTS->RESV_FLAG_4 = MWIPLOTSTS_N->RESV_FLAG_4[0];
    MWIPLOTSTS->RESV_FLAG_5 = MWIPLOTSTS_N->RESV_FLAG_5[0];
}

