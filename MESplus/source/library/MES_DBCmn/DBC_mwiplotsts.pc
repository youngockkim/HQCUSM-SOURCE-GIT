                    NSTD_TIME,
                    REP_FLAG,
                    REP_RET_OPER,
                    STR_RET_FLOW,
                    STR_RET_FLOW_SEQ_NUM,
                    STR_RET_OPER,
                    START_FLAG,
                    START_TIME,
                    START_RES_ID,
                    END_FLAG,
                    END_TIME,
                    END_RES_ID,
                    SAMPLE_FLAG,
                    SAMPLE_WAIT_FLAG,
                    SAMPLE_RESULT,
                    FROM_TO_FLAG,
                    FROM_TO_LOT_ID,
                    SHIP_CODE,
                    SHIP_TIME,
                    ORG_DUE_TIME,
                    SCH_DUE_TIME,
                    CREATE_TIME,
                    FAC_IN_TIME,
                    FLOW_IN_TIME,
                    OPER_IN_TIME,
                    RESERVE_RES_ID,
                    PORT_ID,
                    BATCH_ID,
                    BATCH_SEQ,
                    ORDER_ID,
                    ADD_ORDER_ID_1,
                    ADD_ORDER_ID_2,
                    ADD_ORDER_ID_3,
                    LOT_LOCATION_1,
                    LOT_LOCATION_2,
                    LOT_LOCATION_3,
                    LOT_CMF_1,
                    LOT_CMF_2,
                    LOT_CMF_3,
                    LOT_CMF_4,
                    LOT_CMF_5,
                    LOT_CMF_6,
                    LOT_CMF_7,
                    LOT_CMF_8,
                    LOT_CMF_9,
                    LOT_CMF_10,
                    LOT_CMF_11,
                    LOT_CMF_12,
                    LOT_CMF_13,
                    LOT_CMF_14,
                    LOT_CMF_15,
                    LOT_CMF_16,
                    LOT_CMF_17,
                    LOT_CMF_18,
                    LOT_CMF_19,
                    LOT_CMF_20,
                    LOT_DEL_FLAG,
                    LOT_DEL_CODE,
                    LOT_DEL_TIME,
                    BOM_SET_ID,
                    BOM_SET_VERSION,
                    BOM_ACTIVE_HIST_SEQ,
                    BOM_HIST_SEQ,
                    LAST_TRAN_CODE,
                    LAST_TRAN_TIME,
                    LAST_COMMENT,
                    LAST_ACTIVE_HIST_SEQ,
                    LAST_HIST_SEQ,
                    CRITICAL_RES_ID,
                    CRITICAL_RES_GROUP_ID,
                    SAVE_RES_ID_1,
                    SAVE_RES_ID_2,
                    SUBRES_ID,
                    LOT_GROUP_ID_1,
                    LOT_GROUP_ID_2,
                    LOT_GROUP_ID_3,
                    YIELD_1,
                    YIELD_2,
                    YIELD_3,
                    GOOD_QTY,
                    RESV_FIELD_1,
                    RESV_FIELD_2,
                    RESV_FIELD_3,
                    RESV_FIELD_4,
                    RESV_FIELD_5,
                    RESV_FLAG_1,
                    RESV_FLAG_2,
                    RESV_FLAG_3,
                    RESV_FLAG_4,
                    RESV_FLAG_5
                FROM MWIPLOTSTS
                WHERE FACTORY = :MWIPLOTSTS_N.FACTORY
				  AND CREATE_CODE =  :MWIPLOTSTS_N.CREATE_CODE
				  AND LOT_DEL_FLAG = :MWIPLOTSTS_N.LOT_DEL_FLAG
	              AND CREATE_TIME >= :DBC_Q_COND_N.FROM_TIME 
	              AND CREATE_TIME <= :DBC_Q_COND_N.TO_TIME
                  AND OPER < :MWIPLOTSTS_N.OPER
                ORDER BY LOT_ID;
            EXEC SQL OPEN DBC_MWIPLOTSTS_CUR_201;
            break;

        case 202:
            EXEC SQL DECLARE DBC_MWIPLOTSTS_CUR_202 CURSOR FOR
                SELECT 
                    A.LOT_ID,
                    A.LOT_DESC,
                    A.FACTORY,
                    A.MAT_ID,
                    A.MAT_VER,
                    A.FLOW,
                    A.FLOW_SEQ_NUM,
                    A.OPER,
                    A.QTY_1,
                    A.QTY_2,
                    A.QTY_3,
                    A.CRR_ID,
                    A.LOT_TYPE,
                    A.OWNER_CODE,
                    A.CREATE_CODE,
                    A.LOT_PRIORITY,
                    A.LOT_STATUS,
                    A.HOLD_FLAG,
                    A.HOLD_CODE,
                    A.HOLD_PASSWORD,
                    A.HOLD_PRV_GRP_ID,
                    A.OPER_IN_QTY_1,
                    A.OPER_IN_QTY_2,
                    A.OPER_IN_QTY_3,
                    A.CREATE_QTY_1,
                    A.CREATE_QTY_2,
                    A.CREATE_QTY_3,
                    A.START_QTY_1,
                    A.START_QTY_2,
                    A.START_QTY_3,
                    A.INV_FLAG,
                    A.TRANSIT_FLAG,
                    A.UNIT_EXIST_FLAG,
                    A.INV_UNIT,
                    A.RWK_FLAG,
                    A.RWK_CODE,
                    A.RWK_COUNT,
                    A.RWK_RET_FLOW,
                    A.RWK_RET_FLOW_SEQ_NUM,
                    A.RWK_RET_OPER,
                    A.RWK_END_FLOW,
                    A.RWK_END_FLOW_SEQ_NUM,
                    A.RWK_END_OPER,
                    A.RWK_RET_CLEAR_FLAG,
                    A.RWK_TIME,
                    A.NSTD_FLAG,
                    A.NSTD_RET_FLOW,
                    A.NSTD_RET_FLOW_SEQ_NUM,
                    A.NSTD_RET_OPER,
                    A.NSTD_TIME,
                    A.REP_FLAG,
                    A.REP_RET_OPER,
                    A.STR_RET_FLOW,
                    A.STR_RET_FLOW_SEQ_NUM,
                    A.STR_RET_OPER,
                    A.START_FLAG,
                    A.START_TIME,
                    A.START_RES_ID,
                    A.END_FLAG,
                    A.END_TIME,
                    A.END_RES_ID,
                    A.SAMPLE_FLAG,
                    A.SAMPLE_WAIT_FLAG,
                    A.SAMPLE_RESULT,
                    A.FROM_TO_FLAG,
                    A.FROM_TO_LOT_ID,
                    A.SHIP_CODE,
                    A.SHIP_TIME,
                    A.ORG_DUE_TIME,
                    A.SCH_DUE_TIME,
                    A.CREATE_TIME,
                    A.FAC_IN_TIME,
                    A.FLOW_IN_TIME,
                    A.OPER_IN_TIME,
                    A.RESERVE_RES_ID,
                    A.PORT_ID,
                    A.BATCH_ID,
                    A.BATCH_SEQ,
                    A.ORDER_ID,
                    A.ADD_ORDER_ID_1,
                    A.ADD_ORDER_ID_2,
                    A.ADD_ORDER_ID_3,
                    A.LOT_LOCATION_1,
                    A.LOT_LOCATION_2,
                    A.LOT_LOCATION_3,
                    A.LOT_CMF_1,
                    A.LOT_CMF_2,
                    A.LOT_CMF_3,
                    A.LOT_CMF_4,
                    A.LOT_CMF_5,
                    A.LOT_CMF_6,
                    A.LOT_CMF_7,
                    A.LOT_CMF_8,
                    A.LOT_CMF_9,
                    A.LOT_CMF_10,
                    A.LOT_CMF_11,
                    A.LOT_CMF_12,
                    A.LOT_CMF_13,
                    A.LOT_CMF_14,
                    A.LOT_CMF_15,
                    A.LOT_CMF_16,
                    A.LOT_CMF_17,
                    A.LOT_CMF_18,
                    A.LOT_CMF_19,
                    A.LOT_CMF_20,
                    A.LOT_DEL_FLAG,
                    A.LOT_DEL_CODE,
                    B.SYS_TRAN_TIME AS LOT_DEL_TIME,
                    A.BOM_SET_ID,
                    A.BOM_SET_VERSION,
                    A.BOM_ACTIVE_HIST_SEQ,
                    A.BOM_HIST_SEQ,
                    A.LAST_TRAN_CODE,
                    A.LAST_TRAN_TIME,
                    A.LAST_COMMENT,
                    A.LAST_ACTIVE_HIST_SEQ,
                    A.LAST_HIST_SEQ,
                    A.CRITICAL_RES_ID,
                    A.CRITICAL_RES_GROUP_ID,
                    A.SAVE_RES_ID_1,
                    A.SAVE_RES_ID_2,
                    A.SUBRES_ID,
                    A.LOT_GROUP_ID_1,
                    A.LOT_GROUP_ID_2,
                    A.LOT_GROUP_ID_3,
                    A.YIELD_1,
                    A.YIELD_2,
                    A.YIELD_3,
                    A.GOOD_QTY,
                    A.RESV_FIELD_1,
                    A.RESV_FIELD_2,
                    A.RESV_FIELD_3,
                    A.RESV_FIELD_4,
                    A.RESV_FIELD_5,
                    A.RESV_FLAG_1,
                    A.RESV_FLAG_2,
                    A.RESV_FLAG_3,
                    A.RESV_FLAG_4,
                    A.RESV_FLAG_5
                FROM MWIPLOTSTS A, MWIPLOTHIS B
                WHERE A.FACTORY = :MWIPLOTSTS_N.FACTORY
				  AND A.CREATE_CODE =  :MWIPLOTSTS_N.CREATE_CODE
				  AND A.LOT_DEL_FLAG = :MWIPLOTSTS_N.LOT_DEL_FLAG
	              AND A.CREATE_TIME >= :DBC_Q_COND_N.FROM_TIME 
	              AND A.CREATE_TIME <= :DBC_Q_COND_N.TO_TIME
                  AND A.OPER < :MWIPLOTSTS_N.OPER
				  AND A.LOT_ID = B.LOT_ID
                  AND B.HIST_SEQ = A.LAST_HIST_SEQ
                ORDER BY A.LOT_ID;
            EXEC SQL OPEN DBC_MWIPLOTSTS_CUR_202;
            break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwiplotsts", sel_type);
}


