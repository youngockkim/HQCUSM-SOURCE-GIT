		case 101:
            EXEC SQL CLOSE DBC_MWIPLOTSTS_CUR_101;
            break;

		case 102:
            EXEC SQL CLOSE DBC_MWIPLOTSTS_CUR_102;
            break;

		case 103:
            EXEC SQL CLOSE DBC_MWIPLOTSTS_CUR_103;
            break;

		case 104:
