            {
                make_valid_quote(ts1, MWIPLOTSTS_N.OPER);
                sprintf(sql + strlen(sql), "AND OPER = '%s' ", ts1);
            }
            else
            {
                make_valid_quote(ts1, MWIPLOTSTS_N.FACTORY);
                sprintf(sql + strlen(sql), "AND OPER IN ( SELECT DISTINCT OPER FROM MRASRESMFO WHERE FACTORY = '%s'  ", ts1);

