            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwiplotsts(&MWIPLOTSTS_N, MWIPLOTSTS);
    }
    DB_stop_query_timer("DBC_fetch_mwiplotsts", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwiplotsts(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
            
        case 1:
            EXEC SQL CLOSE DBC_MWIPLOTSTS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWIPLOTSTS_CUR_2;
            break;
            
        case 3:
            EXEC SQL CLOSE DBC_MWIPLOTSTS_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MWIPLOTSTS_CUR_4;
