                FROM MWIPLOTSTS
                WHERE LOT_ID >= :MWIPLOTSTS_N.LOT_ID
                AND LOT_DEL_FLAG = :MWIPLOTSTS_N.LOT_DEL_FLAG 
                AND FACTORY = :MWIPLOTSTS_N.FACTORY
                AND (START_RES_ID = :MWIPLOTSTS_N.START_RES_ID OR START_RES_ID = ' ')
                AND OPER = :MWIPLOTSTS_N.OPER 
                ORDER BY OPER, LOT_STATUS, LOT_PRIORITY, OPER_IN_TIME;
            EXEC SQL OPEN DBC_MWIPLOTSTS_CUR_9;
            break;

