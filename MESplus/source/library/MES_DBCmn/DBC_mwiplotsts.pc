//void LOG_head(void *);
//void COM_log_write(char, char, char);
/* SQL UPDATE Function */
void DBC_update_mwiplotsts(int sel_type, struct MWIPLOTSTS_TAG *MWIPLOTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTSTS_N_TAG MWIPLOTSTS_N;
        struct MWIPLOTSTS_TAG   MWIPLOTSTS_S;
        char   sql[10000];
        char   ts[1000];
        char   bind_vars[200][1001];
        int index;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();



    DBC_add_null_mwiplotsts(&MWIPLOTSTS_N, MWIPLOTSTS);
    DB_error_code = 0;
    memset(sql, 0x00, sizeof(sql));
    memset(ts, 0x00, sizeof(ts));

    switch(sel_type)
    {
        case 1:
            DBC_init_mwiplotsts(&MWIPLOTSTS_S);
            memcpy(MWIPLOTSTS_S.LOT_ID, MWIPLOTSTS->LOT_ID, sizeof(MWIPLOTSTS_S.LOT_ID));
            DBC_select_mwiplotsts(1, &MWIPLOTSTS_S);
            if(DB_error_code != DB_SUCCESS) break;

            index = 0;
            make_valid_quote(bind_vars[index], MWIPLOTSTS_N.LOT_ID);
            sprintf(sql, "UPDATE MWIPLOTSTS SET LOT_ID=:%d", index++);

            if(memcmp(MWIPLOTSTS->LOT_DESC, MWIPLOTSTS_S.LOT_DESC, sizeof(MWIPLOTSTS->LOT_DESC)) != 0) {
                make_valid_quote(bind_vars[index], MWIPLOTSTS_N.LOT_DESC);
                sprintf(sql + strlen(sql), ", LOT_DESC=:%d", index++);
            }
            if(memcmp(MWIPLOTSTS->FACTORY, MWIPLOTSTS_S.FACTORY, sizeof(MWIPLOTSTS->FACTORY)) != 0) {
                make_valid_quote(bind_vars[index], MWIPLOTSTS_N.FACTORY);
                sprintf(sql + strlen(sql), ", FACTORY=:%d", index++);
            }
            if(memcmp(MWIPLOTSTS->MAT_ID, MWIPLOTSTS_S.MAT_ID, sizeof(MWIPLOTSTS->MAT_ID)) != 0) {
                make_valid_quote(bind_vars[index], MWIPLOTSTS_N.MAT_ID);
                sprintf(sql + strlen(sql), ", MAT_ID=:%d", index++);
            }
            if(MWIPLOTSTS->MAT_VER != MWIPLOTSTS_S.MAT_VER) {
                sprintf(bind_vars[index], "%d\0", MWIPLOTSTS_N.MAT_VER);
                sprintf(sql + strlen(sql), ", MAT_VER=:%d", index++);
            }
            if(memcmp(MWIPLOTSTS->FLOW, MWIPLOTSTS_S.FLOW, sizeof(MWIPLOTSTS->FLOW)) != 0) {
                make_valid_quote(bind_vars[index], MWIPLOTSTS_N.FLOW);
                sprintf(sql + strlen(sql), ", FLOW=:%d", index++);
