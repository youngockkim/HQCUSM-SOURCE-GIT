/* SQL SELECT_SCALAR Function */
double DBC_select_mwiplotsts_scalar(int sel_type, struct MWIPLOTSTS_TAG *MWIPLOTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTSTS_N_TAG MWIPLOTSTS_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    

    DBC_add_null_mwiplotsts(&MWIPLOTSTS_N, MWIPLOTSTS);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTSTS
                WHERE FACTORY = :MWIPLOTSTS_N.FACTORY
                AND MAT_ID = :MWIPLOTSTS_N.MAT_ID
                AND MAT_VER = :MWIPLOTSTS_N.MAT_VER
                AND LOT_DEL_FLAG = :MWIPLOTSTS_N.LOT_DEL_FLAG;
            break;
        case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTSTS
                WHERE FACTORY = :MWIPLOTSTS_N.FACTORY
                AND FLOW = :MWIPLOTSTS_N.FLOW
                AND LOT_DEL_FLAG = :MWIPLOTSTS_N.LOT_DEL_FLAG;
            break;
        case 3:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTSTS
                WHERE FACTORY = :MWIPLOTSTS_N.FACTORY
                AND OPER = :MWIPLOTSTS_N.OPER
                AND LOT_DEL_FLAG = :MWIPLOTSTS_N.LOT_DEL_FLAG;
            break;

        case 4:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTSTS
                WHERE FACTORY = :MWIPLOTSTS_N.FACTORY
                AND FLOW = :MWIPLOTSTS_N.FLOW
                AND OPER = :MWIPLOTSTS_N.OPER
                AND LOT_DEL_FLAG = :MWIPLOTSTS_N.LOT_DEL_FLAG;
            break;                              
        case 5:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTSTS
                WHERE FACTORY = :MWIPLOTSTS_N.FACTORY
                AND LOT_DEL_FLAG = :MWIPLOTSTS_N.LOT_DEL_FLAG;
            break;

        case 6:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTSTS
                WHERE FACTORY = :MWIPLOTSTS_N.FACTORY
                AND MAT_ID = :MWIPLOTSTS_N.MAT_ID
                AND MAT_VER = :MWIPLOTSTS_N.MAT_VER
                AND FLOW = :MWIPLOTSTS_N.FLOW
                AND RWK_FLAG = :MWIPLOTSTS_N.RWK_FLAG
                AND NSTD_FLAG = :MWIPLOTSTS_N.NSTD_FLAG
                AND LOT_DEL_FLAG = :MWIPLOTSTS_N.LOT_DEL_FLAG;
            break;     

        case 7:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTSTS
                WHERE FACTORY = :MWIPLOTSTS_N.FACTORY
                AND START_RES_ID = :MWIPLOTSTS_N.START_RES_ID
                AND START_FLAG = :MWIPLOTSTS_N.START_FLAG
                AND LOT_DEL_FLAG = :MWIPLOTSTS_N.LOT_DEL_FLAG;
            break;     

        case 8:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTSTS
                WHERE FACTORY = :MWIPLOTSTS_N.FACTORY
                AND RESERVE_RES_ID = :MWIPLOTSTS_N.RESERVE_RES_ID
                AND LOT_STATUS = :MWIPLOTSTS_N.LOT_STATUS
                AND LOT_DEL_FLAG = :MWIPLOTSTS_N.LOT_DEL_FLAG;
            break;     

        case 9:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTSTS
                WHERE FACTORY = :MWIPLOTSTS_N.FACTORY
                AND MAT_ID = :MWIPLOTSTS_N.MAT_ID
                AND MAT_VER = :MWIPLOTSTS_N.MAT_VER
                AND FLOW = :MWIPLOTSTS_N.FLOW
                AND FLOW_SEQ_NUM = :MWIPLOTSTS_N.FLOW_SEQ_NUM
                AND LOT_DEL_FLAG = :MWIPLOTSTS_N.LOT_DEL_FLAG;
            break;     

        case 10:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTSTS
                WHERE FACTORY = :MWIPLOTSTS_N.FACTORY
                AND MAT_ID = :MWIPLOTSTS_N.MAT_ID
                AND MAT_VER = :MWIPLOTSTS_N.MAT_VER
                AND FLOW = :MWIPLOTSTS_N.FLOW
                AND LOT_DEL_FLAG = :MWIPLOTSTS_N.LOT_DEL_FLAG;
            break;     


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mwiplotsts_scalar", sel_type);
    return d_value;
}


/* SQL DELETE Function */
void DBC_delete_mwiplotsts(int sel_type, struct MWIPLOTSTS_TAG *MWIPLOTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTSTS_N_TAG MWIPLOTSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplotsts(&MWIPLOTSTS_N, MWIPLOTSTS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM MWIPLOTSTS
                WHERE LOT_ID = :MWIPLOTSTS_N.LOT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_delete_mwiplotsts", sel_type);
}


