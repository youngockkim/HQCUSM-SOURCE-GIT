            }
            if(memcmp(MWIPLOTSTS->OPER, MWIPLOTSTS_S.OPER, sizeof(MWIPLOTSTS->OPER)) != 0) {
                make_valid_quote(bind_vars[index], MWIPLOTSTS_N.OPER);
