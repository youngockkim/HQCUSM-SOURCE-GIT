				LOG_head("DB");
				LOG_add("len", 0, strlen(sql));
				LOG_add("sql", 4, strlen(sql), sql);
				COM_log_write('I', 'S' , 'S');
            break;

		case 109:
		        memset( sql, 0x00, sizeof(sql));
				sprintf(sql , "SELECT L.FACTORY   ");
				sprintf(sql + strlen(sql), ",NVL(L.OPER,' ')  AS OPER  ");
				sprintf(sql + strlen(sql), ",NVL(D.OPER_DESC,' ')  AS LOT_CMF_8  ");
				sprintf(sql + strlen(sql), ",NVL(R.RES_CMF_1,' ') AS LOT_CMF_1 ");
				sprintf(sql + strlen(sql), ",NVL(L.MAT_ID,' ')     AS MAT_ID "); 
				sprintf(sql + strlen(sql), ",NVL(M.MAT_DESC,' ')  AS LOT_CMF_2 ");
				sprintf(sql + strlen(sql), ",NVL(R.RES_ID,' ')   AS END_RES_ID   ");
				sprintf(sql + strlen(sql), ",NVL(T.GRANDING_PORT_NO,' ')  AS LOT_CMF_3   ");
				sprintf(sql + strlen(sql), ",NVL(T.TRAN_TIME,' ')  AS LAST_TRAN_TIME");
				sprintf(sql + strlen(sql), ",NVL(ROUND((SYSDATE - TO_DATE(T.TRAN_TIME,'YYYYMMDDHH24MISS')) *24,2), 0) AS LOT_CMF_4");
				sprintf(sql + strlen(sql), ",NVL(T.LOT_ID,' ') AS LOT_ID   ");
				sprintf(sql + strlen(sql), ",NVL(T.CMF_3,' ') AS LOT_CMF_5 ");
				sprintf(sql + strlen(sql), ",NVL(T.CMF_4, C.GRADE) AS LOT_CMF_6");
				sprintf(sql + strlen(sql), ",NVL(T.CMF_5, C.POWER) AS LOT_CMF_7 ");
				sprintf(sql + strlen(sql), ",NVL(L.HOLD_CODE,' ') AS HOLD_CODE ");
				sprintf(sql + strlen(sql), ",NVL(E.REQ_NO,' ') AS LOT_CMF_9 ");
				sprintf(sql + strlen(sql), "FROM MWIPLOTSTS L   ");
				make_valid_quote(ts1, MWIPLOTSTS_N.FACTORY);                                         
				sprintf(sql + strlen(sql), "INNER JOIN CWIPTRPHIS T ON L.FACTORY ='%s' AND L.LOT_ID = T.LOT_ID  ",ts1);
				sprintf(sql + strlen(sql), "INNER JOIN MRASRESDEF R ON R.FACTORY ='%s' AND T.RES_ID = R.RES_ID  ",ts1);
				sprintf(sql + strlen(sql), "INNER JOIN MWIPMATDEF M ON M.FACTORY ='%s' AND T.CMF_2 = M.MAT_ID   ",ts1);
				sprintf(sql + strlen(sql), "INNER JOIN CEDCLOTRLT C ON C.FACTORY ='%s' AND T.LOT_ID = C.LOT_ID AND C.INS_TYPE ='FC' ",ts1);
				sprintf(sql + strlen(sql), "INNER JOIN MWIPOPRDEF D ON L.FACTORY = D.FACTORY AND L.OPER = D.OPER ");
				sprintf(sql + strlen(sql), "LEFT OUTER JOIN ( SELECT A.FACTORY, A.REQ_NO ,A.REQ_TYPE ,A.REQ_STATUS ,B.LOT_ID  ");
				sprintf(sql + strlen(sql), " FROM CWIPREQMST A ");
				sprintf(sql + strlen(sql), " INNER JOIN CWIPREQDTL B ON A.FACTORY = B.FACTORY AND A.REQ_NO = B.REQ_NO AND A.REQ_STATUS = 'REQUEST') ");
				sprintf(sql + strlen(sql), " E ON L.FACTORY = E.FACTORY AND L.LOT_ID  = E.LOT_ID  ");

				//sprintf(sql + strlen(sql), "LEFT OUTER JOIN CWIPREQMST MST ON E.FACTORY = MST.FACTORY AND MST.REQ_NO  = E.REQ_NO ");
				sprintf(sql + strlen(sql), " WHERE L.FACTORY = '%s' ", ts1);

				if(ISSPACE(MWIPLOTSTS->LOT_CMF_1, sizeof(MWIPLOTSTS->LOT_CMF_1)) == DB_FALSE)
				{
					make_valid_quote(ts1, MWIPLOTSTS_N.LOT_CMF_1); /*LINE*/
					sprintf(sql + strlen(sql), " AND R.RES_CMF_1 = '%s' ", ts1); 
				}

				if(ISSPACE(MWIPLOTSTS->OPER, sizeof(MWIPLOTSTS->OPER)) == DB_FALSE)
				{
					make_valid_quote(ts1, MWIPLOTSTS_N.OPER);
					sprintf(sql + strlen(sql), " AND L.OPER ='%s' ",ts1);
				}

				if(ISSPACE(MWIPLOTSTS->MAT_ID, sizeof(MWIPLOTSTS->MAT_ID)) == DB_FALSE)
				{
					make_valid_quote(ts1, MWIPLOTSTS_N.MAT_ID);
					sprintf(sql + strlen(sql), " AND T.CMF_2  ='%s' ",ts1);
				}

				if(ISSPACE(MWIPLOTSTS->LOT_CMF_6, sizeof(MWIPLOTSTS->LOT_CMF_6)) == DB_FALSE)
				{
					make_valid_quote(ts1, MWIPLOTSTS_N.LOT_CMF_6); /*GRADE*/
					sprintf(sql + strlen(sql), " AND T.CMF_4  ='%s' ", ts1);
				}

				if(ISSPACE(MWIPLOTSTS->LOT_CMF_7, sizeof(MWIPLOTSTS->LOT_CMF_7)) == DB_FALSE)
				{
					make_valid_quote(ts1, MWIPLOTSTS_N.LOT_CMF_7); /*POWER*/
					sprintf(sql + strlen(sql), " AND T.CMF_5  ='%s' ", ts1);
				}

				if(ISSPACE(MWIPLOTSTS->END_RES_ID, sizeof(MWIPLOTSTS->END_RES_ID)) == DB_FALSE)
				{
					make_valid_quote(ts1, MWIPLOTSTS_N.END_RES_ID); /*Ľłşń*/
					sprintf(sql + strlen(sql), " AND T.RES_ID  ='%s' ", ts1);
				}

				if(ISSPACE(MWIPLOTSTS->LOT_CMF_3, sizeof(MWIPLOTSTS->LOT_CMF_3)) == DB_FALSE)
				{
					make_valid_quote(ts1, MWIPLOTSTS_N.LOT_CMF_3); /*PORT*/
					sprintf(sql + strlen(sql), " AND T.GRANDING_PORT_NO  ='%s' ", ts1);
				}

				if(ISSPACE(MWIPLOTSTS->HOLD_CODE, sizeof(MWIPLOTSTS->HOLD_CODE)) == DB_FALSE)
				{
					make_valid_quote(ts1, MWIPLOTSTS_N.HOLD_CODE); /*HOLD_CODE*/
