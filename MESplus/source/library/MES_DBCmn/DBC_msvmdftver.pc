            EXEC SQL AT:OraConnName DELETE FROM MSVMDFTVER
                WHERE LIB_NAME = :MSVMDFTVER_N.LIB_NAME
                    AND LIB_VER = :MSVMDFTVER_N.LIB_VER
                    AND SERVICE_NAME = :MSVMDFTVER_N.SERVICE_NAME;
