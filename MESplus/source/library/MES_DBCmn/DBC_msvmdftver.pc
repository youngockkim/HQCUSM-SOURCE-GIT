/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_msvmdftver(int sel_type, struct MSVMDFTVER_TAG *MSVMDFTVER)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSVMDFTVER_N_TAG MSVMDFTVER_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_msvmdftver(&MSVMDFTVER_N, MSVMDFTVER);
    DB_error_code = 0;
    
    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSVMDFTVER_CUR_1 CURSOR FOR
                SELECT 
                    LIB_NAME,
                    LIB_VER,
                    SERVICE_NAME,
                    SERVICE_VER,
                    LOAD_ONLY_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MSVMDFTVER
                WHERE LIB_NAME = :MSVMDFTVER_N.LIB_NAME
                    AND LIB_VER = :MSVMDFTVER_N.LIB_VER
                ORDER BY SERVICE_NAME ASC, SERVICE_VER ASC;
            EXEC SQL OPEN DBC_MSVMDFTVER_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MSVMDFTVER_CUR_2 CURSOR FOR
                SELECT LIB_NAME, 
                       LIB_VER, 
                       SERVICE_NAME, 
                       SERVICE_VER, 
                       LOAD_ONLY_FLAG, 
                       CREATE_USER_ID, 
                       CREATE_TIME, 
                       UPDATE_USER_ID, 
                       UPDATE_TIME
                FROM (
                    SELECT A.*, ROWNUM
                    FROM (
                        SELECT 
                            LIB_NAME,
                            LIB_VER,
                            SERVICE_NAME,
                            SERVICE_VER,
                            LOAD_ONLY_FLAG,
                            CREATE_USER_ID,
                            CREATE_TIME,
                            UPDATE_USER_ID,
                            UPDATE_TIME
                        FROM MSVMDFTVER
                        WHERE ROWID <= :MSVMDFTVER_N.CREATE_USER_ID
                            AND LIB_NAME LIKE '%' ||  :MSVMDFTVER_N.LIB_NAME || '%'
                            AND LIB_VER LIKE '%' ||  :MSVMDFTVER_N.LIB_VER || '%'
                            AND SERVICE_NAME = ' '
                            AND SERVICE_VER = 0
                            AND LOAD_ONLY_FLAG LIKE :MSVMDFTVER_N.LOAD_ONLY_FLAG
                        ORDER BY LIB_NAME ASC, LIB_VER ASC, SERVICE_NAME ASC, SERVICE_VER ASC
                        ) A
                    )
                WHERE ROWNUM >= :MSVMDFTVER_N.SERVICE_VER;

            EXEC SQL OPEN DBC_MSVMDFTVER_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MSVMDFTVER_CUR_3 CURSOR FOR
                SELECT LIB_NAME, 
                       LIB_VER, 
                       SERVICE_NAME, 
                       SERVICE_VER, 
                       LOAD_ONLY_FLAG, 
                       CREATE_USER_ID, 
                       CREATE_TIME, 
                       UPDATE_USER_ID, 
                       UPDATE_TIME
                FROM (
                    SELECT A.*, ROWNUM
                    FROM (
                        SELECT 
                            LIB_NAME,
                            LIB_VER,
                            SERVICE_NAME,
                            SERVICE_VER,
                            LOAD_ONLY_FLAG,
                            CREATE_USER_ID,
                            CREATE_TIME,
                            UPDATE_USER_ID,
                            UPDATE_TIME
                        FROM MSVMDFTVER
                        WHERE ROWID <= :MSVMDFTVER_N.CREATE_USER_ID
                            AND LIB_NAME LIKE '%' ||  :MSVMDFTVER_N.LIB_NAME || '%'
                            AND LIB_VER LIKE '%' ||  :MSVMDFTVER_N.LIB_VER || '%'
                            AND SERVICE_NAME LIKE '%' ||  :MSVMDFTVER_N.SERVICE_NAME || '%'
                            AND SERVICE_VER LIKE '%' ||  :MSVMDFTVER_N.CREATE_TIME || '%'
                            AND SERVICE_NAME <> ' '
                            AND SERVICE_VER > 0
                        ORDER BY LIB_NAME ASC, LIB_VER ASC, SERVICE_NAME ASC, SERVICE_VER ASC
                        ) A
                    )
                WHERE ROWNUM >= :MSVMDFTVER_N.SERVICE_VER;

            EXEC SQL OPEN DBC_MSVMDFTVER_CUR_3;
            break;
            
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_msvmdftver", sel_type);
}


