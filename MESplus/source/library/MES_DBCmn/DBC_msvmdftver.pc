/* Add Null Function */
void DBC_add_null_msvmdftver(struct MSVMDFTVER_N_TAG *MSVMDFTVER_N, struct MSVMDFTVER_TAG *MSVMDFTVER)
{
    /* memset by NULL */
    memset(MSVMDFTVER_N, '\0', sizeof(struct MSVMDFTVER_N_TAG));
    
    MEMCPY_AN(MSVMDFTVER_N->LIB_NAME, MSVMDFTVER->LIB_NAME, sizeof(MSVMDFTVER->LIB_NAME));
    MEMCPY_AN(MSVMDFTVER_N->LIB_VER, MSVMDFTVER->LIB_VER, sizeof(MSVMDFTVER->LIB_VER));
    MEMCPY_AN(MSVMDFTVER_N->SERVICE_NAME, MSVMDFTVER->SERVICE_NAME, sizeof(MSVMDFTVER->SERVICE_NAME));
    MSVMDFTVER_N->SERVICE_VER = MSVMDFTVER->SERVICE_VER;
    MSVMDFTVER_N->LOAD_ONLY_FLAG[0] = MSVMDFTVER->LOAD_ONLY_FLAG;
    MEMCPY_AN(MSVMDFTVER_N->CREATE_USER_ID, MSVMDFTVER->CREATE_USER_ID, sizeof(MSVMDFTVER->CREATE_USER_ID));
    MEMCPY_AN(MSVMDFTVER_N->CREATE_TIME, MSVMDFTVER->CREATE_TIME, sizeof(MSVMDFTVER->CREATE_TIME));
    MEMCPY_AN(MSVMDFTVER_N->UPDATE_USER_ID, MSVMDFTVER->UPDATE_USER_ID, sizeof(MSVMDFTVER->UPDATE_USER_ID));
    MEMCPY_AN(MSVMDFTVER_N->UPDATE_TIME, MSVMDFTVER->UPDATE_TIME, sizeof(MSVMDFTVER->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_msvmdftver(struct MSVMDFTVER_N_TAG *MSVMDFTVER_N, struct MSVMDFTVER_TAG *MSVMDFTVER)
{
    MEMCPY_DN(MSVMDFTVER->LIB_NAME, MSVMDFTVER_N->LIB_NAME, sizeof(MSVMDFTVER->LIB_NAME));
    MEMCPY_DN(MSVMDFTVER->LIB_VER, MSVMDFTVER_N->LIB_VER, sizeof(MSVMDFTVER->LIB_VER));
    MEMCPY_DN(MSVMDFTVER->SERVICE_NAME, MSVMDFTVER_N->SERVICE_NAME, sizeof(MSVMDFTVER->SERVICE_NAME));
    MSVMDFTVER->SERVICE_VER = MSVMDFTVER_N->SERVICE_VER;
    MSVMDFTVER->LOAD_ONLY_FLAG = MSVMDFTVER_N->LOAD_ONLY_FLAG[0];
    MEMCPY_DN(MSVMDFTVER->CREATE_USER_ID, MSVMDFTVER_N->CREATE_USER_ID, sizeof(MSVMDFTVER->CREATE_USER_ID));
    MEMCPY_DN(MSVMDFTVER->CREATE_TIME, MSVMDFTVER_N->CREATE_TIME, sizeof(MSVMDFTVER->CREATE_TIME));
    MEMCPY_DN(MSVMDFTVER->UPDATE_USER_ID, MSVMDFTVER_N->UPDATE_USER_ID, sizeof(MSVMDFTVER->UPDATE_USER_ID));
    MEMCPY_DN(MSVMDFTVER->UPDATE_TIME, MSVMDFTVER_N->UPDATE_TIME, sizeof(MSVMDFTVER->UPDATE_TIME));
}


