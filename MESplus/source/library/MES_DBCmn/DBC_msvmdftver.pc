        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    gc_by_mconn_query = 'N';

    DB_stop_query_timer("DBC_delete_msvmdftver", sel_type);
}

