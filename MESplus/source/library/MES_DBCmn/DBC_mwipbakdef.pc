/* SQL CURSOR CLOSE Function */
void DBC_close_mwipbakdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPBAKDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWIPBAKDEF_CUR_2;
            break;
        case 3:
            EXEC SQL CLOSE DBC_MWIPBAKDEF_CUR_3;
            break;
        case 4:
            EXEC SQL CLOSE DBC_MWIPBAKDEF_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipbakdef", sel_type);
}


/* Initialize Function */
void DBC_init_mwipbakdef(struct MWIPBAKDEF_TAG *MWIPBAKDEF)
{
    /* memset by Space */
    memset(MWIPBAKDEF, ' ', sizeof(struct MWIPBAKDEF_TAG));
    
    MWIPBAKDEF->MAT_VER = 0;
}


/* Add Null Function */
void DBC_add_null_mwipbakdef(struct MWIPBAKDEF_N_TAG *MWIPBAKDEF_N, struct MWIPBAKDEF_TAG *MWIPBAKDEF)
{
    /* memset by NULL */
    memset(MWIPBAKDEF_N, '\0', sizeof(struct MWIPBAKDEF_N_TAG));
    
    MEMCPY_AN(MWIPBAKDEF_N->FACTORY, MWIPBAKDEF->FACTORY, sizeof(MWIPBAKDEF->FACTORY));
    MEMCPY_AN(MWIPBAKDEF_N->MAT_ID, MWIPBAKDEF->MAT_ID, sizeof(MWIPBAKDEF->MAT_ID));
    MWIPBAKDEF_N->MAT_VER = MWIPBAKDEF->MAT_VER;
    MEMCPY_AN(MWIPBAKDEF_N->FLOW, MWIPBAKDEF->FLOW, sizeof(MWIPBAKDEF->FLOW));
    MEMCPY_AN(MWIPBAKDEF_N->OPER, MWIPBAKDEF->OPER, sizeof(MWIPBAKDEF->OPER));
    MWIPBAKDEF_N->BATCH_KEEP_FLAG[0] = MWIPBAKDEF->BATCH_KEEP_FLAG;
    MEMCPY_AN(MWIPBAKDEF_N->CMF_1, MWIPBAKDEF->CMF_1, sizeof(MWIPBAKDEF->CMF_1));
