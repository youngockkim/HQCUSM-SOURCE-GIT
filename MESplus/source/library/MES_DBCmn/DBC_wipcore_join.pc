    CRR_LOT_LIST->CRR1_QTY_1 = CRR_LOT_LIST_N->CRR1_QTY_1;
    CRR_LOT_LIST->CRR1_QTY_2 = CRR_LOT_LIST_N->CRR1_QTY_2;
    CRR_LOT_LIST->CRR1_QTY_3 = CRR_LOT_LIST_N->CRR1_QTY_3;
    CRR_LOT_LIST->CRR2_QTY_1 = CRR_LOT_LIST_N->CRR2_QTY_1;
