/* Del Null Function */
void DBC_del_null_crr_lot_list(struct CRR_LOT_LIST_N_TAG *CRR_LOT_LIST_N, struct CRR_LOT_LIST_TAG *CRR_LOT_LIST)
{
    MEMCPY_DN(CRR_LOT_LIST->FACTORY, CRR_LOT_LIST_N->FACTORY, sizeof(CRR_LOT_LIST->FACTORY));
