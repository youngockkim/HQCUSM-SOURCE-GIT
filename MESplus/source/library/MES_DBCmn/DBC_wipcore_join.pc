                :GET_CYCLETIME_N.PROC_TIME,
                :GET_CYCLETIME_N.HPU_FLAG,
                :GET_CYCLETIME_N.HPU_PROC_TIME,
                :GET_CYCLETIME_N.UPH_FLAG,
                :GET_CYCLETIME_N.UPH_PROC_TIME,
                :GET_CYCLETIME_N.CREATE_USER_ID,
