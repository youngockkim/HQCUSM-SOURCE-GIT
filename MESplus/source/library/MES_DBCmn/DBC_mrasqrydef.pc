    MEMCPY_AN(MRASQRYDEF_N->SHEET_DATA, MRASQRYDEF->SHEET_DATA, sizeof(MRASQRYDEF->SHEET_DATA));
    MRASQRYDEF_N->RESULT_TYPE[0] = MRASQRYDEF->RESULT_TYPE;
    MEMCPY_AN(MRASQRYDEF_N->CHECK_VALUE, MRASQRYDEF->CHECK_VALUE, sizeof(MRASQRYDEF->CHECK_VALUE));
    MEMCPY_AN(MRASQRYDEF_N->UPDATE_USER_ID, MRASQRYDEF->UPDATE_USER_ID, sizeof(MRASQRYDEF->UPDATE_USER_ID));
    MEMCPY_AN(MRASQRYDEF_N->UPDATE_TIME, MRASQRYDEF->UPDATE_TIME, sizeof(MRASQRYDEF->UPDATE_TIME));
    MEMCPY_AN(MRASQRYDEF_N->CREATE_USER_ID, MRASQRYDEF->CREATE_USER_ID, sizeof(MRASQRYDEF->CREATE_USER_ID));
    MEMCPY_AN(MRASQRYDEF_N->CREATE_TIME, MRASQRYDEF->CREATE_TIME, sizeof(MRASQRYDEF->CREATE_TIME));
    MEMCPY_AN(MRASQRYDEF_N->RESV_FIELD1, MRASQRYDEF->RESV_FIELD1, sizeof(MRASQRYDEF->RESV_FIELD1));
