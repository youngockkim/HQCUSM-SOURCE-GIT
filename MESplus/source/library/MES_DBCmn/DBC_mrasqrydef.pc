/* Add Null Function */
void DBC_add_null_mrasqrydef(struct MRASQRYDEF_N_TAG *MRASQRYDEF_N, struct MRASQRYDEF_TAG *MRASQRYDEF)
{
    /* memset by NULL */
    memset(MRASQRYDEF_N, '\0', sizeof(struct MRASQRYDEF_N_TAG));
    
    MEMCPY_AN(MRASQRYDEF_N->FACTORY, MRASQRYDEF->FACTORY, sizeof(MRASQRYDEF->FACTORY));
    MEMCPY_AN(MRASQRYDEF_N->DATA_CODE, MRASQRYDEF->DATA_CODE, sizeof(MRASQRYDEF->DATA_CODE));
