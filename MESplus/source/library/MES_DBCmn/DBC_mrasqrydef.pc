/* Del Null Function */
void DBC_del_null_mrasqrydef(struct MRASQRYDEF_N_TAG *MRASQRYDEF_N, struct MRASQRYDEF_TAG *MRASQRYDEF)
{
    MEMCPY_DN(MRASQRYDEF->FACTORY, MRASQRYDEF_N->FACTORY, sizeof(MRASQRYDEF->FACTORY));
