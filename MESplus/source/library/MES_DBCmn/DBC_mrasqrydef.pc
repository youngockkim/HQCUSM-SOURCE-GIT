/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrasqrydef(int sel_type, struct MRASQRYDEF_TAG *MRASQRYDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASQRYDEF_N_TAG MRASQRYDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrasqrydef(&MRASQRYDEF_N, MRASQRYDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRASQRYDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    DATA_CODE,
                    DATA_TYPE,
                    SHEET_DATA,
                    RESULT_TYPE,
                    CHECK_VALUE,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                FROM MRASQRYDEF
                ORDER BY FACTORY ASC,
                    DATA_CODE ASC;
            EXEC SQL OPEN DBC_MRASQRYDEF_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MRASQRYDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    DATA_CODE,
                    DATA_TYPE,
                    SHEET_DATA,
                    RESULT_TYPE,
                    CHECK_VALUE,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                  FROM MRASQRYDEF 
                 WHERE FACTORY = :MRASQRYDEF_N.FACTORY
                   AND DATA_CODE >= :MRASQRYDEF_N.DATA_CODE
                 ORDER BY DATA_CODE ASC;
            EXEC SQL OPEN DBC_MRASQRYDEF_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MRASQRYDEF_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    DATA_CODE,
                    DATA_TYPE,
                    SHEET_DATA,
                    RESULT_TYPE,
                    CHECK_VALUE,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                  FROM MRASQRYDEF 
                 WHERE FACTORY = :MRASQRYDEF_N.FACTORY
                   AND DATA_TYPE = :MRASQRYDEF_N.DATA_TYPE
                   AND DATA_CODE >= :MRASQRYDEF_N.DATA_CODE
                 ORDER BY DATA_CODE ASC;
            EXEC SQL OPEN DBC_MRASQRYDEF_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrasqrydef", sel_type);
}


