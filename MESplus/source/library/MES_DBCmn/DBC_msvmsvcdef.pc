        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_msvmsvcdef(&MSVMSVCDEF_N, MSVMSVCDEF);
    }
    DB_stop_query_timer("DBC_fetch_msvmsvcdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_msvmsvcdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MSVMSVCDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MSVMSVCDEF_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MSVMSVCDEF_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MSVMSVCDEF_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MSVMSVCDEF_CUR_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_msvmsvcdef", sel_type);
}


/* Initialize Function */
void DBC_init_msvmsvcdef(struct MSVMSVCDEF_TAG *MSVMSVCDEF)
{
    /* memset by Space */
    memset(MSVMSVCDEF, ' ', sizeof(struct MSVMSVCDEF_TAG));
    
}


/* Add Null Function */
void DBC_add_null_msvmsvcdef(struct MSVMSVCDEF_N_TAG *MSVMSVCDEF_N, struct MSVMSVCDEF_TAG *MSVMSVCDEF)
{
    /* memset by NULL */
    memset(MSVMSVCDEF_N, '\0', sizeof(struct MSVMSVCDEF_N_TAG));
    
    MEMCPY_AN(MSVMSVCDEF_N->MODULE_NAME, MSVMSVCDEF->MODULE_NAME, sizeof(MSVMSVCDEF->MODULE_NAME));
    MEMCPY_AN(MSVMSVCDEF_N->SERVICE_NAME, MSVMSVCDEF->SERVICE_NAME, sizeof(MSVMSVCDEF->SERVICE_NAME));
    MEMCPY_AN(MSVMSVCDEF_N->SERVICE_MODE, MSVMSVCDEF->SERVICE_MODE, sizeof(MSVMSVCDEF->SERVICE_MODE));
