/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_msvmsvcdef(int sel_type, struct MSVMSVCDEF_TAG *MSVMSVCDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSVMSVCDEF_N_TAG MSVMSVCDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_msvmsvcdef(&MSVMSVCDEF_N, MSVMSVCDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSVMSVCDEF_CUR_1 CURSOR FOR
                SELECT 
                    SERVICE_NAME,
                    MODULE_NAME,
                    SERVICE_MODE,
                    SERVICE_CATEGORY,
                    SERVICE_TYPE,
                    SERVICE_DESC_1,
                    SERVICE_DESC_2,
                    SERVICE_DESC_3,
                    SEC_CHK_FLAG,
                    LOG_LEVEL,
                    SHARED_LIB_NAME,
                    SERVICE_CMF_1,
                    SERVICE_CMF_2,
                    SERVICE_CMF_3,
                    SERVICE_CMF_4,
                    SERVICE_CMF_5,
                    SERVICE_CMF_6,
                    SERVICE_CMF_7,
                    SERVICE_CMF_8,
                    SERVICE_CMF_9,
                    SERVICE_CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MSVMSVCDEF
                ORDER BY MODULE_NAME ASC,
                    SERVICE_NAME ASC;
            EXEC SQL OPEN DBC_MSVMSVCDEF_CUR_1;
            break;

        case 2:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);

            EXEC SQL DECLARE DBC_MSVMSVCDEF_CUR_2 CURSOR FOR
                SELECT 
                    SERVICE_NAME,
                    MODULE_NAME,
                    SERVICE_MODE,
                    SERVICE_CATEGORY,
                    SERVICE_TYPE,
                    SERVICE_DESC_1,
                    SERVICE_DESC_2,
                    SERVICE_DESC_3,
                    SEC_CHK_FLAG,
                    LOG_LEVEL,
                    SHARED_LIB_NAME,
                    SERVICE_CMF_1,
                    SERVICE_CMF_2,
                    SERVICE_CMF_3,
                    SERVICE_CMF_4,
                    SERVICE_CMF_5,
                    SERVICE_CMF_6,
                    SERVICE_CMF_7,
                    SERVICE_CMF_8,
                    SERVICE_CMF_9,
                    SERVICE_CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MSVMSVCDEF
                WHERE MODULE_NAME LIKE :MSVMSVCDEF_N.MODULE_NAME
                  AND SERVICE_NAME LIKE :MSVMSVCDEF_N.SERVICE_NAME
                  AND SERVICE_CATEGORY LIKE :DBC_Q_COND_N.KEY_3
                  AND ((MODULE_NAME = :DBC_Q_COND_N.KEY_1 AND SERVICE_NAME >= :DBC_Q_COND_N.KEY_2) OR SERVICE_NAME > :DBC_Q_COND_N.KEY_2)
                ORDER BY MODULE_NAME ASC, SERVICE_NAME ASC;
            EXEC SQL OPEN DBC_MSVMSVCDEF_CUR_2;
            break;
            
        case 3:
            EXEC SQL DECLARE DBC_MSVMSVCDEF_CUR_3 CURSOR FOR
                SELECT DISTINCT (MODULE_NAME)
                FROM MSVMSVCDEF
                ORDER BY MODULE_NAME ASC;
            EXEC SQL OPEN DBC_MSVMSVCDEF_CUR_3;
            break;            
 
        case 4:
            EXEC SQL DECLARE DBC_MSVMSVCDEF_CUR_4 CURSOR FOR
                SELECT 
                    SERVICE_NAME,
                    MODULE_NAME,
                    SERVICE_MODE,
                    SERVICE_CATEGORY,
                    SERVICE_TYPE,
                    SERVICE_DESC_1,
                    SERVICE_DESC_2,
                    SERVICE_DESC_3,
                    SEC_CHK_FLAG,
                    LOG_LEVEL,
                    SHARED_LIB_NAME,
                    SERVICE_CMF_1,
                    SERVICE_CMF_2,
                    SERVICE_CMF_3,
                    SERVICE_CMF_4,
                    SERVICE_CMF_5,
                    SERVICE_CMF_6,
                    SERVICE_CMF_7,
                    SERVICE_CMF_8,
                    SERVICE_CMF_9,
                    SERVICE_CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MSVMSVCDEF
                WHERE SEC_CHK_FLAG = :MSVMSVCDEF_N.SEC_CHK_FLAG 
                ORDER BY SERVICE_NAME ASC;
            EXEC SQL OPEN DBC_MSVMSVCDEF_CUR_4;
            break;

        case 5:
            EXEC SQL DECLARE DBC_MSVMSVCDEF_CUR_5 CURSOR FOR
                SELECT 
                    SERVICE_NAME,
                    MODULE_NAME,
                    SERVICE_MODE,
                    SERVICE_CATEGORY,
                    SERVICE_TYPE,
                    SERVICE_DESC_1,
                    SERVICE_DESC_2,
                    SERVICE_DESC_3,
                    SEC_CHK_FLAG,
                    LOG_LEVEL,
                    SHARED_LIB_NAME,
                    SERVICE_CMF_1,
                    SERVICE_CMF_2,
                    SERVICE_CMF_3,
                    SERVICE_CMF_4,
                    SERVICE_CMF_5,
                    SERVICE_CMF_6,
                    SERVICE_CMF_7,
                    SERVICE_CMF_8,
                    SERVICE_CMF_9,
                    SERVICE_CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MSVMSVCDEF
                WHERE MODULE_NAME LIKE :MSVMSVCDEF_N.MODULE_NAME
                  AND SERVICE_MODE LIKE :MSVMSVCDEF_N.SERVICE_MODE
                ORDER BY MODULE_NAME ASC, SERVICE_NAME ASC;
            EXEC SQL OPEN DBC_MSVMSVCDEF_CUR_5;
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_msvmsvcdef", sel_type);
