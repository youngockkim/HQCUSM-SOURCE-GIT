                AND HIST_SEQ = :MQCGLOTDEF_N.HIST_SEQ
                AND QA_HIST_SEQ = :MQCGLOTDEF_N.QA_HIST_SEQ
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC,
