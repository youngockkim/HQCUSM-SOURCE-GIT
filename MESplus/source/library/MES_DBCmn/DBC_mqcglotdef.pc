}


/* Del Null Function */
void DBC_del_null_mqcglotdef(struct MQCGLOTDEF_N_TAG *MQCGLOTDEF_N, struct MQCGLOTDEF_TAG *MQCGLOTDEF)
{
    MEMCPY_DN(MQCGLOTDEF->LOT_ID, MQCGLOTDEF_N->LOT_ID, sizeof(MQCGLOTDEF->LOT_ID));
    MQCGLOTDEF->HIST_SEQ = MQCGLOTDEF_N->HIST_SEQ;
