    {
        case 1:
            EXEC SQL CLOSE DBC_MQCGLOTDEF_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mqcglotdef", sel_type);
}


/* Initialize Function */
void DBC_init_mqcglotdef(struct MQCGLOTDEF_TAG *MQCGLOTDEF)
{
    /* memset by Space */
    memset(MQCGLOTDEF, ' ', sizeof(struct MQCGLOTDEF_TAG));
    
    MQCGLOTDEF->HIST_SEQ = 0;
    MQCGLOTDEF->QA_HIST_SEQ = 0;
    MQCGLOTDEF->MAT_VER = 0;
    MQCGLOTDEF->FLOW_SEQ_NUM = 0;
    MQCGLOTDEF->QTY_1 = 0;
    MQCGLOTDEF->QTY_2 = 0;
    MQCGLOTDEF->QTY_3 = 0;
    MQCGLOTDEF->DEF_SEQ = 0;
    MQCGLOTDEF->DEF_QTY = 0;
    MQCGLOTDEF->YIELD = 0;
}


/* Add Null Function */
void DBC_add_null_mqcglotdef(struct MQCGLOTDEF_N_TAG *MQCGLOTDEF_N, struct MQCGLOTDEF_TAG *MQCGLOTDEF)
{
    /* memset by NULL */
    memset(MQCGLOTDEF_N, '\0', sizeof(struct MQCGLOTDEF_N_TAG));
    
    MEMCPY_AN(MQCGLOTDEF_N->LOT_ID, MQCGLOTDEF->LOT_ID, sizeof(MQCGLOTDEF->LOT_ID));
    MQCGLOTDEF_N->HIST_SEQ = MQCGLOTDEF->HIST_SEQ;
    MQCGLOTDEF_N->QA_HIST_SEQ = MQCGLOTDEF->QA_HIST_SEQ;
    MEMCPY_AN(MQCGLOTDEF_N->TRAN_TIME, MQCGLOTDEF->TRAN_TIME, sizeof(MQCGLOTDEF->TRAN_TIME));
    MEMCPY_AN(MQCGLOTDEF_N->FACTORY, MQCGLOTDEF->FACTORY, sizeof(MQCGLOTDEF->FACTORY));
    MEMCPY_AN(MQCGLOTDEF_N->MAT_ID, MQCGLOTDEF->MAT_ID, sizeof(MQCGLOTDEF->MAT_ID));
    MQCGLOTDEF_N->MAT_VER = MQCGLOTDEF->MAT_VER;
    MEMCPY_AN(MQCGLOTDEF_N->FLOW, MQCGLOTDEF->FLOW, sizeof(MQCGLOTDEF->FLOW));
    MQCGLOTDEF_N->FLOW_SEQ_NUM = MQCGLOTDEF->FLOW_SEQ_NUM;
    MEMCPY_AN(MQCGLOTDEF_N->OPER, MQCGLOTDEF->OPER, sizeof(MQCGLOTDEF->OPER));
    MEMCPY_AN(MQCGLOTDEF_N->QA_OPER, MQCGLOTDEF->QA_OPER, sizeof(MQCGLOTDEF->QA_OPER));
    MEMCPY_AN(MQCGLOTDEF_N->RES_ID, MQCGLOTDEF->RES_ID, sizeof(MQCGLOTDEF->RES_ID));
    MEMCPY_AN(MQCGLOTDEF_N->CRR_ID, MQCGLOTDEF->CRR_ID, sizeof(MQCGLOTDEF->CRR_ID));
    MQCGLOTDEF_N->QTY_1 = MQCGLOTDEF->QTY_1;
    MQCGLOTDEF_N->QTY_2 = MQCGLOTDEF->QTY_2;
    MQCGLOTDEF_N->QTY_3 = MQCGLOTDEF->QTY_3;
    MQCGLOTDEF_N->DEF_SEQ = MQCGLOTDEF->DEF_SEQ;
    MQCGLOTDEF_N->DEF_QTY_FLAG[0] = MQCGLOTDEF->DEF_QTY_FLAG;
    MEMCPY_AN(MQCGLOTDEF_N->DEF_CODE, MQCGLOTDEF->DEF_CODE, sizeof(MQCGLOTDEF->DEF_CODE));
    MQCGLOTDEF_N->DEF_QTY = MQCGLOTDEF->DEF_QTY;
    MQCGLOTDEF_N->YIELD = MQCGLOTDEF->YIELD;
    MQCGLOTDEF_N->HIST_DEL_FLAG[0] = MQCGLOTDEF->HIST_DEL_FLAG;
    MEMCPY_AN(MQCGLOTDEF_N->HIST_DEL_TIME, MQCGLOTDEF->HIST_DEL_TIME, sizeof(MQCGLOTDEF->HIST_DEL_TIME));
    MEMCPY_AN(MQCGLOTDEF_N->HIST_DEL_USER, MQCGLOTDEF->HIST_DEL_USER, sizeof(MQCGLOTDEF->HIST_DEL_USER));
    MEMCPY_AN(MQCGLOTDEF_N->HIST_DEL_COMMENT, MQCGLOTDEF->HIST_DEL_COMMENT, sizeof(MQCGLOTDEF->HIST_DEL_COMMENT));
    MEMCPY_AN(MQCGLOTDEF_N->RESV_FIELD_1, MQCGLOTDEF->RESV_FIELD_1, sizeof(MQCGLOTDEF->RESV_FIELD_1));
    MEMCPY_AN(MQCGLOTDEF_N->RESV_FIELD_2, MQCGLOTDEF->RESV_FIELD_2, sizeof(MQCGLOTDEF->RESV_FIELD_2));
    MEMCPY_AN(MQCGLOTDEF_N->RESV_FIELD_3, MQCGLOTDEF->RESV_FIELD_3, sizeof(MQCGLOTDEF->RESV_FIELD_3));
    MEMCPY_AN(MQCGLOTDEF_N->RESV_FIELD_4, MQCGLOTDEF->RESV_FIELD_4, sizeof(MQCGLOTDEF->RESV_FIELD_4));
    MEMCPY_AN(MQCGLOTDEF_N->RESV_FIELD_5, MQCGLOTDEF->RESV_FIELD_5, sizeof(MQCGLOTDEF->RESV_FIELD_5));
    MEMCPY_AN(MQCGLOTDEF_N->RESV_FIELD_6, MQCGLOTDEF->RESV_FIELD_6, sizeof(MQCGLOTDEF->RESV_FIELD_6));
    MEMCPY_AN(MQCGLOTDEF_N->RESV_FIELD_7, MQCGLOTDEF->RESV_FIELD_7, sizeof(MQCGLOTDEF->RESV_FIELD_7));
    MEMCPY_AN(MQCGLOTDEF_N->RESV_FIELD_8, MQCGLOTDEF->RESV_FIELD_8, sizeof(MQCGLOTDEF->RESV_FIELD_8));
    MEMCPY_AN(MQCGLOTDEF_N->RESV_FIELD_9, MQCGLOTDEF->RESV_FIELD_9, sizeof(MQCGLOTDEF->RESV_FIELD_9));
