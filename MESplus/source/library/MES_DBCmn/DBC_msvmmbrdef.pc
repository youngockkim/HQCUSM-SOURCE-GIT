    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSVMMBRDEF_CUR_1 CURSOR FOR
                SELECT 
                    MEMBER_NAME,
                    MEMBER_DESC_1,
                    MEMBER_DESC_2,
                    MEMBER_DESC_3,
                    MEMBER_TYPE,
                    MEMBER_SIZE,
                    ARRAY_TYPE,
                    USE_RANGE_FLAG,
                    RANGE_MIN,
                    RANGE_MAX,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MSVMMBRDEF
                ORDER BY MEMBER_NAME ASC;
            EXEC SQL OPEN DBC_MSVMMBRDEF_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MSVMMBRDEF_CUR_2 CURSOR FOR
                SELECT 
                    MEMBER_NAME,
                    MEMBER_DESC_1,
                    MEMBER_DESC_2,
                    MEMBER_DESC_3,
                    MEMBER_TYPE,
                    MEMBER_SIZE,
                    ARRAY_TYPE,
                    USE_RANGE_FLAG,
                    RANGE_MIN,
                    RANGE_MAX,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MSVMMBRDEF
                WHERE MEMBER_NAME >= :MSVMMBRDEF_N.MEMBER_NAME
                ORDER BY MEMBER_NAME ASC;
            EXEC SQL OPEN DBC_MSVMMBRDEF_CUR_2;
            break;

        case 3:
            memset( sql, 0x00, sizeof(sql));
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "MEMBER_NAME, ");
            sprintf(sql + strlen(sql),   "MEMBER_DESC_1, ");
            sprintf(sql + strlen(sql),   "MEMBER_DESC_2, ");
            sprintf(sql + strlen(sql),   "MEMBER_DESC_3, ");
            sprintf(sql + strlen(sql),   "MEMBER_TYPE, ");
            sprintf(sql + strlen(sql),   "MEMBER_SIZE, ");
            sprintf(sql + strlen(sql),   "ARRAY_TYPE, ");
            sprintf(sql + strlen(sql),   "USE_RANGE_FLAG, ");
            sprintf(sql + strlen(sql),   "RANGE_MIN, ");
            sprintf(sql + strlen(sql),   "RANGE_MAX, ");
            sprintf(sql + strlen(sql),   "CREATE_USER_ID, ");
            sprintf(sql + strlen(sql),   "CREATE_TIME, ");
            sprintf(sql + strlen(sql),   "UPDATE_USER_ID, ");
            sprintf(sql + strlen(sql),   "UPDATE_TIME ");
            sprintf(sql + strlen(sql), "FROM MSVMMBRDEF WHERE ");
            sprintf(sql + strlen(sql), "MEMBER_NAME LIKE '%%%s%%' ORDER BY MEMBER_NAME ASC", MSVMMBRDEF_N.MEMBER_NAME);            
            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MSVMMBRDEF_CUR_3 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MSVMMBRDEF_CUR_3;                 
            break;    
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
