        case 52:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "DBC_open_get_colset(2) ", 22);
            break;
        

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_medccoldef", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_medccoldef(int sel_type, struct MEDCCOLDEF_TAG *MEDCCOLDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MEDCCOLDEF_N_TAG MEDCCOLDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MEDCCOLDEF_CUR_1 INTO :MEDCCOLDEF_N.COL_SET_ID, :MEDCCOLDEF_N.COL_SET_DESC, :MEDCCOLDEF_N.DELETE_FLAG;
            break;

        case 2:
            EXEC SQL FETCH DBC_MEDCCOLDEF_CUR_2 INTO :MEDCCOLDEF_N.COL_SET_ID, :MEDCCOLDEF_N.COL_SET_DESC, :MEDCCOLDEF_N.DELETE_FLAG;
            break;

        case 3:
            EXEC SQL FETCH DBC_MEDCCOLDEF_CUR_3 INTO :MEDCCOLDEF_N.COL_SET_ID, :MEDCCOLDEF_N.COL_SET_DESC, :MEDCCOLDEF_N.DELETE_FLAG;
            break;
            
        case 4:
            EXEC SQL FETCH DBC_MEDCCOLDEF_CUR_4 INTO :MEDCCOLDEF_N.COL_SET_ID, :MEDCCOLDEF_N.COL_SET_DESC, :MEDCCOLDEF_N.DELETE_FLAG;
            break;

        case 5:
            EXEC SQL FETCH DBC_MEDCCOLDEF_CUR_5 INTO :MEDCCOLDEF_N.COL_SET_ID, :MEDCCOLDEF_N.COL_SET_DESC, :MEDCCOLDEF_N.DELETE_FLAG;
            break;
            
        case 6:
            EXEC SQL FETCH DBC_MEDCCOLDEF_CUR_6 INTO :MEDCCOLDEF_N.COL_SET_ID, :MEDCCOLDEF_N.COL_SET_DESC, :MEDCCOLDEF_N.DELETE_FLAG;
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_medccoldef(&MEDCCOLDEF_N, MEDCCOLDEF);
    }
    DB_stop_query_timer("DBC_fetch_medccoldef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_medccoldef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MEDCCOLDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MEDCCOLDEF_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MEDCCOLDEF_CUR_3;
            break;
            
        case 4:
            EXEC SQL CLOSE DBC_MEDCCOLDEF_CUR_4;
            break;
 
        case 5:
            EXEC SQL CLOSE DBC_MEDCCOLDEF_CUR_5;
            break;
            
        case 6:
            EXEC SQL CLOSE DBC_MEDCCOLDEF_CUR_6;
            break;
           

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_medccoldef", sel_type);
}


/* Initialize Function */
void DBC_init_medccoldef(struct MEDCCOLDEF_TAG *MEDCCOLDEF)
{
    /* memset by Space */
    memset(MEDCCOLDEF, ' ', sizeof(struct MEDCCOLDEF_TAG));
    
}


