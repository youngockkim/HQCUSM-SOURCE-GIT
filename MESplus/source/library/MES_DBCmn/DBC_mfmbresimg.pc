/* Add Null Function */
void DBC_add_null_mfmbresimg(struct MFMBRESIMG_N_TAG *MFMBRESIMG_N, struct MFMBRESIMG_TAG *MFMBRESIMG)
{
    /* memset by NULL */
    memset(MFMBRESIMG_N, '\0', sizeof(struct MFMBRESIMG_N_TAG));
    
    MEMCPY_AN(MFMBRESIMG_N->FACTORY, MFMBRESIMG->FACTORY, sizeof(MFMBRESIMG->FACTORY));
    MEMCPY_AN(MFMBRESIMG_N->RES_ID, MFMBRESIMG->RES_ID, sizeof(MFMBRESIMG->RES_ID));
    MEMCPY_AN(MFMBRESIMG_N->RES_TYPE, MFMBRESIMG->RES_TYPE, sizeof(MFMBRESIMG->RES_TYPE));
    MEMCPY_AN(MFMBRESIMG_N->SUBRES_ID, MFMBRESIMG->SUBRES_ID, sizeof(MFMBRESIMG->SUBRES_ID));
    MFMBRESIMG_N->IMAGE_IDX = MFMBRESIMG->IMAGE_IDX;
}


/* Del Null Function */
void DBC_del_null_mfmbresimg(struct MFMBRESIMG_N_TAG *MFMBRESIMG_N, struct MFMBRESIMG_TAG *MFMBRESIMG)
{
    MEMCPY_DN(MFMBRESIMG->FACTORY, MFMBRESIMG_N->FACTORY, sizeof(MFMBRESIMG->FACTORY));
    MEMCPY_DN(MFMBRESIMG->RES_ID, MFMBRESIMG_N->RES_ID, sizeof(MFMBRESIMG->RES_ID));
