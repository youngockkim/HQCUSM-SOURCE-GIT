/* Add Null Function */
void DBC_add_null_mwipgrddef(struct MWIPGRDDEF_N_TAG *MWIPGRDDEF_N, struct MWIPGRDDEF_TAG *MWIPGRDDEF)
{
    /* memset by NULL */
    memset(MWIPGRDDEF_N, '\0', sizeof(struct MWIPGRDDEF_N_TAG));
    
    MEMCPY_AN(MWIPGRDDEF_N->FACTORY, MWIPGRDDEF->FACTORY, sizeof(MWIPGRDDEF->FACTORY));
    MEMCPY_AN(MWIPGRDDEF_N->MAT_ID, MWIPGRDDEF->MAT_ID, sizeof(MWIPGRDDEF->MAT_ID));
    MWIPGRDDEF_N->MAT_VER = MWIPGRDDEF->MAT_VER;
    MEMCPY_AN(MWIPGRDDEF_N->FLOW, MWIPGRDDEF->FLOW, sizeof(MWIPGRDDEF->FLOW));
    MEMCPY_AN(MWIPGRDDEF_N->OPER, MWIPGRDDEF->OPER, sizeof(MWIPGRDDEF->OPER));
    MEMCPY_AN(MWIPGRDDEF_N->GRADE, MWIPGRDDEF->GRADE, sizeof(MWIPGRDDEF->GRADE));
    MWIPGRDDEF_N->RULE_TYPE[0] = MWIPGRDDEF->RULE_TYPE;
    MWIPGRDDEF_N->SPEC_M = MWIPGRDDEF->SPEC_M;
    MEMCPY_AN(MWIPGRDDEF_N->CHECK_GRADE1, MWIPGRDDEF->CHECK_GRADE1, sizeof(MWIPGRDDEF->CHECK_GRADE1));
    MEMCPY_AN(MWIPGRDDEF_N->COMP1, MWIPGRDDEF->COMP1, sizeof(MWIPGRDDEF->COMP1));
    MWIPGRDDEF_N->VALUE1 = MWIPGRDDEF->VALUE1;
    MEMCPY_AN(MWIPGRDDEF_N->AND_OR, MWIPGRDDEF->AND_OR, sizeof(MWIPGRDDEF->AND_OR));
    MEMCPY_AN(MWIPGRDDEF_N->CHECK_GRADE2, MWIPGRDDEF->CHECK_GRADE2, sizeof(MWIPGRDDEF->CHECK_GRADE2));
    MEMCPY_AN(MWIPGRDDEF_N->COMP2, MWIPGRDDEF->COMP2, sizeof(MWIPGRDDEF->COMP2));
    MWIPGRDDEF_N->VALUE2 = MWIPGRDDEF->VALUE2;
    MWIPGRDDEF_N->CELL_COUNT_VT = MWIPGRDDEF->CELL_COUNT_VT;
    MWIPGRDDEF_N->CELL_COUNT_HR = MWIPGRDDEF->CELL_COUNT_HR;
    MEMCPY_AN(MWIPGRDDEF_N->CREATE_USER_ID, MWIPGRDDEF->CREATE_USER_ID, sizeof(MWIPGRDDEF->CREATE_USER_ID));
    MEMCPY_AN(MWIPGRDDEF_N->CREATE_TIME, MWIPGRDDEF->CREATE_TIME, sizeof(MWIPGRDDEF->CREATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mwipgrddef(struct MWIPGRDDEF_N_TAG *MWIPGRDDEF_N, struct MWIPGRDDEF_TAG *MWIPGRDDEF)
{
    MEMCPY_DN(MWIPGRDDEF->FACTORY, MWIPGRDDEF_N->FACTORY, sizeof(MWIPGRDDEF->FACTORY));
    MEMCPY_DN(MWIPGRDDEF->MAT_ID, MWIPGRDDEF_N->MAT_ID, sizeof(MWIPGRDDEF->MAT_ID));
    MWIPGRDDEF->MAT_VER = MWIPGRDDEF_N->MAT_VER;
    MEMCPY_DN(MWIPGRDDEF->FLOW, MWIPGRDDEF_N->FLOW, sizeof(MWIPGRDDEF->FLOW));
    MEMCPY_DN(MWIPGRDDEF->OPER, MWIPGRDDEF_N->OPER, sizeof(MWIPGRDDEF->OPER));
    MEMCPY_DN(MWIPGRDDEF->GRADE, MWIPGRDDEF_N->GRADE, sizeof(MWIPGRDDEF->GRADE));
    MWIPGRDDEF->RULE_TYPE = MWIPGRDDEF_N->RULE_TYPE[0];
    MWIPGRDDEF->SPEC_M = MWIPGRDDEF_N->SPEC_M;
    MEMCPY_DN(MWIPGRDDEF->CHECK_GRADE1, MWIPGRDDEF_N->CHECK_GRADE1, sizeof(MWIPGRDDEF->CHECK_GRADE1));
