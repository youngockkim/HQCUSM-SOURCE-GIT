/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipgrddef(int sel_type, struct MWIPGRDDEF_TAG *MWIPGRDDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPGRDDEF_N_TAG MWIPGRDDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipgrddef(&MWIPGRDDEF_N, MWIPGRDDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPGRDDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    GRADE,
                    RULE_TYPE,
                    SPEC_M,
                    CHECK_GRADE1,
                    COMP1,
                    VALUE1,
                    AND_OR,
                    CHECK_GRADE2,
                    COMP2,
                    VALUE2,
                    CELL_COUNT_VT,
                    CELL_COUNT_HR,
                    CREATE_USER_ID,
                    CREATE_TIME
                FROM MWIPGRDDEF
                ORDER BY FACTORY ASC,
                    MAT_ID ASC,
                    MAT_VER ASC,
                    FLOW ASC,
                    OPER ASC,
                    RULE_TYPE ASC,
                    GRADE ASC;
            EXEC SQL OPEN DBC_MWIPGRDDEF_CUR_1;
            break;

        case 2:
            /* Use material version up */
            EXEC SQL DECLARE DBC_MWIPGRDDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    GRADE,
                    RULE_TYPE,
                    SPEC_M,
                    CHECK_GRADE1,
                    COMP1,
                    VALUE1,
                    AND_OR,
                    CHECK_GRADE2,
                    COMP2,
                    VALUE2,
                    CELL_COUNT_VT,
                    CELL_COUNT_HR,
                    CREATE_USER_ID,
                    CREATE_TIME
                FROM MWIPGRDDEF
                WHERE FACTORY = :MWIPGRDDEF_N.FACTORY
                    AND MAT_ID = :MWIPGRDDEF_N.MAT_ID
                    AND MAT_VER = :MWIPGRDDEF_N.MAT_VER;
            EXEC SQL OPEN DBC_MWIPGRDDEF_CUR_2;
            break;

            
            
            
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipgrddef", sel_type);
}


