                    DOF_CMF_4 = :MBASDOFDEF_N.DOF_CMF_4,
                    DOF_CMF_5 = :MBASDOFDEF_N.DOF_CMF_5,
                    DOF_CMF_6 = :MBASDOFDEF_N.DOF_CMF_6,
                    DOF_CMF_7 = :MBASDOFDEF_N.DOF_CMF_7,
                    DOF_CMF_8 = :MBASDOFDEF_N.DOF_CMF_8,
                    DOF_CMF_9 = :MBASDOFDEF_N.DOF_CMF_9,
                    DOF_CMF_10 = :MBASDOFDEF_N.DOF_CMF_10,
                    CREATE_USER_ID = :MBASDOFDEF_N.CREATE_USER_ID,
                    CREATE_TIME = :MBASDOFDEF_N.CREATE_TIME,
                    UPDATE_USER_ID = :MBASDOFDEF_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MBASDOFDEF_N.UPDATE_TIME,
                    RESV_FIELD_1 = :MBASDOFDEF_N.RESV_FIELD_1,
                    RESV_FIELD_2 = :MBASDOFDEF_N.RESV_FIELD_2,
                    RESV_FIELD_3 = :MBASDOFDEF_N.RESV_FIELD_3,
                    RESV_FIELD_4 = :MBASDOFDEF_N.RESV_FIELD_4,
                    RESV_FIELD_5 = :MBASDOFDEF_N.RESV_FIELD_5,
                    RESV_FLAG_1 = :MBASDOFDEF_N.RESV_FLAG_1,
                    RESV_FLAG_2 = :MBASDOFDEF_N.RESV_FLAG_2,
                    RESV_FLAG_3 = :MBASDOFDEF_N.RESV_FLAG_3,
                    RESV_FLAG_4 = :MBASDOFDEF_N.RESV_FLAG_4,
                    RESV_FLAG_5 = :MBASDOFDEF_N.RESV_FLAG_5
                WHERE FACTORY = :MBASDOFDEF_N.FACTORY
                    AND DOF_ID = :MBASDOFDEF_N.DOF_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mbasdofdef", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mbasdofdef(int sel_type, struct MBASDOFDEF_TAG *MBASDOFDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBASDOFDEF_N_TAG MBASDOFDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbasdofdef(&MBASDOFDEF_N, MBASDOFDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MBASDOFDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    DOF_ID,
                    DOF_DESC,
                    MODULE_NAME,
                    SERVICE_NAME,
                    PAGE_WIDTH,
                    PAGE_HEIGHT,
                    PAPER_TYPE,
                    DIRECTION_TYPE,
                    TOP_SPACE,
                    BOTTOM_SPACE,
                    LEFT_SPACE,
                    RIGHT_SPACE,
                    DOF_GRP_1,
                    DOF_GRP_2,
                    DOF_GRP_3,
                    DOF_GRP_4,
                    DOF_GRP_5,
                    DOF_GRP_6,
                    DOF_GRP_7,
                    DOF_GRP_8,
                    DOF_GRP_9,
                    DOF_GRP_10,
                    DOF_CMF_1,
                    DOF_CMF_2,
                    DOF_CMF_3,
                    DOF_CMF_4,
                    DOF_CMF_5,
                    DOF_CMF_6,
                    DOF_CMF_7,
                    DOF_CMF_8,
                    DOF_CMF_9,
                    DOF_CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD_1,
                    RESV_FIELD_2,
                    RESV_FIELD_3,
                    RESV_FIELD_4,
                    RESV_FIELD_5,
                    RESV_FLAG_1,
                    RESV_FLAG_2,
                    RESV_FLAG_3,
                    RESV_FLAG_4,
                    RESV_FLAG_5
                FROM MBASDOFDEF
                ORDER BY FACTORY ASC,
                    DOF_ID ASC;
            EXEC SQL OPEN DBC_MBASDOFDEF_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE DBC_MBASDOFDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    DOF_ID,
                    DOF_DESC,
                    MODULE_NAME,
                    SERVICE_NAME,
                    PAGE_WIDTH,
                    PAGE_HEIGHT,
                    PAPER_TYPE,
                    DIRECTION_TYPE,
                    TOP_SPACE,
                    BOTTOM_SPACE,
                    LEFT_SPACE,
                    RIGHT_SPACE,
                    DOF_GRP_1,
                    DOF_GRP_2,
                    DOF_GRP_3,
                    DOF_GRP_4,
                    DOF_GRP_5,
                    DOF_GRP_6,
                    DOF_GRP_7,
                    DOF_GRP_8,
                    DOF_GRP_9,
                    DOF_GRP_10,
                    DOF_CMF_1,
                    DOF_CMF_2,
                    DOF_CMF_3,
                    DOF_CMF_4,
                    DOF_CMF_5,
                    DOF_CMF_6,
                    DOF_CMF_7,
                    DOF_CMF_8,
                    DOF_CMF_9,
                    DOF_CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD_1,
                    RESV_FIELD_2,
                    RESV_FIELD_3,
                    RESV_FIELD_4,
                    RESV_FIELD_5,
                    RESV_FLAG_1,
                    RESV_FLAG_2,
                    RESV_FLAG_3,
                    RESV_FLAG_4,
                    RESV_FLAG_5
                FROM MBASDOFDEF
                WHERE FACTORY LIKE :MBASDOFDEF_N.FACTORY
                AND DOF_ID >= :MBASDOFDEF_N.DOF_ID
                ORDER BY DOF_ID ASC;
            EXEC SQL OPEN DBC_MBASDOFDEF_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mbasdofdef", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mbasdofdef(int sel_type, struct MBASDOFDEF_TAG *MBASDOFDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBASDOFDEF_N_TAG MBASDOFDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MBASDOFDEF_CUR_1 INTO
                :MBASDOFDEF_N.FACTORY,
                :MBASDOFDEF_N.DOF_ID,
                :MBASDOFDEF_N.DOF_DESC,
