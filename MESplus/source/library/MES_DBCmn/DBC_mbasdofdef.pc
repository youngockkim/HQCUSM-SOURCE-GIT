    MEMCPY_AN(MBASDOFDEF_N->DOF_CMF_1, MBASDOFDEF->DOF_CMF_1, sizeof(MBASDOFDEF->DOF_CMF_1));
    MEMCPY_AN(MBASDOFDEF_N->DOF_CMF_2, MBASDOFDEF->DOF_CMF_2, sizeof(MBASDOFDEF->DOF_CMF_2));
    MEMCPY_AN(MBASDOFDEF_N->DOF_CMF_3, MBASDOFDEF->DOF_CMF_3, sizeof(MBASDOFDEF->DOF_CMF_3));
