                :MBASDOFDEF_N.DOF_GRP_10,
                :MBASDOFDEF_N.DOF_CMF_1,
                :MBASDOFDEF_N.DOF_CMF_2,
                :MBASDOFDEF_N.DOF_CMF_3,
                :MBASDOFDEF_N.DOF_CMF_4,
                :MBASDOFDEF_N.DOF_CMF_5,
                :MBASDOFDEF_N.DOF_CMF_6,
                :MBASDOFDEF_N.DOF_CMF_7,
                :MBASDOFDEF_N.DOF_CMF_8,
                :MBASDOFDEF_N.DOF_CMF_9,
                :MBASDOFDEF_N.DOF_CMF_10,
                :MBASDOFDEF_N.CREATE_USER_ID,
                :MBASDOFDEF_N.CREATE_TIME,
                :MBASDOFDEF_N.UPDATE_USER_ID,
                :MBASDOFDEF_N.UPDATE_TIME,
                :MBASDOFDEF_N.RESV_FIELD_1,
                :MBASDOFDEF_N.RESV_FIELD_2,
                :MBASDOFDEF_N.RESV_FIELD_3,
                :MBASDOFDEF_N.RESV_FIELD_4,
                :MBASDOFDEF_N.RESV_FIELD_5,
                :MBASDOFDEF_N.RESV_FLAG_1,
                :MBASDOFDEF_N.RESV_FLAG_2,
                :MBASDOFDEF_N.RESV_FLAG_3,
                :MBASDOFDEF_N.RESV_FLAG_4,
                :MBASDOFDEF_N.RESV_FLAG_5;
            break;

		case 2:
            EXEC SQL FETCH DBC_MBASDOFDEF_CUR_2 INTO
                :MBASDOFDEF_N.FACTORY,
                :MBASDOFDEF_N.DOF_ID,
                :MBASDOFDEF_N.DOF_DESC,
                :MBASDOFDEF_N.MODULE_NAME,
                :MBASDOFDEF_N.SERVICE_NAME,
                :MBASDOFDEF_N.PAGE_WIDTH,
                :MBASDOFDEF_N.PAGE_HEIGHT,
                :MBASDOFDEF_N.PAPER_TYPE,
                :MBASDOFDEF_N.DIRECTION_TYPE,
                :MBASDOFDEF_N.TOP_SPACE,
                :MBASDOFDEF_N.BOTTOM_SPACE,
                :MBASDOFDEF_N.LEFT_SPACE,
                :MBASDOFDEF_N.RIGHT_SPACE,
                :MBASDOFDEF_N.DOF_GRP_1,
                :MBASDOFDEF_N.DOF_GRP_2,
                :MBASDOFDEF_N.DOF_GRP_3,
                :MBASDOFDEF_N.DOF_GRP_4,
                :MBASDOFDEF_N.DOF_GRP_5,
                :MBASDOFDEF_N.DOF_GRP_6,
                :MBASDOFDEF_N.DOF_GRP_7,
                :MBASDOFDEF_N.DOF_GRP_8,
                :MBASDOFDEF_N.DOF_GRP_9,
                :MBASDOFDEF_N.DOF_GRP_10,
                :MBASDOFDEF_N.DOF_CMF_1,
                :MBASDOFDEF_N.DOF_CMF_2,
                :MBASDOFDEF_N.DOF_CMF_3,
                :MBASDOFDEF_N.DOF_CMF_4,
                :MBASDOFDEF_N.DOF_CMF_5,
                :MBASDOFDEF_N.DOF_CMF_6,
                :MBASDOFDEF_N.DOF_CMF_7,
                :MBASDOFDEF_N.DOF_CMF_8,
                :MBASDOFDEF_N.DOF_CMF_9,
                :MBASDOFDEF_N.DOF_CMF_10,
                :MBASDOFDEF_N.CREATE_USER_ID,
                :MBASDOFDEF_N.CREATE_TIME,
                :MBASDOFDEF_N.UPDATE_USER_ID,
                :MBASDOFDEF_N.UPDATE_TIME,
                :MBASDOFDEF_N.RESV_FIELD_1,
                :MBASDOFDEF_N.RESV_FIELD_2,
                :MBASDOFDEF_N.RESV_FIELD_3,
                :MBASDOFDEF_N.RESV_FIELD_4,
                :MBASDOFDEF_N.RESV_FIELD_5,
                :MBASDOFDEF_N.RESV_FLAG_1,
                :MBASDOFDEF_N.RESV_FLAG_2,
                :MBASDOFDEF_N.RESV_FLAG_3,
                :MBASDOFDEF_N.RESV_FLAG_4,
                :MBASDOFDEF_N.RESV_FLAG_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mbasdofdef(&MBASDOFDEF_N, MBASDOFDEF);
    }
    DB_stop_query_timer("DBC_fetch_mbasdofdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mbasdofdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MBASDOFDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MBASDOFDEF_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mbasdofdef", sel_type);
}


/* Initialize Function */
void DBC_init_mbasdofdef(struct MBASDOFDEF_TAG *MBASDOFDEF)
{
    /* memset by Space */
    memset(MBASDOFDEF, ' ', sizeof(struct MBASDOFDEF_TAG));
    
    MBASDOFDEF->PAGE_WIDTH = 0;
    MBASDOFDEF->PAGE_HEIGHT = 0;
    MBASDOFDEF->TOP_SPACE = 0;
    MBASDOFDEF->BOTTOM_SPACE = 0;
    MBASDOFDEF->LEFT_SPACE = 0;
    MBASDOFDEF->RIGHT_SPACE = 0;
}


/* Add Null Function */
void DBC_add_null_mbasdofdef(struct MBASDOFDEF_N_TAG *MBASDOFDEF_N, struct MBASDOFDEF_TAG *MBASDOFDEF)
{
    /* memset by NULL */
    memset(MBASDOFDEF_N, '\0', sizeof(struct MBASDOFDEF_N_TAG));
    
    MEMCPY_AN(MBASDOFDEF_N->FACTORY, MBASDOFDEF->FACTORY, sizeof(MBASDOFDEF->FACTORY));
    MEMCPY_AN(MBASDOFDEF_N->DOF_ID, MBASDOFDEF->DOF_ID, sizeof(MBASDOFDEF->DOF_ID));
    MEMCPY_AN(MBASDOFDEF_N->DOF_DESC, MBASDOFDEF->DOF_DESC, sizeof(MBASDOFDEF->DOF_DESC));
	MEMCPY_AN(MBASDOFDEF_N->MODULE_NAME, MBASDOFDEF->MODULE_NAME, sizeof(MBASDOFDEF->MODULE_NAME));
    MEMCPY_AN(MBASDOFDEF_N->SERVICE_NAME, MBASDOFDEF->SERVICE_NAME, sizeof(MBASDOFDEF->SERVICE_NAME));
    MBASDOFDEF_N->PAGE_WIDTH = MBASDOFDEF->PAGE_WIDTH;
    MBASDOFDEF_N->PAGE_HEIGHT = MBASDOFDEF->PAGE_HEIGHT;
    MEMCPY_AN(MBASDOFDEF_N->PAPER_TYPE, MBASDOFDEF->PAPER_TYPE, sizeof(MBASDOFDEF->PAPER_TYPE));
    MEMCPY_AN(MBASDOFDEF_N->DIRECTION_TYPE, MBASDOFDEF->DIRECTION_TYPE, sizeof(MBASDOFDEF->DIRECTION_TYPE));
    MBASDOFDEF_N->TOP_SPACE = MBASDOFDEF->TOP_SPACE;
    MBASDOFDEF_N->BOTTOM_SPACE = MBASDOFDEF->BOTTOM_SPACE;
    MBASDOFDEF_N->LEFT_SPACE = MBASDOFDEF->LEFT_SPACE;
    MBASDOFDEF_N->RIGHT_SPACE = MBASDOFDEF->RIGHT_SPACE;
    MEMCPY_AN(MBASDOFDEF_N->DOF_GRP_1, MBASDOFDEF->DOF_GRP_1, sizeof(MBASDOFDEF->DOF_GRP_1));
    MEMCPY_AN(MBASDOFDEF_N->DOF_GRP_2, MBASDOFDEF->DOF_GRP_2, sizeof(MBASDOFDEF->DOF_GRP_2));
    MEMCPY_AN(MBASDOFDEF_N->DOF_GRP_3, MBASDOFDEF->DOF_GRP_3, sizeof(MBASDOFDEF->DOF_GRP_3));
    MEMCPY_AN(MBASDOFDEF_N->DOF_GRP_4, MBASDOFDEF->DOF_GRP_4, sizeof(MBASDOFDEF->DOF_GRP_4));
    MEMCPY_AN(MBASDOFDEF_N->DOF_GRP_5, MBASDOFDEF->DOF_GRP_5, sizeof(MBASDOFDEF->DOF_GRP_5));
