    MEMCPY_AN(MBASDOFDEF_N->DOF_CMF_7, MBASDOFDEF->DOF_CMF_7, sizeof(MBASDOFDEF->DOF_CMF_7));
    MEMCPY_AN(MBASDOFDEF_N->DOF_CMF_8, MBASDOFDEF->DOF_CMF_8, sizeof(MBASDOFDEF->DOF_CMF_8));
    MEMCPY_AN(MBASDOFDEF_N->DOF_CMF_9, MBASDOFDEF->DOF_CMF_9, sizeof(MBASDOFDEF->DOF_CMF_9));
    MEMCPY_AN(MBASDOFDEF_N->DOF_CMF_10, MBASDOFDEF->DOF_CMF_10, sizeof(MBASDOFDEF->DOF_CMF_10));
    MEMCPY_AN(MBASDOFDEF_N->CREATE_USER_ID, MBASDOFDEF->CREATE_USER_ID, sizeof(MBASDOFDEF->CREATE_USER_ID));
    MEMCPY_AN(MBASDOFDEF_N->CREATE_TIME, MBASDOFDEF->CREATE_TIME, sizeof(MBASDOFDEF->CREATE_TIME));
    MEMCPY_AN(MBASDOFDEF_N->UPDATE_USER_ID, MBASDOFDEF->UPDATE_USER_ID, sizeof(MBASDOFDEF->UPDATE_USER_ID));
    MEMCPY_AN(MBASDOFDEF_N->UPDATE_TIME, MBASDOFDEF->UPDATE_TIME, sizeof(MBASDOFDEF->UPDATE_TIME));
    MEMCPY_AN(MBASDOFDEF_N->RESV_FIELD_1, MBASDOFDEF->RESV_FIELD_1, sizeof(MBASDOFDEF->RESV_FIELD_1));
    MEMCPY_AN(MBASDOFDEF_N->RESV_FIELD_2, MBASDOFDEF->RESV_FIELD_2, sizeof(MBASDOFDEF->RESV_FIELD_2));
    MEMCPY_AN(MBASDOFDEF_N->RESV_FIELD_3, MBASDOFDEF->RESV_FIELD_3, sizeof(MBASDOFDEF->RESV_FIELD_3));
    MEMCPY_AN(MBASDOFDEF_N->RESV_FIELD_4, MBASDOFDEF->RESV_FIELD_4, sizeof(MBASDOFDEF->RESV_FIELD_4));
    MEMCPY_AN(MBASDOFDEF_N->RESV_FIELD_5, MBASDOFDEF->RESV_FIELD_5, sizeof(MBASDOFDEF->RESV_FIELD_5));
    MBASDOFDEF_N->RESV_FLAG_1[0] = MBASDOFDEF->RESV_FLAG_1;
    MBASDOFDEF_N->RESV_FLAG_2[0] = MBASDOFDEF->RESV_FLAG_2;
    MBASDOFDEF_N->RESV_FLAG_3[0] = MBASDOFDEF->RESV_FLAG_3;
    MBASDOFDEF_N->RESV_FLAG_4[0] = MBASDOFDEF->RESV_FLAG_4;
    MBASDOFDEF_N->RESV_FLAG_5[0] = MBASDOFDEF->RESV_FLAG_5;
}


/* Del Null Function */
void DBC_del_null_mbasdofdef(struct MBASDOFDEF_N_TAG *MBASDOFDEF_N, struct MBASDOFDEF_TAG *MBASDOFDEF)
{
    MEMCPY_DN(MBASDOFDEF->FACTORY, MBASDOFDEF_N->FACTORY, sizeof(MBASDOFDEF->FACTORY));
