                WHERE FACTORY = :MWIPBINREL_N.FACTORY
                    AND REL_LEVEL = :MWIPBINREL_N.REL_LEVEL
                    AND MAT_ID = :MWIPBINREL_N.MAT_ID
                    AND MAT_VER = :MWIPBINREL_N.MAT_VER
                    AND FLOW = :MWIPBINREL_N.FLOW
