/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipbinrel(int sel_type, struct MWIPBINREL_TAG *MWIPBINREL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPBINREL_N_TAG MWIPBINREL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipbinrel(&MWIPBINREL_N, MWIPBINREL);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPBINREL_CUR_1 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    REL_LEVEL,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RES_TYPE,
                    RESG_ID,
                    RES_ID,
                    LOT_CMF_1,
                    LOT_CMF_2,
                    LOT_CMF_3,
                    LOT_CMF_4,
                    LOT_CMF_5,
                    LOT_CMF_6,
                    LOT_CMF_7,
                    LOT_CMF_8,
                    LOT_CMF_9,
                    LOT_CMF_10,
                    LOT_CMF_11,
                    LOT_CMF_12,
                    LOT_CMF_13,
                    LOT_CMF_14,
                    LOT_CMF_15,
                    LOT_CMF_16,
                    LOT_CMF_17,
                    LOT_CMF_18,
                    LOT_CMF_19,
                    LOT_CMF_20,
                    BIN_ID,
                    BIN_UNIT,
                    COL_OTHER_UNIT_FLAG,
                    RESV_FIELD_1,
                    RESV_FIELD_2,
                    RESV_FIELD_3,
                    RESV_FIELD_4,
                    RESV_FIELD_5,
                    RESV_FIELD_6,
                    RESV_FIELD_7,
                    RESV_FIELD_8,
                    RESV_FIELD_9,
                    RESV_FIELD_10,
                    RESV_FIELD_11,
                    RESV_FIELD_12,
                    RESV_FIELD_13,
                    RESV_FIELD_14,
                    RESV_FIELD_15,
                    RESV_FIELD_16,
                    RESV_FIELD_17,
                    RESV_FIELD_18,
                    RESV_FIELD_19,
                    RESV_FIELD_20
                FROM MWIPBINREL
                WHERE FACTORY = :MWIPBINREL_N.FACTORY
                    AND REL_LEVEL = :MWIPBINREL_N.REL_LEVEL
                    AND MAT_ID = :MWIPBINREL_N.MAT_ID
                    AND MAT_VER = :MWIPBINREL_N.MAT_VER
                    AND FLOW = :MWIPBINREL_N.FLOW
                    AND OPER = :MWIPBINREL_N.OPER
                    AND RES_TYPE = :MWIPBINREL_N.RES_TYPE
                    AND RESG_ID = :MWIPBINREL_N.RESG_ID
                    AND RES_ID = :MWIPBINREL_N.RES_ID
                ORDER BY 
                    BIN_ID ASC,
                    BIN_UNIT ASC,
                    LOT_CMF_1 ASC,
                    LOT_CMF_2 ASC,
                    LOT_CMF_3 ASC,
                    LOT_CMF_4 ASC,
                    LOT_CMF_5 ASC,
                    LOT_CMF_6 ASC,
                    LOT_CMF_7 ASC,
                    LOT_CMF_8 ASC,
                    LOT_CMF_9 ASC,
                    LOT_CMF_10 ASC,
                    LOT_CMF_11 ASC,
                    LOT_CMF_12 ASC,
                    LOT_CMF_13 ASC,
                    LOT_CMF_14 ASC,
                    LOT_CMF_15 ASC,
                    LOT_CMF_16 ASC,
                    LOT_CMF_17 ASC,
                    LOT_CMF_18 ASC,
                    LOT_CMF_19 ASC,
                    LOT_CMF_20 ASC;
            EXEC SQL OPEN DBC_MWIPBINREL_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPBINREL_CUR_2 CURSOR FOR
                SELECT * FROM (
                    SELECT ROWNUM ROWSEQ, REL.* FROM (
                        SELECT 
                            CREATE_USER_ID,
                            CREATE_TIME,
                            UPDATE_USER_ID,
                            UPDATE_TIME,
                            FACTORY,
                            REL_LEVEL,
                            MAT_ID,
                            MAT_VER,
                            FLOW,
                            OPER,
                            RES_TYPE,
                            RESG_ID,
                            RES_ID,
                            LOT_CMF_1,
                            LOT_CMF_2,
                            LOT_CMF_3,
                            LOT_CMF_4,
                            LOT_CMF_5,
                            LOT_CMF_6,
                            LOT_CMF_7,
                            LOT_CMF_8,
                            LOT_CMF_9,
                            LOT_CMF_10,
                            LOT_CMF_11,
                            LOT_CMF_12,
                            LOT_CMF_13,
                            LOT_CMF_14,
                            LOT_CMF_15,
                            LOT_CMF_16,
                            LOT_CMF_17,
                            LOT_CMF_18,
                            LOT_CMF_19,
                            LOT_CMF_20,
                            BIN_ID,
                            BIN_UNIT,
                            COL_OTHER_UNIT_FLAG,
                            RESV_FIELD_1,
                            RESV_FIELD_2,
                            RESV_FIELD_3,
                            RESV_FIELD_4,
                            RESV_FIELD_5,
                            RESV_FIELD_6,
                            RESV_FIELD_7,
                            RESV_FIELD_8,
                            RESV_FIELD_9,
                            RESV_FIELD_10,
                            RESV_FIELD_11,
                            RESV_FIELD_12,
                            RESV_FIELD_13,
                            RESV_FIELD_14,
                            RESV_FIELD_15,
                            RESV_FIELD_16,
                            RESV_FIELD_17,
                            RESV_FIELD_18,
                            RESV_FIELD_19,
                            RESV_FIELD_20
                        FROM MWIPBINREL
                        WHERE FACTORY = :MWIPBINREL_N.FACTORY
                            AND REL_LEVEL = :MWIPBINREL_N.REL_LEVEL
                            AND MAT_ID = :MWIPBINREL_N.MAT_ID
                            AND MAT_VER = :MWIPBINREL_N.MAT_VER
                            AND FLOW = :MWIPBINREL_N.FLOW
                            AND OPER = :MWIPBINREL_N.OPER
                            AND RES_TYPE = :MWIPBINREL_N.RES_TYPE
                            AND RESG_ID = :MWIPBINREL_N.RESG_ID
                            AND RES_ID = :MWIPBINREL_N.RES_ID
                        ORDER BY 
                            BIN_ID ASC,
                            BIN_UNIT ASC,
                            LOT_CMF_1 ASC,
                            LOT_CMF_2 ASC,
                            LOT_CMF_3 ASC,
                            LOT_CMF_4 ASC,
                            LOT_CMF_5 ASC,
                            LOT_CMF_6 ASC,
                            LOT_CMF_7 ASC,
                            LOT_CMF_8 ASC,
                            LOT_CMF_9 ASC,
                            LOT_CMF_10 ASC,
                            LOT_CMF_11 ASC,
                            LOT_CMF_12 ASC,
                            LOT_CMF_13 ASC,
                            LOT_CMF_14 ASC,
                            LOT_CMF_15 ASC,
                            LOT_CMF_16 ASC,
                            LOT_CMF_17 ASC,
                            LOT_CMF_18 ASC,
                            LOT_CMF_19 ASC,
                            LOT_CMF_20 ASC
                        ) REL
                    )
                WHERE ROWSEQ >= :DBC_Q_COND_N.FROM_SEQ
                ORDER BY ROWSEQ ASC;
            EXEC SQL OPEN DBC_MWIPBINREL_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MWIPBINREL_CUR_3 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    REL_LEVEL,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RES_TYPE,
                    RESG_ID,
                    RES_ID,
                    LOT_CMF_1,
                    LOT_CMF_2,
                    LOT_CMF_3,
                    LOT_CMF_4,
                    LOT_CMF_5,
                    LOT_CMF_6,
                    LOT_CMF_7,
                    LOT_CMF_8,
                    LOT_CMF_9,
                    LOT_CMF_10,
                    LOT_CMF_11,
                    LOT_CMF_12,
                    LOT_CMF_13,
                    LOT_CMF_14,
                    LOT_CMF_15,
                    LOT_CMF_16,
                    LOT_CMF_17,
                    LOT_CMF_18,
                    LOT_CMF_19,
                    LOT_CMF_20,
                    BIN_ID,
                    BIN_UNIT,
                    COL_OTHER_UNIT_FLAG,
                    RESV_FIELD_1,
                    RESV_FIELD_2,
                    RESV_FIELD_3,
                    RESV_FIELD_4,
                    RESV_FIELD_5,
                    RESV_FIELD_6,
                    RESV_FIELD_7,
                    RESV_FIELD_8,
                    RESV_FIELD_9,
                    RESV_FIELD_10,
                    RESV_FIELD_11,
                    RESV_FIELD_12,
                    RESV_FIELD_13,
                    RESV_FIELD_14,
                    RESV_FIELD_15,
                    RESV_FIELD_16,
                    RESV_FIELD_17,
                    RESV_FIELD_18,
                    RESV_FIELD_19,
                    RESV_FIELD_20
                FROM MWIPBINREL
                WHERE FACTORY = :MWIPBINREL_N.FACTORY
                    AND MAT_ID = :MWIPBINREL_N.MAT_ID
                    AND MAT_VER = :MWIPBINREL_N.MAT_VER
                    AND FLOW = :MWIPBINREL_N.FLOW
                    AND OPER = :MWIPBINREL_N.OPER
                    AND RES_TYPE = :MWIPBINREL_N.RES_TYPE
                    AND RESG_ID = :MWIPBINREL_N.RESG_ID
                    AND RES_ID = :MWIPBINREL_N.RES_ID
                    AND LOT_CMF_1 = :MWIPBINREL_N.LOT_CMF_1
                    AND LOT_CMF_2 = :MWIPBINREL_N.LOT_CMF_2
                    AND LOT_CMF_3 = :MWIPBINREL_N.LOT_CMF_3
                    AND LOT_CMF_4 = :MWIPBINREL_N.LOT_CMF_4
                    AND LOT_CMF_5 = :MWIPBINREL_N.LOT_CMF_5
                    AND LOT_CMF_6 = :MWIPBINREL_N.LOT_CMF_6
                    AND LOT_CMF_7 = :MWIPBINREL_N.LOT_CMF_7
                    AND LOT_CMF_8 = :MWIPBINREL_N.LOT_CMF_8
                    AND LOT_CMF_9 = :MWIPBINREL_N.LOT_CMF_9
                    AND LOT_CMF_10 = :MWIPBINREL_N.LOT_CMF_10
                    AND LOT_CMF_11 = :MWIPBINREL_N.LOT_CMF_11
                    AND LOT_CMF_12 = :MWIPBINREL_N.LOT_CMF_12
                    AND LOT_CMF_13 = :MWIPBINREL_N.LOT_CMF_13
                    AND LOT_CMF_14 = :MWIPBINREL_N.LOT_CMF_14
                    AND LOT_CMF_15 = :MWIPBINREL_N.LOT_CMF_15
                    AND LOT_CMF_16 = :MWIPBINREL_N.LOT_CMF_16
                    AND LOT_CMF_17 = :MWIPBINREL_N.LOT_CMF_17
                    AND LOT_CMF_18 = :MWIPBINREL_N.LOT_CMF_18
                    AND LOT_CMF_19 = :MWIPBINREL_N.LOT_CMF_19
                    AND LOT_CMF_20 = :MWIPBINREL_N.LOT_CMF_20
                ORDER BY BIN_ID ASC, BIN_UNIT ASC;
            EXEC SQL OPEN DBC_MWIPBINREL_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mwipbinrel", sel_type);
}


