            DB_del_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            break;

        case 3:
            EXEC SQL FETCH DBC_MWIPBINREL_CUR_3 INTO
                :MWIPBINREL_N.CREATE_USER_ID,
                :MWIPBINREL_N.CREATE_TIME,
                :MWIPBINREL_N.UPDATE_USER_ID,
