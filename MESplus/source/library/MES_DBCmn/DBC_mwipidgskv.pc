                    :MWIPIDGSKV_N.GEN_ID_SEQ,
                    :MWIPIDGSKV_N.GEN_ID,
                    :MWIPIDGSKV_N.UPDATE_USER_ID,
                    :MWIPIDGSKV_N.UPDATE_TIME,
                    :MWIPIDGSKV_N.SEQ_CONFIRM_KEY,
                    :MWIPIDGSKV_N.CYCLE_INIT_FLAG,
                    :MWIPIDGSKV_N.ID_USED_FLAG,
                    :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_1,
                    :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_2,
                    :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_3,
                    :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_4,
                    :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_5
                FROM MWIPIDGSKV
                WHERE RULE_ID = :MWIPIDGSKV_N.RULE_ID
                    AND RULE_SEQ = :MWIPIDGSKV_N.RULE_SEQ
                    AND FACTORY = :MWIPIDGSKV_N.FACTORY
                    AND MAT_ID = :MWIPIDGSKV_N.MAT_ID
                    AND MAT_VER = :MWIPIDGSKV_N.MAT_VER
                    AND FLOW = :MWIPIDGSKV_N.FLOW
                    AND OPER = :MWIPIDGSKV_N.OPER
                    AND RES_TYPE = :MWIPIDGSKV_N.RES_TYPE
                    AND RESG_ID = :MWIPIDGSKV_N.RESG_ID
                    AND RES_ID = :MWIPIDGSKV_N.RES_ID
                    AND LOT_ID = :MWIPIDGSKV_N.LOT_ID
                    AND SUBLOT_ID = :MWIPIDGSKV_N.SUBLOT_ID
                    AND DATETIME = :MWIPIDGSKV_N.DATETIME
                    AND KEY_1 = :MWIPIDGSKV_N.KEY_1
                    AND KEY_2 = :MWIPIDGSKV_N.KEY_2
                    AND KEY_3 = :MWIPIDGSKV_N.KEY_3
                    AND KEY_4 = :MWIPIDGSKV_N.KEY_4
                    AND KEY_5 = :MWIPIDGSKV_N.KEY_5
                    AND KEY_6 = :MWIPIDGSKV_N.KEY_6
                    AND KEY_7 = :MWIPIDGSKV_N.KEY_7
                    AND KEY_8 = :MWIPIDGSKV_N.KEY_8
                    AND KEY_9 = :MWIPIDGSKV_N.KEY_9
                    AND KEY_10 = :MWIPIDGSKV_N.KEY_10
                    AND GEN_ID_SEQ = :MWIPIDGSKV_N.GEN_ID_SEQ
                FOR UPDATE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwipidgskv(&MWIPIDGSKV_N, MWIPIDGSKV);
    }

    DB_stop_query_timer("DBC_select_mwipidgskv_for_update", sel_type);
}


/* SQL SELECT_SCALAR Function */
double DBC_select_mwipidgskv_scalar(int sel_type, struct MWIPIDGSKV_TAG *MWIPIDGSKV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPIDGSKV_N_TAG MWIPIDGSKV_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipidgskv(&MWIPIDGSKV_N, MWIPIDGSKV);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPIDGSKV
                WHERE RULE_ID = :MWIPIDGSKV_N.RULE_ID
                    AND RULE_SEQ = :MWIPIDGSKV_N.RULE_SEQ
                    AND FACTORY = :MWIPIDGSKV_N.FACTORY
                    AND MAT_ID = :MWIPIDGSKV_N.MAT_ID
                    AND MAT_VER = :MWIPIDGSKV_N.MAT_VER
                    AND FLOW = :MWIPIDGSKV_N.FLOW
                    AND OPER = :MWIPIDGSKV_N.OPER
                    AND RES_TYPE = :MWIPIDGSKV_N.RES_TYPE
                    AND RESG_ID = :MWIPIDGSKV_N.RESG_ID
                    AND RES_ID = :MWIPIDGSKV_N.RES_ID
                    AND LOT_ID = :MWIPIDGSKV_N.LOT_ID
                    AND SUBLOT_ID = :MWIPIDGSKV_N.SUBLOT_ID
                    AND DATETIME = :MWIPIDGSKV_N.DATETIME
                    AND KEY_1 = :MWIPIDGSKV_N.KEY_1
                    AND KEY_2 = :MWIPIDGSKV_N.KEY_2
                    AND KEY_3 = :MWIPIDGSKV_N.KEY_3
                    AND KEY_4 = :MWIPIDGSKV_N.KEY_4
                    AND KEY_5 = :MWIPIDGSKV_N.KEY_5
                    AND KEY_6 = :MWIPIDGSKV_N.KEY_6
                    AND KEY_7 = :MWIPIDGSKV_N.KEY_7
                    AND KEY_8 = :MWIPIDGSKV_N.KEY_8
                    AND KEY_9 = :MWIPIDGSKV_N.KEY_9
                    AND KEY_10 = :MWIPIDGSKV_N.KEY_10
                    AND GEN_ID_SEQ = :MWIPIDGSKV_N.GEN_ID_SEQ;
            break;

        case 2: 
            EXEC SQL SELECT count(*)
                INTO :d_value
                FROM MWIPIDGSKV
                WHERE RULE_ID = :MWIPIDGSKV_N.RULE_ID
                  AND RULE_SEQ = :MWIPIDGSKV_N.RULE_SEQ;
           break;
           
        case 3: 
            EXEC SQL SELECT count(*)
                       INTO :d_value
                       FROM MWIPIDGSKV
                      WHERE RULE_ID = :MWIPIDGSKV_N.RULE_ID;
           break;

        case 4: 
            EXEC SQL SELECT count(*)
                       INTO :d_value
                       FROM MWIPIDGSKV
                      WHERE RULE_ID = :MWIPIDGSKV_N.RULE_ID
                        AND FRONT_SEQ_CONFIRM_KEY_1 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_1
                        AND FRONT_SEQ_CONFIRM_KEY_2 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_2
                        AND FRONT_SEQ_CONFIRM_KEY_3 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_3
                        AND FRONT_SEQ_CONFIRM_KEY_4 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_4
                        AND FRONT_SEQ_CONFIRM_KEY_5 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_5
                        AND ID_USED_FLAG = ' ';
           break;

        case 5: 
            EXEC SQL SELECT count(*)
                       INTO :d_value
                       FROM MWIPIDGSKV
                      WHERE RULE_ID = :MWIPIDGSKV_N.RULE_ID
                        AND RULE_SEQ = :MWIPIDGSKV_N.RULE_SEQ
                        AND GEN_ID_SEQ < :MWIPIDGSKV_N.GEN_ID_SEQ
                        AND FRONT_SEQ_CONFIRM_KEY_1 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_1
                        AND FRONT_SEQ_CONFIRM_KEY_2 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_2
                        AND FRONT_SEQ_CONFIRM_KEY_3 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_3
                        AND FRONT_SEQ_CONFIRM_KEY_4 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_4
                        AND FRONT_SEQ_CONFIRM_KEY_5 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_5;
           break;

		case 6: 
            EXEC SQL SELECT count(*)
                       INTO :d_value
                       FROM MWIPIDGSKV
                      WHERE RULE_ID = :MWIPIDGSKV_N.RULE_ID
                        AND FRONT_SEQ_CONFIRM_KEY_1 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_1
                        AND FRONT_SEQ_CONFIRM_KEY_2 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_2
                        AND FRONT_SEQ_CONFIRM_KEY_3 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_3
                        AND FRONT_SEQ_CONFIRM_KEY_4 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_4
                        AND FRONT_SEQ_CONFIRM_KEY_5 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_5
                        AND ID_USED_FLAG = 'Y';
           break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mwipidgskv_scalar", sel_type);

    return d_value;
}


/* SQL DELETE Function */
void DBC_delete_mwipidgskv(int sel_type, struct MWIPIDGSKV_TAG *MWIPIDGSKV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPIDGSKV_N_TAG MWIPIDGSKV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipidgskv(&MWIPIDGSKV_N, MWIPIDGSKV);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM MWIPIDGSKV
                WHERE RULE_ID = :MWIPIDGSKV_N.RULE_ID
                    AND RULE_SEQ = :MWIPIDGSKV_N.RULE_SEQ
                    AND FACTORY = :MWIPIDGSKV_N.FACTORY
                    AND MAT_ID = :MWIPIDGSKV_N.MAT_ID
                    AND MAT_VER = :MWIPIDGSKV_N.MAT_VER
                    AND FLOW = :MWIPIDGSKV_N.FLOW
