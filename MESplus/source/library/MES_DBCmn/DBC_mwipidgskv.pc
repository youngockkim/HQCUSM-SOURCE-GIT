/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipidgskv(int sel_type, struct MWIPIDGSKV_TAG *MWIPIDGSKV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPIDGSKV_N_TAG MWIPIDGSKV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipidgskv(&MWIPIDGSKV_N, MWIPIDGSKV);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPIDGSKV_CUR_1 CURSOR FOR
                SELECT 
                    RULE_ID,
                    RULE_SEQ,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RES_TYPE,
                    RESG_ID,
                    RES_ID,
                    LOT_ID,
                    SUBLOT_ID,
                    DATETIME,
                    KEY_1,
                    KEY_2,
                    KEY_3,
                    KEY_4,
                    KEY_5,
                    KEY_6,
                    KEY_7,
                    KEY_8,
                    KEY_9,
                    KEY_10,
                    GEN_ID_SEQ,
                    GEN_ID,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    SEQ_CONFIRM_KEY,
                    CYCLE_INIT_FLAG,
                    ID_USED_FLAG,
                    FRONT_SEQ_CONFIRM_KEY_1,
                    FRONT_SEQ_CONFIRM_KEY_2,
                    FRONT_SEQ_CONFIRM_KEY_3,
                    FRONT_SEQ_CONFIRM_KEY_4,
                    FRONT_SEQ_CONFIRM_KEY_5
                FROM MWIPIDGSKV
                WHERE RULE_ID = :MWIPIDGSKV_N.RULE_ID
                    AND RULE_SEQ = :MWIPIDGSKV_N.RULE_SEQ
                    AND FACTORY = :MWIPIDGSKV_N.FACTORY
                    AND MAT_ID = :MWIPIDGSKV_N.MAT_ID
                    AND MAT_VER = :MWIPIDGSKV_N.MAT_VER
                    AND FLOW = :MWIPIDGSKV_N.FLOW
                    AND OPER = :MWIPIDGSKV_N.OPER
                    AND RES_TYPE = :MWIPIDGSKV_N.RES_TYPE
                    AND RESG_ID = :MWIPIDGSKV_N.RESG_ID
                    AND RES_ID = :MWIPIDGSKV_N.RES_ID
                    AND LOT_ID = :MWIPIDGSKV_N.LOT_ID
                    AND SUBLOT_ID = :MWIPIDGSKV_N.SUBLOT_ID
                    AND DATETIME = :MWIPIDGSKV_N.DATETIME
                    AND KEY_1 = :MWIPIDGSKV_N.KEY_1
                    AND KEY_2 = :MWIPIDGSKV_N.KEY_2
                    AND KEY_3 = :MWIPIDGSKV_N.KEY_3
                    AND KEY_4 = :MWIPIDGSKV_N.KEY_4
                    AND KEY_5 = :MWIPIDGSKV_N.KEY_5
                    AND KEY_6 = :MWIPIDGSKV_N.KEY_6
                    AND KEY_7 = :MWIPIDGSKV_N.KEY_7
                    AND KEY_8 = :MWIPIDGSKV_N.KEY_8
                    AND KEY_9 = :MWIPIDGSKV_N.KEY_9
                    AND KEY_10 = :MWIPIDGSKV_N.KEY_10
                    AND GEN_ID_SEQ > :MWIPIDGSKV_N.GEN_ID_SEQ
                    AND ID_USED_FLAG = :MWIPIDGSKV_N.ID_USED_FLAG
               ORDER BY GEN_ID_SEQ ASC;
            EXEC SQL OPEN DBC_MWIPIDGSKV_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPIDGSKV_CUR_2 CURSOR FOR
                SELECT 
                    RULE_ID,
                    RULE_SEQ,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RES_TYPE,
                    RESG_ID,
                    RES_ID,
                    LOT_ID,
                    SUBLOT_ID,
                    DATETIME,
                    KEY_1,
                    KEY_2,
                    KEY_3,
                    KEY_4,
                    KEY_5,
                    KEY_6,
                    KEY_7,
                    KEY_8,
                    KEY_9,
                    KEY_10,
                    GEN_ID_SEQ,
                    GEN_ID,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    SEQ_CONFIRM_KEY,
                    CYCLE_INIT_FLAG,
                    ID_USED_FLAG,
                    FRONT_SEQ_CONFIRM_KEY_1,
                    FRONT_SEQ_CONFIRM_KEY_2,
                    FRONT_SEQ_CONFIRM_KEY_3,
                    FRONT_SEQ_CONFIRM_KEY_4,
                    FRONT_SEQ_CONFIRM_KEY_5
                FROM MWIPIDGSKV
                WHERE RULE_ID = :MWIPIDGSKV_N.RULE_ID
                    AND RULE_SEQ = :MWIPIDGSKV_N.RULE_SEQ
                    AND FACTORY = :MWIPIDGSKV_N.FACTORY
                    AND MAT_ID = :MWIPIDGSKV_N.MAT_ID
                    AND MAT_VER = :MWIPIDGSKV_N.MAT_VER
                    AND FLOW = :MWIPIDGSKV_N.FLOW
                    AND OPER = :MWIPIDGSKV_N.OPER
                    AND RES_TYPE = :MWIPIDGSKV_N.RES_TYPE
                    AND RESG_ID = :MWIPIDGSKV_N.RESG_ID
                    AND RES_ID = :MWIPIDGSKV_N.RES_ID
                    AND LOT_ID = :MWIPIDGSKV_N.LOT_ID
                    AND SUBLOT_ID = :MWIPIDGSKV_N.SUBLOT_ID
                    AND DATETIME = :MWIPIDGSKV_N.DATETIME
                    AND KEY_1 = :MWIPIDGSKV_N.KEY_1
                    AND KEY_2 = :MWIPIDGSKV_N.KEY_2
                    AND KEY_3 = :MWIPIDGSKV_N.KEY_3
                    AND KEY_4 = :MWIPIDGSKV_N.KEY_4
                    AND KEY_5 = :MWIPIDGSKV_N.KEY_5
                    AND KEY_6 = :MWIPIDGSKV_N.KEY_6
                    AND KEY_7 = :MWIPIDGSKV_N.KEY_7
                    AND KEY_8 = :MWIPIDGSKV_N.KEY_8
                    AND KEY_9 = :MWIPIDGSKV_N.KEY_9
                    AND KEY_10 = :MWIPIDGSKV_N.KEY_10
                    AND GEN_ID_SEQ > :MWIPIDGSKV_N.GEN_ID_SEQ
               ORDER BY GEN_ID_SEQ ASC;
            EXEC SQL OPEN DBC_MWIPIDGSKV_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mwipidgskv", sel_type);
}


