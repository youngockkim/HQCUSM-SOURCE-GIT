/* Initialize Function */
void DBC_init_mwipidgskv(struct MWIPIDGSKV_TAG *MWIPIDGSKV)
{
    /* memset by Space */
    memset(MWIPIDGSKV, ' ', sizeof(struct MWIPIDGSKV_TAG));
    
    MWIPIDGSKV->RULE_SEQ = 0;
    MWIPIDGSKV->MAT_VER = 0;
    MWIPIDGSKV->GEN_ID_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mwipidgskv(struct MWIPIDGSKV_N_TAG *MWIPIDGSKV_N, struct MWIPIDGSKV_TAG *MWIPIDGSKV)
{
    /* memset by NULL */
    memset(MWIPIDGSKV_N, '\0', sizeof(struct MWIPIDGSKV_N_TAG));
    
