/* SQL UPDATE Function */
void DBC_update_mwipidgskv(int sel_type, struct MWIPIDGSKV_TAG *MWIPIDGSKV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPIDGSKV_N_TAG MWIPIDGSKV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipidgskv(&MWIPIDGSKV_N, MWIPIDGSKV);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MWIPIDGSKV SET
                    GEN_ID = :MWIPIDGSKV_N.GEN_ID,
                    UPDATE_USER_ID = :MWIPIDGSKV_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MWIPIDGSKV_N.UPDATE_TIME,
                    SEQ_CONFIRM_KEY = :MWIPIDGSKV_N.SEQ_CONFIRM_KEY,
                    CYCLE_INIT_FLAG = :MWIPIDGSKV_N.CYCLE_INIT_FLAG,
                    ID_USED_FLAG = :MWIPIDGSKV_N.ID_USED_FLAG,
                    FRONT_SEQ_CONFIRM_KEY_1 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_1,
                    FRONT_SEQ_CONFIRM_KEY_2 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_2,
                    FRONT_SEQ_CONFIRM_KEY_3 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_3,
                    FRONT_SEQ_CONFIRM_KEY_4 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_4,
                    FRONT_SEQ_CONFIRM_KEY_5 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_5
                WHERE RULE_ID = :MWIPIDGSKV_N.RULE_ID
                    AND RULE_SEQ = :MWIPIDGSKV_N.RULE_SEQ
                    AND FACTORY = :MWIPIDGSKV_N.FACTORY
                    AND MAT_ID = :MWIPIDGSKV_N.MAT_ID
                    AND MAT_VER = :MWIPIDGSKV_N.MAT_VER
                    AND FLOW = :MWIPIDGSKV_N.FLOW
                    AND OPER = :MWIPIDGSKV_N.OPER
                    AND RES_TYPE = :MWIPIDGSKV_N.RES_TYPE
                    AND RESG_ID = :MWIPIDGSKV_N.RESG_ID
                    AND RES_ID = :MWIPIDGSKV_N.RES_ID
                    AND LOT_ID = :MWIPIDGSKV_N.LOT_ID
                    AND SUBLOT_ID = :MWIPIDGSKV_N.SUBLOT_ID
                    AND DATETIME = :MWIPIDGSKV_N.DATETIME
                    AND KEY_1 = :MWIPIDGSKV_N.KEY_1
                    AND KEY_2 = :MWIPIDGSKV_N.KEY_2
                    AND KEY_3 = :MWIPIDGSKV_N.KEY_3
                    AND KEY_4 = :MWIPIDGSKV_N.KEY_4
                    AND KEY_5 = :MWIPIDGSKV_N.KEY_5
                    AND KEY_6 = :MWIPIDGSKV_N.KEY_6
                    AND KEY_7 = :MWIPIDGSKV_N.KEY_7
                    AND KEY_8 = :MWIPIDGSKV_N.KEY_8
                    AND KEY_9 = :MWIPIDGSKV_N.KEY_9
                    AND KEY_10 = :MWIPIDGSKV_N.KEY_10
                    AND GEN_ID_SEQ = :MWIPIDGSKV_N.GEN_ID_SEQ;
            break;

        case 2:
            EXEC SQL UPDATE MWIPIDGSKV SET
                   RULE_SEQ = RULE_SEQ - 1
                WHERE RULE_ID = :MWIPIDGSKV_N.RULE_ID
                    AND RULE_SEQ = :MWIPIDGSKV_N.RULE_SEQ;
            break;
            
        case 3:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);

            EXEC SQL UPDATE MWIPIDGSKV SET
                   RULE_SEQ =  :MWIPIDGSKV_N.RULE_SEQ
                WHERE RULE_ID = :MWIPIDGSKV_N.RULE_ID
                    AND RULE_SEQ =  :DBC_Q_COND_N.FROM_SEQ;
            break;

        case 4:
            EXEC SQL UPDATE MWIPIDGSKV SET
                    FRONT_SEQ_CONFIRM_KEY_1 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_1,
                    FRONT_SEQ_CONFIRM_KEY_2 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_2,
                    FRONT_SEQ_CONFIRM_KEY_3 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_3,
                    FRONT_SEQ_CONFIRM_KEY_4 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_4,
                    FRONT_SEQ_CONFIRM_KEY_5 = :MWIPIDGSKV_N.FRONT_SEQ_CONFIRM_KEY_5
                WHERE RULE_ID = :MWIPIDGSKV_N.RULE_ID
                    AND RULE_SEQ = :MWIPIDGSKV_N.RULE_SEQ
                    AND FACTORY = :MWIPIDGSKV_N.FACTORY
                    AND MAT_ID = :MWIPIDGSKV_N.MAT_ID
                    AND MAT_VER = :MWIPIDGSKV_N.MAT_VER
                    AND FLOW = :MWIPIDGSKV_N.FLOW
                    AND OPER = :MWIPIDGSKV_N.OPER
                    AND RES_TYPE = :MWIPIDGSKV_N.RES_TYPE
                    AND RESG_ID = :MWIPIDGSKV_N.RESG_ID
                    AND RES_ID = :MWIPIDGSKV_N.RES_ID
                    AND LOT_ID = :MWIPIDGSKV_N.LOT_ID
                    AND SUBLOT_ID = :MWIPIDGSKV_N.SUBLOT_ID
                    AND DATETIME = :MWIPIDGSKV_N.DATETIME
                    AND KEY_1 = :MWIPIDGSKV_N.KEY_1
                    AND KEY_2 = :MWIPIDGSKV_N.KEY_2
                    AND KEY_3 = :MWIPIDGSKV_N.KEY_3
                    AND KEY_4 = :MWIPIDGSKV_N.KEY_4
                    AND KEY_5 = :MWIPIDGSKV_N.KEY_5
                    AND KEY_6 = :MWIPIDGSKV_N.KEY_6
                    AND KEY_7 = :MWIPIDGSKV_N.KEY_7
                    AND KEY_8 = :MWIPIDGSKV_N.KEY_8
                    AND KEY_9 = :MWIPIDGSKV_N.KEY_9
                    AND KEY_10 = :MWIPIDGSKV_N.KEY_10
                    AND GEN_ID_SEQ = :MWIPIDGSKV_N.GEN_ID_SEQ;
            break;

        case 5: /* DLLH żˇĽ­ »çżë */
            EXEC SQL UPDATE MWIPIDGSKV SET
                    ID_USED_FLAG = :MWIPIDGSKV_N.ID_USED_FLAG
                WHERE SEQ_CONFIRM_KEY = :MWIPIDGSKV_N.SEQ_CONFIRM_KEY;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
