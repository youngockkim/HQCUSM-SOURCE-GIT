void DBC_add_null_medcchrdef(struct MEDCCHRDEF_N_TAG *MEDCCHRDEF_N, struct MEDCCHRDEF_TAG *MEDCCHRDEF)
{
    /* memset by NULL */
    memset(MEDCCHRDEF_N, '\0', sizeof(struct MEDCCHRDEF_N_TAG));
    
