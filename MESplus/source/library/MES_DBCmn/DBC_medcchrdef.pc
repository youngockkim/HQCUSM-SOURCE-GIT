                    CHAR_TYPE,
                    VALID_TABLE,
                    ATTACH_FILE_DIR
                FROM MEDCCHRDEF
                WHERE FACTORY = :MEDCCHRDEF_N.FACTORY
                    AND VALUE_TYPE = 'N'
                    AND CHAR_ID >= :MEDCCHRDEF_N.CHAR_ID
                ORDER BY CHAR_ID ASC;
            EXEC SQL OPEN DBC_MEDCCHRDEF_CUR_3;
            break;

        case 4:
            EXEC SQL DECLARE DBC_MEDCCHRDEF_CUR_4 CURSOR FOR
