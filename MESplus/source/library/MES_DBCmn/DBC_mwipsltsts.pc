            sprintf(sql + strlen(sql),   "SLT.RESV_FLAG_5 ");
            sprintf(sql + strlen(sql), "FROM MWIPSLTSTS SLT, MWIPCRRLOT CRR WHERE ");

            make_valid_quote(ts, MWIPSLTSTS_N.FACTORY);
            sprintf(sql + strlen(sql), "CRR.FACTORY = '%s'", ts);
            make_valid_quote(ts, MWIPSLTSTS_N.CRR_ID);
            sprintf(sql + strlen(sql), "    AND CRR.CRR_ID = '%s'", ts); 
            if(ISSPACE(MWIPSLTSTS->LOT_ID, sizeof(MWIPSLTSTS->LOT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MWIPSLTSTS_N.LOT_ID);
                sprintf(sql + strlen(sql), " AND SLT.LOT_ID = '%s'", ts);
            }
            sprintf(sql + strlen(sql), "    AND SLT.SUBLOT_DEL_FLAG = ' '");
            sprintf(sql + strlen(sql), "    AND SLT.LOT_ID = CRR.LOT_ID");
            sprintf(sql + strlen(sql), "    AND SLT.CRR_ID = CRR.CRR_ID");
            sprintf(sql + strlen(sql), "    AND SLT.FACTORY = CRR.FACTORY");
            if(MWIPSLTSTS_N.SLOT_NO > 0)
            {
                sprintf(sql + strlen(sql), "    AND SLT.SLOT_NO >= %d", MWIPSLTSTS_N.SLOT_NO);
            }
            sprintf(sql + strlen(sql), " ORDER BY SLT.SLOT_NO, SLT.SUBLOT_ID");

