                    :MWIPSLTSTS_N.GRADE_CODE,
                    :MWIPSLTSTS_N.CELL_GRADE,
                    :MWIPSLTSTS_N.CELL_JUDGE,
                    :MWIPSLTSTS_N.LOT_BASE,
                    :MWIPSLTSTS_N.LOT_HIST_SEQ,
                    :MWIPSLTSTS_N.LAST_TRAN_CODE,
                    :MWIPSLTSTS_N.LAST_TRAN_TIME,
                    :MWIPSLTSTS_N.LAST_COMMENT,
                    :MWIPSLTSTS_N.LAST_ACTIVE_HIST_SEQ,
                    :MWIPSLTSTS_N.LAST_HIST_SEQ,
                    :MWIPSLTSTS_N.SUBLOT_TYPE,
