                    SUBLOT_CMF_14,
                    SUBLOT_CMF_15,
                    SUBLOT_CMF_16,
                    SUBLOT_CMF_17,
                    SUBLOT_CMF_18,
                    SUBLOT_CMF_19,
                    SUBLOT_CMF_20,
                    SUBLOT_DEL_FLAG,
                    SUBLOT_DEL_CODE,
                    SUBLOT_DEL_TIME,
                    GRADE,
                    GRADE_CODE,
                    CELL_GRADE,
                    CELL_JUDGE,
                    LOT_BASE,
                    LOT_HIST_SEQ,
                    LAST_TRAN_CODE,
                    LAST_TRAN_TIME,
                    LAST_COMMENT,
                    LAST_ACTIVE_HIST_SEQ,
                    LAST_HIST_SEQ,
                    SUBLOT_TYPE,
                    RESV_FIELD_1,
                    RESV_FIELD_2,
                    RESV_FIELD_3,
                    RESV_FIELD_4,
                    RESV_FIELD_5,
                    RESV_FLAG_1,
                    RESV_FLAG_2,
                    RESV_FLAG_3,
                    RESV_FLAG_4,
                    RESV_FLAG_5,
                    CRR_SEQ
                FROM (
                    SELECT SLT.*, NVL(CRR.CRR_SEQ, 0) AS CRR_SEQ
                    FROM MWIPSLTSTS SLT, MWIPCRRLOT CRR 
                    WHERE SLT.LOT_ID = :MWIPSLTSTS_N.LOT_ID
                        AND SLT.SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG
                        AND SLT.LOT_ID = CRR.LOT_ID(+)
                        AND SLT.CRR_ID = CRR.CRR_ID(+)
                    )
                WHERE ((SLOT_NO <= :MWIPSLTSTS_N.SLOT_NO AND CRR_SEQ = :MWIPSLTSTS_N.MAT_VER) OR CRR_SEQ > :MWIPSLTSTS_N.MAT_VER)
                ORDER BY CRR_SEQ ASC, SLOT_NO DESC, SUBLOT_ID ASC;
            EXEC SQL OPEN DBC_MWIPSLTSTS_CUR_15;
            break;

        case 16:
            EXEC SQL DECLARE DBC_MWIPSLTSTS_CUR_16 CURSOR FOR 
                SELECT 
                    SUBLOT_ID,
                    LOT_ID,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
