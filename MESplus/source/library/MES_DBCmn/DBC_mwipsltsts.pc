/* SQL UPDATE Function */
void DBC_update_mwipsltsts(int sel_type, struct MWIPSLTSTS_TAG *MWIPSLTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSLTSTS_N_TAG MWIPSLTSTS_N;
        struct MWIPSLTSTS_TAG   MWIPSLTSTS_S;
        char   sql[10000];
        char   ts[1000];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipsltsts(&MWIPSLTSTS_N, MWIPSLTSTS);
    DB_error_code = 0;
    memset(sql, 0x00, sizeof(sql));
    memset(ts, 0x00, sizeof(ts));

    switch(sel_type)
    {
        case 1:
            DBC_init_mwipsltsts(&MWIPSLTSTS_S);
            memcpy(MWIPSLTSTS_S.SUBLOT_ID, MWIPSLTSTS->SUBLOT_ID, sizeof(MWIPSLTSTS_S.SUBLOT_ID));
            DBC_select_mwipsltsts(1, &MWIPSLTSTS_S);
            if(DB_error_code != DB_SUCCESS) break;

            make_valid_quote(ts, MWIPSLTSTS_N.SUBLOT_ID);
            sprintf(sql, "UPDATE MWIPSLTSTS SET SUBLOT_ID='%s'", ts);

            if(memcmp(MWIPSLTSTS->LOT_ID, MWIPSLTSTS_S.LOT_ID, sizeof(MWIPSLTSTS->LOT_ID)) != 0) {
                make_valid_quote(ts, MWIPSLTSTS_N.LOT_ID);
