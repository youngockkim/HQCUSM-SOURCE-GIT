            EXEC SQL CLOSE DBC_MWIPSLTSTS_CUR_7;
            break;

        case 8:
            EXEC SQL CLOSE DBC_MWIPSLTSTS_CUR_8;
            break;

        case 9:
            EXEC SQL CLOSE DBC_MWIPSLTSTS_CUR_9;
            break;

        case 10:
            EXEC SQL CLOSE DBC_MWIPSLTSTS_CUR_10;
            break;

        case 11:
            EXEC SQL CLOSE DBC_MWIPSLTSTS_CUR_11;
            break;

        case 12:
            EXEC SQL CLOSE DBC_MWIPSLTSTS_CUR_12;
            break;

        case 13:
            EXEC SQL CLOSE DBC_MWIPSLTSTS_CUR_13;
            break;

        case 14:
