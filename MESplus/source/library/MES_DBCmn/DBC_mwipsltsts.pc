                    HOLD_PASSWORD,
                    HOLD_PRV_GRP_ID,
                    OPER_IN_QTY_2,
                    OPER_IN_QTY_3,
                    CREATE_QTY_2,
                    CREATE_QTY_3,
                    START_QTY_2,
                    START_QTY_3,
                    INV_FLAG,
