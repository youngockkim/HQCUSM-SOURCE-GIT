                    :MWIPSLTSTS_N.RESV_FLAG_4,
                    :MWIPSLTSTS_N.RESV_FLAG_5
                FROM MWIPSLTSTS
                WHERE LOT_ID = :MWIPSLTSTS_N.LOT_ID
                    AND SLOT_NO = :MWIPSLTSTS_N.SLOT_NO
                    AND SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG 
                    AND ROWNUM = 1;
            break;

        case 3:
            EXEC SQL SELECT DISTINCT HIS.OLD_FACTORY, HIS.OLD_OPER 
                INTO :MWIPSLTSTS_N.FACTORY, :MWIPSLTSTS_N.OPER
                FROM MWIPSLTSTS STS, MWIPSLTHIS HIS
                WHERE STS.LOT_ID = :MWIPSLTSTS_N.LOT_ID
                    AND STS.SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG
                    AND STS.UNIT_EXIST_FLAG = :MWIPSLTSTS_N.UNIT_EXIST_FLAG
                    AND STS.SUBLOT_ID = HIS.SUBLOT_ID
                    AND STS.LAST_ACTIVE_HIST_SEQ = HIS.HIST_SEQ;
            break;

        case 4:
            EXEC SQL SELECT MAX(SUBLOT_ID)
                INTO :MWIPSLTSTS_N.SUBLOT_ID
                FROM MWIPSLTSTS
                WHERE LOT_ID = :MWIPSLTSTS_N.LOT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwipsltsts(&MWIPSLTSTS_N, MWIPSLTSTS);
    }
    DB_stop_query_timer("DBC_select_mwipsltsts", sel_type);
}


