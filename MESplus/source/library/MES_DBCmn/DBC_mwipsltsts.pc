            break;

        case 15:
            EXEC SQL CLOSE DBC_MWIPSLTSTS_CUR_15;
            break;

        case 16:
            EXEC SQL CLOSE DBC_MWIPSLTSTS_CUR_16;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipsltsts", sel_type);
}


/* Initialize Function */
void DBC_init_mwipsltsts(struct MWIPSLTSTS_TAG *MWIPSLTSTS)
{
