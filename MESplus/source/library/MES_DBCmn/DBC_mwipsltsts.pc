                    :MWIPSLTSTS_N.RESV_FIELD_5,
                    :MWIPSLTSTS_N.RESV_FLAG_1,
                    :MWIPSLTSTS_N.RESV_FLAG_2,
                    :MWIPSLTSTS_N.RESV_FLAG_3,
                    :MWIPSLTSTS_N.RESV_FLAG_4,
                    :MWIPSLTSTS_N.RESV_FLAG_5
                FROM MWIPSLTSTS
                WHERE SUBLOT_ID = :MWIPSLTSTS_N.SUBLOT_ID
                FOR UPDATE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwipsltsts(&MWIPSLTSTS_N, MWIPSLTSTS);
    }
    DB_stop_query_timer("DBC_select_mwipsltsts_for_update", sel_type);
}


/* SQL SELECT_SCALAR Function */
double DBC_select_mwipsltsts_scalar(int sel_type, struct MWIPSLTSTS_TAG *MWIPSLTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSLTSTS_N_TAG MWIPSLTSTS_N;
        int    i_value;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipsltsts(&MWIPSLTSTS_N, MWIPSLTSTS);
    DB_error_code = 0;
    i_value = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :i_value
                FROM MWIPSLTSTS
                WHERE LOT_ID = :MWIPSLTSTS_N.LOT_ID;
                
            d_value = (double) i_value;
            break;
            
        case 2:
            EXEC SQL SELECT count(*) 
                INTO :i_value
                FROM MWIPSLTSTS
                WHERE LOT_ID = :MWIPSLTSTS_N.LOT_ID AND
                      SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG;

            d_value = (double) i_value;
            break;

        case 3:
            EXEC SQL SELECT NVL(sum(QTY_2), 0)
                INTO :d_value
                FROM MWIPSLTSTS
                WHERE LOT_ID = :MWIPSLTSTS_N.LOT_ID AND
                      SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG;
            break;

        case 4:
            EXEC SQL SELECT count(*) 
                INTO :i_value
                FROM MWIPSLTSTS
                WHERE LOT_ID = :MWIPSLTSTS_N.LOT_ID AND
                      OPER = :MWIPSLTSTS_N.OPER AND
                      SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG;

            d_value = (double) i_value;
            break;

        case 5:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPSLTSTS
                WHERE LOT_ID = :MWIPSLTSTS_N.LOT_ID AND
                      SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG AND
                      CRR_ID = :MWIPSLTSTS_N.CRR_ID;

            break;

        case 6:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPSLTSTS
                WHERE LOT_ID = :MWIPSLTSTS_N.LOT_ID AND
                      UNIT_EXIST_FLAG = 'Y' AND
                      LOT_BASE = 'Y';

            break;
            
        case 7:
            EXEC SQL SELECT count(*) 
                INTO :i_value
                FROM MWIPSLTSTS
                WHERE LOT_ID = :MWIPSLTSTS_N.LOT_ID
                    AND SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG
                    AND UNIT_EXIST_FLAG = :MWIPSLTSTS_N.UNIT_EXIST_FLAG;

            d_value = (double) i_value;
            break;
            
        case 8:
            EXEC SQL SELECT count(*) 
                INTO :i_value
                FROM MWIPSLTSTS
                WHERE LOT_ID = :MWIPSLTSTS_N.LOT_ID
                    AND SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG
                    AND UNIT_EXIST_FLAG = :MWIPSLTSTS_N.UNIT_EXIST_FLAG
                    AND OPER = :MWIPSLTSTS_N.OPER;

            d_value = (double) i_value;
            break;

        case 9:
            EXEC SQL SELECT NVL(MAX(SLOT_NO), 0) 
                INTO :i_value
                FROM MWIPSLTSTS
                WHERE LOT_ID = :MWIPSLTSTS_N.LOT_ID
                    AND SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG
                    AND UNIT_EXIST_FLAG = :MWIPSLTSTS_N.UNIT_EXIST_FLAG;

            d_value = (double) i_value;
            break;


        case 10:
            EXEC SQL SELECT count(*) 
                INTO :i_value
                FROM MWIPSLTSTS
                WHERE FACTORY = :MWIPSLTSTS_N.FACTORY
                    AND SUBLOT_ID <> :MWIPSLTSTS_N.SUBLOT_ID
                    AND CRR_ID = :MWIPSLTSTS_N.CRR_ID
                    AND SLOT_NO = :MWIPSLTSTS_N.SLOT_NO
                    AND SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG;

            d_value = (double) i_value;
            break;

        case 11:
            EXEC SQL SELECT count(*) 
                INTO :i_value
                FROM MWIPSLTSTS
                WHERE FACTORY = :MWIPSLTSTS_N.FACTORY
                    AND SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG
                    AND CRR_ID = :MWIPSLTSTS_N.CRR_ID;

            d_value = (double) i_value;
            break;

        case 12:
            EXEC SQL SELECT count(*) 
                INTO :i_value
                FROM MWIPSLTSTS
                WHERE FACTORY = :MWIPSLTSTS_N.FACTORY
                    AND CRR_ID = :MWIPSLTSTS_N.CRR_ID
                    AND SLOT_NO = :MWIPSLTSTS_N.SLOT_NO
                    AND SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG;

            d_value = (double) i_value;
            break;

        case 13:
            EXEC SQL SELECT count(*) 
                INTO :i_value
                FROM MWIPSLTSTS
                WHERE FACTORY = :MWIPSLTSTS_N.FACTORY
                    AND LOT_ID = :MWIPSLTSTS_N.LOT_ID
                    AND CRR_ID = :MWIPSLTSTS_N.CRR_ID
                    AND SLOT_NO = :MWIPSLTSTS_N.SLOT_NO
                    AND SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG;

            d_value = (double) i_value;
            break;

        case 14:
            EXEC SQL SELECT NVL(MAX(SLOT_NO), 0) 
                INTO :i_value
                FROM MWIPSLTSTS
                WHERE CRR_ID = :MWIPSLTSTS_N.CRR_ID
                    AND SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG
                    AND UNIT_EXIST_FLAG = :MWIPSLTSTS_N.UNIT_EXIST_FLAG;

            d_value = (double) i_value;
            break;
            
        case 15:
            EXEC SQL SELECT NVL(SUM(QTY_2), 0) 
                INTO :i_value
                FROM MWIPSLTSTS
                WHERE LOT_ID = :MWIPSLTSTS_N.LOT_ID
                    AND SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG
                    AND UNIT_EXIST_FLAG = :MWIPSLTSTS_N.UNIT_EXIST_FLAG;

            d_value = (double) i_value;
            break;

        case 16:
            EXEC SQL SELECT count(*) 
                INTO :i_value
                FROM MWIPSLTSTS
                WHERE LOT_ID = :MWIPSLTSTS_N.LOT_ID
                    AND SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG
                    AND GRADE NOT IN ('F', 'R');

            d_value = (double) i_value;
            break;

        case 17:
            EXEC SQL SELECT count(*) 
                INTO :i_value
                FROM MWIPSLTSTS
                WHERE LOT_ID = :MWIPSLTSTS_N.LOT_ID
                    AND SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG
                    AND LOT_BASE = :MWIPSLTSTS_N.LOT_BASE
                    AND OPER = :MWIPSLTSTS_N.OPER
                    AND START_FLAG = :MWIPSLTSTS_N.START_FLAG;

            d_value = (double) i_value;
            break;

        case 18:
            EXEC SQL SELECT count(*) 
                INTO :i_value
                FROM MWIPSLTSTS
                WHERE LOT_ID = :MWIPSLTSTS_N.LOT_ID
                    AND SUBLOT_DEL_FLAG = :MWIPSLTSTS_N.SUBLOT_DEL_FLAG
                    /* AND LOT_BASE = :MWIPSLTSTS_N.LOT_BASE */
                    AND OPER = :MWIPSLTSTS_N.OPER
                    AND END_FLAG = :MWIPSLTSTS_N.END_FLAG;

            d_value = (double) i_value;
            break;



        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mwipsltsts_scalar", sel_type);
    return d_value;
}


/* SQL DELETE Function */
void DBC_delete_mwipsltsts(int sel_type, struct MWIPSLTSTS_TAG *MWIPSLTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSLTSTS_N_TAG MWIPSLTSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipsltsts(&MWIPSLTSTS_N, MWIPSLTSTS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM MWIPSLTSTS
                WHERE SUBLOT_ID = :MWIPSLTSTS_N.SUBLOT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_delete_mwipsltsts", sel_type);
}


