            }

            make_valid_quote(ts, MWIPSLTSTS_N.SUBLOT_ID);
            sprintf(sql + strlen(sql), " WHERE SUBLOT_ID='%s'", ts);

            EXEC SQL EXECUTE IMMEDIATE :sql;
            break;
            
        case 2:
            EXEC SQL UPDATE MWIPSLTSTS SET
                    GRADE = :MWIPSLTSTS_N.GRADE,
                    GRADE_CODE = :MWIPSLTSTS_N.GRADE_CODE,
                    CELL_GRADE = :MWIPSLTSTS_N.CELL_GRADE,
                    CELL_JUDGE = :MWIPSLTSTS_N.CELL_JUDGE
                WHERE SUBLOT_ID = :MWIPSLTSTS_N.SUBLOT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mwipsltsts", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipsltsts(int sel_type, struct MWIPSLTSTS_TAG *MWIPSLTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSLTSTS_N_TAG MWIPSLTSTS_N;
        char sql[10000];
        char ts[1000];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipsltsts(&MWIPSLTSTS_N, MWIPSLTSTS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPSLTSTS_CUR_1 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    LOT_ID,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    SLOT_NO,
