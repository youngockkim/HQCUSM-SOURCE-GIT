                    TRAN_CMF_9 = :MWIPSLTHIS_N.TRAN_CMF_9,
                    TRAN_CMF_10 = :MWIPSLTHIS_N.TRAN_CMF_10,
                    TRAN_CMF_11 = :MWIPSLTHIS_N.TRAN_CMF_11,
                    TRAN_CMF_12 = :MWIPSLTHIS_N.TRAN_CMF_12,
                    TRAN_CMF_13 = :MWIPSLTHIS_N.TRAN_CMF_13,
                    TRAN_CMF_14 = :MWIPSLTHIS_N.TRAN_CMF_14,
                    TRAN_CMF_15 = :MWIPSLTHIS_N.TRAN_CMF_15,
                    TRAN_CMF_16 = :MWIPSLTHIS_N.TRAN_CMF_16,
                    TRAN_CMF_17 = :MWIPSLTHIS_N.TRAN_CMF_17,
                    TRAN_CMF_18 = :MWIPSLTHIS_N.TRAN_CMF_18,
                    TRAN_CMF_19 = :MWIPSLTHIS_N.TRAN_CMF_19,
                    TRAN_CMF_20 = :MWIPSLTHIS_N.TRAN_CMF_20,
                    TRAN_USER_ID = :MWIPSLTHIS_N.TRAN_USER_ID,
                    TRAN_COMMENT = :MWIPSLTHIS_N.TRAN_COMMENT,
                    PREV_ACTIVE_HIST_SEQ = :MWIPSLTHIS_N.PREV_ACTIVE_HIST_SEQ,
                    MULTI_TR_KEY = :MWIPSLTHIS_N.MULTI_TR_KEY,
                    MULTI_TR_SEQ = :MWIPSLTHIS_N.MULTI_TR_SEQ,
                    EXT_HIST_SEQ = :MWIPSLTHIS_N.EXT_HIST_SEQ,
                    HIST_DEL_FLAG = :MWIPSLTHIS_N.HIST_DEL_FLAG,
                    HIST_DEL_TIME = :MWIPSLTHIS_N.HIST_DEL_TIME,
                    HIST_DEL_USER_ID = :MWIPSLTHIS_N.HIST_DEL_USER_ID,
                    HIST_DEL_COMMENT = :MWIPSLTHIS_N.HIST_DEL_COMMENT
                WHERE SUBLOT_ID = :MWIPSLTHIS_N.SUBLOT_ID
                    AND HIST_SEQ = :MWIPSLTHIS_N.HIST_SEQ;
            break;
            
        case 2: /* DLLH */
            EXEC SQL UPDATE MWIPSLTHIS SET 
                    HIST_DEL_FLAG = :MWIPSLTHIS_N.HIST_DEL_FLAG,
                    HIST_DEL_TIME = :MWIPSLTHIS_N.HIST_DEL_TIME,
                    HIST_DEL_USER_ID = :MWIPSLTHIS_N.HIST_DEL_USER_ID,
                    HIST_DEL_COMMENT = :MWIPSLTHIS_N.HIST_DEL_COMMENT
                WHERE SUBLOT_ID = :MWIPSLTHIS_N.SUBLOT_ID
                    AND HIST_SEQ = :MWIPSLTHIS_N.HIST_SEQ;  
            break;

        case 3: /* DLLH */
            EXEC SQL UPDATE MWIPSLTHIS SET 
                    CRR_ID = :MWIPSLTHIS_N.CRR_ID,
                    SLOT_NO = :MWIPSLTHIS_N.SLOT_NO
                WHERE SUBLOT_ID = :MWIPSLTHIS_N.SUBLOT_ID
                    AND HIST_SEQ = :MWIPSLTHIS_N.HIST_SEQ;  
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mwipslthis", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipslthis(int sel_type, struct MWIPSLTHIS_TAG *MWIPSLTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSLTHIS_N_TAG MWIPSLTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    
