EXEC SQL BEGIN DECLARE SECTION;
    struct MWIPSLTHIS_N_TAG MWIPSLTHIS_N_FOR_ARRAY[MP_SIZE_MAX_HOST_ARRAY];
    unsigned int i_mwipslthis_insert_array_size;
EXEC SQL END DECLARE SECTION;

void DBC_perform_mwipslthis_insert_array()
{
    DB_start_query_timer();
    DB_error_code = 0;

    if(i_mwipslthis_insert_array_size > 0)
    {
        if(i_mwipslthis_insert_array_size > MP_SIZE_MAX_HOST_ARRAY)
        {
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Exceed array size for insert...", strlen("Error : Exceed array size for insert..."));
        }
        else
        {
            EXEC SQL FOR :i_mwipslthis_insert_array_size
                INSERT INTO MWIPSLTHIS VALUES (:MWIPSLTHIS_N_FOR_ARRAY);

            i_mwipslthis_insert_array_size = 0;
        }
    }

    DB_stop_query_timer("DBC_perform_mwipslthis_insert_array", 0);
}

void DBC_add_mwipslthis_insert_array(struct MWIPSLTHIS_TAG *MWIPSLTHIS)
{
    DB_error_code = 0;

    if(i_mwipslthis_insert_array_size >= MP_SIZE_MAX_HOST_ARRAY)
    {
        DBC_perform_mwipslthis_insert_array();
    }

    DBC_add_null_mwipslthis(&MWIPSLTHIS_N_FOR_ARRAY[i_mwipslthis_insert_array_size], MWIPSLTHIS);
    i_mwipslthis_insert_array_size++;
}

void DBC_init_mwipslthis_insert_array()
{
    i_mwipslthis_insert_array_size = 0;
}


