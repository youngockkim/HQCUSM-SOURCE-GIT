/* SQL SELECT_SCALAR Function */
double DBC_select_mwipslthis_scalar(int sel_type, struct MWIPSLTHIS_TAG *MWIPSLTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSLTHIS_N_TAG MWIPSLTHIS_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipslthis(&MWIPSLTHIS_N, MWIPSLTHIS);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPSLTHIS
                WHERE SUBLOT_ID = :MWIPSLTHIS_N.SUBLOT_ID
                    AND HIST_SEQ = :MWIPSLTHIS_N.HIST_SEQ;
            break;

        case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPSLTHIS
                WHERE SUBLOT_ID = :MWIPSLTHIS_N.SUBLOT_ID
                    AND HIST_DEL_FLAG = :MWIPSLTHIS_N.HIST_DEL_FLAG
                    AND TRAN_CODE = :MWIPSLTHIS_N.TRAN_CODE
                    AND OLD_FACTORY = :MWIPSLTHIS_N.FACTORY
                    AND OLD_FLOW = :MWIPSLTHIS_N.FLOW
                    AND OLD_FLOW_SEQ_NUM = :MWIPSLTHIS_N.FLOW_SEQ_NUM
                    AND OLD_OPER = :MWIPSLTHIS_N.OPER;
            break;

        case 3: /* Not Allow Duplicate Flow Seq Num Case : Against Case 2 */
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPSLTHIS
                WHERE SUBLOT_ID = :MWIPSLTHIS_N.SUBLOT_ID
                    AND HIST_DEL_FLAG = :MWIPSLTHIS_N.HIST_DEL_FLAG
                    AND TRAN_CODE = :MWIPSLTHIS_N.TRAN_CODE
                    AND OLD_FACTORY = :MWIPSLTHIS_N.FACTORY
                    AND OLD_FLOW = :MWIPSLTHIS_N.FLOW
                    /* AND OLD_FLOW_SEQ_NUM = :MWIPSLTHIS_N.FLOW_SEQ_NUM */
                    AND OLD_OPER = :MWIPSLTHIS_N.OPER;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mwipslthis_scalar", sel_type);
    return d_value;
}


/* SQL DELETE Function */
void DBC_delete_mwipslthis(int sel_type, struct MWIPSLTHIS_TAG *MWIPSLTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSLTHIS_N_TAG MWIPSLTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipslthis(&MWIPSLTHIS_N, MWIPSLTHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM MWIPSLTHIS
                WHERE SUBLOT_ID = :MWIPSLTHIS_N.SUBLOT_ID
                    AND HIST_SEQ = :MWIPSLTHIS_N.HIST_SEQ;
            break;

        case 2:
            EXEC SQL DELETE FROM MWIPSLTHIS
                WHERE SUBLOT_ID = :MWIPSLTHIS_N.SUBLOT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_delete_mwipslthis", sel_type);
}


