            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwipslthis(&MWIPSLTHIS_N, MWIPSLTHIS);
    }
    DB_stop_query_timer("DBC_fetch_mwipslthis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwipslthis(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPSLTHIS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWIPSLTHIS_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MWIPSLTHIS_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MWIPSLTHIS_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MWIPSLTHIS_CUR_5;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipslthis", sel_type);
}


/* Initialize Function */
void DBC_init_mwipslthis(struct MWIPSLTHIS_TAG *MWIPSLTHIS)
{
    /* memset by Space */
    memset(MWIPSLTHIS, ' ', sizeof(struct MWIPSLTHIS_TAG));
    
    MWIPSLTHIS->HIST_SEQ = 0;
    MWIPSLTHIS->MAT_VER = 0;
    MWIPSLTHIS->FLOW_SEQ_NUM = 0;
    MWIPSLTHIS->SLOT_NO = 0;
    MWIPSLTHIS->QTY_2 = 0;
    MWIPSLTHIS->QTY_3 = 0;
    MWIPSLTHIS->OPER_IN_QTY_2 = 0;
    MWIPSLTHIS->OPER_IN_QTY_3 = 0;
    MWIPSLTHIS->CREATE_QTY_2 = 0;
    MWIPSLTHIS->CREATE_QTY_3 = 0;
    MWIPSLTHIS->START_QTY_2 = 0;
    MWIPSLTHIS->START_QTY_3 = 0;
    MWIPSLTHIS->RWK_COUNT = 0;
    MWIPSLTHIS->RWK_RET_FLOW_SEQ_NUM = 0;
    MWIPSLTHIS->RWK_END_FLOW_SEQ_NUM = 0;
    MWIPSLTHIS->NSTD_RET_FLOW_SEQ_NUM = 0;
    MWIPSLTHIS->LOT_HIST_SEQ = 0;
    MWIPSLTHIS->OLD_MAT_VER = 0;
    MWIPSLTHIS->OLD_FLOW_SEQ_NUM = 0;
    MWIPSLTHIS->OLD_QTY_2 = 0;
    MWIPSLTHIS->OLD_QTY_3 = 0;
    MWIPSLTHIS->PREV_ACTIVE_HIST_SEQ = 0;
    MWIPSLTHIS->MULTI_TR_SEQ = 0;
    MWIPSLTHIS->STR_RET_FLOW_SEQ_NUM = 0;
    MWIPSLTHIS->EXT_HIST_SEQ = 0;
}


