        case 4:
            EXEC SQL SELECT HIS.SUBLOT_ID, HIS.LOT_ID, HIS.CRR_ID, HIS.SLOT_NO, HIS.GRADE, GCM.DATA_2 GRADE_CODE
                       INTO :MWIPSLTHIS_N.SUBLOT_ID, :MWIPSLTHIS_N.LOT_ID, :MWIPSLTHIS_N.CRR_ID, :MWIPSLTHIS_N.SLOT_NO, :MWIPSLTHIS_N.GRADE, :MWIPSLTHIS_N.OLD_CRR_ID
                       FROM MWIPSLTHIS HIS, MGCMTBLDAT GCM
                      WHERE HIS.FACTORY = :MWIPSLTHIS_N.FACTORY
                        AND HIS.SUBLOT_ID = :MWIPSLTHIS_N.SUBLOT_ID
                        AND HIS.HIST_SEQ = (SELECT MAX(HIST_SEQ) 
                                              FROM MWIPSLTHIS
                                             WHERE FACTORY = HIS.FACTORY
                                               AND SUBLOT_ID = HIS.SUBLOT_ID
                                               AND TRAN_CODE = :MWIPSLTHIS_N.TRAN_CODE
                                               AND OPER = :MWIPSLTHIS_N.OPER
                                               AND HIST_DEL_FLAG = ' ')
                        AND GCM.FACTORY = HIS.FACTORY
                        AND GCM.TABLE_NAME = 'SUBLOT_GRADE'
                        AND HIS.GRADE = GCM.KEY_1;
            break;

        //Sublot End ??Lot, Carrier, SlotNo, Grade ?뺣낫
        case 5:
            EXEC SQL SELECT HIS.SUBLOT_ID, HIS.LOT_ID, HIS.CRR_ID, HIS.SLOT_NO, HIS.GRADE, GCM.DATA_2 GRADE_CODE
                       INTO :MWIPSLTHIS_N.SUBLOT_ID, :MWIPSLTHIS_N.LOT_ID, :MWIPSLTHIS_N.CRR_ID, :MWIPSLTHIS_N.SLOT_NO, :MWIPSLTHIS_N.GRADE, :MWIPSLTHIS_N.OLD_CRR_ID
                       FROM MWIPSLTHIS HIS, MGCMTBLDAT GCM
                      WHERE HIS.FACTORY = :MWIPSLTHIS_N.FACTORY
                        AND HIS.SUBLOT_ID = :MWIPSLTHIS_N.SUBLOT_ID
                        AND HIS.HIST_SEQ = (SELECT MAX(HIST_SEQ) 
                                              FROM MWIPSLTHIS
                                             WHERE FACTORY = HIS.FACTORY
                                               AND SUBLOT_ID = HIS.SUBLOT_ID
                                               AND TRAN_CODE = :MWIPSLTHIS_N.TRAN_CODE
                                               AND OLD_OPER = :MWIPSLTHIS_N.OLD_OPER
                                               AND HIST_DEL_FLAG = ' ')
                        AND GCM.FACTORY = HIS.FACTORY
                        AND GCM.TABLE_NAME = 'SUBLOT_GRADE'
                        AND HIS.GRADE = GCM.KEY_1;
            break;
            
