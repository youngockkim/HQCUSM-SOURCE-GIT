                    :MWIPSLTHIS_N.TRAN_CMF_17,
                    :MWIPSLTHIS_N.TRAN_CMF_18,
                    :MWIPSLTHIS_N.TRAN_CMF_19,
                    :MWIPSLTHIS_N.TRAN_CMF_20,
                    :MWIPSLTHIS_N.TRAN_USER_ID,
                    :MWIPSLTHIS_N.TRAN_COMMENT,
                    :MWIPSLTHIS_N.PREV_ACTIVE_HIST_SEQ,
                    :MWIPSLTHIS_N.MULTI_TR_KEY,
                    :MWIPSLTHIS_N.MULTI_TR_SEQ,
                    :MWIPSLTHIS_N.EXT_HIST_SEQ,
                    :MWIPSLTHIS_N.HIST_DEL_FLAG,
                    :MWIPSLTHIS_N.HIST_DEL_TIME,
                    :MWIPSLTHIS_N.HIST_DEL_USER_ID,
                    :MWIPSLTHIS_N.HIST_DEL_COMMENT,
                    :MWIPSLTHIS_N.SUBLOT_TYPE,
                    :MWIPSLTHIS_N.RESV_FIELD_1,
                    :MWIPSLTHIS_N.RESV_FIELD_2,
                    :MWIPSLTHIS_N.RESV_FIELD_3,
                    :MWIPSLTHIS_N.RESV_FIELD_4,
                    :MWIPSLTHIS_N.RESV_FIELD_5,
                    :MWIPSLTHIS_N.RESV_FLAG_1,
                    :MWIPSLTHIS_N.RESV_FLAG_2,
                    :MWIPSLTHIS_N.RESV_FLAG_3,
                    :MWIPSLTHIS_N.RESV_FLAG_4,
                    :MWIPSLTHIS_N.RESV_FLAG_5
                FROM MWIPSLTHIS HIS
                WHERE SUBLOT_ID = :MWIPSLTHIS_N.SUBLOT_ID
                    AND HIST_DEL_FLAG = ' '
                    AND OPER = :MWIPSLTHIS_N.OPER
                    AND OLD_OPER <> OPER
                    AND ROWNUM = 1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwipslthis(&MWIPSLTHIS_N, MWIPSLTHIS);
    }
    DB_stop_query_timer("DBC_select_mwipslthis", sel_type);
}


