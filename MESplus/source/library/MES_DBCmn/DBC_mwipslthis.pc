                    RESV_FLAG_3,
                    RESV_FLAG_4,
                    RESV_FLAG_5
                FROM MWIPSLTHIS 
                WHERE FACTORY = :MWIPSLTHIS_N.FACTORY 
                AND LOT_ID = :MWIPSLTHIS_N.LOT_ID
                AND LOT_HIST_SEQ = :MWIPSLTHIS_N.LOT_HIST_SEQ
                AND HIST_DEL_FLAG = ' '
                ORDER BY SLOT_NO ASC;
            EXEC SQL OPEN DBC_MWIPSLTHIS_CUR_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipslthis", sel_type);
}


/* SQL CURSOR FETCH Function */
