{
    /* memset by NULL */
    memset(MWIPSLTHIS_N, '\0', sizeof(struct MWIPSLTHIS_N_TAG));
    
    MEMCPY_AN(MWIPSLTHIS_N->SUBLOT_ID, MWIPSLTHIS->SUBLOT_ID, sizeof(MWIPSLTHIS->SUBLOT_ID));
