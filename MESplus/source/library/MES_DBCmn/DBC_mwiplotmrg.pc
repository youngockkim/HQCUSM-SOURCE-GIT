    MEMCPY_AN(MWIPLOTMRG_N->FROM_TO_FLOW, MWIPLOTMRG->FROM_TO_FLOW, sizeof(MWIPLOTMRG->FROM_TO_FLOW));
    MWIPLOTMRG_N->FROM_TO_FLOW_SEQ_NUM = MWIPLOTMRG->FROM_TO_FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPLOTMRG_N->FROM_TO_OPER, MWIPLOTMRG->FROM_TO_OPER, sizeof(MWIPLOTMRG->FROM_TO_OPER));
    MWIPLOTMRG_N->FROM_TO_QTY_1 = MWIPLOTMRG->FROM_TO_QTY_1;
    MWIPLOTMRG_N->FROM_TO_QTY_2 = MWIPLOTMRG->FROM_TO_QTY_2;
    MWIPLOTMRG_N->FROM_TO_QTY_3 = MWIPLOTMRG->FROM_TO_QTY_3;
    MWIPLOTMRG_N->FROM_TO_HIST_SEQ = MWIPLOTMRG->FROM_TO_HIST_SEQ;
}


/* Del Null Function */
void DBC_del_null_mwiplotmrg(struct MWIPLOTMRG_N_TAG *MWIPLOTMRG_N, struct MWIPLOTMRG_TAG *MWIPLOTMRG)
{
    MEMCPY_DN(MWIPLOTMRG->LOT_ID, MWIPLOTMRG_N->LOT_ID, sizeof(MWIPLOTMRG->LOT_ID));
