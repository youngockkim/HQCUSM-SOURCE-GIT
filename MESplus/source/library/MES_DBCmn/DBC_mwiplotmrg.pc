    MWIPLOTMRG->FROM_TO_FLAG = MWIPLOTMRG_N->FROM_TO_FLAG[0];
    MEMCPY_DN(MWIPLOTMRG->FROM_TO_LOT_ID, MWIPLOTMRG_N->FROM_TO_LOT_ID, sizeof(MWIPLOTMRG->FROM_TO_LOT_ID));
    MEMCPY_DN(MWIPLOTMRG->FROM_TO_MAT_ID, MWIPLOTMRG_N->FROM_TO_MAT_ID, sizeof(MWIPLOTMRG->FROM_TO_MAT_ID));
    MWIPLOTMRG->FROM_TO_MAT_VER = MWIPLOTMRG_N->FROM_TO_MAT_VER;
    MEMCPY_DN(MWIPLOTMRG->FROM_TO_FLOW, MWIPLOTMRG_N->FROM_TO_FLOW, sizeof(MWIPLOTMRG->FROM_TO_FLOW));
    MWIPLOTMRG->FROM_TO_FLOW_SEQ_NUM = MWIPLOTMRG_N->FROM_TO_FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPLOTMRG->FROM_TO_OPER, MWIPLOTMRG_N->FROM_TO_OPER, sizeof(MWIPLOTMRG->FROM_TO_OPER));
    MWIPLOTMRG->FROM_TO_QTY_1 = MWIPLOTMRG_N->FROM_TO_QTY_1;
    MWIPLOTMRG->FROM_TO_QTY_2 = MWIPLOTMRG_N->FROM_TO_QTY_2;
    MWIPLOTMRG->FROM_TO_QTY_3 = MWIPLOTMRG_N->FROM_TO_QTY_3;
    MWIPLOTMRG->FROM_TO_HIST_SEQ = MWIPLOTMRG_N->FROM_TO_HIST_SEQ;
}



