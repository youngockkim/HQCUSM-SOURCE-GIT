    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPFATCND_CUR_1 CURSOR FOR
                SELECT 
                    ACTION_KEY,
                    SEQ_NO,
                    AND_OR,
                    L_BRACKET,
                    COND_TYPE,
                    FIELD_NAME,
                    OPERATOR,
                    VALUE_TYPE,
                    VALUE_1,
                    VALUE_2,
                    R_BRACKET,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPFATCND
                WHERE ACTION_KEY = :MWIPFATCND_N.ACTION_KEY
                    AND SEQ_NO >= :MWIPFATCND_N.SEQ_NO
                ORDER BY SEQ_NO ASC;
            EXEC SQL OPEN DBC_MWIPFATCND_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
