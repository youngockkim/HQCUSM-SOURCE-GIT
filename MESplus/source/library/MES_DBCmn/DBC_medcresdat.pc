                    VALUE_3 = :MEDCRESDAT_N.VALUE_3,
                    VALUE_4 = :MEDCRESDAT_N.VALUE_4,
                    VALUE_5 = :MEDCRESDAT_N.VALUE_5,
                    VALUE_6 = :MEDCRESDAT_N.VALUE_6,
                    VALUE_7 = :MEDCRESDAT_N.VALUE_7,
                    VALUE_8 = :MEDCRESDAT_N.VALUE_8,
                    VALUE_9 = :MEDCRESDAT_N.VALUE_9,
                    VALUE_10 = :MEDCRESDAT_N.VALUE_10,
                    VALUE_11 = :MEDCRESDAT_N.VALUE_11,
                    VALUE_12 = :MEDCRESDAT_N.VALUE_12,
                    VALUE_13 = :MEDCRESDAT_N.VALUE_13,
                    VALUE_14 = :MEDCRESDAT_N.VALUE_14,
                    VALUE_15 = :MEDCRESDAT_N.VALUE_15,
                    VALUE_16 = :MEDCRESDAT_N.VALUE_16,
                    VALUE_17 = :MEDCRESDAT_N.VALUE_17,
                    VALUE_18 = :MEDCRESDAT_N.VALUE_18,
                    VALUE_19 = :MEDCRESDAT_N.VALUE_19,
                    VALUE_20 = :MEDCRESDAT_N.VALUE_20,
                    VALUE_21 = :MEDCRESDAT_N.VALUE_21,
                    VALUE_22 = :MEDCRESDAT_N.VALUE_22,
                    VALUE_23 = :MEDCRESDAT_N.VALUE_23,
                    VALUE_24 = :MEDCRESDAT_N.VALUE_24,
                    VALUE_25 = :MEDCRESDAT_N.VALUE_25,
                    SPEC_OUT_MASK = :MEDCRESDAT_N.SPEC_OUT_MASK,
                    UPDATE_USER_ID = :MEDCRESDAT_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MEDCRESDAT_N.UPDATE_TIME
                WHERE FACTORY = :MEDCRESDAT_N.FACTORY
                    AND RES_ID = :MEDCRESDAT_N.RES_ID
                    AND SUBRES_ID = :MEDCRESDAT_N.SUBRES_ID
                    AND HIST_SEQ = :MEDCRESDAT_N.HIST_SEQ
                    AND CHAR_SEQ_NUM = :MEDCRESDAT_N.CHAR_SEQ_NUM
                    AND UNIT_SEQ_NUM = :MEDCRESDAT_N.UNIT_SEQ_NUM
                    AND VALUE_SEQ_NUM = :MEDCRESDAT_N.VALUE_SEQ_NUM;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_medcresdat", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_medcresdat(int sel_type, struct MEDCRESDAT_TAG *MEDCRESDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MEDCRESDAT_N_TAG MEDCRESDAT_N;
        char   sql[5120];
        char   ts[1000];
        char   ts2[1000];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_medcresdat(&MEDCRESDAT_N, MEDCRESDAT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MEDCRESDAT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    HIST_SEQ,
                    COL_SEQ,
                    EVENT_ID,
                    TRAN_TIME,
                    RECIPE_ID,
                    RECIPE_VERSION,
                    HIST_DEL_FLAG,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    CHAR_SEQ_NUM,
                    CHAR_ID,
                    UNIT_SEQ_NUM,
                    UNIT_ID,
                    VALUE_SEQ_NUM,
                    VALUE_TYPE,
                    VALUE_COUNT,
                    VALUE_1,
                    VALUE_2,
                    VALUE_3,
                    VALUE_4,
                    VALUE_5,
                    VALUE_6,
                    VALUE_7,
                    VALUE_8,
                    VALUE_9,
                    VALUE_10,
                    VALUE_11,
                    VALUE_12,
                    VALUE_13,
                    VALUE_14,
                    VALUE_15,
                    VALUE_16,
                    VALUE_17,
                    VALUE_18,
                    VALUE_19,
                    VALUE_20,
                    VALUE_21,
                    VALUE_22,
                    VALUE_23,
                    VALUE_24,
                    VALUE_25,
                    SAMPLE_COUNT,
                    NOMINAL,
                    PROCESS_SIGMA,
                    SPEC_OUT_MASK,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    DELETE_USER_ID,
                    DELETE_TIME
                FROM MEDCRESDAT
                WHERE FACTORY = :MEDCRESDAT_N.FACTORY
                    AND RES_ID = :MEDCRESDAT_N.RES_ID
                    AND SUBRES_ID = :MEDCRESDAT_N.SUBRES_ID
                    AND HIST_SEQ = :MEDCRESDAT_N.HIST_SEQ
                    AND CHAR_SEQ_NUM = :MEDCRESDAT_N.CHAR_SEQ_NUM
                    AND UNIT_SEQ_NUM = :MEDCRESDAT_N.UNIT_SEQ_NUM
                ORDER BY VALUE_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MEDCRESDAT_CUR_1;
            break;
        
        case 2:
            memset(sql, 0x00, sizeof(sql));
            memset(ts, 0x00, sizeof(ts));
            memset(ts2, 0x00, sizeof(ts2));
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql), "FACTORY, RES_ID, SUBRES_ID, HIST_SEQ, COL_SEQ, EVENT_ID, TRAN_TIME, RECIPE_ID, RECIPE_VERSION, HIST_DEL_FLAG, COL_SET_ID, ");
            sprintf(sql + strlen(sql), "COL_SET_VERSION, CHAR_SEQ_NUM, CHAR_ID, UNIT_SEQ_NUM, UNIT_ID, VALUE_SEQ_NUM, VALUE_TYPE, VALUE_COUNT, VALUE_1, VALUE_2, ");
            sprintf(sql + strlen(sql), "VALUE_3, VALUE_4, VALUE_5, VALUE_6, VALUE_7, VALUE_8, VALUE_9, VALUE_10, VALUE_11, VALUE_12, VALUE_13, VALUE_14, VALUE_15, ");
            sprintf(sql + strlen(sql), "VALUE_16, VALUE_17, VALUE_18, VALUE_19, VALUE_20, VALUE_21, VALUE_22, VALUE_23, VALUE_24, VALUE_25, SAMPLE_COUNT, NOMINAL, ");
            sprintf(sql + strlen(sql), "PROCESS_SIGMA, SPEC_OUT_MASK, CREATE_USER_ID, CREATE_TIME, UPDATE_USER_ID, UPDATE_TIME, DELETE_USER_ID, DELETE_TIME ");
            sprintf(sql + strlen(sql), "FROM MEDCRESDAT WHERE ");

            make_valid_quote(ts, MEDCRESDAT_N.FACTORY);
            sprintf(sql + strlen(sql), "FACTORY = '%s' ", ts);
            
            make_valid_quote(ts, MEDCRESDAT_N.RES_ID);     
            make_valid_quote(ts2, MEDCRESDAT_N.SUBRES_ID);       
            sprintf(sql + strlen(sql), "AND RES_ID = '%s' AND SUBRES_ID = '%s' AND HIST_SEQ = '%d'", 
                    ts, ts2, MEDCRESDAT_N.HIST_SEQ);
                    
            if(MEDCRESDAT->HIST_DEL_FLAG != 'Y')
            {
                sprintf(sql + strlen(sql), "AND HIST_DEL_FLAG = ' ' ");
            }
            
            sprintf(sql + strlen(sql), "AND ((COL_SEQ > '%d') ", MEDCRESDAT_N.COL_SEQ);
            sprintf(sql + strlen(sql), "OR (COL_SEQ = '%d' AND CHAR_SEQ_NUM > '%d') ", MEDCRESDAT_N.COL_SEQ, MEDCRESDAT_N.CHAR_SEQ_NUM);
            sprintf(sql + strlen(sql), "OR (COL_SEQ = '%d' AND CHAR_SEQ_NUM = '%d' AND UNIT_SEQ_NUM > '%d' ) ", 
                    MEDCRESDAT_N.COL_SEQ,
                    MEDCRESDAT_N.CHAR_SEQ_NUM, 
                    MEDCRESDAT_N.UNIT_SEQ_NUM);
            sprintf(sql + strlen(sql), "OR (COL_SEQ = '%d' AND CHAR_SEQ_NUM = '%d' AND UNIT_SEQ_NUM = '%d' AND VALUE_SEQ_NUM >= '%d')) ", 
                    MEDCRESDAT_N.COL_SEQ,
                    MEDCRESDAT_N.CHAR_SEQ_NUM, 
                    MEDCRESDAT_N.UNIT_SEQ_NUM,  
                    MEDCRESDAT_N.VALUE_SEQ_NUM);
            sprintf(sql + strlen(sql), "ORDER BY COL_SEQ, CHAR_SEQ_NUM, UNIT_SEQ_NUM, VALUE_SEQ_NUM ASC ");
            
            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MEDCRESDAT_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MEDCRESDAT_CUR_2;
            break;
            
        case 3:
            memset(sql, 0x00, sizeof(sql));
            memset(ts, 0x00, sizeof(ts));
            memset(ts2, 0x00, sizeof(ts2));
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql), "FACTORY, RES_ID, SUBRES_ID, HIST_SEQ, COL_SEQ, EVENT_ID, TRAN_TIME, RECIPE_ID, RECIPE_VERSION, HIST_DEL_FLAG, COL_SET_ID, ");
            sprintf(sql + strlen(sql), "COL_SET_VERSION, CHAR_SEQ_NUM, CHAR_ID, UNIT_SEQ_NUM, UNIT_ID, VALUE_SEQ_NUM, VALUE_TYPE, VALUE_COUNT, VALUE_1, VALUE_2, ");
            sprintf(sql + strlen(sql), "VALUE_3, VALUE_4, VALUE_5, VALUE_6, VALUE_7, VALUE_8, VALUE_9, VALUE_10, VALUE_11, VALUE_12, VALUE_13, VALUE_14, VALUE_15, ");
            sprintf(sql + strlen(sql), "VALUE_16, VALUE_17, VALUE_18, VALUE_19, VALUE_20, VALUE_21, VALUE_22, VALUE_23, VALUE_24, VALUE_25, SAMPLE_COUNT, NOMINAL, ");
            sprintf(sql + strlen(sql), "PROCESS_SIGMA, SPEC_OUT_MASK, CREATE_USER_ID, CREATE_TIME, UPDATE_USER_ID, UPDATE_TIME, DELETE_USER_ID, DELETE_TIME ");
            sprintf(sql + strlen(sql), "FROM MEDCRESDAT WHERE ");
            
            make_valid_quote(ts, MEDCRESDAT_N.FACTORY);
            sprintf(sql + strlen(sql), "FACTORY = '%s' ", ts);
            
            make_valid_quote(ts, MEDCRESDAT_N.RES_ID);
            make_valid_quote(ts2, MEDCRESDAT_N.SUBRES_ID);                 
            sprintf(sql + strlen(sql), "AND RES_ID = '%s' AND SUBRES_ID = '%s' AND HIST_SEQ = '%d'", 
                    ts, ts2, MEDCRESDAT_N.HIST_SEQ);
            if(MEDCRESDAT->HIST_DEL_FLAG != 'Y')
            {
                sprintf(sql + strlen(sql), "AND HIST_DEL_FLAG = ' '");
            }
            sprintf(sql + strlen(sql), "AND ((COL_SEQ > '%d') ", MEDCRESDAT_N.COL_SEQ);
            sprintf(sql + strlen(sql), "OR (COL_SEQ = '%d' AND CHAR_SEQ_NUM > '%d') ", MEDCRESDAT_N.COL_SEQ, MEDCRESDAT_N.CHAR_SEQ_NUM);
            sprintf(sql + strlen(sql), "OR (COL_SEQ = '%d' AND CHAR_SEQ_NUM = '%d' AND UNIT_SEQ_NUM > '%d' ) ", 
                    MEDCRESDAT_N.COL_SEQ,
                    MEDCRESDAT_N.CHAR_SEQ_NUM, 
                    MEDCRESDAT_N.UNIT_SEQ_NUM);
            sprintf(sql + strlen(sql), "OR (COL_SEQ = '%d' AND CHAR_SEQ_NUM = '%d' AND UNIT_SEQ_NUM = '%d' AND VALUE_SEQ_NUM >= '%d')) ", 
                    MEDCRESDAT_N.COL_SEQ,
                    MEDCRESDAT_N.CHAR_SEQ_NUM, 
                    MEDCRESDAT_N.UNIT_SEQ_NUM,  
                    MEDCRESDAT_N.VALUE_SEQ_NUM);
            sprintf(sql + strlen(sql), "ORDER BY COL_SEQ, CHAR_SEQ_NUM, UNIT_SEQ_NUM, VALUE_SEQ_NUM ASC ");
   
            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MEDCRESDAT_CUR_3 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MEDCRESDAT_CUR_3;
            break;   

        case 4:
            memset(sql, 0x00, sizeof(sql));
            memset(ts, 0x00, sizeof(ts));
            
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql), "FACTORY, RES_ID, SUBRES_ID, HIST_SEQ, COL_SEQ, EVENT_ID, TRAN_TIME, RECIPE_ID, RECIPE_VERSION, HIST_DEL_FLAG, COL_SET_ID, ");
            sprintf(sql + strlen(sql), "COL_SET_VERSION, CHAR_SEQ_NUM, CHAR_ID, UNIT_SEQ_NUM, UNIT_ID, VALUE_SEQ_NUM, VALUE_TYPE, VALUE_COUNT, VALUE_1, VALUE_2, ");
            sprintf(sql + strlen(sql), "VALUE_3, VALUE_4, VALUE_5, VALUE_6, VALUE_7, VALUE_8, VALUE_9, VALUE_10, VALUE_11, VALUE_12, VALUE_13, VALUE_14, VALUE_15, ");
            sprintf(sql + strlen(sql), "VALUE_16, VALUE_17, VALUE_18, VALUE_19, VALUE_20, VALUE_21, VALUE_22, VALUE_23, VALUE_24, VALUE_25, SAMPLE_COUNT, NOMINAL, ");
            sprintf(sql + strlen(sql), "PROCESS_SIGMA, SPEC_OUT_MASK, CREATE_USER_ID, CREATE_TIME, UPDATE_USER_ID, UPDATE_TIME, DELETE_USER_ID, DELETE_TIME ");
            sprintf(sql + strlen(sql), "FROM MEDCRESDAT WHERE ");
            
            make_valid_quote(ts, MEDCRESDAT_N.FACTORY);
            sprintf(sql + strlen(sql), "FACTORY = '%s' ", ts);
            if(ISSPACE(MEDCRESDAT->SUBRES_ID, sizeof(MEDCRESDAT->SUBRES_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MEDCRESDAT_N.RES_ID);
                sprintf(sql + strlen(sql), "AND RES_ID = '%s' ", ts);
                make_valid_quote(ts, MEDCRESDAT_N.SUBRES_ID);
                sprintf(sql + strlen(sql), "AND SUBRES_ID = '%s' ", ts);
            }
            else
            {
                if(MEDCRESDAT->VALUE_TYPE == 'R')
                {
                    sprintf(sql + strlen(sql), "AND RES_ID = '%s' AND SUBRES_ID = ' ' AND HIST_SEQ <= '%d' ", MEDCRESDAT_N.RES_ID, MEDCRESDAT_N.HIST_SEQ);   
                }
                else
                {
                    sprintf(sql + strlen(sql), "AND ((RES_ID > '%s') OR (RES_ID = '%s' AND SUBRES_ID > '%s') OR (RES_ID = '%s' AND SUBRES_ID = '%s' AND HIST_SEQ <= '%d')) ", 
                            MEDCRESDAT_N.RES_ID, MEDCRESDAT_N.RES_ID, MEDCRESDAT_N.SUBRES_ID, MEDCRESDAT_N.RES_ID, MEDCRESDAT_N.SUBRES_ID, MEDCRESDAT_N.HIST_SEQ);   
                }
            }
            sprintf(sql + strlen(sql), "AND ((COL_SEQ > '%d') ", MEDCRESDAT_N.COL_SEQ);
            sprintf(sql + strlen(sql), "OR (COL_SEQ = '%d' AND CHAR_SEQ_NUM > '%d') ", MEDCRESDAT_N.COL_SEQ, MEDCRESDAT_N.CHAR_SEQ_NUM);
            sprintf(sql + strlen(sql), "OR (COL_SEQ = '%d' AND CHAR_SEQ_NUM = '%d' AND UNIT_SEQ_NUM > '%d' ) ", 
                    MEDCRESDAT_N.COL_SEQ,
                    MEDCRESDAT_N.CHAR_SEQ_NUM, 
                    MEDCRESDAT_N.UNIT_SEQ_NUM);
            sprintf(sql + strlen(sql), "OR (COL_SEQ = '%d' AND CHAR_SEQ_NUM = '%d' AND UNIT_SEQ_NUM = '%d' AND VALUE_SEQ_NUM >= '%d')) ", 
                    MEDCRESDAT_N.COL_SEQ,
                    MEDCRESDAT_N.CHAR_SEQ_NUM, 
                    MEDCRESDAT_N.UNIT_SEQ_NUM,  
                    MEDCRESDAT_N.VALUE_SEQ_NUM);
            if(MEDCRESDAT->HIST_DEL_FLAG != 'Y')
            {
                sprintf(sql + strlen(sql), "AND HIST_DEL_FLAG = ' ' ");   
            }
            if(ISSPACE(MEDCRESDAT->COL_SET_ID, sizeof(MEDCRESDAT->COL_SET_ID)) == DB_FALSE)
            {
                 make_valid_quote(ts, MEDCRESDAT_N.COL_SET_ID);
                sprintf(sql + strlen(sql), "AND COL_SET_ID = '%s' ", ts);
            }
            
            if(ISSPACE(MEDCRESDAT->CHAR_ID, sizeof(MEDCRESDAT->CHAR_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MEDCRESDAT_N.CHAR_ID);
                sprintf(sql + strlen(sql), "AND CHAR_ID = '%s' ", ts);
            }
            if(ISSPACE(MEDCRESDAT->EVENT_ID, sizeof(MEDCRESDAT->EVENT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MEDCRESDAT_N.EVENT_ID);
                sprintf(sql + strlen(sql), "AND EVENT_ID = '%s' ", ts);
            }
            
            make_valid_quote(ts, DBC_Q_COND_N.FROM_TIME);
            sprintf(sql + strlen(sql), "AND TRAN_TIME >= '%s' ", ts);
            
            make_valid_quote(ts, DBC_Q_COND_N.TO_TIME);
            sprintf(sql + strlen(sql), "AND TRAN_TIME < '%s' ", ts);
            sprintf(sql + strlen(sql), "ORDER BY RES_ID, SUBRES_ID, HIST_SEQ DESC, COL_SEQ, CHAR_SEQ_NUM, UNIT_SEQ_NUM, VALUE_SEQ_NUM ASC ");
            
            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MEDCRESDAT_CUR_4 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MEDCRESDAT_CUR_4;
            break;
            
        case 5:
            EXEC SQL DECLARE DBC_MEDCRESDAT_CUR_5 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    HIST_SEQ,
                    COL_SEQ,
                    EVENT_ID,
                    TRAN_TIME,
                    RECIPE_ID,
                    RECIPE_VERSION,
                    HIST_DEL_FLAG,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    CHAR_SEQ_NUM,
                    CHAR_ID,
                    UNIT_SEQ_NUM,
                    UNIT_ID,
                    VALUE_SEQ_NUM,
                    VALUE_TYPE,
                    VALUE_COUNT,
                    VALUE_1,
                    VALUE_2,
                    VALUE_3,
                    VALUE_4,
                    VALUE_5,
                    VALUE_6,
                    VALUE_7,
                    VALUE_8,
                    VALUE_9,
                    VALUE_10,
                    VALUE_11,
                    VALUE_12,
                    VALUE_13,
                    VALUE_14,
                    VALUE_15,
                    VALUE_16,
                    VALUE_17,
                    VALUE_18,
                    VALUE_19,
                    VALUE_20,
                    VALUE_21,
                    VALUE_22,
                    VALUE_23,
                    VALUE_24,
                    VALUE_25,
                    SAMPLE_COUNT,
                    NOMINAL,
                    PROCESS_SIGMA,
                    SPEC_OUT_MASK,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    DELETE_USER_ID,
                    DELETE_TIME
                FROM MEDCRESDAT
                WHERE FACTORY = :MEDCRESDAT_N.FACTORY
                    AND RES_ID = :MEDCRESDAT_N.RES_ID
                    AND SUBRES_ID = :MEDCRESDAT_N.SUBRES_ID
                    AND HIST_SEQ = :MEDCRESDAT_N.HIST_SEQ 
                    AND COL_SEQ = :MEDCRESDAT_N.COL_SEQ 
                    AND UNIT_SEQ_NUM = :MEDCRESDAT_N.UNIT_SEQ_NUM
                    AND CHAR_SEQ_NUM = :MEDCRESDAT_N.CHAR_SEQ_NUM
                    AND VALUE_SEQ_NUM >= :MEDCRESDAT_N.VALUE_SEQ_NUM
                ORDER BY VALUE_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MEDCRESDAT_CUR_5;
            break;
            
        case 6:
            EXEC SQL DECLARE DBC_MEDCRESDAT_CUR_6 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    HIST_SEQ,
                    COL_SEQ,
                    EVENT_ID,
                    TRAN_TIME,
                    RECIPE_ID,
                    RECIPE_VERSION,
                    HIST_DEL_FLAG,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    CHAR_SEQ_NUM,
                    CHAR_ID,
                    UNIT_SEQ_NUM,
                    UNIT_ID,
                    VALUE_SEQ_NUM,
                    VALUE_TYPE,
                    VALUE_COUNT,
                    VALUE_1,
                    VALUE_2,
                    VALUE_3,
                    VALUE_4,
                    VALUE_5,
                    VALUE_6,
                    VALUE_7,
                    VALUE_8,
                    VALUE_9,
                    VALUE_10,
                    VALUE_11,
                    VALUE_12,
                    VALUE_13,
                    VALUE_14,
                    VALUE_15,
                    VALUE_16,
                    VALUE_17,
                    VALUE_18,
                    VALUE_19,
                    VALUE_20,
                    VALUE_21,
                    VALUE_22,
                    VALUE_23,
                    VALUE_24,
                    VALUE_25,
                    SAMPLE_COUNT,
                    NOMINAL,
                    PROCESS_SIGMA,
                    SPEC_OUT_MASK,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    DELETE_USER_ID,
                    DELETE_TIME
                FROM MEDCRESDAT
                WHERE FACTORY = :MEDCRESDAT_N.FACTORY
                    AND RES_ID = :MEDCRESDAT_N.RES_ID
                    AND SUBRES_ID = :MEDCRESDAT_N.SUBRES_ID
                    AND HIST_SEQ = :MEDCRESDAT_N.HIST_SEQ 
                    AND COL_SEQ = :MEDCRESDAT_N.COL_SEQ 
                    AND CHAR_SEQ_NUM = :MEDCRESDAT_N.CHAR_SEQ_NUM
                    AND (
                            (UNIT_SEQ_NUM > :MEDCRESDAT_N.UNIT_SEQ_NUM) OR 
                            (UNIT_SEQ_NUM = :MEDCRESDAT_N.UNIT_SEQ_NUM AND VALUE_SEQ_NUM >= :MEDCRESDAT_N.VALUE_SEQ_NUM)
                        )
                ORDER BY UNIT_SEQ_NUM, VALUE_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MEDCRESDAT_CUR_6;
            break;
            
        case 7:
            EXEC SQL DECLARE DBC_MEDCRESDAT_CUR_7 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    HIST_SEQ,
                    COL_SEQ,
                    EVENT_ID,
                    TRAN_TIME,
                    RECIPE_ID,
                    RECIPE_VERSION,
                    HIST_DEL_FLAG,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    CHAR_SEQ_NUM,
                    CHAR_ID,
                    UNIT_SEQ_NUM,
                    UNIT_ID,
                    VALUE_SEQ_NUM,
                    VALUE_TYPE,
                    VALUE_COUNT,
                    VALUE_1,
                    VALUE_2,
                    VALUE_3,
                    VALUE_4,
                    VALUE_5,
                    VALUE_6,
                    VALUE_7,
                    VALUE_8,
                    VALUE_9,
                    VALUE_10,
                    VALUE_11,
                    VALUE_12,
                    VALUE_13,
                    VALUE_14,
                    VALUE_15,
                    VALUE_16,
                    VALUE_17,
                    VALUE_18,
                    VALUE_19,
                    VALUE_20,
                    VALUE_21,
                    VALUE_22,
                    VALUE_23,
                    VALUE_24,
                    VALUE_25,
                    SAMPLE_COUNT,
                    NOMINAL,
                    PROCESS_SIGMA,
                    SPEC_OUT_MASK,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    DELETE_USER_ID,
                    DELETE_TIME
                FROM MEDCRESDAT
                WHERE FACTORY = :MEDCRESDAT_N.FACTORY
                    AND RES_ID = :MEDCRESDAT_N.RES_ID
                    AND COL_SET_ID = :MEDCRESDAT_N.COL_SET_ID
                    AND CHAR_ID = :MEDCRESDAT_N.CHAR_ID
                    AND UNIT_SEQ_NUM = :MEDCRESDAT_N.UNIT_SEQ_NUM
                    AND HIST_DEL_FLAG = :MEDCRESDAT_N.HIST_DEL_FLAG
                    AND (HIST_SEQ, COL_SEQ) IN (
                        SELECT HIST_SEQ, MIN(COL_SEQ)
                        FROM MEDCRESDAT
                        WHERE FACTORY = :MEDCRESDAT_N.FACTORY
                            AND RES_ID = :MEDCRESDAT_N.RES_ID
                            AND COL_SET_ID = :MEDCRESDAT_N.COL_SET_ID
                            AND CHAR_ID = :MEDCRESDAT_N.CHAR_ID
                            AND UNIT_SEQ_NUM = :MEDCRESDAT_N.UNIT_SEQ_NUM
                            AND HIST_DEL_FLAG = :MEDCRESDAT_N.HIST_DEL_FLAG
                            AND HIST_SEQ = (
                                SELECT MIN(HIST_SEQ)
                                FROM MEDCRESDAT
                                WHERE FACTORY = :MEDCRESDAT_N.FACTORY
                                    AND RES_ID = :MEDCRESDAT_N.RES_ID
                                    AND COL_SET_ID = :MEDCRESDAT_N.COL_SET_ID
                                    AND CHAR_ID = :MEDCRESDAT_N.CHAR_ID
                                    AND UNIT_SEQ_NUM = :MEDCRESDAT_N.UNIT_SEQ_NUM
                                    AND HIST_DEL_FLAG = :MEDCRESDAT_N.HIST_DEL_FLAG
                            )
                        GROUP BY HIST_SEQ
                    )
                ORDER BY VALUE_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MEDCRESDAT_CUR_7;
            break;

        case 8:
            EXEC SQL DECLARE DBC_MEDCRESDAT_CUR_8 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    HIST_SEQ,
                    COL_SEQ,
                    EVENT_ID,
                    TRAN_TIME,
                    RECIPE_ID,
                    RECIPE_VERSION,
                    HIST_DEL_FLAG,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    CHAR_SEQ_NUM,
                    CHAR_ID,
                    UNIT_SEQ_NUM,
                    UNIT_ID,
                    VALUE_SEQ_NUM,
                    VALUE_TYPE,
                    VALUE_COUNT,
                    VALUE_1,
                    VALUE_2,
                    VALUE_3,
                    VALUE_4,
                    VALUE_5,
                    VALUE_6,
                    VALUE_7,
                    VALUE_8,
                    VALUE_9,
                    VALUE_10,
                    VALUE_11,
                    VALUE_12,
                    VALUE_13,
                    VALUE_14,
                    VALUE_15,
                    VALUE_16,
                    VALUE_17,
                    VALUE_18,
                    VALUE_19,
                    VALUE_20,
                    VALUE_21,
                    VALUE_22,
                    VALUE_23,
                    VALUE_24,
                    VALUE_25,
                    SAMPLE_COUNT,
                    NOMINAL,
                    PROCESS_SIGMA,
                    SPEC_OUT_MASK,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    DELETE_USER_ID,
                    DELETE_TIME
                FROM MEDCRESDAT
                WHERE FACTORY = :MEDCRESDAT_N.FACTORY
                    AND RES_ID = :MEDCRESDAT_N.RES_ID
                    AND COL_SET_ID = :MEDCRESDAT_N.COL_SET_ID
                    AND CHAR_ID = :MEDCRESDAT_N.CHAR_ID
                    AND UNIT_SEQ_NUM = :MEDCRESDAT_N.UNIT_SEQ_NUM
                    AND HIST_DEL_FLAG = :MEDCRESDAT_N.HIST_DEL_FLAG
                    AND (HIST_SEQ, COL_SEQ) IN (
                        SELECT HIST_SEQ, MAX(COL_SEQ)
                        FROM MEDCRESDAT
                        WHERE FACTORY = :MEDCRESDAT_N.FACTORY
                            AND RES_ID = :MEDCRESDAT_N.RES_ID
                            AND COL_SET_ID = :MEDCRESDAT_N.COL_SET_ID
                            AND CHAR_ID = :MEDCRESDAT_N.CHAR_ID
                            AND UNIT_SEQ_NUM = :MEDCRESDAT_N.UNIT_SEQ_NUM
                            AND HIST_DEL_FLAG = :MEDCRESDAT_N.HIST_DEL_FLAG
                            AND HIST_SEQ = (
                                SELECT MAX(HIST_SEQ)
                                FROM MEDCRESDAT
                                WHERE FACTORY = :MEDCRESDAT_N.FACTORY
                                    AND RES_ID = :MEDCRESDAT_N.RES_ID
                                    AND COL_SET_ID = :MEDCRESDAT_N.COL_SET_ID
                                    AND CHAR_ID = :MEDCRESDAT_N.CHAR_ID
                                    AND UNIT_SEQ_NUM = :MEDCRESDAT_N.UNIT_SEQ_NUM
                                    AND HIST_DEL_FLAG = :MEDCRESDAT_N.HIST_DEL_FLAG
                            )
                        GROUP BY HIST_SEQ
                    )
                ORDER BY VALUE_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MEDCRESDAT_CUR_8;
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_medcresdat", sel_type);
}


