    MEMCPY_AN(MEDCRESDAT_N->VALUE_11, MEDCRESDAT->VALUE_11, sizeof(MEDCRESDAT->VALUE_11));
    MEMCPY_AN(MEDCRESDAT_N->VALUE_12, MEDCRESDAT->VALUE_12, sizeof(MEDCRESDAT->VALUE_12));
