/* Initialize Function */
void DBC_init_medcprtdef(struct MEDCPRTDEF_TAG *MEDCPRTDEF)
{
    /* memset by Space */
    memset(MEDCPRTDEF, ' ', sizeof(struct MEDCPRTDEF_TAG));
    
    MEDCPRTDEF->COL_SET_VERSION = 0;
}


