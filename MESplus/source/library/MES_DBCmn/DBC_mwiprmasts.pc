/* Del Null Function */
void DBC_del_null_mwiprmasts(struct MWIPRMASTS_N_TAG *MWIPRMASTS_N, struct MWIPRMASTS_TAG *MWIPRMASTS)
{
    MEMCPY_DN(MWIPRMASTS->FACTORY, MWIPRMASTS_N->FACTORY, sizeof(MWIPRMASTS->FACTORY));
    MEMCPY_DN(MWIPRMASTS->WORK_DATE, MWIPRMASTS_N->WORK_DATE, sizeof(MWIPRMASTS->WORK_DATE));
    MEMCPY_DN(MWIPRMASTS->LOT_ID, MWIPRMASTS_N->LOT_ID, sizeof(MWIPRMASTS->LOT_ID));
    MEMCPY_DN(MWIPRMASTS->MAT_ID, MWIPRMASTS_N->MAT_ID, sizeof(MWIPRMASTS->MAT_ID));
