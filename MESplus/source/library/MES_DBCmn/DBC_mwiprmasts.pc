                    CREATE_TIME = :MWIPRMASTS_N.CREATE_TIME,
                    CREATE_CODE = :MWIPRMASTS_N.CREATE_CODE,
                    CREATE_USER_ID = :MWIPRMASTS_N.CREATE_USER_ID,
                    CREATE_COMMENT = :MWIPRMASTS_N.CREATE_COMMENT,
                    RESULT_TIME = :MWIPRMASTS_N.RESULT_TIME,
                    RESULT_CODE = :MWIPRMASTS_N.RESULT_CODE,
                    RESULT_USER_ID = :MWIPRMASTS_N.RESULT_USER_ID,
                    RESULT_COMMENT = :MWIPRMASTS_N.RESULT_COMMENT
                WHERE FACTORY = :MWIPRMASTS_N.FACTORY
                    AND WORK_DATE = :MWIPRMASTS_N.WORK_DATE
                    AND LOT_ID = :MWIPRMASTS_N.LOT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mwiprmasts", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwiprmasts(int sel_type, struct MWIPRMASTS_TAG *MWIPRMASTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPRMASTS_N_TAG MWIPRMASTS_N;
        char   sql[10000];
        char   ts[1000];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiprmasts(&MWIPRMASTS_N, MWIPRMASTS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            memset(sql, 0x00, sizeof(sql));
            memset(ts, 0x00, sizeof(ts));
            
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "FACTORY, ");
            sprintf(sql + strlen(sql),   "WORK_DATE, ");
            sprintf(sql + strlen(sql),   "LOT_ID, ");
            sprintf(sql + strlen(sql),   "MAT_ID, ");
            sprintf(sql + strlen(sql),   "MAT_VER, ");
            sprintf(sql + strlen(sql),   "QTY, ");
            sprintf(sql + strlen(sql),   "HIST_EXIST_FLAG, ");
            sprintf(sql + strlen(sql),   "RMA_STATUS, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_1, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_2, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_3, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_4, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_5, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_6, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_7, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_8, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_9, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_10, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_11, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_12, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_13, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_14, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_15, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_16, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_17, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_18, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_19, ");
            sprintf(sql + strlen(sql),   "RMA_CMF_20, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_1, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_2, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_3, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_4, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_5, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_6, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_7, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_8, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_9, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_10, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_11, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_12, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_13, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_14, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_15, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_16, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_17, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_18, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_19, ");
            sprintf(sql + strlen(sql),   "RESULT_CMF_20, ");
            sprintf(sql + strlen(sql),   "CREATE_TIME, ");
            sprintf(sql + strlen(sql),   "CREATE_CODE, ");
            sprintf(sql + strlen(sql),   "CREATE_USER_ID, ");
            sprintf(sql + strlen(sql),   "CREATE_COMMENT, ");
            sprintf(sql + strlen(sql),   "RESULT_TIME, ");
            sprintf(sql + strlen(sql),   "RESULT_CODE, ");
            sprintf(sql + strlen(sql),   "RESULT_USER_ID, ");
            sprintf(sql + strlen(sql),   "RESULT_COMMENT ");
            sprintf(sql + strlen(sql), "FROM MWIPRMASTS WHERE ");
            
            make_valid_quote(ts, MWIPRMASTS_N.FACTORY);
            sprintf(sql + strlen(sql), "FACTORY = '%s' ", ts);
            
            make_valid_quote(ts, MWIPRMASTS_N.WORK_DATE);
            sprintf(sql + strlen(sql), "AND WORK_DATE <= '%s' ", ts);
            
            make_valid_quote(ts, DBC_Q_COND_N.FROM_TIME);
            sprintf(sql + strlen(sql), "AND ((WORK_DATE > '%s') ", ts);
            
            make_valid_quote(ts, DBC_Q_COND_N.FROM_TIME);
            sprintf(sql + strlen(sql), "OR (WORK_DATE = '%s'  ", ts);
            
            make_valid_quote(ts, MWIPRMASTS_N.LOT_ID);
            sprintf(sql + strlen(sql), "AND LOT_ID >= '%s')) ", ts);
           
            if(ISSPACE(MWIPRMASTS->MAT_ID, sizeof(MWIPRMASTS->MAT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MWIPRMASTS_N.MAT_ID);
                sprintf(sql + strlen(sql), "AND MAT_ID = '%s' ", ts);
            }
            if(MWIPRMASTS->MAT_VER > 0)
            {
                sprintf(sql + strlen(sql), "AND MAT_VER = %d ", MWIPRMASTS->MAT_VER);
            }
            if(ISSPACE(MWIPRMASTS->RMA_STATUS, sizeof(MWIPRMASTS->RMA_STATUS)) == DB_FALSE)
            {
                make_valid_quote(ts, MWIPRMASTS_N.RMA_STATUS);
                sprintf(sql + strlen(sql), "AND RMA_STATUS = '%s' ", ts);
            }
            sprintf(sql + strlen(sql), "ORDER BY WORK_DATE, LOT_ID ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MWIPRMASTS_CUR_1 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MWIPRMASTS_CUR_1;                 
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwiprmasts", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mwiprmasts(int sel_type, struct MWIPRMASTS_TAG *MWIPRMASTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPRMASTS_N_TAG MWIPRMASTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MWIPRMASTS_CUR_1 INTO 
                                                    :MWIPRMASTS_N.FACTORY,
                                                    :MWIPRMASTS_N.WORK_DATE,
                                                    :MWIPRMASTS_N.LOT_ID,
                                                    :MWIPRMASTS_N.MAT_ID,
