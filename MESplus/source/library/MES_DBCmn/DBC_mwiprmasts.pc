                                                    :MWIPRMASTS_N.RMA_CMF_13,
                                                    :MWIPRMASTS_N.RMA_CMF_14,
                                                    :MWIPRMASTS_N.RMA_CMF_15,
                                                    :MWIPRMASTS_N.RMA_CMF_16,
                                                    :MWIPRMASTS_N.RMA_CMF_17,
                                                    :MWIPRMASTS_N.RMA_CMF_18,
                                                    :MWIPRMASTS_N.RMA_CMF_19,
                                                    :MWIPRMASTS_N.RMA_CMF_20,
                                                    :MWIPRMASTS_N.RESULT_CMF_1,
                                                    :MWIPRMASTS_N.RESULT_CMF_2,
                                                    :MWIPRMASTS_N.RESULT_CMF_3,
                                                    :MWIPRMASTS_N.RESULT_CMF_4,
                                                    :MWIPRMASTS_N.RESULT_CMF_5,
                                                    :MWIPRMASTS_N.RESULT_CMF_6,
                                                    :MWIPRMASTS_N.RESULT_CMF_7,
                                                    :MWIPRMASTS_N.RESULT_CMF_8,
                                                    :MWIPRMASTS_N.RESULT_CMF_9,
                                                    :MWIPRMASTS_N.RESULT_CMF_10,
                                                    :MWIPRMASTS_N.RESULT_CMF_11,
                                                    :MWIPRMASTS_N.RESULT_CMF_12,
                                                    :MWIPRMASTS_N.RESULT_CMF_13,
                                                    :MWIPRMASTS_N.RESULT_CMF_14,
                                                    :MWIPRMASTS_N.RESULT_CMF_15,
                                                    :MWIPRMASTS_N.RESULT_CMF_16,
                                                    :MWIPRMASTS_N.RESULT_CMF_17,
                                                    :MWIPRMASTS_N.RESULT_CMF_18,
                                                    :MWIPRMASTS_N.RESULT_CMF_19,
                                                    :MWIPRMASTS_N.RESULT_CMF_20,
                                                    :MWIPRMASTS_N.CREATE_TIME,
                                                    :MWIPRMASTS_N.CREATE_CODE,
                                                    :MWIPRMASTS_N.CREATE_USER_ID,
                                                    :MWIPRMASTS_N.CREATE_COMMENT,
                                                    :MWIPRMASTS_N.RESULT_TIME,
                                                    :MWIPRMASTS_N.RESULT_CODE,
                                                    :MWIPRMASTS_N.RESULT_USER_ID,
                                                    :MWIPRMASTS_N.RESULT_COMMENT;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwiprmasts(&MWIPRMASTS_N, MWIPRMASTS);
    }
    DB_stop_query_timer("DBC_fetch_mwiprmasts", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwiprmasts(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPRMASTS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwiprmasts", sel_type);
}


/* Initialize Function */
void DBC_init_mwiprmasts(struct MWIPRMASTS_TAG *MWIPRMASTS)
{
    /* memset by Space */
    memset(MWIPRMASTS, ' ', sizeof(struct MWIPRMASTS_TAG));
    
    MWIPRMASTS->MAT_VER = 0;
    MWIPRMASTS->QTY = 0;
}


/* Add Null Function */
void DBC_add_null_mwiprmasts(struct MWIPRMASTS_N_TAG *MWIPRMASTS_N, struct MWIPRMASTS_TAG *MWIPRMASTS)
{
    /* memset by NULL */
    memset(MWIPRMASTS_N, '\0', sizeof(struct MWIPRMASTS_N_TAG));
    
    MEMCPY_AN(MWIPRMASTS_N->FACTORY, MWIPRMASTS->FACTORY, sizeof(MWIPRMASTS->FACTORY));
    MEMCPY_AN(MWIPRMASTS_N->WORK_DATE, MWIPRMASTS->WORK_DATE, sizeof(MWIPRMASTS->WORK_DATE));
