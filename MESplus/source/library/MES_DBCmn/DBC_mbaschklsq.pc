/* SQL SELECT Function */
void DBC_select_mbaschklsq(int sel_type, struct MBASCHKLSQ_TAG *MBASCHKLSQ)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBASCHKLSQ_N_TAG MBASCHKLSQ_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbaschklsq(&MBASCHKLSQ_N, MBASCHKLSQ);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    CHKLIST_ID,
                    QUERY_ID,
                    DISP_SEQ,
                    REQUIRE_FLAG
                INTO 
                    :MBASCHKLSQ_N.CREATE_USER_ID,
                    :MBASCHKLSQ_N.CREATE_TIME,
                    :MBASCHKLSQ_N.UPDATE_USER_ID,
                    :MBASCHKLSQ_N.UPDATE_TIME,
                    :MBASCHKLSQ_N.FACTORY,
                    :MBASCHKLSQ_N.CHKLIST_ID,
                    :MBASCHKLSQ_N.QUERY_ID,
                    :MBASCHKLSQ_N.DISP_SEQ,
                    :MBASCHKLSQ_N.REQUIRE_FLAG
                FROM MBASCHKLSQ
                WHERE FACTORY = :MBASCHKLSQ_N.FACTORY
                    AND CHKLIST_ID = :MBASCHKLSQ_N.CHKLIST_ID
                    AND QUERY_ID = :MBASCHKLSQ_N.QUERY_ID;
            break;

		case 2:
            EXEC SQL SELECT 
                    NVL(COUNT(*), 0)
                INTO 
                    :MBASCHKLSQ_N.DISP_SEQ
                FROM MBASCHKLSQ
                WHERE 1=1
					AND FACTORY = :MBASCHKLSQ_N.FACTORY
                    AND CHKLIST_ID = :MBASCHKLSQ_N.CHKLIST_ID;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mbaschklsq(&MBASCHKLSQ_N, MBASCHKLSQ);
    }

    DB_stop_query_timer("DBC_select_mbaschklsq", sel_type);
}


