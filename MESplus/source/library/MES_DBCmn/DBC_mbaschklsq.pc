/* SQL UPDATE Function */
void DBC_update_mbaschklsq(int sel_type, struct MBASCHKLSQ_TAG *MBASCHKLSQ)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBASCHKLSQ_N_TAG MBASCHKLSQ_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbaschklsq(&MBASCHKLSQ_N, MBASCHKLSQ);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MBASCHKLSQ SET
                    CREATE_USER_ID = :MBASCHKLSQ_N.CREATE_USER_ID,
                    CREATE_TIME = :MBASCHKLSQ_N.CREATE_TIME,
                    UPDATE_USER_ID = :MBASCHKLSQ_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MBASCHKLSQ_N.UPDATE_TIME,
                    DISP_SEQ = :MBASCHKLSQ_N.DISP_SEQ,
                    REQUIRE_FLAG = :MBASCHKLSQ_N.REQUIRE_FLAG
                WHERE FACTORY = :MBASCHKLSQ_N.FACTORY
                    AND CHKLIST_ID = :MBASCHKLSQ_N.CHKLIST_ID
                    AND QUERY_ID = :MBASCHKLSQ_N.QUERY_ID;
            break;

		case 2:
			EXEC SQL UPDATE MBASCHKLSQ MBCL
			SET
				DISP_SEQ = (SELECT (DISP_SEQ - 1) FROM MBASCHKLSQ WHERE 1=1
																	AND FACTORY = :MBASCHKLSQ_N.FACTORY
																	AND CHKLIST_ID = :MBASCHKLSQ_N.CHKLIST_ID
																	AND QUERY_ID = MBCL.QUERY_ID)
			WHERE 1=1
				AND FACTORY = :MBASCHKLSQ_N.FACTORY
				AND CHKLIST_ID = :MBASCHKLSQ_N.CHKLIST_ID
				AND DISP_SEQ > :MBASCHKLSQ_N.DISP_SEQ;
			break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_update_mbaschklsq", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mbaschklsq(int sel_type, struct MBASCHKLSQ_TAG *MBASCHKLSQ)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBASCHKLSQ_N_TAG MBASCHKLSQ_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbaschklsq(&MBASCHKLSQ_N, MBASCHKLSQ);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MBASCHKLSQ_CUR_1 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    CHKLIST_ID,
                    QUERY_ID,
                    DISP_SEQ,
                    REQUIRE_FLAG
                FROM MBASCHKLSQ
                ORDER BY FACTORY ASC,
                    CHKLIST_ID ASC,
                    QUERY_ID ASC;
            EXEC SQL OPEN DBC_MBASCHKLSQ_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE DBC_MBASCHKLSQ_CUR_2 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    CHKLIST_ID,
                    QUERY_ID,
                    DISP_SEQ,
                    REQUIRE_FLAG
                FROM MBASCHKLSQ
				WHERE 1=1
					AND FACTORY = :MBASCHKLSQ_N.FACTORY
					AND CHKLIST_ID = :MBASCHKLSQ_N.CHKLIST_ID
                ORDER BY DISP_SEQ;
            EXEC SQL OPEN DBC_MBASCHKLSQ_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mbaschklsq", sel_type);
}


