/* Add Null Function */
void DBC_add_null_mbaschklsq(struct MBASCHKLSQ_N_TAG *MBASCHKLSQ_N, struct MBASCHKLSQ_TAG *MBASCHKLSQ)
{
    /* memset by NULL */
