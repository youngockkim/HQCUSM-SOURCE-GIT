    MEMCPY_AN(MBASCHKLSQ_N->CHKLIST_ID, MBASCHKLSQ->CHKLIST_ID, sizeof(MBASCHKLSQ->CHKLIST_ID));
    MEMCPY_AN(MBASCHKLSQ_N->QUERY_ID, MBASCHKLSQ->QUERY_ID, sizeof(MBASCHKLSQ->QUERY_ID));
    MBASCHKLSQ_N->DISP_SEQ = MBASCHKLSQ->DISP_SEQ;
