/* SQL SELECT_SCALAR Function */
double DBC_select_mspccaldat_scalar(int sel_type, struct MSPCCALDAT_TAG *MSPCCALDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSPCCALDAT_N_TAG MSPCCALDAT_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mspccaldat(&MSPCCALDAT_N, MSPCCALDAT);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND HIST_SEQ = :MSPCCALDAT_N.HIST_SEQ
                    AND UNIT_SEQ = :MSPCCALDAT_N.UNIT_SEQ;
            break;

        case 2:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                        AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                        AND OOC_TYPE <> ' '
                        AND EXCLUDE_FLAG = ' ';
            break;
        case 3:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                        AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                        AND OOC_TYPE2 <> ' '
                        AND EXCLUDE_FLAG = ' ';
            break;   
        case 4:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT AVG(TO_NUMBER(RANGE))
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                    AND EXCLUDE_FLAG = ' '
                    AND RANGE <> ' ';
            break;                
        case 5:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT AVG(TO_NUMBER(AVERAGE))
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                    AND EXCLUDE_FLAG = ' '
                    AND AVERAGE <> ' ';
            break;     
        case 6:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT count(*)
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                    AND EXCLUDE_FLAG = ' ';
            break;     
        case 7:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT STDDEV(TO_NUMBER(AVERAGE))
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                    AND EXCLUDE_FLAG = ' '
                    AND AVERAGE <> ' ';
            break; 
        case 8:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT MIN(TO_NUMBER(AVERAGE))
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                    AND EXCLUDE_FLAG = ' '
                    AND AVERAGE <> ' ';
            break; 
        case 9:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT MAX(TO_NUMBER(AVERAGE))
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                    AND EXCLUDE_FLAG = ' '
                    AND AVERAGE <> ' ';
            break; 
        case 10:
            EXEC SQL SELECT MAX(TO_NUMBER(HIST_SEQ))
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND HIST_SEQ < :MSPCCALDAT_N.HIST_SEQ
                    AND EXCLUDE_FLAG = ' '
                    AND AVERAGE <> ' ';
            break; 
                   
        case 11:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND (HIST_SEQ > :MSPCCALDAT_N.HIST_SEQ
                    OR (HIST_SEQ = :MSPCCALDAT_N.HIST_SEQ
                    AND UNIT_SEQ >= :MSPCCALDAT_N.UNIT_SEQ));
            break;                    
        case 12:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT AVG(TO_NUMBER(MSPCCALDAT.STDDEV))
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                    AND EXCLUDE_FLAG = ' '
                    AND MSPCCALDAT.STDDEV <> ' ';
            break;  
        
        case 13:
            EXEC SQL SELECT NVL(MAX(HIST_SEQ),0) 
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID;
            break;           
            
        case 14:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT count(*)
                INTO :d_value
                FROM 
                    (SELECT LOT_ID FROM MSPCCHTDEF A, MSPCCALDAT B
                    WHERE A.FACTORY = B.FACTORY
                        AND A.CHART_ID = B.CHART_ID
                        AND A.FACTORY= :MSPCCALDAT_N.FACTORY 
                        AND A.CHART_ID= :MSPCCALDAT_N.CHART_ID
                        AND A.LOT_RES_FLAG= 'L'
                        AND B.TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                        AND B.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                        AND B.LOT_ID <> ' '
                        AND B.EXCLUDE_FLAG = ' '
                        GROUP BY B.LOT_ID);
                break;
                        
        case 15:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT count(*)
                INTO :d_value
                FROM 
                    (SELECT B.RES_ID FROM MSPCCHTDEF A, MSPCCALDAT B
                    WHERE A.FACTORY = B.FACTORY
                        AND A.CHART_ID = B.CHART_ID
                        AND A.FACTORY= :MSPCCALDAT_N.FACTORY 
                        AND A.CHART_ID= :MSPCCALDAT_N.CHART_ID
                        AND A.LOT_RES_FLAG= 'R'
                        AND B.TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                        AND B.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                        AND B.RES_ID <> ' '
                        AND B.EXCLUDE_FLAG = ' '
                        GROUP BY B.RES_ID);
                break;
                
         case 16:    
            EXEC SQL SELECT NVL(MAX(HIST_SEQ),0) 
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND TRAN_TIME <= :MSPCCALDAT_N.TRAN_TIME;
            break;   
            
        case 17:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND LOT_ID = :MSPCCALDAT_N.LOT_ID
                    AND COL_SET_ID = :MSPCCALDAT_N.COL_SET_ID
                    AND EDC_HIST_SEQ = :MSPCCALDAT_N.EDC_HIST_SEQ
                    AND EDC_COL_SEQ = :MSPCCALDAT_N.EDC_COL_SEQ;
            break;
            
        case 18:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND RES_ID = :MSPCCALDAT_N.RES_ID
                    AND SUBRES_ID = :MSPCCALDAT_N.SUBRES_ID
                    AND EDC_HIST_SEQ = :MSPCCALDAT_N.EDC_HIST_SEQ
                    AND EDC_COL_SEQ = :MSPCCALDAT_N.EDC_COL_SEQ;
            break;

        case 19:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT STDDEV(TO_NUMBER(AVERAGE))
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                    AND EXCLUDE_FLAG = ' '
                    AND MSPCCALDAT.AVERAGE <> ' ';
            break;

		case 20:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT STDDEV(TO_NUMBER(RANGE))
                INTO :d_value
                FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                    AND EXCLUDE_FLAG = ' '
					AND RANGE <> ' ';
            break;

        case 21:  
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL SELECT AVG(TO_NUMBER(RANGE))
                INTO :d_value
                FROM
                (
                    SELECT RANGE, ROWNUM A
                    FROM 
                    (
                        SELECT * 
                        FROM MSPCCALDAT
                        WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                            AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                            AND TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                            AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                            AND EXCLUDE_FLAG = ' '
                            AND RANGE <> ' '    
                            ORDER by HIST_SEQ, UNIT_SEQ
                    )
                ) WHERE A > 1;
            break;                

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mspccaldat_scalar", sel_type);
    return d_value;
}


/* SQL DELETE Function */
void DBC_delete_mspccaldat(int sel_type, struct MSPCCALDAT_TAG *MSPCCALDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSPCCALDAT_N_TAG MSPCCALDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mspccaldat(&MSPCCALDAT_N, MSPCCALDAT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND HIST_SEQ = :MSPCCALDAT_N.HIST_SEQ
                    AND UNIT_SEQ = :MSPCCALDAT_N.UNIT_SEQ;
            break;
            
        case 2:
            EXEC SQL DELETE FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND HIST_SEQ = :MSPCCALDAT_N.HIST_SEQ;
            break;
            
       case 3:
            EXEC SQL DELETE FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND COL_SET_ID = :MSPCCALDAT_N.COL_SET_ID
                    AND LOT_ID = :MSPCCALDAT_N.LOT_ID
                    AND EDC_HIST_SEQ = :MSPCCALDAT_N.EDC_HIST_SEQ
                    AND EDC_COL_SEQ = :MSPCCALDAT_N.EDC_COL_SEQ
                    AND EDC_CHAR_SEQ = :MSPCCALDAT_N.EDC_CHAR_SEQ;
            break;
            
       case 4:
            EXEC SQL DELETE FROM MSPCCALDAT
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND RES_ID = :MSPCCALDAT_N.RES_ID
                    AND SUBRES_ID = :MSPCCALDAT_N.SUBRES_ID
                    AND EDC_HIST_SEQ = :MSPCCALDAT_N.EDC_HIST_SEQ
                    AND EDC_COL_SEQ = :MSPCCALDAT_N.EDC_COL_SEQ
                    AND EDC_CHAR_SEQ = :MSPCCALDAT_N.EDC_CHAR_SEQ;
            break;

                

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_delete_mspccaldat", sel_type);
}


/* SQL INSERT Function */
