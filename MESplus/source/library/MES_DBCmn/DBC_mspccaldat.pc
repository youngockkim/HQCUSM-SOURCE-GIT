                    :MSPCCALDAT_N.RES_ID,
                    :MSPCCALDAT_N.SUBRES_ID,
                    :MSPCCALDAT_N.COL_SET_ID,
                    :MSPCCALDAT_N.EDC_HIST_SEQ,
                    :MSPCCALDAT_N.EDC_COL_SEQ,
                    :MSPCCALDAT_N.EDC_CHAR_SEQ,
                    :MSPCCALDAT_N.CREATE_USER_ID,
                    :MSPCCALDAT_N.CREATE_TIME,
                    :MSPCCALDAT_N.UPDATE_USER_ID,
                    :MSPCCALDAT_N.UPDATE_TIME,
                    :MSPCCALDAT_N.RESV_FIELD1,
                    :MSPCCALDAT_N.RESV_FIELD2,
                    :MSPCCALDAT_N.RESV_FIELD3,
                    :MSPCCALDAT_N.RESV_FIELD4,
                    :MSPCCALDAT_N.RESV_FIELD5,
                    :MSPCCALDAT_N.RESV_FIELD6,
                    :MSPCCALDAT_N.RESV_FIELD7,
                    :MSPCCALDAT_N.RESV_FIELD8,
                    :MSPCCALDAT_N.RESV_FIELD9,
                    :MSPCCALDAT_N.RESV_FIELD10
        );
    DB_stop_query_timer("DBC_insert_mspccaldat", 0);
}


/* SQL UPDATE Function */
void DBC_update_mspccaldat(int sel_type, struct MSPCCALDAT_TAG *MSPCCALDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSPCCALDAT_N_TAG MSPCCALDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mspccaldat(&MSPCCALDAT_N, MSPCCALDAT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MSPCCALDAT SET
                    TRAN_TIME = :MSPCCALDAT_N.TRAN_TIME,
                    LOT_RES_FLAG = :MSPCCALDAT_N.LOT_RES_FLAG,
                    VALUE_COUNT = :MSPCCALDAT_N.VALUE_COUNT,
                    WEIGHT_VALUE = :MSPCCALDAT_N.WEIGHT_VALUE,
                    AVERAGE = :MSPCCALDAT_N.AVERAGE,
                    MSPCCALDAT.STDDEV = :MSPCCALDAT_N.STDDEV,
                    RANGE = :MSPCCALDAT_N.RANGE,
                    MIN_VALUE = :MSPCCALDAT_N.MIN_VALUE,
                    MAX_VALUE = :MSPCCALDAT_N.MAX_VALUE,
                    USL = :MSPCCALDAT_N.USL,
                    TARGET = :MSPCCALDAT_N.TARGET,
                    LSL = :MSPCCALDAT_N.LSL,
                    UCL = :MSPCCALDAT_N.UCL,
                    CL = :MSPCCALDAT_N.CL,
                    LCL = :MSPCCALDAT_N.LCL,
                    UCL2 = :MSPCCALDAT_N.UCL2,
                    CL2 = :MSPCCALDAT_N.CL2,
                    LCL2 = :MSPCCALDAT_N.LCL2,
                    OOC_TYPE = :MSPCCALDAT_N.OOC_TYPE,
                    OOC_TYPE2 = :MSPCCALDAT_N.OOC_TYPE2,
                    EXCLUDE_FLAG = :MSPCCALDAT_N.EXCLUDE_FLAG,
                    LOT_ID = :MSPCCALDAT_N.LOT_ID,
                    RES_ID = :MSPCCALDAT_N.RES_ID,
                    SUBRES_ID = :MSPCCALDAT_N.SUBRES_ID,
                    EDC_HIST_SEQ = :MSPCCALDAT_N.EDC_HIST_SEQ,
                    EDC_COL_SEQ = :MSPCCALDAT_N.EDC_COL_SEQ,
                    EDC_CHAR_SEQ = :MSPCCALDAT_N.EDC_CHAR_SEQ,
                    CREATE_USER_ID = :MSPCCALDAT_N.CREATE_USER_ID,
                    CREATE_TIME = :MSPCCALDAT_N.CREATE_TIME,
                    UPDATE_USER_ID = :MSPCCALDAT_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MSPCCALDAT_N.UPDATE_TIME,
                    RESV_FIELD1 = :MSPCCALDAT_N.RESV_FIELD1,
                    RESV_FIELD2 = :MSPCCALDAT_N.RESV_FIELD2,
                    RESV_FIELD3 = :MSPCCALDAT_N.RESV_FIELD3,
                    RESV_FIELD4 = :MSPCCALDAT_N.RESV_FIELD4,
                    RESV_FIELD5 = :MSPCCALDAT_N.RESV_FIELD5,
                    RESV_FIELD6 = :MSPCCALDAT_N.RESV_FIELD6,
                    RESV_FIELD7 = :MSPCCALDAT_N.RESV_FIELD7,
                    RESV_FIELD8 = :MSPCCALDAT_N.RESV_FIELD8,
                    RESV_FIELD9 = :MSPCCALDAT_N.RESV_FIELD9,
                    RESV_FIELD10 = :MSPCCALDAT_N.RESV_FIELD10
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND HIST_SEQ = :MSPCCALDAT_N.HIST_SEQ
                    AND UNIT_SEQ = :MSPCCALDAT_N.UNIT_SEQ;
            break;

        case 2:
            EXEC SQL UPDATE MSPCCALDAT SET
                    HIST_SEQ = HIST_SEQ + 1
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND HIST_SEQ > :MSPCCALDAT_N.HIST_SEQ;
            break;
            
        case 3:
            EXEC SQL UPDATE MSPCCALDAT SET
                    EXCLUDE_FLAG = :MSPCCALDAT_N.EXCLUDE_FLAG
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND HIST_SEQ = :MSPCCALDAT_N.HIST_SEQ
                    AND UNIT_SEQ = :MSPCCALDAT_N.UNIT_SEQ;
            break;
            
        case 4:
            EXEC SQL UPDATE MSPCCALDAT SET
                    EXCLUDE_FLAG = :MSPCCALDAT_N.EXCLUDE_FLAG
                WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND HIST_SEQ = :MSPCCALDAT_N.HIST_SEQ;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mspccaldat", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mspccaldat(int sel_type, struct MSPCCALDAT_TAG *MSPCCALDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSPCCALDAT_N_TAG MSPCCALDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mspccaldat(&MSPCCALDAT_N, MSPCCALDAT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSPCCALDAT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    UNIT_SEQ,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    VALUE_COUNT,
                    WEIGHT_VALUE,
                    AVERAGE,
                    MSPCCALDAT.STDDEV,
                    RANGE,
                    MIN_VALUE,
                    MAX_VALUE,
                    USL,
                    TARGET,
                    LSL,
                    UCL,
                    CL,
                    LCL,
                    UCL2,
                    CL2,
                    LCL2,
                    OOC_TYPE,
                    OOC_TYPE2,
                    EXCLUDE_FLAG,
                    LOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    COL_SET_ID,
                    EDC_HIST_SEQ,
                    EDC_COL_SEQ,
                    EDC_CHAR_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5,
                    RESV_FIELD6,
                    RESV_FIELD7,
                    RESV_FIELD8,
                    RESV_FIELD9,
                    RESV_FIELD10
                FROM MSPCCALDAT
                    WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND HIST_SEQ <= :MSPCCALDAT_N.HIST_SEQ
                    AND EXCLUDE_FLAG = ' '
                ORDER BY HIST_SEQ DESC,
                    UNIT_SEQ DESC;
            EXEC SQL OPEN DBC_MSPCCALDAT_CUR_1;
            break;
        case 2:
            EXEC SQL DECLARE DBC_MSPCCALDAT_CUR_2 CURSOR FOR
                SELECT HIST_SEQ, UNIT_SEQ, OOC_TYPE, OOC_TYPE2 
                FROM MSPCCALDAT
                    WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND HIST_SEQ > :MSPCCALDAT_N.HIST_SEQ
                    AND EXCLUDE_FLAG = ' '
                ORDER BY HIST_SEQ,
                    UNIT_SEQ;
            EXEC SQL OPEN DBC_MSPCCALDAT_CUR_2;
            break;
            
        case 3:
            EXEC SQL DECLARE DBC_MSPCCALDAT_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    UNIT_SEQ,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    VALUE_COUNT,
                    WEIGHT_VALUE,
                    AVERAGE,
                    MSPCCALDAT.STDDEV,
                    RANGE,
                    MIN_VALUE,
                    MAX_VALUE,
                    USL,
                    TARGET,
                    LSL,
                    UCL,
                    CL,
                    LCL,
                    UCL2,
                    CL2,
                    LCL2,
                    OOC_TYPE,
                    OOC_TYPE2,
                    EXCLUDE_FLAG,
                    LOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    COL_SET_ID,
                    EDC_HIST_SEQ,
                    EDC_COL_SEQ,
                    EDC_CHAR_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5,
                    RESV_FIELD6,
                    RESV_FIELD7,
                    RESV_FIELD8,
                    RESV_FIELD9,
                    RESV_FIELD10
                FROM MSPCCALDAT
                    WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND (HIST_SEQ < :MSPCCALDAT_N.HIST_SEQ
                    OR (HIST_SEQ = :MSPCCALDAT_N.HIST_SEQ 
                    AND UNIT_SEQ <= :MSPCCALDAT_N.UNIT_SEQ))
                    AND EXCLUDE_FLAG = ' '
                ORDER BY HIST_SEQ DESC,
                    UNIT_SEQ DESC;
            EXEC SQL OPEN DBC_MSPCCALDAT_CUR_3;
            break;
        
         case 4:
            EXEC SQL DECLARE DBC_MSPCCALDAT_CUR_4 CURSOR FOR
                SELECT AVERAGE 
                FROM MSPCCALDAT
                    WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND HIST_SEQ = :MSPCCALDAT_N.HIST_SEQ
                ORDER BY UNIT_SEQ DESC;
            EXEC SQL OPEN DBC_MSPCCALDAT_CUR_4;
            break;   

        case 5:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N); 
            EXEC SQL DECLARE DBC_MSPCCALDAT_CUR_5 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    UNIT_SEQ,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    VALUE_COUNT,
                    WEIGHT_VALUE,
                    AVERAGE,
                    MSPCCALDAT.STDDEV,
                    RANGE,
                    MIN_VALUE,
                    MAX_VALUE,
                    USL,
                    TARGET,
                    LSL,
                    UCL,
                    CL,
                    LCL,
                    UCL2,
                    CL2,
                    LCL2,
                    OOC_TYPE,
                    OOC_TYPE2,
                    EXCLUDE_FLAG,
                    LOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    COL_SET_ID,
                    EDC_HIST_SEQ,
                    EDC_COL_SEQ,
                    EDC_CHAR_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5,
                    RESV_FIELD6,
                    RESV_FIELD7,
                    RESV_FIELD8,
                    RESV_FIELD9,
                    RESV_FIELD10
                FROM MSPCCALDAT
                    WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                    AND TRAN_TIME <= :DBC_Q_COND_N.TO_TIME
                    AND (HIST_SEQ > :MSPCCALDAT_N.HIST_SEQ
                     OR (HIST_SEQ = :MSPCCALDAT_N.HIST_SEQ AND UNIT_SEQ > :MSPCCALDAT_N.UNIT_SEQ))
                    AND EXCLUDE_FLAG = ' '
                ORDER BY HIST_SEQ, UNIT_SEQ;
            EXEC SQL OPEN DBC_MSPCCALDAT_CUR_5;
            break;   
        case 6:
            EXEC SQL DECLARE DBC_MSPCCALDAT_CUR_6 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    UNIT_SEQ,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    VALUE_COUNT,
                    WEIGHT_VALUE,
                    AVERAGE,
                    MSPCCALDAT.STDDEV,
                    RANGE,
                    MIN_VALUE,
                    MAX_VALUE,
                    USL,
                    TARGET,
                    LSL,
                    UCL,
                    CL,
                    LCL,
                    UCL2,
                    CL2,
                    LCL2,
                    OOC_TYPE,
                    OOC_TYPE2,
                    EXCLUDE_FLAG,
                    LOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    COL_SET_ID,
                    EDC_HIST_SEQ,
                    EDC_COL_SEQ,
                    EDC_CHAR_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5,
                    RESV_FIELD6,
                    RESV_FIELD7,
                    RESV_FIELD8,
                    RESV_FIELD9,
                    RESV_FIELD10
                FROM MSPCCALDAT
                    WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND (HIST_SEQ > :MSPCCALDAT_N.HIST_SEQ
                    OR (HIST_SEQ = :MSPCCALDAT_N.HIST_SEQ
                    AND UNIT_SEQ > :MSPCCALDAT_N.UNIT_SEQ))
                    AND EXCLUDE_FLAG = ' '
                ORDER BY HIST_SEQ,
                    UNIT_SEQ;
            EXEC SQL OPEN DBC_MSPCCALDAT_CUR_6;
            break;  
            
        case 7:
            EXEC SQL DECLARE DBC_MSPCCALDAT_CUR_7 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    UNIT_SEQ,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    VALUE_COUNT,
                    WEIGHT_VALUE,
                    AVERAGE,
                    MSPCCALDAT.STDDEV,
                    RANGE,
                    MIN_VALUE,
                    MAX_VALUE,
                    USL,
                    TARGET,
                    LSL,
                    UCL,
                    CL,
                    LCL,
                    UCL2,
                    CL2,
                    LCL2,
                    OOC_TYPE,
                    OOC_TYPE2,
                    EXCLUDE_FLAG,
                    LOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    COL_SET_ID,
                    EDC_HIST_SEQ,
                    EDC_COL_SEQ,
                    EDC_CHAR_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5,
                    RESV_FIELD6,
                    RESV_FIELD7,
                    RESV_FIELD8,
                    RESV_FIELD9,
                    RESV_FIELD10
                FROM MSPCCALDAT
                    WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND EXCLUDE_FLAG = ' '
                ORDER BY HIST_SEQ DESC,
                    UNIT_SEQ DESC,
                    EDC_COL_SEQ DESC;
            EXEC SQL OPEN DBC_MSPCCALDAT_CUR_7;
            break;
            
        case 8:
            EXEC SQL DECLARE DBC_MSPCCALDAT_CUR_8 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    UNIT_SEQ,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    VALUE_COUNT,
                    WEIGHT_VALUE,
                    AVERAGE,
                    MSPCCALDAT.STDDEV,
                    RANGE,
                    MIN_VALUE,
                    MAX_VALUE,
                    USL,
                    TARGET,
                    LSL,
                    UCL,
                    CL,
                    LCL,
                    UCL2,
                    CL2,
                    LCL2,
                    OOC_TYPE,
                    OOC_TYPE2,
                    EXCLUDE_FLAG,
                    LOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    COL_SET_ID,
                    EDC_HIST_SEQ,
                    EDC_COL_SEQ,
                    EDC_CHAR_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5,
                    RESV_FIELD6,
                    RESV_FIELD7,
                    RESV_FIELD8,
                    RESV_FIELD9,
                    RESV_FIELD10
                FROM MSPCCALDAT
                    WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND COL_SET_ID = :MSPCCALDAT_N.COL_SET_ID
                    AND LOT_ID = :MSPCCALDAT_N.LOT_ID
                    AND EDC_HIST_SEQ = :MSPCCALDAT_N.EDC_HIST_SEQ
                    AND EDC_COL_SEQ = :MSPCCALDAT_N.EDC_COL_SEQ
                    AND EDC_CHAR_SEQ = :MSPCCALDAT_N.EDC_CHAR_SEQ;
            EXEC SQL OPEN DBC_MSPCCALDAT_CUR_8;
            break;
            
       case 9:
            EXEC SQL DECLARE DBC_MSPCCALDAT_CUR_9 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    UNIT_SEQ,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    VALUE_COUNT,
                    WEIGHT_VALUE,
                    AVERAGE,
                    MSPCCALDAT.STDDEV,
                    RANGE,
                    MIN_VALUE,
                    MAX_VALUE,
                    USL,
                    TARGET,
                    LSL,
                    UCL,
                    CL,
                    LCL,
                    UCL2,
                    CL2,
                    LCL2,
                    OOC_TYPE,
                    OOC_TYPE2,
                    EXCLUDE_FLAG,
                    LOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    COL_SET_ID,
                    EDC_HIST_SEQ,
                    EDC_COL_SEQ,
                    EDC_CHAR_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5,
                    RESV_FIELD6,
                    RESV_FIELD7,
                    RESV_FIELD8,
                    RESV_FIELD9,
                    RESV_FIELD10
                FROM MSPCCALDAT
                    WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND RES_ID = :MSPCCALDAT_N.RES_ID
                    AND SUBRES_ID = :MSPCCALDAT_N.SUBRES_ID
                    AND EDC_HIST_SEQ = :MSPCCALDAT_N.EDC_HIST_SEQ
                    AND EDC_COL_SEQ = :MSPCCALDAT_N.EDC_COL_SEQ
                    AND EDC_CHAR_SEQ = :MSPCCALDAT_N.EDC_CHAR_SEQ;
            EXEC SQL OPEN DBC_MSPCCALDAT_CUR_9;
            break;

       case 10:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            EXEC SQL DECLARE DBC_MSPCCALDAT_CUR_10 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    UNIT_SEQ,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    VALUE_COUNT,
                    WEIGHT_VALUE,
                    AVERAGE,
                    MSPCCALDAT.STDDEV,
                    RANGE,
                    MIN_VALUE,
                    MAX_VALUE,
                    USL,
                    TARGET,
                    LSL,
                    UCL,
                    CL,
                    LCL,
                    UCL2,
                    CL2,
                    LCL2,
                    OOC_TYPE,
                    OOC_TYPE2,
                    EXCLUDE_FLAG,
                    LOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    COL_SET_ID,
                    EDC_HIST_SEQ,
                    EDC_COL_SEQ,
                    EDC_CHAR_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5,
                    RESV_FIELD6,
                    RESV_FIELD7,
                    RESV_FIELD8,
                    RESV_FIELD9,
                    RESV_FIELD10
                FROM MSPCCALDAT
                    WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND TRAN_TIME <= :DBC_Q_COND_N.TO_TIME 
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME
                    AND EXCLUDE_FLAG = ' '
                    AND RANGE <> ' ';
            EXEC SQL OPEN DBC_MSPCCALDAT_CUR_10;
            break;

        case 11: /* Add by J.S. 2013.12.11 Add Limit */
            EXEC SQL DECLARE DBC_MSPCCALDAT_CUR_11 CURSOR FOR
                SELECT /*+ INDEX_DESC(MSPCCALDAT MSPCCALDAT_PK ) */
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    UNIT_SEQ,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    VALUE_COUNT,
                    WEIGHT_VALUE,
                    AVERAGE,
                    MSPCCALDAT.STDDEV,
                    RANGE,
                    MIN_VALUE,
                    MAX_VALUE,
                    USL,
                    TARGET,
                    LSL,
                    UCL,
                    CL,
                    LCL,
                    UCL2,
                    CL2,
                    LCL2,
                    OOC_TYPE,
                    OOC_TYPE2,
                    EXCLUDE_FLAG,
                    LOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    COL_SET_ID,
                    EDC_HIST_SEQ,
                    EDC_COL_SEQ,
                    EDC_CHAR_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5,
                    RESV_FIELD6,
                    RESV_FIELD7,
                    RESV_FIELD8,
                    RESV_FIELD9,
                    RESV_FIELD10
                FROM MSPCCALDAT
                    WHERE FACTORY = :MSPCCALDAT_N.FACTORY
                    AND CHART_ID = :MSPCCALDAT_N.CHART_ID
                    AND (
                            HIST_SEQ < :MSPCCALDAT_N.HIST_SEQ OR
                                (HIST_SEQ = :MSPCCALDAT_N.HIST_SEQ  AND UNIT_SEQ <= :MSPCCALDAT_N.UNIT_SEQ)
                        )
                    AND EXCLUDE_FLAG = ' '
     AND ROWNUM <= 30;
            EXEC SQL OPEN DBC_MSPCCALDAT_CUR_11;
            break;

		case 12: 
            EXEC SQL DECLARE DBC_MSPCCALDAT_CUR_12 CURSOR FOR
                SELECT DEF_RATE, 
				       DEF_INPUT, 
				       TIME_SPAN
                FROM
				(   
					SELECT 
						  RTRIM(TO_CHAR(AVERAGE*100, 'FM9990D99'), '.') || '%' AS DEF_RATE,
						  MIN_VALUE || '/' || MAX_VALUE AS DEF_INPUT,
						 ' (Time:' || SUBSTR(TRAN_TIME,9,2) || ' ~ ' || LPAD(TO_NUMBER(SUBSTR(TRAN_TIME,9,2)+1),2,'0') || ')' AS TIME_SPAN,
						 TRAN_TIME
					FROM
					(
						SELECT B.AVERAGE, B.MIN_VALUE, B.MAX_VALUE, B.TRAN_TIME
						FROM MSPCCALDAT A, MSPCCALDAT B
						WHERE A.FACTORY = :MSPCCALDAT_N.FACTORY
						 AND A.CHART_ID = :MSPCCALDAT_N.CHART_ID
						 AND A.OOC_TYPE > ' '
						 AND A.HIST_SEQ = (
											SELECT MAX(HIST_SEQ) FROM MSPCCALDAT
											WHERE CHART_ID = :MSPCCALDAT_N.CHART_ID
											AND OOC_TYPE > ' ')
						 AND B.TRAN_TIME <= A.TRAN_TIME                    
						 AND B.TRAN_TIME >= TO_CHAR(TO_DATE(A.TRAN_TIME, 'YYYYMMDDHH24MISS') - 1/8, 'YYYYMMDDHH24MISS')
						 AND B.CHART_ID = :MSPCCALDAT_N.CHART_ID
						ORDER BY B.TRAN_TIME DESC
					) WHERE ROWNUM <= 3 
				) ORDER BY TRAN_TIME;  
            EXEC SQL OPEN DBC_MSPCCALDAT_CUR_12;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mspccaldat", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mspccaldat(int sel_type, struct MSPCCALDAT_TAG *MSPCCALDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSPCCALDAT_N_TAG MSPCCALDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MSPCCALDAT_CUR_1 INTO 
                                                    :MSPCCALDAT_N.FACTORY,
                                                    :MSPCCALDAT_N.CHART_ID,
                                                    :MSPCCALDAT_N.HIST_SEQ,
                                                    :MSPCCALDAT_N.UNIT_SEQ,
                                                    :MSPCCALDAT_N.TRAN_TIME,
                                                    :MSPCCALDAT_N.LOT_RES_FLAG,
                                                    :MSPCCALDAT_N.VALUE_COUNT,
                                                    :MSPCCALDAT_N.WEIGHT_VALUE,
                                                    :MSPCCALDAT_N.AVERAGE,
                                                    :MSPCCALDAT_N.STDDEV,
                                                    :MSPCCALDAT_N.RANGE,
                                                    :MSPCCALDAT_N.MIN_VALUE,
                                                    :MSPCCALDAT_N.MAX_VALUE,
                                                    :MSPCCALDAT_N.USL,
                                                    :MSPCCALDAT_N.TARGET,
                                                    :MSPCCALDAT_N.LSL,
                                                    :MSPCCALDAT_N.UCL,
                                                    :MSPCCALDAT_N.CL,
                                                    :MSPCCALDAT_N.LCL,
                                                    :MSPCCALDAT_N.UCL2,
                                                    :MSPCCALDAT_N.CL2,
                                                    :MSPCCALDAT_N.LCL2,
                                                    :MSPCCALDAT_N.OOC_TYPE,
                                                    :MSPCCALDAT_N.OOC_TYPE2,
                                                    :MSPCCALDAT_N.EXCLUDE_FLAG,
                                                    :MSPCCALDAT_N.LOT_ID,
                                                    :MSPCCALDAT_N.RES_ID,
                                                    :MSPCCALDAT_N.SUBRES_ID,
                                                    :MSPCCALDAT_N.COL_SET_ID,
                                                    :MSPCCALDAT_N.EDC_HIST_SEQ,
                                                    :MSPCCALDAT_N.EDC_COL_SEQ,
                                                    :MSPCCALDAT_N.EDC_CHAR_SEQ,
                                                    :MSPCCALDAT_N.CREATE_USER_ID,
                                                    :MSPCCALDAT_N.CREATE_TIME,
                                                    :MSPCCALDAT_N.UPDATE_USER_ID,
                                                    :MSPCCALDAT_N.UPDATE_TIME,
                                                    :MSPCCALDAT_N.RESV_FIELD1,
                                                    :MSPCCALDAT_N.RESV_FIELD2,
                                                    :MSPCCALDAT_N.RESV_FIELD3,
                                                    :MSPCCALDAT_N.RESV_FIELD4,
                                                    :MSPCCALDAT_N.RESV_FIELD5,
                                                    :MSPCCALDAT_N.RESV_FIELD6,
                                                    :MSPCCALDAT_N.RESV_FIELD7,
                                                    :MSPCCALDAT_N.RESV_FIELD8,
                                                    :MSPCCALDAT_N.RESV_FIELD9,
                                                    :MSPCCALDAT_N.RESV_FIELD10;
            break;
        case 2:
            EXEC SQL FETCH DBC_MSPCCALDAT_CUR_2 INTO :MSPCCALDAT_N.HIST_SEQ, :MSPCCALDAT_N.UNIT_SEQ, :MSPCCALDAT_N.OOC_TYPE, :MSPCCALDAT_N.OOC_TYPE2;
            break;
        case 3:
            EXEC SQL FETCH DBC_MSPCCALDAT_CUR_3 INTO 
                                                    :MSPCCALDAT_N.FACTORY,
                                                    :MSPCCALDAT_N.CHART_ID,
                                                    :MSPCCALDAT_N.HIST_SEQ,
                                                    :MSPCCALDAT_N.UNIT_SEQ,
                                                    :MSPCCALDAT_N.TRAN_TIME,
                                                    :MSPCCALDAT_N.LOT_RES_FLAG,
                                                    :MSPCCALDAT_N.VALUE_COUNT,
                                                    :MSPCCALDAT_N.WEIGHT_VALUE,
                                                    :MSPCCALDAT_N.AVERAGE,
                                                    :MSPCCALDAT_N.STDDEV,
                                                    :MSPCCALDAT_N.RANGE,
                                                    :MSPCCALDAT_N.MIN_VALUE,
                                                    :MSPCCALDAT_N.MAX_VALUE,
                                                    :MSPCCALDAT_N.USL,
                                                    :MSPCCALDAT_N.TARGET,
                                                    :MSPCCALDAT_N.LSL,
                                                    :MSPCCALDAT_N.UCL,
                                                    :MSPCCALDAT_N.CL,
                                                    :MSPCCALDAT_N.LCL,
                                                    :MSPCCALDAT_N.UCL2,
                                                    :MSPCCALDAT_N.CL2,
                                                    :MSPCCALDAT_N.LCL2,
                                                    :MSPCCALDAT_N.OOC_TYPE,
                                                    :MSPCCALDAT_N.OOC_TYPE2,
                                                    :MSPCCALDAT_N.EXCLUDE_FLAG,
                                                    :MSPCCALDAT_N.LOT_ID,
                                                    :MSPCCALDAT_N.RES_ID,
                                                    :MSPCCALDAT_N.SUBRES_ID,
