/* SQL CURSOR CLOSE Function */
void DBC_close_mspccaldat(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MSPCCALDAT_CUR_1;
            break;
        case 2:
            EXEC SQL CLOSE DBC_MSPCCALDAT_CUR_2;
            break;  
        case 3:
            EXEC SQL CLOSE DBC_MSPCCALDAT_CUR_3;
            break;      
        case 4:
            EXEC SQL CLOSE DBC_MSPCCALDAT_CUR_4;
            break; 
        case 5:
            EXEC SQL CLOSE DBC_MSPCCALDAT_CUR_5;
            break; 
        case 6:
            EXEC SQL CLOSE DBC_MSPCCALDAT_CUR_6;
            break;    
        case 7:
            EXEC SQL CLOSE DBC_MSPCCALDAT_CUR_7;
            break; 
            
        case 8:
            EXEC SQL CLOSE DBC_MSPCCALDAT_CUR_8;
            break;    
        case 9:
            EXEC SQL CLOSE DBC_MSPCCALDAT_CUR_9;
            break; 
        case 10:
            EXEC SQL CLOSE DBC_MSPCCALDAT_CUR_10;
            break;      
        case 11: /* Add by J.S. 2013.12.11 Add Limit */
            EXEC SQL CLOSE DBC_MSPCCALDAT_CUR_11;
            break;    
        case 12: 
            EXEC SQL CLOSE DBC_MSPCCALDAT_CUR_12;
            break; 
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mspccaldat", sel_type);
}


/* Initialize Function */
void DBC_init_mspccaldat(struct MSPCCALDAT_TAG *MSPCCALDAT)
{
    /* memset by Space */
    memset(MSPCCALDAT, ' ', sizeof(struct MSPCCALDAT_TAG));
    
    MSPCCALDAT->HIST_SEQ = 0;
    MSPCCALDAT->UNIT_SEQ = 0;
    MSPCCALDAT->VALUE_COUNT = 0;
    MSPCCALDAT->EDC_HIST_SEQ = 0;
    MSPCCALDAT->EDC_COL_SEQ = 0;
    MSPCCALDAT->EDC_CHAR_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mspccaldat(struct MSPCCALDAT_N_TAG *MSPCCALDAT_N, struct MSPCCALDAT_TAG *MSPCCALDAT)
{
    /* memset by NULL */
    memset(MSPCCALDAT_N, '\0', sizeof(struct MSPCCALDAT_N_TAG));
    
    MEMCPY_AN(MSPCCALDAT_N->FACTORY, MSPCCALDAT->FACTORY, sizeof(MSPCCALDAT->FACTORY));
    MEMCPY_AN(MSPCCALDAT_N->CHART_ID, MSPCCALDAT->CHART_ID, sizeof(MSPCCALDAT->CHART_ID));
    MSPCCALDAT_N->HIST_SEQ = MSPCCALDAT->HIST_SEQ;
    MSPCCALDAT_N->UNIT_SEQ = MSPCCALDAT->UNIT_SEQ;
    MEMCPY_AN(MSPCCALDAT_N->TRAN_TIME, MSPCCALDAT->TRAN_TIME, sizeof(MSPCCALDAT->TRAN_TIME));
    MSPCCALDAT_N->LOT_RES_FLAG[0] = MSPCCALDAT->LOT_RES_FLAG;
    MSPCCALDAT_N->VALUE_COUNT = MSPCCALDAT->VALUE_COUNT;
    MEMCPY_AN(MSPCCALDAT_N->WEIGHT_VALUE, MSPCCALDAT->WEIGHT_VALUE, sizeof(MSPCCALDAT->WEIGHT_VALUE));
    MEMCPY_AN(MSPCCALDAT_N->AVERAGE, MSPCCALDAT->AVERAGE, sizeof(MSPCCALDAT->AVERAGE));
    MEMCPY_AN(MSPCCALDAT_N->STDDEV, MSPCCALDAT->STDDEV, sizeof(MSPCCALDAT->STDDEV));
    MEMCPY_AN(MSPCCALDAT_N->RANGE, MSPCCALDAT->RANGE, sizeof(MSPCCALDAT->RANGE));
    MEMCPY_AN(MSPCCALDAT_N->MIN_VALUE, MSPCCALDAT->MIN_VALUE, sizeof(MSPCCALDAT->MIN_VALUE));
    MEMCPY_AN(MSPCCALDAT_N->MAX_VALUE, MSPCCALDAT->MAX_VALUE, sizeof(MSPCCALDAT->MAX_VALUE));
    MEMCPY_AN(MSPCCALDAT_N->USL, MSPCCALDAT->USL, sizeof(MSPCCALDAT->USL));
    MEMCPY_AN(MSPCCALDAT_N->TARGET, MSPCCALDAT->TARGET, sizeof(MSPCCALDAT->TARGET));
    MEMCPY_AN(MSPCCALDAT_N->LSL, MSPCCALDAT->LSL, sizeof(MSPCCALDAT->LSL));
    MEMCPY_AN(MSPCCALDAT_N->UCL, MSPCCALDAT->UCL, sizeof(MSPCCALDAT->UCL));
    MEMCPY_AN(MSPCCALDAT_N->CL, MSPCCALDAT->CL, sizeof(MSPCCALDAT->CL));
    MEMCPY_AN(MSPCCALDAT_N->LCL, MSPCCALDAT->LCL, sizeof(MSPCCALDAT->LCL));
    MEMCPY_AN(MSPCCALDAT_N->UCL2, MSPCCALDAT->UCL2, sizeof(MSPCCALDAT->UCL2));
    MEMCPY_AN(MSPCCALDAT_N->CL2, MSPCCALDAT->CL2, sizeof(MSPCCALDAT->CL2));
    MEMCPY_AN(MSPCCALDAT_N->LCL2, MSPCCALDAT->LCL2, sizeof(MSPCCALDAT->LCL2));
    MSPCCALDAT_N->OOC_TYPE[0] = MSPCCALDAT->OOC_TYPE;
    MSPCCALDAT_N->OOC_TYPE2[0] = MSPCCALDAT->OOC_TYPE2;
    MSPCCALDAT_N->EXCLUDE_FLAG[0] = MSPCCALDAT->EXCLUDE_FLAG;
    MEMCPY_AN(MSPCCALDAT_N->LOT_ID, MSPCCALDAT->LOT_ID, sizeof(MSPCCALDAT->LOT_ID));
    MEMCPY_AN(MSPCCALDAT_N->RES_ID, MSPCCALDAT->RES_ID, sizeof(MSPCCALDAT->RES_ID));
    MEMCPY_AN(MSPCCALDAT_N->SUBRES_ID, MSPCCALDAT->SUBRES_ID, sizeof(MSPCCALDAT->SUBRES_ID));
    MEMCPY_AN(MSPCCALDAT_N->COL_SET_ID, MSPCCALDAT->COL_SET_ID, sizeof(MSPCCALDAT->COL_SET_ID));
    MSPCCALDAT_N->EDC_HIST_SEQ = MSPCCALDAT->EDC_HIST_SEQ;
    MSPCCALDAT_N->EDC_COL_SEQ = MSPCCALDAT->EDC_COL_SEQ;
    MSPCCALDAT_N->EDC_CHAR_SEQ = MSPCCALDAT->EDC_CHAR_SEQ;
    MEMCPY_AN(MSPCCALDAT_N->CREATE_USER_ID, MSPCCALDAT->CREATE_USER_ID, sizeof(MSPCCALDAT->CREATE_USER_ID));
    MEMCPY_AN(MSPCCALDAT_N->CREATE_TIME, MSPCCALDAT->CREATE_TIME, sizeof(MSPCCALDAT->CREATE_TIME));
