    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPSLTCVH_CUR_1 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    HIST_SEQ,
                    LOT_ID,
                    LOT_HIST_SEQ,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_ID,
                    CAUSE_FLOW,
                    CAUSE_OPER,
                    CAUSE_RES_ID,
                    QTY_FLAG,
                    CV_CODE,
                    CV_QTY
                FROM MWIPSLTCVH
                ORDER BY SUBLOT_ID ASC,
                    HIST_SEQ ASC,
                    LOT_ID ASC,
                    QTY_FLAG ASC,
                    CV_CODE ASC;
            EXEC SQL OPEN DBC_MWIPSLTCVH_CUR_1;
