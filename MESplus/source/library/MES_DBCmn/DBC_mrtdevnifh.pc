    MEMCPY_AN(MRTDEVNIFH_N->CREATE_USER_ID, MRTDEVNIFH->CREATE_USER_ID, sizeof(MRTDEVNIFH->CREATE_USER_ID));
    MEMCPY_AN(MRTDEVNIFH_N->CREATE_TIME, MRTDEVNIFH->CREATE_TIME, sizeof(MRTDEVNIFH->CREATE_TIME));
    MEMCPY_AN(MRTDEVNIFH_N->UPDATE_USER_ID, MRTDEVNIFH->UPDATE_USER_ID, sizeof(MRTDEVNIFH->UPDATE_USER_ID));
    MEMCPY_AN(MRTDEVNIFH_N->UPDATE_TIME, MRTDEVNIFH->UPDATE_TIME, sizeof(MRTDEVNIFH->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mrtdevnifh(struct MRTDEVNIFH_N_TAG *MRTDEVNIFH_N, struct MRTDEVNIFH_TAG *MRTDEVNIFH)
{
    MRTDEVNIFH->EVENT_SEQ = MRTDEVNIFH_N->EVENT_SEQ;
    MEMCPY_DN(MRTDEVNIFH->TRAN_CODE, MRTDEVNIFH_N->TRAN_CODE, sizeof(MRTDEVNIFH->TRAN_CODE));
    MEMCPY_DN(MRTDEVNIFH->TRAN_TIME, MRTDEVNIFH_N->TRAN_TIME, sizeof(MRTDEVNIFH->TRAN_TIME));
    MEMCPY_DN(MRTDEVNIFH->CHANGE_MEMBER, MRTDEVNIFH_N->CHANGE_MEMBER, sizeof(MRTDEVNIFH->CHANGE_MEMBER));
    MEMCPY_DN(MRTDEVNIFH->FACTORY, MRTDEVNIFH_N->FACTORY, sizeof(MRTDEVNIFH->FACTORY));
    MEMCPY_DN(MRTDEVNIFH->LOT_ID, MRTDEVNIFH_N->LOT_ID, sizeof(MRTDEVNIFH->LOT_ID));
    MEMCPY_DN(MRTDEVNIFH->BATCH_ID, MRTDEVNIFH_N->BATCH_ID, sizeof(MRTDEVNIFH->BATCH_ID));
    MEMCPY_DN(MRTDEVNIFH->DSP_ID, MRTDEVNIFH_N->DSP_ID, sizeof(MRTDEVNIFH->DSP_ID));
    MEMCPY_DN(MRTDEVNIFH->RULE_ID, MRTDEVNIFH_N->RULE_ID, sizeof(MRTDEVNIFH->RULE_ID));
    MEMCPY_DN(MRTDEVNIFH->MAT_ID, MRTDEVNIFH_N->MAT_ID, sizeof(MRTDEVNIFH->MAT_ID));
    MRTDEVNIFH->MAT_VER = MRTDEVNIFH_N->MAT_VER;
    MEMCPY_DN(MRTDEVNIFH->FLOW, MRTDEVNIFH_N->FLOW, sizeof(MRTDEVNIFH->FLOW));
    MEMCPY_DN(MRTDEVNIFH->OPER, MRTDEVNIFH_N->OPER, sizeof(MRTDEVNIFH->OPER));
    MEMCPY_DN(MRTDEVNIFH->RESG_ID, MRTDEVNIFH_N->RESG_ID, sizeof(MRTDEVNIFH->RESG_ID));
    MEMCPY_DN(MRTDEVNIFH->RES_ID, MRTDEVNIFH_N->RES_ID, sizeof(MRTDEVNIFH->RES_ID));
    MEMCPY_DN(MRTDEVNIFH->RES_TYPE, MRTDEVNIFH_N->RES_TYPE, sizeof(MRTDEVNIFH->RES_TYPE));
    MEMCPY_DN(MRTDEVNIFH->ETC_TYPE, MRTDEVNIFH_N->ETC_TYPE, sizeof(MRTDEVNIFH->ETC_TYPE));
    MEMCPY_DN(MRTDEVNIFH->ETC_ID, MRTDEVNIFH_N->ETC_ID, sizeof(MRTDEVNIFH->ETC_ID));
    MEMCPY_DN(MRTDEVNIFH->CUSTOM_ACTION_KEY, MRTDEVNIFH_N->CUSTOM_ACTION_KEY, sizeof(MRTDEVNIFH->CUSTOM_ACTION_KEY));
    MRTDEVNIFH->UNSELECT_CAPABLE_ONLY_FLAG = MRTDEVNIFH_N->UNSELECT_CAPABLE_ONLY_FLAG[0];
    MEMCPY_DN(MRTDEVNIFH->CREATE_USER_ID, MRTDEVNIFH_N->CREATE_USER_ID, sizeof(MRTDEVNIFH->CREATE_USER_ID));
    MEMCPY_DN(MRTDEVNIFH->CREATE_TIME, MRTDEVNIFH_N->CREATE_TIME, sizeof(MRTDEVNIFH->CREATE_TIME));
    MEMCPY_DN(MRTDEVNIFH->UPDATE_USER_ID, MRTDEVNIFH_N->UPDATE_USER_ID, sizeof(MRTDEVNIFH->UPDATE_USER_ID));
    MEMCPY_DN(MRTDEVNIFH->UPDATE_TIME, MRTDEVNIFH_N->UPDATE_TIME, sizeof(MRTDEVNIFH->UPDATE_TIME));
}



