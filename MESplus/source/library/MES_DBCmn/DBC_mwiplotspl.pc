void DBC_add_null_mwiplotspl(struct MWIPLOTSPL_N_TAG *MWIPLOTSPL_N, struct MWIPLOTSPL_TAG *MWIPLOTSPL)
{
    /* memset by NULL */
    memset(MWIPLOTSPL_N, '\0', sizeof(struct MWIPLOTSPL_N_TAG));
    
    MEMCPY_AN(MWIPLOTSPL_N->LOT_ID, MWIPLOTSPL->LOT_ID, sizeof(MWIPLOTSPL->LOT_ID));
    MWIPLOTSPL_N->HIST_SEQ = MWIPLOTSPL->HIST_SEQ;
    MEMCPY_AN(MWIPLOTSPL_N->TRAN_TIME, MWIPLOTSPL->TRAN_TIME, sizeof(MWIPLOTSPL->TRAN_TIME));
    MWIPLOTSPL_N->HIST_DEL_FLAG[0] = MWIPLOTSPL->HIST_DEL_FLAG;
    MEMCPY_AN(MWIPLOTSPL_N->FACTORY, MWIPLOTSPL->FACTORY, sizeof(MWIPLOTSPL->FACTORY));
    MEMCPY_AN(MWIPLOTSPL_N->MAT_ID, MWIPLOTSPL->MAT_ID, sizeof(MWIPLOTSPL->MAT_ID));
    MWIPLOTSPL_N->MAT_VER = MWIPLOTSPL->MAT_VER;
    MEMCPY_AN(MWIPLOTSPL_N->FLOW, MWIPLOTSPL->FLOW, sizeof(MWIPLOTSPL->FLOW));
    MWIPLOTSPL_N->FLOW_SEQ_NUM = MWIPLOTSPL->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPLOTSPL_N->OPER, MWIPLOTSPL->OPER, sizeof(MWIPLOTSPL->OPER));
    MWIPLOTSPL_N->FROM_TO_FLAG[0] = MWIPLOTSPL->FROM_TO_FLAG;
    MEMCPY_AN(MWIPLOTSPL_N->FROM_TO_LOT_ID, MWIPLOTSPL->FROM_TO_LOT_ID, sizeof(MWIPLOTSPL->FROM_TO_LOT_ID));
    MEMCPY_AN(MWIPLOTSPL_N->FROM_TO_MAT_ID, MWIPLOTSPL->FROM_TO_MAT_ID, sizeof(MWIPLOTSPL->FROM_TO_MAT_ID));
    MWIPLOTSPL_N->FROM_TO_MAT_VER = MWIPLOTSPL->FROM_TO_MAT_VER;
    MEMCPY_AN(MWIPLOTSPL_N->FROM_TO_FLOW, MWIPLOTSPL->FROM_TO_FLOW, sizeof(MWIPLOTSPL->FROM_TO_FLOW));
    MWIPLOTSPL_N->FROM_TO_FLOW_SEQ_NUM = MWIPLOTSPL->FROM_TO_FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPLOTSPL_N->FROM_TO_OPER, MWIPLOTSPL->FROM_TO_OPER, sizeof(MWIPLOTSPL->FROM_TO_OPER));
    MWIPLOTSPL_N->FROM_TO_QTY_1 = MWIPLOTSPL->FROM_TO_QTY_1;
    MWIPLOTSPL_N->FROM_TO_QTY_2 = MWIPLOTSPL->FROM_TO_QTY_2;
    MWIPLOTSPL_N->FROM_TO_QTY_3 = MWIPLOTSPL->FROM_TO_QTY_3;
    MWIPLOTSPL_N->FROM_TO_HIST_SEQ = MWIPLOTSPL->FROM_TO_HIST_SEQ;
}


/* Del Null Function */
void DBC_del_null_mwiplotspl(struct MWIPLOTSPL_N_TAG *MWIPLOTSPL_N, struct MWIPLOTSPL_TAG *MWIPLOTSPL)
{
    MEMCPY_DN(MWIPLOTSPL->LOT_ID, MWIPLOTSPL_N->LOT_ID, sizeof(MWIPLOTSPL->LOT_ID));
    MWIPLOTSPL->HIST_SEQ = MWIPLOTSPL_N->HIST_SEQ;
