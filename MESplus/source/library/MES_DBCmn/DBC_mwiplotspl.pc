/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwiplotspl(int sel_type, struct MWIPLOTSPL_TAG *MWIPLOTSPL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTSPL_N_TAG MWIPLOTSPL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplotspl(&MWIPLOTSPL_N, MWIPLOTSPL);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPLOTSPL_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    FROM_TO_FLAG,
                    FROM_TO_LOT_ID,
                    FROM_TO_MAT_ID,
                    FROM_TO_MAT_VER,
                    FROM_TO_FLOW,
                    FROM_TO_FLOW_SEQ_NUM,
                    FROM_TO_OPER,
                    FROM_TO_QTY_1,
                    FROM_TO_QTY_2,
                    FROM_TO_QTY_3,
                    FROM_TO_HIST_SEQ
                FROM MWIPLOTSPL
                WHERE LOT_ID = :MWIPLOTSPL_N.LOT_ID
                ORDER BY HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MWIPLOTSPL_CUR_1;
            break;

        case 2: /* Add by J.S. 2011.11.10 for rtd */
            EXEC SQL DECLARE DBC_MWIPLOTSPL_CUR_2 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    FROM_TO_FLAG,
                    FROM_TO_LOT_ID,
                    FROM_TO_MAT_ID,
                    FROM_TO_MAT_VER,
                    FROM_TO_FLOW,
                    FROM_TO_FLOW_SEQ_NUM,
                    FROM_TO_OPER,
                    FROM_TO_QTY_1,
                    FROM_TO_QTY_2,
                    FROM_TO_QTY_3,
                    FROM_TO_HIST_SEQ
                FROM MWIPLOTSPL
                WHERE LOT_ID = :MWIPLOTSPL_N.LOT_ID
                AND FROM_TO_FLAG = :MWIPLOTSPL_N.FROM_TO_FLAG
                AND TRAN_TIME >= :MWIPLOTSPL_N.TRAN_TIME
                ORDER BY HIST_SEQ DESC;
            EXEC SQL OPEN DBC_MWIPLOTSPL_CUR_2;
            break;



        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwiplotspl", sel_type);
}


