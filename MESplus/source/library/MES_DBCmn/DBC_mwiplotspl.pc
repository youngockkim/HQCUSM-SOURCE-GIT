    MWIPLOTSPL->FROM_TO_FLAG = MWIPLOTSPL_N->FROM_TO_FLAG[0];
    MEMCPY_DN(MWIPLOTSPL->FROM_TO_LOT_ID, MWIPLOTSPL_N->FROM_TO_LOT_ID, sizeof(MWIPLOTSPL->FROM_TO_LOT_ID));
    MEMCPY_DN(MWIPLOTSPL->FROM_TO_MAT_ID, MWIPLOTSPL_N->FROM_TO_MAT_ID, sizeof(MWIPLOTSPL->FROM_TO_MAT_ID));
    MWIPLOTSPL->FROM_TO_MAT_VER = MWIPLOTSPL_N->FROM_TO_MAT_VER;
