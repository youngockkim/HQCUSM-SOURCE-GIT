    MWIPLOTSPL->FROM_TO_FLOW_SEQ_NUM = MWIPLOTSPL_N->FROM_TO_FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPLOTSPL->FROM_TO_OPER, MWIPLOTSPL_N->FROM_TO_OPER, sizeof(MWIPLOTSPL->FROM_TO_OPER));
    MWIPLOTSPL->FROM_TO_QTY_1 = MWIPLOTSPL_N->FROM_TO_QTY_1;
    MWIPLOTSPL->FROM_TO_QTY_2 = MWIPLOTSPL_N->FROM_TO_QTY_2;
