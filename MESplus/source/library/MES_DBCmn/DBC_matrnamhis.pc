                    HIST_DEL_FLAG,
                    HIST_DEL_TIME,
                    HIST_DEL_USER_ID,
                    HIST_DEL_COMMENT,
                    TRAN_USER_ID
                FROM MATRNAMHIS
                WHERE FACTORY = :MATRNAMHIS_N.FACTORY
                    AND ATTR_TYPE = :MATRNAMHIS_N.ATTR_TYPE
                    AND ATTR_KEY = :MATRNAMHIS_N.ATTR_KEY
                    AND KEY_HIST_SEQ = :MATRNAMHIS_N.KEY_HIST_SEQ
                ORDER BY HIST_SEQ DESC, PREV_ACTIVE_HIST_SEQ DESC;
            EXEC SQL OPEN DBC_MATRNAMHIS_CUR_2;
            break;

        case 3:
            memset( sql, 0x00, sizeof(sql));
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql), "FACTORY, ");
            sprintf(sql + strlen(sql), "ATTR_TYPE, ");
            sprintf(sql + strlen(sql), "ATTR_NAME, ");
            sprintf(sql + strlen(sql), "ATTR_KEY, ");
            sprintf(sql + strlen(sql), "HIST_SEQ, ");
            sprintf(sql + strlen(sql), "ATTR_OLD_VALUE, ");
            sprintf(sql + strlen(sql), "ATTR_NEW_VALUE, ");
            sprintf(sql + strlen(sql), "NULL_FLAG, ");
            sprintf(sql + strlen(sql), "TRAN_TIME, ");
            sprintf(sql + strlen(sql), "SYS_TRAN_TIME, ");
            sprintf(sql + strlen(sql), "KEY_HIST_SEQ, ");
            sprintf(sql + strlen(sql), "PREV_ACTIVE_HIST_SEQ, ");
            sprintf(sql + strlen(sql), "HIST_START_SEQ, ");
            sprintf(sql + strlen(sql), "HIST_DEL_FLAG, ");
            sprintf(sql + strlen(sql), "HIST_DEL_TIME, ");
            sprintf(sql + strlen(sql), "HIST_DEL_USER_ID, ");
            sprintf(sql + strlen(sql), "HIST_DEL_COMMENT, ");
