                    ATTR_TYPE,
                    ATTR_NAME,
                    ATTR_KEY,
                    HIST_SEQ,
                    ATTR_OLD_VALUE,
                    ATTR_NEW_VALUE,
                    NULL_FLAG,
                    TRAN_TIME,
                    SYS_TRAN_TIME,
                    KEY_HIST_SEQ,
                    PREV_ACTIVE_HIST_SEQ,
                    HIST_START_SEQ,
                    HIST_DEL_FLAG,
                    HIST_DEL_TIME,
                    HIST_DEL_USER_ID,
                    HIST_DEL_COMMENT,
                    TRAN_USER_ID
                FROM MATRNAMHIS
                ORDER BY FACTORY ASC,
                    ATTR_TYPE ASC,
                    ATTR_NAME ASC,
                    ATTR_KEY ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MATRNAMHIS_CUR_1;
            break;

         case 2:
            EXEC SQL DECLARE DBC_MATRNAMHIS_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    ATTR_TYPE,
                    ATTR_NAME,
                    ATTR_KEY,
                    HIST_SEQ,
                    ATTR_OLD_VALUE,
                    ATTR_NEW_VALUE,
                    NULL_FLAG,
                    TRAN_TIME,
                    SYS_TRAN_TIME,
