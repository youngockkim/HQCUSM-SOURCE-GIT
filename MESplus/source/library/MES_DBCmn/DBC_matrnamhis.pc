                                                    :MATRNAMHIS_N.KEY_HIST_SEQ,
                                                    :MATRNAMHIS_N.PREV_ACTIVE_HIST_SEQ,
                                                    :MATRNAMHIS_N.HIST_START_SEQ,
                                                    :MATRNAMHIS_N.HIST_DEL_FLAG,
                                                    :MATRNAMHIS_N.HIST_DEL_TIME,
                                                    :MATRNAMHIS_N.HIST_DEL_USER_ID,
                                                    :MATRNAMHIS_N.HIST_DEL_COMMENT,
                                                    :MATRNAMHIS_N.TRAN_USER_ID;
            break;

        case 2:
            EXEC SQL FETCH DBC_MATRNAMHIS_CUR_2 INTO 
                                                    :MATRNAMHIS_N.FACTORY,
                                                    :MATRNAMHIS_N.ATTR_TYPE,
                                                    :MATRNAMHIS_N.ATTR_NAME,
                                                    :MATRNAMHIS_N.ATTR_KEY,
                                                    :MATRNAMHIS_N.HIST_SEQ,
                                                    :MATRNAMHIS_N.ATTR_OLD_VALUE,
                                                    :MATRNAMHIS_N.ATTR_NEW_VALUE,
                                                    :MATRNAMHIS_N.NULL_FLAG,
                                                    :MATRNAMHIS_N.TRAN_TIME,
                                                    :MATRNAMHIS_N.SYS_TRAN_TIME,
                                                    :MATRNAMHIS_N.KEY_HIST_SEQ,
                                                    :MATRNAMHIS_N.PREV_ACTIVE_HIST_SEQ,
                                                    :MATRNAMHIS_N.HIST_START_SEQ,
                                                    :MATRNAMHIS_N.HIST_DEL_FLAG,
                                                    :MATRNAMHIS_N.HIST_DEL_TIME,
                                                    :MATRNAMHIS_N.HIST_DEL_USER_ID,
                                                    :MATRNAMHIS_N.HIST_DEL_COMMENT,
                                                    :MATRNAMHIS_N.TRAN_USER_ID;
            break;
            
        case 3:
            EXEC SQL FETCH DBC_MATRNAMHIS_CUR_3 INTO 
                                                    :MATRNAMHIS_N.FACTORY,
                                                    :MATRNAMHIS_N.ATTR_TYPE,
                                                    :MATRNAMHIS_N.ATTR_NAME,
                                                    :MATRNAMHIS_N.ATTR_KEY,
                                                    :MATRNAMHIS_N.HIST_SEQ,
                                                    :MATRNAMHIS_N.ATTR_OLD_VALUE,
                                                    :MATRNAMHIS_N.ATTR_NEW_VALUE,
                                                    :MATRNAMHIS_N.NULL_FLAG,
                                                    :MATRNAMHIS_N.TRAN_TIME,
                                                    :MATRNAMHIS_N.SYS_TRAN_TIME,
                                                    :MATRNAMHIS_N.KEY_HIST_SEQ,
                                                    :MATRNAMHIS_N.PREV_ACTIVE_HIST_SEQ,
                                                    :MATRNAMHIS_N.HIST_START_SEQ,
                                                    :MATRNAMHIS_N.HIST_DEL_FLAG,
                                                    :MATRNAMHIS_N.HIST_DEL_TIME,
                                                    :MATRNAMHIS_N.HIST_DEL_USER_ID,
                                                    :MATRNAMHIS_N.HIST_DEL_COMMENT,
                                                    :MATRNAMHIS_N.TRAN_USER_ID;
            break;
            
        case 4:
            EXEC SQL FETCH DBC_MATRNAMHIS_CUR_4 INTO 
                                                    :MATRNAMHIS_N.FACTORY,
                                                    :MATRNAMHIS_N.ATTR_TYPE,
                                                    :MATRNAMHIS_N.ATTR_NAME,
                                                    :MATRNAMHIS_N.ATTR_KEY,
                                                    :MATRNAMHIS_N.HIST_SEQ,
                                                    :MATRNAMHIS_N.ATTR_OLD_VALUE,
                                                    :MATRNAMHIS_N.ATTR_NEW_VALUE,
                                                    :MATRNAMHIS_N.NULL_FLAG,
                                                    :MATRNAMHIS_N.TRAN_TIME,
                                                    :MATRNAMHIS_N.SYS_TRAN_TIME,
                                                    :MATRNAMHIS_N.KEY_HIST_SEQ,
                                                    :MATRNAMHIS_N.PREV_ACTIVE_HIST_SEQ,
                                                    :MATRNAMHIS_N.HIST_START_SEQ,
                                                    :MATRNAMHIS_N.HIST_DEL_FLAG,
                                                    :MATRNAMHIS_N.HIST_DEL_TIME,
                                                    :MATRNAMHIS_N.HIST_DEL_USER_ID,
                                                    :MATRNAMHIS_N.HIST_DEL_COMMENT,
                                                    :MATRNAMHIS_N.TRAN_USER_ID;
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_matrnamhis(&MATRNAMHIS_N, MATRNAMHIS);
    }
    DB_stop_query_timer("DBC_fetch_matrnamhis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_matrnamhis(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MATRNAMHIS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MATRNAMHIS_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MATRNAMHIS_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MATRNAMHIS_CUR_4;
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_matrnamhis", sel_type);
}


/* Initialize Function */
void DBC_init_matrnamhis(struct MATRNAMHIS_TAG *MATRNAMHIS)
{
    /* memset by Space */
    memset(MATRNAMHIS, ' ', sizeof(struct MATRNAMHIS_TAG));
    
    MATRNAMHIS->HIST_SEQ = 0;
    MATRNAMHIS->KEY_HIST_SEQ = 0;
    MATRNAMHIS->PREV_ACTIVE_HIST_SEQ = 0;
    MATRNAMHIS->HIST_START_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_matrnamhis(struct MATRNAMHIS_N_TAG *MATRNAMHIS_N, struct MATRNAMHIS_TAG *MATRNAMHIS)
{
    /* memset by NULL */
    memset(MATRNAMHIS_N, '\0', sizeof(struct MATRNAMHIS_N_TAG));
    
    MEMCPY_AN(MATRNAMHIS_N->FACTORY, MATRNAMHIS->FACTORY, sizeof(MATRNAMHIS->FACTORY));
    MEMCPY_AN(MATRNAMHIS_N->ATTR_TYPE, MATRNAMHIS->ATTR_TYPE, sizeof(MATRNAMHIS->ATTR_TYPE));
    MEMCPY_AN(MATRNAMHIS_N->ATTR_NAME, MATRNAMHIS->ATTR_NAME, sizeof(MATRNAMHIS->ATTR_NAME));
    MEMCPY_AN(MATRNAMHIS_N->ATTR_KEY, MATRNAMHIS->ATTR_KEY, sizeof(MATRNAMHIS->ATTR_KEY));
    MATRNAMHIS_N->HIST_SEQ = MATRNAMHIS->HIST_SEQ;
    MEMCPY_AN(MATRNAMHIS_N->ATTR_OLD_VALUE, MATRNAMHIS->ATTR_OLD_VALUE, sizeof(MATRNAMHIS->ATTR_OLD_VALUE));
    MEMCPY_AN(MATRNAMHIS_N->ATTR_NEW_VALUE, MATRNAMHIS->ATTR_NEW_VALUE, sizeof(MATRNAMHIS->ATTR_NEW_VALUE));
    MATRNAMHIS_N->NULL_FLAG[0] = MATRNAMHIS->NULL_FLAG;
    MEMCPY_AN(MATRNAMHIS_N->TRAN_TIME, MATRNAMHIS->TRAN_TIME, sizeof(MATRNAMHIS->TRAN_TIME));
    MEMCPY_AN(MATRNAMHIS_N->SYS_TRAN_TIME, MATRNAMHIS->SYS_TRAN_TIME, sizeof(MATRNAMHIS->SYS_TRAN_TIME));
    MATRNAMHIS_N->KEY_HIST_SEQ = MATRNAMHIS->KEY_HIST_SEQ;
    MATRNAMHIS_N->PREV_ACTIVE_HIST_SEQ = MATRNAMHIS->PREV_ACTIVE_HIST_SEQ;
    MATRNAMHIS_N->HIST_START_SEQ = MATRNAMHIS->HIST_START_SEQ;
    MATRNAMHIS_N->HIST_DEL_FLAG[0] = MATRNAMHIS->HIST_DEL_FLAG;
    MEMCPY_AN(MATRNAMHIS_N->HIST_DEL_TIME, MATRNAMHIS->HIST_DEL_TIME, sizeof(MATRNAMHIS->HIST_DEL_TIME));
    MEMCPY_AN(MATRNAMHIS_N->HIST_DEL_USER_ID, MATRNAMHIS->HIST_DEL_USER_ID, sizeof(MATRNAMHIS->HIST_DEL_USER_ID));
    MEMCPY_AN(MATRNAMHIS_N->HIST_DEL_COMMENT, MATRNAMHIS->HIST_DEL_COMMENT, sizeof(MATRNAMHIS->HIST_DEL_COMMENT));
    MEMCPY_AN(MATRNAMHIS_N->TRAN_USER_ID, MATRNAMHIS->TRAN_USER_ID, sizeof(MATRNAMHIS->TRAN_USER_ID));
}


/* Del Null Function */
void DBC_del_null_matrnamhis(struct MATRNAMHIS_N_TAG *MATRNAMHIS_N, struct MATRNAMHIS_TAG *MATRNAMHIS)
{
    MEMCPY_DN(MATRNAMHIS->FACTORY, MATRNAMHIS_N->FACTORY, sizeof(MATRNAMHIS->FACTORY));
    MEMCPY_DN(MATRNAMHIS->ATTR_TYPE, MATRNAMHIS_N->ATTR_TYPE, sizeof(MATRNAMHIS->ATTR_TYPE));
    MEMCPY_DN(MATRNAMHIS->ATTR_NAME, MATRNAMHIS_N->ATTR_NAME, sizeof(MATRNAMHIS->ATTR_NAME));
    MEMCPY_DN(MATRNAMHIS->ATTR_KEY, MATRNAMHIS_N->ATTR_KEY, sizeof(MATRNAMHIS->ATTR_KEY));
    MATRNAMHIS->HIST_SEQ = MATRNAMHIS_N->HIST_SEQ;
    MEMCPY_DN(MATRNAMHIS->ATTR_OLD_VALUE, MATRNAMHIS_N->ATTR_OLD_VALUE, sizeof(MATRNAMHIS->ATTR_OLD_VALUE));
    MEMCPY_DN(MATRNAMHIS->ATTR_NEW_VALUE, MATRNAMHIS_N->ATTR_NEW_VALUE, sizeof(MATRNAMHIS->ATTR_NEW_VALUE));
    MATRNAMHIS->NULL_FLAG = MATRNAMHIS_N->NULL_FLAG[0];
    MEMCPY_DN(MATRNAMHIS->TRAN_TIME, MATRNAMHIS_N->TRAN_TIME, sizeof(MATRNAMHIS->TRAN_TIME));
    MEMCPY_DN(MATRNAMHIS->SYS_TRAN_TIME, MATRNAMHIS_N->SYS_TRAN_TIME, sizeof(MATRNAMHIS->SYS_TRAN_TIME));
    MATRNAMHIS->KEY_HIST_SEQ = MATRNAMHIS_N->KEY_HIST_SEQ;
    MATRNAMHIS->PREV_ACTIVE_HIST_SEQ = MATRNAMHIS_N->PREV_ACTIVE_HIST_SEQ;
    MATRNAMHIS->HIST_START_SEQ = MATRNAMHIS_N->HIST_START_SEQ;
    MATRNAMHIS->HIST_DEL_FLAG = MATRNAMHIS_N->HIST_DEL_FLAG[0];
    MEMCPY_DN(MATRNAMHIS->HIST_DEL_TIME, MATRNAMHIS_N->HIST_DEL_TIME, sizeof(MATRNAMHIS->HIST_DEL_TIME));
    MEMCPY_DN(MATRNAMHIS->HIST_DEL_USER_ID, MATRNAMHIS_N->HIST_DEL_USER_ID, sizeof(MATRNAMHIS->HIST_DEL_USER_ID));
    MEMCPY_DN(MATRNAMHIS->HIST_DEL_COMMENT, MATRNAMHIS_N->HIST_DEL_COMMENT, sizeof(MATRNAMHIS->HIST_DEL_COMMENT));
    MEMCPY_DN(MATRNAMHIS->TRAN_USER_ID, MATRNAMHIS_N->TRAN_USER_ID, sizeof(MATRNAMHIS->TRAN_USER_ID));
}


