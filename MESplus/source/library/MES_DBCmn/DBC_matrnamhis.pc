            sprintf(sql + strlen(sql), "FROM MATRNAMHIS WHERE ");
            make_valid_quote(ts1, MATRNAMHIS_N.ATTR_TYPE);
            sprintf(sql + strlen(sql), "ATTR_TYPE = '%s' ", ts1);

            make_valid_quote(ts1, MATRNAMHIS_N.ATTR_KEY);
            sprintf(sql + strlen(sql), "AND ATTR_KEY = '%s' ", ts1);

            if(ISSPACE(MATRNAMHIS->FACTORY, sizeof(MATRNAMHIS->FACTORY)) == DB_FALSE)
            {
                make_valid_quote(ts1, MATRNAMHIS_N.FACTORY);
                sprintf(sql + strlen(sql), "AND FACTORY = '%s' ", ts1);
            }

            if(MATRNAMHIS->HIST_DEL_FLAG == ' ')
            {
                sprintf(sql + strlen(sql), "AND HIST_DEL_FLAG = ' ' ");
            }

            if(ISSPACE(MATRNAMHIS->ATTR_NAME, sizeof(MATRNAMHIS->ATTR_NAME)) == DB_FALSE)
            {
                make_valid_quote(ts1, MATRNAMHIS_N.ATTR_NAME);
                sprintf(sql + strlen(sql), "AND ATTR_NAME = '%s' ", ts1);
            }

            make_valid_quote(ts1, DBC_Q_COND_N.FROM_TIME);
            make_valid_quote(ts2, DBC_Q_COND_N.TO_TIME);
            sprintf(sql + strlen(sql), "AND TRAN_TIME >= '%s' AND TRAN_TIME < '%s' ", ts1, ts2);

            make_valid_quote(ts1, MATRNAMHIS_N.ATTR_NEW_VALUE);
            sprintf(sql + strlen(sql), "AND ((ATTR_NAME = '%s' AND HIST_SEQ >= %d) OR HIST_SEQ > %d)", ts1, MATRNAMHIS->HIST_SEQ, MATRNAMHIS->HIST_SEQ);

            sprintf(sql + strlen(sql), "ORDER BY ATTR_NAME ASC, HIST_SEQ ASC");
        
            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MATRNAMHIS_CUR_3 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MATRNAMHIS_CUR_3;                 
            break;

        case 4:
            EXEC SQL DECLARE DBC_MATRNAMHIS_CUR_4 CURSOR FOR
                SELECT 
