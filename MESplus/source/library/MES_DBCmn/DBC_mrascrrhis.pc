/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrascrrhis(int sel_type, struct MRASCRRHIS_TAG *MRASCRRHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASCRRHIS_N_TAG MRASCRRHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrascrrhis(&MRASCRRHIS_N, MRASCRRHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRASCRRHIS_CUR_1 CURSOR FOR
                SELECT 
                    CRR_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    SYS_TRAN_TIME,
                    TRAN_CODE,
                    FACTORY,
                    CRR_STATUS,
                    CRR_STATUS_FLAG,
                    USAGE_COUNT,
                    CLEAN_COUNT,
                    RES_ID,
                    SUBRES_ID,
                    PORT_ID,
                    LOCATION_1,
                    LOCATION_2,
                    LOCATION_3,
                    LOCATION_4,
                    LOCATION_5,
                    NEED_CLEAN_FLAG,
                    FINISH_CLEAN_FLAG,
                    LAST_CLEAN_TIME,
                    LOT_ID,
                    LOT_HIST_SEQ,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    TBL_SLOT,
                    MOVE_FLAG,
                    EMPTY_FLAG,
                    STOCK_IN_TIME,
                    TRAN_CMF_1,
                    TRAN_CMF_2,
                    TRAN_CMF_3,
                    TRAN_CMF_4,
                    TRAN_CMF_5,
                    TRAN_CMF_6,
                    TRAN_CMF_7,
                    TRAN_CMF_8,
                    TRAN_CMF_9,
                    TRAN_CMF_10,
                    TRAN_CMF_11,
                    TRAN_CMF_12,
                    TRAN_CMF_13,
                    TRAN_CMF_14,
                    TRAN_CMF_15,
                    TRAN_CMF_16,
                    TRAN_CMF_17,
                    TRAN_CMF_18,
                    TRAN_CMF_19,
                    TRAN_CMF_20,
                    TRAN_USER_ID,
                    TRAN_COMMENT,
                    CRR_CMF_1,
                    CRR_CMF_2,
                    CRR_CMF_3,
                    CRR_CMF_4,
                    CRR_CMF_5,
                    CRR_CMF_6,
                    CRR_CMF_7,
                    CRR_CMF_8,
                    CRR_CMF_9,
                    CRR_CMF_10,
                    CRR_CMF_11,
                    CRR_CMF_12,
                    CRR_CMF_13,
                    CRR_CMF_14,
                    CRR_CMF_15,
                    CRR_CMF_16,
                    CRR_CMF_17,
                    CRR_CMF_18,
                    CRR_CMF_19,
                    CRR_CMF_20,
                    REUSE_COUNT
                FROM MRASCRRHIS
                ORDER BY CRR_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MRASCRRHIS_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MRASCRRHIS_CUR_2 CURSOR FOR
                SELECT 
                    CRR_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    SYS_TRAN_TIME,
                    TRAN_CODE,
                    FACTORY,
                    CRR_STATUS,
                    CRR_STATUS_FLAG,
                    USAGE_COUNT,
                    CLEAN_COUNT,
                    RES_ID,
                    SUBRES_ID,
                    PORT_ID,
                    LOCATION_1,
                    LOCATION_2,
                    LOCATION_3,
                    LOCATION_4,
                    LOCATION_5,
                    NEED_CLEAN_FLAG,
                    FINISH_CLEAN_FLAG,
                    LAST_CLEAN_TIME,
                    LOT_ID,
                    LOT_HIST_SEQ,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    TBL_SLOT,
                    MOVE_FLAG,
                    EMPTY_FLAG,
                    STOCK_IN_TIME,
                    TRAN_CMF_1,
                    TRAN_CMF_2,
                    TRAN_CMF_3,
                    TRAN_CMF_4,
                    TRAN_CMF_5,
                    TRAN_CMF_6,
                    TRAN_CMF_7,
                    TRAN_CMF_8,
                    TRAN_CMF_9,
                    TRAN_CMF_10,
                    TRAN_CMF_11,
                    TRAN_CMF_12,
                    TRAN_CMF_13,
                    TRAN_CMF_14,
                    TRAN_CMF_15,
                    TRAN_CMF_16,
                    TRAN_CMF_17,
                    TRAN_CMF_18,
                    TRAN_CMF_19,
                    TRAN_CMF_20,
                    TRAN_USER_ID,
                    TRAN_COMMENT,
                    CRR_CMF_1,
                    CRR_CMF_2,
                    CRR_CMF_3,
                    CRR_CMF_4,
                    CRR_CMF_5,
                    CRR_CMF_6,
                    CRR_CMF_7,
                    CRR_CMF_8,
                    CRR_CMF_9,
                    CRR_CMF_10,
                    CRR_CMF_11,
                    CRR_CMF_12,
                    CRR_CMF_13,
                    CRR_CMF_14,
                    CRR_CMF_15,
                    CRR_CMF_16,
                    CRR_CMF_17,
                    CRR_CMF_18,
                    CRR_CMF_19,
                    CRR_CMF_20,
                    REUSE_COUNT
                FROM MRASCRRHIS
                WHERE CRR_ID = :MRASCRRHIS_N.CRR_ID
                    AND HIST_SEQ <= :MRASCRRHIS_N.HIST_SEQ
                    AND TRAN_TIME >= :MRASCRRHIS_N.TRAN_TIME
                    AND TRAN_TIME <= :MRASCRRHIS_N.SYS_TRAN_TIME
                ORDER BY HIST_SEQ DESC;
            EXEC SQL OPEN DBC_MRASCRRHIS_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MRASCRRHIS_CUR_3 CURSOR FOR
                SELECT CRR_ID 
                FROM MRASCRRHIS
                WHERE LOT_ID = :MRASCRRHIS_N.LOT_ID
                    AND LOT_HIST_SEQ = :MRASCRRHIS_N.LOT_HIST_SEQ
                    AND CRR_ID >= :MRASCRRHIS_N.CRR_ID
                GROUP BY CRR_ID
                ORDER BY CRR_ID ASC;
            EXEC SQL OPEN DBC_MRASCRRHIS_CUR_3;
            break;

        case 4:
            EXEC SQL DECLARE DBC_MRASCRRHIS_CUR_4 CURSOR FOR
                SELECT 
                    CRR_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    SYS_TRAN_TIME,
                    TRAN_CODE,
                    FACTORY,
                    CRR_STATUS,
                    CRR_STATUS_FLAG,
                    USAGE_COUNT,
                    CLEAN_COUNT,
                    RES_ID,
                    SUBRES_ID,
                    PORT_ID,
                    LOCATION_1,
                    LOCATION_2,
                    LOCATION_3,
                    LOCATION_4,
                    LOCATION_5,
                    NEED_CLEAN_FLAG,
                    FINISH_CLEAN_FLAG,
                    LAST_CLEAN_TIME,
                    LOT_ID,
                    LOT_HIST_SEQ,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    TBL_SLOT,
                    MOVE_FLAG,
                    EMPTY_FLAG,
                    STOCK_IN_TIME,
                    TRAN_CMF_1,
                    TRAN_CMF_2,
                    TRAN_CMF_3,
                    TRAN_CMF_4,
                    TRAN_CMF_5,
                    TRAN_CMF_6,
                    TRAN_CMF_7,
                    TRAN_CMF_8,
                    TRAN_CMF_9,
                    TRAN_CMF_10,
                    TRAN_CMF_11,
                    TRAN_CMF_12,
                    TRAN_CMF_13,
                    TRAN_CMF_14,
                    TRAN_CMF_15,
                    TRAN_CMF_16,
                    TRAN_CMF_17,
                    TRAN_CMF_18,
                    TRAN_CMF_19,
                    TRAN_CMF_20,
                    TRAN_USER_ID,
                    TRAN_COMMENT,
                    CRR_CMF_1,
                    CRR_CMF_2,
                    CRR_CMF_3,
                    CRR_CMF_4,
                    CRR_CMF_5,
                    CRR_CMF_6,
                    CRR_CMF_7,
                    CRR_CMF_8,
                    CRR_CMF_9,
                    CRR_CMF_10,
                    CRR_CMF_11,
                    CRR_CMF_12,
                    CRR_CMF_13,
                    CRR_CMF_14,
                    CRR_CMF_15,
                    CRR_CMF_16,
                    CRR_CMF_17,
                    CRR_CMF_18,
                    CRR_CMF_19,
                    CRR_CMF_20,
                    REUSE_COUNT
                FROM MRASCRRHIS
                WHERE LOT_ID = :MRASCRRHIS_N.LOT_ID
                    AND ((CRR_ID = :MRASCRRHIS_N.CRR_ID AND HIST_SEQ >= :MRASCRRHIS_N.HIST_SEQ) OR CRR_ID > :MRASCRRHIS_N.CRR_ID)
                    AND TRAN_TIME >= :MRASCRRHIS_N.TRAN_TIME
                    AND TRAN_TIME <= :MRASCRRHIS_N.SYS_TRAN_TIME
                ORDER BY CRR_ID ASC, HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MRASCRRHIS_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrascrrhis", sel_type);
}


