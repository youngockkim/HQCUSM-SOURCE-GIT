/* SQL CURSOR CLOSE Function */
void DBC_close_mrascrrhis(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MRASCRRHIS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MRASCRRHIS_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MRASCRRHIS_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MRASCRRHIS_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mrascrrhis", sel_type);
}


/* Initialize Function */
void DBC_init_mrascrrhis(struct MRASCRRHIS_TAG *MRASCRRHIS)
{
    /* memset by Space */
    memset(MRASCRRHIS, ' ', sizeof(struct MRASCRRHIS_TAG));
    
    MRASCRRHIS->HIST_SEQ = 0;
    MRASCRRHIS->USAGE_COUNT = 0;
    MRASCRRHIS->CLEAN_COUNT = 0;
    MRASCRRHIS->LOT_HIST_SEQ = 0;
    MRASCRRHIS->QTY_1 = 0;
    MRASCRRHIS->QTY_2 = 0;
    MRASCRRHIS->QTY_3 = 0;
    MRASCRRHIS->REUSE_COUNT = 0;
}


/* Add Null Function */
void DBC_add_null_mrascrrhis(struct MRASCRRHIS_N_TAG *MRASCRRHIS_N, struct MRASCRRHIS_TAG *MRASCRRHIS)
{
    /* memset by NULL */
    memset(MRASCRRHIS_N, '\0', sizeof(struct MRASCRRHIS_N_TAG));
    
    MEMCPY_AN(MRASCRRHIS_N->CRR_ID, MRASCRRHIS->CRR_ID, sizeof(MRASCRRHIS->CRR_ID));
    MRASCRRHIS_N->HIST_SEQ = MRASCRRHIS->HIST_SEQ;
    MEMCPY_AN(MRASCRRHIS_N->TRAN_TIME, MRASCRRHIS->TRAN_TIME, sizeof(MRASCRRHIS->TRAN_TIME));
    MEMCPY_AN(MRASCRRHIS_N->SYS_TRAN_TIME, MRASCRRHIS->SYS_TRAN_TIME, sizeof(MRASCRRHIS->SYS_TRAN_TIME));
    MEMCPY_AN(MRASCRRHIS_N->TRAN_CODE, MRASCRRHIS->TRAN_CODE, sizeof(MRASCRRHIS->TRAN_CODE));
    MEMCPY_AN(MRASCRRHIS_N->FACTORY, MRASCRRHIS->FACTORY, sizeof(MRASCRRHIS->FACTORY));
    MEMCPY_AN(MRASCRRHIS_N->CRR_STATUS, MRASCRRHIS->CRR_STATUS, sizeof(MRASCRRHIS->CRR_STATUS));
    MRASCRRHIS_N->CRR_STATUS_FLAG[0] = MRASCRRHIS->CRR_STATUS_FLAG;
    MRASCRRHIS_N->USAGE_COUNT = MRASCRRHIS->USAGE_COUNT;
    MRASCRRHIS_N->CLEAN_COUNT = MRASCRRHIS->CLEAN_COUNT;
    MEMCPY_AN(MRASCRRHIS_N->RES_ID, MRASCRRHIS->RES_ID, sizeof(MRASCRRHIS->RES_ID));
    MEMCPY_AN(MRASCRRHIS_N->SUBRES_ID, MRASCRRHIS->SUBRES_ID, sizeof(MRASCRRHIS->SUBRES_ID));
    MEMCPY_AN(MRASCRRHIS_N->PORT_ID, MRASCRRHIS->PORT_ID, sizeof(MRASCRRHIS->PORT_ID));
    MEMCPY_AN(MRASCRRHIS_N->LOCATION_1, MRASCRRHIS->LOCATION_1, sizeof(MRASCRRHIS->LOCATION_1));
    MEMCPY_AN(MRASCRRHIS_N->LOCATION_2, MRASCRRHIS->LOCATION_2, sizeof(MRASCRRHIS->LOCATION_2));
