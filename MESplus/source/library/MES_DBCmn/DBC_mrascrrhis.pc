                    :MRASCRRHIS_N.REUSE_COUNT
                FROM MRASCRRHIS
                WHERE CRR_ID = :MRASCRRHIS_N.CRR_ID
                    AND HIST_SEQ = :MRASCRRHIS_N.HIST_SEQ
                FOR UPDATE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mrascrrhis(&MRASCRRHIS_N, MRASCRRHIS);
    }
    DB_stop_query_timer("DBC_select_mrascrrhis_for_update", sel_type);
}


/* SQL SELECT_SCALAR Function */
double DBC_select_mrascrrhis_scalar(int sel_type, struct MRASCRRHIS_TAG *MRASCRRHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASCRRHIS_N_TAG MRASCRRHIS_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrascrrhis(&MRASCRRHIS_N, MRASCRRHIS);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MRASCRRHIS
                WHERE CRR_ID = :MRASCRRHIS_N.CRR_ID
                    AND HIST_SEQ = :MRASCRRHIS_N.HIST_SEQ;
            break;

        case 2:
            EXEC SQL SELECT NVL(MAX(HIST_SEQ),0) 
                INTO :d_value
                FROM MRASCRRHIS
                WHERE CRR_ID = :MRASCRRHIS_N.CRR_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mrascrrhis_scalar", sel_type);
    return d_value;
}


