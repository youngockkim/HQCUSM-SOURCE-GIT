                       FROM MRASCRRHIS HIS, MRASCRRDEF DEF
                      WHERE HIS.FACTORY = :MRASCRRHIS_N.FACTORY
                        AND HIS.CRR_ID = :MRASCRRHIS_N.CRR_ID
                        AND HIS.HIST_SEQ = (SELECT MAX(HIST_SEQ)
                                              FROM MRASCRRHIS
                                             WHERE FACTORY = HIS.FACTORY
                                               AND CRR_ID = HIS.CRR_ID
                                               AND TRAN_CODE = 'END'   
                                               AND RES_ID = :MRASCRRHIS_N.RES_ID)
                        AND HIS.FACTORY = DEF.FACTORY
                        AND HIS.CRR_ID = DEF.CRR_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mrascrrhis(&MRASCRRHIS_N, MRASCRRHIS);
    }
    DB_stop_query_timer("DBC_select_mrascrrhis", sel_type);
}


