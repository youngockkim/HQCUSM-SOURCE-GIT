                    CHT_CMF_6 = :MSPCCHTDEF_N.CHT_CMF_6,
                    CHT_CMF_7 = :MSPCCHTDEF_N.CHT_CMF_7,
                    CHT_CMF_8 = :MSPCCHTDEF_N.CHT_CMF_8,
                    CHT_CMF_9 = :MSPCCHTDEF_N.CHT_CMF_9,
                    CHT_CMF_10 = :MSPCCHTDEF_N.CHT_CMF_10,
