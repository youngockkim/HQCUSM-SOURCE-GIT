                    R_RULE_CHECK_TBL = :MSPCCHTDEF_N.R_RULE_CHECK_TBL,
                    X_ALARM_CODE_TBL = :MSPCCHTDEF_N.X_ALARM_CODE_TBL,
                    R_ALARM_CODE_TBL = :MSPCCHTDEF_N.R_ALARM_CODE_TBL,
