                    WB_SIGMA_FLAG,
                    MIN_TRIAL_NUMBER
                FROM MSPCCHTDEF
                WHERE FACTORY = :MSPCCHTDEF_N.FACTORY
                    AND MAT_ID = ' '
                    AND MAT_VER = ' '
                    AND (FLOW = :MSPCCHTDEF_N.FLOW OR PROC_FLOW = :MSPCCHTDEF_N.FLOW);
            EXEC SQL OPEN DBC_MSPCCHTDEF_CUR_16;
            break;  
        case 17:
            EXEC SQL DECLARE DBC_MSPCCHTDEF_CUR_17 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    CHART_DESC,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RES_ID,
                    SUBRES_ID,
                    COL_SET_ID,
                    SYNC_EDC_FLAG,
                    CHAR_ID,
                    LOT_RES_FLAG,
                    MEAS_RES_ID,
                    PROC_FLOW,
                    PROC_OPER,
                    PROC_RES_ID,
                    RECIPE_ID,
                    RECIPE_VERSION,
                    GRAPH_TYPE,
                    UNIT_USE_FLAG,
                    UNIT_COUNT,
                    SAMPLE_SIZE,
                    CONSTANT_1,
                    CONSTANT_2,
                    CONSTANT_3,
                    CONSTANT_4,
