    /* memset by NULL */
    memset(MTMPCRRHIS_N, '\0', sizeof(struct MTMPCRRHIS_N_TAG));
    
    MTMPCRRHIS_N->TABLE_UPDATE_SEQ = MTMPCRRHIS->TABLE_UPDATE_SEQ;
    MEMCPY_AN(MTMPCRRHIS_N->CM_KEY_1, MTMPCRRHIS->CM_KEY_1, sizeof(MTMPCRRHIS->CM_KEY_1));
