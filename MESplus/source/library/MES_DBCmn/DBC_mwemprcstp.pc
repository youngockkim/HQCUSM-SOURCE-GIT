                :MWEMPRCSTP_N.PROC_ID,
                :MWEMPRCSTP_N.STEP_ID,
                :MWEMPRCSTP_N.STEP_SEQ,
                :MWEMPRCSTP_N.OPTIONAL_FLAG,
                :MWEMPRCSTP_N.ARBITRARY_FLAG,
                :MWEMPRCSTP_N.INPUT_APPROVER_FLAG,
                :MWEMPRCSTP_N.STEP_GROUP,
                :MWEMPRCSTP_N.MIN_PROC_STEP_COUNT,
                :MWEMPRCSTP_N.NOTIFY_ALARM_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwemprcstp(&MWEMPRCSTP_N, MWEMPRCSTP);
    }

    DB_stop_query_timer("DBC_fetch_mwemprcstp", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwemprcstp(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWEMPRCSTP_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWEMPRCSTP_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MWEMPRCSTP_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MWEMPRCSTP_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MWEMPRCSTP_CUR_5;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("DBC_close_mwemprcstp", sel_type);
}


/* Initialize Function */
void DBC_init_mwemprcstp(struct MWEMPRCSTP_TAG *MWEMPRCSTP)
{
    /* memset by Space */
    memset(MWEMPRCSTP, ' ', sizeof(struct MWEMPRCSTP_TAG));
    
    MWEMPRCSTP->STEP_SEQ = 0;
    MWEMPRCSTP->MIN_PROC_STEP_COUNT = 0;
}


/* Add Null Function */
void DBC_add_null_mwemprcstp(struct MWEMPRCSTP_N_TAG *MWEMPRCSTP_N, struct MWEMPRCSTP_TAG *MWEMPRCSTP)
{
    /* memset by NULL */
    memset(MWEMPRCSTP_N, '\0', sizeof(struct MWEMPRCSTP_N_TAG));
    
    MEMCPY_AN(MWEMPRCSTP_N->CREATE_TIME, MWEMPRCSTP->CREATE_TIME, sizeof(MWEMPRCSTP->CREATE_TIME));
    MEMCPY_AN(MWEMPRCSTP_N->CREATE_USER_ID, MWEMPRCSTP->CREATE_USER_ID, sizeof(MWEMPRCSTP->CREATE_USER_ID));
    MEMCPY_AN(MWEMPRCSTP_N->UPDATE_TIME, MWEMPRCSTP->UPDATE_TIME, sizeof(MWEMPRCSTP->UPDATE_TIME));
    MEMCPY_AN(MWEMPRCSTP_N->UPDATE_USER_ID, MWEMPRCSTP->UPDATE_USER_ID, sizeof(MWEMPRCSTP->UPDATE_USER_ID));
    MEMCPY_AN(MWEMPRCSTP_N->FACTORY, MWEMPRCSTP->FACTORY, sizeof(MWEMPRCSTP->FACTORY));
    MEMCPY_AN(MWEMPRCSTP_N->WORK_PROC_TYPE, MWEMPRCSTP->WORK_PROC_TYPE, sizeof(MWEMPRCSTP->WORK_PROC_TYPE));
    MEMCPY_AN(MWEMPRCSTP_N->PROC_ID, MWEMPRCSTP->PROC_ID, sizeof(MWEMPRCSTP->PROC_ID));
    MEMCPY_AN(MWEMPRCSTP_N->STEP_ID, MWEMPRCSTP->STEP_ID, sizeof(MWEMPRCSTP->STEP_ID));
    MWEMPRCSTP_N->STEP_SEQ = MWEMPRCSTP->STEP_SEQ;
    MWEMPRCSTP_N->OPTIONAL_FLAG[0] = MWEMPRCSTP->OPTIONAL_FLAG;
    MWEMPRCSTP_N->ARBITRARY_FLAG[0] = MWEMPRCSTP->ARBITRARY_FLAG;
    MWEMPRCSTP_N->INPUT_APPROVER_FLAG[0] = MWEMPRCSTP->INPUT_APPROVER_FLAG;
    MEMCPY_AN(MWEMPRCSTP_N->STEP_GROUP, MWEMPRCSTP->STEP_GROUP, sizeof(MWEMPRCSTP->STEP_GROUP));
    MWEMPRCSTP_N->MIN_PROC_STEP_COUNT = MWEMPRCSTP->MIN_PROC_STEP_COUNT;
    MEMCPY_AN(MWEMPRCSTP_N->NOTIFY_ALARM_ID, MWEMPRCSTP->NOTIFY_ALARM_ID, sizeof(MWEMPRCSTP->NOTIFY_ALARM_ID));
}


/* Del Null Function */
void DBC_del_null_mwemprcstp(struct MWEMPRCSTP_N_TAG *MWEMPRCSTP_N, struct MWEMPRCSTP_TAG *MWEMPRCSTP)
{
    MEMCPY_DN(MWEMPRCSTP->CREATE_TIME, MWEMPRCSTP_N->CREATE_TIME, sizeof(MWEMPRCSTP->CREATE_TIME));
    MEMCPY_DN(MWEMPRCSTP->CREATE_USER_ID, MWEMPRCSTP_N->CREATE_USER_ID, sizeof(MWEMPRCSTP->CREATE_USER_ID));
    MEMCPY_DN(MWEMPRCSTP->UPDATE_TIME, MWEMPRCSTP_N->UPDATE_TIME, sizeof(MWEMPRCSTP->UPDATE_TIME));
    MEMCPY_DN(MWEMPRCSTP->UPDATE_USER_ID, MWEMPRCSTP_N->UPDATE_USER_ID, sizeof(MWEMPRCSTP->UPDATE_USER_ID));
    MEMCPY_DN(MWEMPRCSTP->FACTORY, MWEMPRCSTP_N->FACTORY, sizeof(MWEMPRCSTP->FACTORY));
    MEMCPY_DN(MWEMPRCSTP->WORK_PROC_TYPE, MWEMPRCSTP_N->WORK_PROC_TYPE, sizeof(MWEMPRCSTP->WORK_PROC_TYPE));
    MEMCPY_DN(MWEMPRCSTP->PROC_ID, MWEMPRCSTP_N->PROC_ID, sizeof(MWEMPRCSTP->PROC_ID));
    MEMCPY_DN(MWEMPRCSTP->STEP_ID, MWEMPRCSTP_N->STEP_ID, sizeof(MWEMPRCSTP->STEP_ID));
    MWEMPRCSTP->STEP_SEQ = MWEMPRCSTP_N->STEP_SEQ;
    MWEMPRCSTP->OPTIONAL_FLAG = MWEMPRCSTP_N->OPTIONAL_FLAG[0];
    MWEMPRCSTP->ARBITRARY_FLAG = MWEMPRCSTP_N->ARBITRARY_FLAG[0];
    MWEMPRCSTP->INPUT_APPROVER_FLAG = MWEMPRCSTP_N->INPUT_APPROVER_FLAG[0];
    MEMCPY_DN(MWEMPRCSTP->STEP_GROUP, MWEMPRCSTP_N->STEP_GROUP, sizeof(MWEMPRCSTP->STEP_GROUP));
    MWEMPRCSTP->MIN_PROC_STEP_COUNT = MWEMPRCSTP_N->MIN_PROC_STEP_COUNT;
    MEMCPY_DN(MWEMPRCSTP->NOTIFY_ALARM_ID, MWEMPRCSTP_N->NOTIFY_ALARM_ID, sizeof(MWEMPRCSTP->NOTIFY_ALARM_ID));
}


