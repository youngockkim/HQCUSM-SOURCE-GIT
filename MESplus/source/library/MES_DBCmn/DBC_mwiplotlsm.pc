/* SQL UPDATE Function */
void DBC_update_mwiplotlsm(int sel_type, struct MWIPLOTLSM_TAG *MWIPLOTLSM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTLSM_N_TAG MWIPLOTLSM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplotlsm(&MWIPLOTLSM_N, MWIPLOTLSM);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MWIPLOTLSM SET
                    TRAN_TIME = :MWIPLOTLSM_N.TRAN_TIME,
                    HIST_DEL_FLAG = :MWIPLOTLSM_N.HIST_DEL_FLAG,
                    FACTORY = :MWIPLOTLSM_N.FACTORY,
                    MAT_ID = :MWIPLOTLSM_N.MAT_ID,
                    MAT_VER = :MWIPLOTLSM_N.MAT_VER,
                    FLOW = :MWIPLOTLSM_N.FLOW,
                    FLOW_SEQ_NUM = :MWIPLOTLSM_N.FLOW_SEQ_NUM,
                    OPER = :MWIPLOTLSM_N.OPER,
                    RES_ID = :MWIPLOTLSM_N.RES_ID,
