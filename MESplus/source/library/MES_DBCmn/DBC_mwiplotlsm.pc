}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwiplotlsm(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPLOTLSM_CUR_1;
            break;
        
        case 2:
            EXEC SQL CLOSE DBC_MWIPLOTLSM_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MWIPLOTLSM_CUR_3;
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwiplotlsm", sel_type);
}


/* Initialize Function */
void DBC_init_mwiplotlsm(struct MWIPLOTLSM_TAG *MWIPLOTLSM)
{
    /* memset by Space */
    memset(MWIPLOTLSM, ' ', sizeof(struct MWIPLOTLSM_TAG));
    
    MWIPLOTLSM->HIST_SEQ = 0;
    MWIPLOTLSM->MAT_VER = 0;
    MWIPLOTLSM->FLOW_SEQ_NUM = 0;
    MWIPLOTLSM->SEQ_NUM = 0;
    MWIPLOTLSM->LOSS_QTY = 0;
}


/* Add Null Function */
void DBC_add_null_mwiplotlsm(struct MWIPLOTLSM_N_TAG *MWIPLOTLSM_N, struct MWIPLOTLSM_TAG *MWIPLOTLSM)
{
    /* memset by NULL */
    memset(MWIPLOTLSM_N, '\0', sizeof(struct MWIPLOTLSM_N_TAG));
    
    MEMCPY_AN(MWIPLOTLSM_N->LOT_ID, MWIPLOTLSM->LOT_ID, sizeof(MWIPLOTLSM->LOT_ID));
    MWIPLOTLSM_N->HIST_SEQ = MWIPLOTLSM->HIST_SEQ;
    MWIPLOTLSM_N->QTY_FLAG[0] = MWIPLOTLSM->QTY_FLAG;
    MEMCPY_AN(MWIPLOTLSM_N->TRAN_TIME, MWIPLOTLSM->TRAN_TIME, sizeof(MWIPLOTLSM->TRAN_TIME));
    MWIPLOTLSM_N->HIST_DEL_FLAG[0] = MWIPLOTLSM->HIST_DEL_FLAG;
    MEMCPY_AN(MWIPLOTLSM_N->FACTORY, MWIPLOTLSM->FACTORY, sizeof(MWIPLOTLSM->FACTORY));
    MEMCPY_AN(MWIPLOTLSM_N->MAT_ID, MWIPLOTLSM->MAT_ID, sizeof(MWIPLOTLSM->MAT_ID));
    MWIPLOTLSM_N->MAT_VER = MWIPLOTLSM->MAT_VER;
    MEMCPY_AN(MWIPLOTLSM_N->FLOW, MWIPLOTLSM->FLOW, sizeof(MWIPLOTLSM->FLOW));
    MWIPLOTLSM_N->FLOW_SEQ_NUM = MWIPLOTLSM->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPLOTLSM_N->OPER, MWIPLOTLSM->OPER, sizeof(MWIPLOTLSM->OPER));
    MEMCPY_AN(MWIPLOTLSM_N->RES_ID, MWIPLOTLSM->RES_ID, sizeof(MWIPLOTLSM->RES_ID));
    MWIPLOTLSM_N->SEQ_NUM = MWIPLOTLSM->SEQ_NUM;
    MEMCPY_AN(MWIPLOTLSM_N->LOSS_CODE, MWIPLOTLSM->LOSS_CODE, sizeof(MWIPLOTLSM->LOSS_CODE));
    MWIPLOTLSM_N->LOSS_QTY = MWIPLOTLSM->LOSS_QTY;
}


/* Del Null Function */
void DBC_del_null_mwiplotlsm(struct MWIPLOTLSM_N_TAG *MWIPLOTLSM_N, struct MWIPLOTLSM_TAG *MWIPLOTLSM)
{
    MEMCPY_DN(MWIPLOTLSM->LOT_ID, MWIPLOTLSM_N->LOT_ID, sizeof(MWIPLOTLSM->LOT_ID));
    MWIPLOTLSM->HIST_SEQ = MWIPLOTLSM_N->HIST_SEQ;
    MWIPLOTLSM->QTY_FLAG = MWIPLOTLSM_N->QTY_FLAG[0];
    MEMCPY_DN(MWIPLOTLSM->TRAN_TIME, MWIPLOTLSM_N->TRAN_TIME, sizeof(MWIPLOTLSM->TRAN_TIME));
    MWIPLOTLSM->HIST_DEL_FLAG = MWIPLOTLSM_N->HIST_DEL_FLAG[0];
    MEMCPY_DN(MWIPLOTLSM->FACTORY, MWIPLOTLSM_N->FACTORY, sizeof(MWIPLOTLSM->FACTORY));
    MEMCPY_DN(MWIPLOTLSM->MAT_ID, MWIPLOTLSM_N->MAT_ID, sizeof(MWIPLOTLSM->MAT_ID));
    MWIPLOTLSM->MAT_VER = MWIPLOTLSM_N->MAT_VER;
    MEMCPY_DN(MWIPLOTLSM->FLOW, MWIPLOTLSM_N->FLOW, sizeof(MWIPLOTLSM->FLOW));
    MWIPLOTLSM->FLOW_SEQ_NUM = MWIPLOTLSM_N->FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPLOTLSM->OPER, MWIPLOTLSM_N->OPER, sizeof(MWIPLOTLSM->OPER));
    MEMCPY_DN(MWIPLOTLSM->RES_ID, MWIPLOTLSM_N->RES_ID, sizeof(MWIPLOTLSM->RES_ID));
    MWIPLOTLSM->SEQ_NUM = MWIPLOTLSM_N->SEQ_NUM;
    MEMCPY_DN(MWIPLOTLSM->LOSS_CODE, MWIPLOTLSM_N->LOSS_CODE, sizeof(MWIPLOTLSM->LOSS_CODE));
    MWIPLOTLSM->LOSS_QTY = MWIPLOTLSM_N->LOSS_QTY;
}




