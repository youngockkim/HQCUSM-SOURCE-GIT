/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrascrrdef(int sel_type, struct MRASCRRDEF_TAG *MRASCRRDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASCRRDEF_N_TAG MRASCRRDEF_N;
        char   sql[10000];
        char   ts[1000];
        //FILE   *fp;
    EXEC SQL END DECLARE SECTION;    

    DB_start_query_timer();
    
    DBC_add_null_mrascrrdef(&MRASCRRDEF_N, MRASCRRDEF);
    DB_error_code = 0;
    memset(ts, 0x00, sizeof(ts));

    switch(sel_type)
    {
        case 1:
            memset( sql, 0x00, sizeof(sql));
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql), "CRR_ID, CRR_DESC, FACTORY, CRR_GROUP, CRR_STATUS, CRR_STATUS_FLAG, CRR_TYPE1, CRR_TYPE2, CRR_TYPE3, CRR_MATERIAL, ");
