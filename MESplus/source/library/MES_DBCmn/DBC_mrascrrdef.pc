/* SQL CURSOR CLOSE Function */
void DBC_close_mrascrrdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MRASCRRDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MRASCRRDEF_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MRASCRRDEF_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MRASCRRDEF_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MRASCRRDEF_CUR_5;
            break;

        case 7:
            EXEC SQL CLOSE DBC_MRASCRRDEF_CUR_7;
            break;

        case 8:
            EXEC SQL CLOSE DBC_MRASCRRDEF_CUR_8;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mrascrrdef", sel_type);
}



/* Initialize Function */
void DBC_init_mrascrrdef(struct MRASCRRDEF_TAG *MRASCRRDEF)
{
    /* memset by Space */
    memset(MRASCRRDEF, ' ', sizeof(struct MRASCRRDEF_TAG));
    
    MRASCRRDEF->CRR_SIZE = 0;
    MRASCRRDEF->USAGE_LIMIT_COUNT = 0;
    MRASCRRDEF->USAGE_LIMIT_TIME = 0;
    MRASCRRDEF->USAGE_COUNT = 0;
    MRASCRRDEF->CLEAN_LIMIT_COUNT = 0;
    MRASCRRDEF->CLEAN_COUNT = 0;
    MRASCRRDEF->LOT_HIST_SEQ = 0;
    MRASCRRDEF->QTY_1 = 0;
    MRASCRRDEF->QTY_2 = 0;
    MRASCRRDEF->QTY_3 = 0;
    MRASCRRDEF->LAST_HIST_SEQ = 0;
    MRASCRRDEF->REUSE_LIMIT_COUNT = 0;
    MRASCRRDEF->REUSE_LIMIT_TIME = 0;
    MRASCRRDEF->REUSE_COUNT = 0;
}


