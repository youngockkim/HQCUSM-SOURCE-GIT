                sprintf(sql + strlen(sql), "AND CRR_ID LIKE '%s%%' ", ts);
            }

            sprintf(sql + strlen(sql), "ORDER BY CRR_ID ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MRASCRRDEF_CUR_7 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MRASCRRDEF_CUR_7;       
            break;

        case 8:
            memset( sql, 0x00, sizeof(sql));
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql), "CRR_ID, CRR_DESC, FACTORY, CRR_GROUP, CRR_STATUS, CRR_STATUS_FLAG, CRR_TYPE1, CRR_TYPE2, CRR_TYPE3, CRR_MATERIAL, ");
            sprintf(sql + strlen(sql), "CRR_SIZE, USE_AREA_ID, USE_SUB_AREA_ID, USE_RES_ID, USAGE_LIMIT_COUNT, USAGE_LIMIT_TIME, USAGE_COUNT, CLEAN_LIMIT_COUNT, ");
            sprintf(sql + strlen(sql), "CLEAN_COUNT, RES_ID, SUBRES_ID, PORT_ID, LOCATION_1, LOCATION_2, LOCATION_3, LOCATION_4, LOCATION_5, OLD_RES_ID, ");
            sprintf(sql + strlen(sql), "OLD_SUBRES_ID, OLD_PORT_ID, OLD_LOCATION_1, OLD_LOCATION_2, OLD_LOCATION_3, OLD_LOCATION_4, OLD_LOCATION_5, NEED_CLEAN_FLAG, ");
            sprintf(sql + strlen(sql), "FINISH_CLEAN_FLAG, LAST_CLEAN_TIME, LOT_ID, LOT_HIST_SEQ, QTY_1, QTY_2, QTY_3, TBL_SLOT, MOVE_FLAG, EMPTY_FLAG, ");
            sprintf(sql + strlen(sql), "STOCK_IN_TIME, PLAN_TERMINATE_TIME, CRR_CMF_1, CRR_CMF_2, CRR_CMF_3, CRR_CMF_4, CRR_CMF_5, CRR_CMF_6, CRR_CMF_7, ");
            sprintf(sql + strlen(sql), "CRR_CMF_8, CRR_CMF_9, CRR_CMF_10, CRR_CMF_11, CRR_CMF_12, CRR_CMF_13, CRR_CMF_14, CRR_CMF_15, CRR_CMF_16, CRR_CMF_17, ");
            sprintf(sql + strlen(sql), "CRR_CMF_18, CRR_CMF_19, CRR_CMF_20, LAST_HIST_SEQ, LAST_TRAN_TIME, LAST_TRAN_CODE, CREATE_USER_ID, CREATE_TIME, ");
            sprintf(sql + strlen(sql), "UPDATE_USER_ID, UPDATE_TIME, USAGE_LIMIT_ALARM, CLEAN_LIMIT_ALARM, REUSE_LIMIT_COUNT, REUSE_LIMIT_TIME, REUSE_COUNT, REUSE_LIMIT_ALARM ");
            sprintf(sql + strlen(sql), "FROM MRASCRRDEF ");

            make_valid_quote(ts, MRASCRRDEF_N.FACTORY);
            sprintf(sql + strlen(sql), "WHERE FACTORY = '%s' ", ts);
            make_valid_quote(ts, MRASCRRDEF_N.CRR_ID);
            sprintf(sql + strlen(sql), "AND CRR_ID >= '%s' ", ts);
            
            sprintf(sql + strlen(sql), "AND CRR_GROUP IN ( SELECT CRR_GROUP FROM MRASCGRREL ");

            make_valid_quote(ts, MRASCRRDEF_N.FACTORY);
            sprintf(sql + strlen(sql), "WHERE FACTORY = '%s' ", ts);
            sprintf(sql + strlen(sql), "AND REL_LEVEL = '%c' ", MRASCRRDEF->MOVE_FLAG);
            make_valid_quote(ts, MRASCRRDEF_N.CRR_CMF_1);
            sprintf(sql + strlen(sql), "AND MAT_ID = '%s' ", ts);
            make_valid_quote(ts, MRASCRRDEF_N.CRR_CMF_2);
            sprintf(sql + strlen(sql), "AND MAT_VER = '%s' ", ts);
            make_valid_quote(ts, MRASCRRDEF_N.CRR_CMF_3);
            sprintf(sql + strlen(sql), "AND FLOW = '%s' ", ts);
            make_valid_quote(ts, MRASCRRDEF_N.CRR_CMF_4);
            sprintf(sql + strlen(sql), "AND OPER = '%s' ", ts);
            make_valid_quote(ts, MRASCRRDEF_N.CRR_CMF_5);
            sprintf(sql + strlen(sql), "AND RES_ID = '%s' ", ts);
            make_valid_quote(ts, MRASCRRDEF_N.CRR_CMF_6);
            sprintf(sql + strlen(sql), "AND PORT_ID = '%s' ) ", ts);

            if(ISSPACE(MRASCRRDEF->CRR_TYPE1, sizeof(MRASCRRDEF->CRR_TYPE1)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASCRRDEF_N.CRR_TYPE1);
                sprintf(sql + strlen(sql), "AND CRR_TYPE1 = '%s' ", ts);
            }
            if(ISSPACE(MRASCRRDEF->CRR_DESC, sizeof(MRASCRRDEF->CRR_DESC)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASCRRDEF_N.CRR_DESC);
                sprintf(sql + strlen(sql), "AND CRR_ID LIKE '%s%%' ", ts);
            }

            sprintf(sql + strlen(sql), "AND EMPTY_FLAG = '%c' ", MRASCRRDEF_N.EMPTY_FLAG[0]);
            sprintf(sql + strlen(sql), "ORDER BY CRR_ID ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MRASCRRDEF_CUR_8 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MRASCRRDEF_CUR_8;       
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrascrrdef", sel_type);
}


