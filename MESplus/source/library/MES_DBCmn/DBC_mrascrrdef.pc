                    :MRASCRRDEF_N.REUSE_COUNT,
                    :MRASCRRDEF_N.REUSE_LIMIT_ALARM
                FROM MRASCRRDEF
                WHERE CRR_ID = :MRASCRRDEF_N.CRR_ID
                FOR UPDATE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mrascrrdef(&MRASCRRDEF_N, MRASCRRDEF);
    }

    DB_stop_query_timer("DBC_select_mrascrrdef_for_update", sel_type);
}


/* SQL SELECT_SCALAR Function */
double DBC_select_mrascrrdef_scalar(int sel_type, struct MRASCRRDEF_TAG *MRASCRRDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASCRRDEF_N_TAG MRASCRRDEF_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrascrrdef(&MRASCRRDEF_N, MRASCRRDEF);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MRASCRRDEF
                WHERE CRR_ID = :MRASCRRDEF_N.CRR_ID;
            break;

        case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MRASCRRDEF
                WHERE FACTORY = :MRASCRRDEF_N.FACTORY
                    AND ROWNUM = 1;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mrascrrdef_scalar", sel_type);

    return d_value;
}


/* SQL DELETE Function */
void DBC_delete_mrascrrdef(int sel_type, struct MRASCRRDEF_TAG *MRASCRRDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASCRRDEF_N_TAG MRASCRRDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrascrrdef(&MRASCRRDEF_N, MRASCRRDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM MRASCRRDEF
                WHERE CRR_ID = :MRASCRRDEF_N.CRR_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_delete_mrascrrdef", sel_type);
}


