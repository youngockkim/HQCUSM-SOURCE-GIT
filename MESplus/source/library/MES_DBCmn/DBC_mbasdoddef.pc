                :MBASDODDEF_N.ROW_DATA_INC,
                :MBASDODDEF_N.COL_DATA_INC,
                :MBASDODDEF_N.ARR_CELL_SIZE,
                :MBASDODDEF_N.ARR_CELL_FONT,
                :MBASDODDEF_N.CREATE_USER_ID,
                :MBASDODDEF_N.CREATE_TIME,
                :MBASDODDEF_N.UPDATE_USER_ID,
                :MBASDODDEF_N.UPDATE_TIME,
                :MBASDODDEF_N.RESV_FIELD_1,
                :MBASDODDEF_N.RESV_FIELD_2,
                :MBASDODDEF_N.RESV_FIELD_3,
                :MBASDODDEF_N.RESV_FIELD_4,
                :MBASDODDEF_N.RESV_FIELD_5,
                :MBASDODDEF_N.RESV_FLAG_1,
                :MBASDODDEF_N.RESV_FLAG_2,
                :MBASDODDEF_N.RESV_FLAG_3,
                :MBASDODDEF_N.RESV_FLAG_4,
                :MBASDODDEF_N.RESV_FLAG_5;
            break;

        case 2:
            EXEC SQL FETCH DBC_MBASDODDEF_CUR_2 INTO
                :MBASDODDEF_N.FACTORY,
                :MBASDODDEF_N.DOF_ID,
                :MBASDODDEF_N.DOT_ID,
                :MBASDODDEF_N.DOT_SEQ,
                :MBASDODDEF_N.LEFT_POSITION,
                :MBASDODDEF_N.SPACE_COUNT,
                :MBASDODDEF_N.START_PAGE,
                :MBASDODDEF_N.STOP_PAGE,
                :MBASDODDEF_N.HEADER_FLAG,
                :MBASDODDEF_N.KEEP_LINE_FLAG,
                :MBASDODDEF_N.KEEP_LINE,
                :MBASDODDEF_N.PAGE_BREAK,
                :MBASDODDEF_N.ROW_DATA_INC,
                :MBASDODDEF_N.COL_DATA_INC,
                :MBASDODDEF_N.ARR_CELL_SIZE,
                :MBASDODDEF_N.ARR_CELL_FONT,
                :MBASDODDEF_N.CREATE_USER_ID,
                :MBASDODDEF_N.CREATE_TIME,
                :MBASDODDEF_N.UPDATE_USER_ID,
                :MBASDODDEF_N.UPDATE_TIME,
                :MBASDODDEF_N.RESV_FIELD_1,
                :MBASDODDEF_N.RESV_FIELD_2,
                :MBASDODDEF_N.RESV_FIELD_3,
                :MBASDODDEF_N.RESV_FIELD_4,
                :MBASDODDEF_N.RESV_FIELD_5,
                :MBASDODDEF_N.RESV_FLAG_1,
                :MBASDODDEF_N.RESV_FLAG_2,
                :MBASDODDEF_N.RESV_FLAG_3,
                :MBASDODDEF_N.RESV_FLAG_4,
                :MBASDODDEF_N.RESV_FLAG_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mbasdoddef(&MBASDODDEF_N, MBASDODDEF);
    }
    DB_stop_query_timer("DBC_fetch_mbasdoddef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mbasdoddef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MBASDODDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MBASDODDEF_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mbasdoddef", sel_type);
}


/* Initialize Function */
void DBC_init_mbasdoddef(struct MBASDODDEF_TAG *MBASDODDEF)
{
    /* memset by Space */
    memset(MBASDODDEF, ' ', sizeof(struct MBASDODDEF_TAG));
    
    MBASDODDEF->DOT_SEQ = 0;
    MBASDODDEF->LEFT_POSITION = 0;
    MBASDODDEF->SPACE_COUNT = 0;
    MBASDODDEF->START_PAGE = 0;
    MBASDODDEF->STOP_PAGE = 0;	
	MBASDODDEF->KEEP_LINE = 0;
}


/* Add Null Function */
void DBC_add_null_mbasdoddef(struct MBASDODDEF_N_TAG *MBASDODDEF_N, struct MBASDODDEF_TAG *MBASDODDEF)
{
    /* memset by NULL */
    memset(MBASDODDEF_N, '\0', sizeof(struct MBASDODDEF_N_TAG));
    
    MEMCPY_AN(MBASDODDEF_N->FACTORY, MBASDODDEF->FACTORY, sizeof(MBASDODDEF->FACTORY));
    MEMCPY_AN(MBASDODDEF_N->DOF_ID, MBASDODDEF->DOF_ID, sizeof(MBASDODDEF->DOF_ID));
    MEMCPY_AN(MBASDODDEF_N->DOT_ID, MBASDODDEF->DOT_ID, sizeof(MBASDODDEF->DOT_ID));
    MBASDODDEF_N->DOT_SEQ = MBASDODDEF->DOT_SEQ;
    MBASDODDEF_N->LEFT_POSITION = MBASDODDEF->LEFT_POSITION;
    MBASDODDEF_N->SPACE_COUNT = MBASDODDEF->SPACE_COUNT;
    MBASDODDEF_N->START_PAGE = MBASDODDEF->START_PAGE;
    MBASDODDEF_N->STOP_PAGE = MBASDODDEF->STOP_PAGE;
    MBASDODDEF_N->HEADER_FLAG[0] = MBASDODDEF->HEADER_FLAG;
	MBASDODDEF_N->KEEP_LINE_FLAG[0] = MBASDODDEF->KEEP_LINE_FLAG;
	MBASDODDEF_N->KEEP_LINE = MBASDODDEF->KEEP_LINE;
    MBASDODDEF_N->PAGE_BREAK[0] = MBASDODDEF->PAGE_BREAK;
    MBASDODDEF_N->ROW_DATA_INC[0] = MBASDODDEF->ROW_DATA_INC;
    MBASDODDEF_N->COL_DATA_INC[0] = MBASDODDEF->COL_DATA_INC;
    MBASDODDEF_N->ARR_CELL_SIZE[0] = MBASDODDEF->ARR_CELL_SIZE;
    MBASDODDEF_N->ARR_CELL_FONT[0] = MBASDODDEF->ARR_CELL_FONT;
    MEMCPY_AN(MBASDODDEF_N->CREATE_USER_ID, MBASDODDEF->CREATE_USER_ID, sizeof(MBASDODDEF->CREATE_USER_ID));
    MEMCPY_AN(MBASDODDEF_N->CREATE_TIME, MBASDODDEF->CREATE_TIME, sizeof(MBASDODDEF->CREATE_TIME));
    MEMCPY_AN(MBASDODDEF_N->UPDATE_USER_ID, MBASDODDEF->UPDATE_USER_ID, sizeof(MBASDODDEF->UPDATE_USER_ID));
    MEMCPY_AN(MBASDODDEF_N->UPDATE_TIME, MBASDODDEF->UPDATE_TIME, sizeof(MBASDODDEF->UPDATE_TIME));
    MEMCPY_AN(MBASDODDEF_N->RESV_FIELD_1, MBASDODDEF->RESV_FIELD_1, sizeof(MBASDODDEF->RESV_FIELD_1));
    MEMCPY_AN(MBASDODDEF_N->RESV_FIELD_2, MBASDODDEF->RESV_FIELD_2, sizeof(MBASDODDEF->RESV_FIELD_2));
    MEMCPY_AN(MBASDODDEF_N->RESV_FIELD_3, MBASDODDEF->RESV_FIELD_3, sizeof(MBASDODDEF->RESV_FIELD_3));
    MEMCPY_AN(MBASDODDEF_N->RESV_FIELD_4, MBASDODDEF->RESV_FIELD_4, sizeof(MBASDODDEF->RESV_FIELD_4));
    MEMCPY_AN(MBASDODDEF_N->RESV_FIELD_5, MBASDODDEF->RESV_FIELD_5, sizeof(MBASDODDEF->RESV_FIELD_5));
    MBASDODDEF_N->RESV_FLAG_1[0] = MBASDODDEF->RESV_FLAG_1;
    MBASDODDEF_N->RESV_FLAG_2[0] = MBASDODDEF->RESV_FLAG_2;
    MBASDODDEF_N->RESV_FLAG_3[0] = MBASDODDEF->RESV_FLAG_3;
    MBASDODDEF_N->RESV_FLAG_4[0] = MBASDODDEF->RESV_FLAG_4;
    MBASDODDEF_N->RESV_FLAG_5[0] = MBASDODDEF->RESV_FLAG_5;
}


/* Del Null Function */
void DBC_del_null_mbasdoddef(struct MBASDODDEF_N_TAG *MBASDODDEF_N, struct MBASDODDEF_TAG *MBASDODDEF)
{
    MEMCPY_DN(MBASDODDEF->FACTORY, MBASDODDEF_N->FACTORY, sizeof(MBASDODDEF->FACTORY));
    MEMCPY_DN(MBASDODDEF->DOF_ID, MBASDODDEF_N->DOF_ID, sizeof(MBASDODDEF->DOF_ID));
    MEMCPY_DN(MBASDODDEF->DOT_ID, MBASDODDEF_N->DOT_ID, sizeof(MBASDODDEF->DOT_ID));
    MBASDODDEF->DOT_SEQ = MBASDODDEF_N->DOT_SEQ;
    MBASDODDEF->LEFT_POSITION = MBASDODDEF_N->LEFT_POSITION;
    MBASDODDEF->SPACE_COUNT = MBASDODDEF_N->SPACE_COUNT;
    MBASDODDEF->START_PAGE = MBASDODDEF_N->START_PAGE;
    MBASDODDEF->STOP_PAGE = MBASDODDEF_N->STOP_PAGE;
    MBASDODDEF->HEADER_FLAG = MBASDODDEF_N->HEADER_FLAG[0];
	MBASDODDEF->KEEP_LINE_FLAG = MBASDODDEF_N->KEEP_LINE_FLAG[0];
	MBASDODDEF->KEEP_LINE = MBASDODDEF_N->KEEP_LINE;
    MBASDODDEF->PAGE_BREAK = MBASDODDEF_N->PAGE_BREAK[0];
    MBASDODDEF->ROW_DATA_INC = MBASDODDEF_N->ROW_DATA_INC[0];
    MBASDODDEF->COL_DATA_INC = MBASDODDEF_N->COL_DATA_INC[0];
    MBASDODDEF->ARR_CELL_SIZE = MBASDODDEF_N->ARR_CELL_SIZE[0];
    MBASDODDEF->ARR_CELL_FONT = MBASDODDEF_N->ARR_CELL_FONT[0];
    MEMCPY_DN(MBASDODDEF->CREATE_USER_ID, MBASDODDEF_N->CREATE_USER_ID, sizeof(MBASDODDEF->CREATE_USER_ID));
    MEMCPY_DN(MBASDODDEF->CREATE_TIME, MBASDODDEF_N->CREATE_TIME, sizeof(MBASDODDEF->CREATE_TIME));
