    MEMCPY_DN(MBASDODDEF->UPDATE_TIME, MBASDODDEF_N->UPDATE_TIME, sizeof(MBASDODDEF->UPDATE_TIME));
    MEMCPY_DN(MBASDODDEF->RESV_FIELD_1, MBASDODDEF_N->RESV_FIELD_1, sizeof(MBASDODDEF->RESV_FIELD_1));
    MEMCPY_DN(MBASDODDEF->RESV_FIELD_2, MBASDODDEF_N->RESV_FIELD_2, sizeof(MBASDODDEF->RESV_FIELD_2));
    MEMCPY_DN(MBASDODDEF->RESV_FIELD_3, MBASDODDEF_N->RESV_FIELD_3, sizeof(MBASDODDEF->RESV_FIELD_3));
    MEMCPY_DN(MBASDODDEF->RESV_FIELD_4, MBASDODDEF_N->RESV_FIELD_4, sizeof(MBASDODDEF->RESV_FIELD_4));
    MEMCPY_DN(MBASDODDEF->RESV_FIELD_5, MBASDODDEF_N->RESV_FIELD_5, sizeof(MBASDODDEF->RESV_FIELD_5));
    MBASDODDEF->RESV_FLAG_1 = MBASDODDEF_N->RESV_FLAG_1[0];
    MBASDODDEF->RESV_FLAG_2 = MBASDODDEF_N->RESV_FLAG_2[0];
    MBASDODDEF->RESV_FLAG_3 = MBASDODDEF_N->RESV_FLAG_3[0];
    MBASDODDEF->RESV_FLAG_4 = MBASDODDEF_N->RESV_FLAG_4[0];
    MBASDODDEF->RESV_FLAG_5 = MBASDODDEF_N->RESV_FLAG_5[0];
}


