/* SQL UPDATE Function */
void DBC_update_mbasdoddef(int sel_type, struct MBASDODDEF_TAG *MBASDODDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBASDODDEF_N_TAG MBASDODDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbasdoddef(&MBASDODDEF_N, MBASDODDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MBASDODDEF SET
                    LEFT_POSITION = :MBASDODDEF_N.LEFT_POSITION,
                    SPACE_COUNT = :MBASDODDEF_N.SPACE_COUNT,
                    START_PAGE = :MBASDODDEF_N.START_PAGE,
                    STOP_PAGE = :MBASDODDEF_N.STOP_PAGE,
                    HEADER_FLAG = :MBASDODDEF_N.HEADER_FLAG,
					KEEP_LINE_FLAG = :MBASDODDEF_N.KEEP_LINE_FLAG,
					KEEP_LINE = :MBASDODDEF_N.KEEP_LINE,
                    PAGE_BREAK = :MBASDODDEF_N.PAGE_BREAK,
                    ROW_DATA_INC = :MBASDODDEF_N.ROW_DATA_INC,
                    COL_DATA_INC = :MBASDODDEF_N.COL_DATA_INC,
                    ARR_CELL_SIZE = :MBASDODDEF_N.ARR_CELL_SIZE,
                    ARR_CELL_FONT = :MBASDODDEF_N.ARR_CELL_FONT,
                    CREATE_USER_ID = :MBASDODDEF_N.CREATE_USER_ID,
                    CREATE_TIME = :MBASDODDEF_N.CREATE_TIME,
                    UPDATE_USER_ID = :MBASDODDEF_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MBASDODDEF_N.UPDATE_TIME,
                    RESV_FIELD_1 = :MBASDODDEF_N.RESV_FIELD_1,
                    RESV_FIELD_2 = :MBASDODDEF_N.RESV_FIELD_2,
                    RESV_FIELD_3 = :MBASDODDEF_N.RESV_FIELD_3,
                    RESV_FIELD_4 = :MBASDODDEF_N.RESV_FIELD_4,
                    RESV_FIELD_5 = :MBASDODDEF_N.RESV_FIELD_5,
                    RESV_FLAG_1 = :MBASDODDEF_N.RESV_FLAG_1,
                    RESV_FLAG_2 = :MBASDODDEF_N.RESV_FLAG_2,
                    RESV_FLAG_3 = :MBASDODDEF_N.RESV_FLAG_3,
                    RESV_FLAG_4 = :MBASDODDEF_N.RESV_FLAG_4,
                    RESV_FLAG_5 = :MBASDODDEF_N.RESV_FLAG_5
                WHERE FACTORY = :MBASDODDEF_N.FACTORY
                    AND DOF_ID = :MBASDODDEF_N.DOF_ID
                    AND DOT_ID = :MBASDODDEF_N.DOT_ID
                    AND DOT_SEQ = :MBASDODDEF_N.DOT_SEQ;
            break;

		case 2:
            EXEC SQL UPDATE MBASDODDEF SET
					DOT_SEQ = DOT_SEQ + 1
                WHERE FACTORY = :MBASDODDEF_N.FACTORY
                    AND DOF_ID = :MBASDODDEF_N.DOF_ID
                    AND DOT_SEQ >= :MBASDODDEF_N.DOT_SEQ;
            break;

		case 3:
            EXEC SQL UPDATE MBASDODDEF SET
					DOT_SEQ = DOT_SEQ - 1
                WHERE FACTORY = :MBASDODDEF_N.FACTORY
                    AND DOF_ID = :MBASDODDEF_N.DOF_ID
                    AND DOT_SEQ > :MBASDODDEF_N.DOT_SEQ;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mbasdoddef", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mbasdoddef(int sel_type, struct MBASDODDEF_TAG *MBASDODDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBASDODDEF_N_TAG MBASDODDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbasdoddef(&MBASDODDEF_N, MBASDODDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MBASDODDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    DOF_ID,
                    DOT_ID,
                    DOT_SEQ,
                    LEFT_POSITION,
                    SPACE_COUNT,
                    START_PAGE,
                    STOP_PAGE,
                    HEADER_FLAG,
                    KEEP_LINE_FLAG,
                    KEEP_LINE,
                    PAGE_BREAK,
                    ROW_DATA_INC,
                    COL_DATA_INC,
                    ARR_CELL_SIZE,
                    ARR_CELL_FONT,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD_1,
                    RESV_FIELD_2,
                    RESV_FIELD_3,
                    RESV_FIELD_4,
                    RESV_FIELD_5,
                    RESV_FLAG_1,
                    RESV_FLAG_2,
                    RESV_FLAG_3,
                    RESV_FLAG_4,
                    RESV_FLAG_5
                FROM MBASDODDEF
                ORDER BY FACTORY ASC,
                    DOF_ID ASC,
					DOT_SEQ ASC,
                    DOT_ID ASC;
            EXEC SQL OPEN DBC_MBASDODDEF_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MBASDODDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    DOF_ID,
                    DOT_ID,
                    DOT_SEQ,
                    LEFT_POSITION,
                    SPACE_COUNT,
                    START_PAGE,
                    STOP_PAGE,
                    HEADER_FLAG,
                    KEEP_LINE_FLAG,
                    KEEP_LINE,
                    PAGE_BREAK,
                    ROW_DATA_INC,
                    COL_DATA_INC,
                    ARR_CELL_SIZE,
                    ARR_CELL_FONT,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RESV_FIELD_1,
                    RESV_FIELD_2,
                    RESV_FIELD_3,
                    RESV_FIELD_4,
                    RESV_FIELD_5,
                    RESV_FLAG_1,
                    RESV_FLAG_2,
                    RESV_FLAG_3,
                    RESV_FLAG_4,
                    RESV_FLAG_5
                FROM MBASDODDEF
                WHERE FACTORY = :MBASDODDEF_N.FACTORY
                AND DOF_ID = :MBASDODDEF_N.DOF_ID 
				AND DOT_SEQ >= :MBASDODDEF_N.DOT_SEQ               				
                ORDER BY DOT_SEQ ASC;
            EXEC SQL OPEN DBC_MBASDODDEF_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mbasdoddef", sel_type);
}


