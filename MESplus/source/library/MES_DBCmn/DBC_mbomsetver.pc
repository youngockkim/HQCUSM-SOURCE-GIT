/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mbomsetver(int sel_type, struct MBOMSETVER_TAG *MBOMSETVER)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBOMSETVER_N_TAG MBOMSETVER_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbomsetver(&MBOMSETVER_N, MBOMSETVER);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MBOMSETVER_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    BOM_SET_ID,
                    BOM_SET_VERSION,
                    APPLY_START_TIME,
                    APPLY_END_TIME,
                    APPROVAL_FLAG,
                    APPROVAL_USER_ID,
                    APPROVAL_TIME,
                    RELEASE_FLAG,
                    RELEASE_USER_ID,
                    RELEASE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MBOMSETVER
                WHERE FACTORY = :MBOMSETVER_N.FACTORY
                    AND BOM_SET_ID = :MBOMSETVER_N.BOM_SET_ID 
                    AND BOM_SET_VERSION <= :MBOMSETVER_N.BOM_SET_VERSION
                ORDER BY BOM_SET_VERSION DESC;
            EXEC SQL OPEN DBC_MBOMSETVER_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MBOMSETVER_CUR_2 CURSOR FOR
                SELECT BOM_SET_ID, BOM_SET_VERSION 
                FROM MBOMSETVER
                WHERE FACTORY = :MBOMSETVER_N.FACTORY
                    AND BOM_SET_ID = :MBOMSETVER_N.BOM_SET_ID
                    AND (APPLY_START_TIME = ' ' OR APPLY_START_TIME < :MBOMSETVER_N.APPLY_START_TIME)
                    AND (APPLY_END_TIME = ' ' OR APPLY_END_TIME > :MBOMSETVER_N.APPLY_END_TIME)
                    AND RELEASE_FLAG = 'Y'
                ORDER BY BOM_SET_VERSION DESC;
            EXEC SQL OPEN DBC_MBOMSETVER_CUR_2;
            break;

        case 51:
            EXEC SQL DECLARE DBC_MBOMSETVER_CUR_51 CURSOR FOR
                SELECT SV.BOM_SET_ID, SV.BOM_SET_VERSION 
                FROM MBOMSETVER SV, MWIPLOTSTS LS, MWIPMATDEF MD
                WHERE LS.FACTORY = :MBOMSETVER_N.FACTORY
                    AND MD.FACTORY = LS.FACTORY
                    AND SV.FACTORY = LS.FACTORY
                    AND LS.LOT_ID = :MBOMSETVER_N.BOM_SET_ID
                    AND MD.MAT_ID = LS.MAT_ID
                    AND MD.MAT_VER = LS.MAT_VER
                    AND SV.BOM_SET_ID = MD.BOM_SET_ID
                    AND SV.RELEASE_FLAG = 'Y'
                    AND (SV.APPLY_START_TIME = ' ' OR SV.APPLY_START_TIME < :MBOMSETVER_N.APPLY_START_TIME)
                    AND (SV.APPLY_END_TIME = ' ' OR SV.APPLY_END_TIME > :MBOMSETVER_N.APPLY_END_TIME)
                ORDER BY SV.BOM_SET_VERSION DESC;
            EXEC SQL OPEN DBC_MBOMSETVER_CUR_51;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mbomsetver", sel_type);
}


