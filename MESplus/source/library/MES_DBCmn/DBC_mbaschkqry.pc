/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mbaschkqry(int sel_type, struct MBASCHKQRY_TAG *MBASCHKQRY)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBASCHKQRY_N_TAG MBASCHKQRY_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbaschkqry(&MBASCHKQRY_N, MBASCHKQRY);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MBASCHKQRY_CUR_1 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    QUERY_ID,
                    QUERY_TYPE,
                    QUERY,
                    ANSWER_FMT,
                    ANSWER_SIZE,
                    VALID_TBL_TYPE,
                    VALID_TBL_NAME
                FROM MBASCHKQRY
                ORDER BY FACTORY ASC,
                    QUERY_ID ASC;
            EXEC SQL OPEN DBC_MBASCHKQRY_CUR_1;
            break;
		
		case 101:
            EXEC SQL DECLARE DBC_MBASCHKQRY_CUR_101 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    QUERY_ID,
                    QUERY_TYPE,
                    QUERY,
                    ANSWER_FMT,
                    ANSWER_SIZE,
                    VALID_TBL_TYPE,
                    VALID_TBL_NAME
                FROM MBASCHKQRY
				WHERE 1=1
					AND FACTORY = :MBASCHKQRY_N.FACTORY
					AND QUERY_ID >= :MBASCHKQRY_N.QUERY_ID
                ORDER BY QUERY_ID ASC;
            EXEC SQL OPEN DBC_MBASCHKQRY_CUR_101;
            break;

		case 102:
            EXEC SQL DECLARE DBC_MBASCHKQRY_CUR_102 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    QUERY_ID,
                    QUERY_TYPE,
                    QUERY,
                    ANSWER_FMT,
                    ANSWER_SIZE,
                    VALID_TBL_TYPE,
                    VALID_TBL_NAME
                FROM MBASCHKQRY
				WHERE 1=1
					AND FACTORY = :MBASCHKQRY_N.FACTORY
					AND QUERY_TYPE = :MBASCHKQRY_N.QUERY_TYPE
					AND QUERY_ID >= :MBASCHKQRY_N.QUERY_ID
                ORDER BY QUERY_ID ASC;
            EXEC SQL OPEN DBC_MBASCHKQRY_CUR_102;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
