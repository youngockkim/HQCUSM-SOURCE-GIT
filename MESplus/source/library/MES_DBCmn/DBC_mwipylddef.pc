                                                    :MWIPYLDDEF_N.RESV_FIELD_1,
                                                    :MWIPYLDDEF_N.RESV_FIELD_2,
                                                    :MWIPYLDDEF_N.RESV_FIELD_3,
                                                    :MWIPYLDDEF_N.RESV_FIELD_4,
                                                    :MWIPYLDDEF_N.RESV_FIELD_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwipylddef(&MWIPYLDDEF_N, MWIPYLDDEF);
    }
    DB_stop_query_timer("DBC_fetch_mwipylddef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwipylddef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPYLDDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWIPYLDDEF_CUR_2;
            break;
        case 3:
            EXEC SQL CLOSE DBC_MWIPYLDDEF_CUR_3;
            break;
        case 4:
            EXEC SQL CLOSE DBC_MWIPYLDDEF_CUR_4;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipylddef", sel_type);
}


/* Initialize Function */
void DBC_init_mwipylddef(struct MWIPYLDDEF_TAG *MWIPYLDDEF)
{
    /* memset by Space */
    memset(MWIPYLDDEF, ' ', sizeof(struct MWIPYLDDEF_TAG));
    
    MWIPYLDDEF->MAT_VER = 0;
    MWIPYLDDEF->FLOW_SEQ_NUM = 0;
    MWIPYLDDEF->STD_YIELD = 0;
    MWIPYLDDEF->PLN_YIELD = 0;
    MWIPYLDDEF->UNIT_CHG_YIELD = 0;
    MWIPYLDDEF->CUSTOM_YIELD_1 = 0;
    MWIPYLDDEF->CUSTOM_YIELD_2 = 0;
    MWIPYLDDEF->CUSTOM_YIELD_3 = 0;
    MWIPYLDDEF->CUSTOM_YIELD_4 = 0;
    MWIPYLDDEF->CUSTOM_YIELD_5 = 0;
}


/* Add Null Function */
void DBC_add_null_mwipylddef(struct MWIPYLDDEF_N_TAG *MWIPYLDDEF_N, struct MWIPYLDDEF_TAG *MWIPYLDDEF)
{
    /* memset by NULL */
    memset(MWIPYLDDEF_N, '\0', sizeof(struct MWIPYLDDEF_N_TAG));
    
    MEMCPY_AN(MWIPYLDDEF_N->FACTORY, MWIPYLDDEF->FACTORY, sizeof(MWIPYLDDEF->FACTORY));
    MEMCPY_AN(MWIPYLDDEF_N->MAT_ID, MWIPYLDDEF->MAT_ID, sizeof(MWIPYLDDEF->MAT_ID));
    MWIPYLDDEF_N->MAT_VER = MWIPYLDDEF->MAT_VER;
    MEMCPY_AN(MWIPYLDDEF_N->FLOW, MWIPYLDDEF->FLOW, sizeof(MWIPYLDDEF->FLOW));
    MWIPYLDDEF_N->FLOW_SEQ_NUM = MWIPYLDDEF->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPYLDDEF_N->OPER, MWIPYLDDEF->OPER, sizeof(MWIPYLDDEF->OPER));
    MWIPYLDDEF_N->OPT_LEVEL[0] = MWIPYLDDEF->OPT_LEVEL;
    MWIPYLDDEF_N->STD_YIELD = MWIPYLDDEF->STD_YIELD;
    MWIPYLDDEF_N->PLN_YIELD = MWIPYLDDEF->PLN_YIELD;
    MWIPYLDDEF_N->UNIT_CHG_YIELD = MWIPYLDDEF->UNIT_CHG_YIELD;
    MWIPYLDDEF_N->CUSTOM_YIELD_1 = MWIPYLDDEF->CUSTOM_YIELD_1;
    MWIPYLDDEF_N->CUSTOM_YIELD_2 = MWIPYLDDEF->CUSTOM_YIELD_2;
    MWIPYLDDEF_N->CUSTOM_YIELD_3 = MWIPYLDDEF->CUSTOM_YIELD_3;
    MWIPYLDDEF_N->CUSTOM_YIELD_4 = MWIPYLDDEF->CUSTOM_YIELD_4;
    MWIPYLDDEF_N->CUSTOM_YIELD_5 = MWIPYLDDEF->CUSTOM_YIELD_5;
    MEMCPY_AN(MWIPYLDDEF_N->CREATE_USER_ID, MWIPYLDDEF->CREATE_USER_ID, sizeof(MWIPYLDDEF->CREATE_USER_ID));
    MEMCPY_AN(MWIPYLDDEF_N->CREATE_TIME, MWIPYLDDEF->CREATE_TIME, sizeof(MWIPYLDDEF->CREATE_TIME));
    MEMCPY_AN(MWIPYLDDEF_N->UPDATE_USER_ID, MWIPYLDDEF->UPDATE_USER_ID, sizeof(MWIPYLDDEF->UPDATE_USER_ID));
    MEMCPY_AN(MWIPYLDDEF_N->UPDATE_TIME, MWIPYLDDEF->UPDATE_TIME, sizeof(MWIPYLDDEF->UPDATE_TIME));
    MEMCPY_AN(MWIPYLDDEF_N->RESV_FIELD_1, MWIPYLDDEF->RESV_FIELD_1, sizeof(MWIPYLDDEF->RESV_FIELD_1));
    MEMCPY_AN(MWIPYLDDEF_N->RESV_FIELD_2, MWIPYLDDEF->RESV_FIELD_2, sizeof(MWIPYLDDEF->RESV_FIELD_2));
    MEMCPY_AN(MWIPYLDDEF_N->RESV_FIELD_3, MWIPYLDDEF->RESV_FIELD_3, sizeof(MWIPYLDDEF->RESV_FIELD_3));
    MEMCPY_AN(MWIPYLDDEF_N->RESV_FIELD_4, MWIPYLDDEF->RESV_FIELD_4, sizeof(MWIPYLDDEF->RESV_FIELD_4));
    MEMCPY_AN(MWIPYLDDEF_N->RESV_FIELD_5, MWIPYLDDEF->RESV_FIELD_5, sizeof(MWIPYLDDEF->RESV_FIELD_5));
}


/* Del Null Function */
void DBC_del_null_mwipylddef(struct MWIPYLDDEF_N_TAG *MWIPYLDDEF_N, struct MWIPYLDDEF_TAG *MWIPYLDDEF)
{
    MEMCPY_DN(MWIPYLDDEF->FACTORY, MWIPYLDDEF_N->FACTORY, sizeof(MWIPYLDDEF->FACTORY));
    MEMCPY_DN(MWIPYLDDEF->MAT_ID, MWIPYLDDEF_N->MAT_ID, sizeof(MWIPYLDDEF->MAT_ID));
    MWIPYLDDEF->MAT_VER = MWIPYLDDEF_N->MAT_VER;
    MEMCPY_DN(MWIPYLDDEF->FLOW, MWIPYLDDEF_N->FLOW, sizeof(MWIPYLDDEF->FLOW));
    MWIPYLDDEF->FLOW_SEQ_NUM = MWIPYLDDEF_N->FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPYLDDEF->OPER, MWIPYLDDEF_N->OPER, sizeof(MWIPYLDDEF->OPER));
    MWIPYLDDEF->OPT_LEVEL = MWIPYLDDEF_N->OPT_LEVEL[0];
    MWIPYLDDEF->STD_YIELD = MWIPYLDDEF_N->STD_YIELD;
    MWIPYLDDEF->PLN_YIELD = MWIPYLDDEF_N->PLN_YIELD;
    MWIPYLDDEF->UNIT_CHG_YIELD = MWIPYLDDEF_N->UNIT_CHG_YIELD;
    MWIPYLDDEF->CUSTOM_YIELD_1 = MWIPYLDDEF_N->CUSTOM_YIELD_1;
    MWIPYLDDEF->CUSTOM_YIELD_2 = MWIPYLDDEF_N->CUSTOM_YIELD_2;
    MWIPYLDDEF->CUSTOM_YIELD_3 = MWIPYLDDEF_N->CUSTOM_YIELD_3;
    MWIPYLDDEF->CUSTOM_YIELD_4 = MWIPYLDDEF_N->CUSTOM_YIELD_4;
    MWIPYLDDEF->CUSTOM_YIELD_5 = MWIPYLDDEF_N->CUSTOM_YIELD_5;
    MEMCPY_DN(MWIPYLDDEF->CREATE_USER_ID, MWIPYLDDEF_N->CREATE_USER_ID, sizeof(MWIPYLDDEF->CREATE_USER_ID));
    MEMCPY_DN(MWIPYLDDEF->CREATE_TIME, MWIPYLDDEF_N->CREATE_TIME, sizeof(MWIPYLDDEF->CREATE_TIME));
    MEMCPY_DN(MWIPYLDDEF->UPDATE_USER_ID, MWIPYLDDEF_N->UPDATE_USER_ID, sizeof(MWIPYLDDEF->UPDATE_USER_ID));
    MEMCPY_DN(MWIPYLDDEF->UPDATE_TIME, MWIPYLDDEF_N->UPDATE_TIME, sizeof(MWIPYLDDEF->UPDATE_TIME));
    MEMCPY_DN(MWIPYLDDEF->RESV_FIELD_1, MWIPYLDDEF_N->RESV_FIELD_1, sizeof(MWIPYLDDEF->RESV_FIELD_1));
    MEMCPY_DN(MWIPYLDDEF->RESV_FIELD_2, MWIPYLDDEF_N->RESV_FIELD_2, sizeof(MWIPYLDDEF->RESV_FIELD_2));
    MEMCPY_DN(MWIPYLDDEF->RESV_FIELD_3, MWIPYLDDEF_N->RESV_FIELD_3, sizeof(MWIPYLDDEF->RESV_FIELD_3));
    MEMCPY_DN(MWIPYLDDEF->RESV_FIELD_4, MWIPYLDDEF_N->RESV_FIELD_4, sizeof(MWIPYLDDEF->RESV_FIELD_4));
    MEMCPY_DN(MWIPYLDDEF->RESV_FIELD_5, MWIPYLDDEF_N->RESV_FIELD_5, sizeof(MWIPYLDDEF->RESV_FIELD_5));
}


