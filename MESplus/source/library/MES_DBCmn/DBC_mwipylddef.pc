                                                    :MWIPYLDDEF_N.CUSTOM_YIELD_1,
                                                    :MWIPYLDDEF_N.CUSTOM_YIELD_2,
                                                    :MWIPYLDDEF_N.CUSTOM_YIELD_3,
                                                    :MWIPYLDDEF_N.CUSTOM_YIELD_4,
                                                    :MWIPYLDDEF_N.CUSTOM_YIELD_5,
                                                    :MWIPYLDDEF_N.CREATE_USER_ID,
                                                    :MWIPYLDDEF_N.CREATE_TIME,
                                                    :MWIPYLDDEF_N.UPDATE_USER_ID,
                                                    :MWIPYLDDEF_N.UPDATE_TIME,
                                                    :MWIPYLDDEF_N.RESV_FIELD_1,
                                                    :MWIPYLDDEF_N.RESV_FIELD_2,
                                                    :MWIPYLDDEF_N.RESV_FIELD_3,
                                                    :MWIPYLDDEF_N.RESV_FIELD_4,
                                                    :MWIPYLDDEF_N.RESV_FIELD_5;
            break;
        case 3:
            EXEC SQL FETCH DBC_MWIPYLDDEF_CUR_3 INTO 
                                                    :MWIPYLDDEF_N.FACTORY,
                                                    :MWIPYLDDEF_N.MAT_ID,
                                                    :MWIPYLDDEF_N.MAT_VER,
                                                    :MWIPYLDDEF_N.FLOW,
                                                    :MWIPYLDDEF_N.FLOW_SEQ_NUM,
                                                    :MWIPYLDDEF_N.OPER,
                                                    :MWIPYLDDEF_N.OPT_LEVEL,
                                                    :MWIPYLDDEF_N.STD_YIELD,
                                                    :MWIPYLDDEF_N.PLN_YIELD,
                                                    :MWIPYLDDEF_N.UNIT_CHG_YIELD,
                                                    :MWIPYLDDEF_N.CUSTOM_YIELD_1,
                                                    :MWIPYLDDEF_N.CUSTOM_YIELD_2,
                                                    :MWIPYLDDEF_N.CUSTOM_YIELD_3,
                                                    :MWIPYLDDEF_N.CUSTOM_YIELD_4,
                                                    :MWIPYLDDEF_N.CUSTOM_YIELD_5,
                                                    :MWIPYLDDEF_N.CREATE_USER_ID,
                                                    :MWIPYLDDEF_N.CREATE_TIME,
                                                    :MWIPYLDDEF_N.UPDATE_USER_ID,
                                                    :MWIPYLDDEF_N.UPDATE_TIME,
                                                    :MWIPYLDDEF_N.RESV_FIELD_1,
                                                    :MWIPYLDDEF_N.RESV_FIELD_2,
                                                    :MWIPYLDDEF_N.RESV_FIELD_3,
                                                    :MWIPYLDDEF_N.RESV_FIELD_4,
                                                    :MWIPYLDDEF_N.RESV_FIELD_5;
            break;
        case 4:
            EXEC SQL FETCH DBC_MWIPYLDDEF_CUR_4 INTO 
                                                    :MWIPYLDDEF_N.FACTORY,
                                                    :MWIPYLDDEF_N.MAT_ID,
                                                    :MWIPYLDDEF_N.MAT_VER,
                                                    :MWIPYLDDEF_N.FLOW,
                                                    :MWIPYLDDEF_N.FLOW_SEQ_NUM,
                                                    :MWIPYLDDEF_N.OPER,
                                                    :MWIPYLDDEF_N.OPT_LEVEL,
                                                    :MWIPYLDDEF_N.STD_YIELD,
                                                    :MWIPYLDDEF_N.PLN_YIELD,
                                                    :MWIPYLDDEF_N.UNIT_CHG_YIELD,
                                                    :MWIPYLDDEF_N.CUSTOM_YIELD_1,
                                                    :MWIPYLDDEF_N.CUSTOM_YIELD_2,
                                                    :MWIPYLDDEF_N.CUSTOM_YIELD_3,
                                                    :MWIPYLDDEF_N.CUSTOM_YIELD_4,
                                                    :MWIPYLDDEF_N.CUSTOM_YIELD_5,
                                                    :MWIPYLDDEF_N.CREATE_USER_ID,
                                                    :MWIPYLDDEF_N.CREATE_TIME,
                                                    :MWIPYLDDEF_N.UPDATE_USER_ID,
