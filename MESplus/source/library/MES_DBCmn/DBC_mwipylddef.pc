                                                    :MWIPYLDDEF_N.RESV_FIELD_5;
            break;

        case 2:
            EXEC SQL FETCH DBC_MWIPYLDDEF_CUR_2 INTO 
                                                    :MWIPYLDDEF_N.FACTORY,
                                                    :MWIPYLDDEF_N.MAT_ID,
                                                    :MWIPYLDDEF_N.MAT_VER,
                                                    :MWIPYLDDEF_N.FLOW,
