/* Initialize Function */
void DBC_init_mwipsltlos(struct MWIPSLTLOS_TAG *MWIPSLTLOS)
{
    /* memset by Space */
    memset(MWIPSLTLOS, ' ', sizeof(struct MWIPSLTLOS_TAG));
    
    MWIPSLTLOS->HIST_SEQ = 0;
    MWIPSLTLOS->LOT_HIST_SEQ = 0;
    MWIPSLTLOS->MAT_VER = 0;
    MWIPSLTLOS->FLOW_SEQ_NUM = 0;
    MWIPSLTLOS->LOSS_QTY = 0;
}


/* Add Null Function */
void DBC_add_null_mwipsltlos(struct MWIPSLTLOS_N_TAG *MWIPSLTLOS_N, struct MWIPSLTLOS_TAG *MWIPSLTLOS)
{
    /* memset by NULL */
    memset(MWIPSLTLOS_N, '\0', sizeof(struct MWIPSLTLOS_N_TAG));
    
    MEMCPY_AN(MWIPSLTLOS_N->SUBLOT_ID, MWIPSLTLOS->SUBLOT_ID, sizeof(MWIPSLTLOS->SUBLOT_ID));
    MEMCPY_AN(MWIPSLTLOS_N->LOT_ID, MWIPSLTLOS->LOT_ID, sizeof(MWIPSLTLOS->LOT_ID));
    MWIPSLTLOS_N->HIST_SEQ = MWIPSLTLOS->HIST_SEQ;
    MWIPSLTLOS_N->LOT_HIST_SEQ = MWIPSLTLOS->LOT_HIST_SEQ;
    MWIPSLTLOS_N->QTY_FLAG[0] = MWIPSLTLOS->QTY_FLAG;
    MWIPSLTLOS_N->GRADE[0] = MWIPSLTLOS->GRADE;
    MEMCPY_AN(MWIPSLTLOS_N->LOSS_CODE, MWIPSLTLOS->LOSS_CODE, sizeof(MWIPSLTLOS->LOSS_CODE));
    MEMCPY_AN(MWIPSLTLOS_N->TRAN_TIME, MWIPSLTLOS->TRAN_TIME, sizeof(MWIPSLTLOS->TRAN_TIME));
    MWIPSLTLOS_N->HIST_DEL_FLAG[0] = MWIPSLTLOS->HIST_DEL_FLAG;
    MEMCPY_AN(MWIPSLTLOS_N->FACTORY, MWIPSLTLOS->FACTORY, sizeof(MWIPSLTLOS->FACTORY));
    MEMCPY_AN(MWIPSLTLOS_N->MAT_ID, MWIPSLTLOS->MAT_ID, sizeof(MWIPSLTLOS->MAT_ID));
    MWIPSLTLOS_N->MAT_VER = MWIPSLTLOS->MAT_VER;
    MEMCPY_AN(MWIPSLTLOS_N->FLOW, MWIPSLTLOS->FLOW, sizeof(MWIPSLTLOS->FLOW));
    MWIPSLTLOS_N->FLOW_SEQ_NUM = MWIPSLTLOS->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPSLTLOS_N->OPER, MWIPSLTLOS->OPER, sizeof(MWIPSLTLOS->OPER));
    MEMCPY_AN(MWIPSLTLOS_N->RES_ID, MWIPSLTLOS->RES_ID, sizeof(MWIPSLTLOS->RES_ID));
    MEMCPY_AN(MWIPSLTLOS_N->CAUSE_FLOW, MWIPSLTLOS->CAUSE_FLOW, sizeof(MWIPSLTLOS->CAUSE_FLOW));
    MEMCPY_AN(MWIPSLTLOS_N->CAUSE_OPER, MWIPSLTLOS->CAUSE_OPER, sizeof(MWIPSLTLOS->CAUSE_OPER));
    MEMCPY_AN(MWIPSLTLOS_N->CAUSE_RES_ID, MWIPSLTLOS->CAUSE_RES_ID, sizeof(MWIPSLTLOS->CAUSE_RES_ID));
    MWIPSLTLOS_N->LOSS_QTY = MWIPSLTLOS->LOSS_QTY;
}


/* Del Null Function */
void DBC_del_null_mwipsltlos(struct MWIPSLTLOS_N_TAG *MWIPSLTLOS_N, struct MWIPSLTLOS_TAG *MWIPSLTLOS)
{
    MEMCPY_DN(MWIPSLTLOS->SUBLOT_ID, MWIPSLTLOS_N->SUBLOT_ID, sizeof(MWIPSLTLOS->SUBLOT_ID));
    MEMCPY_DN(MWIPSLTLOS->LOT_ID, MWIPSLTLOS_N->LOT_ID, sizeof(MWIPSLTLOS->LOT_ID));
    MWIPSLTLOS->HIST_SEQ = MWIPSLTLOS_N->HIST_SEQ;
    MWIPSLTLOS->LOT_HIST_SEQ = MWIPSLTLOS_N->LOT_HIST_SEQ;
    MWIPSLTLOS->QTY_FLAG = MWIPSLTLOS_N->QTY_FLAG[0];
    MWIPSLTLOS->GRADE = MWIPSLTLOS_N->GRADE[0];
    MEMCPY_DN(MWIPSLTLOS->LOSS_CODE, MWIPSLTLOS_N->LOSS_CODE, sizeof(MWIPSLTLOS->LOSS_CODE));
    MEMCPY_DN(MWIPSLTLOS->TRAN_TIME, MWIPSLTLOS_N->TRAN_TIME, sizeof(MWIPSLTLOS->TRAN_TIME));
    MWIPSLTLOS->HIST_DEL_FLAG = MWIPSLTLOS_N->HIST_DEL_FLAG[0];
    MEMCPY_DN(MWIPSLTLOS->FACTORY, MWIPSLTLOS_N->FACTORY, sizeof(MWIPSLTLOS->FACTORY));
    MEMCPY_DN(MWIPSLTLOS->MAT_ID, MWIPSLTLOS_N->MAT_ID, sizeof(MWIPSLTLOS->MAT_ID));
    MWIPSLTLOS->MAT_VER = MWIPSLTLOS_N->MAT_VER;
    MEMCPY_DN(MWIPSLTLOS->FLOW, MWIPSLTLOS_N->FLOW, sizeof(MWIPSLTLOS->FLOW));
    MWIPSLTLOS->FLOW_SEQ_NUM = MWIPSLTLOS_N->FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPSLTLOS->OPER, MWIPSLTLOS_N->OPER, sizeof(MWIPSLTLOS->OPER));
    MEMCPY_DN(MWIPSLTLOS->RES_ID, MWIPSLTLOS_N->RES_ID, sizeof(MWIPSLTLOS->RES_ID));
    MEMCPY_DN(MWIPSLTLOS->CAUSE_FLOW, MWIPSLTLOS_N->CAUSE_FLOW, sizeof(MWIPSLTLOS->CAUSE_FLOW));
    MEMCPY_DN(MWIPSLTLOS->CAUSE_OPER, MWIPSLTLOS_N->CAUSE_OPER, sizeof(MWIPSLTLOS->CAUSE_OPER));
    MEMCPY_DN(MWIPSLTLOS->CAUSE_RES_ID, MWIPSLTLOS_N->CAUSE_RES_ID, sizeof(MWIPSLTLOS->CAUSE_RES_ID));
    MWIPSLTLOS->LOSS_QTY = MWIPSLTLOS_N->LOSS_QTY;
}


