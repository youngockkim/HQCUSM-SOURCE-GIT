/* SQL UPDATE Function */
void DBC_update_mwipsltlos(int sel_type, struct MWIPSLTLOS_TAG *MWIPSLTLOS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSLTLOS_N_TAG MWIPSLTLOS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipsltlos(&MWIPSLTLOS_N, MWIPSLTLOS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MWIPSLTLOS SET
                    GRADE = :MWIPSLTLOS_N.GRADE,
                    TRAN_TIME = :MWIPSLTLOS_N.TRAN_TIME,
                    HIST_DEL_FLAG = :MWIPSLTLOS_N.HIST_DEL_FLAG,
                    FACTORY = :MWIPSLTLOS_N.FACTORY,
                    MAT_ID = :MWIPSLTLOS_N.MAT_ID,
                    MAT_VER = :MWIPSLTLOS_N.MAT_VER,
                    FLOW = :MWIPSLTLOS_N.FLOW,
                    FLOW_SEQ_NUM = :MWIPSLTLOS_N.FLOW_SEQ_NUM,
                    OPER = :MWIPSLTLOS_N.OPER,
                    RES_ID = :MWIPSLTLOS_N.RES_ID,
                    CAUSE_FLOW = :MWIPSLTLOS_N.CAUSE_FLOW,
                    CAUSE_OPER = :MWIPSLTLOS_N.CAUSE_OPER,
                    CAUSE_RES_ID = :MWIPSLTLOS_N.CAUSE_RES_ID,
                    LOSS_QTY = :MWIPSLTLOS_N.LOSS_QTY
                WHERE SUBLOT_ID = :MWIPSLTLOS_N.SUBLOT_ID
                    AND LOT_ID = :MWIPSLTLOS_N.LOT_ID
                    AND HIST_SEQ = :MWIPSLTLOS_N.HIST_SEQ
                    AND QTY_FLAG = :MWIPSLTLOS_N.QTY_FLAG
                    AND LOSS_CODE = :MWIPSLTLOS_N.LOSS_CODE;
            break;

        case 2:
            EXEC SQL UPDATE MWIPSLTLOS SET
                    HIST_DEL_FLAG = :MWIPSLTLOS_N.HIST_DEL_FLAG
                WHERE SUBLOT_ID = :MWIPSLTLOS_N.SUBLOT_ID
                    AND HIST_SEQ = :MWIPSLTLOS_N.HIST_SEQ;
            break;

            
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mwipsltlos", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipsltlos(int sel_type, struct MWIPSLTLOS_TAG *MWIPSLTLOS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSLTLOS_N_TAG MWIPSLTLOS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipsltlos(&MWIPSLTLOS_N, MWIPSLTLOS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPSLTLOS_CUR_1 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    LOT_ID,
                    HIST_SEQ,
                    LOT_HIST_SEQ,
                    QTY_FLAG,
                    GRADE,
                    LOSS_CODE,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_ID,
                    CAUSE_FLOW,
                    CAUSE_OPER,
                    CAUSE_RES_ID,
                    LOSS_QTY
                FROM MWIPSLTLOS
                ORDER BY SUBLOT_ID ASC,
                    LOT_ID ASC,
                    HIST_SEQ ASC,
                    QTY_FLAG ASC,
                    LOSS_CODE ASC;
            EXEC SQL OPEN DBC_MWIPSLTLOS_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPSLTLOS_CUR_2 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    LOT_ID,
                    HIST_SEQ,
                    LOT_HIST_SEQ,
                    QTY_FLAG,
                    GRADE,
                    LOSS_CODE,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_ID,
                    CAUSE_FLOW,
                    CAUSE_OPER,
                    CAUSE_RES_ID,
                    LOSS_QTY
                FROM MWIPSLTLOS
                WHERE SUBLOT_ID = :MWIPSLTLOS_N.SUBLOT_ID
                    AND HIST_SEQ <= :MWIPSLTLOS_N.HIST_SEQ
                    AND TRAN_TIME BETWEEN :MWIPSLTLOS_N.TRAN_TIME AND :MWIPSLTLOS_N.CAUSE_RES_ID
                    AND OPER LIKE :MWIPSLTLOS_N.OPER
                    AND LOSS_CODE LIKE :MWIPSLTLOS_N.LOSS_CODE
                    AND GRADE LIKE :MWIPSLTLOS_N.GRADE
                    AND HIST_DEL_FLAG LIKE :MWIPSLTLOS_N.HIST_DEL_FLAG
                    AND QTY_FLAG LIKE :MWIPSLTLOS_N.QTY_FLAG
                ORDER BY HIST_SEQ DESC, QTY_FLAG ASC, GRADE DESC, LOSS_CODE ASC;
            EXEC SQL OPEN DBC_MWIPSLTLOS_CUR_2;
            break;

            // Sublot LOSS ?類ｋ궖
        case 3:
            EXEC SQL DECLARE DBC_MWIPSLTLOS_CUR_3 CURSOR FOR
                SELECT LOS.SUBLOT_ID, LOS.LOSS_CODE, DECODE(LOS.GRADE, ' ', 'N', 'Y') GRADE
                  FROM MWIPSLTLOS LOS
                 WHERE LOS.FACTORY = :MWIPSLTLOS_N.FACTORY
                   AND LOS.SUBLOT_ID = :MWIPSLTLOS_N.SUBLOT_ID
                   AND LOS.HIST_SEQ = (SELECT MAX(HIST_SEQ) 
                                         FROM MWIPSLTLOS
                                        WHERE FACTORY = LOS.FACTORY
                                          AND SUBLOT_ID = LOS.SUBLOT_ID
                                          AND QTY_FLAG = 1
                                          AND OPER = :MWIPSLTLOS_N.OPER
                                          AND HIST_DEL_FLAG = ' ')
                                        ORDER BY LOS.GRADE DESC, LOS.LOSS_CODE ASC;
            EXEC SQL OPEN DBC_MWIPSLTLOS_CUR_3;
            break;      
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipsltlos", sel_type);
}


