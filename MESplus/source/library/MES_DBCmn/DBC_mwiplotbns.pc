                BONUS_QTY_6,
                BONUS_QTY_7,
                BONUS_QTY_8,
                BONUS_QTY_9,
                BONUS_QTY_10,
                BONUS_COMMENT_1,
                BONUS_COMMENT_2,
                BONUS_COMMENT_3
            FROM MWIPLOTBNS
            WHERE LOT_ID = :MWIPLOTBNS_N.LOT_ID
                AND HIST_SEQ = :MWIPLOTBNS_N.HIST_SEQ
            ORDER BY QTY_FLAG ASC;
        EXEC SQL OPEN DBC_MWIPLOTBNS_CUR_1;
        break;

    case 2:
        /* Initialize the sql variable */
        memset( sql, 0x00, sizeof(sql));

        /* Begin making the sql */
        sprintf(sql, "SELECT * FROM (SELECT ROWNUM ROWSEQ, BNS.* FROM (SELECT ");
        sprintf(sql + strlen(sql),   "LOT_ID, ");
        sprintf(sql + strlen(sql),   "HIST_SEQ, ");
        sprintf(sql + strlen(sql),   "QTY_FLAG, ");
        sprintf(sql + strlen(sql),   "TRAN_TIME, ");
        sprintf(sql + strlen(sql),   "HIST_DEL_FLAG, ");
        sprintf(sql + strlen(sql),   "FACTORY, ");
        sprintf(sql + strlen(sql),   "MAT_ID, ");
        sprintf(sql + strlen(sql),   "MAT_VER, ");
        sprintf(sql + strlen(sql),   "FLOW, ");
        sprintf(sql + strlen(sql),   "FLOW_SEQ_NUM, ");
        sprintf(sql + strlen(sql),   "OPER, ");
        sprintf(sql + strlen(sql),   "RES_ID, ");
        sprintf(sql + strlen(sql),   "CAUSE_FLOW, ");
        sprintf(sql + strlen(sql),   "CAUSE_OPER, ");
        sprintf(sql + strlen(sql),   "CAUSE_RES_ID, ");
        sprintf(sql + strlen(sql),   "NEW_QTY, ");
        sprintf(sql + strlen(sql),   "OLD_QTY, ");
        sprintf(sql + strlen(sql),   "TOTAL_BONUS_QTY, ");
        sprintf(sql + strlen(sql),   "BONUS_CODE_1, ");
        sprintf(sql + strlen(sql),   "BONUS_CODE_2, ");
        sprintf(sql + strlen(sql),   "BONUS_CODE_3, ");
        sprintf(sql + strlen(sql),   "BONUS_CODE_4, ");
        sprintf(sql + strlen(sql),   "BONUS_CODE_5, ");
        sprintf(sql + strlen(sql),   "BONUS_CODE_6, ");
        sprintf(sql + strlen(sql),   "BONUS_CODE_7, ");
        sprintf(sql + strlen(sql),   "BONUS_CODE_8, ");
        sprintf(sql + strlen(sql),   "BONUS_CODE_9, ");
        sprintf(sql + strlen(sql),   "BONUS_CODE_10, ");
        sprintf(sql + strlen(sql),   "BONUS_QTY_1, ");
        sprintf(sql + strlen(sql),   "BONUS_QTY_2, ");
        sprintf(sql + strlen(sql),   "BONUS_QTY_3, ");
        sprintf(sql + strlen(sql),   "BONUS_QTY_4, ");
        sprintf(sql + strlen(sql),   "BONUS_QTY_5, ");
        sprintf(sql + strlen(sql),   "BONUS_QTY_6, ");
        sprintf(sql + strlen(sql),   "BONUS_QTY_7, ");
        sprintf(sql + strlen(sql),   "BONUS_QTY_8, ");
        sprintf(sql + strlen(sql),   "BONUS_QTY_9, ");
        sprintf(sql + strlen(sql),   "BONUS_QTY_10, ");
        sprintf(sql + strlen(sql),   "BONUS_COMMENT_1, ");
        sprintf(sql + strlen(sql),   "BONUS_COMMENT_2, ");
        sprintf(sql + strlen(sql),   "BONUS_COMMENT_3 ");
        sprintf(sql + strlen(sql), "FROM MWIPLOTBNS WHERE ");

        make_valid_quote(ts1, MWIPLOTBNS_N.FACTORY);
        sprintf(sql + strlen(sql), "FACTORY = '%s' ", ts1);

        make_valid_quote(ts2, DBC_Q_COND_N.FROM_TIME);
        make_valid_quote(ts3, DBC_Q_COND_N.TO_TIME);
        sprintf(sql + strlen(sql), "AND TRAN_TIME >= '%s' AND TRAN_TIME < '%s' ", ts2, ts3);

        //Adding of the filtering conditions into the SQL statement
        if(ISSPACE(MWIPLOTBNS->LOT_ID, sizeof(MWIPLOTBNS->LOT_ID)) == DB_FALSE)
        {
            make_valid_quote(ts1, MWIPLOTBNS_N.LOT_ID);
            sprintf(sql + strlen(sql), "AND LOT_ID = '%s' ", ts1);
        }

        if(ISSPACE(MWIPLOTBNS->MAT_ID, sizeof(MWIPLOTBNS->MAT_ID)) == DB_FALSE)
        {
            make_valid_quote(ts1, MWIPLOTBNS_N.MAT_ID);
            sprintf(sql + strlen(sql), "AND MAT_ID = '%s' ", ts1);
        }

        if(MWIPLOTBNS->MAT_VER > 0)
        {
            sprintf(sql + strlen(sql), "AND MAT_VER = %d ", MWIPLOTBNS->MAT_VER);
        }

        if(ISSPACE(MWIPLOTBNS->FLOW, sizeof(MWIPLOTBNS->FLOW)) == DB_FALSE)
        {
            make_valid_quote(ts1, MWIPLOTBNS_N.FLOW);
            sprintf(sql + strlen(sql), "AND FLOW = '%s' ", ts1);
        }

        if(ISSPACE(MWIPLOTBNS->OPER, sizeof(MWIPLOTBNS->OPER)) == DB_FALSE)
        {
            make_valid_quote(ts1, MWIPLOTBNS_N.OPER);
            sprintf(sql + strlen(sql), "AND OPER = '%s' ", ts1);
        }

        if(ISSPACE(MWIPLOTBNS->RES_ID, sizeof(MWIPLOTBNS->RES_ID)) == DB_FALSE)
        {
            make_valid_quote(ts1, MWIPLOTBNS_N.RES_ID);
            sprintf(sql + strlen(sql), "AND RES_ID = '%s' ", ts1);
        }

        if(MWIPLOTBNS->QTY_FLAG != ' ')
        {
            sprintf(sql + strlen(sql), "AND QTY_FLAG = '%c' ", MWIPLOTBNS->QTY_FLAG);        
        }
        if(MWIPLOTBNS->HIST_DEL_FLAG != 'Y')
        {
            sprintf(sql + strlen(sql), "AND HIST_DEL_FLAG = ' ' ");
        }

        //This is the sorting statement of the SQL
        sprintf(sql + strlen(sql), "ORDER BY TRAN_TIME DESC, LOT_ID ASC, HIST_SEQ DESC, QTY_FLAG ASC) BNS ) WHERE ROWSEQ >= %d ORDER BY ROWSEQ ASC", DBC_Q_COND_N.FROM_SEQ);

        /* Check the sql */
        //fp=fopen("sql.txt","w");
        //fprintf(fp,"%s",sql);
        //fclose(fp);

        /* Open the cursor */
        EXEC SQL PREPARE S FROM :sql;
        EXEC SQL DECLARE DBC_MWIPLOTBNS_CUR_2 CURSOR FOR S;
        EXEC SQL OPEN DBC_MWIPLOTBNS_CUR_2;
        break;




    default:
        DB_error_code = 9999;
        memset(DB_error_msg, ' ', sizeof(DB_error_msg));
        memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
        break;
    }
    DB_stop_query_timer("DBC_open_mwiplotbns", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mwiplotbns(int sel_type, struct MWIPLOTBNS_TAG *MWIPLOTBNS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTBNS_N_TAG MWIPLOTBNS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
    case 1:
        EXEC SQL FETCH DBC_MWIPLOTBNS_CUR_1 INTO 
                                                :MWIPLOTBNS_N.LOT_ID,
                                                :MWIPLOTBNS_N.HIST_SEQ,
                                                :MWIPLOTBNS_N.QTY_FLAG,
                                                :MWIPLOTBNS_N.TRAN_TIME,
                                                :MWIPLOTBNS_N.HIST_DEL_FLAG,
                                                :MWIPLOTBNS_N.FACTORY,
                                                :MWIPLOTBNS_N.MAT_ID,
                                                :MWIPLOTBNS_N.MAT_VER,
                                                :MWIPLOTBNS_N.FLOW,
                                                :MWIPLOTBNS_N.FLOW_SEQ_NUM,
                                                :MWIPLOTBNS_N.OPER,
                                                :MWIPLOTBNS_N.RES_ID,
                                                :MWIPLOTBNS_N.CAUSE_FLOW,
                                                :MWIPLOTBNS_N.CAUSE_OPER,
                                                :MWIPLOTBNS_N.CAUSE_RES_ID,
                                                :MWIPLOTBNS_N.NEW_QTY,
                                                :MWIPLOTBNS_N.OLD_QTY,
                                                :MWIPLOTBNS_N.TOTAL_BONUS_QTY,
                                                :MWIPLOTBNS_N.BONUS_CODE_1,
                                                :MWIPLOTBNS_N.BONUS_CODE_2,
                                                :MWIPLOTBNS_N.BONUS_CODE_3,
                                                :MWIPLOTBNS_N.BONUS_CODE_4,
                                                :MWIPLOTBNS_N.BONUS_CODE_5,
                                                :MWIPLOTBNS_N.BONUS_CODE_6,
                                                :MWIPLOTBNS_N.BONUS_CODE_7,
                                                :MWIPLOTBNS_N.BONUS_CODE_8,
                                                :MWIPLOTBNS_N.BONUS_CODE_9,
                                                :MWIPLOTBNS_N.BONUS_CODE_10,
                                                :MWIPLOTBNS_N.BONUS_QTY_1,
                                                :MWIPLOTBNS_N.BONUS_QTY_2,
                                                :MWIPLOTBNS_N.BONUS_QTY_3,
                                                :MWIPLOTBNS_N.BONUS_QTY_4,
                                                :MWIPLOTBNS_N.BONUS_QTY_5,
                                                :MWIPLOTBNS_N.BONUS_QTY_6,
                                                :MWIPLOTBNS_N.BONUS_QTY_7,
                                                :MWIPLOTBNS_N.BONUS_QTY_8,
                                                :MWIPLOTBNS_N.BONUS_QTY_9,
                                                :MWIPLOTBNS_N.BONUS_QTY_10,
                                                :MWIPLOTBNS_N.BONUS_COMMENT_1,
                                                :MWIPLOTBNS_N.BONUS_COMMENT_2,
                                                :MWIPLOTBNS_N.BONUS_COMMENT_3;
        break;

    case 2:
        EXEC SQL FETCH DBC_MWIPLOTBNS_CUR_2 INTO :DBC_Q_COND_N.FROM_SEQ,
                                                :MWIPLOTBNS_N.LOT_ID,
                                                :MWIPLOTBNS_N.HIST_SEQ,
                                                :MWIPLOTBNS_N.QTY_FLAG,
                                                :MWIPLOTBNS_N.TRAN_TIME,
                                                :MWIPLOTBNS_N.HIST_DEL_FLAG,
                                                :MWIPLOTBNS_N.FACTORY,
                                                :MWIPLOTBNS_N.MAT_ID,
                                                :MWIPLOTBNS_N.MAT_VER,
                                                :MWIPLOTBNS_N.FLOW,
                                                :MWIPLOTBNS_N.FLOW_SEQ_NUM,
                                                :MWIPLOTBNS_N.OPER,
                                                :MWIPLOTBNS_N.RES_ID,
                                                :MWIPLOTBNS_N.CAUSE_FLOW,
                                                :MWIPLOTBNS_N.CAUSE_OPER,
                                                :MWIPLOTBNS_N.CAUSE_RES_ID,
                                                :MWIPLOTBNS_N.NEW_QTY,
                                                :MWIPLOTBNS_N.OLD_QTY,
                                                :MWIPLOTBNS_N.TOTAL_BONUS_QTY,
                                                :MWIPLOTBNS_N.BONUS_CODE_1,
                                                :MWIPLOTBNS_N.BONUS_CODE_2,
                                                :MWIPLOTBNS_N.BONUS_CODE_3,
                                                :MWIPLOTBNS_N.BONUS_CODE_4,
                                                :MWIPLOTBNS_N.BONUS_CODE_5,
                                                :MWIPLOTBNS_N.BONUS_CODE_6,
                                                :MWIPLOTBNS_N.BONUS_CODE_7,
                                                :MWIPLOTBNS_N.BONUS_CODE_8,
                                                :MWIPLOTBNS_N.BONUS_CODE_9,
                                                :MWIPLOTBNS_N.BONUS_CODE_10,
                                                :MWIPLOTBNS_N.BONUS_QTY_1,
                                                :MWIPLOTBNS_N.BONUS_QTY_2,
                                                :MWIPLOTBNS_N.BONUS_QTY_3,
                                                :MWIPLOTBNS_N.BONUS_QTY_4,
                                                :MWIPLOTBNS_N.BONUS_QTY_5,
                                                :MWIPLOTBNS_N.BONUS_QTY_6,
                                                :MWIPLOTBNS_N.BONUS_QTY_7,
                                                :MWIPLOTBNS_N.BONUS_QTY_8,
                                                :MWIPLOTBNS_N.BONUS_QTY_9,
                                                :MWIPLOTBNS_N.BONUS_QTY_10,
                                                :MWIPLOTBNS_N.BONUS_COMMENT_1,
                                                :MWIPLOTBNS_N.BONUS_COMMENT_2,
                                                :MWIPLOTBNS_N.BONUS_COMMENT_3;
        DB_del_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
        break;


    default:
        DB_error_code = 9999;
        memset(DB_error_msg, ' ', sizeof(DB_error_msg));
        memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
        break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwiplotbns(&MWIPLOTBNS_N, MWIPLOTBNS);
    }
    DB_stop_query_timer("DBC_fetch_mwiplotbns", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwiplotbns(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
    case 1:
        EXEC SQL CLOSE DBC_MWIPLOTBNS_CUR_1;
        break;

    case 2:
        EXEC SQL CLOSE DBC_MWIPLOTBNS_CUR_2;
        break;


    default:
        DB_error_code = 9999;
        memset(DB_error_msg, ' ', sizeof(DB_error_msg));
        memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
        break;
    }
    DB_stop_query_timer("DBC_close_mwiplotbns", sel_type);
}


/* Initialize Function */
void DBC_init_mwiplotbns(struct MWIPLOTBNS_TAG *MWIPLOTBNS)
{
    /* memset by Space */
    memset(MWIPLOTBNS, ' ', sizeof(struct MWIPLOTBNS_TAG));

    MWIPLOTBNS->HIST_SEQ = 0;
    MWIPLOTBNS->MAT_VER = 0;
    MWIPLOTBNS->FLOW_SEQ_NUM = 0;
    MWIPLOTBNS->NEW_QTY = 0;
    MWIPLOTBNS->OLD_QTY = 0;
    MWIPLOTBNS->TOTAL_BONUS_QTY = 0;
    MWIPLOTBNS->BONUS_QTY_1 = 0;
    MWIPLOTBNS->BONUS_QTY_2 = 0;
    MWIPLOTBNS->BONUS_QTY_3 = 0;
    MWIPLOTBNS->BONUS_QTY_4 = 0;
    MWIPLOTBNS->BONUS_QTY_5 = 0;
    MWIPLOTBNS->BONUS_QTY_6 = 0;
    MWIPLOTBNS->BONUS_QTY_7 = 0;
    MWIPLOTBNS->BONUS_QTY_8 = 0;
    MWIPLOTBNS->BONUS_QTY_9 = 0;
    MWIPLOTBNS->BONUS_QTY_10 = 0;
}


/* Add Null Function */
void DBC_add_null_mwiplotbns(struct MWIPLOTBNS_N_TAG *MWIPLOTBNS_N, struct MWIPLOTBNS_TAG *MWIPLOTBNS)
{
    /* memset by NULL */
    memset(MWIPLOTBNS_N, '\0', sizeof(struct MWIPLOTBNS_N_TAG));

    MEMCPY_AN(MWIPLOTBNS_N->LOT_ID, MWIPLOTBNS->LOT_ID, sizeof(MWIPLOTBNS->LOT_ID));
    MWIPLOTBNS_N->HIST_SEQ = MWIPLOTBNS->HIST_SEQ;
    MWIPLOTBNS_N->QTY_FLAG[0] = MWIPLOTBNS->QTY_FLAG;
    MEMCPY_AN(MWIPLOTBNS_N->TRAN_TIME, MWIPLOTBNS->TRAN_TIME, sizeof(MWIPLOTBNS->TRAN_TIME));
    MWIPLOTBNS_N->HIST_DEL_FLAG[0] = MWIPLOTBNS->HIST_DEL_FLAG;
    MEMCPY_AN(MWIPLOTBNS_N->FACTORY, MWIPLOTBNS->FACTORY, sizeof(MWIPLOTBNS->FACTORY));
    MEMCPY_AN(MWIPLOTBNS_N->MAT_ID, MWIPLOTBNS->MAT_ID, sizeof(MWIPLOTBNS->MAT_ID));
    MWIPLOTBNS_N->MAT_VER = MWIPLOTBNS->MAT_VER;
    MEMCPY_AN(MWIPLOTBNS_N->FLOW, MWIPLOTBNS->FLOW, sizeof(MWIPLOTBNS->FLOW));
    MWIPLOTBNS_N->FLOW_SEQ_NUM = MWIPLOTBNS->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPLOTBNS_N->OPER, MWIPLOTBNS->OPER, sizeof(MWIPLOTBNS->OPER));
    MEMCPY_AN(MWIPLOTBNS_N->RES_ID, MWIPLOTBNS->RES_ID, sizeof(MWIPLOTBNS->RES_ID));
    MEMCPY_AN(MWIPLOTBNS_N->CAUSE_FLOW, MWIPLOTBNS->CAUSE_FLOW, sizeof(MWIPLOTBNS->CAUSE_FLOW));
    MEMCPY_AN(MWIPLOTBNS_N->CAUSE_OPER, MWIPLOTBNS->CAUSE_OPER, sizeof(MWIPLOTBNS->CAUSE_OPER));
    MEMCPY_AN(MWIPLOTBNS_N->CAUSE_RES_ID, MWIPLOTBNS->CAUSE_RES_ID, sizeof(MWIPLOTBNS->CAUSE_RES_ID));
    MWIPLOTBNS_N->NEW_QTY = MWIPLOTBNS->NEW_QTY;
    MWIPLOTBNS_N->OLD_QTY = MWIPLOTBNS->OLD_QTY;
    MWIPLOTBNS_N->TOTAL_BONUS_QTY = MWIPLOTBNS->TOTAL_BONUS_QTY;
    MEMCPY_AN(MWIPLOTBNS_N->BONUS_CODE_1, MWIPLOTBNS->BONUS_CODE_1, sizeof(MWIPLOTBNS->BONUS_CODE_1));
    MEMCPY_AN(MWIPLOTBNS_N->BONUS_CODE_2, MWIPLOTBNS->BONUS_CODE_2, sizeof(MWIPLOTBNS->BONUS_CODE_2));
    MEMCPY_AN(MWIPLOTBNS_N->BONUS_CODE_3, MWIPLOTBNS->BONUS_CODE_3, sizeof(MWIPLOTBNS->BONUS_CODE_3));
    MEMCPY_AN(MWIPLOTBNS_N->BONUS_CODE_4, MWIPLOTBNS->BONUS_CODE_4, sizeof(MWIPLOTBNS->BONUS_CODE_4));
    MEMCPY_AN(MWIPLOTBNS_N->BONUS_CODE_5, MWIPLOTBNS->BONUS_CODE_5, sizeof(MWIPLOTBNS->BONUS_CODE_5));
    MEMCPY_AN(MWIPLOTBNS_N->BONUS_CODE_6, MWIPLOTBNS->BONUS_CODE_6, sizeof(MWIPLOTBNS->BONUS_CODE_6));
    MEMCPY_AN(MWIPLOTBNS_N->BONUS_CODE_7, MWIPLOTBNS->BONUS_CODE_7, sizeof(MWIPLOTBNS->BONUS_CODE_7));
    MEMCPY_AN(MWIPLOTBNS_N->BONUS_CODE_8, MWIPLOTBNS->BONUS_CODE_8, sizeof(MWIPLOTBNS->BONUS_CODE_8));
    MEMCPY_AN(MWIPLOTBNS_N->BONUS_CODE_9, MWIPLOTBNS->BONUS_CODE_9, sizeof(MWIPLOTBNS->BONUS_CODE_9));
    MEMCPY_AN(MWIPLOTBNS_N->BONUS_CODE_10, MWIPLOTBNS->BONUS_CODE_10, sizeof(MWIPLOTBNS->BONUS_CODE_10));
    MWIPLOTBNS_N->BONUS_QTY_1 = MWIPLOTBNS->BONUS_QTY_1;
    MWIPLOTBNS_N->BONUS_QTY_2 = MWIPLOTBNS->BONUS_QTY_2;
    MWIPLOTBNS_N->BONUS_QTY_3 = MWIPLOTBNS->BONUS_QTY_3;
    MWIPLOTBNS_N->BONUS_QTY_4 = MWIPLOTBNS->BONUS_QTY_4;
    MWIPLOTBNS_N->BONUS_QTY_5 = MWIPLOTBNS->BONUS_QTY_5;
    MWIPLOTBNS_N->BONUS_QTY_6 = MWIPLOTBNS->BONUS_QTY_6;
    MWIPLOTBNS_N->BONUS_QTY_7 = MWIPLOTBNS->BONUS_QTY_7;
    MWIPLOTBNS_N->BONUS_QTY_8 = MWIPLOTBNS->BONUS_QTY_8;
    MWIPLOTBNS_N->BONUS_QTY_9 = MWIPLOTBNS->BONUS_QTY_9;
    MWIPLOTBNS_N->BONUS_QTY_10 = MWIPLOTBNS->BONUS_QTY_10;
    MEMCPY_AN(MWIPLOTBNS_N->BONUS_COMMENT_1, MWIPLOTBNS->BONUS_COMMENT_1, sizeof(MWIPLOTBNS->BONUS_COMMENT_1));
    MEMCPY_AN(MWIPLOTBNS_N->BONUS_COMMENT_2, MWIPLOTBNS->BONUS_COMMENT_2, sizeof(MWIPLOTBNS->BONUS_COMMENT_2));
    MEMCPY_AN(MWIPLOTBNS_N->BONUS_COMMENT_3, MWIPLOTBNS->BONUS_COMMENT_3, sizeof(MWIPLOTBNS->BONUS_COMMENT_3));
}


/* Del Null Function */
void DBC_del_null_mwiplotbns(struct MWIPLOTBNS_N_TAG *MWIPLOTBNS_N, struct MWIPLOTBNS_TAG *MWIPLOTBNS)
{
    MEMCPY_DN(MWIPLOTBNS->LOT_ID, MWIPLOTBNS_N->LOT_ID, sizeof(MWIPLOTBNS->LOT_ID));
    MWIPLOTBNS->HIST_SEQ = MWIPLOTBNS_N->HIST_SEQ;
    MWIPLOTBNS->QTY_FLAG = MWIPLOTBNS_N->QTY_FLAG[0];
    MEMCPY_DN(MWIPLOTBNS->TRAN_TIME, MWIPLOTBNS_N->TRAN_TIME, sizeof(MWIPLOTBNS->TRAN_TIME));
    MWIPLOTBNS->HIST_DEL_FLAG = MWIPLOTBNS_N->HIST_DEL_FLAG[0];
    MEMCPY_DN(MWIPLOTBNS->FACTORY, MWIPLOTBNS_N->FACTORY, sizeof(MWIPLOTBNS->FACTORY));
    MEMCPY_DN(MWIPLOTBNS->MAT_ID, MWIPLOTBNS_N->MAT_ID, sizeof(MWIPLOTBNS->MAT_ID));
    MWIPLOTBNS->MAT_VER = MWIPLOTBNS_N->MAT_VER;
    MEMCPY_DN(MWIPLOTBNS->FLOW, MWIPLOTBNS_N->FLOW, sizeof(MWIPLOTBNS->FLOW));
    MWIPLOTBNS->FLOW_SEQ_NUM = MWIPLOTBNS_N->FLOW_SEQ_NUM;
