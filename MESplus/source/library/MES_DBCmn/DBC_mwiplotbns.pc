    MEMCPY_DN(MWIPLOTBNS->RES_ID, MWIPLOTBNS_N->RES_ID, sizeof(MWIPLOTBNS->RES_ID));
    MEMCPY_DN(MWIPLOTBNS->CAUSE_FLOW, MWIPLOTBNS_N->CAUSE_FLOW, sizeof(MWIPLOTBNS->CAUSE_FLOW));
    MEMCPY_DN(MWIPLOTBNS->CAUSE_OPER, MWIPLOTBNS_N->CAUSE_OPER, sizeof(MWIPLOTBNS->CAUSE_OPER));
    MEMCPY_DN(MWIPLOTBNS->CAUSE_RES_ID, MWIPLOTBNS_N->CAUSE_RES_ID, sizeof(MWIPLOTBNS->CAUSE_RES_ID));
    MWIPLOTBNS->NEW_QTY = MWIPLOTBNS_N->NEW_QTY;
    MWIPLOTBNS->OLD_QTY = MWIPLOTBNS_N->OLD_QTY;
    MWIPLOTBNS->TOTAL_BONUS_QTY = MWIPLOTBNS_N->TOTAL_BONUS_QTY;
    MEMCPY_DN(MWIPLOTBNS->BONUS_CODE_1, MWIPLOTBNS_N->BONUS_CODE_1, sizeof(MWIPLOTBNS->BONUS_CODE_1));
    MEMCPY_DN(MWIPLOTBNS->BONUS_CODE_2, MWIPLOTBNS_N->BONUS_CODE_2, sizeof(MWIPLOTBNS->BONUS_CODE_2));
    MEMCPY_DN(MWIPLOTBNS->BONUS_CODE_3, MWIPLOTBNS_N->BONUS_CODE_3, sizeof(MWIPLOTBNS->BONUS_CODE_3));
    MEMCPY_DN(MWIPLOTBNS->BONUS_CODE_4, MWIPLOTBNS_N->BONUS_CODE_4, sizeof(MWIPLOTBNS->BONUS_CODE_4));
