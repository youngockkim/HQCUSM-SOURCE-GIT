/* SQL INSERT Function */
void DBC_insert_mwiplydcod(struct MWIPLYDCOD_TAG *MWIPLYDCOD)
{
	EXEC SQL BEGIN DECLARE SECTION;
    struct MWIPLYDCOD_N_TAG MWIPLYDCOD_N;
	EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplydcod(&MWIPLYDCOD_N, MWIPLYDCOD);
    DB_error_code = 0;

    EXEC SQL INSERT INTO MWIPLYDCOD( 
                    FACTORY, 
                    MAT_ID, 
