/* SQL UPDATE Function */
void DBC_update_mwiplydcod(int sel_type, struct MWIPLYDCOD_TAG *MWIPLYDCOD)
{
	EXEC SQL BEGIN DECLARE SECTION;
    struct MWIPLYDCOD_N_TAG MWIPLYDCOD_N;
	EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplydcod(&MWIPLYDCOD_N, MWIPLYDCOD);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MWIPLYDCOD SET
                    CODE_UPPER_YIELD = :MWIPLYDCOD_N.CODE_UPPER_YIELD,
                    CODE_LOW_YIELD = :MWIPLYDCOD_N.CODE_LOW_YIELD,
                    CODE_AQL_TYPE = :MWIPLYDCOD_N.CODE_AQL_TYPE,
                    CHECK_BEFORE_DAY = :MWIPLYDCOD_N.CHECK_BEFORE_DAY,
                    AFFECT_RANGE_BEFORE = :MWIPLYDCOD_N.AFFECT_RANGE_BEFORE,
                    AFFECT_RANGE_AFTER = :MWIPLYDCOD_N.AFFECT_RANGE_AFTER,
                    ALARM_ID = :MWIPLYDCOD_N.ALARM_ID,
                    PROTECT_END_FLAG = :MWIPLYDCOD_N.PROTECT_END_FLAG,
                    DESCRIPTION = :MWIPLYDCOD_N.DESCRIPTION,
                    CREATE_TIME = :MWIPLYDCOD_N.CREATE_TIME,
                    CREATE_USER = :MWIPLYDCOD_N.CREATE_USER,
                    UPDATE_TIME = :MWIPLYDCOD_N.UPDATE_TIME,
                    UPDATE_USER = :MWIPLYDCOD_N.UPDATE_USER
                WHERE FACTORY = :MWIPLYDCOD_N.FACTORY
                    AND MAT_ID = :MWIPLYDCOD_N.MAT_ID
                    AND MAT_VER = :MWIPLYDCOD_N.MAT_VER
                    AND FLOW = :MWIPLYDCOD_N.FLOW
                    AND FLOW_SEQ_NUM = :MWIPLYDCOD_N.FLOW_SEQ_NUM
                    AND OPER = :MWIPLYDCOD_N.OPER
                    AND RES_ID = :MWIPLYDCOD_N.RES_ID
                    AND SUBRES_ID = :MWIPLYDCOD_N.SUBRES_ID
                    AND LOT_CMF_1 = :MWIPLYDCOD_N.LOT_CMF_1
                    AND LOT_CMF_2 = :MWIPLYDCOD_N.LOT_CMF_2
                    AND LOT_CMF_3 = :MWIPLYDCOD_N.LOT_CMF_3
                    AND LOT_CMF_4 = :MWIPLYDCOD_N.LOT_CMF_4
                    AND LOT_CMF_5 = :MWIPLYDCOD_N.LOT_CMF_5
                    AND LOT_CMF_6 = :MWIPLYDCOD_N.LOT_CMF_6
                    AND LOT_CMF_7 = :MWIPLYDCOD_N.LOT_CMF_7
                    AND LOT_CMF_8 = :MWIPLYDCOD_N.LOT_CMF_8
                    AND LOT_CMF_9 = :MWIPLYDCOD_N.LOT_CMF_9
                    AND LOT_CMF_10 = :MWIPLYDCOD_N.LOT_CMF_10
                    AND LOT_CMF_11 = :MWIPLYDCOD_N.LOT_CMF_11
                    AND LOT_CMF_12 = :MWIPLYDCOD_N.LOT_CMF_12
                    AND LOT_CMF_13 = :MWIPLYDCOD_N.LOT_CMF_13
                    AND LOT_CMF_14 = :MWIPLYDCOD_N.LOT_CMF_14
                    AND LOT_CMF_15 = :MWIPLYDCOD_N.LOT_CMF_15
                    AND LOT_CMF_16 = :MWIPLYDCOD_N.LOT_CMF_16
                    AND LOT_CMF_17 = :MWIPLYDCOD_N.LOT_CMF_17
                    AND LOT_CMF_18 = :MWIPLYDCOD_N.LOT_CMF_18
                    AND LOT_CMF_19 = :MWIPLYDCOD_N.LOT_CMF_19
                    AND LOT_CMF_20 = :MWIPLYDCOD_N.LOT_CMF_20
                    AND KEY_CODE = :MWIPLYDCOD_N.KEY_CODE
                    AND CODE = :MWIPLYDCOD_N.CODE
                    AND CODE_UNIT_TYPE = :MWIPLYDCOD_N.CODE_UNIT_TYPE
                    AND CHECK_RANGE = :MWIPLYDCOD_N.CHECK_RANGE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mwiplydcod", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwiplydcod(int sel_type, struct MWIPLYDCOD_TAG *MWIPLYDCOD)
{
	EXEC SQL BEGIN DECLARE SECTION;
    struct MWIPLYDCOD_N_TAG MWIPLYDCOD_N;
	EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplydcod(&MWIPLYDCOD_N, MWIPLYDCOD);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPLYDCOD_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_ID,
                    SUBRES_ID,
                    LOT_CMF_1,
                    LOT_CMF_2,
                    LOT_CMF_3,
                    LOT_CMF_4,
                    LOT_CMF_5,
                    LOT_CMF_6,
                    LOT_CMF_7,
                    LOT_CMF_8,
                    LOT_CMF_9,
                    LOT_CMF_10,
                    LOT_CMF_11,
                    LOT_CMF_12,
                    LOT_CMF_13,
                    LOT_CMF_14,
                    LOT_CMF_15,
                    LOT_CMF_16,
                    LOT_CMF_17,
                    LOT_CMF_18,
                    LOT_CMF_19,
                    LOT_CMF_20,
                    KEY_CODE,
                    CODE,
                    CODE_UPPER_YIELD,
                    CODE_LOW_YIELD,
                    CODE_UNIT_TYPE,
                    CODE_AQL_TYPE,
                    CHECK_RANGE,
                    CHECK_BEFORE_DAY,
                    AFFECT_RANGE_BEFORE,
                    AFFECT_RANGE_AFTER,
                    ALARM_ID,
                    PROTECT_END_FLAG,
                    DESCRIPTION,
                    CREATE_TIME,
                    CREATE_USER,
                    UPDATE_TIME,
                    UPDATE_USER
                FROM MWIPLYDCOD
                ORDER BY FACTORY ASC,
                    MAT_ID ASC,
                    MAT_VER ASC,
                    FLOW ASC,
                    FLOW_SEQ_NUM ASC,
                    OPER ASC,
                    RES_ID ASC,
                    SUBRES_ID ASC,
                    LOT_CMF_1 ASC,
                    LOT_CMF_2 ASC,
                    LOT_CMF_3 ASC,
                    LOT_CMF_4 ASC,
                    LOT_CMF_5 ASC,
                    LOT_CMF_6 ASC,
                    LOT_CMF_7 ASC,
                    LOT_CMF_8 ASC,
                    LOT_CMF_9 ASC,
                    LOT_CMF_10 ASC,
                    LOT_CMF_11 ASC,
                    LOT_CMF_12 ASC,
                    LOT_CMF_13 ASC,
                    LOT_CMF_14 ASC,
                    LOT_CMF_15 ASC,
                    LOT_CMF_16 ASC,
                    LOT_CMF_17 ASC,
                    LOT_CMF_18 ASC,
                    LOT_CMF_19 ASC,
                    LOT_CMF_20 ASC,
                    KEY_CODE ASC,
                    CODE ASC,
                    CODE_UNIT_TYPE ASC,
                    CHECK_RANGE ASC;
            EXEC SQL OPEN DBC_MWIPLYDCOD_CUR_1;
            break;

        case 2:
			EXEC SQL DECLARE DBC_MWIPLYDCOD_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_ID,
                    SUBRES_ID,
                    LOT_CMF_1,
                    LOT_CMF_2,
                    LOT_CMF_3,
                    LOT_CMF_4,
                    LOT_CMF_5,
                    LOT_CMF_6,
                    LOT_CMF_7,
                    LOT_CMF_8,
                    LOT_CMF_9,
                    LOT_CMF_10,
                    LOT_CMF_11,
                    LOT_CMF_12,
                    LOT_CMF_13,
                    LOT_CMF_14,
                    LOT_CMF_15,
                    LOT_CMF_16,
                    LOT_CMF_17,
                    LOT_CMF_18,
                    LOT_CMF_19,
                    LOT_CMF_20,
                    KEY_CODE,
                    CODE,
                    CODE_UPPER_YIELD,
                    CODE_LOW_YIELD,
                    CODE_UNIT_TYPE,
                    CODE_AQL_TYPE,
                    CHECK_RANGE,
                    CHECK_BEFORE_DAY,
                    AFFECT_RANGE_BEFORE,
                    AFFECT_RANGE_AFTER,
                    ALARM_ID,
                    PROTECT_END_FLAG,
                    DESCRIPTION,
                    CREATE_TIME,
                    CREATE_USER,
                    UPDATE_TIME,
                    UPDATE_USER
                FROM MWIPLYDCOD
				WHERE FACTORY = :MWIPLYDCOD_N.FACTORY
                    AND MAT_ID = :MWIPLYDCOD_N.MAT_ID
                    AND MAT_VER = :MWIPLYDCOD_N.MAT_VER
                    AND FLOW = :MWIPLYDCOD_N.FLOW
                    AND FLOW_SEQ_NUM = :MWIPLYDCOD_N.FLOW_SEQ_NUM
                    AND OPER = :MWIPLYDCOD_N.OPER
                    AND RES_ID = :MWIPLYDCOD_N.RES_ID
                    AND SUBRES_ID = :MWIPLYDCOD_N.SUBRES_ID
                    AND LOT_CMF_1 = :MWIPLYDCOD_N.LOT_CMF_1
                    AND LOT_CMF_2 = :MWIPLYDCOD_N.LOT_CMF_2
                    AND LOT_CMF_3 = :MWIPLYDCOD_N.LOT_CMF_3
                    AND LOT_CMF_4 = :MWIPLYDCOD_N.LOT_CMF_4
                    AND LOT_CMF_5 = :MWIPLYDCOD_N.LOT_CMF_5
                    AND LOT_CMF_6 = :MWIPLYDCOD_N.LOT_CMF_6
                    AND LOT_CMF_7 = :MWIPLYDCOD_N.LOT_CMF_7
                    AND LOT_CMF_8 = :MWIPLYDCOD_N.LOT_CMF_8
                    AND LOT_CMF_9 = :MWIPLYDCOD_N.LOT_CMF_9
                    AND LOT_CMF_10 = :MWIPLYDCOD_N.LOT_CMF_10
                    AND LOT_CMF_11 = :MWIPLYDCOD_N.LOT_CMF_11
                    AND LOT_CMF_12 = :MWIPLYDCOD_N.LOT_CMF_12
                    AND LOT_CMF_13 = :MWIPLYDCOD_N.LOT_CMF_13
                    AND LOT_CMF_14 = :MWIPLYDCOD_N.LOT_CMF_14
                    AND LOT_CMF_15 = :MWIPLYDCOD_N.LOT_CMF_15
                    AND LOT_CMF_16 = :MWIPLYDCOD_N.LOT_CMF_16
                    AND LOT_CMF_17 = :MWIPLYDCOD_N.LOT_CMF_17
                    AND LOT_CMF_18 = :MWIPLYDCOD_N.LOT_CMF_18
                    AND LOT_CMF_19 = :MWIPLYDCOD_N.LOT_CMF_19
                    AND LOT_CMF_20 = :MWIPLYDCOD_N.LOT_CMF_20
                    AND KEY_CODE = :MWIPLYDCOD_N.KEY_CODE
                ORDER BY CODE, CODE_UNIT_TYPE, CHECK_RANGE ASC;
            EXEC SQL OPEN DBC_MWIPLYDCOD_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwiplydcod", sel_type);
}


