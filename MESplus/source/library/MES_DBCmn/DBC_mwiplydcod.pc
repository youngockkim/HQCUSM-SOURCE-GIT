/* SQL CURSOR CLOSE Function */
void DBC_close_mwiplydcod(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPLYDCOD_CUR_1;
            break;

        case 2:
			 EXEC SQL CLOSE DBC_MWIPLYDCOD_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwiplydcod", sel_type);
}


/* Initialize Function */
void DBC_init_mwiplydcod(struct MWIPLYDCOD_TAG *MWIPLYDCOD)
{
    /* memset by Space */
    memset(MWIPLYDCOD, ' ', sizeof(struct MWIPLYDCOD_TAG));
    
    MWIPLYDCOD->MAT_VER = 0;
    MWIPLYDCOD->FLOW_SEQ_NUM = 0;
    MWIPLYDCOD->CODE_UPPER_YIELD = 0;
    MWIPLYDCOD->CODE_LOW_YIELD = 0;
    MWIPLYDCOD->CHECK_RANGE = 0;
    MWIPLYDCOD->CHECK_BEFORE_DAY = 0;
    MWIPLYDCOD->AFFECT_RANGE_BEFORE = 0;
    MWIPLYDCOD->AFFECT_RANGE_AFTER = 0;
}


/* Add Null Function */
void DBC_add_null_mwiplydcod(struct MWIPLYDCOD_N_TAG *MWIPLYDCOD_N, struct MWIPLYDCOD_TAG *MWIPLYDCOD)
{
    /* memset by NULL */
    memset(MWIPLYDCOD_N, '\0', sizeof(struct MWIPLYDCOD_N_TAG));
    
    MEMCPY_AN(MWIPLYDCOD_N->FACTORY, MWIPLYDCOD->FACTORY, sizeof(MWIPLYDCOD->FACTORY));
    MEMCPY_AN(MWIPLYDCOD_N->MAT_ID, MWIPLYDCOD->MAT_ID, sizeof(MWIPLYDCOD->MAT_ID));
    MWIPLYDCOD_N->MAT_VER = MWIPLYDCOD->MAT_VER;
    MEMCPY_AN(MWIPLYDCOD_N->FLOW, MWIPLYDCOD->FLOW, sizeof(MWIPLYDCOD->FLOW));
    MWIPLYDCOD_N->FLOW_SEQ_NUM = MWIPLYDCOD->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPLYDCOD_N->OPER, MWIPLYDCOD->OPER, sizeof(MWIPLYDCOD->OPER));
    MEMCPY_AN(MWIPLYDCOD_N->RES_ID, MWIPLYDCOD->RES_ID, sizeof(MWIPLYDCOD->RES_ID));
    MEMCPY_AN(MWIPLYDCOD_N->SUBRES_ID, MWIPLYDCOD->SUBRES_ID, sizeof(MWIPLYDCOD->SUBRES_ID));
    MEMCPY_AN(MWIPLYDCOD_N->LOT_CMF_1, MWIPLYDCOD->LOT_CMF_1, sizeof(MWIPLYDCOD->LOT_CMF_1));
    MEMCPY_AN(MWIPLYDCOD_N->LOT_CMF_2, MWIPLYDCOD->LOT_CMF_2, sizeof(MWIPLYDCOD->LOT_CMF_2));
    MEMCPY_AN(MWIPLYDCOD_N->LOT_CMF_3, MWIPLYDCOD->LOT_CMF_3, sizeof(MWIPLYDCOD->LOT_CMF_3));
    MEMCPY_AN(MWIPLYDCOD_N->LOT_CMF_4, MWIPLYDCOD->LOT_CMF_4, sizeof(MWIPLYDCOD->LOT_CMF_4));
    MEMCPY_AN(MWIPLYDCOD_N->LOT_CMF_5, MWIPLYDCOD->LOT_CMF_5, sizeof(MWIPLYDCOD->LOT_CMF_5));
