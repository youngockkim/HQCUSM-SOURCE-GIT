        case 1:
            EXEC SQL DECLARE DBC_MBATPRCSTS_CUR_1 CURSOR FOR
                SELECT 
                    JOB_PROC_ID,
                    PROC_RUN_SUBNO,
                    LAST_HIST_SEQ,
                    START_TIME,
                    END_TIME,
                    ELAPSED_TIME,
                    STATUS_FLAG,
                    ERROR_MSG,
                    DB_ERROR_MSG,
                    PROC_KEY_1,
                    PROC_KEY_2,
                    PROC_KEY_3,
                    PROC_KEY_4,
                    PROC_KEY_5
                FROM MBATPRCSTS
                ORDER BY JOB_PROC_ID ASC,
                    PROC_RUN_SUBNO ASC;
            EXEC SQL OPEN DBC_MBATPRCSTS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
