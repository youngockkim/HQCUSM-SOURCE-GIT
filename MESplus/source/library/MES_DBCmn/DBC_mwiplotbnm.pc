    DB_stop_query_timer("DBC_close_mwiplotbnm", sel_type);
}


/* Initialize Function */
void DBC_init_mwiplotbnm(struct MWIPLOTBNM_TAG *MWIPLOTBNM)
{
    /* memset by Space */
    memset(MWIPLOTBNM, ' ', sizeof(struct MWIPLOTBNM_TAG));
    
    MWIPLOTBNM->HIST_SEQ = 0;
    MWIPLOTBNM->MAT_VER = 0;
    MWIPLOTBNM->FLOW_SEQ_NUM = 0;
    MWIPLOTBNM->SEQ_NUM = 0;
    MWIPLOTBNM->BONUS_QTY = 0;
}


/* Add Null Function */
void DBC_add_null_mwiplotbnm(struct MWIPLOTBNM_N_TAG *MWIPLOTBNM_N, struct MWIPLOTBNM_TAG *MWIPLOTBNM)
{
    /* memset by NULL */
    memset(MWIPLOTBNM_N, '\0', sizeof(struct MWIPLOTBNM_N_TAG));
    
    MEMCPY_AN(MWIPLOTBNM_N->LOT_ID, MWIPLOTBNM->LOT_ID, sizeof(MWIPLOTBNM->LOT_ID));
    MWIPLOTBNM_N->HIST_SEQ = MWIPLOTBNM->HIST_SEQ;
    MWIPLOTBNM_N->QTY_FLAG[0] = MWIPLOTBNM->QTY_FLAG;
    MEMCPY_AN(MWIPLOTBNM_N->TRAN_TIME, MWIPLOTBNM->TRAN_TIME, sizeof(MWIPLOTBNM->TRAN_TIME));
    MWIPLOTBNM_N->HIST_DEL_FLAG[0] = MWIPLOTBNM->HIST_DEL_FLAG;
    MEMCPY_AN(MWIPLOTBNM_N->FACTORY, MWIPLOTBNM->FACTORY, sizeof(MWIPLOTBNM->FACTORY));
    MEMCPY_AN(MWIPLOTBNM_N->MAT_ID, MWIPLOTBNM->MAT_ID, sizeof(MWIPLOTBNM->MAT_ID));
    MWIPLOTBNM_N->MAT_VER = MWIPLOTBNM->MAT_VER;
    MEMCPY_AN(MWIPLOTBNM_N->FLOW, MWIPLOTBNM->FLOW, sizeof(MWIPLOTBNM->FLOW));
    MWIPLOTBNM_N->FLOW_SEQ_NUM = MWIPLOTBNM->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPLOTBNM_N->OPER, MWIPLOTBNM->OPER, sizeof(MWIPLOTBNM->OPER));
    MEMCPY_AN(MWIPLOTBNM_N->RES_ID, MWIPLOTBNM->RES_ID, sizeof(MWIPLOTBNM->RES_ID));
    MWIPLOTBNM_N->SEQ_NUM = MWIPLOTBNM->SEQ_NUM;
    MEMCPY_AN(MWIPLOTBNM_N->BONUS_CODE, MWIPLOTBNM->BONUS_CODE, sizeof(MWIPLOTBNM->BONUS_CODE));
    MWIPLOTBNM_N->BONUS_QTY = MWIPLOTBNM->BONUS_QTY;
}


/* Del Null Function */
void DBC_del_null_mwiplotbnm(struct MWIPLOTBNM_N_TAG *MWIPLOTBNM_N, struct MWIPLOTBNM_TAG *MWIPLOTBNM)
{
    MEMCPY_DN(MWIPLOTBNM->LOT_ID, MWIPLOTBNM_N->LOT_ID, sizeof(MWIPLOTBNM->LOT_ID));
    MWIPLOTBNM->HIST_SEQ = MWIPLOTBNM_N->HIST_SEQ;
    MWIPLOTBNM->QTY_FLAG = MWIPLOTBNM_N->QTY_FLAG[0];
    MEMCPY_DN(MWIPLOTBNM->TRAN_TIME, MWIPLOTBNM_N->TRAN_TIME, sizeof(MWIPLOTBNM->TRAN_TIME));
    MWIPLOTBNM->HIST_DEL_FLAG = MWIPLOTBNM_N->HIST_DEL_FLAG[0];
    MEMCPY_DN(MWIPLOTBNM->FACTORY, MWIPLOTBNM_N->FACTORY, sizeof(MWIPLOTBNM->FACTORY));
    MEMCPY_DN(MWIPLOTBNM->MAT_ID, MWIPLOTBNM_N->MAT_ID, sizeof(MWIPLOTBNM->MAT_ID));
    MWIPLOTBNM->MAT_VER = MWIPLOTBNM_N->MAT_VER;
    MEMCPY_DN(MWIPLOTBNM->FLOW, MWIPLOTBNM_N->FLOW, sizeof(MWIPLOTBNM->FLOW));
    MWIPLOTBNM->FLOW_SEQ_NUM = MWIPLOTBNM_N->FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPLOTBNM->OPER, MWIPLOTBNM_N->OPER, sizeof(MWIPLOTBNM->OPER));
    MEMCPY_DN(MWIPLOTBNM->RES_ID, MWIPLOTBNM_N->RES_ID, sizeof(MWIPLOTBNM->RES_ID));
    MWIPLOTBNM->SEQ_NUM = MWIPLOTBNM_N->SEQ_NUM;
    MEMCPY_DN(MWIPLOTBNM->BONUS_CODE, MWIPLOTBNM_N->BONUS_CODE, sizeof(MWIPLOTBNM->BONUS_CODE));
    MWIPLOTBNM->BONUS_QTY = MWIPLOTBNM_N->BONUS_QTY;
}



