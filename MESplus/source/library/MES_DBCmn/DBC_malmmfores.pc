/* SQL CURSOR CLOSE Function */
void DBC_close_malmmfores(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MALMMFORES_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MALMMFORES_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MALMMFORES_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MALMMFORES_CUR_4;
            break;
        case 5:
            EXEC SQL CLOSE DBC_MALMMFORES_CUR_5;
            break;
        case 6:
            EXEC SQL CLOSE DBC_MALMMFORES_CUR_6;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_malmmfores", sel_type);
}


/* Initialize Function */
void DBC_init_malmmfores(struct MALMMFORES_TAG *MALMMFORES)
{
    /* memset by Space */
    memset(MALMMFORES, ' ', sizeof(struct MALMMFORES_TAG));
    
    MALMMFORES->MAT_VER = 0;
}


/* Add Null Function */
void DBC_add_null_malmmfores(struct MALMMFORES_N_TAG *MALMMFORES_N, struct MALMMFORES_TAG *MALMMFORES)
{
    /* memset by NULL */
    memset(MALMMFORES_N, '\0', sizeof(struct MALMMFORES_N_TAG));
    
    MEMCPY_AN(MALMMFORES_N->FACTORY, MALMMFORES->FACTORY, sizeof(MALMMFORES->FACTORY));
    MALMMFORES_N->REL_LEVEL[0] = MALMMFORES->REL_LEVEL;
    MEMCPY_AN(MALMMFORES_N->MAT_ID, MALMMFORES->MAT_ID, sizeof(MALMMFORES->MAT_ID));
    MALMMFORES_N->MAT_VER = MALMMFORES->MAT_VER;
    MEMCPY_AN(MALMMFORES_N->FLOW, MALMMFORES->FLOW, sizeof(MALMMFORES->FLOW));
    MEMCPY_AN(MALMMFORES_N->OPER, MALMMFORES->OPER, sizeof(MALMMFORES->OPER));
    MEMCPY_AN(MALMMFORES_N->RES_TYPE, MALMMFORES->RES_TYPE, sizeof(MALMMFORES->RES_TYPE));
    MEMCPY_AN(MALMMFORES_N->RESG_ID, MALMMFORES->RESG_ID, sizeof(MALMMFORES->RESG_ID));
    MEMCPY_AN(MALMMFORES_N->RES_ID, MALMMFORES->RES_ID, sizeof(MALMMFORES->RES_ID));
    MEMCPY_AN(MALMMFORES_N->ALARM_ID, MALMMFORES->ALARM_ID, sizeof(MALMMFORES->ALARM_ID));
    MEMCPY_AN(MALMMFORES_N->APPLY_FROM_TIME, MALMMFORES->APPLY_FROM_TIME, sizeof(MALMMFORES->APPLY_FROM_TIME));
    MEMCPY_AN(MALMMFORES_N->APPLY_TO_TIME, MALMMFORES->APPLY_TO_TIME, sizeof(MALMMFORES->APPLY_TO_TIME));
    MEMCPY_AN(MALMMFORES_N->LOT_ID, MALMMFORES->LOT_ID, sizeof(MALMMFORES->LOT_ID));
    MALMMFORES_N->INHERIT_CHILD_FLAG[0] = MALMMFORES->INHERIT_CHILD_FLAG;
    MALMMFORES_N->TRAN_POINT[0] = MALMMFORES->TRAN_POINT;
    MEMCPY_AN(MALMMFORES_N->EVENT_ID, MALMMFORES->EVENT_ID, sizeof(MALMMFORES->EVENT_ID));
    MALMMFORES_N->NEED_CONFIRM_FLAG[0] = MALMMFORES->NEED_CONFIRM_FLAG;
    MALMMFORES_N->OVERRIDE_MSG_FLAG[0] = MALMMFORES->OVERRIDE_MSG_FLAG;
    MEMCPY_AN(MALMMFORES_N->ALARM_SUBJECT, MALMMFORES->ALARM_SUBJECT, sizeof(MALMMFORES->ALARM_SUBJECT));
    MEMCPY_AN(MALMMFORES_N->ALARM_MSG_1, MALMMFORES->ALARM_MSG_1, sizeof(MALMMFORES->ALARM_MSG_1));
    MEMCPY_AN(MALMMFORES_N->ALARM_MSG_2, MALMMFORES->ALARM_MSG_2, sizeof(MALMMFORES->ALARM_MSG_2));
    MEMCPY_AN(MALMMFORES_N->ALARM_MSG_3, MALMMFORES->ALARM_MSG_3, sizeof(MALMMFORES->ALARM_MSG_3));
    MALMMFORES_N->OVERRIDE_COMMENT_FLAG[0] = MALMMFORES->OVERRIDE_COMMENT_FLAG;
    MEMCPY_AN(MALMMFORES_N->ALARM_COMMENT_1, MALMMFORES->ALARM_COMMENT_1, sizeof(MALMMFORES->ALARM_COMMENT_1));
    MEMCPY_AN(MALMMFORES_N->ALARM_COMMENT_2, MALMMFORES->ALARM_COMMENT_2, sizeof(MALMMFORES->ALARM_COMMENT_2));
    MEMCPY_AN(MALMMFORES_N->ALARM_COMMENT_3, MALMMFORES->ALARM_COMMENT_3, sizeof(MALMMFORES->ALARM_COMMENT_3));
    MEMCPY_AN(MALMMFORES_N->ALARM_COMMENT_4, MALMMFORES->ALARM_COMMENT_4, sizeof(MALMMFORES->ALARM_COMMENT_4));
    MEMCPY_AN(MALMMFORES_N->ALARM_COMMENT_5, MALMMFORES->ALARM_COMMENT_5, sizeof(MALMMFORES->ALARM_COMMENT_5));
    MALMMFORES_N->OVERRIDE_PDF_FLAG[0] = MALMMFORES->OVERRIDE_PDF_FLAG;
    MEMCPY_AN(MALMMFORES_N->PDF_FILE_NAME, MALMMFORES->PDF_FILE_NAME, sizeof(MALMMFORES->PDF_FILE_NAME));
    MALMMFORES_N->OVERRIDE_IMAGE_FLAG[0] = MALMMFORES->OVERRIDE_IMAGE_FLAG;
    MEMCPY_AN(MALMMFORES_N->IMAGE_FILE_NAME, MALMMFORES->IMAGE_FILE_NAME, sizeof(MALMMFORES->IMAGE_FILE_NAME));
    MEMCPY_AN(MALMMFORES_N->FILE_NAME_KEY, MALMMFORES->FILE_NAME_KEY, sizeof(MALMMFORES->FILE_NAME_KEY));
    MEMCPY_AN(MALMMFORES_N->CREATE_USER_ID, MALMMFORES->CREATE_USER_ID, sizeof(MALMMFORES->CREATE_USER_ID));
    MEMCPY_AN(MALMMFORES_N->CREATE_TIME, MALMMFORES->CREATE_TIME, sizeof(MALMMFORES->CREATE_TIME));
    MEMCPY_AN(MALMMFORES_N->UPDATE_USER_ID, MALMMFORES->UPDATE_USER_ID, sizeof(MALMMFORES->UPDATE_USER_ID));
    MEMCPY_AN(MALMMFORES_N->UPDATE_TIME, MALMMFORES->UPDATE_TIME, sizeof(MALMMFORES->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_malmmfores(struct MALMMFORES_N_TAG *MALMMFORES_N, struct MALMMFORES_TAG *MALMMFORES)
{
    MEMCPY_DN(MALMMFORES->FACTORY, MALMMFORES_N->FACTORY, sizeof(MALMMFORES->FACTORY));
    MALMMFORES->REL_LEVEL = MALMMFORES_N->REL_LEVEL[0];
    MEMCPY_DN(MALMMFORES->MAT_ID, MALMMFORES_N->MAT_ID, sizeof(MALMMFORES->MAT_ID));
