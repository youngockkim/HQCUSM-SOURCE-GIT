                    AND RESG_ID = :MALMMFORES_N.RESG_ID
                    AND RES_ID = :MALMMFORES_N.RES_ID
                    AND ALARM_ID >= :MALMMFORES_N.ALARM_ID
                ORDER BY ALARM_ID ASC;
            EXEC SQL OPEN DBC_MALMMFORES_CUR_1;
            break;

