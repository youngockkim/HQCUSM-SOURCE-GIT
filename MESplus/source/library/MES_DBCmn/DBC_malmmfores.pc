                    IMAGE_FILE_NAME,
                    FILE_NAME_KEY
                FROM MALMMFORES
                WHERE FACTORY = :MALMMFORES_N.FACTORY
                    AND REL_LEVEL = :MALMMFORES_N.REL_LEVEL
                    AND MAT_ID = :MALMMFORES_N.MAT_ID
                    AND MAT_VER = :MALMMFORES_N.MAT_VER
                    AND FLOW = :MALMMFORES_N.FLOW
