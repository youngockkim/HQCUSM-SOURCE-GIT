/* Function Declaration */
void DBC_add_null_res_labor_list(struct RES_LABOR_LIST_N_TAG *RES_LABOR_LIST_N, struct RES_LABOR_LIST_TAG *RES_LABOR_LIST);
void DBC_del_null_res_labor_list(struct RES_LABOR_LIST_N_TAG *RES_LABOR_LIST_N, struct RES_LABOR_LIST_TAG *RES_LABOR_LIST);

/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_res_labor_list(int sel_type, struct RES_LABOR_LIST_TAG *RES_LABOR_LIST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RES_LABOR_LIST_N_TAG RES_LABOR_LIST_N;
        char sql[5120];
        char ts[1000];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    
    memset(sql, 0x00, sizeof(sql));
    memset(ts, 0x00, sizeof(ts));

    DBC_add_null_res_labor_list(&RES_LABOR_LIST_N, RES_LABOR_LIST);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_RES_LABOR_LIST_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    WORK_DATE,
                    RES_ID,
                    WORK_POSITION,
                    WORK_SHIFT,
                    DIRECT_LABOR_COUNT,
                    INDIRECT_LABOR_COUNT,
                    DIRECT_LABOR_MIN,
                    INDIRECT_LABOR_MIN,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM
                (
                    SELECT CAL.FACTORY AS FACTORY, CAL.SYS_DATE AS WORK_DATE, NVL(LAB.RES_ID, ' ') AS RES_ID,
                           CAL.WORK_POSITION AS WORK_POSITION, CAL.SHIFT AS WORK_SHIFT, NVL(LAB.DIRECT_LABOR_COUNT, 0) AS DIRECT_LABOR_COUNT,
                           NVL(LAB.INDIRECT_LABOR_COUNT, 0) AS INDIRECT_LABOR_COUNT, NVL(LAB.DIRECT_LABOR_MIN, 0) AS DIRECT_LABOR_MIN,
                           NVL(LAB.INDIRECT_LABOR_MIN, 0) AS INDIRECT_LABOR_MIN,NVL(LAB.CREATE_USER_ID, ' ') AS CREATE_USER_ID,
                           NVL(LAB.CREATE_TIME, ' ') AS CREATE_TIME, NVL(LAB.UPDATE_USER_ID, ' ') AS UPDATE_USER_ID,
                           NVL(LAB.UPDATE_TIME, ' ') AS UPDATE_TIME 
                    FROM 
                    (
                        SELECT TD.FACTORY, CD.SYS_DATE, TD.WORK_POSITION, SH.SHIFT 
                        FROM 
                        (
                            SELECT SYS_DATE 
                            FROM MWIPCALDEF
                            WHERE CALENDAR_ID = :RES_LABOR_LIST_N.FACTORY
                                AND CALENDAR_TYPE = :RES_LABOR_LIST_N.CALENDAR_TYPE
                                AND HOLIDAY_FLAG = ' '
                                AND PLAN_YEAR = :RES_LABOR_LIST_N.PLAN_YEAR
                                AND PLAN_MONTH = :RES_LABOR_LIST_N.PLAN_MONTH
                                AND SYS_DATE >= :RES_LABOR_LIST_N.WORK_DATE
                        ) CD, 
                        ( 
                            SELECT FACTORY, KEY_1 AS WORK_POSITION 
                            FROM MGCMTBLDAT
                            WHERE FACTORY = :RES_LABOR_LIST_N.FACTORY
                                AND TABLE_NAME = :RES_LABOR_LIST_N.WORK_POSITION_TBL_NAME
                        ) TD, 
                        (
                            SELECT DISTINCT SHIFT 
                            FROM 
                            (
                                SELECT DECODE(LTRIM(RTRIM(SHIFT_1_START)), '',' ','1') AS SHIFT
                                FROM MWIPFACDEF 
                                WHERE FACTORY = :RES_LABOR_LIST_N.FACTORY 
                                
                                UNION
                                
                                SELECT DECODE(LTRIM(RTRIM(SHIFT_2_START)), '',' ','2') AS SHIFT
                                FROM MWIPFACDEF 
                                WHERE FACTORY = :RES_LABOR_LIST_N.FACTORY 
                                
                                UNION
                                
                                SELECT DECODE(LTRIM(RTRIM(SHIFT_3_START)), '',' ','3') AS SHIFT
                                FROM MWIPFACDEF 
                                WHERE FACTORY = :RES_LABOR_LIST_N.FACTORY 
                                
                                UNION
                                
                                SELECT DECODE(LTRIM(RTRIM(SHIFT_4_START)), '',' ','4') AS SHIFT
                                FROM MWIPFACDEF 
                                WHERE FACTORY = :RES_LABOR_LIST_N.FACTORY 
                                
                                UNION
                                
                                SELECT ' ' AS SHIFT 
                                FROM DUAL
                            ) SH 
                        ) SH 
                    ) CAL , 
                    (
                        SELECT 
                            FACTORY,
                            RES_ID,
                            WORK_POSITION,
                            WORK_DATE,
                            WORK_SHIFT,
                            DIRECT_LABOR_COUNT,
                            INDIRECT_LABOR_COUNT,
                            DIRECT_LABOR_MIN,
                            INDIRECT_LABOR_MIN,
                            CREATE_USER_ID,
                            CREATE_TIME,
                            UPDATE_USER_ID,
                            UPDATE_TIME
                        FROM MRASRESLAB 
                        WHERE FACTORY = :RES_LABOR_LIST_N.FACTORY 
                            AND RES_ID = :RES_LABOR_LIST_N.RES_ID 
                            AND WORK_DATE >= :RES_LABOR_LIST_N.WORK_DATE
                    ) LAB 
                    WHERE CAL.SYS_DATE = LAB.WORK_DATE(+) 
                        AND CAL.WORK_POSITION = LAB.WORK_POSITION(+) 
                        AND CAL.SHIFT = LAB.WORK_SHIFT(+)
                ) A 
                WHERE 
                (
                    (WORK_DATE > :RES_LABOR_LIST_N.WORK_DATE) OR
                    (WORK_DATE = :RES_LABOR_LIST_N.WORK_DATE AND WORK_POSITION > :RES_LABOR_LIST_N.WORK_POSITION) OR
                    (WORK_DATE = :RES_LABOR_LIST_N.WORK_DATE AND WORK_POSITION = :RES_LABOR_LIST_N.WORK_POSITION AND WORK_SHIFT >= :RES_LABOR_LIST_N.WORK_SHIFT)
                )
                ORDER BY WORK_DATE, WORK_POSITION, WORK_SHIFT;
            EXEC SQL OPEN DBC_RES_LABOR_LIST_CUR_1;
            break;

        case 2:            
            sprintf(sql,               "SELECT * FROM (");
            sprintf(sql + strlen(sql), " SELECT CAL.FACTORY AS FACTORY, CAL.SYS_DATE AS WORK_DATE, NVL(LAB.RES_ID, ' ') AS RES_ID,");
            sprintf(sql + strlen(sql), " CAL.WORK_POSITION AS WORK_POSITION, CAL.SHIFT AS WORK_SHIFT, NVL(LAB.DIRECT_LABOR_COUNT, 0) AS DIRECT_LABOR_COUNT,");
            sprintf(sql + strlen(sql), " NVL(LAB.INDIRECT_LABOR_COUNT, 0) AS INDIRECT_LABOR_COUNT, NVL(LAB.DIRECT_LABOR_MIN, 0) AS DIRECT_LABOR_MIN,");
            sprintf(sql + strlen(sql), " NVL(LAB.INDIRECT_LABOR_MIN, 0) AS INDIRECT_LABOR_MIN,NVL(LAB.CREATE_USER_ID, ' ') AS CREATE_USER_ID,");
            sprintf(sql + strlen(sql), " NVL(LAB.CREATE_TIME, ' ') AS CREATE_TIME, NVL(LAB.UPDATE_USER_ID, ' ') AS UPDATE_USER_ID,");
            sprintf(sql + strlen(sql), " NVL(LAB.UPDATE_TIME, ' ') AS UPDATE_TIME FROM (");
            sprintf(sql + strlen(sql), " SELECT TD.FACTORY, CD.SYS_DATE, TD.WORK_POSITION, SH.SHIFT FROM (");
            sprintf(sql + strlen(sql), "  SELECT SYS_DATE FROM MWIPCALDEF");
            make_valid_quote(ts, RES_LABOR_LIST_N.FACTORY);
            sprintf(sql + strlen(sql), "  WHERE CALENDAR_ID='%s'",ts);
            sprintf(sql + strlen(sql), "  AND CALENDAR_TYPE='%c'", RES_LABOR_LIST_N.CALENDAR_TYPE[0]);
            sprintf(sql + strlen(sql), "  AND HOLIDAY_FLAG=' '");
            sprintf(sql + strlen(sql), "  AND PLAN_YEAR=%d", RES_LABOR_LIST_N.PLAN_YEAR);
            sprintf(sql + strlen(sql), "  AND PLAN_MONTH=%d", RES_LABOR_LIST_N.PLAN_MONTH);
            sprintf(sql + strlen(sql), "  AND SYS_DATE>='%s'", RES_LABOR_LIST_N.WORK_DATE);
            sprintf(sql + strlen(sql), "  ) CD, ( ");
            sprintf(sql + strlen(sql), "  SELECT FACTORY, KEY_1 AS WORK_POSITION FROM MGCMTBLDAT");
            make_valid_quote(ts, RES_LABOR_LIST_N.FACTORY);
            sprintf(sql + strlen(sql), "  WHERE FACTORY='%s'",ts);
            make_valid_quote(ts, RES_LABOR_LIST_N.WORK_POSITION_TBL_NAME);
            sprintf(sql + strlen(sql), "  AND TABLE_NAME='%s'",ts);
            sprintf(sql + strlen(sql), "  ) TD, (");
            sprintf(sql + strlen(sql), "  SELECT DISTINCT SHIFT FROM (");
            sprintf(sql + strlen(sql), "  SELECT DECODE(LTRIM(RTRIM(SHIFT_1_START)), '', ' ', '1') AS SHIFT");
            make_valid_quote(ts, RES_LABOR_LIST_N.FACTORY);
            sprintf(sql + strlen(sql), "  FROM MWIPFACDEF WHERE FACTORY='%s' UNION",ts);
            sprintf(sql + strlen(sql), "  SELECT DECODE(LTRIM(RTRIM(SHIFT_2_START)), '', ' ', '2') AS SHIFT");
            make_valid_quote(ts, RES_LABOR_LIST_N.FACTORY);
            sprintf(sql + strlen(sql), "  FROM MWIPFACDEF WHERE FACTORY='%s' UNION",ts);
            sprintf(sql + strlen(sql), "  SELECT DECODE(LTRIM(RTRIM(SHIFT_3_START)), '', ' ', '3') AS SHIFT");
            make_valid_quote(ts, RES_LABOR_LIST_N.FACTORY);
            sprintf(sql + strlen(sql), "  FROM MWIPFACDEF WHERE FACTORY='%s' UNION",ts);
            sprintf(sql + strlen(sql), "  SELECT DECODE(LTRIM(RTRIM(SHIFT_4_START)), '', ' ', '4') AS SHIFT");
            make_valid_quote(ts, RES_LABOR_LIST_N.FACTORY);
            sprintf(sql + strlen(sql), "  FROM MWIPFACDEF WHERE FACTORY='%s' UNION",ts);
            sprintf(sql + strlen(sql), "  SELECT ' ' AS SHIFT FROM DUAL");
            sprintf(sql + strlen(sql), "  ) SH ) SH ) CAL , (");
            sprintf(sql + strlen(sql), " SELECT * FROM MRASRESLAB WHERE");
            make_valid_quote(ts, RES_LABOR_LIST_N.FACTORY);
            sprintf(sql + strlen(sql), " FACTORY='%s' AND",ts);
           
            make_valid_quote(ts, RES_LABOR_LIST_N.WORK_DATE);
            sprintf(sql + strlen(sql), " WORK_DATE>='%s'",ts);
            sprintf(sql + strlen(sql), " ) LAB WHERE");
            sprintf(sql + strlen(sql), " CAL.SYS_DATE=LAB.WORK_DATE(+) AND");
            sprintf(sql + strlen(sql), " CAL.WORK_POSITION=LAB.WORK_POSITION(+) AND");
            sprintf(sql + strlen(sql), " CAL.SHIFT=LAB.WORK_SHIFT(+)"); 
            sprintf(sql + strlen(sql), " ) A WHERE");
            
            if(RES_LABOR_LIST->IS_RESOURCE == DB_TRUE)
            {
                make_valid_quote(ts, RES_LABOR_LIST_N.RES_ID);
                sprintf(sql + strlen(sql), " RES_ID='%s' AND",ts);
            }
            if(RES_LABOR_LIST->IS_WORK_POSITION == DB_TRUE)
            {
                make_valid_quote(ts, RES_LABOR_LIST_N.WORK_POSITION);
                sprintf(sql + strlen(sql), " WORK_POSITION='%s' AND",ts);
            }
            if(RES_LABOR_LIST->IS_WORK_SHIFT == DB_TRUE)
            {
                sprintf(sql + strlen(sql), " WORK_SHIFT = '%c' AND", RES_LABOR_LIST_N.WORK_SHIFT[0]);
            }
            
            if(RES_LABOR_LIST->IS_RESOURCE == DB_FALSE)
            {
                sprintf(sql + strlen(sql), " RES_ID<>' ' AND");                
            }
            
            make_valid_quote(ts, RES_LABOR_LIST_N.WORK_DATE);
            sprintf(sql + strlen(sql), " (WORK_DATE >'%s'",ts);
            
            make_valid_quote(ts, RES_LABOR_LIST_N.WORK_DATE);
            sprintf(sql + strlen(sql), " OR (WORK_DATE = '%s'",ts);
            make_valid_quote(ts, RES_LABOR_LIST_N.RES_ID);
            sprintf(sql + strlen(sql), " AND RES_ID > '%s')",ts);
            
            make_valid_quote(ts, RES_LABOR_LIST_N.WORK_DATE);
            sprintf(sql + strlen(sql), " OR (WORK_DATE = '%s'",ts);
            make_valid_quote(ts, RES_LABOR_LIST_N.RES_ID);
            sprintf(sql + strlen(sql), " AND RES_ID = '%s'",ts);
            make_valid_quote(ts, RES_LABOR_LIST_N.WORK_POSITION);
            sprintf(sql + strlen(sql), " AND WORK_POSITION > '%s')",ts);
            
            make_valid_quote(ts, RES_LABOR_LIST_N.WORK_DATE);
            sprintf(sql + strlen(sql), " OR (WORK_DATE = '%s'",ts);
            make_valid_quote(ts, RES_LABOR_LIST_N.RES_ID);
            sprintf(sql + strlen(sql), " AND RES_ID = '%s'",ts);
            make_valid_quote(ts, RES_LABOR_LIST_N.WORK_POSITION);
            sprintf(sql + strlen(sql), " AND WORK_POSITION = '%s' AND WORK_SHIFT >= '%c'))",ts, RES_LABOR_LIST_N.WORK_SHIFT[0]);
            
            sprintf(sql + strlen(sql), " ORDER BY WORK_DATE, RES_ID, WORK_POSITION, WORK_SHIFT ");
 
            EXEC SQL PREPARE S FROM :sql;
            
            /*
            LOG_head("DB");
            LOG_add("len", 1, strlen(sql));
            LOG_add("sql", 4, strlen(sql), sql);
            COM_log_write('I', 'S' , 'S');
            */
            
            EXEC SQL DECLARE DBC_RES_LABOR_LIST_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN DBC_RES_LABOR_LIST_CUR_2;  
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_res_labor_list", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_res_labor_list(int sel_type, struct RES_LABOR_LIST_TAG *RES_LABOR_LIST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RES_LABOR_LIST_N_TAG RES_LABOR_LIST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_RES_LABOR_LIST_CUR_1 INTO 
            :RES_LABOR_LIST_N.FACTORY,
            :RES_LABOR_LIST_N.WORK_DATE,
            :RES_LABOR_LIST_N.RES_ID,
            :RES_LABOR_LIST_N.WORK_POSITION,
            :RES_LABOR_LIST_N.WORK_SHIFT,
            :RES_LABOR_LIST_N.DIRECT_LABOR_COUNT,
            :RES_LABOR_LIST_N.INDIRECT_LABOR_COUNT,
            :RES_LABOR_LIST_N.DIRECT_LABOR_MIN,
            :RES_LABOR_LIST_N.INDIRECT_LABOR_MIN,
            :RES_LABOR_LIST_N.CREATE_USER_ID,
            :RES_LABOR_LIST_N.CREATE_TIME,
            :RES_LABOR_LIST_N.UPDATE_USER_ID,
            :RES_LABOR_LIST_N.UPDATE_TIME;
            break;
        case 2:
            EXEC SQL FETCH DBC_RES_LABOR_LIST_CUR_2 INTO 
            :RES_LABOR_LIST_N.FACTORY,
            :RES_LABOR_LIST_N.WORK_DATE,
            :RES_LABOR_LIST_N.RES_ID,
            :RES_LABOR_LIST_N.WORK_POSITION,
            :RES_LABOR_LIST_N.WORK_SHIFT,
            :RES_LABOR_LIST_N.DIRECT_LABOR_COUNT,
            :RES_LABOR_LIST_N.INDIRECT_LABOR_COUNT,
            :RES_LABOR_LIST_N.DIRECT_LABOR_MIN,
            :RES_LABOR_LIST_N.INDIRECT_LABOR_MIN,
            :RES_LABOR_LIST_N.CREATE_USER_ID,
            :RES_LABOR_LIST_N.CREATE_TIME,
            :RES_LABOR_LIST_N.UPDATE_USER_ID,
            :RES_LABOR_LIST_N.UPDATE_TIME;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_res_labor_list(&RES_LABOR_LIST_N, RES_LABOR_LIST);
    }
    DB_stop_query_timer("DBC_fetch_res_labor_list", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_res_labor_list(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_RES_LABOR_LIST_CUR_1;
            break;
        case 2:
            EXEC SQL CLOSE DBC_RES_LABOR_LIST_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_res_labor_list", sel_type);
}


/* Initialize Function */
void DBC_init_res_labor_list(struct RES_LABOR_LIST_TAG *RES_LABOR_LIST)
{
    /* memset by Space */
    memset(RES_LABOR_LIST, ' ', sizeof(struct RES_LABOR_LIST_TAG));
    
    RES_LABOR_LIST->DIRECT_LABOR_COUNT = 0;
    RES_LABOR_LIST->INDIRECT_LABOR_COUNT = 0;
    RES_LABOR_LIST->DIRECT_LABOR_MIN = 0;
    RES_LABOR_LIST->INDIRECT_LABOR_MIN = 0;
    RES_LABOR_LIST->PLAN_YEAR = 0;
    RES_LABOR_LIST->PLAN_MONTH = 0;
    RES_LABOR_LIST->IS_RESOURCE = 0;
    RES_LABOR_LIST->IS_WORK_POSITION = 0;
    RES_LABOR_LIST->IS_WORK_SHIFT = 0;
}


/* Add Null Function */
void DBC_add_null_res_labor_list(struct RES_LABOR_LIST_N_TAG *RES_LABOR_LIST_N, struct RES_LABOR_LIST_TAG *RES_LABOR_LIST)
{
    /* memset by NULL */
    memset(RES_LABOR_LIST_N, '\0', sizeof(struct RES_LABOR_LIST_N_TAG));
    
    MEMCPY_AN(RES_LABOR_LIST_N->FACTORY, RES_LABOR_LIST->FACTORY, sizeof(RES_LABOR_LIST->FACTORY));
    MEMCPY_AN(RES_LABOR_LIST_N->RES_ID, RES_LABOR_LIST->RES_ID, sizeof(RES_LABOR_LIST->RES_ID));
    MEMCPY_AN(RES_LABOR_LIST_N->WORK_POSITION, RES_LABOR_LIST->WORK_POSITION, sizeof(RES_LABOR_LIST->WORK_POSITION));
    MEMCPY_AN(RES_LABOR_LIST_N->WORK_DATE, RES_LABOR_LIST->WORK_DATE, sizeof(RES_LABOR_LIST->WORK_DATE));
    RES_LABOR_LIST_N->WORK_SHIFT[0] = RES_LABOR_LIST->WORK_SHIFT;
    RES_LABOR_LIST_N->DIRECT_LABOR_COUNT = RES_LABOR_LIST->DIRECT_LABOR_COUNT;
    RES_LABOR_LIST_N->INDIRECT_LABOR_COUNT = RES_LABOR_LIST->INDIRECT_LABOR_COUNT;
    RES_LABOR_LIST_N->DIRECT_LABOR_MIN = RES_LABOR_LIST->DIRECT_LABOR_MIN;
    RES_LABOR_LIST_N->INDIRECT_LABOR_MIN = RES_LABOR_LIST->INDIRECT_LABOR_MIN;
    MEMCPY_AN(RES_LABOR_LIST_N->CREATE_USER_ID, RES_LABOR_LIST->CREATE_USER_ID, sizeof(RES_LABOR_LIST->CREATE_USER_ID));
    MEMCPY_AN(RES_LABOR_LIST_N->CREATE_TIME, RES_LABOR_LIST->CREATE_TIME, sizeof(RES_LABOR_LIST->CREATE_TIME));
    MEMCPY_AN(RES_LABOR_LIST_N->UPDATE_USER_ID, RES_LABOR_LIST->UPDATE_USER_ID, sizeof(RES_LABOR_LIST->UPDATE_USER_ID));
    MEMCPY_AN(RES_LABOR_LIST_N->UPDATE_TIME, RES_LABOR_LIST->UPDATE_TIME, sizeof(RES_LABOR_LIST->UPDATE_TIME));
    RES_LABOR_LIST_N->CALENDAR_TYPE[0] = RES_LABOR_LIST->CALENDAR_TYPE;
    RES_LABOR_LIST_N->PLAN_YEAR = RES_LABOR_LIST->PLAN_YEAR;
    RES_LABOR_LIST_N->PLAN_MONTH = RES_LABOR_LIST->PLAN_MONTH;
    MEMCPY_AN(RES_LABOR_LIST_N->WORK_POSITION_TBL_NAME, RES_LABOR_LIST->WORK_POSITION_TBL_NAME, sizeof(RES_LABOR_LIST->WORK_POSITION_TBL_NAME));
    RES_LABOR_LIST_N->IS_RESOURCE = RES_LABOR_LIST->IS_RESOURCE;
    RES_LABOR_LIST_N->IS_WORK_POSITION = RES_LABOR_LIST->IS_WORK_POSITION;
    RES_LABOR_LIST_N->IS_WORK_SHIFT = RES_LABOR_LIST->IS_WORK_SHIFT;
}


/* Del Null Function */
void DBC_del_null_res_labor_list(struct RES_LABOR_LIST_N_TAG *RES_LABOR_LIST_N, struct RES_LABOR_LIST_TAG *RES_LABOR_LIST)
{
    MEMCPY_DN(RES_LABOR_LIST->FACTORY, RES_LABOR_LIST_N->FACTORY, sizeof(RES_LABOR_LIST->FACTORY));
    MEMCPY_DN(RES_LABOR_LIST->RES_ID, RES_LABOR_LIST_N->RES_ID, sizeof(RES_LABOR_LIST->RES_ID));
    MEMCPY_DN(RES_LABOR_LIST->WORK_POSITION, RES_LABOR_LIST_N->WORK_POSITION, sizeof(RES_LABOR_LIST->WORK_POSITION));
    MEMCPY_DN(RES_LABOR_LIST->WORK_DATE, RES_LABOR_LIST_N->WORK_DATE, sizeof(RES_LABOR_LIST->WORK_DATE));
    RES_LABOR_LIST->WORK_SHIFT = RES_LABOR_LIST_N->WORK_SHIFT[0];
    RES_LABOR_LIST->DIRECT_LABOR_COUNT = RES_LABOR_LIST_N->DIRECT_LABOR_COUNT;
    RES_LABOR_LIST->INDIRECT_LABOR_COUNT = RES_LABOR_LIST_N->INDIRECT_LABOR_COUNT;
    RES_LABOR_LIST->DIRECT_LABOR_MIN = RES_LABOR_LIST_N->DIRECT_LABOR_MIN;
    RES_LABOR_LIST->INDIRECT_LABOR_MIN = RES_LABOR_LIST_N->INDIRECT_LABOR_MIN;
    MEMCPY_DN(RES_LABOR_LIST->CREATE_USER_ID, RES_LABOR_LIST_N->CREATE_USER_ID, sizeof(RES_LABOR_LIST->CREATE_USER_ID));
    MEMCPY_DN(RES_LABOR_LIST->CREATE_TIME, RES_LABOR_LIST_N->CREATE_TIME, sizeof(RES_LABOR_LIST->CREATE_TIME));
    MEMCPY_DN(RES_LABOR_LIST->UPDATE_USER_ID, RES_LABOR_LIST_N->UPDATE_USER_ID, sizeof(RES_LABOR_LIST->UPDATE_USER_ID));
    MEMCPY_DN(RES_LABOR_LIST->UPDATE_TIME, RES_LABOR_LIST_N->UPDATE_TIME, sizeof(RES_LABOR_LIST->UPDATE_TIME));    
    RES_LABOR_LIST->CALENDAR_TYPE = RES_LABOR_LIST_N->CALENDAR_TYPE[0];
    RES_LABOR_LIST->PLAN_YEAR = RES_LABOR_LIST_N->PLAN_YEAR;
    RES_LABOR_LIST->PLAN_MONTH = RES_LABOR_LIST_N->PLAN_MONTH;
    MEMCPY_AN(RES_LABOR_LIST->WORK_POSITION_TBL_NAME, RES_LABOR_LIST_N->WORK_POSITION_TBL_NAME, sizeof(RES_LABOR_LIST->WORK_POSITION_TBL_NAME));
    RES_LABOR_LIST->IS_RESOURCE = RES_LABOR_LIST_N->IS_RESOURCE;
    RES_LABOR_LIST->IS_WORK_POSITION = RES_LABOR_LIST_N->IS_WORK_POSITION;
    RES_LABOR_LIST->IS_WORK_SHIFT = RES_LABOR_LIST_N->IS_WORK_SHIFT;
}

