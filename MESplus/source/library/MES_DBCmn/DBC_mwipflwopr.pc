        struct MWIPFLWOPR_N_TAG MWIPFLWOPR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipflwopr(&MWIPFLWOPR_N, MWIPFLWOPR);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MWIPFLWOPR SET
                    OPT_OPER_GROUP = :MWIPFLWOPR_N.OPT_OPER_GROUP,
                    OPT_OPER_OPTION_FLAG = :MWIPFLWOPR_N.OPT_OPER_OPTION_FLAG,
                    SEQ_NUM = :MWIPFLWOPR_N.SEQ_NUM,
                    PREV_OPER = :MWIPFLWOPR_N.PREV_OPER,
                    NEXT_OPER = :MWIPFLWOPR_N.NEXT_OPER,
                    CREATE_USER_ID = :MWIPFLWOPR_N.CREATE_USER_ID,
                    CREATE_TIME = :MWIPFLWOPR_N.CREATE_TIME,
                    UPDATE_USER_ID = :MWIPFLWOPR_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MWIPFLWOPR_N.UPDATE_TIME
                WHERE FACTORY = :MWIPFLWOPR_N.FACTORY
                    AND FLOW = :MWIPFLWOPR_N.FLOW
                    AND OPER = :MWIPFLWOPR_N.OPER;
            break;
        case 2:
            EXEC SQL UPDATE MWIPFLWOPR SET
                    SEQ_NUM = SEQ_NUM + 1
                WHERE FACTORY = :MWIPFLWOPR_N.FACTORY
                    AND FLOW = :MWIPFLWOPR_N.FLOW
                    AND SEQ_NUM >= :MWIPFLWOPR_N.SEQ_NUM;
            break;
        case 3:
            EXEC SQL UPDATE MWIPFLWOPR SET
                    SEQ_NUM = SEQ_NUM - 1
                WHERE FACTORY = :MWIPFLWOPR_N.FACTORY
                    AND FLOW = :MWIPFLWOPR_N.FLOW
                    AND SEQ_NUM >= :MWIPFLWOPR_N.SEQ_NUM;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
