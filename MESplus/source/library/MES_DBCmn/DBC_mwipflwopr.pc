    MWIPFLWOPR_N->OPT_OPER_OPTION_FLAG[0] = MWIPFLWOPR->OPT_OPER_OPTION_FLAG;
    MWIPFLWOPR_N->SEQ_NUM = MWIPFLWOPR->SEQ_NUM;
    MEMCPY_AN(MWIPFLWOPR_N->PREV_OPER, MWIPFLWOPR->PREV_OPER, sizeof(MWIPFLWOPR->PREV_OPER));
    MEMCPY_AN(MWIPFLWOPR_N->NEXT_OPER, MWIPFLWOPR->NEXT_OPER, sizeof(MWIPFLWOPR->NEXT_OPER));
    MEMCPY_AN(MWIPFLWOPR_N->CREATE_USER_ID, MWIPFLWOPR->CREATE_USER_ID, sizeof(MWIPFLWOPR->CREATE_USER_ID));
    MEMCPY_AN(MWIPFLWOPR_N->CREATE_TIME, MWIPFLWOPR->CREATE_TIME, sizeof(MWIPFLWOPR->CREATE_TIME));
    MEMCPY_AN(MWIPFLWOPR_N->UPDATE_USER_ID, MWIPFLWOPR->UPDATE_USER_ID, sizeof(MWIPFLWOPR->UPDATE_USER_ID));
    MEMCPY_AN(MWIPFLWOPR_N->UPDATE_TIME, MWIPFLWOPR->UPDATE_TIME, sizeof(MWIPFLWOPR->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mwipflwopr(struct MWIPFLWOPR_N_TAG *MWIPFLWOPR_N, struct MWIPFLWOPR_TAG *MWIPFLWOPR)
{
    MEMCPY_DN(MWIPFLWOPR->FACTORY, MWIPFLWOPR_N->FACTORY, sizeof(MWIPFLWOPR->FACTORY));
    MEMCPY_DN(MWIPFLWOPR->FLOW, MWIPFLWOPR_N->FLOW, sizeof(MWIPFLWOPR->FLOW));
    MEMCPY_DN(MWIPFLWOPR->OPER, MWIPFLWOPR_N->OPER, sizeof(MWIPFLWOPR->OPER));
    MEMCPY_DN(MWIPFLWOPR->OPT_OPER_GROUP, MWIPFLWOPR_N->OPT_OPER_GROUP, sizeof(MWIPFLWOPR->OPT_OPER_GROUP));
    MWIPFLWOPR->OPT_OPER_OPTION_FLAG = MWIPFLWOPR_N->OPT_OPER_OPTION_FLAG[0];
    MWIPFLWOPR->SEQ_NUM = MWIPFLWOPR_N->SEQ_NUM;
    MEMCPY_DN(MWIPFLWOPR->PREV_OPER, MWIPFLWOPR_N->PREV_OPER, sizeof(MWIPFLWOPR->PREV_OPER));
    MEMCPY_DN(MWIPFLWOPR->NEXT_OPER, MWIPFLWOPR_N->NEXT_OPER, sizeof(MWIPFLWOPR->NEXT_OPER));
    MEMCPY_DN(MWIPFLWOPR->CREATE_USER_ID, MWIPFLWOPR_N->CREATE_USER_ID, sizeof(MWIPFLWOPR->CREATE_USER_ID));
    MEMCPY_DN(MWIPFLWOPR->CREATE_TIME, MWIPFLWOPR_N->CREATE_TIME, sizeof(MWIPFLWOPR->CREATE_TIME));
    MEMCPY_DN(MWIPFLWOPR->UPDATE_USER_ID, MWIPFLWOPR_N->UPDATE_USER_ID, sizeof(MWIPFLWOPR->UPDATE_USER_ID));
    MEMCPY_DN(MWIPFLWOPR->UPDATE_TIME, MWIPFLWOPR_N->UPDATE_TIME, sizeof(MWIPFLWOPR->UPDATE_TIME));
}



