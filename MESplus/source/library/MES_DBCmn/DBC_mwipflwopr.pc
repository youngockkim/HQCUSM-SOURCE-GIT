        struct MWIPFLWOPR_N_TAG MWIPFLWOPR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipflwopr(&MWIPFLWOPR_N, MWIPFLWOPR);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPFLWOPR_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    FLOW,
                    OPER,
                    OPT_OPER_GROUP,
                    OPT_OPER_OPTION_FLAG,
                    SEQ_NUM,
                    PREV_OPER,
                    NEXT_OPER,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPFLWOPR
                WHERE FACTORY = :MWIPFLWOPR_N.FACTORY
                    AND FLOW = :MWIPFLWOPR_N.FLOW
                ORDER BY SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPFLWOPR_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPFLWOPR_CUR_2 CURSOR FOR
                SELECT FLOW, OPER 
                FROM MWIPFLWOPR
                WHERE FACTORY = :MWIPFLWOPR_N.FACTORY
                    AND FLOW = :MWIPFLWOPR_N.FLOW
                    AND OPT_OPER_GROUP = :MWIPFLWOPR_N.OPT_OPER_GROUP
                ORDER BY SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPFLWOPR_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MWIPFLWOPR_CUR_3 CURSOR FOR
                SELECT FLOW, OPER 
                FROM MWIPFLWOPR
                WHERE FACTORY = :MWIPFLWOPR_N.FACTORY
                    AND FLOW = :MWIPFLWOPR_N.FLOW
                    AND SEQ_NUM >= :MWIPFLWOPR_N.SEQ_NUM
                    AND OPT_OPER_GROUP = :MWIPFLWOPR_N.OPT_OPER_GROUP
                ORDER BY SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPFLWOPR_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipflwopr", sel_type);
}


