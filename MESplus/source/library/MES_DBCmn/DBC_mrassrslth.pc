void DBC_del_null_mrassrslth(struct MRASSRSLTH_N_TAG *MRASSRSLTH_N, struct MRASSRSLTH_TAG *MRASSRSLTH)
{
    MEMCPY_DN(MRASSRSLTH->FACTORY, MRASSRSLTH_N->FACTORY, sizeof(MRASSRSLTH->FACTORY));
    MEMCPY_DN(MRASSRSLTH->RES_ID, MRASSRSLTH_N->RES_ID, sizeof(MRASSRSLTH->RES_ID));
    MEMCPY_DN(MRASSRSLTH->SUBRES_ID, MRASSRSLTH_N->SUBRES_ID, sizeof(MRASSRSLTH->SUBRES_ID));
    MRASSRSLTH->HIST_SEQ = MRASSRSLTH_N->HIST_SEQ;
    MEMCPY_DN(MRASSRSLTH->LOT_ID, MRASSRSLTH_N->LOT_ID, sizeof(MRASSRSLTH->LOT_ID));
    MEMCPY_DN(MRASSRSLTH->SUBLOT_ID, MRASSRSLTH_N->SUBLOT_ID, sizeof(MRASSRSLTH->SUBLOT_ID));
    MEMCPY_DN(MRASSRSLTH->PARENTS_SUBRES_ID, MRASSRSLTH_N->PARENTS_SUBRES_ID, sizeof(MRASSRSLTH->PARENTS_SUBRES_ID));
    MRASSRSLTH->RES_HIST_SEQ = MRASSRSLTH_N->RES_HIST_SEQ;
    MEMCPY_DN(MRASSRSLTH->EVENT_ID, MRASSRSLTH_N->EVENT_ID, sizeof(MRASSRSLTH->EVENT_ID));
    MEMCPY_DN(MRASSRSLTH->TRAN_TIME, MRASSRSLTH_N->TRAN_TIME, sizeof(MRASSRSLTH->TRAN_TIME));
    MRASSRSLTH->LOT_HIST_SEQ = MRASSRSLTH_N->LOT_HIST_SEQ;
    MRASSRSLTH->SUBLOT_HIST_SEQ = MRASSRSLTH_N->SUBLOT_HIST_SEQ;
    MEMCPY_DN(MRASSRSLTH->MAT_ID, MRASSRSLTH_N->MAT_ID, sizeof(MRASSRSLTH->MAT_ID));
    MRASSRSLTH->MAT_VER = MRASSRSLTH_N->MAT_VER;
    MEMCPY_DN(MRASSRSLTH->FLOW, MRASSRSLTH_N->FLOW, sizeof(MRASSRSLTH->FLOW));
    MEMCPY_DN(MRASSRSLTH->OPER, MRASSRSLTH_N->OPER, sizeof(MRASSRSLTH->OPER));
    MRASSRSLTH->LOT_TYPE = MRASSRSLTH_N->LOT_TYPE[0];
    MRASSRSLTH->RWK_FLAG = MRASSRSLTH_N->RWK_FLAG[0];
    MRASSRSLTH->QTY_1 = MRASSRSLTH_N->QTY_1;
    MRASSRSLTH->QTY_2 = MRASSRSLTH_N->QTY_2;
    MRASSRSLTH->QTY_3 = MRASSRSLTH_N->QTY_3;
    MRASSRSLTH->HIST_DEL_FLAG = MRASSRSLTH_N->HIST_DEL_FLAG[0];
}


