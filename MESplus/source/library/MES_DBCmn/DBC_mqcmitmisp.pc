    MEMCPY_AN(MQCMITMISP_N->ISP_CMF_9, MQCMITMISP->ISP_CMF_9, sizeof(MQCMITMISP->ISP_CMF_9));
    MEMCPY_AN(MQCMITMISP_N->ISP_CMF_10, MQCMITMISP->ISP_CMF_10, sizeof(MQCMITMISP->ISP_CMF_10));
    MEMCPY_AN(MQCMITMISP_N->ISP_COMMENT, MQCMITMISP->ISP_COMMENT, sizeof(MQCMITMISP->ISP_COMMENT));
    MEMCPY_AN(MQCMITMISP_N->USER_ID, MQCMITMISP->USER_ID, sizeof(MQCMITMISP->USER_ID));
    MEMCPY_AN(MQCMITMISP_N->TRAN_TIME, MQCMITMISP->TRAN_TIME, sizeof(MQCMITMISP->TRAN_TIME));
