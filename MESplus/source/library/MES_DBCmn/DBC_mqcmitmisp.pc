                                                     :MQCMITMISP_N.BATCH_HIST_SEQ, 
                                                     :MQCMITMISP_N.INSP_SET_ID, 
                                                     :MQCMITMISP_N.INSP_SET_VERSION, 
                                                     :MQCMITMISP_N.INSP_ITEM, 
                                                     :MQCMITMISP_N.TEST_QTY, 
                                                     :MQCMITMISP_N.DEFECT_QTY;
            break;
            
        case 2:
            EXEC SQL FETCH DBC_MQCMITMISP_CUR_2 INTO 
                                                    :MQCMITMISP_N.FACTORY,
                                                    :MQCMITMISP_N.BATCH_ID,
                                                    :MQCMITMISP_N.BATCH_HIST_SEQ,
                                                    :MQCMITMISP_N.ITEM_ID,
                                                    :MQCMITMISP_N.INSP_ITEM,
                                                    :MQCMITMISP_N.HIST_DEL_FLAG,
                                                    :MQCMITMISP_N.DEL_RESULT_SEQ,
                                                    :MQCMITMISP_N.INSP_SET_ID,
                                                    :MQCMITMISP_N.INSP_SET_VERSION,
                                                    :MQCMITMISP_N.INSP_SEQ,
                                                    :MQCMITMISP_N.INSP_METHOD,
                                                    :MQCMITMISP_N.SAMPLE_QTY,
                                                    :MQCMITMISP_N.TEST_QTY,
                                                    :MQCMITMISP_N.DEFECT_QTY,
                                                    :MQCMITMISP_N.RESULT_FLAG,
                                                    :MQCMITMISP_N.ISP_CMF_1,
                                                    :MQCMITMISP_N.ISP_CMF_2,
                                                    :MQCMITMISP_N.ISP_CMF_3,
                                                    :MQCMITMISP_N.ISP_CMF_4,
                                                    :MQCMITMISP_N.ISP_CMF_5,
                                                    :MQCMITMISP_N.ISP_CMF_6,
                                                    :MQCMITMISP_N.ISP_CMF_7,
                                                    :MQCMITMISP_N.ISP_CMF_8,
                                                    :MQCMITMISP_N.ISP_CMF_9,
                                                    :MQCMITMISP_N.ISP_CMF_10,
                                                    :MQCMITMISP_N.ISP_COMMENT,
                                                    :MQCMITMISP_N.USER_ID,
                                                    :MQCMITMISP_N.TRAN_TIME;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mqcmitmisp(&MQCMITMISP_N, MQCMITMISP);
    }
    DB_stop_query_timer("DBC_fetch_mqcmitmisp", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mqcmitmisp(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MQCMITMISP_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_MQCMITMISP_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mqcmitmisp", sel_type);
}


/* Initialize Function */
void DBC_init_mqcmitmisp(struct MQCMITMISP_TAG *MQCMITMISP)
{
    /* memset by Space */
    memset(MQCMITMISP, ' ', sizeof(struct MQCMITMISP_TAG));
    
    MQCMITMISP->BATCH_HIST_SEQ = 0;
    MQCMITMISP->DEL_RESULT_SEQ = 0;
    MQCMITMISP->INSP_SET_VERSION = 0;
    MQCMITMISP->INSP_SEQ = 0;
    MQCMITMISP->SAMPLE_QTY = 0;
    MQCMITMISP->TEST_QTY = 0;
    MQCMITMISP->DEFECT_QTY = 0;
}


/* Add Null Function */
void DBC_add_null_mqcmitmisp(struct MQCMITMISP_N_TAG *MQCMITMISP_N, struct MQCMITMISP_TAG *MQCMITMISP)
{
    /* memset by NULL */
    memset(MQCMITMISP_N, '\0', sizeof(struct MQCMITMISP_N_TAG));
    
    MEMCPY_AN(MQCMITMISP_N->FACTORY, MQCMITMISP->FACTORY, sizeof(MQCMITMISP->FACTORY));
    MEMCPY_AN(MQCMITMISP_N->BATCH_ID, MQCMITMISP->BATCH_ID, sizeof(MQCMITMISP->BATCH_ID));
    MQCMITMISP_N->BATCH_HIST_SEQ = MQCMITMISP->BATCH_HIST_SEQ;
