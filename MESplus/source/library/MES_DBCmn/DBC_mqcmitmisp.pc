/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mqcmitmisp(int sel_type, struct MQCMITMISP_TAG *MQCMITMISP)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MQCMITMISP_N_TAG MQCMITMISP_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mqcmitmisp(&MQCMITMISP_N, MQCMITMISP);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MQCMITMISP_CUR_1 CURSOR FOR
                SELECT BATCH_ID, BATCH_HIST_SEQ, INSP_SET_ID, INSP_SET_VERSION, INSP_ITEM, SUM(TEST_QTY) AS TEST_QTY, SUM(DEFECT_QTY) AS DEFECT_QTY 
                FROM MQCMITMISP
                WHERE FACTORY =:MQCMITMISP_N.FACTORY
                  AND BATCH_ID =:MQCMITMISP_N.BATCH_ID
                  AND BATCH_HIST_SEQ =:MQCMITMISP_N.BATCH_HIST_SEQ
                  AND INSP_SET_ID =:MQCMITMISP_N.INSP_SET_ID
                  AND INSP_SET_VERSION =:MQCMITMISP_N.INSP_SET_VERSION
                  AND INSP_ITEM >=:MQCMITMISP_N.INSP_ITEM
                GROUP BY BATCH_ID, BATCH_HIST_SEQ, INSP_SET_ID, INSP_SET_VERSION, INSP_ITEM
                ORDER BY BATCH_ID ASC,
                    BATCH_HIST_SEQ ASC,
                    INSP_SET_ID ASC,
                    INSP_SET_VERSION ASC,
                    INSP_ITEM ASC;
            EXEC SQL OPEN DBC_MQCMITMISP_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MQCMITMISP_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    BATCH_ID,
                    BATCH_HIST_SEQ,
                    ITEM_ID,
                    INSP_ITEM,
                    HIST_DEL_FLAG,
                    DEL_RESULT_SEQ,
                    INSP_SET_ID,
                    INSP_SET_VERSION,
                    INSP_SEQ,
                    INSP_METHOD,
                    SAMPLE_QTY,
                    TEST_QTY,
                    DEFECT_QTY,
                    RESULT_FLAG,
                    ISP_CMF_1,
                    ISP_CMF_2,
                    ISP_CMF_3,
                    ISP_CMF_4,
                    ISP_CMF_5,
                    ISP_CMF_6,
                    ISP_CMF_7,
                    ISP_CMF_8,
                    ISP_CMF_9,
                    ISP_CMF_10,
                    ISP_COMMENT,
                    USER_ID,
                    TRAN_TIME
                FROM MQCMITMISP
                WHERE FACTORY =:MQCMITMISP_N.FACTORY
                  AND BATCH_ID =:MQCMITMISP_N.BATCH_ID
                  AND INSP_SEQ =:MQCMITMISP_N.INSP_SEQ
                  AND INSP_SET_ID =:MQCMITMISP_N.INSP_SET_ID
                  AND INSP_SET_VERSION =:MQCMITMISP_N.INSP_SET_VERSION
                  AND INSP_ITEM =:MQCMITMISP_N.INSP_ITEM
                  AND ITEM_ID >=:MQCMITMISP_N.ITEM_ID
                  AND HIST_DEL_FLAG <> 'Y'
                ORDER BY ITEM_ID ASC;
            EXEC SQL OPEN DBC_MQCMITMISP_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mqcmitmisp", sel_type);
}


