    MEMCPY_AN(MQCMITMISP_N->INSP_ITEM, MQCMITMISP->INSP_ITEM, sizeof(MQCMITMISP->INSP_ITEM));
    MQCMITMISP_N->HIST_DEL_FLAG[0] = MQCMITMISP->HIST_DEL_FLAG;
    MQCMITMISP_N->DEL_RESULT_SEQ = MQCMITMISP->DEL_RESULT_SEQ;
    MEMCPY_AN(MQCMITMISP_N->INSP_SET_ID, MQCMITMISP->INSP_SET_ID, sizeof(MQCMITMISP->INSP_SET_ID));
    MQCMITMISP_N->INSP_SET_VERSION = MQCMITMISP->INSP_SET_VERSION;
    MQCMITMISP_N->INSP_SEQ = MQCMITMISP->INSP_SEQ;
    MEMCPY_AN(MQCMITMISP_N->INSP_METHOD, MQCMITMISP->INSP_METHOD, sizeof(MQCMITMISP->INSP_METHOD));
    MQCMITMISP_N->SAMPLE_QTY = MQCMITMISP->SAMPLE_QTY;
    MQCMITMISP_N->TEST_QTY = MQCMITMISP->TEST_QTY;
    MQCMITMISP_N->DEFECT_QTY = MQCMITMISP->DEFECT_QTY;
    MQCMITMISP_N->RESULT_FLAG[0] = MQCMITMISP->RESULT_FLAG;
    MEMCPY_AN(MQCMITMISP_N->ISP_CMF_1, MQCMITMISP->ISP_CMF_1, sizeof(MQCMITMISP->ISP_CMF_1));
    MEMCPY_AN(MQCMITMISP_N->ISP_CMF_2, MQCMITMISP->ISP_CMF_2, sizeof(MQCMITMISP->ISP_CMF_2));
