/* SQL CURSOR CLOSE Function */
void DBC_close_mspcsumdat(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MSPCSUMDAT_CUR_1;
            break;
        case 2:
            EXEC SQL CLOSE DBC_MSPCSUMDAT_CUR_2;
            break;
        case 3:
            EXEC SQL CLOSE DBC_MSPCSUMDAT_CUR_3;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mspcsumdat", sel_type);
}


/* Initialize Function */
void DBC_init_mspcsumdat(struct MSPCSUMDAT_TAG *MSPCSUMDAT)
{
    /* memset by Space */
    memset(MSPCSUMDAT, ' ', sizeof(struct MSPCSUMDAT_TAG));
    
    MSPCSUMDAT->OOC_COUNT = 0;
    MSPCSUMDAT->OOC2_COUNT = 0;
    MSPCSUMDAT->POINT_COUNT = 0;
}


/* Add Null Function */
void DBC_add_null_mspcsumdat(struct MSPCSUMDAT_N_TAG *MSPCSUMDAT_N, struct MSPCSUMDAT_TAG *MSPCSUMDAT)
{
    /* memset by NULL */
    memset(MSPCSUMDAT_N, '\0', sizeof(struct MSPCSUMDAT_N_TAG));
    
    MEMCPY_AN(MSPCSUMDAT_N->FACTORY, MSPCSUMDAT->FACTORY, sizeof(MSPCSUMDAT->FACTORY));
    MEMCPY_AN(MSPCSUMDAT_N->CHART_ID, MSPCSUMDAT->CHART_ID, sizeof(MSPCSUMDAT->CHART_ID));
    MSPCSUMDAT_N->PERIOD_FLAG[0] = MSPCSUMDAT->PERIOD_FLAG;
    MEMCPY_AN(MSPCSUMDAT_N->CAL_YEAR, MSPCSUMDAT->CAL_YEAR, sizeof(MSPCSUMDAT->CAL_YEAR));
    MEMCPY_AN(MSPCSUMDAT_N->CAL_QUARTER, MSPCSUMDAT->CAL_QUARTER, sizeof(MSPCSUMDAT->CAL_QUARTER));
    MEMCPY_AN(MSPCSUMDAT_N->CAL_MONTH, MSPCSUMDAT->CAL_MONTH, sizeof(MSPCSUMDAT->CAL_MONTH));
    MEMCPY_AN(MSPCSUMDAT_N->CAL_WEEK, MSPCSUMDAT->CAL_WEEK, sizeof(MSPCSUMDAT->CAL_WEEK));
    MEMCPY_AN(MSPCSUMDAT_N->CAL_DAY, MSPCSUMDAT->CAL_DAY, sizeof(MSPCSUMDAT->CAL_DAY));
    MEMCPY_AN(MSPCSUMDAT_N->STDDEV, MSPCSUMDAT->STDDEV, sizeof(MSPCSUMDAT->STDDEV));
    MEMCPY_AN(MSPCSUMDAT_N->XBARBAR, MSPCSUMDAT->XBARBAR, sizeof(MSPCSUMDAT->XBARBAR));
    MEMCPY_AN(MSPCSUMDAT_N->RBAR, MSPCSUMDAT->RBAR, sizeof(MSPCSUMDAT->RBAR));
    MEMCPY_AN(MSPCSUMDAT_N->RANGE, MSPCSUMDAT->RANGE, sizeof(MSPCSUMDAT->RANGE));
    MEMCPY_AN(MSPCSUMDAT_N->MIN_VALUE, MSPCSUMDAT->MIN_VALUE, sizeof(MSPCSUMDAT->MIN_VALUE));
    MEMCPY_AN(MSPCSUMDAT_N->MAX_VALUE, MSPCSUMDAT->MAX_VALUE, sizeof(MSPCSUMDAT->MAX_VALUE));
    MEMCPY_AN(MSPCSUMDAT_N->CP, MSPCSUMDAT->CP, sizeof(MSPCSUMDAT->CP));
    MEMCPY_AN(MSPCSUMDAT_N->CPK, MSPCSUMDAT->CPK, sizeof(MSPCSUMDAT->CPK));
    MEMCPY_AN(MSPCSUMDAT_N->CPM, MSPCSUMDAT->CPM, sizeof(MSPCSUMDAT->CPM));
    MEMCPY_AN(MSPCSUMDAT_N->PP, MSPCSUMDAT->PP, sizeof(MSPCSUMDAT->PP));
    MEMCPY_AN(MSPCSUMDAT_N->PPK, MSPCSUMDAT->PPK, sizeof(MSPCSUMDAT->PPK));
    MEMCPY_AN(MSPCSUMDAT_N->PPM, MSPCSUMDAT->PPM, sizeof(MSPCSUMDAT->PPM));
    MSPCSUMDAT_N->OOC_COUNT = MSPCSUMDAT->OOC_COUNT;
    MSPCSUMDAT_N->OOC2_COUNT = MSPCSUMDAT->OOC2_COUNT;
    MSPCSUMDAT_N->POINT_COUNT = MSPCSUMDAT->POINT_COUNT;
    MSPCSUMDAT_N->GRADE[0] = MSPCSUMDAT->GRADE;
    MEMCPY_AN(MSPCSUMDAT_N->CAL_START_TIME, MSPCSUMDAT->CAL_START_TIME, sizeof(MSPCSUMDAT->CAL_START_TIME));
    MEMCPY_AN(MSPCSUMDAT_N->CAL_END_TIME, MSPCSUMDAT->CAL_END_TIME, sizeof(MSPCSUMDAT->CAL_END_TIME));
    MEMCPY_AN(MSPCSUMDAT_N->CREATE_USER_ID, MSPCSUMDAT->CREATE_USER_ID, sizeof(MSPCSUMDAT->CREATE_USER_ID));
    MEMCPY_AN(MSPCSUMDAT_N->CREATE_TIME, MSPCSUMDAT->CREATE_TIME, sizeof(MSPCSUMDAT->CREATE_TIME));
    MEMCPY_AN(MSPCSUMDAT_N->RESV_FIELD1, MSPCSUMDAT->RESV_FIELD1, sizeof(MSPCSUMDAT->RESV_FIELD1));
    MEMCPY_AN(MSPCSUMDAT_N->RESV_FIELD2, MSPCSUMDAT->RESV_FIELD2, sizeof(MSPCSUMDAT->RESV_FIELD2));
    MEMCPY_AN(MSPCSUMDAT_N->RESV_FIELD3, MSPCSUMDAT->RESV_FIELD3, sizeof(MSPCSUMDAT->RESV_FIELD3));
    MEMCPY_AN(MSPCSUMDAT_N->RESV_FIELD4, MSPCSUMDAT->RESV_FIELD4, sizeof(MSPCSUMDAT->RESV_FIELD4));
    MEMCPY_AN(MSPCSUMDAT_N->RESV_FIELD5, MSPCSUMDAT->RESV_FIELD5, sizeof(MSPCSUMDAT->RESV_FIELD5));
}


/* Del Null Function */
void DBC_del_null_mspcsumdat(struct MSPCSUMDAT_N_TAG *MSPCSUMDAT_N, struct MSPCSUMDAT_TAG *MSPCSUMDAT)
{
    MEMCPY_DN(MSPCSUMDAT->FACTORY, MSPCSUMDAT_N->FACTORY, sizeof(MSPCSUMDAT->FACTORY));
