            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N); 
            EXEC SQL DECLARE DBC_MSPCSUMDAT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    PERIOD_FLAG,
                    CAL_YEAR,
                    CAL_QUARTER,
                    CAL_MONTH,
                    CAL_WEEK,
                    CAL_DAY,
