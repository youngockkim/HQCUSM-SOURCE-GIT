                    RESV_FIELD4,
                    RESV_FIELD5
                FROM MSPCSUMDAT
                WHERE FACTORY = :MSPCSUMDAT_N.FACTORY
                    AND PERIOD_FLAG = :MSPCSUMDAT_N.PERIOD_FLAG
