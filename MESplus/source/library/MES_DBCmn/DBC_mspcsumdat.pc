    MEMCPY_DN(MSPCSUMDAT->CREATE_TIME, MSPCSUMDAT_N->CREATE_TIME, sizeof(MSPCSUMDAT->CREATE_TIME));
    MEMCPY_DN(MSPCSUMDAT->RESV_FIELD1, MSPCSUMDAT_N->RESV_FIELD1, sizeof(MSPCSUMDAT->RESV_FIELD1));
