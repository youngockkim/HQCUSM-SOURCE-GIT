                    AND PROC_EVENT_ID = :MWEMEVNHIS_N.PROC_EVENT_ID
                    AND HIST_DEL_FLAG LIKE :MWEMEVNHIS_N.HIST_DEL_FLAG
                    AND HIST_SEQ <= :MWEMEVNHIS_N.HIST_SEQ
                ORDER BY HIST_SEQ DESC;
