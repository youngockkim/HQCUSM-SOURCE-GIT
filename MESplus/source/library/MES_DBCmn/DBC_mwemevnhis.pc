        DBC_del_null_mwemevnhis(&MWEMEVNHIS_N, MWEMEVNHIS);
    }

    DB_stop_query_timer("DBC_fetch_mwemevnhis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwemevnhis(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWEMEVNHIS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWEMEVNHIS_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MWEMEVNHIS_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("DBC_close_mwemevnhis", sel_type);
}


/* Initialize Function */
void DBC_init_mwemevnhis(struct MWEMEVNHIS_TAG *MWEMEVNHIS)
{
    /* memset by Space */
    memset(MWEMEVNHIS, ' ', sizeof(struct MWEMEVNHIS_TAG));
    
    MWEMEVNHIS->HIST_SEQ = 0;
    MWEMEVNHIS->PREV_ACTIVE_HIST_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mwemevnhis(struct MWEMEVNHIS_N_TAG *MWEMEVNHIS_N, struct MWEMEVNHIS_TAG *MWEMEVNHIS)
{
    /* memset by NULL */
    memset(MWEMEVNHIS_N, '\0', sizeof(struct MWEMEVNHIS_N_TAG));
    
    MEMCPY_AN(MWEMEVNHIS_N->FACTORY, MWEMEVNHIS->FACTORY, sizeof(MWEMEVNHIS->FACTORY));
    MEMCPY_AN(MWEMEVNHIS_N->PROC_EVENT_ID, MWEMEVNHIS->PROC_EVENT_ID, sizeof(MWEMEVNHIS->PROC_EVENT_ID));
    MWEMEVNHIS_N->HIST_SEQ = MWEMEVNHIS->HIST_SEQ;
    MEMCPY_AN(MWEMEVNHIS_N->PROC_EVENT_DESC, MWEMEVNHIS->PROC_EVENT_DESC, sizeof(MWEMEVNHIS->PROC_EVENT_DESC));
    MEMCPY_AN(MWEMEVNHIS_N->WORK_PROC_TYPE, MWEMEVNHIS->WORK_PROC_TYPE, sizeof(MWEMEVNHIS->WORK_PROC_TYPE));
    MEMCPY_AN(MWEMEVNHIS_N->PROC_ID, MWEMEVNHIS->PROC_ID, sizeof(MWEMEVNHIS->PROC_ID));
    MEMCPY_AN(MWEMEVNHIS_N->STEP_ID, MWEMEVNHIS->STEP_ID, sizeof(MWEMEVNHIS->STEP_ID));
    MWEMEVNHIS_N->PROC_STATUS[0] = MWEMEVNHIS->PROC_STATUS;
    MEMCPY_AN(MWEMEVNHIS_N->REPORT_TIME, MWEMEVNHIS->REPORT_TIME, sizeof(MWEMEVNHIS->REPORT_TIME));
    MEMCPY_AN(MWEMEVNHIS_N->REPORT_USER_ID, MWEMEVNHIS->REPORT_USER_ID, sizeof(MWEMEVNHIS->REPORT_USER_ID));
    MEMCPY_AN(MWEMEVNHIS_N->LAST_STEP_ID, MWEMEVNHIS->LAST_STEP_ID, sizeof(MWEMEVNHIS->LAST_STEP_ID));
    MEMCPY_AN(MWEMEVNHIS_N->LAST_STEP_APPROVER, MWEMEVNHIS->LAST_STEP_APPROVER, sizeof(MWEMEVNHIS->LAST_STEP_APPROVER));
    MEMCPY_AN(MWEMEVNHIS_N->LAST_STEP_FINISH_TIME, MWEMEVNHIS->LAST_STEP_FINISH_TIME, sizeof(MWEMEVNHIS->LAST_STEP_FINISH_TIME));
    MWEMEVNHIS_N->STEP_APPROVER_TYPE[0] = MWEMEVNHIS->STEP_APPROVER_TYPE;
    MEMCPY_AN(MWEMEVNHIS_N->STEP_APPROVER, MWEMEVNHIS->STEP_APPROVER, sizeof(MWEMEVNHIS->STEP_APPROVER));
    MEMCPY_AN(MWEMEVNHIS_N->TRAN_TIME, MWEMEVNHIS->TRAN_TIME, sizeof(MWEMEVNHIS->TRAN_TIME));
    MEMCPY_AN(MWEMEVNHIS_N->TRAN_USER_ID, MWEMEVNHIS->TRAN_USER_ID, sizeof(MWEMEVNHIS->TRAN_USER_ID));
    MEMCPY_AN(MWEMEVNHIS_N->TRAN_COMMENT, MWEMEVNHIS->TRAN_COMMENT, sizeof(MWEMEVNHIS->TRAN_COMMENT));
    MWEMEVNHIS_N->PREV_ACTIVE_HIST_SEQ = MWEMEVNHIS->PREV_ACTIVE_HIST_SEQ;
    MWEMEVNHIS_N->HIST_DEL_FLAG[0] = MWEMEVNHIS->HIST_DEL_FLAG;
    MEMCPY_AN(MWEMEVNHIS_N->HIST_DEL_TIME, MWEMEVNHIS->HIST_DEL_TIME, sizeof(MWEMEVNHIS->HIST_DEL_TIME));
    MEMCPY_AN(MWEMEVNHIS_N->HIST_DEL_USER_ID, MWEMEVNHIS->HIST_DEL_USER_ID, sizeof(MWEMEVNHIS->HIST_DEL_USER_ID));
    MEMCPY_AN(MWEMEVNHIS_N->HIST_DEL_COMMENT, MWEMEVNHIS->HIST_DEL_COMMENT, sizeof(MWEMEVNHIS->HIST_DEL_COMMENT));
}


/* Del Null Function */
void DBC_del_null_mwemevnhis(struct MWEMEVNHIS_N_TAG *MWEMEVNHIS_N, struct MWEMEVNHIS_TAG *MWEMEVNHIS)
{
    MEMCPY_DN(MWEMEVNHIS->FACTORY, MWEMEVNHIS_N->FACTORY, sizeof(MWEMEVNHIS->FACTORY));
    MEMCPY_DN(MWEMEVNHIS->PROC_EVENT_ID, MWEMEVNHIS_N->PROC_EVENT_ID, sizeof(MWEMEVNHIS->PROC_EVENT_ID));
    MWEMEVNHIS->HIST_SEQ = MWEMEVNHIS_N->HIST_SEQ;
    MEMCPY_DN(MWEMEVNHIS->PROC_EVENT_DESC, MWEMEVNHIS_N->PROC_EVENT_DESC, sizeof(MWEMEVNHIS->PROC_EVENT_DESC));
    MEMCPY_DN(MWEMEVNHIS->WORK_PROC_TYPE, MWEMEVNHIS_N->WORK_PROC_TYPE, sizeof(MWEMEVNHIS->WORK_PROC_TYPE));
    MEMCPY_DN(MWEMEVNHIS->PROC_ID, MWEMEVNHIS_N->PROC_ID, sizeof(MWEMEVNHIS->PROC_ID));
    MEMCPY_DN(MWEMEVNHIS->STEP_ID, MWEMEVNHIS_N->STEP_ID, sizeof(MWEMEVNHIS->STEP_ID));
    MWEMEVNHIS->PROC_STATUS = MWEMEVNHIS_N->PROC_STATUS[0];
    MEMCPY_DN(MWEMEVNHIS->REPORT_TIME, MWEMEVNHIS_N->REPORT_TIME, sizeof(MWEMEVNHIS->REPORT_TIME));
    MEMCPY_DN(MWEMEVNHIS->REPORT_USER_ID, MWEMEVNHIS_N->REPORT_USER_ID, sizeof(MWEMEVNHIS->REPORT_USER_ID));
    MEMCPY_DN(MWEMEVNHIS->LAST_STEP_ID, MWEMEVNHIS_N->LAST_STEP_ID, sizeof(MWEMEVNHIS->LAST_STEP_ID));
    MEMCPY_DN(MWEMEVNHIS->LAST_STEP_APPROVER, MWEMEVNHIS_N->LAST_STEP_APPROVER, sizeof(MWEMEVNHIS->LAST_STEP_APPROVER));
    MEMCPY_DN(MWEMEVNHIS->LAST_STEP_FINISH_TIME, MWEMEVNHIS_N->LAST_STEP_FINISH_TIME, sizeof(MWEMEVNHIS->LAST_STEP_FINISH_TIME));
    MWEMEVNHIS->STEP_APPROVER_TYPE = MWEMEVNHIS_N->STEP_APPROVER_TYPE[0];
    MEMCPY_DN(MWEMEVNHIS->STEP_APPROVER, MWEMEVNHIS_N->STEP_APPROVER, sizeof(MWEMEVNHIS->STEP_APPROVER));
    MEMCPY_DN(MWEMEVNHIS->TRAN_TIME, MWEMEVNHIS_N->TRAN_TIME, sizeof(MWEMEVNHIS->TRAN_TIME));
    MEMCPY_DN(MWEMEVNHIS->TRAN_USER_ID, MWEMEVNHIS_N->TRAN_USER_ID, sizeof(MWEMEVNHIS->TRAN_USER_ID));
    MEMCPY_DN(MWEMEVNHIS->TRAN_COMMENT, MWEMEVNHIS_N->TRAN_COMMENT, sizeof(MWEMEVNHIS->TRAN_COMMENT));
    MWEMEVNHIS->PREV_ACTIVE_HIST_SEQ = MWEMEVNHIS_N->PREV_ACTIVE_HIST_SEQ;
    MWEMEVNHIS->HIST_DEL_FLAG = MWEMEVNHIS_N->HIST_DEL_FLAG[0];
    MEMCPY_DN(MWEMEVNHIS->HIST_DEL_TIME, MWEMEVNHIS_N->HIST_DEL_TIME, sizeof(MWEMEVNHIS->HIST_DEL_TIME));
    MEMCPY_DN(MWEMEVNHIS->HIST_DEL_USER_ID, MWEMEVNHIS_N->HIST_DEL_USER_ID, sizeof(MWEMEVNHIS->HIST_DEL_USER_ID));
    MEMCPY_DN(MWEMEVNHIS->HIST_DEL_COMMENT, MWEMEVNHIS_N->HIST_DEL_COMMENT, sizeof(MWEMEVNHIS->HIST_DEL_COMMENT));
}


