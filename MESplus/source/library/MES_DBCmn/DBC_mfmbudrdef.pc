    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MFMBUDRDEF_CUR_1 CURSOR FOR
                SELECT GROUP_ID, GROUP_DESC, WIDTH, HEIGHT 
                FROM MFMBUDRDEF
                WHERE FACTORY = :MFMBUDRDEF_N.FACTORY
                    AND GROUP_ID >= :MFMBUDRDEF_N.GROUP_ID
