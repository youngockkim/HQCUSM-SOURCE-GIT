    DB_start_query_timer();

    DBC_add_null_mwipidgdef(&MWIPIDGDEF_N, MWIPIDGDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPIDGDEF_CUR_1 CURSOR FOR
                SELECT 
                    RULE_ID,
                    RULE_DESC,
                    FACTORY,
                    GEN_TYPE,
                    SAVE_POINT,
                    FULFILL_SEQ,
                    APPROVAL_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    NOT_USED_ID_SEARCH_OPTION
                FROM MWIPIDGDEF
                    WHERE FACTORY = :MWIPIDGDEF_N.FACTORY
                    AND GEN_TYPE LIKE :MWIPIDGDEF_N.GEN_TYPE
                    AND RULE_ID >= :MWIPIDGDEF_N.RULE_ID
                ORDER BY RULE_ID ASC;
            EXEC SQL OPEN DBC_MWIPIDGDEF_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MWIPIDGDEF_CUR_2 CURSOR FOR
                SELECT 
                    RULE_ID,
                    RULE_DESC,
                    FACTORY,
                    GEN_TYPE,
                    SAVE_POINT,
                    FULFILL_SEQ,
                    APPROVAL_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    NOT_USED_ID_SEARCH_OPTION
                FROM MWIPIDGDEF
                    WHERE GEN_TYPE LIKE :MWIPIDGDEF_N.GEN_TYPE
                    AND RULE_ID >= :MWIPIDGDEF_N.RULE_ID
                ORDER BY RULE_ID ASC;
            EXEC SQL OPEN DBC_MWIPIDGDEF_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
