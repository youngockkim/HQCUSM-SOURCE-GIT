                    CREATE_USER_ID,
                    CREATE_TIME
                FROM MWIPCRRLTH
                WHERE LOT_ID = :MWIPCRRLTH_N.LOT_ID
                    AND HIST_SEQ = :MWIPCRRLTH_N.HIST_SEQ
                ORDER BY CRR_SEQ ASC;
            EXEC SQL OPEN DBC_MWIPCRRLTH_CUR_2;
            break;


        default:
            DB_error_code = 9999;
