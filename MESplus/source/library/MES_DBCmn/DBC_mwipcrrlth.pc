    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPCRRLTH_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    CRR_ID,
                    FACTORY,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    CRR_SEQ,
                    HIST_DEL_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME
                FROM MWIPCRRLTH
                WHERE FACTORY = :MWIPCRRLTH_N.FACTORY 
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC,
                    CRR_ID ASC;
            EXEC SQL OPEN DBC_MWIPCRRLTH_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPCRRLTH_CUR_2 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    CRR_ID,
                    FACTORY,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    CRR_SEQ,
