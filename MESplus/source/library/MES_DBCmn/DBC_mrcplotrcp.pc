    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRCPLOTRCP_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    RECIPE,
                    RECIPE_VERSION,
                    PP_ID,
                    COAT_PP_ID,
