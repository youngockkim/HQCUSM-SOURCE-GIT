/* Del Null Function */
void DBC_del_null_mrcplotrcp(struct MRCPLOTRCP_N_TAG *MRCPLOTRCP_N, struct MRCPLOTRCP_TAG *MRCPLOTRCP)
{
    MEMCPY_DN(MRCPLOTRCP->LOT_ID, MRCPLOTRCP_N->LOT_ID, sizeof(MRCPLOTRCP->LOT_ID));
    MEMCPY_DN(MRCPLOTRCP->FACTORY, MRCPLOTRCP_N->FACTORY, sizeof(MRCPLOTRCP->FACTORY));
    MEMCPY_DN(MRCPLOTRCP->RES_ID, MRCPLOTRCP_N->RES_ID, sizeof(MRCPLOTRCP->RES_ID));
    MEMCPY_DN(MRCPLOTRCP->SUBRES_ID, MRCPLOTRCP_N->SUBRES_ID, sizeof(MRCPLOTRCP->SUBRES_ID));
    MEMCPY_DN(MRCPLOTRCP->RECIPE, MRCPLOTRCP_N->RECIPE, sizeof(MRCPLOTRCP->RECIPE));
    MRCPLOTRCP->RECIPE_VERSION = MRCPLOTRCP_N->RECIPE_VERSION;
    MEMCPY_DN(MRCPLOTRCP->PP_ID, MRCPLOTRCP_N->PP_ID, sizeof(MRCPLOTRCP->PP_ID));
    MEMCPY_DN(MRCPLOTRCP->COAT_PP_ID, MRCPLOTRCP_N->COAT_PP_ID, sizeof(MRCPLOTRCP->COAT_PP_ID));
    MEMCPY_DN(MRCPLOTRCP->RETICLE_ID, MRCPLOTRCP_N->RETICLE_ID, sizeof(MRCPLOTRCP->RETICLE_ID));
    MEMCPY_DN(MRCPLOTRCP->COL_SET_ID, MRCPLOTRCP_N->COL_SET_ID, sizeof(MRCPLOTRCP->COL_SET_ID));
    MEMCPY_DN(MRCPLOTRCP->PROC_TIME, MRCPLOTRCP_N->PROC_TIME, sizeof(MRCPLOTRCP->PROC_TIME));
    MRCPLOTRCP->MODIFY_FLAG = MRCPLOTRCP_N->MODIFY_FLAG[0];
    MRCPLOTRCP->INLINE_MODIFY = MRCPLOTRCP_N->INLINE_MODIFY[0];
    MEMCPY_DN(MRCPLOTRCP->UPDATE_USER_ID, MRCPLOTRCP_N->UPDATE_USER_ID, sizeof(MRCPLOTRCP->UPDATE_USER_ID));
    MEMCPY_DN(MRCPLOTRCP->UPDATE_TIME, MRCPLOTRCP_N->UPDATE_TIME, sizeof(MRCPLOTRCP->UPDATE_TIME));
