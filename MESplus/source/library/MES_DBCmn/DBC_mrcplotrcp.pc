                    COL_SET_ID,
                    PROC_TIME,
                    MODIFY_FLAG,
                    INLINE_MODIFY,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRCPLOTRCP
                ORDER BY LOT_ID ASC;
            EXEC SQL OPEN DBC_MRCPLOTRCP_CUR_1;
