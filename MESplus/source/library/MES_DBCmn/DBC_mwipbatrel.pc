/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipbatrel(int sel_type, struct MWIPBATREL_TAG *MWIPBATREL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPBATREL_N_TAG MWIPBATREL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipbatrel(&MWIPBATREL_N, MWIPBATREL);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPBATREL_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    REL_LEVEL,
                    RES_TYPE,
                    RESG_ID,
                    RES_ID,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RECIPE,
                    CRT_RULE_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPBATREL
                WHERE FACTORY = :MWIPBATREL_N.FACTORY
                    AND REL_LEVEL = :MWIPBATREL_N.REL_LEVEL
                    AND RES_TYPE = :MWIPBATREL_N.RES_TYPE
                    AND RESG_ID = :MWIPBATREL_N.RESG_ID
                    AND RES_ID = :MWIPBATREL_N.RES_ID
                ORDER BY CRT_RULE_ID ASC,
                    MAT_ID ASC,
                    MAT_VER ASC,
                    FLOW ASC,
                    OPER ASC,
                    RECIPE ASC;
            EXEC SQL OPEN DBC_MWIPBATREL_CUR_1;
            break;
        case 2:
            EXEC SQL DECLARE DBC_MWIPBATREL_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    REL_LEVEL,
                    RES_TYPE,
                    RESG_ID,
                    RES_ID,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RECIPE,
                    CRT_RULE_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPBATREL
                WHERE FACTORY = :MWIPBATREL_N.FACTORY
                    AND REL_LEVEL = 'R'
                    AND CRT_RULE_ID = :MWIPBATREL_N.CRT_RULE_ID
                ORDER BY RES_ID;
            EXEC SQL OPEN DBC_MWIPBATREL_CUR_2;
            break;
            
        case 3:
            EXEC SQL DECLARE DBC_MWIPBATREL_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    REL_LEVEL,
                    RES_TYPE,
                    RESG_ID,
                    RES_ID,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RECIPE,
                    CRT_RULE_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPBATREL
                WHERE FACTORY = :MWIPBATREL_N.FACTORY
                    AND REL_LEVEL = 'T'
                    AND CRT_RULE_ID = :MWIPBATREL_N.CRT_RULE_ID
                ORDER BY RES_TYPE;
            EXEC SQL OPEN DBC_MWIPBATREL_CUR_3;
            break;
            
        case 4:
            EXEC SQL DECLARE DBC_MWIPBATREL_CUR_4 CURSOR FOR
                SELECT 
                    FACTORY,
                    REL_LEVEL,
                    RES_TYPE,
                    RESG_ID,
                    RES_ID,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RECIPE,
                    CRT_RULE_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPBATREL
                WHERE FACTORY = :MWIPBATREL_N.FACTORY
                    AND REL_LEVEL = 'G'
                    AND CRT_RULE_ID = :MWIPBATREL_N.CRT_RULE_ID
                ORDER BY RESG_ID;
            EXEC SQL OPEN DBC_MWIPBATREL_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipbatrel", sel_type);
}


