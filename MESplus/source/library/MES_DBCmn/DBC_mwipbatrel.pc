/* Initialize Function */
void DBC_init_mwipbatrel(struct MWIPBATREL_TAG *MWIPBATREL)
{
    /* memset by Space */
    memset(MWIPBATREL, ' ', sizeof(struct MWIPBATREL_TAG));
    
    MWIPBATREL->MAT_VER = 0;
}


/* Add Null Function */
void DBC_add_null_mwipbatrel(struct MWIPBATREL_N_TAG *MWIPBATREL_N, struct MWIPBATREL_TAG *MWIPBATREL)
{
    /* memset by NULL */
    memset(MWIPBATREL_N, '\0', sizeof(struct MWIPBATREL_N_TAG));
    
    MEMCPY_AN(MWIPBATREL_N->FACTORY, MWIPBATREL->FACTORY, sizeof(MWIPBATREL->FACTORY));
    MWIPBATREL_N->REL_LEVEL[0] = MWIPBATREL->REL_LEVEL;
    MEMCPY_AN(MWIPBATREL_N->RES_TYPE, MWIPBATREL->RES_TYPE, sizeof(MWIPBATREL->RES_TYPE));
    MEMCPY_AN(MWIPBATREL_N->RESG_ID, MWIPBATREL->RESG_ID, sizeof(MWIPBATREL->RESG_ID));
    MEMCPY_AN(MWIPBATREL_N->RES_ID, MWIPBATREL->RES_ID, sizeof(MWIPBATREL->RES_ID));
    MEMCPY_AN(MWIPBATREL_N->MAT_ID, MWIPBATREL->MAT_ID, sizeof(MWIPBATREL->MAT_ID));
    MWIPBATREL_N->MAT_VER = MWIPBATREL->MAT_VER;
    MEMCPY_AN(MWIPBATREL_N->FLOW, MWIPBATREL->FLOW, sizeof(MWIPBATREL->FLOW));
    MEMCPY_AN(MWIPBATREL_N->OPER, MWIPBATREL->OPER, sizeof(MWIPBATREL->OPER));
    MEMCPY_AN(MWIPBATREL_N->RECIPE, MWIPBATREL->RECIPE, sizeof(MWIPBATREL->RECIPE));
    MEMCPY_AN(MWIPBATREL_N->CRT_RULE_ID, MWIPBATREL->CRT_RULE_ID, sizeof(MWIPBATREL->CRT_RULE_ID));
    MEMCPY_AN(MWIPBATREL_N->CREATE_USER_ID, MWIPBATREL->CREATE_USER_ID, sizeof(MWIPBATREL->CREATE_USER_ID));
    MEMCPY_AN(MWIPBATREL_N->CREATE_TIME, MWIPBATREL->CREATE_TIME, sizeof(MWIPBATREL->CREATE_TIME));
    MEMCPY_AN(MWIPBATREL_N->UPDATE_USER_ID, MWIPBATREL->UPDATE_USER_ID, sizeof(MWIPBATREL->UPDATE_USER_ID));
    MEMCPY_AN(MWIPBATREL_N->UPDATE_TIME, MWIPBATREL->UPDATE_TIME, sizeof(MWIPBATREL->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mwipbatrel(struct MWIPBATREL_N_TAG *MWIPBATREL_N, struct MWIPBATREL_TAG *MWIPBATREL)
{
    MEMCPY_DN(MWIPBATREL->FACTORY, MWIPBATREL_N->FACTORY, sizeof(MWIPBATREL->FACTORY));
    MWIPBATREL->REL_LEVEL = MWIPBATREL_N->REL_LEVEL[0];
    MEMCPY_DN(MWIPBATREL->RES_TYPE, MWIPBATREL_N->RES_TYPE, sizeof(MWIPBATREL->RES_TYPE));
    MEMCPY_DN(MWIPBATREL->RESG_ID, MWIPBATREL_N->RESG_ID, sizeof(MWIPBATREL->RESG_ID));
    MEMCPY_DN(MWIPBATREL->RES_ID, MWIPBATREL_N->RES_ID, sizeof(MWIPBATREL->RES_ID));
    MEMCPY_DN(MWIPBATREL->MAT_ID, MWIPBATREL_N->MAT_ID, sizeof(MWIPBATREL->MAT_ID));
    MWIPBATREL->MAT_VER = MWIPBATREL_N->MAT_VER;
    MEMCPY_DN(MWIPBATREL->FLOW, MWIPBATREL_N->FLOW, sizeof(MWIPBATREL->FLOW));
    MEMCPY_DN(MWIPBATREL->OPER, MWIPBATREL_N->OPER, sizeof(MWIPBATREL->OPER));
    MEMCPY_DN(MWIPBATREL->RECIPE, MWIPBATREL_N->RECIPE, sizeof(MWIPBATREL->RECIPE));
    MEMCPY_DN(MWIPBATREL->CRT_RULE_ID, MWIPBATREL_N->CRT_RULE_ID, sizeof(MWIPBATREL->CRT_RULE_ID));
    MEMCPY_DN(MWIPBATREL->CREATE_USER_ID, MWIPBATREL_N->CREATE_USER_ID, sizeof(MWIPBATREL->CREATE_USER_ID));
    MEMCPY_DN(MWIPBATREL->CREATE_TIME, MWIPBATREL_N->CREATE_TIME, sizeof(MWIPBATREL->CREATE_TIME));
    MEMCPY_DN(MWIPBATREL->UPDATE_USER_ID, MWIPBATREL_N->UPDATE_USER_ID, sizeof(MWIPBATREL->UPDATE_USER_ID));
    MEMCPY_DN(MWIPBATREL->UPDATE_TIME, MWIPBATREL_N->UPDATE_TIME, sizeof(MWIPBATREL->UPDATE_TIME));
}


