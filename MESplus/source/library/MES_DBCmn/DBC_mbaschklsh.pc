                :MBASCHKLSH_N.COMPLETE_USER_ID,
                :MBASCHKLSH_N.DELETE_FLAG,
                :MBASCHKLSH_N.DELETE_TIME,
                :MBASCHKLSH_N.DELETE_USER_ID,
                :MBASCHKLSH_N.BASE_OBJ_ID,
                :MBASCHKLSH_N.BASE_OBJ_HIST_SEQ,
                :MBASCHKLSH_N.KEY_1_VALUE,
                :MBASCHKLSH_N.KEY_2_VALUE,
                :MBASCHKLSH_N.KEY_3_VALUE,
                :MBASCHKLSH_N.KEY_4_VALUE,
                :MBASCHKLSH_N.KEY_5_VALUE,
                :MBASCHKLSH_N.KEY_6_VALUE,
                :MBASCHKLSH_N.KEY_7_VALUE,
                :MBASCHKLSH_N.KEY_8_VALUE,
                :MBASCHKLSH_N.KEY_9_VALUE,
                :MBASCHKLSH_N.KEY_10_VALUE;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mbaschklsh(&MBASCHKLSH_N, MBASCHKLSH);
    }

    DB_stop_query_timer("DBC_fetch_mbaschklsh", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mbaschklsh(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MBASCHKLSH_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MBASCHKLSH_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("DBC_close_mbaschklsh", sel_type);
}


/* Initialize Function */
void DBC_init_mbaschklsh(struct MBASCHKLSH_TAG *MBASCHKLSH)
{
    /* memset by Space */
    memset(MBASCHKLSH, ' ', sizeof(struct MBASCHKLSH_TAG));
    
    MBASCHKLSH->HIST_SEQ = 0;
    MBASCHKLSH->BASE_OBJ_HIST_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mbaschklsh(struct MBASCHKLSH_N_TAG *MBASCHKLSH_N, struct MBASCHKLSH_TAG *MBASCHKLSH)
{
    /* memset by NULL */
    memset(MBASCHKLSH_N, '\0', sizeof(struct MBASCHKLSH_N_TAG));
    
    MEMCPY_AN(MBASCHKLSH_N->CREATE_USER_ID, MBASCHKLSH->CREATE_USER_ID, sizeof(MBASCHKLSH->CREATE_USER_ID));
    MEMCPY_AN(MBASCHKLSH_N->CREATE_TIME, MBASCHKLSH->CREATE_TIME, sizeof(MBASCHKLSH->CREATE_TIME));
    MEMCPY_AN(MBASCHKLSH_N->UPDATE_USER_ID, MBASCHKLSH->UPDATE_USER_ID, sizeof(MBASCHKLSH->UPDATE_USER_ID));
    MEMCPY_AN(MBASCHKLSH_N->UPDATE_TIME, MBASCHKLSH->UPDATE_TIME, sizeof(MBASCHKLSH->UPDATE_TIME));
    MEMCPY_AN(MBASCHKLSH_N->FACTORY, MBASCHKLSH->FACTORY, sizeof(MBASCHKLSH->FACTORY));
    MEMCPY_AN(MBASCHKLSH_N->CHKLIST_ID, MBASCHKLSH->CHKLIST_ID, sizeof(MBASCHKLSH->CHKLIST_ID));
    MEMCPY_AN(MBASCHKLSH_N->REL_KEY, MBASCHKLSH->REL_KEY, sizeof(MBASCHKLSH->REL_KEY));
    MBASCHKLSH_N->HIST_SEQ = MBASCHKLSH->HIST_SEQ;
    MEMCPY_AN(MBASCHKLSH_N->TRAN_TIME, MBASCHKLSH->TRAN_TIME, sizeof(MBASCHKLSH->TRAN_TIME));
    MEMCPY_AN(MBASCHKLSH_N->TRAN_USER_ID, MBASCHKLSH->TRAN_USER_ID, sizeof(MBASCHKLSH->TRAN_USER_ID));
    MBASCHKLSH_N->COMPLETE_FLAG[0] = MBASCHKLSH->COMPLETE_FLAG;
    MEMCPY_AN(MBASCHKLSH_N->COMPLETE_TIME, MBASCHKLSH->COMPLETE_TIME, sizeof(MBASCHKLSH->COMPLETE_TIME));
    MEMCPY_AN(MBASCHKLSH_N->COMPLETE_USER_ID, MBASCHKLSH->COMPLETE_USER_ID, sizeof(MBASCHKLSH->COMPLETE_USER_ID));
    MBASCHKLSH_N->DELETE_FLAG[0] = MBASCHKLSH->DELETE_FLAG;
    MEMCPY_AN(MBASCHKLSH_N->DELETE_TIME, MBASCHKLSH->DELETE_TIME, sizeof(MBASCHKLSH->DELETE_TIME));
    MEMCPY_AN(MBASCHKLSH_N->DELETE_USER_ID, MBASCHKLSH->DELETE_USER_ID, sizeof(MBASCHKLSH->DELETE_USER_ID));
    MEMCPY_AN(MBASCHKLSH_N->BASE_OBJ_ID, MBASCHKLSH->BASE_OBJ_ID, sizeof(MBASCHKLSH->BASE_OBJ_ID));
    MBASCHKLSH_N->BASE_OBJ_HIST_SEQ = MBASCHKLSH->BASE_OBJ_HIST_SEQ;
    MEMCPY_AN(MBASCHKLSH_N->KEY_1_VALUE, MBASCHKLSH->KEY_1_VALUE, sizeof(MBASCHKLSH->KEY_1_VALUE));
    MEMCPY_AN(MBASCHKLSH_N->KEY_2_VALUE, MBASCHKLSH->KEY_2_VALUE, sizeof(MBASCHKLSH->KEY_2_VALUE));
    MEMCPY_AN(MBASCHKLSH_N->KEY_3_VALUE, MBASCHKLSH->KEY_3_VALUE, sizeof(MBASCHKLSH->KEY_3_VALUE));
    MEMCPY_AN(MBASCHKLSH_N->KEY_4_VALUE, MBASCHKLSH->KEY_4_VALUE, sizeof(MBASCHKLSH->KEY_4_VALUE));
    MEMCPY_AN(MBASCHKLSH_N->KEY_5_VALUE, MBASCHKLSH->KEY_5_VALUE, sizeof(MBASCHKLSH->KEY_5_VALUE));
    MEMCPY_AN(MBASCHKLSH_N->KEY_6_VALUE, MBASCHKLSH->KEY_6_VALUE, sizeof(MBASCHKLSH->KEY_6_VALUE));
    MEMCPY_AN(MBASCHKLSH_N->KEY_7_VALUE, MBASCHKLSH->KEY_7_VALUE, sizeof(MBASCHKLSH->KEY_7_VALUE));
    MEMCPY_AN(MBASCHKLSH_N->KEY_8_VALUE, MBASCHKLSH->KEY_8_VALUE, sizeof(MBASCHKLSH->KEY_8_VALUE));
    MEMCPY_AN(MBASCHKLSH_N->KEY_9_VALUE, MBASCHKLSH->KEY_9_VALUE, sizeof(MBASCHKLSH->KEY_9_VALUE));
    MEMCPY_AN(MBASCHKLSH_N->KEY_10_VALUE, MBASCHKLSH->KEY_10_VALUE, sizeof(MBASCHKLSH->KEY_10_VALUE));
}


/* Del Null Function */
void DBC_del_null_mbaschklsh(struct MBASCHKLSH_N_TAG *MBASCHKLSH_N, struct MBASCHKLSH_TAG *MBASCHKLSH)
{
    MEMCPY_DN(MBASCHKLSH->CREATE_USER_ID, MBASCHKLSH_N->CREATE_USER_ID, sizeof(MBASCHKLSH->CREATE_USER_ID));
    MEMCPY_DN(MBASCHKLSH->CREATE_TIME, MBASCHKLSH_N->CREATE_TIME, sizeof(MBASCHKLSH->CREATE_TIME));
