    MEMCPY_DN(MBASCHKLSH->DELETE_USER_ID, MBASCHKLSH_N->DELETE_USER_ID, sizeof(MBASCHKLSH->DELETE_USER_ID));
    MEMCPY_DN(MBASCHKLSH->BASE_OBJ_ID, MBASCHKLSH_N->BASE_OBJ_ID, sizeof(MBASCHKLSH->BASE_OBJ_ID));
