/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mbaschklsh(int sel_type, struct MBASCHKLSH_TAG *MBASCHKLSH)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBASCHKLSH_N_TAG MBASCHKLSH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbaschklsh(&MBASCHKLSH_N, MBASCHKLSH);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MBASCHKLSH_CUR_1 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    CHKLIST_ID,
                    REL_KEY,
                    HIST_SEQ,
                    TRAN_TIME,
                    TRAN_USER_ID,
                    COMPLETE_FLAG,
                    COMPLETE_TIME,
                    COMPLETE_USER_ID,
                    DELETE_FLAG,
                    DELETE_TIME,
                    DELETE_USER_ID,
                    BASE_OBJ_ID,
                    BASE_OBJ_HIST_SEQ,
                    KEY_1_VALUE,
                    KEY_2_VALUE,
                    KEY_3_VALUE,
                    KEY_4_VALUE,
                    KEY_5_VALUE,
                    KEY_6_VALUE,
                    KEY_7_VALUE,
                    KEY_8_VALUE,
                    KEY_9_VALUE,
                    KEY_10_VALUE
                FROM MBASCHKLSH
                ORDER BY FACTORY ASC,
                    CHKLIST_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MBASCHKLSH_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MBASCHKLSH_CUR_2 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    CHKLIST_ID,
                    REL_KEY,
                    HIST_SEQ,
                    TRAN_TIME,
                    TRAN_USER_ID,
                    COMPLETE_FLAG,
                    COMPLETE_TIME,
                    COMPLETE_USER_ID,
                    DELETE_FLAG,
                    DELETE_TIME,
                    DELETE_USER_ID,
                    BASE_OBJ_ID,
                    BASE_OBJ_HIST_SEQ,
                    KEY_1_VALUE,
                    KEY_2_VALUE,
                    KEY_3_VALUE,
                    KEY_4_VALUE,
                    KEY_5_VALUE,
                    KEY_6_VALUE,
                    KEY_7_VALUE,
                    KEY_8_VALUE,
                    KEY_9_VALUE,
                    KEY_10_VALUE
                FROM MBASCHKLSH
                WHERE FACTORY = :MBASCHKLSH_N.FACTORY
                AND CHKLIST_ID = :MBASCHKLSH_N.CHKLIST_ID
                AND BASE_OBJ_ID LIKE :MBASCHKLSH_N.BASE_OBJ_ID
                AND DELETE_FLAG LIKE :MBASCHKLSH_N.DELETE_FLAG
                AND CREATE_TIME >= :DBC_Q_COND_N.FROM_TIME
                AND CREATE_TIME < :DBC_Q_COND_N.TO_TIME
                AND HIST_SEQ <= :MBASCHKLSH_N.HIST_SEQ
                ORDER BY HIST_SEQ DESC;
            EXEC SQL OPEN DBC_MBASCHKLSH_CUR_2;
            break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mbaschklsh", sel_type);
}


