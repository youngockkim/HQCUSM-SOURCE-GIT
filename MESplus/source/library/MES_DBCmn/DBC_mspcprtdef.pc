                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                FROM MSPCPRTDEF
                ORDER BY FACTORY ASC,
                    CHART_ID ASC;
            EXEC SQL OPEN DBC_MSPCPRTDEF_CUR_1;
            break;


        default:
            DB_error_code = 9999;
