                WHERE WC.FACTORY = MC.FACTORY    
                  AND WC.COL_SET_ID = MC.COL_SET_ID
                  AND WC.FACTORY = :MWIPCOLDEF_N.FACTORY               
                  AND MAT_ID = :MWIPCOLDEF_N.MAT_ID
                  AND MAT_VER = :MWIPCOLDEF_N.MAT_VER
                  AND WC.FLOW = :MWIPCOLDEF_N.FLOW                  
                  AND WC.OPER = :MWIPCOLDEF_N.OPER                  
