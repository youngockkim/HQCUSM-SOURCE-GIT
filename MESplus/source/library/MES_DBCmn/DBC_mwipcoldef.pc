                         WC.UPDATE_TIME
                INTO 
                    :MWIPCOLDEF_N.FACTORY,
                    :MWIPCOLDEF_N.MAT_ID,
                    :MWIPCOLDEF_N.MAT_VER,
                    :MWIPCOLDEF_N.FLOW,
                    :MWIPCOLDEF_N.OPER,
