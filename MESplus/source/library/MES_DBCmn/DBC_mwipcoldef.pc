/* SQL CURSOR CLOSE Function */
void DBC_close_mwipcoldef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPCOLDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWIPCOLDEF_CUR_2;
            break;
            
        case 3:
            EXEC SQL CLOSE DBC_MWIPCOLDEF_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MWIPCOLDEF_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MWIPCOLDEF_CUR_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipcoldef", sel_type);
}


/* Initialize Function */
void DBC_init_mwipcoldef(struct MWIPCOLDEF_TAG *MWIPCOLDEF)
{
    /* memset by Space */
    memset(MWIPCOLDEF, ' ', sizeof(struct MWIPCOLDEF_TAG));
    
    MWIPCOLDEF->MAT_VER = 0;
}


/* Add Null Function */
void DBC_add_null_mwipcoldef(struct MWIPCOLDEF_N_TAG *MWIPCOLDEF_N, struct MWIPCOLDEF_TAG *MWIPCOLDEF)
{
    /* memset by NULL */
    memset(MWIPCOLDEF_N, '\0', sizeof(struct MWIPCOLDEF_N_TAG));
    
    MEMCPY_AN(MWIPCOLDEF_N->FACTORY, MWIPCOLDEF->FACTORY, sizeof(MWIPCOLDEF->FACTORY));
    MEMCPY_AN(MWIPCOLDEF_N->MAT_ID, MWIPCOLDEF->MAT_ID, sizeof(MWIPCOLDEF->MAT_ID));
    MWIPCOLDEF_N->MAT_VER = MWIPCOLDEF->MAT_VER;
    MEMCPY_AN(MWIPCOLDEF_N->FLOW, MWIPCOLDEF->FLOW, sizeof(MWIPCOLDEF->FLOW));
    MEMCPY_AN(MWIPCOLDEF_N->OPER, MWIPCOLDEF->OPER, sizeof(MWIPCOLDEF->OPER));
    MWIPCOLDEF_N->OPT_LEVEL[0] = MWIPCOLDEF->OPT_LEVEL;
    MEMCPY_AN(MWIPCOLDEF_N->COL_SET_ID, MWIPCOLDEF->COL_SET_ID, sizeof(MWIPCOLDEF->COL_SET_ID));
    MWIPCOLDEF_N->COLLECTION_MODE[0] = MWIPCOLDEF->COLLECTION_MODE;
    MWIPCOLDEF_N->DEFAULT_FLAG[0] = MWIPCOLDEF->DEFAULT_FLAG;
    MWIPCOLDEF_N->DISABLE_FLAG[0] = MWIPCOLDEF->DISABLE_FLAG;
    MEMCPY_AN(MWIPCOLDEF_N->CREATE_USER_ID, MWIPCOLDEF->CREATE_USER_ID, sizeof(MWIPCOLDEF->CREATE_USER_ID));
    MEMCPY_AN(MWIPCOLDEF_N->CREATE_TIME, MWIPCOLDEF->CREATE_TIME, sizeof(MWIPCOLDEF->CREATE_TIME));
    MEMCPY_AN(MWIPCOLDEF_N->UPDATE_USER_ID, MWIPCOLDEF->UPDATE_USER_ID, sizeof(MWIPCOLDEF->UPDATE_USER_ID));
    MEMCPY_AN(MWIPCOLDEF_N->UPDATE_TIME, MWIPCOLDEF->UPDATE_TIME, sizeof(MWIPCOLDEF->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mwipcoldef(struct MWIPCOLDEF_N_TAG *MWIPCOLDEF_N, struct MWIPCOLDEF_TAG *MWIPCOLDEF)
{
    MEMCPY_DN(MWIPCOLDEF->FACTORY, MWIPCOLDEF_N->FACTORY, sizeof(MWIPCOLDEF->FACTORY));
    MEMCPY_DN(MWIPCOLDEF->MAT_ID, MWIPCOLDEF_N->MAT_ID, sizeof(MWIPCOLDEF->MAT_ID));
    MWIPCOLDEF->MAT_VER = MWIPCOLDEF_N->MAT_VER;
    MEMCPY_DN(MWIPCOLDEF->FLOW, MWIPCOLDEF_N->FLOW, sizeof(MWIPCOLDEF->FLOW));
    MEMCPY_DN(MWIPCOLDEF->OPER, MWIPCOLDEF_N->OPER, sizeof(MWIPCOLDEF->OPER));
    MWIPCOLDEF->OPT_LEVEL = MWIPCOLDEF_N->OPT_LEVEL[0];
    MEMCPY_DN(MWIPCOLDEF->COL_SET_ID, MWIPCOLDEF_N->COL_SET_ID, sizeof(MWIPCOLDEF->COL_SET_ID));
    MWIPCOLDEF->COLLECTION_MODE = MWIPCOLDEF_N->COLLECTION_MODE[0];
    MWIPCOLDEF->DEFAULT_FLAG = MWIPCOLDEF_N->DEFAULT_FLAG[0];
    MWIPCOLDEF->DISABLE_FLAG = MWIPCOLDEF_N->DISABLE_FLAG[0];
    MEMCPY_DN(MWIPCOLDEF->CREATE_USER_ID, MWIPCOLDEF_N->CREATE_USER_ID, sizeof(MWIPCOLDEF->CREATE_USER_ID));
    MEMCPY_DN(MWIPCOLDEF->CREATE_TIME, MWIPCOLDEF_N->CREATE_TIME, sizeof(MWIPCOLDEF->CREATE_TIME));
    MEMCPY_DN(MWIPCOLDEF->UPDATE_USER_ID, MWIPCOLDEF_N->UPDATE_USER_ID, sizeof(MWIPCOLDEF->UPDATE_USER_ID));
    MEMCPY_DN(MWIPCOLDEF->UPDATE_TIME, MWIPCOLDEF_N->UPDATE_TIME, sizeof(MWIPCOLDEF->UPDATE_TIME));
}


