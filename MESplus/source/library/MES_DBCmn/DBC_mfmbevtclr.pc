/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mfmbevtclr(int sel_type, struct MFMBEVTCLR_TAG *MFMBEVTCLR)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MFMBEVTCLR_N_TAG MFMBEVTCLR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mfmbevtclr(&MFMBEVTCLR_N, MFMBEVTCLR);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MFMBEVTCLR_CUR_1 CURSOR FOR
                SELECT A.EVENT_ID, NVL(B.RES_TYPE, ' '), NVL(B.COLOR, 0) FROM
                    (SELECT * FROM MRASEVNDEF 
                    WHERE FACTORY =  :MFMBEVTCLR_N.FACTORY) A,                
                    (SELECT * FROM MFMBEVTCLR
                    WHERE FACTORY = :MFMBEVTCLR_N.FACTORY
                    AND RES_TYPE = :MFMBEVTCLR_N.RES_TYPE) B
                    WHERE A.FACTORY = B.FACTORY(+)
                        AND A.EVENT_ID = B.EVENT_ID(+) 
                        AND A.EVENT_ID >= :MFMBEVTCLR_N.EVENT_ID
                ORDER BY A.EVENT_ID ASC;
            EXEC SQL OPEN DBC_MFMBEVTCLR_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MFMBEVTCLR_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_TYPE,
                    EVENT_ID,
                    COLOR,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MFMBEVTCLR
                WHERE FACTORY = :MFMBEVTCLR_N.FACTORY
                    AND EVENT_ID >= :MFMBEVTCLR_N.EVENT_ID
                ORDER BY RES_TYPE, EVENT_ID ASC;
            EXEC SQL OPEN DBC_MFMBEVTCLR_CUR_2;
            break;
            
        case 3:
            EXEC SQL DECLARE DBC_MFMBEVTCLR_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_TYPE,
                    EVENT_ID,
                    COLOR,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MFMBEVTCLR
                WHERE FACTORY = :MFMBEVTCLR_N.FACTORY
                    AND RES_TYPE = :MFMBEVTCLR_N.RES_TYPE
                    AND EVENT_ID >= :MFMBEVTCLR_N.EVENT_ID
                    AND EVENT_ID NOT IN(SELECT EVENT_ID FROM MRASEVNDEF WHERE FACTORY = :MFMBEVTCLR_N.FACTORY)
                ORDER BY EVENT_ID ASC;
            EXEC SQL OPEN DBC_MFMBEVTCLR_CUR_3;
            break;
            
        case 4:
            EXEC SQL DECLARE DBC_MFMBEVTCLR_CUR_4 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_TYPE,
                    EVENT_ID,
                    COLOR,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MFMBEVTCLR
                WHERE FACTORY = :MFMBEVTCLR_N.FACTORY
                    AND RES_TYPE = :MFMBEVTCLR_N.RES_TYPE
                    AND EVENT_ID >= :MFMBEVTCLR_N.EVENT_ID
                    ORDER BY EVENT_ID ASC;
            EXEC SQL OPEN DBC_MFMBEVTCLR_CUR_4;
            break;   
            
       case 5:
            EXEC SQL DECLARE DBC_MFMBEVTCLR_CUR_5 CURSOR FOR
                SELECT A.TOOL_EVENT_ID, NVL(B.RES_TYPE, ' '), NVL(B.COLOR, 0) FROM
                    (SELECT  DISTINCT FACTORY, TOOL_EVENT_ID  FROM MRASTEVDEF
                    WHERE FACTORY =  :MFMBEVTCLR_N.FACTORY) A,                
                    (SELECT * FROM MFMBEVTCLR
                    WHERE FACTORY = :MFMBEVTCLR_N.FACTORY
                    AND RES_TYPE = :MFMBEVTCLR_N.RES_TYPE) B
                    WHERE A.FACTORY = B.FACTORY(+)
                        AND A.TOOL_EVENT_ID = B.EVENT_ID(+) 
                        AND A.TOOL_EVENT_ID >= :MFMBEVTCLR_N.EVENT_ID
                ORDER BY A.TOOL_EVENT_ID ASC;
            EXEC SQL OPEN DBC_MFMBEVTCLR_CUR_5;
            break; 
            
       case 6:
            EXEC SQL DECLARE DBC_MFMBEVTCLR_CUR_6 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_TYPE,
                    EVENT_ID,
                    COLOR,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MFMBEVTCLR
                WHERE FACTORY = :MFMBEVTCLR_N.FACTORY
                    AND RES_TYPE = :MFMBEVTCLR_N.RES_TYPE
                    AND EVENT_ID >= :MFMBEVTCLR_N.EVENT_ID
                    AND EVENT_ID NOT IN(SELECT TOOL_EVENT_ID FROM MRASTEVDEF WHERE FACTORY = :MFMBEVTCLR_N.FACTORY)
                ORDER BY EVENT_ID ASC;
            EXEC SQL OPEN DBC_MFMBEVTCLR_CUR_6;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mfmbevtclr", sel_type);
}


