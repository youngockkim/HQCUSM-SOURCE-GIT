    MEMCPY_DN(MFMBEVTCLR->CREATE_TIME, MFMBEVTCLR_N->CREATE_TIME, sizeof(MFMBEVTCLR->CREATE_TIME));
    MEMCPY_DN(MFMBEVTCLR->UPDATE_USER_ID, MFMBEVTCLR_N->UPDATE_USER_ID, sizeof(MFMBEVTCLR->UPDATE_USER_ID));
