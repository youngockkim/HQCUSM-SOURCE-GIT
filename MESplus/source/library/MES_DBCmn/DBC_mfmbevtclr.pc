/* Add Null Function */
void DBC_add_null_mfmbevtclr(struct MFMBEVTCLR_N_TAG *MFMBEVTCLR_N, struct MFMBEVTCLR_TAG *MFMBEVTCLR)
{
    /* memset by NULL */
    memset(MFMBEVTCLR_N, '\0', sizeof(struct MFMBEVTCLR_N_TAG));
    
    MEMCPY_AN(MFMBEVTCLR_N->FACTORY, MFMBEVTCLR->FACTORY, sizeof(MFMBEVTCLR->FACTORY));
    MEMCPY_AN(MFMBEVTCLR_N->RES_TYPE, MFMBEVTCLR->RES_TYPE, sizeof(MFMBEVTCLR->RES_TYPE));
    MEMCPY_AN(MFMBEVTCLR_N->EVENT_ID, MFMBEVTCLR->EVENT_ID, sizeof(MFMBEVTCLR->EVENT_ID));
    MFMBEVTCLR_N->COLOR = MFMBEVTCLR->COLOR;
    MEMCPY_AN(MFMBEVTCLR_N->CREATE_USER_ID, MFMBEVTCLR->CREATE_USER_ID, sizeof(MFMBEVTCLR->CREATE_USER_ID));
    MEMCPY_AN(MFMBEVTCLR_N->CREATE_TIME, MFMBEVTCLR->CREATE_TIME, sizeof(MFMBEVTCLR->CREATE_TIME));
    MEMCPY_AN(MFMBEVTCLR_N->UPDATE_USER_ID, MFMBEVTCLR->UPDATE_USER_ID, sizeof(MFMBEVTCLR->UPDATE_USER_ID));
    MEMCPY_AN(MFMBEVTCLR_N->UPDATE_TIME, MFMBEVTCLR->UPDATE_TIME, sizeof(MFMBEVTCLR->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mfmbevtclr(struct MFMBEVTCLR_N_TAG *MFMBEVTCLR_N, struct MFMBEVTCLR_TAG *MFMBEVTCLR)
{
