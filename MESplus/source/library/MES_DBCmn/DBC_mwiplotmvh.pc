/* Add Null Function */
void DBC_add_null_mwiplotmvh(struct MWIPLOTMVH_N_TAG *MWIPLOTMVH_N, struct MWIPLOTMVH_TAG *MWIPLOTMVH)
{
    /* memset by NULL */
    memset(MWIPLOTMVH_N, '\0', sizeof(struct MWIPLOTMVH_N_TAG));
    
    MEMCPY_AN(MWIPLOTMVH_N->LOT_ID, MWIPLOTMVH->LOT_ID, sizeof(MWIPLOTMVH->LOT_ID));
    MWIPLOTMVH_N->HIST_SEQ = MWIPLOTMVH->HIST_SEQ;
    MEMCPY_AN(MWIPLOTMVH_N->TRAN_TIME, MWIPLOTMVH->TRAN_TIME, sizeof(MWIPLOTMVH->TRAN_TIME));
    MEMCPY_AN(MWIPLOTMVH_N->TRAN_CODE, MWIPLOTMVH->TRAN_CODE, sizeof(MWIPLOTMVH->TRAN_CODE));
    MWIPLOTMVH_N->HIST_DEL_FLAG[0] = MWIPLOTMVH->HIST_DEL_FLAG;
    MEMCPY_AN(MWIPLOTMVH_N->FACTORY, MWIPLOTMVH->FACTORY, sizeof(MWIPLOTMVH->FACTORY));
    MEMCPY_AN(MWIPLOTMVH_N->MAT_ID, MWIPLOTMVH->MAT_ID, sizeof(MWIPLOTMVH->MAT_ID));
    MWIPLOTMVH_N->MAT_VER = MWIPLOTMVH->MAT_VER;
    MEMCPY_AN(MWIPLOTMVH_N->FLOW, MWIPLOTMVH->FLOW, sizeof(MWIPLOTMVH->FLOW));
    MWIPLOTMVH_N->FLOW_SEQ_NUM = MWIPLOTMVH->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPLOTMVH_N->OPER, MWIPLOTMVH->OPER, sizeof(MWIPLOTMVH->OPER));
    MEMCPY_AN(MWIPLOTMVH_N->START_TIME, MWIPLOTMVH->START_TIME, sizeof(MWIPLOTMVH->START_TIME));
    MEMCPY_AN(MWIPLOTMVH_N->END_TIME, MWIPLOTMVH->END_TIME, sizeof(MWIPLOTMVH->END_TIME));
    MEMCPY_AN(MWIPLOTMVH_N->OPER_IN_TIME, MWIPLOTMVH->OPER_IN_TIME, sizeof(MWIPLOTMVH->OPER_IN_TIME));
    MWIPLOTMVH_N->QUEUE_TIME = MWIPLOTMVH->QUEUE_TIME;
    MWIPLOTMVH_N->PROC_TIME = MWIPLOTMVH->PROC_TIME;
    MWIPLOTMVH_N->TOTAL_TIME = MWIPLOTMVH->TOTAL_TIME;
