void DBC_del_null_mwiplotmvh(struct MWIPLOTMVH_N_TAG *MWIPLOTMVH_N, struct MWIPLOTMVH_TAG *MWIPLOTMVH)
{
    MEMCPY_DN(MWIPLOTMVH->LOT_ID, MWIPLOTMVH_N->LOT_ID, sizeof(MWIPLOTMVH->LOT_ID));
    MWIPLOTMVH->HIST_SEQ = MWIPLOTMVH_N->HIST_SEQ;
    MEMCPY_DN(MWIPLOTMVH->TRAN_TIME, MWIPLOTMVH_N->TRAN_TIME, sizeof(MWIPLOTMVH->TRAN_TIME));
    MEMCPY_DN(MWIPLOTMVH->TRAN_CODE, MWIPLOTMVH_N->TRAN_CODE, sizeof(MWIPLOTMVH->TRAN_CODE));
    MWIPLOTMVH->HIST_DEL_FLAG = MWIPLOTMVH_N->HIST_DEL_FLAG[0];
    MEMCPY_DN(MWIPLOTMVH->FACTORY, MWIPLOTMVH_N->FACTORY, sizeof(MWIPLOTMVH->FACTORY));
    MEMCPY_DN(MWIPLOTMVH->MAT_ID, MWIPLOTMVH_N->MAT_ID, sizeof(MWIPLOTMVH->MAT_ID));
    MWIPLOTMVH->MAT_VER = MWIPLOTMVH_N->MAT_VER;
    MEMCPY_DN(MWIPLOTMVH->FLOW, MWIPLOTMVH_N->FLOW, sizeof(MWIPLOTMVH->FLOW));
    MWIPLOTMVH->FLOW_SEQ_NUM = MWIPLOTMVH_N->FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPLOTMVH->OPER, MWIPLOTMVH_N->OPER, sizeof(MWIPLOTMVH->OPER));
    MEMCPY_DN(MWIPLOTMVH->START_TIME, MWIPLOTMVH_N->START_TIME, sizeof(MWIPLOTMVH->START_TIME));
    MEMCPY_DN(MWIPLOTMVH->END_TIME, MWIPLOTMVH_N->END_TIME, sizeof(MWIPLOTMVH->END_TIME));
    MEMCPY_DN(MWIPLOTMVH->OPER_IN_TIME, MWIPLOTMVH_N->OPER_IN_TIME, sizeof(MWIPLOTMVH->OPER_IN_TIME));
    MWIPLOTMVH->QUEUE_TIME = MWIPLOTMVH_N->QUEUE_TIME;
    MWIPLOTMVH->PROC_TIME = MWIPLOTMVH_N->PROC_TIME;
    MWIPLOTMVH->TOTAL_TIME = MWIPLOTMVH_N->TOTAL_TIME;
}


