                    AND PRU.USER_ID = :MATRNAMDEF_N.CREATE_USER_ID
                    AND PRD.FACTORY = PRU.FACTORY
                    AND PRD.PRV_GRP_ID = PRU.PRV_GRP_ID
                    AND PRD.PRV_TYPE = 'ATTRIBUTE'
                    AND ATR.FACTORY = PRD.FACTORY
                    AND ATR.ATTR_NAME = PRD.PRV_ITEM1
