    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mspcalmhis(&MSPCALMHIS_N, MSPCALMHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSPCALMHIS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    ALARM_ID,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    LOT_ID,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    PROC_OPER,
                    RES_ID,
                    PROC_RES_ID,
                    EVENT_ID,
                    CHAR_ID,
                    UNIT_ID,
                    UNIT_SEQ,
                    XR_FLAG,
                    OOC_TYPE,
                    ALARM_LEVEL_FLAG,
                    ALARM_MSG,
                    ACK_FLAG,
                    ACK_TIME,
                    ACK_USER_ID,
                    CLEAR_FLAG,
                    CLEAR_TIME,
                    CLEAR_USER_ID,
                    CLEAR_COMMENT,
                    USER_ID
                FROM MSPCALMHIS
                ORDER BY FACTORY ASC,
                    CHART_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MSPCALMHIS_CUR_1;
            break;

        case 2:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N); 
            EXEC SQL DECLARE DBC_MSPCALMHIS_CUR_2 CURSOR FOR
                SELECT
                           A.FACTORY,
                           A.CHART_ID,
                           A.HIST_SEQ,
                           A.ALARM_ID,
                           A.TRAN_TIME,
                           A.LOT_RES_FLAG,
                           A.LOT_ID,
                           A.MAT_ID,
                           A.MAT_VER,
                           A.FLOW,
                           A.FLOW_SEQ_NUM,
                           A.OPER,
                           A.PROC_OPER,
                           A.RES_ID,
                           A.PROC_RES_ID,
                           A.EVENT_ID,
                           A.CHAR_ID,
                           A.UNIT_ID,
                           A.UNIT_SEQ,
                           A.XR_FLAG,
                           A.OOC_TYPE,
                           A.ALARM_LEVEL_FLAG,
                           A.ALARM_MSG,
                           A.ACK_FLAG,
                           A.ACK_TIME,
                           A.ACK_USER_ID,
                           A.CLEAR_FLAG,
                           A.CLEAR_TIME,
                           A.CLEAR_USER_ID,
                           A.CLEAR_COMMENT,
                           A.USER_ID
                FROM MSPCALMHIS A, MSPCCHTDEF B
                WHERE A.FACTORY = :MSPCALMHIS_N.FACTORY
                    AND A.FACTORY = B.FACTORY
                    AND A.CHART_ID = B.CHART_ID
                    AND B.DELETE_FLAG <> :MSPCALMHIS_N.ACK_FLAG
                    AND ((A.CHART_ID > :MSPCALMHIS_N.CHART_ID) OR (A.CHART_ID = :MSPCALMHIS_N.CHART_ID AND A.HIST_SEQ <= :MSPCALMHIS_N.HIST_SEQ))
                    AND A.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME 
                    AND A.TRAN_TIME < :DBC_Q_COND_N.TO_TIME
                ORDER BY A.CHART_ID ASC, A.HIST_SEQ DESC;
            EXEC SQL OPEN DBC_MSPCALMHIS_CUR_2;                 
            break;
            
            
        case 3:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N); 
            EXEC SQL DECLARE DBC_MSPCALMHIS_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    HIST_SEQ,
                    ALARM_ID,
                    TRAN_TIME,
                    LOT_RES_FLAG,
                    LOT_ID,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    PROC_OPER,
                    RES_ID,
                    PROC_RES_ID,
                    EVENT_ID,
