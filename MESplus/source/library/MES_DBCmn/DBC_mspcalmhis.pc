                    ACK_USER_ID,
                    CLEAR_FLAG,
                    CLEAR_TIME,
                    CLEAR_USER_ID,
                    CLEAR_COMMENT,
                    USER_ID
                FROM MSPCALMHIS
                WHERE FACTORY = :MSPCALMHIS_N.FACTORY
                    AND CHART_ID = :MSPCALMHIS_N.CHART_ID
                    AND HIST_SEQ <= :MSPCALMHIS_N.HIST_SEQ
                    AND TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME 
                    AND TRAN_TIME < :DBC_Q_COND_N.TO_TIME
                ORDER BY HIST_SEQ DESC;
            EXEC SQL OPEN DBC_MSPCALMHIS_CUR_3;                 
            break;
            
        case 4:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N); 
            EXEC SQL DECLARE DBC_MSPCALMHIS_CUR_4 CURSOR FOR
                SELECT
                           A.FACTORY,
                           A.CHART_ID,
                           A.HIST_SEQ,
                           A.ALARM_ID,
                           A.TRAN_TIME,
                           A.LOT_RES_FLAG,
                           A.LOT_ID,
                           A.MAT_ID,
                           A.MAT_VER,
                           A.FLOW,
                           A.FLOW_SEQ_NUM,
                           A.OPER,
                           A.PROC_OPER,
                           A.RES_ID,
                           A.PROC_RES_ID,
                           A.EVENT_ID,
                           A.CHAR_ID,
                           A.UNIT_ID,
                           A.UNIT_SEQ,
                           A.XR_FLAG,
                           A.OOC_TYPE,
                           A.ALARM_LEVEL_FLAG,
                           A.ALARM_MSG,
                           A.ACK_FLAG,
                           A.ACK_TIME,
                           A.ACK_USER_ID,
                           A.CLEAR_FLAG,
                           A.CLEAR_TIME,
                           A.CLEAR_USER_ID,
                           A.CLEAR_COMMENT,
                           A.USER_ID
                FROM MSPCALMHIS A, MSPCCHTDEF B
                WHERE A.FACTORY = :MSPCALMHIS_N.FACTORY
                    AND A.FACTORY = B.FACTORY
                    AND A.CHART_ID = B.CHART_ID
                    AND A.CHART_ID IN (SELECT CHART_ID FROM MSPCCHTSET WHERE FACTORY = :MSPCALMHIS_N.FACTORY AND CHART_SET_ID = :DBC_Q_COND_N.KEY_1 AND CHART_ID >= :MSPCALMHIS_N.CHART_ID)
                    AND B.DELETE_FLAG <> :MSPCALMHIS_N.ACK_FLAG
                    AND ((A.CHART_ID > :MSPCALMHIS_N.CHART_ID) OR (A.CHART_ID = :MSPCALMHIS_N.CHART_ID AND A.HIST_SEQ <= :MSPCALMHIS_N.HIST_SEQ))
                    AND A.TRAN_TIME >= :DBC_Q_COND_N.FROM_TIME 
                    AND A.TRAN_TIME < :DBC_Q_COND_N.TO_TIME
                ORDER BY A.CHART_ID ASC, A.HIST_SEQ DESC;
            EXEC SQL OPEN DBC_MSPCALMHIS_CUR_4;                 
