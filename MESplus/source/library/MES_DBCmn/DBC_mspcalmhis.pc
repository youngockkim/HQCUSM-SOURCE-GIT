/* SQL CURSOR CLOSE Function */
void DBC_close_mspcalmhis(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MSPCALMHIS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MSPCALMHIS_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MSPCALMHIS_CUR_3;
            break;
            
        case 4:
            EXEC SQL CLOSE DBC_MSPCALMHIS_CUR_4;
            break;    


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mspcalmhis", sel_type);
}


/* Initialize Function */
void DBC_init_mspcalmhis(struct MSPCALMHIS_TAG *MSPCALMHIS)
{
    /* memset by Space */
    memset(MSPCALMHIS, ' ', sizeof(struct MSPCALMHIS_TAG));
    
    MSPCALMHIS->HIST_SEQ = 0;
    MSPCALMHIS->MAT_VER = 0;
    MSPCALMHIS->FLOW_SEQ_NUM = 0;
    MSPCALMHIS->UNIT_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mspcalmhis(struct MSPCALMHIS_N_TAG *MSPCALMHIS_N, struct MSPCALMHIS_TAG *MSPCALMHIS)
{
    /* memset by NULL */
    memset(MSPCALMHIS_N, '\0', sizeof(struct MSPCALMHIS_N_TAG));
    
    MEMCPY_AN(MSPCALMHIS_N->FACTORY, MSPCALMHIS->FACTORY, sizeof(MSPCALMHIS->FACTORY));
    MEMCPY_AN(MSPCALMHIS_N->CHART_ID, MSPCALMHIS->CHART_ID, sizeof(MSPCALMHIS->CHART_ID));
    MSPCALMHIS_N->HIST_SEQ = MSPCALMHIS->HIST_SEQ;
