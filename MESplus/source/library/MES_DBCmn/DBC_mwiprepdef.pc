        struct MWIPREPDEF_N_TAG MWIPREPDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiprepdef(&MWIPREPDEF_N, MWIPREPDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPREPDEF_CUR_1 CURSOR FOR
                SELECT REP_OPER, RET_OPER 
                FROM MWIPREPDEF
                WHERE FACTORY = :MWIPREPDEF_N.FACTORY
                    AND OPER = :MWIPREPDEF_N.OPER
                    AND REP_OPER >= :MWIPREPDEF_N.REP_OPER
                ORDER BY REP_OPER ASC;
            EXEC SQL OPEN DBC_MWIPREPDEF_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MWIPREPDEF_CUR_2 CURSOR FOR
                SELECT REP_OPER, RET_OPER 
                FROM MWIPREPDEF
                WHERE FACTORY = :MWIPREPDEF_N.FACTORY
                    AND OPER = :MWIPREPDEF_N.OPER
                    AND REP_OPER = :MWIPREPDEF_N.REP_OPER
                ORDER BY REP_OPER ASC;
            EXEC SQL OPEN DBC_MWIPREPDEF_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MWIPREPDEF_CUR_3 CURSOR FOR
                SELECT FACTORY,
                       OPER,
                       REP_OPER,
                       RET_OPER,
                       CREATE_USER_ID,
                       CREATE_TIME,
                       UPDATE_USER_ID,
                       UPDATE_TIME
                FROM MWIPREPDEF
                WHERE FACTORY = :MWIPREPDEF_N.FACTORY
                    AND OPER = :MWIPREPDEF_N.OPER
                ORDER BY REP_OPER ASC;
            EXEC SQL OPEN DBC_MWIPREPDEF_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwiprepdef", sel_type);
}


