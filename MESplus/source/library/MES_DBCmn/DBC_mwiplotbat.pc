        struct MWIPLOTBAT_N_TAG MWIPLOTBAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplotbat(&MWIPLOTBAT_N, MWIPLOTBAT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT 
                         LOT_ID,
                         HIST_SEQ,
                         TRAN_CODE,
                         TRAN_TIME,
                         HIST_DEL_FLAG,
                         FACTORY,
                         MAT_ID,
                         MAT_VER,
                         FLOW,
                         FLOW_SEQ_NUM,
                         OPER,
                         RES_ID,
                         BATCH_ID,
                         BATCH_SEQ
                INTO 
                    :MWIPLOTBAT_N.LOT_ID,
                    :MWIPLOTBAT_N.HIST_SEQ,
                    :MWIPLOTBAT_N.TRAN_CODE,
                    :MWIPLOTBAT_N.TRAN_TIME,
                    :MWIPLOTBAT_N.HIST_DEL_FLAG,
                    :MWIPLOTBAT_N.FACTORY,
                    :MWIPLOTBAT_N.MAT_ID,
                    :MWIPLOTBAT_N.MAT_VER,
                    :MWIPLOTBAT_N.FLOW,
                    :MWIPLOTBAT_N.FLOW_SEQ_NUM,
                    :MWIPLOTBAT_N.OPER,
                    :MWIPLOTBAT_N.RES_ID,
                    :MWIPLOTBAT_N.BATCH_ID,
                    :MWIPLOTBAT_N.BATCH_SEQ
                FROM MWIPLOTBAT
                WHERE LOT_ID = :MWIPLOTBAT_N.LOT_ID
                    AND HIST_SEQ = :MWIPLOTBAT_N.HIST_SEQ;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
