    MWIPLOTBAT->FLOW_SEQ_NUM = 0;
    MWIPLOTBAT->BATCH_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mwiplotbat(struct MWIPLOTBAT_N_TAG *MWIPLOTBAT_N, struct MWIPLOTBAT_TAG *MWIPLOTBAT)
{
    /* memset by NULL */
    memset(MWIPLOTBAT_N, '\0', sizeof(struct MWIPLOTBAT_N_TAG));
    
    MEMCPY_AN(MWIPLOTBAT_N->LOT_ID, MWIPLOTBAT->LOT_ID, sizeof(MWIPLOTBAT->LOT_ID));
    MWIPLOTBAT_N->HIST_SEQ = MWIPLOTBAT->HIST_SEQ;
    MEMCPY_AN(MWIPLOTBAT_N->TRAN_CODE, MWIPLOTBAT->TRAN_CODE, sizeof(MWIPLOTBAT->TRAN_CODE));
    MEMCPY_AN(MWIPLOTBAT_N->TRAN_TIME, MWIPLOTBAT->TRAN_TIME, sizeof(MWIPLOTBAT->TRAN_TIME));
    MWIPLOTBAT_N->HIST_DEL_FLAG[0] = MWIPLOTBAT->HIST_DEL_FLAG;
    MEMCPY_AN(MWIPLOTBAT_N->FACTORY, MWIPLOTBAT->FACTORY, sizeof(MWIPLOTBAT->FACTORY));
    MEMCPY_AN(MWIPLOTBAT_N->MAT_ID, MWIPLOTBAT->MAT_ID, sizeof(MWIPLOTBAT->MAT_ID));
    MWIPLOTBAT_N->MAT_VER = MWIPLOTBAT->MAT_VER;
    MEMCPY_AN(MWIPLOTBAT_N->FLOW, MWIPLOTBAT->FLOW, sizeof(MWIPLOTBAT->FLOW));
    MWIPLOTBAT_N->FLOW_SEQ_NUM = MWIPLOTBAT->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPLOTBAT_N->OPER, MWIPLOTBAT->OPER, sizeof(MWIPLOTBAT->OPER));
    MEMCPY_AN(MWIPLOTBAT_N->RES_ID, MWIPLOTBAT->RES_ID, sizeof(MWIPLOTBAT->RES_ID));
    MEMCPY_AN(MWIPLOTBAT_N->BATCH_ID, MWIPLOTBAT->BATCH_ID, sizeof(MWIPLOTBAT->BATCH_ID));
    MWIPLOTBAT_N->BATCH_SEQ = MWIPLOTBAT->BATCH_SEQ;
}


