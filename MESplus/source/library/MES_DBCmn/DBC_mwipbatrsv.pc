        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipbatrsv", sel_type);
}


/* Initialize Function */
void DBC_init_mwipbatrsv(struct MWIPBATRSV_TAG *MWIPBATRSV)
{
    /* memset by Space */
    memset(MWIPBATRSV, ' ', sizeof(struct MWIPBATRSV_TAG));
    
    MWIPBATRSV->MAT_VER = 0;
    MWIPBATRSV->FLOW_SEQ_NUM = 0;
}


/* Add Null Function */
void DBC_add_null_mwipbatrsv(struct MWIPBATRSV_N_TAG *MWIPBATRSV_N, struct MWIPBATRSV_TAG *MWIPBATRSV)
{
    /* memset by NULL */
    memset(MWIPBATRSV_N, '\0', sizeof(struct MWIPBATRSV_N_TAG));
    
    MEMCPY_AN(MWIPBATRSV_N->FACTORY, MWIPBATRSV->FACTORY, sizeof(MWIPBATRSV->FACTORY));
    MEMCPY_AN(MWIPBATRSV_N->MAT_ID, MWIPBATRSV->MAT_ID, sizeof(MWIPBATRSV->MAT_ID));
    MWIPBATRSV_N->MAT_VER = MWIPBATRSV->MAT_VER;
    MEMCPY_AN(MWIPBATRSV_N->FLOW, MWIPBATRSV->FLOW, sizeof(MWIPBATRSV->FLOW));
    MWIPBATRSV_N->FLOW_SEQ_NUM = MWIPBATRSV->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPBATRSV_N->OPER, MWIPBATRSV->OPER, sizeof(MWIPBATRSV->OPER));
    MEMCPY_AN(MWIPBATRSV_N->RES_TYPE, MWIPBATRSV->RES_TYPE, sizeof(MWIPBATRSV->RES_TYPE));
    MEMCPY_AN(MWIPBATRSV_N->RESG_ID, MWIPBATRSV->RESG_ID, sizeof(MWIPBATRSV->RESG_ID));
    MEMCPY_AN(MWIPBATRSV_N->RES_ID, MWIPBATRSV->RES_ID, sizeof(MWIPBATRSV->RES_ID));
    MEMCPY_AN(MWIPBATRSV_N->RECIPE, MWIPBATRSV->RECIPE, sizeof(MWIPBATRSV->RECIPE));
    MEMCPY_AN(MWIPBATRSV_N->RSV_BATCH_ID, MWIPBATRSV->RSV_BATCH_ID, sizeof(MWIPBATRSV->RSV_BATCH_ID));
    MEMCPY_AN(MWIPBATRSV_N->CRT_RULE_ID, MWIPBATRSV->CRT_RULE_ID, sizeof(MWIPBATRSV->CRT_RULE_ID));
    MEMCPY_AN(MWIPBATRSV_N->CREATE_USER_ID, MWIPBATRSV->CREATE_USER_ID, sizeof(MWIPBATRSV->CREATE_USER_ID));
    MEMCPY_AN(MWIPBATRSV_N->CREATE_TIME, MWIPBATRSV->CREATE_TIME, sizeof(MWIPBATRSV->CREATE_TIME));
    MEMCPY_AN(MWIPBATRSV_N->UPDATE_USER_ID, MWIPBATRSV->UPDATE_USER_ID, sizeof(MWIPBATRSV->UPDATE_USER_ID));
    MEMCPY_AN(MWIPBATRSV_N->UPDATE_TIME, MWIPBATRSV->UPDATE_TIME, sizeof(MWIPBATRSV->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mwipbatrsv(struct MWIPBATRSV_N_TAG *MWIPBATRSV_N, struct MWIPBATRSV_TAG *MWIPBATRSV)
{
    MEMCPY_DN(MWIPBATRSV->FACTORY, MWIPBATRSV_N->FACTORY, sizeof(MWIPBATRSV->FACTORY));
    MEMCPY_DN(MWIPBATRSV->MAT_ID, MWIPBATRSV_N->MAT_ID, sizeof(MWIPBATRSV->MAT_ID));
    MWIPBATRSV->MAT_VER = MWIPBATRSV_N->MAT_VER;
    MEMCPY_DN(MWIPBATRSV->FLOW, MWIPBATRSV_N->FLOW, sizeof(MWIPBATRSV->FLOW));
    MWIPBATRSV->FLOW_SEQ_NUM = MWIPBATRSV_N->FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPBATRSV->OPER, MWIPBATRSV_N->OPER, sizeof(MWIPBATRSV->OPER));
    MEMCPY_DN(MWIPBATRSV->RES_TYPE, MWIPBATRSV_N->RES_TYPE, sizeof(MWIPBATRSV->RES_TYPE));
    MEMCPY_DN(MWIPBATRSV->RESG_ID, MWIPBATRSV_N->RESG_ID, sizeof(MWIPBATRSV->RESG_ID));
    MEMCPY_DN(MWIPBATRSV->RES_ID, MWIPBATRSV_N->RES_ID, sizeof(MWIPBATRSV->RES_ID));
    MEMCPY_DN(MWIPBATRSV->RECIPE, MWIPBATRSV_N->RECIPE, sizeof(MWIPBATRSV->RECIPE));
    MEMCPY_DN(MWIPBATRSV->RSV_BATCH_ID, MWIPBATRSV_N->RSV_BATCH_ID, sizeof(MWIPBATRSV->RSV_BATCH_ID));
    MEMCPY_DN(MWIPBATRSV->CRT_RULE_ID, MWIPBATRSV_N->CRT_RULE_ID, sizeof(MWIPBATRSV->CRT_RULE_ID));
    MEMCPY_DN(MWIPBATRSV->CREATE_USER_ID, MWIPBATRSV_N->CREATE_USER_ID, sizeof(MWIPBATRSV->CREATE_USER_ID));
    MEMCPY_DN(MWIPBATRSV->CREATE_TIME, MWIPBATRSV_N->CREATE_TIME, sizeof(MWIPBATRSV->CREATE_TIME));
    MEMCPY_DN(MWIPBATRSV->UPDATE_USER_ID, MWIPBATRSV_N->UPDATE_USER_ID, sizeof(MWIPBATRSV->UPDATE_USER_ID));
    MEMCPY_DN(MWIPBATRSV->UPDATE_TIME, MWIPBATRSV_N->UPDATE_TIME, sizeof(MWIPBATRSV->UPDATE_TIME));
}


