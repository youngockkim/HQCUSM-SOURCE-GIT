                    RECIPE,
                    RSV_BATCH_ID,
                    CRT_RULE_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPBATRSV
                ORDER BY FACTORY ASC,
                    MAT_ID ASC,
                    MAT_VER ASC,
                    FLOW ASC,
                    FLOW_SEQ_NUM ASC,
                    OPER ASC,
                    RES_TYPE ASC,
                    RESG_ID ASC,
                    RES_ID ASC,
                    RECIPE ASC,
                    RSV_BATCH_ID ASC;
            EXEC SQL OPEN DBC_MWIPBATRSV_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPBATRSV_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_TYPE,
                    RESG_ID,
                    RES_ID,
                    RECIPE,
                    RSV_BATCH_ID,
                    CRT_RULE_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPBATRSV
                WHERE FACTORY = :MWIPBATRSV_N.FACTORY
                    AND MAT_ID = :MWIPBATRSV_N.MAT_ID
                    AND MAT_VER = :MWIPBATRSV_N.MAT_VER
                    AND FLOW = :MWIPBATRSV_N.FLOW
                    AND FLOW_SEQ_NUM = :MWIPBATRSV_N.FLOW_SEQ_NUM
                    AND OPER = :MWIPBATRSV_N.OPER
                ORDER BY RSV_BATCH_ID ASC;
            EXEC SQL OPEN DBC_MWIPBATRSV_CUR_2;
            break;

        case 3: /* Not Allow Duplicate Flow Seq Num Case : Against Case 2 */
            EXEC SQL DECLARE DBC_MWIPBATRSV_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_TYPE,
                    RESG_ID,
                    RES_ID,
                    RECIPE,
                    RSV_BATCH_ID,
                    CRT_RULE_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
