/* Add Null Function */
void DBC_add_null_mrascrrmfo(struct MRASCRRMFO_N_TAG *MRASCRRMFO_N, struct MRASCRRMFO_TAG *MRASCRRMFO)
{
    /* memset by NULL */
    memset(MRASCRRMFO_N, '\0', sizeof(struct MRASCRRMFO_N_TAG));
    
    MEMCPY_AN(MRASCRRMFO_N->FACTORY, MRASCRRMFO->FACTORY, sizeof(MRASCRRMFO->FACTORY));
    MRASCRRMFO_N->REL_LEVEL[0] = MRASCRRMFO->REL_LEVEL;
    MEMCPY_AN(MRASCRRMFO_N->MAT_ID, MRASCRRMFO->MAT_ID, sizeof(MRASCRRMFO->MAT_ID));
    MRASCRRMFO_N->MAT_VER = MRASCRRMFO->MAT_VER;
    MEMCPY_AN(MRASCRRMFO_N->FLOW, MRASCRRMFO->FLOW, sizeof(MRASCRRMFO->FLOW));
    MEMCPY_AN(MRASCRRMFO_N->OPER, MRASCRRMFO->OPER, sizeof(MRASCRRMFO->OPER));
    MRASCRRMFO_N->CHG_POINT[0] = MRASCRRMFO->CHG_POINT;
    MEMCPY_AN(MRASCRRMFO_N->CUR_TYPE, MRASCRRMFO->CUR_TYPE, sizeof(MRASCRRMFO->CUR_TYPE));
    MEMCPY_AN(MRASCRRMFO_N->TO_TYPE, MRASCRRMFO->TO_TYPE, sizeof(MRASCRRMFO->TO_TYPE));
    MEMCPY_AN(MRASCRRMFO_N->CHG_MODE, MRASCRRMFO->CHG_MODE, sizeof(MRASCRRMFO->CHG_MODE));
    MEMCPY_AN(MRASCRRMFO_N->CREATE_USER_ID, MRASCRRMFO->CREATE_USER_ID, sizeof(MRASCRRMFO->CREATE_USER_ID));
    MEMCPY_AN(MRASCRRMFO_N->CREATE_TIME, MRASCRRMFO->CREATE_TIME, sizeof(MRASCRRMFO->CREATE_TIME));
    MEMCPY_AN(MRASCRRMFO_N->UPDATE_USER_ID, MRASCRRMFO->UPDATE_USER_ID, sizeof(MRASCRRMFO->UPDATE_USER_ID));
    MEMCPY_AN(MRASCRRMFO_N->UPDATE_TIME, MRASCRRMFO->UPDATE_TIME, sizeof(MRASCRRMFO->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mrascrrmfo(struct MRASCRRMFO_N_TAG *MRASCRRMFO_N, struct MRASCRRMFO_TAG *MRASCRRMFO)
{
    MEMCPY_DN(MRASCRRMFO->FACTORY, MRASCRRMFO_N->FACTORY, sizeof(MRASCRRMFO->FACTORY));
    MRASCRRMFO->REL_LEVEL = MRASCRRMFO_N->REL_LEVEL[0];
    MEMCPY_DN(MRASCRRMFO->MAT_ID, MRASCRRMFO_N->MAT_ID, sizeof(MRASCRRMFO->MAT_ID));
    MRASCRRMFO->MAT_VER = MRASCRRMFO_N->MAT_VER;
    MEMCPY_DN(MRASCRRMFO->FLOW, MRASCRRMFO_N->FLOW, sizeof(MRASCRRMFO->FLOW));
    MEMCPY_DN(MRASCRRMFO->OPER, MRASCRRMFO_N->OPER, sizeof(MRASCRRMFO->OPER));
    MRASCRRMFO->CHG_POINT = MRASCRRMFO_N->CHG_POINT[0];
    MEMCPY_DN(MRASCRRMFO->CUR_TYPE, MRASCRRMFO_N->CUR_TYPE, sizeof(MRASCRRMFO->CUR_TYPE));
    MEMCPY_DN(MRASCRRMFO->TO_TYPE, MRASCRRMFO_N->TO_TYPE, sizeof(MRASCRRMFO->TO_TYPE));
    MEMCPY_DN(MRASCRRMFO->CHG_MODE, MRASCRRMFO_N->CHG_MODE, sizeof(MRASCRRMFO->CHG_MODE));
    MEMCPY_DN(MRASCRRMFO->CREATE_USER_ID, MRASCRRMFO_N->CREATE_USER_ID, sizeof(MRASCRRMFO->CREATE_USER_ID));
    MEMCPY_DN(MRASCRRMFO->CREATE_TIME, MRASCRRMFO_N->CREATE_TIME, sizeof(MRASCRRMFO->CREATE_TIME));
    MEMCPY_DN(MRASCRRMFO->UPDATE_USER_ID, MRASCRRMFO_N->UPDATE_USER_ID, sizeof(MRASCRRMFO->UPDATE_USER_ID));
    MEMCPY_DN(MRASCRRMFO->UPDATE_TIME, MRASCRRMFO_N->UPDATE_TIME, sizeof(MRASCRRMFO->UPDATE_TIME));
}


