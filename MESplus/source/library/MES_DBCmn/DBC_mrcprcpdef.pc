/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrcprcpdef(int sel_type, struct MRCPRCPDEF_TAG *MRCPRCPDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRCPRCPDEF_N_TAG MRCPRCPDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrcprcpdef(&MRCPRCPDEF_N, MRCPRCPDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRCPRCPDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    RECIPE,
                    RECIPE_DESC,
                    RCP_GRP_1,
                    RCP_GRP_2,
                    RCP_GRP_3,
                    RCP_GRP_4,
                    RCP_GRP_5,
                    RCP_GRP_6,
                    RCP_GRP_7,
                    RCP_GRP_8,
                    RCP_GRP_9,
                    RCP_GRP_10,
                    RCP_CMF_1,
                    RCP_CMF_2,
                    RCP_CMF_3,
                    RCP_CMF_4,
                    RCP_CMF_5,
                    RCP_CMF_6,
                    RCP_CMF_7,
                    RCP_CMF_8,
                    RCP_CMF_9,
                    RCP_CMF_10,
                    APPROVAL_REQUIRE_FLAG,
                    APPROVAL_USER_ID,
                    DELETE_FLAG,
                    DELETE_USER_ID,
                    DELETE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRCPRCPDEF
                WHERE
                    FACTORY = :MRCPRCPDEF_N.FACTORY
                    AND RES_ID = :MRCPRCPDEF_N.RES_ID
                    AND SUBRES_ID = :MRCPRCPDEF_N.SUBRES_ID
                    AND RECIPE >= :MRCPRCPDEF_N.RECIPE                
                ORDER BY RECIPE ASC;
            EXEC SQL OPEN DBC_MRCPRCPDEF_CUR_1;
            break;

        case 2:
            /* ?諭???⑤벊???筌욊쑵六??롫뮉 ?貫???쇱벥 ??됰뻻???귐딅뮞??*/
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);         
            EXEC SQL DECLARE DBC_MRCPRCPDEF_CUR_2 CURSOR FOR
                SELECT DISTINCT RECIPE, RECIPE_DESC, DELETE_FLAG 
                FROM MRCPRCPDEF
                WHERE 
                    FACTORY = :MRCPRCPDEF_N.FACTORY
                    AND RES_ID IN (SELECT RES_ID FROM MRASRESMFO WHERE FACTORY = :MRCPRCPDEF_N.FACTORY AND OPER = :DBC_Q_COND_N.OPER)
                ORDER BY RECIPE ASC;
            EXEC SQL OPEN DBC_MRCPRCPDEF_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrcprcpdef", sel_type);
}


