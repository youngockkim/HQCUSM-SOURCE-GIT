                                                    :MRCPRCPDEF_N.RCP_GRP_4,
                                                    :MRCPRCPDEF_N.RCP_GRP_5,
                                                    :MRCPRCPDEF_N.RCP_GRP_6,
                                                    :MRCPRCPDEF_N.RCP_GRP_7,
                                                    :MRCPRCPDEF_N.RCP_GRP_8,
                                                    :MRCPRCPDEF_N.RCP_GRP_9,
                                                    :MRCPRCPDEF_N.RCP_GRP_10,
                                                    :MRCPRCPDEF_N.RCP_CMF_1,
                                                    :MRCPRCPDEF_N.RCP_CMF_2,
                                                    :MRCPRCPDEF_N.RCP_CMF_3,
                                                    :MRCPRCPDEF_N.RCP_CMF_4,
                                                    :MRCPRCPDEF_N.RCP_CMF_5,
                                                    :MRCPRCPDEF_N.RCP_CMF_6,
                                                    :MRCPRCPDEF_N.RCP_CMF_7,
                                                    :MRCPRCPDEF_N.RCP_CMF_8,
                                                    :MRCPRCPDEF_N.RCP_CMF_9,
                                                    :MRCPRCPDEF_N.RCP_CMF_10,
                                                    :MRCPRCPDEF_N.APPROVAL_REQUIRE_FLAG,
                                                    :MRCPRCPDEF_N.APPROVAL_USER_ID,
                                                    :MRCPRCPDEF_N.DELETE_FLAG,
                                                    :MRCPRCPDEF_N.DELETE_USER_ID,
                                                    :MRCPRCPDEF_N.DELETE_TIME,
                                                    :MRCPRCPDEF_N.CREATE_USER_ID,
                                                    :MRCPRCPDEF_N.CREATE_TIME,
                                                    :MRCPRCPDEF_N.UPDATE_USER_ID,
                                                    :MRCPRCPDEF_N.UPDATE_TIME;
            break;

        case 2:
            EXEC SQL FETCH DBC_MRCPRCPDEF_CUR_2 INTO 
                                                    :MRCPRCPDEF_N.RECIPE,
                                                    :MRCPRCPDEF_N.RECIPE_DESC,
                                                    :MRCPRCPDEF_N.DELETE_FLAG;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mrcprcpdef(&MRCPRCPDEF_N, MRCPRCPDEF);
    }
    DB_stop_query_timer("DBC_fetch_mrcprcpdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mrcprcpdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MRCPRCPDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MRCPRCPDEF_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mrcprcpdef", sel_type);
}


/* Initialize Function */
void DBC_init_mrcprcpdef(struct MRCPRCPDEF_TAG *MRCPRCPDEF)
{
    /* memset by Space */
    memset(MRCPRCPDEF, ' ', sizeof(struct MRCPRCPDEF_TAG));
    
}


/* Add Null Function */
void DBC_add_null_mrcprcpdef(struct MRCPRCPDEF_N_TAG *MRCPRCPDEF_N, struct MRCPRCPDEF_TAG *MRCPRCPDEF)
{
    /* memset by NULL */
    memset(MRCPRCPDEF_N, '\0', sizeof(struct MRCPRCPDEF_N_TAG));
    
    MEMCPY_AN(MRCPRCPDEF_N->FACTORY, MRCPRCPDEF->FACTORY, sizeof(MRCPRCPDEF->FACTORY));
    MEMCPY_AN(MRCPRCPDEF_N->RES_ID, MRCPRCPDEF->RES_ID, sizeof(MRCPRCPDEF->RES_ID));
