                    "AND (HOLD_USER_ID = '%s' OR USER_ID_1 = '%s' OR USER_ID_2 = '%s' OR USER_ID_3 = '%s') ", 
                    ts1, ts1, ts1, ts1);
            }
            /* ?袁⑥┷ ??덈쭆野?(?깅??곻쭩???뤿?椰꾧퀡援?USER_TIME_3??揶쏅?????쇰선 ??덈뮉野?鈺곌퀣??袁⑥┷) ??뽰뇚) */
            if(ISSPACE(MWIPLOTHLD->USER_TIME_3, sizeof(MWIPLOTHLD->USER_TIME_3)) == DB_FALSE)
            {
                sprintf(sql + strlen(sql),
                    "AND (USER_TIME_3 = ' ') AND (RELEASE_HIST_SEQ = 0) ");
            }
            
            make_valid_quote(ts1, MWIPLOTHLD_N.HOLD_TRAN_TIME);
            make_valid_quote(ts2, MWIPLOTHLD_N.LOT_ID);
            sprintf(sql + strlen(sql), "AND (HOLD_TRAN_TIME > '%s' OR (HOLD_TRAN_TIME = '%s' AND LOT_ID >= '%s')) ", ts1, ts1, ts2);
            /*?????????? ??뽰뇚 */
            sprintf(sql + strlen(sql), "AND HIST_DEL_FLAG = ' ' ");
            
            sprintf(sql + strlen(sql), "ORDER BY HOLD_TRAN_TIME, LOT_ID ");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MWIPLOTHLD_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MWIPLOTHLD_CUR_2;                 
            break;



        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwiplothld", sel_type);
}


