                                                    :MWIPLOTHLD_N.HOLD_PRV_GRP_ID,
                                                    :MWIPLOTHLD_N.HOLD_COMMENT,
                                                    :MWIPLOTHLD_N.RELEASE_CODE,
                                                    :MWIPLOTHLD_N.RELEASE_USER_ID,
                                                    :MWIPLOTHLD_N.RELEASE_COMMENT,
                                                    :MWIPLOTHLD_N.USER_ID_1,
                                                    :MWIPLOTHLD_N.USER_TIME_1,
                                                    :MWIPLOTHLD_N.USER_COMMENT_1,
                                                    :MWIPLOTHLD_N.USER_ID_2,
                                                    :MWIPLOTHLD_N.USER_TIME_2,
                                                    :MWIPLOTHLD_N.USER_COMMENT_2,
                                                    :MWIPLOTHLD_N.USER_ID_3,
                                                    :MWIPLOTHLD_N.USER_TIME_3,
                                                    :MWIPLOTHLD_N.USER_COMMENT_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwiplothld(&MWIPLOTHLD_N, MWIPLOTHLD);
    }
    DB_stop_query_timer("DBC_fetch_mwiplothld", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwiplothld(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPLOTHLD_CUR_1;
            break;
        case 2:
            EXEC SQL CLOSE DBC_MWIPLOTHLD_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwiplothld", sel_type);
}


/* Initialize Function */
void DBC_init_mwiplothld(struct MWIPLOTHLD_TAG *MWIPLOTHLD)
{
    /* memset by Space */
    memset(MWIPLOTHLD, ' ', sizeof(struct MWIPLOTHLD_TAG));
    
    MWIPLOTHLD->HIST_SEQ = 0;
    MWIPLOTHLD->RELEASE_HIST_SEQ = 0;
    MWIPLOTHLD->MAT_VER = 0;
    MWIPLOTHLD->FLOW_SEQ_NUM = 0;
    MWIPLOTHLD->QTY_1 = 0;
    MWIPLOTHLD->QTY_2 = 0;
    MWIPLOTHLD->QTY_3 = 0;
}


/* Add Null Function */
void DBC_add_null_mwiplothld(struct MWIPLOTHLD_N_TAG *MWIPLOTHLD_N, struct MWIPLOTHLD_TAG *MWIPLOTHLD)
{
    /* memset by NULL */
    memset(MWIPLOTHLD_N, '\0', sizeof(struct MWIPLOTHLD_N_TAG));
    
    MEMCPY_AN(MWIPLOTHLD_N->LOT_ID, MWIPLOTHLD->LOT_ID, sizeof(MWIPLOTHLD->LOT_ID));
    MWIPLOTHLD_N->HIST_SEQ = MWIPLOTHLD->HIST_SEQ;
