            sprintf(sql + strlen(sql),   "CMF_12, ");
            sprintf(sql + strlen(sql),   "CMF_13, ");
            sprintf(sql + strlen(sql),   "CMF_14, ");
            sprintf(sql + strlen(sql),   "CMF_15, ");
            sprintf(sql + strlen(sql),   "CMF_16, ");
            sprintf(sql + strlen(sql),   "CMF_17, ");
            sprintf(sql + strlen(sql),   "CMF_18, ");
            sprintf(sql + strlen(sql),   "CMF_19, ");
            sprintf(sql + strlen(sql),   "CMF_20, ");
            sprintf(sql + strlen(sql),   "HOLD_CODE, ");
            sprintf(sql + strlen(sql),   "HOLD_USER_ID, ");
            sprintf(sql + strlen(sql),   "HOLD_PRV_GRP_ID, ");
            sprintf(sql + strlen(sql),   "HOLD_COMMENT, ");
            sprintf(sql + strlen(sql),   "RELEASE_CODE, ");
            sprintf(sql + strlen(sql),   "RELEASE_USER_ID, ");
            sprintf(sql + strlen(sql),   "RELEASE_COMMENT, ");
            sprintf(sql + strlen(sql),   "USER_ID_1, ");
            sprintf(sql + strlen(sql),   "USER_TIME_1, ");
            sprintf(sql + strlen(sql),   "USER_COMMENT_1, ");
            sprintf(sql + strlen(sql),   "USER_ID_2, ");
            sprintf(sql + strlen(sql),   "USER_TIME_2, ");
            sprintf(sql + strlen(sql),   "USER_COMMENT_2, ");
            sprintf(sql + strlen(sql),   "USER_ID_3, ");
            sprintf(sql + strlen(sql),   "USER_TIME_3, ");
            sprintf(sql + strlen(sql),   "USER_COMMENT_3 ");
            sprintf(sql + strlen(sql), "FROM MWIPLOTHLD WHERE ");

            make_valid_quote(ts1, MWIPLOTHLD_N.FACTORY);
            make_valid_quote(ts2, DBC_Q_COND_N.FROM_TIME);
            make_valid_quote(ts3, DBC_Q_COND_N.TO_TIME);

            sprintf(sql + strlen(sql), "FACTORY = '%s' AND HOLD_TRAN_TIME >= '%s' AND HOLD_TRAN_TIME < '%s' ", ts1, ts2, ts3);
            if(ISSPACE(MWIPLOTHLD->MAT_ID, sizeof(MWIPLOTHLD->MAT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts1, MWIPLOTHLD_N.MAT_ID);
                sprintf(sql + strlen(sql), "AND MAT_ID = '%s' ", ts1);
            }
            if(MWIPLOTHLD->MAT_VER > 0)
            {
                sprintf(sql + strlen(sql), "AND MAT_VER = %d ", MWIPLOTHLD->MAT_VER);
            }
            if(ISSPACE(MWIPLOTHLD->HOLD_CODE, sizeof(MWIPLOTHLD->HOLD_CODE)) == DB_FALSE)
            {
                make_valid_quote(ts1, MWIPLOTHLD_N.HOLD_CODE);
                sprintf(sql + strlen(sql), "AND HOLD_CODE = '%s' ", ts1);
            }
            if(ISSPACE(MWIPLOTHLD->HOLD_PRV_GRP_ID, sizeof(MWIPLOTHLD->HOLD_PRV_GRP_ID)) == DB_FALSE)
