                    :MWIPLOTHLD_N.USER_TIME_3,
                    :MWIPLOTHLD_N.USER_COMMENT_3
                FROM MWIPLOTHLD
                WHERE LOT_ID = :MWIPLOTHLD_N.LOT_ID
                    AND HIST_SEQ = 
                    (
                        SELECT NVL(MAX(A.HIST_SEQ), 0) 
                        FROM MWIPLOTHLD A, MWIPLOTHIS B
                        WHERE A.LOT_ID = :MWIPLOTHLD_N.LOT_ID
                            AND A.FACTORY = :MWIPLOTHLD_N.FACTORY
                            AND A.MAT_ID = :MWIPLOTHLD_N.MAT_ID
                            AND A.MAT_VER = :MWIPLOTHLD_N.MAT_VER
                            AND A.FLOW = :MWIPLOTHLD_N.FLOW
                            AND A.OPER = :MWIPLOTHLD_N.OPER
                            AND A.HOLD_CODE = :MWIPLOTHLD_N.HOLD_CODE
                            AND A.HIST_DEL_FLAG = ' '
                            AND B.LOT_ID = :MWIPLOTHLD_N.LOT_ID
                            AND B.HIST_SEQ = A.HIST_SEQ
                            AND B.HIST_DEL_FLAG = ' '
                            AND B.START_FLAG = ' '
                    );
            break;

        case 6: /* Add by J.S. 2011.04.12 */
            EXEC SQL SELECT 
                         LOT_ID,
                         HIST_SEQ,
                         HOLD_TRAN_TIME,
                         RELEASE_TRAN_TIME,
                         HIST_DEL_FLAG,
