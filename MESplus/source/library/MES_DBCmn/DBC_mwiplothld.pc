/* SQL UPDATE Function */
void DBC_update_mwiplothld(int sel_type, struct MWIPLOTHLD_TAG *MWIPLOTHLD)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTHLD_N_TAG MWIPLOTHLD_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplothld(&MWIPLOTHLD_N, MWIPLOTHLD);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MWIPLOTHLD SET
                    HOLD_TRAN_TIME = :MWIPLOTHLD_N.HOLD_TRAN_TIME,
                    RELEASE_TRAN_TIME = :MWIPLOTHLD_N.RELEASE_TRAN_TIME,
                    HIST_DEL_FLAG = :MWIPLOTHLD_N.HIST_DEL_FLAG,
