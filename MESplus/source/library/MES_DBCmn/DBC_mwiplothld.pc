                    HOLD_PRV_GRP_ID,
                    HOLD_COMMENT,
                    RELEASE_CODE,
                    RELEASE_USER_ID,
                    RELEASE_COMMENT,
                    USER_ID_1,
                    USER_TIME_1,
                    USER_COMMENT_1,
                    USER_ID_2,
                    USER_TIME_2,
                    USER_COMMENT_2,
                    USER_ID_3,
