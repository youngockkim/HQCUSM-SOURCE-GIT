                    CMF_5 = :MWIPLOTHLD_N.CMF_5,
                    CMF_6 = :MWIPLOTHLD_N.CMF_6,
                    CMF_7 = :MWIPLOTHLD_N.CMF_7,
                    CMF_8 = :MWIPLOTHLD_N.CMF_8,
                    CMF_9 = :MWIPLOTHLD_N.CMF_9,
                    CMF_10 = :MWIPLOTHLD_N.CMF_10,
                    CMF_11 = :MWIPLOTHLD_N.CMF_11,
                    CMF_12 = :MWIPLOTHLD_N.CMF_12,
                    CMF_13 = :MWIPLOTHLD_N.CMF_13,
                    CMF_14 = :MWIPLOTHLD_N.CMF_14,
                    CMF_15 = :MWIPLOTHLD_N.CMF_15,
                    CMF_16 = :MWIPLOTHLD_N.CMF_16,
                    CMF_17 = :MWIPLOTHLD_N.CMF_17,
                    CMF_18 = :MWIPLOTHLD_N.CMF_18,
                    CMF_19 = :MWIPLOTHLD_N.CMF_19,
                    CMF_20 = :MWIPLOTHLD_N.CMF_20,
                    HOLD_CODE = :MWIPLOTHLD_N.HOLD_CODE,
                    HOLD_USER_ID = :MWIPLOTHLD_N.HOLD_USER_ID,
                    HOLD_PRV_GRP_ID = :MWIPLOTHLD_N.HOLD_PRV_GRP_ID,
                    HOLD_COMMENT = :MWIPLOTHLD_N.HOLD_COMMENT,
                    RELEASE_CODE = :MWIPLOTHLD_N.RELEASE_CODE,
                    RELEASE_USER_ID = :MWIPLOTHLD_N.RELEASE_USER_ID,
                    RELEASE_COMMENT = :MWIPLOTHLD_N.RELEASE_COMMENT,
                    USER_ID_1 = :MWIPLOTHLD_N.USER_ID_1,
                    USER_TIME_1 = :MWIPLOTHLD_N.USER_TIME_1,
                    USER_COMMENT_1 = :MWIPLOTHLD_N.USER_COMMENT_1,
                    USER_ID_2 = :MWIPLOTHLD_N.USER_ID_2,
                    USER_TIME_2 = :MWIPLOTHLD_N.USER_TIME_2,
                    USER_COMMENT_2 = :MWIPLOTHLD_N.USER_COMMENT_2,
                    USER_ID_3 = :MWIPLOTHLD_N.USER_ID_3,
                    USER_TIME_3 = :MWIPLOTHLD_N.USER_TIME_3,
                    USER_COMMENT_3 = :MWIPLOTHLD_N.USER_COMMENT_3
                WHERE LOT_ID = :MWIPLOTHLD_N.LOT_ID
                    AND HIST_SEQ = :MWIPLOTHLD_N.HIST_SEQ;
            break;


        case 2:
            EXEC SQL UPDATE MWIPLOTHLD SET
                    HIST_DEL_FLAG = :MWIPLOTHLD_N.HIST_DEL_FLAG
                WHERE LOT_ID = :MWIPLOTHLD_N.LOT_ID
                    AND HIST_SEQ = :MWIPLOTHLD_N.HIST_SEQ;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mwiplothld", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwiplothld(int sel_type, struct MWIPLOTHLD_TAG *MWIPLOTHLD)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTHLD_N_TAG MWIPLOTHLD_N;
        char   sql[5120];
        char   ts1[100];
        char   ts2[100];
        char   ts3[100];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();


    DBC_add_null_mwiplothld(&MWIPLOTHLD_N, MWIPLOTHLD);
    DB_error_code = 0;
    
    memset( ts1, 0x00, sizeof(ts1));
    memset( ts2, 0x00, sizeof(ts2));
    memset( ts3, 0x00, sizeof(ts3));

    switch(sel_type)
    {
        case 1:
            memset( sql, 0x00, sizeof(sql));
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "LOT_ID, ");
            sprintf(sql + strlen(sql),   "HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "HOLD_TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "RELEASE_TRAN_TIME, ");
