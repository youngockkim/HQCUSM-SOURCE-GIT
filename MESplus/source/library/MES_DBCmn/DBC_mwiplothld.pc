                    :MWIPLOTHLD_N.RELEASE_CODE,
                    :MWIPLOTHLD_N.RELEASE_USER_ID,
                    :MWIPLOTHLD_N.RELEASE_COMMENT,
                    :MWIPLOTHLD_N.USER_ID_1,
                    :MWIPLOTHLD_N.USER_TIME_1,
                    :MWIPLOTHLD_N.USER_COMMENT_1,
                    :MWIPLOTHLD_N.USER_ID_2,
                    :MWIPLOTHLD_N.USER_TIME_2,
                    :MWIPLOTHLD_N.USER_COMMENT_2,
                    :MWIPLOTHLD_N.USER_ID_3,
                    :MWIPLOTHLD_N.USER_TIME_3,
                    :MWIPLOTHLD_N.USER_COMMENT_3
                FROM MWIPLOTHLD
                WHERE LOT_ID = :MWIPLOTHLD_N.LOT_ID
                    AND HIST_SEQ = 
                    (
                        SELECT NVL(MAX(A.HIST_SEQ), 0) 
                        FROM MWIPLOTHLD A, MWIPLOTHIS B
                        WHERE A.LOT_ID = :MWIPLOTHLD_N.LOT_ID
                            AND A.FACTORY = :MWIPLOTHLD_N.FACTORY
                            AND A.MAT_ID = :MWIPLOTHLD_N.MAT_ID
                            AND A.MAT_VER = :MWIPLOTHLD_N.MAT_VER
                            AND A.FLOW = :MWIPLOTHLD_N.FLOW
                            AND A.OPER = :MWIPLOTHLD_N.OPER
                            AND A.HOLD_CODE = :MWIPLOTHLD_N.HOLD_CODE
                            AND A.HIST_DEL_FLAG = ' '
                            AND B.LOT_ID = :MWIPLOTHLD_N.LOT_ID
                            AND B.HIST_SEQ = A.HIST_SEQ
                            AND B.HIST_DEL_FLAG = ' '
                            AND B.START_FLAG = 'Y'
                    );
            break;



        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwiplothld(&MWIPLOTHLD_N, MWIPLOTHLD);
    }
    DB_stop_query_timer("DBC_select_mwiplothld", sel_type);
}


