            }
            if(ISSPACE(MWIPLOTHLD->USER_ID_1, sizeof(MWIPLOTHLD->USER_ID_1)) == DB_FALSE)
            {
                make_valid_quote(ts1, MWIPLOTHLD_N.USER_ID_1);
                sprintf(sql + strlen(sql),
                    "AND (HOLD_USER_ID = '%s' OR USER_ID_1 = '%s' OR USER_ID_2 = '%s' OR USER_ID_3 = '%s') ", 
                    ts1, ts1, ts1, ts1);
            }
            
            make_valid_quote(ts1, MWIPLOTHLD_N.HOLD_TRAN_TIME);
            make_valid_quote(ts2, MWIPLOTHLD_N.LOT_ID);
            sprintf(sql + strlen(sql), "AND (HOLD_TRAN_TIME > '%s' OR (HOLD_TRAN_TIME = '%s' AND LOT_ID >= '%s')) ",
                ts1, ts1, ts2);
            sprintf(sql + strlen(sql), "ORDER BY HOLD_TRAN_TIME, LOT_ID ");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MWIPLOTHLD_CUR_1 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MWIPLOTHLD_CUR_1;                 
            break;
            
        case 2:
            memset( sql, 0x00, sizeof(sql));
