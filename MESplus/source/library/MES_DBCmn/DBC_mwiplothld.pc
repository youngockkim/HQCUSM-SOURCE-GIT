/* SQL SELECT_SCALAR Function */
double DBC_select_mwiplothld_scalar(int sel_type, struct MWIPLOTHLD_TAG *MWIPLOTHLD)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTHLD_N_TAG MWIPLOTHLD_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    

    DBC_add_null_mwiplothld(&MWIPLOTHLD_N, MWIPLOTHLD);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTHLD
                WHERE LOT_ID = :MWIPLOTHLD_N.LOT_ID
                    AND HIST_SEQ = :MWIPLOTHLD_N.HIST_SEQ;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mwiplothld_scalar", sel_type);
    return d_value;
}


/* SQL DELETE Function */
void DBC_delete_mwiplothld(int sel_type, struct MWIPLOTHLD_TAG *MWIPLOTHLD)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTHLD_N_TAG MWIPLOTHLD_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplothld(&MWIPLOTHLD_N, MWIPLOTHLD);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM MWIPLOTHLD
                WHERE LOT_ID = :MWIPLOTHLD_N.LOT_ID
                    AND HIST_SEQ = :MWIPLOTHLD_N.HIST_SEQ;
            break;

        case 2:
            EXEC SQL DELETE FROM MWIPLOTHLD
                WHERE LOT_ID = :MWIPLOTHLD_N.LOT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_delete_mwiplothld", sel_type);
}


/* SQL INSERT Function */
void DBC_insert_mwiplothld(struct MWIPLOTHLD_TAG *MWIPLOTHLD)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTHLD_N_TAG MWIPLOTHLD_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplothld(&MWIPLOTHLD_N, MWIPLOTHLD);
    DB_error_code = 0;

    EXEC SQL INSERT INTO MWIPLOTHLD (
                    LOT_ID,
                    HIST_SEQ,
                    HOLD_TRAN_TIME,
                    RELEASE_TRAN_TIME,
                    HIST_DEL_FLAG,
                    RELEASE_HIST_SEQ,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
