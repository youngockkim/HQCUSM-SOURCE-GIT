/* Del Null Function */
void DBC_del_null_mwiplothld(struct MWIPLOTHLD_N_TAG *MWIPLOTHLD_N, struct MWIPLOTHLD_TAG *MWIPLOTHLD)
{
    MEMCPY_DN(MWIPLOTHLD->LOT_ID, MWIPLOTHLD_N->LOT_ID, sizeof(MWIPLOTHLD->LOT_ID));
    MWIPLOTHLD->HIST_SEQ = MWIPLOTHLD_N->HIST_SEQ;
    MEMCPY_DN(MWIPLOTHLD->HOLD_TRAN_TIME, MWIPLOTHLD_N->HOLD_TRAN_TIME, sizeof(MWIPLOTHLD->HOLD_TRAN_TIME));
    MEMCPY_DN(MWIPLOTHLD->RELEASE_TRAN_TIME, MWIPLOTHLD_N->RELEASE_TRAN_TIME, sizeof(MWIPLOTHLD->RELEASE_TRAN_TIME));
    MWIPLOTHLD->HIST_DEL_FLAG = MWIPLOTHLD_N->HIST_DEL_FLAG[0];
    MWIPLOTHLD->RELEASE_HIST_SEQ = MWIPLOTHLD_N->RELEASE_HIST_SEQ;
    MEMCPY_DN(MWIPLOTHLD->FACTORY, MWIPLOTHLD_N->FACTORY, sizeof(MWIPLOTHLD->FACTORY));
    MEMCPY_DN(MWIPLOTHLD->MAT_ID, MWIPLOTHLD_N->MAT_ID, sizeof(MWIPLOTHLD->MAT_ID));
    MWIPLOTHLD->MAT_VER = MWIPLOTHLD_N->MAT_VER;
    MEMCPY_DN(MWIPLOTHLD->FLOW, MWIPLOTHLD_N->FLOW, sizeof(MWIPLOTHLD->FLOW));
    MWIPLOTHLD->FLOW_SEQ_NUM = MWIPLOTHLD_N->FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPLOTHLD->OPER, MWIPLOTHLD_N->OPER, sizeof(MWIPLOTHLD->OPER));
