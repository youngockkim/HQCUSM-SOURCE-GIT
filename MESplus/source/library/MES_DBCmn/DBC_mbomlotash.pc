    MBOMLOTASH->SERIAL_TYPE = MBOMLOTASH_N->SERIAL_TYPE[0];
    MEMCPY_DN(MBOMLOTASH->FLOW, MBOMLOTASH_N->FLOW, sizeof(MBOMLOTASH->FLOW));
    MEMCPY_DN(MBOMLOTASH->OPER, MBOMLOTASH_N->OPER, sizeof(MBOMLOTASH->OPER));
    MBOMLOTASH->TO_MAT_ATT_QTY = MBOMLOTASH_N->TO_MAT_ATT_QTY;
    MEMCPY_DN(MBOMLOTASH->TO_SERIAL_ID, MBOMLOTASH_N->TO_SERIAL_ID, sizeof(MBOMLOTASH->TO_SERIAL_ID));
    MEMCPY_DN(MBOMLOTASH->CREATE_USER_ID, MBOMLOTASH_N->CREATE_USER_ID, sizeof(MBOMLOTASH->CREATE_USER_ID));
    MEMCPY_DN(MBOMLOTASH->CREATE_TIME, MBOMLOTASH_N->CREATE_TIME, sizeof(MBOMLOTASH->CREATE_TIME));
    MEMCPY_DN(MBOMLOTASH->UPDATE_USER_ID, MBOMLOTASH_N->UPDATE_USER_ID, sizeof(MBOMLOTASH->UPDATE_USER_ID));
    MEMCPY_DN(MBOMLOTASH->UPDATE_TIME, MBOMLOTASH_N->UPDATE_TIME, sizeof(MBOMLOTASH->UPDATE_TIME));
