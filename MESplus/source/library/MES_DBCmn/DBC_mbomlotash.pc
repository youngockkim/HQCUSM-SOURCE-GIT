    MBOMLOTASH->ALT_MAT_FLAG = MBOMLOTASH_N->ALT_MAT_FLAG[0];
    MEMCPY_DN(MBOMLOTASH->MAT_ID, MBOMLOTASH_N->MAT_ID, sizeof(MBOMLOTASH->MAT_ID));
    MBOMLOTASH->MAT_VER = MBOMLOTASH_N->MAT_VER;
    MBOMLOTASH->MAT_QTY = MBOMLOTASH_N->MAT_QTY;
    MEMCPY_DN(MBOMLOTASH->MAT_UNIT, MBOMLOTASH_N->MAT_UNIT, sizeof(MBOMLOTASH->MAT_UNIT));
    MBOMLOTASH->MAT_ATT_QTY = MBOMLOTASH_N->MAT_ATT_QTY;
