/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mbomlotash(int sel_type, struct MBOMLOTASH_TAG *MBOMLOTASH)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBOMLOTASH_N_TAG MBOMLOTASH_N;
        char   sql[5120];
        char   ts[1000];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbomlotash(&MBOMLOTASH_N, MBOMLOTASH);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MBOMLOTASH_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOT_ID,
                    BOM_HIST_SEQ,
                    BOM_SET_ID,
                    BOM_SET_VERSION,
                    SEQ_NUM,
                    SERIAL_SEQ_NUM,
                    BOM_HIST_TYPE,
                    PART_GRP,
                    ALT_MAT_FLAG,
                    MAT_ID,
                    MAT_VER,
                    MAT_QTY,
                    MAT_UNIT,
                    MAT_ATT_QTY,
                    SERIAL_ID,
                    SERIAL_TYPE,
                    FLOW,
                    OPER,
                    TO_MAT_ATT_QTY,
                    TO_SERIAL_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    HIST_DEL_FLAG,
                    HIST_DEL_TIME,
                    HIST_DEL_USER_ID
                FROM MBOMLOTASH
                WHERE FACTORY = :MBOMLOTASH_N.FACTORY
                    AND LOT_ID = :MBOMLOTASH_N.LOT_ID
                    AND HIST_DEL_FLAG = ' '
                ORDER BY BOM_HIST_SEQ DESC, SEQ_NUM ASC, SERIAL_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MBOMLOTASH_CUR_1;
            break;

        case 2:
            memset(sql, 0x00, sizeof(sql));
            memset(ts, 0x00, sizeof(ts));
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql), "FACTORY, ");
            sprintf(sql + strlen(sql), "LOT_ID, ");
            sprintf(sql + strlen(sql), "BOM_HIST_SEQ, ");
            sprintf(sql + strlen(sql), "BOM_SET_ID, ");
            sprintf(sql + strlen(sql), "BOM_SET_VERSION, ");
            sprintf(sql + strlen(sql), "SEQ_NUM, ");
            sprintf(sql + strlen(sql), "SERIAL_SEQ_NUM, ");
            sprintf(sql + strlen(sql), "BOM_HIST_TYPE, ");
            sprintf(sql + strlen(sql), "PART_GRP, ");
            sprintf(sql + strlen(sql), "ALT_MAT_FLAG, ");
            sprintf(sql + strlen(sql), "MAT_ID, ");
            sprintf(sql + strlen(sql), "MAT_VER, ");
            sprintf(sql + strlen(sql), "MAT_QTY, ");
            sprintf(sql + strlen(sql), "MAT_UNIT, ");
            sprintf(sql + strlen(sql), "MAT_ATT_QTY, ");
            sprintf(sql + strlen(sql), "SERIAL_ID, ");
            sprintf(sql + strlen(sql), "SERIAL_TYPE, ");
            sprintf(sql + strlen(sql), "FLOW, ");
            sprintf(sql + strlen(sql), "OPER, ");
            sprintf(sql + strlen(sql), "TO_MAT_ATT_QTY, ");
            sprintf(sql + strlen(sql), "TO_SERIAL_ID, ");
            sprintf(sql + strlen(sql), "CREATE_USER_ID, ");
            sprintf(sql + strlen(sql), "CREATE_TIME, ");
            sprintf(sql + strlen(sql), "UPDATE_USER_ID, ");
            sprintf(sql + strlen(sql), "UPDATE_TIME, ");
            sprintf(sql + strlen(sql), "HIST_DEL_FLAG, ");
            sprintf(sql + strlen(sql), "HIST_DEL_TIME, ");
            sprintf(sql + strlen(sql), "HIST_DEL_USER_ID ");
            sprintf(sql + strlen(sql), "FROM MBOMLOTASH ");
            
            make_valid_quote(ts, MBOMLOTASH_N.FACTORY);
            sprintf(sql + strlen(sql), " WHERE FACTORY = '%s'", ts);
            
            make_valid_quote(ts, MBOMLOTASH_N.LOT_ID);
            sprintf(sql + strlen(sql), " AND LOT_ID = '%s'", ts);
            
            sprintf(sql + strlen(sql), " AND ((BOM_HIST_SEQ < %d)", MBOMLOTASH_N.BOM_HIST_SEQ);
            sprintf(sql + strlen(sql), "  OR (BOM_HIST_SEQ = %d AND SEQ_NUM > %d)",
                MBOMLOTASH_N.BOM_HIST_SEQ, MBOMLOTASH_N.SEQ_NUM);
            sprintf(sql + strlen(sql), "  OR (BOM_HIST_SEQ = %d AND SEQ_NUM = %d AND SERIAL_SEQ_NUM >= %d))",
                MBOMLOTASH_N.BOM_HIST_SEQ, MBOMLOTASH_N.SEQ_NUM, MBOMLOTASH_N.SERIAL_SEQ_NUM);
                
            make_valid_quote(ts, DBC_Q_COND.FROM_TIME);
            sprintf(sql + strlen(sql), " AND CREATE_TIME >= '%s'", ts);
            
            make_valid_quote(ts, DBC_Q_COND.TO_TIME);
            sprintf(sql + strlen(sql), " AND CREATE_TIME < '%s'", ts);
            
            if(MBOMLOTASH_N.HIST_DEL_FLAG[0] != 'Y')
            {
                sprintf(sql + strlen(sql), " AND HIST_DEL_FLAG = ' '");
            }
            sprintf(sql + strlen(sql), " ORDER BY BOM_HIST_SEQ DESC, SEQ_NUM ASC, SERIAL_SEQ_NUM ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MBOMLOTASH_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MBOMLOTASH_CUR_2;                 
            break;

        case 3:
            EXEC SQL DECLARE DBC_MBOMLOTASH_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOT_ID,
                    BOM_HIST_SEQ,
                    BOM_SET_ID,
                    BOM_SET_VERSION,
                    SEQ_NUM,
                    SERIAL_SEQ_NUM,
                    BOM_HIST_TYPE,
                    PART_GRP,
                    ALT_MAT_FLAG,
                    MAT_ID,
                    MAT_VER,
                    MAT_QTY,
                    MAT_UNIT,
                    MAT_ATT_QTY,
                    SERIAL_ID,
                    SERIAL_TYPE,
                    FLOW,
                    OPER,
                    TO_MAT_ATT_QTY,
                    TO_SERIAL_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    HIST_DEL_FLAG,
                    HIST_DEL_TIME,
                    HIST_DEL_USER_ID
                FROM MBOMLOTASH
                WHERE FACTORY = :MBOMLOTASH_N.FACTORY
                    AND LOT_ID = :MBOMLOTASH_N.LOT_ID
                    AND BOM_HIST_SEQ < :MBOMLOTASH_N.BOM_HIST_SEQ
                    AND SEQ_NUM = :MBOMLOTASH_N.SEQ_NUM
                    AND BOM_HIST_TYPE <> :MBOMLOTASH_N.BOM_HIST_TYPE
                    AND HIST_DEL_FLAG = ' '
                ORDER BY BOM_HIST_SEQ DESC, SERIAL_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MBOMLOTASH_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mbomlotash", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mbomlotash(int sel_type, struct MBOMLOTASH_TAG *MBOMLOTASH)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBOMLOTASH_N_TAG MBOMLOTASH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MBOMLOTASH_CUR_1 INTO 
