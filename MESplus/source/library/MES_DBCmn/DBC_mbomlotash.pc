            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mbomlotash(&MBOMLOTASH_N, MBOMLOTASH);
    }
    DB_stop_query_timer("DBC_fetch_mbomlotash", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mbomlotash(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MBOMLOTASH_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MBOMLOTASH_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MBOMLOTASH_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mbomlotash", sel_type);
}


/* Initialize Function */
void DBC_init_mbomlotash(struct MBOMLOTASH_TAG *MBOMLOTASH)
{
    /* memset by Space */
    memset(MBOMLOTASH, ' ', sizeof(struct MBOMLOTASH_TAG));
    
    MBOMLOTASH->BOM_HIST_SEQ = 0;
    MBOMLOTASH->BOM_SET_VERSION = 0;
    MBOMLOTASH->SEQ_NUM = 0;
    MBOMLOTASH->SERIAL_SEQ_NUM = 0;
    MBOMLOTASH->MAT_VER = 0;
    MBOMLOTASH->MAT_QTY = 0;
    MBOMLOTASH->MAT_ATT_QTY = 0;
    MBOMLOTASH->TO_MAT_ATT_QTY = 0;
}


/* Add Null Function */
void DBC_add_null_mbomlotash(struct MBOMLOTASH_N_TAG *MBOMLOTASH_N, struct MBOMLOTASH_TAG *MBOMLOTASH)
{
    /* memset by NULL */
    memset(MBOMLOTASH_N, '\0', sizeof(struct MBOMLOTASH_N_TAG));
    
    MEMCPY_AN(MBOMLOTASH_N->FACTORY, MBOMLOTASH->FACTORY, sizeof(MBOMLOTASH->FACTORY));
    MEMCPY_AN(MBOMLOTASH_N->LOT_ID, MBOMLOTASH->LOT_ID, sizeof(MBOMLOTASH->LOT_ID));
    MBOMLOTASH_N->BOM_HIST_SEQ = MBOMLOTASH->BOM_HIST_SEQ;
    MEMCPY_AN(MBOMLOTASH_N->BOM_SET_ID, MBOMLOTASH->BOM_SET_ID, sizeof(MBOMLOTASH->BOM_SET_ID));
    MBOMLOTASH_N->BOM_SET_VERSION = MBOMLOTASH->BOM_SET_VERSION;
    MBOMLOTASH_N->SEQ_NUM = MBOMLOTASH->SEQ_NUM;
    MBOMLOTASH_N->SERIAL_SEQ_NUM = MBOMLOTASH->SERIAL_SEQ_NUM;
    MBOMLOTASH_N->BOM_HIST_TYPE[0] = MBOMLOTASH->BOM_HIST_TYPE;
    MEMCPY_AN(MBOMLOTASH_N->PART_GRP, MBOMLOTASH->PART_GRP, sizeof(MBOMLOTASH->PART_GRP));
    MBOMLOTASH_N->ALT_MAT_FLAG[0] = MBOMLOTASH->ALT_MAT_FLAG;
    MEMCPY_AN(MBOMLOTASH_N->MAT_ID, MBOMLOTASH->MAT_ID, sizeof(MBOMLOTASH->MAT_ID));
    MBOMLOTASH_N->MAT_VER = MBOMLOTASH->MAT_VER;
    MBOMLOTASH_N->MAT_QTY = MBOMLOTASH->MAT_QTY;
    MEMCPY_AN(MBOMLOTASH_N->MAT_UNIT, MBOMLOTASH->MAT_UNIT, sizeof(MBOMLOTASH->MAT_UNIT));
    MBOMLOTASH_N->MAT_ATT_QTY = MBOMLOTASH->MAT_ATT_QTY;
    MEMCPY_AN(MBOMLOTASH_N->SERIAL_ID, MBOMLOTASH->SERIAL_ID, sizeof(MBOMLOTASH->SERIAL_ID));
    MBOMLOTASH_N->SERIAL_TYPE[0] = MBOMLOTASH->SERIAL_TYPE;
    MEMCPY_AN(MBOMLOTASH_N->FLOW, MBOMLOTASH->FLOW, sizeof(MBOMLOTASH->FLOW));
    MEMCPY_AN(MBOMLOTASH_N->OPER, MBOMLOTASH->OPER, sizeof(MBOMLOTASH->OPER));
    MBOMLOTASH_N->TO_MAT_ATT_QTY = MBOMLOTASH->TO_MAT_ATT_QTY;
    MEMCPY_AN(MBOMLOTASH_N->TO_SERIAL_ID, MBOMLOTASH->TO_SERIAL_ID, sizeof(MBOMLOTASH->TO_SERIAL_ID));
    MEMCPY_AN(MBOMLOTASH_N->CREATE_USER_ID, MBOMLOTASH->CREATE_USER_ID, sizeof(MBOMLOTASH->CREATE_USER_ID));
    MEMCPY_AN(MBOMLOTASH_N->CREATE_TIME, MBOMLOTASH->CREATE_TIME, sizeof(MBOMLOTASH->CREATE_TIME));
    MEMCPY_AN(MBOMLOTASH_N->UPDATE_USER_ID, MBOMLOTASH->UPDATE_USER_ID, sizeof(MBOMLOTASH->UPDATE_USER_ID));
    MEMCPY_AN(MBOMLOTASH_N->UPDATE_TIME, MBOMLOTASH->UPDATE_TIME, sizeof(MBOMLOTASH->UPDATE_TIME));
    MBOMLOTASH_N->HIST_DEL_FLAG[0] = MBOMLOTASH->HIST_DEL_FLAG;
    MEMCPY_AN(MBOMLOTASH_N->HIST_DEL_TIME, MBOMLOTASH->HIST_DEL_TIME, sizeof(MBOMLOTASH->HIST_DEL_TIME));
    MEMCPY_AN(MBOMLOTASH_N->HIST_DEL_USER_ID, MBOMLOTASH->HIST_DEL_USER_ID, sizeof(MBOMLOTASH->HIST_DEL_USER_ID));
}


/* Del Null Function */
void DBC_del_null_mbomlotash(struct MBOMLOTASH_N_TAG *MBOMLOTASH_N, struct MBOMLOTASH_TAG *MBOMLOTASH)
{
    MEMCPY_DN(MBOMLOTASH->FACTORY, MBOMLOTASH_N->FACTORY, sizeof(MBOMLOTASH->FACTORY));
    MEMCPY_DN(MBOMLOTASH->LOT_ID, MBOMLOTASH_N->LOT_ID, sizeof(MBOMLOTASH->LOT_ID));
    MBOMLOTASH->BOM_HIST_SEQ = MBOMLOTASH_N->BOM_HIST_SEQ;
    MEMCPY_DN(MBOMLOTASH->BOM_SET_ID, MBOMLOTASH_N->BOM_SET_ID, sizeof(MBOMLOTASH->BOM_SET_ID));
