    MEMCPY_DN(MBOMLOTASH->HIST_DEL_TIME, MBOMLOTASH_N->HIST_DEL_TIME, sizeof(MBOMLOTASH->HIST_DEL_TIME));
    MEMCPY_DN(MBOMLOTASH->HIST_DEL_USER_ID, MBOMLOTASH_N->HIST_DEL_USER_ID, sizeof(MBOMLOTASH->HIST_DEL_USER_ID));
