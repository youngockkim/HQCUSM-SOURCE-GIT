/* SQL CURSOR CLOSE Function */
void DBC_close_mbomsetmat(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MBOMSETMAT_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MBOMSETMAT_CUR_2;
            break;

		case 3:
            EXEC SQL CLOSE DBC_MBOMSETMAT_CUR_3;
            break;

		case 4:
            EXEC SQL CLOSE DBC_MBOMSETMAT_CUR_4;
            break;

		case 101:
            EXEC SQL CLOSE DBC_MBOMSETMAT_CUR_101;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mbomsetmat", sel_type);
}

/* Initialize Function */
void DBC_init_mbomsetmat(struct MBOMSETMAT_TAG *MBOMSETMAT)
{
    /* memset by Space */
    memset(MBOMSETMAT, ' ', sizeof(struct MBOMSETMAT_TAG));
    
    MBOMSETMAT->BOM_SET_VERSION = 0;
    MBOMSETMAT->SEQ_NUM = 0;
    MBOMSETMAT->MAT_VER = 0;
    MBOMSETMAT->MAT_QTY = 0;
}


/* Add Null Function */
void DBC_add_null_mbomsetmat(struct MBOMSETMAT_N_TAG *MBOMSETMAT_N, struct MBOMSETMAT_TAG *MBOMSETMAT)
{
    /* memset by NULL */
    memset(MBOMSETMAT_N, '\0', sizeof(struct MBOMSETMAT_N_TAG));
    
    MEMCPY_AN(MBOMSETMAT_N->FACTORY, MBOMSETMAT->FACTORY, sizeof(MBOMSETMAT->FACTORY));
    MEMCPY_AN(MBOMSETMAT_N->BOM_SET_ID, MBOMSETMAT->BOM_SET_ID, sizeof(MBOMSETMAT->BOM_SET_ID));
    MBOMSETMAT_N->BOM_SET_VERSION = MBOMSETMAT->BOM_SET_VERSION;
    MBOMSETMAT_N->SEQ_NUM = MBOMSETMAT->SEQ_NUM;
    MEMCPY_AN(MBOMSETMAT_N->PART_GRP, MBOMSETMAT->PART_GRP, sizeof(MBOMSETMAT->PART_GRP));
    MBOMSETMAT_N->ALT_MAT_FLAG[0] = MBOMSETMAT->ALT_MAT_FLAG;
    MEMCPY_AN(MBOMSETMAT_N->MAT_ID, MBOMSETMAT->MAT_ID, sizeof(MBOMSETMAT->MAT_ID));
    MBOMSETMAT_N->MAT_VER = MBOMSETMAT->MAT_VER;
    MBOMSETMAT_N->MAT_QTY = MBOMSETMAT->MAT_QTY;
    MEMCPY_AN(MBOMSETMAT_N->MAT_UNIT, MBOMSETMAT->MAT_UNIT, sizeof(MBOMSETMAT->MAT_UNIT));
    MBOMSETMAT_N->OPT_INPUT_FLAG[0] = MBOMSETMAT->OPT_INPUT_FLAG;
    MBOMSETMAT_N->AUTO_INPUT_FLAG[0] = MBOMSETMAT->AUTO_INPUT_FLAG;
    MBOMSETMAT_N->SERIAL_INPUT_FLAG[0] = MBOMSETMAT->SERIAL_INPUT_FLAG;
    MBOMSETMAT_N->SERIAL_TYPE[0] = MBOMSETMAT->SERIAL_TYPE;
    MBOMSETMAT_N->CHK_SERIAL_FLAG[0] = MBOMSETMAT->CHK_SERIAL_FLAG;
    MEMCPY_AN(MBOMSETMAT_N->FLOW, MBOMSETMAT->FLOW, sizeof(MBOMSETMAT->FLOW));
    MEMCPY_AN(MBOMSETMAT_N->OPER, MBOMSETMAT->OPER, sizeof(MBOMSETMAT->OPER));
    MEMCPY_AN(MBOMSETMAT_N->INV_OPER, MBOMSETMAT->INV_OPER, sizeof(MBOMSETMAT->INV_OPER));
    MEMCPY_AN(MBOMSETMAT_N->PART_CMF_1, MBOMSETMAT->PART_CMF_1, sizeof(MBOMSETMAT->PART_CMF_1));
    MEMCPY_AN(MBOMSETMAT_N->PART_CMF_2, MBOMSETMAT->PART_CMF_2, sizeof(MBOMSETMAT->PART_CMF_2));
    MEMCPY_AN(MBOMSETMAT_N->PART_CMF_3, MBOMSETMAT->PART_CMF_3, sizeof(MBOMSETMAT->PART_CMF_3));
    MEMCPY_AN(MBOMSETMAT_N->PART_CMF_4, MBOMSETMAT->PART_CMF_4, sizeof(MBOMSETMAT->PART_CMF_4));
    MEMCPY_AN(MBOMSETMAT_N->PART_CMF_5, MBOMSETMAT->PART_CMF_5, sizeof(MBOMSETMAT->PART_CMF_5));
    MEMCPY_AN(MBOMSETMAT_N->PART_CMF_6, MBOMSETMAT->PART_CMF_6, sizeof(MBOMSETMAT->PART_CMF_6));
    MEMCPY_AN(MBOMSETMAT_N->PART_CMF_7, MBOMSETMAT->PART_CMF_7, sizeof(MBOMSETMAT->PART_CMF_7));
    MEMCPY_AN(MBOMSETMAT_N->PART_CMF_8, MBOMSETMAT->PART_CMF_8, sizeof(MBOMSETMAT->PART_CMF_8));
    MEMCPY_AN(MBOMSETMAT_N->PART_CMF_9, MBOMSETMAT->PART_CMF_9, sizeof(MBOMSETMAT->PART_CMF_9));
    MEMCPY_AN(MBOMSETMAT_N->PART_CMF_10, MBOMSETMAT->PART_CMF_10, sizeof(MBOMSETMAT->PART_CMF_10));
    MEMCPY_AN(MBOMSETMAT_N->CREATE_USER_ID, MBOMSETMAT->CREATE_USER_ID, sizeof(MBOMSETMAT->CREATE_USER_ID));
    MEMCPY_AN(MBOMSETMAT_N->CREATE_TIME, MBOMSETMAT->CREATE_TIME, sizeof(MBOMSETMAT->CREATE_TIME));
    MEMCPY_AN(MBOMSETMAT_N->UPDATE_USER_ID, MBOMSETMAT->UPDATE_USER_ID, sizeof(MBOMSETMAT->UPDATE_USER_ID));
    MEMCPY_AN(MBOMSETMAT_N->UPDATE_TIME, MBOMSETMAT->UPDATE_TIME, sizeof(MBOMSETMAT->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mbomsetmat(struct MBOMSETMAT_N_TAG *MBOMSETMAT_N, struct MBOMSETMAT_TAG *MBOMSETMAT)
{
    MEMCPY_DN(MBOMSETMAT->FACTORY, MBOMSETMAT_N->FACTORY, sizeof(MBOMSETMAT->FACTORY));
    MEMCPY_DN(MBOMSETMAT->BOM_SET_ID, MBOMSETMAT_N->BOM_SET_ID, sizeof(MBOMSETMAT->BOM_SET_ID));
    MBOMSETMAT->BOM_SET_VERSION = MBOMSETMAT_N->BOM_SET_VERSION;
    MBOMSETMAT->SEQ_NUM = MBOMSETMAT_N->SEQ_NUM;
    MEMCPY_DN(MBOMSETMAT->PART_GRP, MBOMSETMAT_N->PART_GRP, sizeof(MBOMSETMAT->PART_GRP));
    MBOMSETMAT->ALT_MAT_FLAG = MBOMSETMAT_N->ALT_MAT_FLAG[0];
    MEMCPY_DN(MBOMSETMAT->MAT_ID, MBOMSETMAT_N->MAT_ID, sizeof(MBOMSETMAT->MAT_ID));
    MBOMSETMAT->MAT_VER = MBOMSETMAT_N->MAT_VER;
    MBOMSETMAT->MAT_QTY = MBOMSETMAT_N->MAT_QTY;
    MEMCPY_DN(MBOMSETMAT->MAT_UNIT, MBOMSETMAT_N->MAT_UNIT, sizeof(MBOMSETMAT->MAT_UNIT));
    MBOMSETMAT->OPT_INPUT_FLAG = MBOMSETMAT_N->OPT_INPUT_FLAG[0];
    MBOMSETMAT->AUTO_INPUT_FLAG = MBOMSETMAT_N->AUTO_INPUT_FLAG[0];
    MBOMSETMAT->SERIAL_INPUT_FLAG = MBOMSETMAT_N->SERIAL_INPUT_FLAG[0];
    MBOMSETMAT->SERIAL_TYPE = MBOMSETMAT_N->SERIAL_TYPE[0];
    MBOMSETMAT->CHK_SERIAL_FLAG = MBOMSETMAT_N->CHK_SERIAL_FLAG[0];
    MEMCPY_DN(MBOMSETMAT->FLOW, MBOMSETMAT_N->FLOW, sizeof(MBOMSETMAT->FLOW));
    MEMCPY_DN(MBOMSETMAT->OPER, MBOMSETMAT_N->OPER, sizeof(MBOMSETMAT->OPER));
    MEMCPY_DN(MBOMSETMAT->INV_OPER, MBOMSETMAT_N->INV_OPER, sizeof(MBOMSETMAT->INV_OPER));
    MEMCPY_DN(MBOMSETMAT->PART_CMF_1, MBOMSETMAT_N->PART_CMF_1, sizeof(MBOMSETMAT->PART_CMF_1));
    MEMCPY_DN(MBOMSETMAT->PART_CMF_2, MBOMSETMAT_N->PART_CMF_2, sizeof(MBOMSETMAT->PART_CMF_2));
