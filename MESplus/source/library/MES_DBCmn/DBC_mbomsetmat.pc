            sprintf(sql + strlen(sql), "PART_CMF_7, ");
            sprintf(sql + strlen(sql), "PART_CMF_8, ");
            sprintf(sql + strlen(sql), "PART_CMF_9, ");
            sprintf(sql + strlen(sql), "PART_CMF_10, ");
            sprintf(sql + strlen(sql), "CREATE_USER_ID, ");
            sprintf(sql + strlen(sql), "CREATE_TIME, ");
            sprintf(sql + strlen(sql), "UPDATE_USER_ID, ");
            sprintf(sql + strlen(sql), "UPDATE_TIME ");
            sprintf(sql + strlen(sql), "FROM MBOMSETMAT WHERE ");
            sprintf(sql + strlen(sql), "FACTORY = '%s' AND BOM_SET_ID = '%s' AND BOM_SET_VERSION = %d AND SEQ_NUM >= %d ",
                MBOMSETMAT_N.FACTORY, MBOMSETMAT_N.BOM_SET_ID, MBOMSETMAT_N.BOM_SET_VERSION, MBOMSETMAT_N.SEQ_NUM);
            if(ISSPACE(MBOMSETMAT->FLOW, sizeof(MBOMSETMAT->FLOW)) == DB_FALSE)
            {
                sprintf(sql + strlen(sql), "AND FLOW = '%s' ", MBOMSETMAT_N.FLOW);
            }
            if(ISSPACE(MBOMSETMAT->OPER, sizeof(MBOMSETMAT->OPER)) == DB_FALSE)
            {
                sprintf(sql + strlen(sql), "AND OPER = '%s' ", MBOMSETMAT_N.OPER);
            }
            sprintf(sql + strlen(sql), "ORDER BY SEQ_NUM ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MBOMSETMAT_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MBOMSETMAT_CUR_2;                 
            break;

		case 3:
            EXEC SQL DECLARE DBC_MBOMSETMAT_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    BOM_SET_ID,
                    BOM_SET_VERSION,
                    SEQ_NUM,
                    PART_GRP,
                    ALT_MAT_FLAG,
                    MAT_ID,
                    MAT_VER,
                    MAT_QTY,
                    MAT_UNIT,
                    OPT_INPUT_FLAG,
                    AUTO_INPUT_FLAG,
                    SERIAL_INPUT_FLAG,
                    SERIAL_TYPE,
                    CHK_SERIAL_FLAG,
                    FLOW,
                    OPER,
                    INV_OPER,
                    PART_CMF_1,
                    PART_CMF_2,
                    PART_CMF_3,
                    PART_CMF_4,
                    PART_CMF_5,
                    PART_CMF_6,
                    PART_CMF_7,
                    PART_CMF_8,
                    PART_CMF_9,
                    PART_CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MBOMSETMAT
                WHERE FACTORY = :MBOMSETMAT_N.FACTORY
                    AND MAT_ID = :MBOMSETMAT_N.MAT_ID
                    AND MAT_VER = :MBOMSETMAT_N.MAT_VER
                ORDER BY BOM_SET_ID ASC;
            EXEC SQL OPEN DBC_MBOMSETMAT_CUR_3;
            break;

		case 4:
            EXEC SQL DECLARE DBC_MBOMSETMAT_CUR_4 CURSOR FOR
                SELECT 
                    FACTORY,
                    BOM_SET_ID,
                    BOM_SET_VERSION,
                    SEQ_NUM,
                    PART_GRP,
                    ALT_MAT_FLAG,
                    MAT_ID,
                    MAT_VER,
                    MAT_QTY,
                    MAT_UNIT,
                    OPT_INPUT_FLAG,
                    AUTO_INPUT_FLAG,
                    SERIAL_INPUT_FLAG,
                    SERIAL_TYPE,
                    CHK_SERIAL_FLAG,
                    FLOW,
                    OPER,
                    INV_OPER,
                    PART_CMF_1,
                    PART_CMF_2,
                    PART_CMF_3,
                    PART_CMF_4,
                    PART_CMF_5,
                    PART_CMF_6,
                    PART_CMF_7,
                    PART_CMF_8,
                    PART_CMF_9,
                    PART_CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MBOMSETMAT
                WHERE FACTORY = :MBOMSETMAT_N.FACTORY
                    AND BOM_SET_ID = :MBOMSETMAT_N.BOM_SET_ID
                    AND BOM_SET_VERSION = (
											SELECT MAX(BOM_SET_VERSION) FROM MBOMSETMAT 
											WHERE FACTORY=:MBOMSETMAT_N.FACTORY
											AND BOM_SET_ID = :MBOMSETMAT_N.BOM_SET_ID
											)
                ORDER BY SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MBOMSETMAT_CUR_4;
            break;

			case 101:
            EXEC SQL DECLARE DBC_MBOMSETMAT_CUR_101 CURSOR FOR
                SELECT 
                    FACTORY,
                    BOM_SET_ID,
                    BOM_SET_VERSION,
                    SEQ_NUM,
                    PART_GRP,
                    ALT_MAT_FLAG,
                    MAT_ID,
                    MAT_VER,
                    MAT_QTY,
                    MAT_UNIT,
                    OPT_INPUT_FLAG,
                    AUTO_INPUT_FLAG,
                    SERIAL_INPUT_FLAG,
                    SERIAL_TYPE,
                    CHK_SERIAL_FLAG,
                    FLOW,
                    OPER,
                    INV_OPER,
                    PART_CMF_1,
                    PART_CMF_2,
                    PART_CMF_3,
                    PART_CMF_4,
                    PART_CMF_5,
                    PART_CMF_6,
                    PART_CMF_7,
                    PART_CMF_8,
                    PART_CMF_9,
                    PART_CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MBOMSETMAT
                WHERE FACTORY = :MBOMSETMAT_N.FACTORY
                    AND BOM_SET_ID = :MBOMSETMAT_N.BOM_SET_ID
                    AND BOM_SET_VERSION = (
											SELECT MAX(BOM_SET_VERSION) FROM MBOMSETMAT 
											WHERE FACTORY=:MBOMSETMAT_N.FACTORY
											AND BOM_SET_ID = :MBOMSETMAT_N.BOM_SET_ID
											)
					AND OPER = :MBOMSETMAT_N.OPER
                ORDER BY SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MBOMSETMAT_CUR_101;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mbomsetmat", sel_type);
}


