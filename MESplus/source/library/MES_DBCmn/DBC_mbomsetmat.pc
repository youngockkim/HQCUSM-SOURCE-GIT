/* SQL UPDATE Function */
void DBC_update_mbomsetmat(int sel_type, struct MBOMSETMAT_TAG *MBOMSETMAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBOMSETMAT_N_TAG MBOMSETMAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbomsetmat(&MBOMSETMAT_N, MBOMSETMAT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MBOMSETMAT SET
                    PART_GRP = :MBOMSETMAT_N.PART_GRP,
                    ALT_MAT_FLAG = :MBOMSETMAT_N.ALT_MAT_FLAG,
                    MAT_ID = :MBOMSETMAT_N.MAT_ID,
                    MAT_VER = :MBOMSETMAT_N.MAT_VER,
                    MAT_QTY = :MBOMSETMAT_N.MAT_QTY,
                    MAT_UNIT = :MBOMSETMAT_N.MAT_UNIT,
                    OPT_INPUT_FLAG = :MBOMSETMAT_N.OPT_INPUT_FLAG,
                    AUTO_INPUT_FLAG = :MBOMSETMAT_N.AUTO_INPUT_FLAG,
                    SERIAL_INPUT_FLAG = :MBOMSETMAT_N.SERIAL_INPUT_FLAG,
                    SERIAL_TYPE = :MBOMSETMAT_N.SERIAL_TYPE,
                    CHK_SERIAL_FLAG = :MBOMSETMAT_N.CHK_SERIAL_FLAG,
                    FLOW = :MBOMSETMAT_N.FLOW,
                    OPER = :MBOMSETMAT_N.OPER,
                    INV_OPER = :MBOMSETMAT_N.INV_OPER,
                    PART_CMF_1 = :MBOMSETMAT_N.PART_CMF_1,
                    PART_CMF_2 = :MBOMSETMAT_N.PART_CMF_2,
                    PART_CMF_3 = :MBOMSETMAT_N.PART_CMF_3,
                    PART_CMF_4 = :MBOMSETMAT_N.PART_CMF_4,
                    PART_CMF_5 = :MBOMSETMAT_N.PART_CMF_5,
                    PART_CMF_6 = :MBOMSETMAT_N.PART_CMF_6,
                    PART_CMF_7 = :MBOMSETMAT_N.PART_CMF_7,
                    PART_CMF_8 = :MBOMSETMAT_N.PART_CMF_8,
                    PART_CMF_9 = :MBOMSETMAT_N.PART_CMF_9,
                    PART_CMF_10 = :MBOMSETMAT_N.PART_CMF_10,
                    CREATE_USER_ID = :MBOMSETMAT_N.CREATE_USER_ID,
                    CREATE_TIME = :MBOMSETMAT_N.CREATE_TIME,
                    UPDATE_USER_ID = :MBOMSETMAT_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MBOMSETMAT_N.UPDATE_TIME
                WHERE FACTORY = :MBOMSETMAT_N.FACTORY
                    AND BOM_SET_ID = :MBOMSETMAT_N.BOM_SET_ID
                    AND BOM_SET_VERSION = :MBOMSETMAT_N.BOM_SET_VERSION
                    AND SEQ_NUM = :MBOMSETMAT_N.SEQ_NUM;
            break;

        case 2:
            EXEC SQL UPDATE MBOMSETMAT SET
                    SEQ_NUM = SEQ_NUM - 1
                WHERE FACTORY = :MBOMSETMAT_N.FACTORY
                    AND BOM_SET_ID = :MBOMSETMAT_N.BOM_SET_ID
                    AND BOM_SET_VERSION = :MBOMSETMAT_N.BOM_SET_VERSION
                    AND SEQ_NUM > :MBOMSETMAT_N.SEQ_NUM;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mbomsetmat", sel_type);
}


