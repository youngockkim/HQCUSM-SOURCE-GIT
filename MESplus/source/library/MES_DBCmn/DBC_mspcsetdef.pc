/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mspcsetdef(int sel_type, struct MSPCSETDEF_TAG *MSPCSETDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSPCSETDEF_N_TAG MSPCSETDEF_N;
        char   sql[5120];
        char   ts1[100];
        char   ts2[100];
        char   ts3[100];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();


    DBC_add_null_mspcsetdef(&MSPCSETDEF_N, MSPCSETDEF);
    DB_error_code = 0;

    memset( ts1, 0x00, sizeof(ts1));
    memset( ts2, 0x00, sizeof(ts2));
    memset( ts3, 0x00, sizeof(ts3));

    switch(sel_type)
    {
        case 1:
            memset( sql, 0x00, sizeof(sql));
            sprintf(sql,               "SELECT CHART_SET_ID, CHART_SET_DESC FROM MSPCSETDEF WHERE ");
  
            make_valid_quote(ts1, MSPCSETDEF_N.FACTORY);
            make_valid_quote(ts2, MSPCSETDEF_N.CHART_SET_ID);

            sprintf(sql + strlen(sql), "FACTORY = '%s' AND CHART_SET_ID >= '%s' ",ts1, ts2);             
          
            if(ISSPACE(MSPCSETDEF->MAT_ID, sizeof(MSPCSETDEF->MAT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts1, MSPCSETDEF_N.MAT_ID);
                sprintf(sql + strlen(sql), "AND MAT_ID = '%s' ", ts1);
            }
            if(MSPCSETDEF->MAT_VER != 0) /* Add for V42 */
            {
                sprintf(sql + strlen(sql), "AND MAT_VER = %d ", MSPCSETDEF_N.MAT_VER);
            }
            if(ISSPACE(MSPCSETDEF->FLOW, sizeof(MSPCSETDEF->FLOW)) == DB_FALSE)
            {
                make_valid_quote(ts1, MSPCSETDEF_N.FLOW);
                sprintf(sql + strlen(sql), "AND FLOW = '%s' ", ts1);
            }            
            if(ISSPACE(MSPCSETDEF->OPER, sizeof(MSPCSETDEF->OPER)) == DB_FALSE)
            {
                make_valid_quote(ts1, MSPCSETDEF_N.OPER);
                sprintf(sql + strlen(sql), "AND OPER = '%s' ", ts1);
            }
            if(ISSPACE(MSPCSETDEF->RES_ID, sizeof(MSPCSETDEF->RES_ID)) == DB_FALSE)
            {
                make_valid_quote(ts1, MSPCSETDEF_N.RES_ID);
                sprintf(sql + strlen(sql), "AND RES_ID = '%s' ", ts1);
            }
            if(MSPCSETDEF->LOT_RES_FLAG != ' ')
            {
                sprintf(sql + strlen(sql), "AND LOT_RES_FLAG = '%c' ", MSPCSETDEF_N.LOT_RES_FLAG[0]);
            }
            sprintf(sql + strlen(sql), "ORDER BY CHART_SET_ID ASC");


            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MSPCSETDEF_CUR_1 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MSPCSETDEF_CUR_1;                 
            break;            
        
        case 2:
            memset( sql, 0x00, sizeof(sql));
            sprintf(sql,               "SELECT CHART_SET_ID, CHART_SET_DESC FROM MSPCSETDEF WHERE ");
  
            make_valid_quote(ts1, MSPCSETDEF_N.FACTORY);
            make_valid_quote(ts2, MSPCSETDEF_N.CHART_SET_ID);

            sprintf(sql + strlen(sql), "FACTORY = '%s' AND CHART_SET_ID >= '%s' ",ts1, ts2);             
          
            make_valid_quote(ts1, MSPCSETDEF_N.MAT_ID);
            make_valid_quote(ts2, MSPCSETDEF_N.FLOW);
            make_valid_quote(ts3, MSPCSETDEF_N.OPER);
            /* Add for V42 */
            /*
            sprintf(sql + strlen(sql), "AND ((MAT_ID = '%s' AND MAT_VER = %d AND FLOW = '%s' AND OPER = '%s') ", ts1, MSPCSETDEF_N.MAT_VER, ts2, ts3);
            sprintf(sql + strlen(sql), "OR (MAT_ID = ' ' AND FLOW = '%s' AND OPER = '%s') ", ts2, ts3);
            sprintf(sql + strlen(sql), "OR (MAT_ID = ' ' AND FLOW = ' ' AND OPER = '%s') ", ts3);
            sprintf(sql + strlen(sql), "OR (MAT_ID = '%s' AND FLOW = ' ' AND OPER = '%s')) ", ts1, ts3);
            */
            if(ISSPACE(MSPCSETDEF->RES_ID, sizeof(MSPCSETDEF->RES_ID)) == DB_FALSE)
            {
                make_valid_quote(ts1, MSPCSETDEF_N.RES_ID);
                sprintf(sql + strlen(sql), "AND RES_ID = '%s' ", ts1);
            }
            if(MSPCSETDEF->LOT_RES_FLAG != ' ')
            {
                sprintf(sql + strlen(sql), "AND LOT_RES_FLAG = '%c' ", MSPCSETDEF_N.LOT_RES_FLAG[0]);
            }
            sprintf(sql + strlen(sql), "ORDER BY CHART_SET_ID ASC");


            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MSPCSETDEF_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MSPCSETDEF_CUR_2;                 
            break;           
    
        case 3:
            EXEC SQL DECLARE DBC_MSPCSETDEF_CUR_3 CURSOR FOR
                SELECT CHART_SET_ID, CHART_SET_DESC 
                FROM MSPCSETDEF
                WHERE FACTORY = :MSPCSETDEF_N.FACTORY
                    AND LOT_RES_FLAG = 'L'
                    AND MAT_ID = :MSPCSETDEF_N.MAT_ID
                    AND FLOW = :MSPCSETDEF_N.FLOW
                    AND OPER = :MSPCSETDEF_N.OPER
                    ORDER BY CHART_SET_ID ASC;
            EXEC SQL OPEN DBC_MSPCSETDEF_CUR_3;
            break; 

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mspcsetdef", sel_type);
}


