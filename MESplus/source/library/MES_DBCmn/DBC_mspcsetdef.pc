            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mspcsetdef(&MSPCSETDEF_N, MSPCSETDEF);
    }
    DB_stop_query_timer("DBC_fetch_mspcsetdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mspcsetdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MSPCSETDEF_CUR_1;
            break;
        case 2:
            EXEC SQL CLOSE DBC_MSPCSETDEF_CUR_2;
            break;
        case 3:
            EXEC SQL CLOSE DBC_MSPCSETDEF_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mspcsetdef", sel_type);
}


/* Initialize Function */
void DBC_init_mspcsetdef(struct MSPCSETDEF_TAG *MSPCSETDEF)
{
    /* memset by Space */
    memset(MSPCSETDEF, ' ', sizeof(struct MSPCSETDEF_TAG));
    
    MSPCSETDEF->MAT_VER = 0;
}


/* Add Null Function */
void DBC_add_null_mspcsetdef(struct MSPCSETDEF_N_TAG *MSPCSETDEF_N, struct MSPCSETDEF_TAG *MSPCSETDEF)
{
    /* memset by NULL */
    memset(MSPCSETDEF_N, '\0', sizeof(struct MSPCSETDEF_N_TAG));
    
    MEMCPY_AN(MSPCSETDEF_N->FACTORY, MSPCSETDEF->FACTORY, sizeof(MSPCSETDEF->FACTORY));
