/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwiplotlnr(int sel_type, struct MWIPLOTLNR_TAG *MWIPLOTLNR)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTLNR_N_TAG MWIPLOTLNR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplotlnr(&MWIPLOTLNR_N, MWIPLOTLNR);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPLOTLNR_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    QTY_FLAG,
                    SEQ_NUM,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_ID,
                    REASON_CODE,
                    REASON_QTY
                FROM MWIPLOTLNR
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC,
                    QTY_FLAG ASC,
                    SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPLOTLNR_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwiplotlnr", sel_type);
}


