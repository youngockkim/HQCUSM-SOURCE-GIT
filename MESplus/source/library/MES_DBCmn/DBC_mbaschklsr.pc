    MEMCPY_AN(MBASCHKLSR_N->EVENT_ID, MBASCHKLSR->EVENT_ID, sizeof(MBASCHKLSR->EVENT_ID));
    MEMCPY_AN(MBASCHKLSR_N->CHKLIST_ID, MBASCHKLSR->CHKLIST_ID, sizeof(MBASCHKLSR->CHKLIST_ID));
