                    APPLY_FROM_TIME = :MBASCHKLSR_N.APPLY_FROM_TIME,
                    APPLY_TO_TIME = :MBASCHKLSR_N.APPLY_TO_TIME,
                    REQ_COMPLETE_FLAG = :MBASCHKLSR_N.REQ_COMPLETE_FLAG,
                    COMPLETE_USER_ID = :MBASCHKLSR_N.COMPLETE_USER_ID,
                    INHERIT_CHILD_FLAG = :MBASCHKLSR_N.INHERIT_CHILD_FLAG,
                    KEY_1_REQ = :MBASCHKLSR_N.KEY_1_REQ,
                    KEY_2_REQ = :MBASCHKLSR_N.KEY_2_REQ,
                    KEY_3_REQ = :MBASCHKLSR_N.KEY_3_REQ,
                    KEY_4_REQ = :MBASCHKLSR_N.KEY_4_REQ,
                    KEY_5_REQ = :MBASCHKLSR_N.KEY_5_REQ,
                    KEY_6_REQ = :MBASCHKLSR_N.KEY_6_REQ,
                    KEY_7_REQ = :MBASCHKLSR_N.KEY_7_REQ,
                    KEY_8_REQ = :MBASCHKLSR_N.KEY_8_REQ,
                    KEY_9_REQ = :MBASCHKLSR_N.KEY_9_REQ,
                    KEY_10_REQ = :MBASCHKLSR_N.KEY_10_REQ
                WHERE FACTORY = :MBASCHKLSR_N.FACTORY
                    AND REL_LEVEL = :MBASCHKLSR_N.REL_LEVEL
                    AND MAT_ID = :MBASCHKLSR_N.MAT_ID
                    AND MAT_VER = :MBASCHKLSR_N.MAT_VER
                    AND FLOW = :MBASCHKLSR_N.FLOW
                    AND OPER = :MBASCHKLSR_N.OPER
                    AND BA_POINT = :MBASCHKLSR_N.BA_POINT
                    AND LOT_ID = :MBASCHKLSR_N.LOT_ID
                    AND TRAN_CODE = :MBASCHKLSR_N.TRAN_CODE
                    AND RESG_ID = :MBASCHKLSR_N.RESG_ID
                    AND RES_TYPE = :MBASCHKLSR_N.RES_TYPE
                    AND RES_ID = :MBASCHKLSR_N.RES_ID
                    AND EVENT_ID = :MBASCHKLSR_N.EVENT_ID
                    AND CHKLIST_ID = :MBASCHKLSR_N.CHKLIST_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_update_mbaschklsr", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mbaschklsr(int sel_type, struct MBASCHKLSR_TAG *MBASCHKLSR)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBASCHKLSR_N_TAG MBASCHKLSR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbaschklsr(&MBASCHKLSR_N, MBASCHKLSR);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MBASCHKLSR_CUR_1 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    REL_LEVEL,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    BA_POINT,
                    LOT_ID,
                    TRAN_CODE,
                    RESG_ID,
                    RES_TYPE,
                    RES_ID,
                    EVENT_ID,
                    CHKLIST_ID,
                    REL_KEY,
                    APPLY_FROM_TIME,
                    APPLY_TO_TIME,
                    REQ_COMPLETE_FLAG,
                    COMPLETE_USER_ID,
                    INHERIT_CHILD_FLAG,
                    KEY_1_REQ,
                    KEY_2_REQ,
                    KEY_3_REQ,
                    KEY_4_REQ,
                    KEY_5_REQ,
                    KEY_6_REQ,
                    KEY_7_REQ,
                    KEY_8_REQ,
                    KEY_9_REQ,
                    KEY_10_REQ
                FROM MBASCHKLSR
                ORDER BY FACTORY ASC,
                    REL_LEVEL ASC,
                    MAT_ID ASC,
                    MAT_VER ASC,
                    FLOW ASC,
                    OPER ASC,
                    BA_POINT ASC,
                    LOT_ID ASC,
                    TRAN_CODE ASC,
                    RESG_ID ASC,
                    RES_TYPE ASC,
                    RES_ID ASC,
                    EVENT_ID ASC,
                    CHKLIST_ID ASC;
            EXEC SQL OPEN DBC_MBASCHKLSR_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MBASCHKLSR_CUR_2 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    REL_LEVEL,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    BA_POINT,
                    LOT_ID,
                    TRAN_CODE,
                    RESG_ID,
                    RES_TYPE,
                    RES_ID,
                    EVENT_ID,
                    CHKLIST_ID,
                    REL_KEY,
                    APPLY_FROM_TIME,
                    APPLY_TO_TIME,
                    REQ_COMPLETE_FLAG,
                    COMPLETE_USER_ID,
                    INHERIT_CHILD_FLAG,
                    KEY_1_REQ,
                    KEY_2_REQ,
                    KEY_3_REQ,
                    KEY_4_REQ,
                    KEY_5_REQ,
                    KEY_6_REQ,
                    KEY_7_REQ,
                    KEY_8_REQ,
                    KEY_9_REQ,
                    KEY_10_REQ
                FROM MBASCHKLSR
                WHERE FACTORY = :MBASCHKLSR_N.FACTORY
                    AND REL_LEVEL = :MBASCHKLSR_N.REL_LEVEL
                    AND MAT_ID = :MBASCHKLSR_N.MAT_ID
                    AND MAT_VER = :MBASCHKLSR_N.MAT_VER
                    AND FLOW = :MBASCHKLSR_N.FLOW
                    AND OPER = :MBASCHKLSR_N.OPER
                    AND RESG_ID = :MBASCHKLSR_N.RESG_ID
                    AND RES_TYPE = :MBASCHKLSR_N.RES_TYPE
                    AND RES_ID = :MBASCHKLSR_N.RES_ID
                    AND CHKLIST_ID >= :MBASCHKLSR_N.CHKLIST_ID
                ORDER BY CHKLIST_ID;
            EXEC SQL OPEN DBC_MBASCHKLSR_CUR_2;
            break;

        /* Find Cheklist will be used by Lot-Transaction or Resource-Event */
        case 3:
            EXEC SQL DECLARE DBC_MBASCHKLSR_CUR_3 CURSOR FOR
                SELECT 
                    R.CREATE_USER_ID,
                    R.CREATE_TIME,
                    R.UPDATE_USER_ID,
                    R.UPDATE_TIME,
                    R.FACTORY,
                    R.REL_LEVEL,
                    R.MAT_ID,
                    R.MAT_VER,
                    R.FLOW,
                    R.OPER,
                    R.BA_POINT,
                    R.LOT_ID,
                    R.TRAN_CODE,
                    R.RESG_ID,
                    R.RES_TYPE,
                    R.RES_ID,
                    R.EVENT_ID,
                    R.CHKLIST_ID,
                    R.REL_KEY,
                    R.APPLY_FROM_TIME,
                    R.APPLY_TO_TIME,
                    R.REQ_COMPLETE_FLAG,
                    R.COMPLETE_USER_ID,
                    R.INHERIT_CHILD_FLAG,
                    R.KEY_1_REQ,
                    R.KEY_2_REQ,
                    R.KEY_3_REQ,
                    R.KEY_4_REQ,
                    R.KEY_5_REQ,
                    R.KEY_6_REQ,
                    R.KEY_7_REQ,
                    R.KEY_8_REQ,
                    R.KEY_9_REQ,
                    R.KEY_10_REQ
                FROM MBASCHKLSR R, MBASCHKLST T
                WHERE R.FACTORY = :MBASCHKLSR_N.FACTORY
                AND (
                      /*MFO*/
                      (REL_LEVEL = '1' AND MAT_ID = :MBASCHKLSR_N.MAT_ID AND MAT_VER = :MBASCHKLSR_N.MAT_VER AND FLOW = :MBASCHKLSR_N.FLOW AND OPER = :MBASCHKLSR_N.OPER) OR
                      (REL_LEVEL = '2' AND FLOW = :MBASCHKLSR_N.FLOW AND OPER = :MBASCHKLSR_N.OPER) OR
                      (REL_LEVEL = '3' AND OPER = :MBASCHKLSR_N.OPER) OR
                      (REL_LEVEL = '4' AND MAT_ID = :MBASCHKLSR_N.MAT_ID AND MAT_VER = :MBASCHKLSR_N.MAT_VER AND OPER = :MBASCHKLSR_N.OPER) OR
                      (REL_LEVEL = '5' AND MAT_ID = :MBASCHKLSR_N.MAT_ID AND MAT_VER = :MBASCHKLSR_N.MAT_VER AND FLOW = :MBASCHKLSR_N.FLOW) OR
                      (REL_LEVEL = '6' AND MAT_ID = :MBASCHKLSR_N.MAT_ID AND MAT_VER = :MBASCHKLSR_N.MAT_VER) OR
                      (REL_LEVEL = '7' AND FLOW = :MBASCHKLSR_N.FLOW) OR
                      (REL_LEVEL = '8' AND R.FACTORY = :MBASCHKLSR_N.FACTORY) OR
                      /*RAS*/
                      (REL_LEVEL = 'T' AND RES_TYPE = :MBASCHKLSR_N.RES_TYPE) OR
                      (REL_LEVEL = 'G' AND RESG_ID = :MBASCHKLSR_N.RESG_ID) OR
                      (REL_LEVEL = 'R' AND RES_ID = :MBASCHKLSR_N.RES_ID) 
                    )
                AND (
                      /*MFO*/
                      (REL_LEVEL IN ('1', '2', '3', '4', '5', '6', '7', '8') AND
                       TRAN_CODE LIKE :MBASCHKLSR_N.TRAN_CODE AND
                       (LOT_ID = ' ' OR LOT_ID = :MBASCHKLSR_N.LOT_ID)
                      ) OR
                      /*RAS*/
                      (REL_LEVEL IN ('T', 'G', 'R') AND
                       EVENT_ID LIKE :MBASCHKLSR_N.EVENT_ID
                      )
                    )
                AND BA_POINT LIKE :MBASCHKLSR_N.BA_POINT
                AND (APPLY_FROM_TIME = ' ' OR APPLY_FROM_TIME <= :MBASCHKLSR_N.APPLY_FROM_TIME)
                AND (APPLY_TO_TIME = ' ' OR APPLY_TO_TIME >= :MBASCHKLSR_N.APPLY_TO_TIME)
                AND R.CHKLIST_ID >= :MBASCHKLSR_N.CHKLIST_ID
                AND R.FACTORY = T.FACTORY
                AND R.CHKLIST_ID = T.CHKLIST_ID
                AND T.CHKLIST_TYPE LIKE :DBC_Q_COND_N.KEY_1
                ORDER BY R.CHKLIST_ID;
            EXEC SQL OPEN DBC_MBASCHKLSR_CUR_3;
            break;

        /* Find Cheklist will be used by Lot-Transaction or Resource-Event */
        case 4:
            EXEC SQL DECLARE DBC_MBASCHKLSR_CUR_4 CURSOR FOR
                SELECT 
                    DISTINCT T.CHKLIST_TYPE
                FROM MBASCHKLSR R, MBASCHKLST T
                WHERE R.FACTORY = :MBASCHKLSR_N.FACTORY
                AND (
                      /*MFO*/
                      (REL_LEVEL = '1' AND MAT_ID = :MBASCHKLSR_N.MAT_ID AND MAT_VER = :MBASCHKLSR_N.MAT_VER AND FLOW = :MBASCHKLSR_N.FLOW AND OPER = :MBASCHKLSR_N.OPER) OR
                      (REL_LEVEL = '2' AND FLOW = :MBASCHKLSR_N.FLOW AND OPER = :MBASCHKLSR_N.OPER) OR
                      (REL_LEVEL = '3' AND OPER = :MBASCHKLSR_N.OPER) OR
                      (REL_LEVEL = '4' AND MAT_ID = :MBASCHKLSR_N.MAT_ID AND MAT_VER = :MBASCHKLSR_N.MAT_VER AND OPER = :MBASCHKLSR_N.OPER) OR
                      (REL_LEVEL = '5' AND MAT_ID = :MBASCHKLSR_N.MAT_ID AND MAT_VER = :MBASCHKLSR_N.MAT_VER AND FLOW = :MBASCHKLSR_N.FLOW) OR
                      (REL_LEVEL = '6' AND MAT_ID = :MBASCHKLSR_N.MAT_ID AND MAT_VER = :MBASCHKLSR_N.MAT_VER) OR
                      (REL_LEVEL = '6' AND FLOW = :MBASCHKLSR_N.FLOW) OR
                      (REL_LEVEL = '8' AND R.FACTORY = :MBASCHKLSR_N.FACTORY) OR
                      /*RAS*/
                      (REL_LEVEL = 'T' AND RES_TYPE = :MBASCHKLSR_N.RES_TYPE) OR
                      (REL_LEVEL = 'G' AND RESG_ID = :MBASCHKLSR_N.RESG_ID) OR
                      (REL_LEVEL = 'R' AND RES_ID = :MBASCHKLSR_N.RES_ID) 
                    )
                AND (
                      /*MFO*/
                      (REL_LEVEL IN ('1', '2', '3', '4', '5', '6', '7', '8') AND
                       TRAN_CODE = :MBASCHKLSR_N.TRAN_CODE AND
                       (LOT_ID = ' ' OR LOT_ID = :MBASCHKLSR_N.LOT_ID)
                      ) OR
                      /*RAS*/
                      (REL_LEVEL IN ('T', 'G', 'R') AND
                       EVENT_ID = :MBASCHKLSR_N.EVENT_ID
                      )
                    )
                AND BA_POINT = :MBASCHKLSR_N.BA_POINT
                AND BA_POINT <> ' '
                AND (APPLY_FROM_TIME = ' ' OR APPLY_FROM_TIME <= :MBASCHKLSR_N.APPLY_FROM_TIME)
                AND (APPLY_TO_TIME = ' ' OR APPLY_TO_TIME >= :MBASCHKLSR_N.APPLY_TO_TIME)
                AND R.FACTORY = T.FACTORY
                AND R.CHKLIST_ID = T.CHKLIST_ID
                ORDER BY T.CHKLIST_TYPE;
            EXEC SQL OPEN DBC_MBASCHKLSR_CUR_4;
            break;

        /* Find Cheklist will be copyed by split-lot */
        case 5:
            EXEC SQL DECLARE DBC_MBASCHKLSR_CUR_5 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    REL_LEVEL,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    BA_POINT,
                    LOT_ID,
                    TRAN_CODE,
                    RESG_ID,
                    RES_TYPE,
                    RES_ID,
                    EVENT_ID,
                    CHKLIST_ID,
                    REL_KEY,
                    APPLY_FROM_TIME,
                    APPLY_TO_TIME,
                    REQ_COMPLETE_FLAG,
                    COMPLETE_USER_ID,
                    INHERIT_CHILD_FLAG,
                    KEY_1_REQ,
                    KEY_2_REQ,
                    KEY_3_REQ,
                    KEY_4_REQ,
                    KEY_5_REQ,
                    KEY_6_REQ,
                    KEY_7_REQ,
                    KEY_8_REQ,
                    KEY_9_REQ,
                    KEY_10_REQ
                FROM MBASCHKLSR
                WHERE FACTORY = :MBASCHKLSR_N.FACTORY
                AND LOT_ID = :MBASCHKLSR_N.LOT_ID
                AND INHERIT_CHILD_FLAG = :MBASCHKLSR_N.INHERIT_CHILD_FLAG
                ORDER BY CHKLIST_ID, REL_KEY;
            EXEC SQL OPEN DBC_MBASCHKLSR_CUR_5;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mbaschklsr", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mbaschklsr(int sel_type, struct MBASCHKLSR_TAG *MBASCHKLSR)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBASCHKLSR_N_TAG MBASCHKLSR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MBASCHKLSR_CUR_1 INTO
                :MBASCHKLSR_N.CREATE_USER_ID,
                :MBASCHKLSR_N.CREATE_TIME,
                :MBASCHKLSR_N.UPDATE_USER_ID,
                :MBASCHKLSR_N.UPDATE_TIME,
                :MBASCHKLSR_N.FACTORY,
                :MBASCHKLSR_N.REL_LEVEL,
                :MBASCHKLSR_N.MAT_ID,
                :MBASCHKLSR_N.MAT_VER,
                :MBASCHKLSR_N.FLOW,
                :MBASCHKLSR_N.OPER,
                :MBASCHKLSR_N.BA_POINT,
                :MBASCHKLSR_N.LOT_ID,
                :MBASCHKLSR_N.TRAN_CODE,
                :MBASCHKLSR_N.RESG_ID,
                :MBASCHKLSR_N.RES_TYPE,
                :MBASCHKLSR_N.RES_ID,
                :MBASCHKLSR_N.EVENT_ID,
                :MBASCHKLSR_N.CHKLIST_ID,
                :MBASCHKLSR_N.REL_KEY,
                :MBASCHKLSR_N.APPLY_FROM_TIME,
                :MBASCHKLSR_N.APPLY_TO_TIME,
                :MBASCHKLSR_N.REQ_COMPLETE_FLAG,
                :MBASCHKLSR_N.COMPLETE_USER_ID,
                :MBASCHKLSR_N.INHERIT_CHILD_FLAG,
                :MBASCHKLSR_N.KEY_1_REQ,
                :MBASCHKLSR_N.KEY_2_REQ,
                :MBASCHKLSR_N.KEY_3_REQ,
                :MBASCHKLSR_N.KEY_4_REQ,
                :MBASCHKLSR_N.KEY_5_REQ,
                :MBASCHKLSR_N.KEY_6_REQ,
                :MBASCHKLSR_N.KEY_7_REQ,
                :MBASCHKLSR_N.KEY_8_REQ,
                :MBASCHKLSR_N.KEY_9_REQ,
                :MBASCHKLSR_N.KEY_10_REQ;
            break;

        case 2:
            EXEC SQL FETCH DBC_MBASCHKLSR_CUR_2 INTO
                :MBASCHKLSR_N.CREATE_USER_ID,
                :MBASCHKLSR_N.CREATE_TIME,
                :MBASCHKLSR_N.UPDATE_USER_ID,
                :MBASCHKLSR_N.UPDATE_TIME,
                :MBASCHKLSR_N.FACTORY,
                :MBASCHKLSR_N.REL_LEVEL,
                :MBASCHKLSR_N.MAT_ID,
                :MBASCHKLSR_N.MAT_VER,
                :MBASCHKLSR_N.FLOW,
                :MBASCHKLSR_N.OPER,
                :MBASCHKLSR_N.BA_POINT,
                :MBASCHKLSR_N.LOT_ID,
                :MBASCHKLSR_N.TRAN_CODE,
                :MBASCHKLSR_N.RESG_ID,
                :MBASCHKLSR_N.RES_TYPE,
                :MBASCHKLSR_N.RES_ID,
                :MBASCHKLSR_N.EVENT_ID,
                :MBASCHKLSR_N.CHKLIST_ID,
                :MBASCHKLSR_N.REL_KEY,
                :MBASCHKLSR_N.APPLY_FROM_TIME,
                :MBASCHKLSR_N.APPLY_TO_TIME,
                :MBASCHKLSR_N.REQ_COMPLETE_FLAG,
                :MBASCHKLSR_N.COMPLETE_USER_ID,
                :MBASCHKLSR_N.INHERIT_CHILD_FLAG,
                :MBASCHKLSR_N.KEY_1_REQ,
                :MBASCHKLSR_N.KEY_2_REQ,
                :MBASCHKLSR_N.KEY_3_REQ,
                :MBASCHKLSR_N.KEY_4_REQ,
                :MBASCHKLSR_N.KEY_5_REQ,
                :MBASCHKLSR_N.KEY_6_REQ,
                :MBASCHKLSR_N.KEY_7_REQ,
                :MBASCHKLSR_N.KEY_8_REQ,
                :MBASCHKLSR_N.KEY_9_REQ,
                :MBASCHKLSR_N.KEY_10_REQ;
            break;

        case 3:
            EXEC SQL FETCH DBC_MBASCHKLSR_CUR_3 INTO
                :MBASCHKLSR_N.CREATE_USER_ID,
                :MBASCHKLSR_N.CREATE_TIME,
                :MBASCHKLSR_N.UPDATE_USER_ID,
                :MBASCHKLSR_N.UPDATE_TIME,
                :MBASCHKLSR_N.FACTORY,
                :MBASCHKLSR_N.REL_LEVEL,
                :MBASCHKLSR_N.MAT_ID,
                :MBASCHKLSR_N.MAT_VER,
                :MBASCHKLSR_N.FLOW,
                :MBASCHKLSR_N.OPER,
                :MBASCHKLSR_N.BA_POINT,
                :MBASCHKLSR_N.LOT_ID,
                :MBASCHKLSR_N.TRAN_CODE,
                :MBASCHKLSR_N.RESG_ID,
                :MBASCHKLSR_N.RES_TYPE,
                :MBASCHKLSR_N.RES_ID,
                :MBASCHKLSR_N.EVENT_ID,
                :MBASCHKLSR_N.CHKLIST_ID,
                :MBASCHKLSR_N.REL_KEY,
                :MBASCHKLSR_N.APPLY_FROM_TIME,
                :MBASCHKLSR_N.APPLY_TO_TIME,
                :MBASCHKLSR_N.REQ_COMPLETE_FLAG,
                :MBASCHKLSR_N.COMPLETE_USER_ID,
                :MBASCHKLSR_N.INHERIT_CHILD_FLAG,
                :MBASCHKLSR_N.KEY_1_REQ,
                :MBASCHKLSR_N.KEY_2_REQ,
                :MBASCHKLSR_N.KEY_3_REQ,
                :MBASCHKLSR_N.KEY_4_REQ,
                :MBASCHKLSR_N.KEY_5_REQ,
                :MBASCHKLSR_N.KEY_6_REQ,
                :MBASCHKLSR_N.KEY_7_REQ,
                :MBASCHKLSR_N.KEY_8_REQ,
                :MBASCHKLSR_N.KEY_9_REQ,
                :MBASCHKLSR_N.KEY_10_REQ;
            break;

        case 4:
            EXEC SQL FETCH DBC_MBASCHKLSR_CUR_4 INTO
                :DBC_Q_COND_N.KEY_1;
            break;

        case 5:
            EXEC SQL FETCH DBC_MBASCHKLSR_CUR_5 INTO
                :MBASCHKLSR_N.CREATE_USER_ID,
                :MBASCHKLSR_N.CREATE_TIME,
                :MBASCHKLSR_N.UPDATE_USER_ID,
                :MBASCHKLSR_N.UPDATE_TIME,
                :MBASCHKLSR_N.FACTORY,
                :MBASCHKLSR_N.REL_LEVEL,
                :MBASCHKLSR_N.MAT_ID,
                :MBASCHKLSR_N.MAT_VER,
                :MBASCHKLSR_N.FLOW,
                :MBASCHKLSR_N.OPER,
                :MBASCHKLSR_N.BA_POINT,
                :MBASCHKLSR_N.LOT_ID,
                :MBASCHKLSR_N.TRAN_CODE,
                :MBASCHKLSR_N.RESG_ID,
                :MBASCHKLSR_N.RES_TYPE,
                :MBASCHKLSR_N.RES_ID,
                :MBASCHKLSR_N.EVENT_ID,
                :MBASCHKLSR_N.CHKLIST_ID,
                :MBASCHKLSR_N.REL_KEY,
                :MBASCHKLSR_N.APPLY_FROM_TIME,
                :MBASCHKLSR_N.APPLY_TO_TIME,
                :MBASCHKLSR_N.REQ_COMPLETE_FLAG,
                :MBASCHKLSR_N.COMPLETE_USER_ID,
                :MBASCHKLSR_N.INHERIT_CHILD_FLAG,
                :MBASCHKLSR_N.KEY_1_REQ,
                :MBASCHKLSR_N.KEY_2_REQ,
                :MBASCHKLSR_N.KEY_3_REQ,
                :MBASCHKLSR_N.KEY_4_REQ,
                :MBASCHKLSR_N.KEY_5_REQ,
                :MBASCHKLSR_N.KEY_6_REQ,
                :MBASCHKLSR_N.KEY_7_REQ,
                :MBASCHKLSR_N.KEY_8_REQ,
                :MBASCHKLSR_N.KEY_9_REQ,
                :MBASCHKLSR_N.KEY_10_REQ;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mbaschklsr(&MBASCHKLSR_N, MBASCHKLSR);
        if(sel_type == 4) DB_del_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
    }

    DB_stop_query_timer("DBC_fetch_mbaschklsr", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mbaschklsr(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MBASCHKLSR_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MBASCHKLSR_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MBASCHKLSR_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MBASCHKLSR_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MBASCHKLSR_CUR_5;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("DBC_close_mbaschklsr", sel_type);
}


/* Initialize Function */
void DBC_init_mbaschklsr(struct MBASCHKLSR_TAG *MBASCHKLSR)
{
    /* memset by Space */
    memset(MBASCHKLSR, ' ', sizeof(struct MBASCHKLSR_TAG));
    
    MBASCHKLSR->MAT_VER = 0;
}


/* Add Null Function */
void DBC_add_null_mbaschklsr(struct MBASCHKLSR_N_TAG *MBASCHKLSR_N, struct MBASCHKLSR_TAG *MBASCHKLSR)
{
    /* memset by NULL */
    memset(MBASCHKLSR_N, '\0', sizeof(struct MBASCHKLSR_N_TAG));
    
    MEMCPY_AN(MBASCHKLSR_N->CREATE_USER_ID, MBASCHKLSR->CREATE_USER_ID, sizeof(MBASCHKLSR->CREATE_USER_ID));
