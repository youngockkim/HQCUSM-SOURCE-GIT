    MEMCPY_AN(MBASCHKLSR_N->APPLY_TO_TIME, MBASCHKLSR->APPLY_TO_TIME, sizeof(MBASCHKLSR->APPLY_TO_TIME));
    MBASCHKLSR_N->REQ_COMPLETE_FLAG[0] = MBASCHKLSR->REQ_COMPLETE_FLAG;
    MEMCPY_AN(MBASCHKLSR_N->COMPLETE_USER_ID, MBASCHKLSR->COMPLETE_USER_ID, sizeof(MBASCHKLSR->COMPLETE_USER_ID));
    MBASCHKLSR_N->INHERIT_CHILD_FLAG[0] = MBASCHKLSR->INHERIT_CHILD_FLAG;
