    MEMCPY_AN(MRASSHTDEF_N->SHEET_GRP_5, MRASSHTDEF->SHEET_GRP_5, sizeof(MRASSHTDEF->SHEET_GRP_5));
    MEMCPY_AN(MRASSHTDEF_N->SHEET_GRP_6, MRASSHTDEF->SHEET_GRP_6, sizeof(MRASSHTDEF->SHEET_GRP_6));
    MEMCPY_AN(MRASSHTDEF_N->SHEET_GRP_7, MRASSHTDEF->SHEET_GRP_7, sizeof(MRASSHTDEF->SHEET_GRP_7));
    MEMCPY_AN(MRASSHTDEF_N->SHEET_GRP_8, MRASSHTDEF->SHEET_GRP_8, sizeof(MRASSHTDEF->SHEET_GRP_8));
    MEMCPY_AN(MRASSHTDEF_N->SHEET_GRP_9, MRASSHTDEF->SHEET_GRP_9, sizeof(MRASSHTDEF->SHEET_GRP_9));
    MEMCPY_AN(MRASSHTDEF_N->SHEET_GRP_10, MRASSHTDEF->SHEET_GRP_10, sizeof(MRASSHTDEF->SHEET_GRP_10));
    MEMCPY_AN(MRASSHTDEF_N->UPDATE_USER_ID, MRASSHTDEF->UPDATE_USER_ID, sizeof(MRASSHTDEF->UPDATE_USER_ID));
    MEMCPY_AN(MRASSHTDEF_N->UPDATE_TIME, MRASSHTDEF->UPDATE_TIME, sizeof(MRASSHTDEF->UPDATE_TIME));
    MEMCPY_AN(MRASSHTDEF_N->CREATE_USER_ID, MRASSHTDEF->CREATE_USER_ID, sizeof(MRASSHTDEF->CREATE_USER_ID));
    MEMCPY_AN(MRASSHTDEF_N->CREATE_TIME, MRASSHTDEF->CREATE_TIME, sizeof(MRASSHTDEF->CREATE_TIME));
    MEMCPY_AN(MRASSHTDEF_N->RESV_FIELD1, MRASSHTDEF->RESV_FIELD1, sizeof(MRASSHTDEF->RESV_FIELD1));
    MEMCPY_AN(MRASSHTDEF_N->RESV_FIELD2, MRASSHTDEF->RESV_FIELD2, sizeof(MRASSHTDEF->RESV_FIELD2));
    MEMCPY_AN(MRASSHTDEF_N->RESV_FIELD3, MRASSHTDEF->RESV_FIELD3, sizeof(MRASSHTDEF->RESV_FIELD3));
    MEMCPY_AN(MRASSHTDEF_N->RESV_FIELD4, MRASSHTDEF->RESV_FIELD4, sizeof(MRASSHTDEF->RESV_FIELD4));
    MEMCPY_AN(MRASSHTDEF_N->RESV_FIELD5, MRASSHTDEF->RESV_FIELD5, sizeof(MRASSHTDEF->RESV_FIELD5));
}


/* Del Null Function */
