            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mrasshtdef(&MRASSHTDEF_N, MRASSHTDEF);
    }
    DB_stop_query_timer("DBC_fetch_mrasshtdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mrasshtdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MRASSHTDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MRASSHTDEF_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mrasshtdef", sel_type);
}


/* Initialize Function */
void DBC_init_mrasshtdef(struct MRASSHTDEF_TAG *MRASSHTDEF)
{
    /* memset by Space */
    memset(MRASSHTDEF, ' ', sizeof(struct MRASSHTDEF_TAG));
    
}


/* Add Null Function */
void DBC_add_null_mrasshtdef(struct MRASSHTDEF_N_TAG *MRASSHTDEF_N, struct MRASSHTDEF_TAG *MRASSHTDEF)
{
    /* memset by NULL */
    memset(MRASSHTDEF_N, '\0', sizeof(struct MRASSHTDEF_N_TAG));
    
    MEMCPY_AN(MRASSHTDEF_N->FACTORY, MRASSHTDEF->FACTORY, sizeof(MRASSHTDEF->FACTORY));
    MEMCPY_AN(MRASSHTDEF_N->SHEET_NAME, MRASSHTDEF->SHEET_NAME, sizeof(MRASSHTDEF->SHEET_NAME));
    MEMCPY_AN(MRASSHTDEF_N->SHEET_DESC, MRASSHTDEF->SHEET_DESC, sizeof(MRASSHTDEF->SHEET_DESC));
