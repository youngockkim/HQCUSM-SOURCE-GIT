/* SQL CURSOR CLOSE Function */
void DBC_close_mwipidgrul(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPIDGRUL_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_MWIPIDGRUL_CUR_2;
            break;
            
        case 3:
            EXEC SQL CLOSE DBC_MWIPIDGRUL_CUR_3;
            break;
            
        case 4:
            EXEC SQL CLOSE DBC_MWIPIDGRUL_CUR_4;
            break;
            
        case 5:
            EXEC SQL CLOSE DBC_MWIPIDGRUL_CUR_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipidgrul", sel_type);
}


/* Initialize Function */
void DBC_init_mwipidgrul(struct MWIPIDGRUL_TAG *MWIPIDGRUL)
{
    /* memset by Space */
    memset(MWIPIDGRUL, ' ', sizeof(struct MWIPIDGRUL_TAG));
    
    MWIPIDGRUL->RULE_SEQ = 0;
    MWIPIDGRUL->START_POS = 0;
    MWIPIDGRUL->LENGTH = 0;
    MWIPIDGRUL->DEP_RULE_SEQ = 0;    
}


/* Add Null Function */
void DBC_add_null_mwipidgrul(struct MWIPIDGRUL_N_TAG *MWIPIDGRUL_N, struct MWIPIDGRUL_TAG *MWIPIDGRUL)
{
    /* memset by NULL */
    memset(MWIPIDGRUL_N, '\0', sizeof(struct MWIPIDGRUL_N_TAG));
    
    MEMCPY_AN(MWIPIDGRUL_N->RULE_ID, MWIPIDGRUL->RULE_ID, sizeof(MWIPIDGRUL->RULE_ID));
    MWIPIDGRUL_N->RULE_SEQ = MWIPIDGRUL->RULE_SEQ;
    MWIPIDGRUL_N->RULE_TYPE[0] = MWIPIDGRUL->RULE_TYPE;
    MEMCPY_AN(MWIPIDGRUL_N->DATA_1, MWIPIDGRUL->DATA_1, sizeof(MWIPIDGRUL->DATA_1));
    MEMCPY_AN(MWIPIDGRUL_N->DATA_2, MWIPIDGRUL->DATA_2, sizeof(MWIPIDGRUL->DATA_2));
    MEMCPY_AN(MWIPIDGRUL_N->DATA_3, MWIPIDGRUL->DATA_3, sizeof(MWIPIDGRUL->DATA_3));
    MWIPIDGRUL_N->FIELD_TYPE[0] = MWIPIDGRUL->FIELD_TYPE;
    MWIPIDGRUL_N->START_POS = MWIPIDGRUL->START_POS;
    MWIPIDGRUL_N->LENGTH = MWIPIDGRUL->LENGTH;
    MWIPIDGRUL_N->USE_ALT_DATE[0] = MWIPIDGRUL->USE_ALT_DATE;
    MWIPIDGRUL_N->OVR_DATE_FLAG[0] = MWIPIDGRUL->OVR_DATE_FLAG;    
    MWIPIDGRUL_N->USE_CALENDAR[0] = MWIPIDGRUL->USE_CALENDAR;
    MWIPIDGRUL_N->USE_NUMERIC[0] = MWIPIDGRUL->USE_NUMERIC;
    MWIPIDGRUL_N->NUM_INC_ORDER[0] = MWIPIDGRUL->NUM_INC_ORDER;
    MWIPIDGRUL_N->NUM_ODD_EVEN[0] = MWIPIDGRUL->NUM_ODD_EVEN;
    MWIPIDGRUL_N->USE_ALPHA[0] = MWIPIDGRUL->USE_ALPHA;
    MWIPIDGRUL_N->ALP_INC_ORDER[0] = MWIPIDGRUL->ALP_INC_ORDER;
    MWIPIDGRUL_N->ALP_CASE[0] = MWIPIDGRUL->ALP_CASE;
    MWIPIDGRUL_N->ALP_ODD_EVEN[0] = MWIPIDGRUL->ALP_ODD_EVEN;
    MWIPIDGRUL_N->NUM_ALP_ORDER[0] = MWIPIDGRUL->NUM_ALP_ORDER;
    MWIPIDGRUL_N->DEP_RULE_SEQ = MWIPIDGRUL->DEP_RULE_SEQ;    
    MWIPIDGRUL_N->ALLOW_CYCLE_SEQ[0] = MWIPIDGRUL->ALLOW_CYCLE_SEQ;
    MEMCPY_AN(MWIPIDGRUL_N->CYCLE_INIT_VALUE, MWIPIDGRUL->CYCLE_INIT_VALUE, sizeof(MWIPIDGRUL->CYCLE_INIT_VALUE));
    MEMCPY_AN(MWIPIDGRUL_N->CREATE_INIT_VALUE, MWIPIDGRUL->CREATE_INIT_VALUE, sizeof(MWIPIDGRUL->CREATE_INIT_VALUE));
