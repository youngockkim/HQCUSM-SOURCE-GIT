/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mfmbenvdef(int sel_type, struct MFMBENVDEF_TAG *MFMBENVDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MFMBENVDEF_N_TAG MFMBENVDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mfmbenvdef(&MFMBENVDEF_N, MFMBENVDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MFMBENVDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FONT_FAMILY,
                    RES_WIDTH,
                    RES_HEIGHT,
                    SRS_WIDTH,
                    SRS_HEIGHT,
                    POT_WIDTH,
                    POT_HEIGHT,
                    TOL_WIDTH,
                    TOL_HEIGHT,
                    RTG_WIDTH,
                    RTG_HEIGHT,
                    ELP_WIDTH,
                    ELP_HEIGHT,
                    TRI_WIDTH,
                    TRI_HEIGHT,
                    VER_WIDTH,
                    VER_HEIGHT,
                    HOR_WIDTH,
                    HOR_HEIGHT,
                    PIE1_WIDTH,
                    PIE1_HEIGHT,
                    PIE2_WIDTH,
                    PIE2_HEIGHT,
                    PIE3_WIDTH,
                    PIE3_HEIGHT,
                    PIE4_WIDTH,
                    PIE4_HEIGHT,
                    LAYOUT_WIDTH,
                    LAYOUT_HEIGHT,
                    UDR_WIDTH,
                    UDR_HEIGHT,
                    EVENT_COLOR_FLAG,
                    SIGNAL_FLAG,
                    TEXT_SIZE,
                    TEXT_COLOR,
                    BACK_COLOR,
                    BACK_OPT
                FROM MFMBENVDEF
                WHERE FACTORY >= :MFMBENVDEF_N.FACTORY
                ORDER BY FACTORY ASC;
            EXEC SQL OPEN DBC_MFMBENVDEF_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
