/* Add Null Function */
void DBC_add_null_mfmbenvdef(struct MFMBENVDEF_N_TAG *MFMBENVDEF_N, struct MFMBENVDEF_TAG *MFMBENVDEF)
{
    /* memset by NULL */
    memset(MFMBENVDEF_N, '\0', sizeof(struct MFMBENVDEF_N_TAG));
    
    MEMCPY_AN(MFMBENVDEF_N->FACTORY, MFMBENVDEF->FACTORY, sizeof(MFMBENVDEF->FACTORY));
    MEMCPY_AN(MFMBENVDEF_N->CREATE_USER_ID, MFMBENVDEF->CREATE_USER_ID, sizeof(MFMBENVDEF->CREATE_USER_ID));
