    MEMCPY_AN(MFMBENVDEF_N->FONT_FAMILY, MFMBENVDEF->FONT_FAMILY, sizeof(MFMBENVDEF->FONT_FAMILY));
    MFMBENVDEF_N->RES_WIDTH = MFMBENVDEF->RES_WIDTH;
    MFMBENVDEF_N->RES_HEIGHT = MFMBENVDEF->RES_HEIGHT;
