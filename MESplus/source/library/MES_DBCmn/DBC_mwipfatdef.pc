    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPFATDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    OPER_POINT,
                    BA_POINT,
                    OPT_LEVEL,
                    POINT_KEY,
                    CREATE_USER_ID,
                    CREATE_TIME
                FROM MWIPFATDEF
                WHERE FACTORY = :MWIPFATDEF_N.FACTORY
                    AND MAT_ID = :MWIPFATDEF_N.MAT_ID
                    AND MAT_VER = :MWIPFATDEF_N.MAT_VER
                    AND FLOW = :MWIPFATDEF_N.FLOW
                    AND OPER = :MWIPFATDEF_N.OPER
                    AND OPT_LEVEL = :MWIPFATDEF_N.OPT_LEVEL
                    AND POINT_KEY >= :MWIPFATDEF_N.POINT_KEY
                ORDER BY POINT_KEY ASC;
            EXEC SQL OPEN DBC_MWIPFATDEF_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPFATDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    OPER_POINT,
                    BA_POINT,
                    OPT_LEVEL,
                    POINT_KEY,
                    CREATE_USER_ID,
                    CREATE_TIME
                FROM MWIPFATDEF
                WHERE FACTORY = :MWIPFATDEF_N.FACTORY
                    AND MAT_ID = ' '
                    AND MAT_VER = 0
                    AND FLOW = :MWIPFATDEF_N.FLOW;
            EXEC SQL OPEN DBC_MWIPFATDEF_CUR_2;
            break;

        case 3:
            /* Use material version up */
            EXEC SQL DECLARE DBC_MWIPFATDEF_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    OPER_POINT,
                    BA_POINT,
                    OPT_LEVEL,
                    POINT_KEY,
                    CREATE_USER_ID,
                    CREATE_TIME
                FROM MWIPFATDEF
                WHERE FACTORY = :MWIPFATDEF_N.FACTORY
                    AND MAT_ID = :MWIPFATDEF_N.MAT_ID
                    AND MAT_VER = :MWIPFATDEF_N.MAT_VER;
            EXEC SQL OPEN DBC_MWIPFATDEF_CUR_3;
            break;

        case 4:
            /* Use workflow */
            EXEC SQL DECLARE DBC_MWIPFATDEF_CUR_4 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    OPER_POINT,
                    BA_POINT,
                    OPT_LEVEL,
                    POINT_KEY,
                    CREATE_USER_ID,
                    CREATE_TIME
                FROM MWIPFATDEF
                WHERE FACTORY = :MWIPFATDEF_N.FACTORY
				AND OPER = :MWIPFATDEF_N.OPER;
            EXEC SQL OPEN DBC_MWIPFATDEF_CUR_4;
            break;

        case 5:
            EXEC SQL DECLARE DBC_MWIPFATDEF_CUR_5 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    OPER_POINT,
                    BA_POINT,
                    OPT_LEVEL,
                    POINT_KEY,
                    CREATE_USER_ID,
                    CREATE_TIME
                FROM MWIPFATDEF
                WHERE FACTORY = :MWIPFATDEF_N.FACTORY
                    AND MAT_ID = ' '
                    AND MAT_VER = 0
                    AND FLOW = ' '
                    AND OPER = :MWIPFATDEF_N.OPER;
            EXEC SQL OPEN DBC_MWIPFATDEF_CUR_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipfatdef", sel_type);
