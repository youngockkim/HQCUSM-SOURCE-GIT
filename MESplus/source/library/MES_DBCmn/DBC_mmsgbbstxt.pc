                FROM MMSGBBSTXT
                WHERE FACTORY = :MMSGBBSTXT_N.FACTORY
                    AND MAIN_MENU_ID = :MMSGBBSTXT_N.MAIN_MENU_ID
                    AND SUB_MENU_ID = :MMSGBBSTXT_N.SUB_MENU_ID
                    AND BBS_SEQ = :MMSGBBSTXT_N.BBS_SEQ
                ORDER BY TEXT_SEQ ASC;
            EXEC SQL OPEN DBC_MMSGBBSTXT_CUR_1;
