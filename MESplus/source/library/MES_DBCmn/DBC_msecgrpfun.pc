    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_msecgrpfun(&MSECGRPFUN_N, MSECGRPFUN);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSECGRPFUN_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    PROGRAM_ID,
                    SEC_GRP_ID,
                    FUNC_NAME,
                    DISP_LEVEL,
                    SEPARATOR,
                    SHORT_CUT,
                    ADD_TOOL_BAR,
                    CTL_EN_FLAG_1,
                    CTL_EN_FLAG_2,
                    CTL_EN_FLAG_3,
                    CTL_EN_FLAG_4,
                    CTL_EN_FLAG_5,
