    MRTDDSPDEF_N->RES_OR_OPER[0] = MRTDDSPDEF->RES_OR_OPER;
    MEMCPY_AN(MRTDDSPDEF_N->PRV_GRP_ID, MRTDDSPDEF->PRV_GRP_ID, sizeof(MRTDDSPDEF->PRV_GRP_ID));
    MRTDDSPDEF_N->MAX_COUNT = MRTDDSPDEF->MAX_COUNT;
    MEMCPY_AN(MRTDDSPDEF_N->LOT_RULE, MRTDDSPDEF->LOT_RULE, sizeof(MRTDDSPDEF->LOT_RULE));
    MEMCPY_AN(MRTDDSPDEF_N->RESOURCE_RULE, MRTDDSPDEF->RESOURCE_RULE, sizeof(MRTDDSPDEF->RESOURCE_RULE));
    MEMCPY_AN(MRTDDSPDEF_N->CREATE_USER_ID, MRTDDSPDEF->CREATE_USER_ID, sizeof(MRTDDSPDEF->CREATE_USER_ID));
