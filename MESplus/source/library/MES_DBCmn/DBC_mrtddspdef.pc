/* Del Null Function */
void DBC_del_null_mrtddspdef(struct MRTDDSPDEF_N_TAG *MRTDDSPDEF_N, struct MRTDDSPDEF_TAG *MRTDDSPDEF)
{
    MEMCPY_DN(MRTDDSPDEF->FACTORY, MRTDDSPDEF_N->FACTORY, sizeof(MRTDDSPDEF->FACTORY));
    MEMCPY_DN(MRTDDSPDEF->DSP_ID, MRTDDSPDEF_N->DSP_ID, sizeof(MRTDDSPDEF->DSP_ID));
    MEMCPY_DN(MRTDDSPDEF->DSP_DESC, MRTDDSPDEF_N->DSP_DESC, sizeof(MRTDDSPDEF->DSP_DESC));
    MRTDDSPDEF->RES_OR_OPER = MRTDDSPDEF_N->RES_OR_OPER[0];
    MEMCPY_DN(MRTDDSPDEF->PRV_GRP_ID, MRTDDSPDEF_N->PRV_GRP_ID, sizeof(MRTDDSPDEF->PRV_GRP_ID));
    MRTDDSPDEF->MAX_COUNT = MRTDDSPDEF_N->MAX_COUNT;
