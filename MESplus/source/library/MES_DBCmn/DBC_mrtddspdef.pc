    MEMCPY_AN(MRTDDSPDEF_N->UPDATE_USER_ID, MRTDDSPDEF->UPDATE_USER_ID, sizeof(MRTDDSPDEF->UPDATE_USER_ID));
    MEMCPY_AN(MRTDDSPDEF_N->UPDATE_TIME, MRTDDSPDEF->UPDATE_TIME, sizeof(MRTDDSPDEF->UPDATE_TIME));
