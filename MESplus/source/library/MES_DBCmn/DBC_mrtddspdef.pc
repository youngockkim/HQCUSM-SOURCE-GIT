/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrtddspdef(int sel_type, struct MRTDDSPDEF_TAG *MRTDDSPDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRTDDSPDEF_N_TAG MRTDDSPDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrtddspdef(&MRTDDSPDEF_N, MRTDDSPDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRTDDSPDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    DSP_ID,
                    DSP_DESC,
                    RES_OR_OPER,
                    PRV_GRP_ID,
                    MAX_COUNT,
                    LOT_RULE,
                    RESOURCE_RULE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRTDDSPDEF
                WHERE FACTORY = :MRTDDSPDEF_N.FACTORY
                    AND DSP_ID >= :MRTDDSPDEF_N.DSP_ID
                ORDER BY DSP_ID ASC;
            EXEC SQL OPEN DBC_MRTDDSPDEF_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MRTDDSPDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    DSP_ID,
                    DSP_DESC,
                    RES_OR_OPER,
                    PRV_GRP_ID,
                    MAX_COUNT,
                    LOT_RULE,
                    RESOURCE_RULE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRTDDSPDEF
                WHERE FACTORY = :MRTDDSPDEF_N.FACTORY
                    AND DSP_ID >= :MRTDDSPDEF_N.DSP_ID
                    AND (PRV_GRP_ID IN (
                    SELECT PRV_GRP_ID 
                    FROM MSECPRVUSR
                    WHERE FACTORY = :MRTDDSPDEF_N.FACTORY
                        AND USER_ID = :MRTDDSPDEF_N.CREATE_USER_ID)   
                        OR PRV_GRP_ID = ' ')
                    ORDER BY DSP_ID ASC;
            EXEC SQL OPEN DBC_MRTDDSPDEF_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MRTDDSPDEF_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    DSP_ID,
                    DSP_DESC,
                    RES_OR_OPER,
                    PRV_GRP_ID,
                    MAX_COUNT,
                    LOT_RULE,
                    RESOURCE_RULE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRTDDSPDEF
                WHERE FACTORY = :MRTDDSPDEF_N.FACTORY
                    AND (LOT_RULE = :MRTDDSPDEF_N.LOT_RULE
                         OR RESOURCE_RULE = :MRTDDSPDEF_N.RESOURCE_RULE
                        )
                ORDER BY DSP_ID ASC;
            EXEC SQL OPEN DBC_MRTDDSPDEF_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrtddspdef", sel_type);
}


