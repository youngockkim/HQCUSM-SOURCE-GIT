                    :MRASRESHIS_N.TRAN_CMF_20,
                    :MRASRESHIS_N.TRAN_USER_ID,
                    :MRASRESHIS_N.TRAN_COMMENT,
                    :MRASRESHIS_N.LAST_DOWN_TIME,
                    :MRASRESHIS_N.LAST_DOWN_HIST_SEQ,
                    :MRASRESHIS_N.HIST_START_SEQ,
                    :MRASRESHIS_N.HIST_DEL_FLAG,
                    :MRASRESHIS_N.HIST_DEL_TIME,
                    :MRASRESHIS_N.HIST_DEL_USER_ID,
                    :MRASRESHIS_N.HIST_DEL_COMMENT
                FROM MRASRESHIS
                WHERE FACTORY = :MRASRESHIS_N.FACTORY
                    AND RES_ID = :MRASRESHIS_N.RES_ID
                    AND HIST_SEQ = :MRASRESHIS_N.HIST_SEQ
                FOR UPDATE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mrasreshis(&MRASRESHIS_N, MRASRESHIS);
    }
    DB_stop_query_timer("DBC_select_mrasreshis_for_update", sel_type);
}


/* SQL SELECT_SCALAR Function */
double DBC_select_mrasreshis_scalar(int sel_type, struct MRASRESHIS_TAG *MRASRESHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASRESHIS_N_TAG MRASRESHIS_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrasreshis(&MRASRESHIS_N, MRASRESHIS);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MRASRESHIS
                WHERE FACTORY = :MRASRESHIS_N.FACTORY
                    AND RES_ID = :MRASRESHIS_N.RES_ID
                    AND HIST_SEQ = :MRASRESHIS_N.HIST_SEQ;
            break;
            
        case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MRASRESHIS
                WHERE FACTORY = :MRASRESHIS_N.FACTORY
                    AND RES_ID = :MRASRESHIS_N.RES_ID
                    AND HIST_DEL_FLAG <> 'Y';
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mrasreshis_scalar", sel_type);
    return d_value;
}


