                    TRAN_CMF_14 = :MRASRESHIS_N.TRAN_CMF_14,
                    TRAN_CMF_15 = :MRASRESHIS_N.TRAN_CMF_15,
                    TRAN_CMF_16 = :MRASRESHIS_N.TRAN_CMF_16,
                    TRAN_CMF_17 = :MRASRESHIS_N.TRAN_CMF_17,
                    TRAN_CMF_18 = :MRASRESHIS_N.TRAN_CMF_18,
