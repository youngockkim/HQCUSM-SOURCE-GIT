    MINVMATSTS->QTY_1 = 0;
    MINVMATSTS->QTY_2 = 0;
    MINVMATSTS->QTY_3 = 0;
    MINVMATSTS->ALLOC_QTY = 0;
    MINVMATSTS->LAST_HIST_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_minvmatsts(struct MINVMATSTS_N_TAG *MINVMATSTS_N, struct MINVMATSTS_TAG *MINVMATSTS)
{
    /* memset by NULL */
    memset(MINVMATSTS_N, '\0', sizeof(struct MINVMATSTS_N_TAG));
    
    MEMCPY_AN(MINVMATSTS_N->FACTORY, MINVMATSTS->FACTORY, sizeof(MINVMATSTS->FACTORY));
    MEMCPY_AN(MINVMATSTS_N->MAT_ID, MINVMATSTS->MAT_ID, sizeof(MINVMATSTS->MAT_ID));
    MINVMATSTS_N->MAT_VER = MINVMATSTS->MAT_VER;
    MEMCPY_AN(MINVMATSTS_N->OPER, MINVMATSTS->OPER, sizeof(MINVMATSTS->OPER));
    MINVMATSTS_N->QTY_1 = MINVMATSTS->QTY_1;
    MINVMATSTS_N->QTY_2 = MINVMATSTS->QTY_2;
    MINVMATSTS_N->QTY_3 = MINVMATSTS->QTY_3;
    MINVMATSTS_N->ALLOC_QTY = MINVMATSTS->ALLOC_QTY;
    MEMCPY_AN(MINVMATSTS_N->LAST_TRAN_CODE, MINVMATSTS->LAST_TRAN_CODE, sizeof(MINVMATSTS->LAST_TRAN_CODE));
    MEMCPY_AN(MINVMATSTS_N->LAST_TRAN_TIME, MINVMATSTS->LAST_TRAN_TIME, sizeof(MINVMATSTS->LAST_TRAN_TIME));
    MINVMATSTS_N->LAST_HIST_SEQ = MINVMATSTS->LAST_HIST_SEQ;
}


/* Del Null Function */
void DBC_del_null_minvmatsts(struct MINVMATSTS_N_TAG *MINVMATSTS_N, struct MINVMATSTS_TAG *MINVMATSTS)
{
    MEMCPY_DN(MINVMATSTS->FACTORY, MINVMATSTS_N->FACTORY, sizeof(MINVMATSTS->FACTORY));
    MEMCPY_DN(MINVMATSTS->MAT_ID, MINVMATSTS_N->MAT_ID, sizeof(MINVMATSTS->MAT_ID));
    MINVMATSTS->MAT_VER = MINVMATSTS_N->MAT_VER;
