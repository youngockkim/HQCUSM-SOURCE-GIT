    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MINVMATSTS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    OPER,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    ALLOC_QTY,
                    LAST_TRAN_CODE,
                    LAST_TRAN_TIME,
                    LAST_HIST_SEQ
                FROM MINVMATSTS
                WHERE FACTORY = :MINVMATSTS_N.FACTORY
                    AND MAT_ID = :MINVMATSTS_N.MAT_ID
                    AND MAT_VER = :MINVMATSTS_N.MAT_VER
                ORDER BY OPER ASC;
            EXEC SQL OPEN DBC_MINVMATSTS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
