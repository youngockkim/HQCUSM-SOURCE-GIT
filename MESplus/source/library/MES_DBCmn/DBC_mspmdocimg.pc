                FROM MSPMDOCIMG
                WHERE SPEC_REL_ID = :MSPMDOCIMG_N.SPEC_REL_ID
                    AND SPEC_REL_VER = :MSPMDOCIMG_N.SPEC_REL_VER
                ORDER BY CHAR_ID ASC;
            EXEC SQL OPEN DBC_MSPMDOCIMG_CUR_1;
