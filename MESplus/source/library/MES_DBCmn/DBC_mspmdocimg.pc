    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSPMDOCIMG_CUR_1 CURSOR FOR
                SELECT 
                    SPEC_REL_ID,
                    SPEC_REL_VER,
                    CHAR_ID,
                    DOC_NAME_1,
                    DOC_NAME_2,
                    DOC_NAME_3,
                    DOC_NAME_4,
