/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mbatprchis(int sel_type, struct MBATPRCHIS_TAG *MBATPRCHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBATPRCHIS_N_TAG MBATPRCHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbatprchis(&MBATPRCHIS_N, MBATPRCHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MBATPRCHIS_CUR_1 CURSOR FOR
                SELECT 
                    JOB_PROC_ID,
                    PROC_RUN_SUBNO,
                    HIST_SEQ,
                    START_TIME,
                    END_TIME,
                    ELAPSED_TIME,
                    STATUS_FLAG,
                    ERROR_MSG,
                    DB_ERROR_MSG,
                    PROC_KEY_1,
                    PROC_KEY_2,
                    PROC_KEY_3,
                    PROC_KEY_4,
                    PROC_KEY_5
                FROM MBATPRCHIS
                ORDER BY JOB_PROC_ID ASC,
                    PROC_RUN_SUBNO ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MBATPRCHIS_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MBATPRCHIS_CUR_2 CURSOR FOR
                SELECT ROWSEQ,
                    JOB_PROC_ID,
                    PROC_RUN_SUBNO,
                    HIST_SEQ,
                    START_TIME,
                    END_TIME,
                    ELAPSED_TIME,
                    STATUS_FLAG,
                    ERROR_MSG,
                    DB_ERROR_MSG,
                    PROC_KEY_1,
                    PROC_KEY_2,
                    PROC_KEY_3,
                    PROC_KEY_4,
                    PROC_KEY_5
                FROM (
                    SELECT ROWNUM ROWSEQ, JPH.*
                    FROM (
                        SELECT 
                            JOB_PROC_ID,
                            PROC_RUN_SUBNO,
                            HIST_SEQ,
                            START_TIME,
                            END_TIME,
                            ELAPSED_TIME,
                            STATUS_FLAG,
                            ERROR_MSG,
                            DB_ERROR_MSG,
                            PROC_KEY_1,
                            PROC_KEY_2,
                            PROC_KEY_3,
                            PROC_KEY_4,
                            PROC_KEY_5
                        FROM MBATPRCHIS
                        WHERE JOB_PROC_ID = :MBATPRCHIS_N.JOB_PROC_ID
                            AND START_TIME BETWEEN :MBATPRCHIS_N.START_TIME AND :MBATPRCHIS_N.END_TIME
                        ORDER BY START_TIME DESC, HIST_SEQ DESC, PROC_RUN_SUBNO ASC
                    ) JPH
                )
                WHERE ROWSEQ >= :MBATPRCHIS_N.HIST_SEQ;

            EXEC SQL OPEN DBC_MBATPRCHIS_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mbatprchis", sel_type);
}


