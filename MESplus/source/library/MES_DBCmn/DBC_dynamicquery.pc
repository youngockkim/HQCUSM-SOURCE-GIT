#include "DBC_common.h"

#include <sqlda.h>
#include <sqlcpr.h>

/* SQL Error Handling */
EXEC SQL WHENEVER SQLERROR DO DB_usr_error();
EXEC SQL WHENEVER NOT FOUND DO DB_usr_error();

/* Maximum number of select-list items or bind variables. */
/* 칼럼의 최대수 */
#define DSQL_MAX_COL_CNT    1000    

/* Maximum lengths of the _names_ of the select-list items or indicator variables. */
/* 칼럼 이름 문자열의 최대 길이 */
#define DSQL_MAX_VNAME_LEN     50    
#define DSQL_MAX_INAME_LEN     50
/* 데이터 값의 최대 길이 */
#define DSQL_MAX_NUMBER_VALUE_LEN     50

#ifndef NULL
#define NULL  0
#endif

#ifndef dvoid
#define dvoid  void
#endif

struct 
{
    int precision;
    int scale;
}sql_num_size[DSQL_MAX_COL_CNT];

SQLDA    *sqlda_bind_dp;
SQLDA    *sqlda_select_dp;

SQLDA    *nsql_bind_dp;
SQLDA    *nsql_select_dp;

int        dsql_live_flag;

void DB_to_upper_dsql(char *d, const char *s, int size) 
{
    int     i;
    char    c;

    for (i = 0; i < size; i++)
    {
        if(*(s+i) >= 97 && *(s+i) <= 122) 
        {
            c = *(s+i) - 32;
        }
        else
        {
            c = *(s+i);
        }

        *(d+i) = c;

        if(c == 0x00) 
        {
            break;
        }
    }
}

int DB_string_length_dsql(const char *s, int size)
{
    int i;

    for (i = 0; i < size; i++) {
        if(s[i] == ' ' || s[i] == 0x00) {
            break;
        }
    }

    return i;
}


/* Dynamic Sql을 이용해서 C 환경에서 Result Set과 비슷한 효과를 얻기 위해 구현 */
/* 2007.08.16. Aiden.
   공백이 2개 이상 연속되면 쿼리가 잘려버림... 
   source sql string 의 길이를 모르기 때문에 공백 2개 이상이면 쿼리가 끝인 것으로 인식하였으나 
   Pretty format 으로 sql 을 작성할 경우 sql 이 중간에 잘림. 그래서 사용안함.
void DB_add_null_dsql(char *d, char *s, int size)
{
    int  i;
    int  i_null_pos;
    int  i_space_count; 
   
    i_space_count = 0;
    i_null_pos = 0;

    for(i = 0 ; i < size ; i++) 
    {
        if(*(s+i) == 0x00)
        {
            *(d+i) = *(s+i);
            return ;
        }
        
        if(*(s+i) == ' ' && i_space_count >= 2) 
        {
            *(d+i_null_pos) = 0x00;
            return ;
        }
        else 
        {
            if(*(s+i) == ' ' && i_space_count == 0) 
            {
                i_null_pos = i;
                i_space_count = 1;
            }
            else if(*(s+i) == ' ' && i_space_count > 0) 
            {
                i_space_count++;
            }
            else if(*(s+i) != ' ' && i_space_count > 0)
            {
                i_space_count = 0;
            }
    
            *(d+i) = *(s+i);
        }
    }

    *(d+i_null_pos) = 0x00;
}
*/

void DB_add_null_dsql(char *d, const char *s, const int size)
{
    int i;
    int i_end_of_space; 
   
    i_end_of_space = 0;

    for (i = size - 1; i >= 0; i--)
    {
        if(*(s + i) == ' ' && i_end_of_space == 0)
        {
            *(d + i) = '\0';
        }
        else
        {
            *(d + i) = *(s + i);
            i_end_of_space = 1;
        }
    }

    if(*(d) == '\0') {
        *(d) = ' ';
    }
}

int DB_alloc_descriptors_nsql(int size, int max_vname_len, int max_iname_len)
{
    int i;

    if((nsql_bind_dp = SQLSQLDAAlloc(SQL_SINGLE_RCTX, size, max_vname_len, max_iname_len)) == (SQLDA *) 0) 
    {
        DB_error_code = 9999;
        memset(DB_error_msg, ' ', sizeof(DB_error_msg));
        memcpy(DB_error_msg, "Error : Cannot allocate memory for bind descriptor.", strlen("Error : Cannot allocate memory for bind descriptor."));
        return DB_FALSE;  /* Have to exit in this case. */
    }

    if((nsql_select_dp = SQLSQLDAAlloc (SQL_SINGLE_RCTX, size, max_vname_len, 0)) == (SQLDA *) 0) 
    {
        DB_error_code = 9999;
        memset(DB_error_msg, ' ', sizeof(DB_error_msg));
        memcpy(DB_error_msg, "Error : Cannot allocate memory for select descriptor.", strlen("Error : Cannot allocate memory for select descriptor."));
        return DB_FALSE;  /* Have to exit in this case. */
    }

    nsql_select_dp->N = DSQL_MAX_COL_CNT;

    /* Allocate the pointers to the indicator variables, and the actual data. */
    for (i = 0; i < DSQL_MAX_COL_CNT; i++) 
    {
        nsql_bind_dp->I[i] = (short *) malloc(sizeof (short));
        nsql_select_dp->I[i] = (short *) malloc(sizeof(short));
        nsql_bind_dp->V[i] = (char *) malloc(1);
        nsql_select_dp->V[i] = (char *) malloc(1);
    }
       
    return DB_TRUE;
}

int DB_alloc_descriptors_dsql(int size, int max_vname_len, int max_iname_len) 
{
    int        i;

    /* The first SQLSQLDAAlloc parameter is the runtime context.

       The second parameter determines the maximum number of
       array elements in each variable in the descriptor. In
       other words, it determines the maximum number of bind
       variables or select-list items in the SQL statement.
      
       The third parameter determines the maximum length of
       strings used to hold the names of select-list items
       or placeholders.  The maximum length of column 
       names in ORACLE is 30, but you can allocate more or less
       as needed.
     
       The fourth parameter determines the maximum length of
       strings used to hold the names of any indicator
       variables.  To follow ORACLE standards, the maximum
       length of these should be 30.  But, you can allocate
       more or less as needed. */

    if((sqlda_bind_dp = SQLSQLDAAlloc(SQL_SINGLE_RCTX, size, max_vname_len, max_iname_len)) == (SQLDA *) 0) 
    {
        DB_error_code = 9999;
        memset(DB_error_msg, ' ', sizeof(DB_error_msg));
        memcpy(DB_error_msg, "Error : Cannot allocate memory for bind descriptor.", strlen("Error : Cannot allocate memory for bind descriptor."));
        return DB_FALSE;  /* Have to exit in this case. */
    }

    if((sqlda_select_dp = SQLSQLDAAlloc (SQL_SINGLE_RCTX, size, max_vname_len, 0)) == (SQLDA *) 0) 
    {
        DB_error_code = 9999;
        memset(DB_error_msg, ' ', sizeof(DB_error_msg));
        memcpy(DB_error_msg, "Error : Cannot allocate memory for select descriptor.", strlen("Error : Cannot allocate memory for select descriptor."));
        return DB_FALSE;  /* Have to exit in this case. */
    }

    sqlda_select_dp->N = DSQL_MAX_COL_CNT;

    /* Allocate the pointers to the indicator variables, and the actual data. */
    for (i = 0; i < DSQL_MAX_COL_CNT; i++) 
    {
        sqlda_bind_dp->I[i] = (short *) malloc(sizeof (short));
        sqlda_select_dp->I[i] = (short *) malloc(sizeof(short));
        sqlda_bind_dp->V[i] = (char *) malloc(1);
        sqlda_select_dp->V[i] = (char *) malloc(1);
    }
       
    return DB_TRUE;
}


int DB_set_bind_variables(SQLDA *bind_dp, char null_terminate_bind_variables[][1001], int vars_count)
{
    int i, n;

    /* Describe any bind variables (input host variables) */
    bind_dp->N = DSQL_MAX_COL_CNT;  /* Initialize count of array elements. */
    EXEC SQL DESCRIBE BIND VARIABLES FOR dsql_statement INTO bind_dp;

    /* If F is negative, there were more bind variables
       than originally allocated by SQLSQLDAAlloc(). */
    if (bind_dp->F < 0)
    {
        DB_error_code = 9999;
        memset(DB_error_msg, ' ', sizeof(DB_error_msg));
        memcpy(DB_error_msg, "Error : Too many bind variables.", strlen("Error : Too many bind variables."));
        return DB_FALSE;  /* Have to exit in this case. */
    }
    else if (bind_dp->F != vars_count)
    {
        DB_error_code = 9999;
        memset(DB_error_msg, ' ', sizeof(DB_error_msg));
        sprintf(DB_error_msg, "Error : Not same the number of variables in query with parameters. Query[%d], Params[%d]", bind_dp->F, vars_count);
        return DB_FALSE;
    }

    /* Set the maximum number of array elements in the
       descriptor to the number found. */
    bind_dp->N = bind_dp->F;
 
    /* Get the value of each bind variable as a
     * character string.
     *   
     * C[i] contains the length of the bind variable
     *      name used in the SQL statement.
     * S[i] contains the actual name of the bind variable
     *      used in the SQL statement.
     *
     * L[i] will contain the length of the data value
     *      entered.
     *
     * V[i] will contain the address of the data value
     *      entered.
     *
     * T[i] is always set to 1 because in this sample program
     *      data values for all bind variables are entered
     *      as character strings.
     *      ORACLE converts to the table value from CHAR.
     *
     * I[i] will point to the indicator value, which is
     *      set to -1 when the bind variable value is "null".
     */
    for (i = 0; i < bind_dp->F; i++)
    {
        /* Get length and remove the new line character. */
        n = strlen(null_terminate_bind_variables[i]);

        /* Set it in the descriptor. */
        bind_dp->L[i] = n;

        /* (re-)allocate the buffer for the value.
           SQLSQLDAAlloc() reserves a pointer location for
           V[i] but does not allocate the full space for
           the pointer. */

         bind_dp->V[i] = (char *) realloc(bind_dp->V[i],
                         (bind_dp->L[i] + 1));            

        /* And copy it in. */
        strncpy(bind_dp->V[i], null_terminate_bind_variables[i], n);

        /* Set the indicator variable's value. */
        /*if ((strncmp(bind_dp->V[i], "NULL", 4) == 0) ||
                (strncmp(bind_dp->V[i], "null", 4) == 0))
            *bind_dp->I[i] = -1;
        else
        */
        if (n == 0)
            *bind_dp->I[i] = -1;
        else
            *bind_dp->I[i] = 0;
    
        /* Set the bind datatype to 1 for CHAR. */
        if (ISSPACE(bind_dp->V[i], bind_dp->L[i]) == DB_TRUE)
            bind_dp->T[i] = 96;
        else
            bind_dp->T[i] = 1;
    }

    return DB_TRUE;
}

void DB_free_nsql()
{
    int    i;

    /* When done, free the memory allocated for pointers in the bind and select descriptors. */
    for (i = 0; i < DSQL_MAX_COL_CNT; i++)
    {    
        if(nsql_bind_dp->V[i] != (char *) 0)
        {
            free(nsql_bind_dp->V[i]);
        }
        free(nsql_bind_dp->I[i]);   /* MAX_ITEMS were allocated. */
        if(nsql_select_dp->V[i] != (char *) 0)
        {
            free(nsql_select_dp->V[i]);
        }
        free(nsql_select_dp->I[i]); /* MAX_ITEMS were allocated. */
    }

    /* Free space used by the descriptors themselves. */
    SQLSQLDAFree(SQL_SINGLE_RCTX, nsql_bind_dp);
    SQLSQLDAFree(SQL_SINGLE_RCTX, nsql_select_dp);
}

void DB_usr_error_bind()
{
    char err_msg[512];           
    size_t buf_len, msg_len;

    EXEC SQL WHENEVER SQLERROR CONTINUE;

    DB_error_code = sqlca.sqlcode;
    memset(DB_error_msg, 0x00, sizeof(DB_error_msg));

    if(gc_by_mconn_query != 'Y')
    {
        if(gc_db_connected == 'Y')
        {
            if(DB_error_code == DB_LISTENER_FAILED ||
               DB_error_code == DB_DISCONNECT  ||
               DB_error_code == DB_EOF_CHANNEL ||
               DB_error_code == DB_FAIL_PACKET_WRITE ||
               DB_error_code == DB_NOT_LOGGED_ON ||
               DB_error_code == DB_LOST_CONTACT ||
               DB_error_code == DB_NO_LISTENER)
            {
                gc_db_connected = 'N';
            }
        }
    }
    else if(gc_by_mconn_query == 'Y')
    {
        if(gc_mdb_connected == 'Y')
        {
            if(DB_error_code == DB_LISTENER_FAILED ||
               DB_error_code == DB_DISCONNECT  ||
               DB_error_code == DB_EOF_CHANNEL ||
               DB_error_code == DB_FAIL_PACKET_WRITE ||
               DB_error_code == DB_NOT_LOGGED_ON ||
               DB_error_code == DB_LOST_CONTACT ||
               DB_error_code == DB_NO_LISTENER)
            {
                gc_mdb_connected = 'N';
            }
        }
    }
    
    buf_len = sizeof(err_msg);
    sqlglm(err_msg, &buf_len, &msg_len);
    
    if(msg_len > 199) {
        msg_len = 199;
    }

    memcpy(DB_error_msg, err_msg, msg_len);

    DB_free_nsql();

    return;     
}

int DB_process_select_list_dsql() 
{
    int        i;
    int        null_ok;
    int        precision;
    int        scale;
    int        number_type;

    /* If the SQL statement is a SELECT, describe the
       select-list items.  The DESCRIBE function returns
       their names, datatypes, lengths (including precision
       and scale), and NULL/NOT NULL statuses. */

    sqlda_select_dp->N = DSQL_MAX_COL_CNT;
    
    EXEC SQL DESCRIBE SELECT LIST FOR dsql_statement INTO sqlda_select_dp;

    /* If F is negative, there were more select-list items than originally allocated by SQLSQLDAAlloc(). */
    if(sqlda_select_dp->F < 0) 
    {
        DB_error_code = 9999;
        sprintf(DB_error_msg, "Too many select-columns count (%d), maximum is (%d)", -(sqlda_select_dp->F), DSQL_MAX_COL_CNT);
        return DB_FALSE;
    }

    /* Set the maximum number of array elements in the descriptor to the number found. */
    sqlda_select_dp->N = sqlda_select_dp->F;

    /* Allocate storage for each select-list item.
  
       SQLNumberPrecV6() is used to extract precision and scale
       from the length (select_dp->L[i]).

       sqlcolumnNullCheck() is used to reset the high-order bit of
       the datatype and to check whether the column
       is NOT NULL.

       CHAR    datatypes have length, but zero precision and
               scale.  The length is defined at CREATE time.

       NUMBER  datatypes have precision and scale only if
               defined at CREATE time.  If the column
               definition was just NUMBER, the precision
               and scale are zero, and you must allocate
               the required maximum length.

       DATE    datatypes return a length of 7 if the default
               format is used.  This should be increased to
               9 to store the actual date character string.
               If you use the TO_CHAR function, the maximum
               length could be 75, but will probably be less
               (you can see the effects of this in SQL*Plus).

       ROWID   datatype always returns a fixed length of 18 if
               coerced to CHAR.

       LONG and
       LONG RAW datatypes return a length of 0 (zero),
               so you need to set a maximum.  In this example,
               it is 240 characters. */
    
    for (i = 0; i < sqlda_select_dp->F; i++) 
    {
        /* Turn off high-order bit of datatype (in this example, it does not matter if the column is NOT NULL). */
        SQLColumnNullCheck (SQL_SINGLE_RCTX, (unsigned short *)&(sqlda_select_dp->T[i]), 
            (unsigned short *)&(sqlda_select_dp->T[i]), &null_ok);

        number_type = 0;
        switch (sqlda_select_dp->T[i])
        {
            case  1 : /* CHAR datatype: no change in length needed, except possibly for TO_CHAR conversions (not handled here). */
                break;
            case  2 : /* NUMBER datatype: use SQLNumberPrecV6() to extract precision and scale. */
                SQLNumberPrecV6( SQL_SINGLE_RCTX, (unsigned long *)&(sqlda_select_dp->L[i]), &precision, &scale);
                /* Allow for maximum size of NUMBER. */
                if(precision == 0) 
                {
                    number_type = 1;
                    precision = 40;
                    scale = 3;
                }
                /*Save precision and scale*/
                sql_num_size[i].precision = precision;
                sql_num_size[i].scale = scale;
                
                /* Also allow for decimal point and possible sign. */

                /* convert NUMBER datatype to FLOAT if scale > 0, INT otherwise. */
                if(scale > 0 || number_type == 1)
                    //sqlda_select_dp->L[i] = sizeof(float);
                    sqlda_select_dp->L[i] = sizeof(double);
                else
                    sqlda_select_dp->L[i] = sizeof(int);
                
                break;

            case  8 : /* LONG datatype */
                sqlda_select_dp->L[i] = 240;
                break;

            case 11 : /* ROWID datatype */
                sqlda_select_dp->L[i] = 18;
                break;

            case 12 : /* DATE datatype */
                sqlda_select_dp->L[i] = 9;
                break;
 
            case 23 : /* RAW datatype */
                break;

            case 24 : /* LONG RAW datatype */
                sqlda_select_dp->L[i] = 240;
                break;
        }
        /* Allocate space for the select-list data values.
           SQLSQLDAAlloc() reserves a pointer location for
           V[i] but does not allocate the full space for
           the pointer.  */

        if(sqlda_select_dp->T[i] == 2)
        {
            sqlda_select_dp->V[i] = (char *) realloc(sqlda_select_dp->V[i], sqlda_select_dp->L[i]);  
        }
        else
        {
            sqlda_select_dp->V[i] = (char *) realloc(sqlda_select_dp->V[i], sqlda_select_dp->L[i] + 1);  
        }

        /* Coerce ALL datatypes except for LONG RAW and NUMBER to character. */
        if(sqlda_select_dp->T[i] != 24 && sqlda_select_dp->T[i] != 2)
        {
            sqlda_select_dp->T[i] = 1;
        }

        /* Coerce the datatypes of NUMBERs to float or int depending on the scale. */
    
        if(sqlda_select_dp->T[i] == 2)
        {
            if(number_type == 0)
            {
                if(scale > 0)
                {
                    sqlda_select_dp->T[i] = 4;  /* float */
                }
                else
                {
                    sqlda_select_dp->T[i] = 3;  /* int */
                }
            }
            else
            {
                sqlda_select_dp->T[i] = 4;  /* float */
            }
        }
    }
    
    return DB_TRUE;
}

/* SQL INSERT/UPDATE/DELETE */
int DBC_execute_non_query(const char* query_null_terminate_string)
{
    EXEC SQL BEGIN DECLARE SECTION;
        char *s_query;
    EXEC SQL END DECLARE SECTION;

    s_query = query_null_terminate_string;
    DB_error_code = 0;
    memset(DB_error_msg, ' ', sizeof(DB_error_msg));
    
    EXEC SQL WHENEVER SQLERROR DO DB_usr_error();
    EXEC SQL WHENEVER NOT FOUND DO DB_usr_error();

    EXEC SQL EXECUTE IMMEDIATE :s_query;

    return sqlca.sqlerrd[2];
}

int DBC_execute_non_query_without_dcl(const char* query_null_terminate_string, int length)
{
    EXEC SQL BEGIN DECLARE SECTION;
        char *s_query;
        char s_tmp[21];
    EXEC SQL END DECLARE SECTION;

    s_query = query_null_terminate_string;
    DB_error_code = 0;
    memset(DB_error_msg, ' ', sizeof(DB_error_msg));
    
    // DCL Validation
    memset(s_tmp, 0x00, sizeof(s_tmp));
    DB_to_upper_dsql(s_tmp, s_query, length > 20 ? 20 : length);

    if (memcmp(s_tmp, "COMMIT", strlen("COMMIT")) == 0 ||
        memcmp(s_tmp, "ROLLBACK", strlen("ROLLBACK")) == 0 ||
        memcmp(s_tmp, "GRANT", strlen("GRANT")) == 0 ||
        memcmp(s_tmp, "SAVEPOINT", strlen("SAVEPOINT")) == 0 ||
        memcmp(s_tmp, "REVOKE", strlen("REVOKE")) == 0)
    {
        DB_error_code = 9999;
        memcpy(DB_error_msg, "Error : NOT SUPPORT DCL QUERY", strlen("Error : NOT SUPPORT DCL QUERY"));
        return DB_FALSE;
    }

    EXEC SQL WHENEVER SQLERROR DO DB_usr_error();
    EXEC SQL WHENEVER NOT FOUND DO DB_usr_error();

    EXEC SQL EXECUTE IMMEDIATE :s_query;

    return sqlca.sqlerrd[2];
}

int DBC_execute_non_query_with_bind(const char* query_null_terminate_string, char null_terminate_bind_variables[][1001], int vars_count)
{
    EXEC SQL BEGIN DECLARE SECTION;
        char *s_query;
    EXEC SQL END DECLARE SECTION;

    s_query = query_null_terminate_string;

    DB_error_code = 0;
    memset(DB_error_msg, ' ', sizeof(DB_error_msg));

    if (DB_alloc_descriptors_nsql(DSQL_MAX_COL_CNT, DSQL_MAX_VNAME_LEN, DSQL_MAX_INAME_LEN) == DB_FALSE)
    {
        return DB_FALSE;  /* Have to exit in this case. */
    }

    EXEC SQL PREPARE dsql_statement FROM :s_query;
    EXEC SQL DECLARE dsql_cursor CURSOR FOR dsql_statement;

    if (DB_set_bind_variables(nsql_bind_dp, null_terminate_bind_variables, vars_count) == DB_FALSE)
    {
        return DB_FALSE;
    }

    EXEC SQL WHENEVER SQLERROR DO DB_usr_error();
    EXEC SQL WHENEVER NOT FOUND DO DB_usr_error();

    EXEC SQL OPEN dsql_cursor USING DESCRIPTOR nsql_bind_dp;

    DB_free_nsql();

    EXEC SQL CLOSE dsql_cursor;

    return DB_TRUE;
}

/* Dynamic SQL Execute */
#define MAX_SQL_SIZE 500100
int DBC_execute_long_query_with_bind(const char *query_max_500100_bytes_fixed_size_string, int query_size, int *col_count, char null_terminate_bind_variables[][1001], int vars_count)
{
    EXEC SQL BEGIN DECLARE SECTION;
    static char    sql[MAX_SQL_SIZE + 1];
    static char    sql_1[6];
    EXEC SQL END DECLARE SECTION;

    DB_error_code = 0;

    if(query_size > MAX_SQL_SIZE)
    {
        query_size = MAX_SQL_SIZE;
    }
    sql[MAX_SQL_SIZE] = 0x00;

    DB_add_null_dsql(sql, query_max_500100_bytes_fixed_size_string, query_size);
    sql[query_size] = 0x00;

    if(sql[0] == 0x00 || strlen(sql) < 6) 
    {
        DB_error_code = 9999;
        memset(DB_error_msg, ' ', sizeof(DB_error_msg));
        memcpy(DB_error_msg, "Error : NULL QUERY", strlen("Error : NULL QUERY"));
        return DB_FALSE;
    }

    /* Allocate memory for the select and bind descriptors. */
    if(DB_alloc_descriptors_dsql(DSQL_MAX_COL_CNT, DSQL_MAX_VNAME_LEN, DSQL_MAX_INAME_LEN) != DB_TRUE) 
    {
        return DB_FALSE;
    }

    dsql_live_flag = 1;

    EXEC SQL PREPARE dsql_statement FROM :sql;
    EXEC SQL DECLARE dsql_cursor CURSOR FOR dsql_statement;

    if(DB_error_code != 0)
    {
        return DB_FALSE;
    }

    if (vars_count > 0)
    {
        if (DB_set_bind_variables(sqlda_bind_dp, null_terminate_bind_variables, vars_count) == DB_FALSE)
        {
            return DB_FALSE;
        }
    }

    /* Open the cursor and execute the statement.
       If the statement is not a query (SELECT), the statement processing is completed after the OPEN. */

    EXEC SQL WHENEVER SQLERROR DO DB_usr_error();
    EXEC SQL WHENEVER NOT FOUND DO DB_usr_error();

    EXEC SQL OPEN dsql_cursor USING DESCRIPTOR sqlda_bind_dp;

    if(DB_error_code != 0)
    {
        return DB_FALSE;
    }
        
    /* Call the function that processes the select-list.
       If the statement is not a query, this function just returns, doing nothing. */

    DB_to_upper_dsql(sql_1, sql, 6);

    if(memcmp(sql_1, "SELECT", 6) != 0) 
    {
        DBC_close_dsql();
        DB_error_code = 9999;
        memset(DB_error_msg, ' ', sizeof(DB_error_msg));
        memcpy(DB_error_msg, "Error : No SELECT SQL", strlen("Error : No SELECT SQL"));
        return DB_FALSE;
    }

    if(DB_process_select_list_dsql() != DB_TRUE) 
    {
        DBC_close_dsql();
        return DB_FALSE;
    }

    *col_count = sqlda_select_dp->F;

    /* 
    sqlca.sqlerrd[2] : INSERT, UPDATE, DELETE 연산 시 영향받은 레코드 개수가 저장된다. 
    SELECT문이나 FETCH문 수행시 출력 호스트 변수가 배열일 경우, 
    리턴되는 레코드 개수가 저장된다. 이 경우 리턴되는 레코드 개수는 누적되지 않고 
    현재 FETCH된 레코드 개수이다. 따라서 이 값은 배열 크기보다 클 수 없다. 
    커서를 사용했을 때에는 OPNE문이 수행되는 순간의 sqlerrd[2] 값은 0 이며 FETCH문장이
    수행될 때마다 하나씩 증가하게 된다.
    */

    return sqlca.sqlerrd[2];
}

int DBC_execute_long_query(const char *query_max_500100_bytes_fixed_size_string, int query_size, int *col_count) 
{
    return DBC_execute_long_query_with_bind(query_max_500100_bytes_fixed_size_string, query_size, col_count, NULL, 0);
}

int DBC_execute_query(const char *query_10000_bytes_fixed_size_string_or_max_10000_bytes_null_terminate_string, int *col_count) 
{
    int i;
    for(i = 0; i < 10000; i++)
    {
        if(query_10000_bytes_fixed_size_string_or_max_10000_bytes_null_terminate_string[i] == 0x00) break;
    }

    return DBC_execute_long_query(query_10000_bytes_fixed_size_string_or_max_10000_bytes_null_terminate_string, i, col_count);
}

int DBC_execute_query2(const char *query_10000_bytes_fixed_size_string_or_max_10000_bytes_null_terminate_string) 
{
    int i_col_count = 0;
    return DBC_execute_query(query_10000_bytes_fixed_size_string_or_max_10000_bytes_null_terminate_string, &i_col_count);
}

int DBC_execute_query3(const char *query_max_500100_bytes_null_terminate_string) 
{
    int i_col_count = 0;
    return DBC_execute_long_query(query_max_500100_bytes_null_terminate_string, (int)strlen(query_max_500100_bytes_null_terminate_string), &i_col_count);
}

int DBC_get_next() 
{
    /* FETCH each row selected and print the column values. */
    EXEC SQL FETCH dsql_cursor USING DESCRIPTOR sqlda_select_dp;
    if(sqlca.sqlcode == DB_NOT_FOUND || sqlca.sqlcode < DB_SUCCESS) 
    {
        DBC_close_dsql();
        return DB_FALSE;
    }

    return DB_TRUE;
}

void DB_itoa(int data_i, char *d_p, int size_i)
{
    char temp_char_stg[DSQL_MAX_NUMBER_VALUE_LEN + 1];

    sprintf(temp_char_stg, "%-*d", size_i, data_i);
    memcpy(d_p, temp_char_stg, size_i);
}

void DB_ltoa(long data_l, char *d_p, int size_i)
{
    char temp_char_stg[DSQL_MAX_NUMBER_VALUE_LEN + 1];

    sprintf(temp_char_stg, "%-*ld", size_i, data_l);
    memcpy(d_p, temp_char_stg, size_i);
}
 
void DB_dtoa(double data_f, char *d_p, int size_i)
{
    char temp_char_stg[DSQL_MAX_NUMBER_VALUE_LEN + 1];

    //sprintf(temp_char_stg, "%-*G", size_i, data_f);
    sprintf(temp_char_stg, "%-*.16g", size_i, data_f);
    memcpy(d_p, temp_char_stg, size_i);
}

int DBC_get_column_info(const int column, char *s_name, char *s_type, int *i_double_scale, int *i_size)
{
    int     precision;
    int     scale;
    char    s_col_name[255];
    char    s_col_type[10];

    *i_double_scale = 0;
    *i_size = 0;

    /* Even if the column returns NULL value, get column information
    if(*sqlda_select_dp->I[column] < 0)
    {
        return DB_FALSE;
    }
    */

    memset(s_col_name, 0x00, sizeof(s_col_name));
    memset(s_col_type, 0x00, sizeof(s_col_type));

    memcpy(s_col_name, sqlda_select_dp->S[column], sqlda_select_dp->C[column]);

    switch (sqlda_select_dp->T[column])
    {
        case  1 : /* CHAR datatype */
            if(sqlda_select_dp->L[column] > 1)
                strcpy(s_col_type, "STR");
            else
                strcpy(s_col_type, "CHR");
            
            *i_size = sqlda_select_dp->L[column];
            break;

       case  3 : /* INTEGER datatype */
            strcpy(s_col_type, "INT");
            *i_size = sql_num_size[column].precision;
            break;

        case  4 : /* DOUBLE datatype */
            strcpy(s_col_type, "DBL");
            *i_size = sql_num_size[column].precision;
            *i_double_scale = sql_num_size[column].scale;
            break;

        case  8 : /* LONG datatype */
            strcpy(s_col_type, "LNG");
            break;

        case 11 : /* ROWID datatype */
            
            break;

        case 12 : /* DATE datatype */
            
            break;

        case 23 : /* RAW datatype */
            break;

        case 24 : /* LONG RAW datatype */
            
            break;
    }

    strcpy(s_name, s_col_name);
    strcpy(s_type, s_col_type);
   

    return DB_TRUE;
}

int DBC_get_value(const int column, char *return_value, int i_return_value_size)
{
    int i_value_length;

    if(*sqlda_select_dp->I[column] < 0)
    {
        return DB_FALSE;
    }

    switch (sqlda_select_dp->T[column])
    {
        case  1 : /* CHAR datatype */
            i_value_length = sqlda_select_dp->L[column];

            if(i_value_length > 1)
            {
                if(i_value_length > i_return_value_size)
                {
                    i_value_length = i_return_value_size;
                }

                memcpy(return_value, sqlda_select_dp->V[column], i_value_length);
            }
            else
            {
                return_value[0] = DBC_get_char(column);
            }
            break;

        case  3 : /* INTEGER datatype */
            i_value_length = DSQL_MAX_NUMBER_VALUE_LEN;

            if(i_return_value_size < DSQL_MAX_NUMBER_VALUE_LEN)
            {
                i_value_length = i_return_value_size;
            }

            DB_itoa(DBC_get_int(column), return_value, i_value_length);
            break;

        case  4 : /* DOUBLE datatype */
            i_value_length = DSQL_MAX_NUMBER_VALUE_LEN;

            if(i_return_value_size < DSQL_MAX_NUMBER_VALUE_LEN)
            {
                i_value_length = i_return_value_size;
            }

            DB_dtoa(DBC_get_double(column), return_value, i_value_length);
            break;

        case  8 : /* LONG datatype */
            i_value_length = DSQL_MAX_NUMBER_VALUE_LEN;

            if(i_return_value_size < DSQL_MAX_NUMBER_VALUE_LEN)
            {
                i_value_length = i_return_value_size;
            }

            DB_ltoa(DBC_get_double(column), return_value, i_value_length);
            break;

        case 11 : /* ROWID datatype */
            
            break;

        case 12 : /* DATE datatype */
            
            break;

        case 23 : /* RAW datatype */
            break;

        case 24 : /* LONG RAW datatype */
            
            break;
    }

    return DB_TRUE;
}

int DBC_get_value_cn(const char *column_name, char *return_value, int i_return_value_size)
{
    int     i;
    char    cn[DSQL_MAX_VNAME_LEN];

    DB_to_upper_dsql(cn, column_name, DSQL_MAX_VNAME_LEN);

    for (i = 0; i < sqlda_select_dp->F; i++) 
    {
        if(memcmp(sqlda_select_dp->S[i], cn, sqlda_select_dp->C[i]) == 0) 
        {
            if(DB_string_length_dsql(cn, DSQL_MAX_VNAME_LEN) == sqlda_select_dp->C[i])
            {
                break;
            }
        }
    }
    if(i == sqlda_select_dp->F)
    {
        return DB_FALSE;
    }

    return DBC_get_value(i, return_value, i_return_value_size);
}

int DBC_get_int(const int column) 
{
    int i = 0;

    /* NULL 인 경우 */
    if(*sqlda_select_dp->I[column] < 0) 
    {
        i = -999;
    }
    else 
    {
        /* Integer가 아닌 경우 */
        if(sqlda_select_dp->T[column] != 3 && sqlda_select_dp->T[column] != 4) 
        {
            i = -9999;
        }
        else 
        {
            if(sqlda_select_dp->T[column] == 3)
            {
                i = *(int *)sqlda_select_dp->V[column];
            }
            else if(sqlda_select_dp->T[column] == 4)
            {
                double d = *(double *)sqlda_select_dp->V[column];
                i = (int)d;
            }
        }
    }

    return i;
}

double DBC_get_double(const int column) 
{
    double d = 0;

    /* NULL 인 경우 */
    if(*sqlda_select_dp->I[column] < 0) 
    {
        d = -999;
    }
    else 
    {
        if(sqlda_select_dp->T[column] != 4 && sqlda_select_dp->T[column] != 3) 
        {
            d = -9999;
        }
        else 
        {
            if(sqlda_select_dp->T[column] == 4)
            {
                d = *(double *)sqlda_select_dp->V[column];
            }
            else if(sqlda_select_dp->T[column] == 3)
            {
                int i = *(int *)sqlda_select_dp->V[column];
                d = (double)i;
            }
        }
    }

    return d;
}

char DBC_get_char(const int column) 
{
    char ch = 0x00;

    /* NULL 인 경우 */
    if(*sqlda_select_dp->I[column] < 0) 
    {
        ch = 0x00;
    }
    else 
    {
        if(sqlda_select_dp->T[column] != 1) 
        {
            ch = 0x00;
        }
        else 
        {
            ch = sqlda_select_dp->V[column][0];
        }
    }

    return ch;
}

void DBC_get_string(const int column, char *dest_pt, int i_value_size) 
{
    /* NULL 인 경우 */
    if(*sqlda_select_dp->I[column] < 0) 
    {
        dest_pt[0] = 0x00;
    }
    else 
    {
        if(sqlda_select_dp->T[column] != 1) 
        {

        }
        else 
        {
            if(sqlda_select_dp->L[column] > i_value_size)
            {
                memcpy(dest_pt, sqlda_select_dp->V[column], i_value_size);
            }
            else
            {
                memcpy(dest_pt, sqlda_select_dp->V[column], sqlda_select_dp->L[column]);
            }

            memcpy(dest_pt, sqlda_select_dp->V[column], sqlda_select_dp->L[column]);
        }
    }
}

int DBC_get_int_cn(const char *column_name) 
{
    int     i;
    char    cn[DSQL_MAX_VNAME_LEN];

    DB_to_upper_dsql(cn, column_name, DSQL_MAX_VNAME_LEN);

    for (i = 0; i < sqlda_select_dp->F; i++) 
    {
        if(memcmp(sqlda_select_dp->S[i], cn, sqlda_select_dp->C[i]) == 0) 
        {
            if(DB_string_length_dsql(cn, DSQL_MAX_VNAME_LEN) == sqlda_select_dp->C[i])
            {
                return DBC_get_int(i);
            }
        }
    }

    return -9999;
}

double DBC_get_double_cn(const char *column_name) 
{
    int     i;
    char    cn[DSQL_MAX_VNAME_LEN];

    DB_to_upper_dsql(cn, column_name, DSQL_MAX_VNAME_LEN);

    for (i = 0; i < sqlda_select_dp->F; i++) 
    {
        if(memcmp(sqlda_select_dp->S[i], cn, sqlda_select_dp->C[i]) == 0) 
        {
            if(DB_string_length_dsql(cn, DSQL_MAX_VNAME_LEN) == sqlda_select_dp->C[i])
            {
                return DBC_get_double(i);
            }
        }
    }

    return -9999;
}

char DBC_get_char_cn(const char *column_name) 
{
    int        i;
    char    cn[DSQL_MAX_VNAME_LEN];

    DB_to_upper_dsql(cn, column_name, DSQL_MAX_VNAME_LEN);

    for (i = 0; i < sqlda_select_dp->F; i++)
    {
        if(memcmp(sqlda_select_dp->S[i], cn, sqlda_select_dp->C[i]) == 0) 
        {
            if(DB_string_length_dsql(cn, DSQL_MAX_VNAME_LEN) == sqlda_select_dp->C[i])
            {
                return DBC_get_char(i);
            }
        }
    }

    return 0x00;
}

void DBC_get_string_cn(const char *column_name, char *dest_pt, int i_value_size) 
{
    int        i;
    char    cn[DSQL_MAX_VNAME_LEN];

    DB_to_upper_dsql(cn, column_name, DSQL_MAX_VNAME_LEN);

    for (i = 0; i < sqlda_select_dp->F; i++) 
    {
        if(memcmp(sqlda_select_dp->S[i], cn, sqlda_select_dp->C[i]) == 0) 
        {
            if(DB_string_length_dsql(cn, DSQL_MAX_VNAME_LEN) == sqlda_select_dp->C[i])
            {
                DBC_get_string(i, dest_pt, i_value_size);
                break;
            }
        }
    }
}


void DBC_close_dsql()
{
    int    i;

    if(dsql_live_flag == 0) 
        return;

    /* When done, free the memory allocated for pointers in the bind and select descriptors. */
    for (i = 0; i < DSQL_MAX_COL_CNT; i++)
    {    
        if(sqlda_bind_dp->V[i] != (char *) 0)
        {
            free(sqlda_bind_dp->V[i]);
        }
        free(sqlda_bind_dp->I[i]);   /* MAX_ITEMS were allocated. */
        if(sqlda_select_dp->V[i] != (char *) 0)
        {
            free(sqlda_select_dp->V[i]);
        }
        free(sqlda_select_dp->I[i]); /* MAX_ITEMS were allocated. */
    }

    /* Free space used by the descriptors themselves. */
    SQLSQLDAFree(SQL_SINGLE_RCTX, sqlda_bind_dp);
    SQLSQLDAFree(SQL_SINGLE_RCTX, sqlda_select_dp);

    EXEC SQL WHENEVER SQLERROR CONTINUE;

    /* Close the cursor. */
    EXEC SQL CLOSE dsql_cursor;

    dsql_live_flag = 0;
}

