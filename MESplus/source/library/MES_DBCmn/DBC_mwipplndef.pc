    MEMCPY_AN(MWIPPLNDEF_N->MAT_ID, MWIPPLNDEF->MAT_ID, sizeof(MWIPPLNDEF->MAT_ID));
    MWIPPLNDEF_N->MAT_VER = MWIPPLNDEF->MAT_VER;
    MEMCPY_AN(MWIPPLNDEF_N->RES_ID, MWIPPLNDEF->RES_ID, sizeof(MWIPPLNDEF->RES_ID));
    MWIPPLNDEF_N->PLAN_QTY = MWIPPLNDEF->PLAN_QTY;
    MWIPPLNDEF_N->QTY = MWIPPLNDEF->QTY;
    MWIPPLNDEF_N->LOT_TYPE[0] = MWIPPLNDEF->LOT_TYPE;
    MEMCPY_AN(MWIPPLNDEF_N->OWNER_CODE, MWIPPLNDEF->OWNER_CODE, sizeof(MWIPPLNDEF->OWNER_CODE));
    MEMCPY_AN(MWIPPLNDEF_N->CREATE_CODE, MWIPPLNDEF->CREATE_CODE, sizeof(MWIPPLNDEF->CREATE_CODE));
    MWIPPLNDEF_N->LOT_PRIORITY[0] = MWIPPLNDEF->LOT_PRIORITY;
    MEMCPY_AN(MWIPPLNDEF_N->ORG_DUE_TIME, MWIPPLNDEF->ORG_DUE_TIME, sizeof(MWIPPLNDEF->ORG_DUE_TIME));
    MWIPPLNDEF_N->CREATE_LOT_COUNT = MWIPPLNDEF->CREATE_LOT_COUNT;
    MWIPPLNDEF_N->CREATE_QTY = MWIPPLNDEF->CREATE_QTY;
    MEMCPY_AN(MWIPPLNDEF_N->CREATE_USER_ID, MWIPPLNDEF->CREATE_USER_ID, sizeof(MWIPPLNDEF->CREATE_USER_ID));
    MEMCPY_AN(MWIPPLNDEF_N->CREATE_TIME, MWIPPLNDEF->CREATE_TIME, sizeof(MWIPPLNDEF->CREATE_TIME));
    MEMCPY_AN(MWIPPLNDEF_N->UPDATE_USER_ID, MWIPPLNDEF->UPDATE_USER_ID, sizeof(MWIPPLNDEF->UPDATE_USER_ID));
    MEMCPY_AN(MWIPPLNDEF_N->UPDATE_TIME, MWIPPLNDEF->UPDATE_TIME, sizeof(MWIPPLNDEF->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mwipplndef(struct MWIPPLNDEF_N_TAG *MWIPPLNDEF_N, struct MWIPPLNDEF_TAG *MWIPPLNDEF)
{
    MEMCPY_DN(MWIPPLNDEF->FACTORY, MWIPPLNDEF_N->FACTORY, sizeof(MWIPPLNDEF->FACTORY));
    MEMCPY_DN(MWIPPLNDEF->WORK_DATE, MWIPPLNDEF_N->WORK_DATE, sizeof(MWIPPLNDEF->WORK_DATE));
    MEMCPY_DN(MWIPPLNDEF->MAT_ID, MWIPPLNDEF_N->MAT_ID, sizeof(MWIPPLNDEF->MAT_ID));
    MWIPPLNDEF->MAT_VER = MWIPPLNDEF_N->MAT_VER;
    MEMCPY_DN(MWIPPLNDEF->RES_ID, MWIPPLNDEF_N->RES_ID, sizeof(MWIPPLNDEF->RES_ID));
    MWIPPLNDEF->PLAN_QTY = MWIPPLNDEF_N->PLAN_QTY;
    MWIPPLNDEF->QTY = MWIPPLNDEF_N->QTY;
    MWIPPLNDEF->LOT_TYPE = MWIPPLNDEF_N->LOT_TYPE[0];
    MEMCPY_DN(MWIPPLNDEF->OWNER_CODE, MWIPPLNDEF_N->OWNER_CODE, sizeof(MWIPPLNDEF->OWNER_CODE));
    MEMCPY_DN(MWIPPLNDEF->CREATE_CODE, MWIPPLNDEF_N->CREATE_CODE, sizeof(MWIPPLNDEF->CREATE_CODE));
    MWIPPLNDEF->LOT_PRIORITY = MWIPPLNDEF_N->LOT_PRIORITY[0];
    MEMCPY_DN(MWIPPLNDEF->ORG_DUE_TIME, MWIPPLNDEF_N->ORG_DUE_TIME, sizeof(MWIPPLNDEF->ORG_DUE_TIME));
    MWIPPLNDEF->CREATE_LOT_COUNT = MWIPPLNDEF_N->CREATE_LOT_COUNT;
    MWIPPLNDEF->CREATE_QTY = MWIPPLNDEF_N->CREATE_QTY;
    MEMCPY_DN(MWIPPLNDEF->CREATE_USER_ID, MWIPPLNDEF_N->CREATE_USER_ID, sizeof(MWIPPLNDEF->CREATE_USER_ID));
    MEMCPY_DN(MWIPPLNDEF->CREATE_TIME, MWIPPLNDEF_N->CREATE_TIME, sizeof(MWIPPLNDEF->CREATE_TIME));
    MEMCPY_DN(MWIPPLNDEF->UPDATE_USER_ID, MWIPPLNDEF_N->UPDATE_USER_ID, sizeof(MWIPPLNDEF->UPDATE_USER_ID));
    MEMCPY_DN(MWIPPLNDEF->UPDATE_TIME, MWIPPLNDEF_N->UPDATE_TIME, sizeof(MWIPPLNDEF->UPDATE_TIME));
}



