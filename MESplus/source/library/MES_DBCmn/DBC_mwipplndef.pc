    memset(MWIPPLNDEF_N, '\0', sizeof(struct MWIPPLNDEF_N_TAG));
    
    MEMCPY_AN(MWIPPLNDEF_N->FACTORY, MWIPPLNDEF->FACTORY, sizeof(MWIPPLNDEF->FACTORY));
