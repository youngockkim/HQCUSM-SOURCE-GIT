/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipplndef(int sel_type, struct MWIPPLNDEF_TAG *MWIPPLNDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPPLNDEF_N_TAG MWIPPLNDEF_N;
        char   sql[5120];
        char   ts[1000];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    

    DBC_add_null_mwipplndef(&MWIPPLNDEF_N, MWIPPLNDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPPLNDEF_CUR_1 CURSOR FOR
                SELECT MAT_ID, MAT_VER, PLAN_QTY 
                FROM MWIPPLNDEF
                WHERE FACTORY = :MWIPPLNDEF_N.FACTORY
                    AND WORK_DATE = :MWIPPLNDEF_N.WORK_DATE
                    AND ((MAT_ID = :MWIPPLNDEF_N.MAT_ID AND MAT_VER >= :MWIPPLNDEF_N.MAT_VER) OR MAT_ID > :MWIPPLNDEF_N.MAT_ID)
                ORDER BY MAT_ID, MAT_VER ASC;
            EXEC SQL OPEN DBC_MWIPPLNDEF_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MWIPPLNDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    WORK_DATE,
                    MAT_ID,
                    MAT_VER,
                    RES_ID,
                    PLAN_QTY,
                    QTY,
                    LOT_TYPE,
                    OWNER_CODE,
                    CREATE_CODE,
                    LOT_PRIORITY,
                    ORG_DUE_TIME,
                    CREATE_LOT_COUNT,
                    CREATE_QTY,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPPLNDEF
                WHERE FACTORY = :MWIPPLNDEF_N.FACTORY
                    AND WORK_DATE <= :MWIPPLNDEF_N.UPDATE_TIME
                    AND (
                            (WORK_DATE > :MWIPPLNDEF_N.CREATE_TIME) OR
                            (WORK_DATE = :MWIPPLNDEF_N.CREATE_TIME AND ((MAT_ID = :MWIPPLNDEF_N.MAT_ID AND MAT_VER >= :MWIPPLNDEF_N.MAT_VER) OR MAT_ID > :MWIPPLNDEF_N.MAT_ID))
                        )
                ORDER BY WORK_DATE, MAT_ID, MAT_VER ASC;
            EXEC SQL OPEN DBC_MWIPPLNDEF_CUR_2;
            break;
            
        case 51:
            memset( sql, 0x00, sizeof(sql));
            memset( ts, 0x00, sizeof(ts));

            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "FACTORY, ");
            sprintf(sql + strlen(sql),   "WORK_DATE, ");
            sprintf(sql + strlen(sql),   "MAT_ID, ");
            sprintf(sql + strlen(sql),   "MAT_VER, ");
            sprintf(sql + strlen(sql),   "RES_ID, ");
            sprintf(sql + strlen(sql),   "PLAN_QTY, ");
            sprintf(sql + strlen(sql),   "QTY, ");
            sprintf(sql + strlen(sql),   "LOT_TYPE, ");
            sprintf(sql + strlen(sql),   "OWNER_CODE, ");
            sprintf(sql + strlen(sql),   "CREATE_CODE, ");
            sprintf(sql + strlen(sql),   "LOT_PRIORITY, ");
            sprintf(sql + strlen(sql),   "ORG_DUE_TIME, ");
            sprintf(sql + strlen(sql),   "CREATE_LOT_COUNT, ");
            sprintf(sql + strlen(sql),   "CREATE_QTY, ");
            sprintf(sql + strlen(sql),   "CREATE_USER_ID, ");
            sprintf(sql + strlen(sql),   "CREATE_TIME, ");
            sprintf(sql + strlen(sql),   "UPDATE_USER_ID, ");
            sprintf(sql + strlen(sql),   "UPDATE_TIME ");
            sprintf(sql + strlen(sql), "FROM MWIPPLNDEF WHERE ");
            
            make_valid_quote(ts, MWIPPLNDEF_N.FACTORY);  
            sprintf(sql + strlen(sql), "FACTORY = '%s' ", ts);   
            
            make_valid_quote(ts, DBC_Q_COND_N.FROM_TIME);  
            sprintf(sql + strlen(sql), "AND WORK_DATE >= '%s' ", ts);      
            
            make_valid_quote(ts, DBC_Q_COND_N.TO_TIME);  
            sprintf(sql + strlen(sql), "AND WORK_DATE <= '%s' ", ts);   
            
            if(ISSPACE(MWIPPLNDEF->MAT_ID, sizeof(MWIPPLNDEF->MAT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MWIPPLNDEF_N.MAT_ID);  
                sprintf(sql + strlen(sql), "AND MAT_ID = '%s' ", ts);
                
                /* Add for V42 */
                sprintf(sql + strlen(sql), "AND MAT_VER = '%d' ", MWIPPLNDEF->MAT_VER);
            }
            else
            {
                if(ISSPACE(DBC_Q_COND.MAT_TYPE, sizeof(DBC_Q_COND.MAT_TYPE)) == DB_FALSE ||
                    ISSPACE(DBC_Q_COND.MAT_GRP, sizeof(DBC_Q_COND.MAT_GRP)) == DB_FALSE)
                {
                    make_valid_quote(ts, MWIPPLNDEF_N.FACTORY);  
                    sprintf(sql + strlen(sql), " AND MAT_ID IN ( SELECT MAT_ID FROM MWIPMATDEF WHERE FACTORY = '%s' ", 
                        ts);
                    if(ISSPACE(DBC_Q_COND.MAT_TYPE, sizeof(DBC_Q_COND.MAT_TYPE)) == DB_FALSE)
                    {
                        make_valid_quote(ts, DBC_Q_COND.MAT_TYPE);
                        sprintf(sql + strlen(sql), "AND MAT_TYPE = '%s' ", ts);
                    }
                    if(ISSPACE(DBC_Q_COND.MAT_GRP, sizeof(DBC_Q_COND.MAT_GRP)) == DB_FALSE)
                    {
                        make_valid_quote(ts, DBC_Q_COND.MAT_GRP);
                        sprintf(sql + strlen(sql), "AND (MAT_GRP_1 = '%s' ", ts);
                        sprintf(sql + strlen(sql), "OR MAT_GRP_2 = '%s' ", ts);
                        sprintf(sql + strlen(sql), "OR MAT_GRP_3 = '%s' ", ts);
                        sprintf(sql + strlen(sql), "OR MAT_GRP_4 = '%s' ", ts);
                        sprintf(sql + strlen(sql), "OR MAT_GRP_5 = '%s' ", ts);
                        sprintf(sql + strlen(sql), "OR MAT_GRP_6 = '%s' ", ts);
                        sprintf(sql + strlen(sql), "OR MAT_GRP_7 = '%s' ", ts);
                        sprintf(sql + strlen(sql), "OR MAT_GRP_8 = '%s' ", ts);
                        sprintf(sql + strlen(sql), "OR MAT_GRP_9 = '%s' ", ts);
                        sprintf(sql + strlen(sql), "OR MAT_GRP_10 = '%s') ", ts);
                    }
                    sprintf(sql + strlen(sql), ") ");
                } 
            }
            sprintf(sql + strlen(sql), "ORDER BY WORK_DATE, MAT_ID ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MWIPPLNDEF_CUR_51 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MWIPPLNDEF_CUR_51;                 
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipplndef", sel_type);
}


