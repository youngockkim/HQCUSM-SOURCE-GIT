/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwiplotqtm(int sel_type, struct MWIPLOTQTM_TAG *MWIPLOTQTM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTQTM_N_TAG MWIPLOTQTM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplotqtm(&MWIPLOTQTM_N, MWIPLOTQTM);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPLOTQTM_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    FROM_FACTORY,
                    FROM_FLOW,
                    FROM_FLOW_SEQ_NUM,
                    FROM_OPER,
                    QUEUE_TIME,
                    NEG_QUEUE_TIME,
                    CAL_SOURCE_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    OPT_LEVEL,
                    OPER_IN_TIME,
                    QUEUE_TIME_FROM_OPER_IN,
                    NEG_QUEUE_TIME_FROM_OPER_IN,
                    QUEUE_TIME_FROM_START,
                    NEG_QUEUE_TIME_FROM_START,
                    QUEUE_TIME_FROM_END,
                    NEG_QUEUE_TIME_FROM_END
                FROM MWIPLOTQTM
                WHERE LOT_ID = :MWIPLOTQTM_N.LOT_ID
                ORDER BY HIST_SEQ DESC;
            EXEC SQL OPEN DBC_MWIPLOTQTM_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mwiplotqtm", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mwiplotqtm(int sel_type, struct MWIPLOTQTM_TAG *MWIPLOTQTM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTQTM_N_TAG MWIPLOTQTM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
