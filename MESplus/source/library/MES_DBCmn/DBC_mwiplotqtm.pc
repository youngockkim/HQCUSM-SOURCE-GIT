/* Add Null Function */
void DBC_add_null_mwiplotqtm(struct MWIPLOTQTM_N_TAG *MWIPLOTQTM_N, struct MWIPLOTQTM_TAG *MWIPLOTQTM)
{
    /* memset by NULL */
    memset(MWIPLOTQTM_N, '\0', sizeof(struct MWIPLOTQTM_N_TAG));
    
    MEMCPY_AN(MWIPLOTQTM_N->LOT_ID, MWIPLOTQTM->LOT_ID, sizeof(MWIPLOTQTM->LOT_ID));
    MWIPLOTQTM_N->HIST_SEQ = MWIPLOTQTM->HIST_SEQ;
    MEMCPY_AN(MWIPLOTQTM_N->FROM_FACTORY, MWIPLOTQTM->FROM_FACTORY, sizeof(MWIPLOTQTM->FROM_FACTORY));
    MEMCPY_AN(MWIPLOTQTM_N->FROM_FLOW, MWIPLOTQTM->FROM_FLOW, sizeof(MWIPLOTQTM->FROM_FLOW));
    MWIPLOTQTM_N->FROM_FLOW_SEQ_NUM = MWIPLOTQTM->FROM_FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPLOTQTM_N->FROM_OPER, MWIPLOTQTM->FROM_OPER, sizeof(MWIPLOTQTM->FROM_OPER));
    MWIPLOTQTM_N->QUEUE_TIME = MWIPLOTQTM->QUEUE_TIME;
    MWIPLOTQTM_N->NEG_QUEUE_TIME = MWIPLOTQTM->NEG_QUEUE_TIME;
    MWIPLOTQTM_N->CAL_SOURCE_FLAG[0] = MWIPLOTQTM->CAL_SOURCE_FLAG;
    MEMCPY_AN(MWIPLOTQTM_N->FACTORY, MWIPLOTQTM->FACTORY, sizeof(MWIPLOTQTM->FACTORY));
    MEMCPY_AN(MWIPLOTQTM_N->MAT_ID, MWIPLOTQTM->MAT_ID, sizeof(MWIPLOTQTM->MAT_ID));
    MWIPLOTQTM_N->MAT_VER = MWIPLOTQTM->MAT_VER;
    MEMCPY_AN(MWIPLOTQTM_N->FLOW, MWIPLOTQTM->FLOW, sizeof(MWIPLOTQTM->FLOW));
    MWIPLOTQTM_N->FLOW_SEQ_NUM = MWIPLOTQTM->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPLOTQTM_N->OPER, MWIPLOTQTM->OPER, sizeof(MWIPLOTQTM->OPER));
    MWIPLOTQTM_N->OPT_LEVEL[0] = MWIPLOTQTM->OPT_LEVEL;
    MEMCPY_AN(MWIPLOTQTM_N->OPER_IN_TIME, MWIPLOTQTM->OPER_IN_TIME, sizeof(MWIPLOTQTM->OPER_IN_TIME));
    MWIPLOTQTM_N->QUEUE_TIME_FROM_OPER_IN = MWIPLOTQTM->QUEUE_TIME_FROM_OPER_IN;
    MWIPLOTQTM_N->NEG_QUEUE_TIME_FROM_OPER_IN = MWIPLOTQTM->NEG_QUEUE_TIME_FROM_OPER_IN;
    MWIPLOTQTM_N->QUEUE_TIME_FROM_START = MWIPLOTQTM->QUEUE_TIME_FROM_START;
