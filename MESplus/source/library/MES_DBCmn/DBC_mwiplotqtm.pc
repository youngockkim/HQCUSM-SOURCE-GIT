                :MWIPLOTQTM_N.FROM_OPER,
                :MWIPLOTQTM_N.QUEUE_TIME,
                :MWIPLOTQTM_N.NEG_QUEUE_TIME,
                :MWIPLOTQTM_N.CAL_SOURCE_FLAG,
                :MWIPLOTQTM_N.FACTORY,
                :MWIPLOTQTM_N.MAT_ID,
                :MWIPLOTQTM_N.MAT_VER,
                :MWIPLOTQTM_N.FLOW,
