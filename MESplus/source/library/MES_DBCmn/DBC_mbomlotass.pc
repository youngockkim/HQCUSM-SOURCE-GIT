    /* memset by NULL */
    memset(MBOMLOTASS_N, '\0', sizeof(struct MBOMLOTASS_N_TAG));
    
    MEMCPY_AN(MBOMLOTASS_N->FACTORY, MBOMLOTASS->FACTORY, sizeof(MBOMLOTASS->FACTORY));
    MEMCPY_AN(MBOMLOTASS_N->LOT_ID, MBOMLOTASS->LOT_ID, sizeof(MBOMLOTASS->LOT_ID));
    MEMCPY_AN(MBOMLOTASS_N->BOM_SET_ID, MBOMLOTASS->BOM_SET_ID, sizeof(MBOMLOTASS->BOM_SET_ID));
    MBOMLOTASS_N->BOM_SET_VERSION = MBOMLOTASS->BOM_SET_VERSION;
    MBOMLOTASS_N->SEQ_NUM = MBOMLOTASS->SEQ_NUM;
    MBOMLOTASS_N->SERIAL_SEQ_NUM = MBOMLOTASS->SERIAL_SEQ_NUM;
    MEMCPY_AN(MBOMLOTASS_N->PART_GRP, MBOMLOTASS->PART_GRP, sizeof(MBOMLOTASS->PART_GRP));
    MBOMLOTASS_N->ALT_MAT_FLAG[0] = MBOMLOTASS->ALT_MAT_FLAG;
    MEMCPY_AN(MBOMLOTASS_N->MAT_ID, MBOMLOTASS->MAT_ID, sizeof(MBOMLOTASS->MAT_ID));
    MBOMLOTASS_N->MAT_VER = MBOMLOTASS->MAT_VER;
    MBOMLOTASS_N->MAT_QTY = MBOMLOTASS->MAT_QTY;
    MEMCPY_AN(MBOMLOTASS_N->MAT_UNIT, MBOMLOTASS->MAT_UNIT, sizeof(MBOMLOTASS->MAT_UNIT));
    MBOMLOTASS_N->MAT_ATT_QTY = MBOMLOTASS->MAT_ATT_QTY;
    MEMCPY_AN(MBOMLOTASS_N->SERIAL_ID, MBOMLOTASS->SERIAL_ID, sizeof(MBOMLOTASS->SERIAL_ID));
    MBOMLOTASS_N->SERIAL_TYPE[0] = MBOMLOTASS->SERIAL_TYPE;
    MEMCPY_AN(MBOMLOTASS_N->FLOW, MBOMLOTASS->FLOW, sizeof(MBOMLOTASS->FLOW));
    MEMCPY_AN(MBOMLOTASS_N->OPER, MBOMLOTASS->OPER, sizeof(MBOMLOTASS->OPER));
    MEMCPY_AN(MBOMLOTASS_N->CREATE_USER_ID, MBOMLOTASS->CREATE_USER_ID, sizeof(MBOMLOTASS->CREATE_USER_ID));
    MEMCPY_AN(MBOMLOTASS_N->CREATE_TIME, MBOMLOTASS->CREATE_TIME, sizeof(MBOMLOTASS->CREATE_TIME));
    MEMCPY_AN(MBOMLOTASS_N->UPDATE_USER_ID, MBOMLOTASS->UPDATE_USER_ID, sizeof(MBOMLOTASS->UPDATE_USER_ID));
    MEMCPY_AN(MBOMLOTASS_N->UPDATE_TIME, MBOMLOTASS->UPDATE_TIME, sizeof(MBOMLOTASS->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mbomlotass(struct MBOMLOTASS_N_TAG *MBOMLOTASS_N, struct MBOMLOTASS_TAG *MBOMLOTASS)
{
    MEMCPY_DN(MBOMLOTASS->FACTORY, MBOMLOTASS_N->FACTORY, sizeof(MBOMLOTASS->FACTORY));
    MEMCPY_DN(MBOMLOTASS->LOT_ID, MBOMLOTASS_N->LOT_ID, sizeof(MBOMLOTASS->LOT_ID));
    MEMCPY_DN(MBOMLOTASS->BOM_SET_ID, MBOMLOTASS_N->BOM_SET_ID, sizeof(MBOMLOTASS->BOM_SET_ID));
    MBOMLOTASS->BOM_SET_VERSION = MBOMLOTASS_N->BOM_SET_VERSION;
    MBOMLOTASS->SEQ_NUM = MBOMLOTASS_N->SEQ_NUM;
    MBOMLOTASS->SERIAL_SEQ_NUM = MBOMLOTASS_N->SERIAL_SEQ_NUM;
    MEMCPY_DN(MBOMLOTASS->PART_GRP, MBOMLOTASS_N->PART_GRP, sizeof(MBOMLOTASS->PART_GRP));
    MBOMLOTASS->ALT_MAT_FLAG = MBOMLOTASS_N->ALT_MAT_FLAG[0];
    MEMCPY_DN(MBOMLOTASS->MAT_ID, MBOMLOTASS_N->MAT_ID, sizeof(MBOMLOTASS->MAT_ID));
    MBOMLOTASS->MAT_VER = MBOMLOTASS_N->MAT_VER;
    MBOMLOTASS->MAT_QTY = MBOMLOTASS_N->MAT_QTY;
    MEMCPY_DN(MBOMLOTASS->MAT_UNIT, MBOMLOTASS_N->MAT_UNIT, sizeof(MBOMLOTASS->MAT_UNIT));
    MBOMLOTASS->MAT_ATT_QTY = MBOMLOTASS_N->MAT_ATT_QTY;
    MEMCPY_DN(MBOMLOTASS->SERIAL_ID, MBOMLOTASS_N->SERIAL_ID, sizeof(MBOMLOTASS->SERIAL_ID));
    MBOMLOTASS->SERIAL_TYPE = MBOMLOTASS_N->SERIAL_TYPE[0];
    MEMCPY_DN(MBOMLOTASS->FLOW, MBOMLOTASS_N->FLOW, sizeof(MBOMLOTASS->FLOW));
    MEMCPY_DN(MBOMLOTASS->OPER, MBOMLOTASS_N->OPER, sizeof(MBOMLOTASS->OPER));
    MEMCPY_DN(MBOMLOTASS->CREATE_USER_ID, MBOMLOTASS_N->CREATE_USER_ID, sizeof(MBOMLOTASS->CREATE_USER_ID));
    MEMCPY_DN(MBOMLOTASS->CREATE_TIME, MBOMLOTASS_N->CREATE_TIME, sizeof(MBOMLOTASS->CREATE_TIME));
    MEMCPY_DN(MBOMLOTASS->UPDATE_USER_ID, MBOMLOTASS_N->UPDATE_USER_ID, sizeof(MBOMLOTASS->UPDATE_USER_ID));
    MEMCPY_DN(MBOMLOTASS->UPDATE_TIME, MBOMLOTASS_N->UPDATE_TIME, sizeof(MBOMLOTASS->UPDATE_TIME));
}


