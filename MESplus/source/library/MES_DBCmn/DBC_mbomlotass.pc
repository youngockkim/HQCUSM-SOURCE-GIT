/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mbomlotass(int sel_type, struct MBOMLOTASS_TAG *MBOMLOTASS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBOMLOTASS_N_TAG MBOMLOTASS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbomlotass(&MBOMLOTASS_N, MBOMLOTASS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MBOMLOTASS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOT_ID,
                    BOM_SET_ID,
                    BOM_SET_VERSION,
                    SEQ_NUM,
                    SERIAL_SEQ_NUM,
                    PART_GRP,
                    ALT_MAT_FLAG,
                    MAT_ID,
                    MAT_VER,
                    MAT_QTY,
                    MAT_UNIT,
                    MAT_ATT_QTY,
                    SERIAL_ID,
                    SERIAL_TYPE,
                    FLOW,
                    OPER,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MBOMLOTASS
                WHERE FACTORY = :MBOMLOTASS_N.FACTORY
                    AND LOT_ID = :MBOMLOTASS_N.LOT_ID
                    AND BOM_SET_ID = :MBOMLOTASS_N.BOM_SET_ID
                    AND BOM_SET_VERSION = :MBOMLOTASS_N.BOM_SET_VERSION
                    AND SEQ_NUM = :MBOMLOTASS_N.SEQ_NUM
                ORDER BY SERIAL_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MBOMLOTASS_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MBOMLOTASS_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOT_ID,
                    BOM_SET_ID,
                    BOM_SET_VERSION,
                    SEQ_NUM,
                    SERIAL_SEQ_NUM,
                    PART_GRP,
                    ALT_MAT_FLAG,
                    MAT_ID,
                    MAT_VER,
                    MAT_QTY,
                    MAT_UNIT,
                    MAT_ATT_QTY,
                    SERIAL_ID,
                    SERIAL_TYPE,
                    FLOW,
                    OPER,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MBOMLOTASS
                WHERE FACTORY = :MBOMLOTASS_N.FACTORY
                    AND LOT_ID = :MBOMLOTASS_N.LOT_ID
                    AND ( (SEQ_NUM > :MBOMLOTASS_N.SEQ_NUM) 
                       OR (SEQ_NUM = :MBOMLOTASS_N.SEQ_NUM AND SERIAL_SEQ_NUM >= :MBOMLOTASS_N.SERIAL_SEQ_NUM) )
                ORDER BY BOM_SET_VERSION ASC, SEQ_NUM ASC, SERIAL_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MBOMLOTASS_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MBOMLOTASS_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOT_ID,
                    BOM_SET_ID,
                    BOM_SET_VERSION,
                    SEQ_NUM,
                    SERIAL_SEQ_NUM,
                    PART_GRP,
                    ALT_MAT_FLAG,
                    MAT_ID,
                    MAT_VER,
                    MAT_QTY,
                    MAT_UNIT,
                    MAT_ATT_QTY,
                    SERIAL_ID,
                    SERIAL_TYPE,
                    FLOW,
                    OPER,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MBOMLOTASS
                WHERE FACTORY = :MBOMLOTASS_N.FACTORY
                    AND LOT_ID = :MBOMLOTASS_N.LOT_ID
                    AND BOM_SET_ID = :MBOMLOTASS_N.BOM_SET_ID
                    AND BOM_SET_VERSION = :MBOMLOTASS_N.BOM_SET_VERSION
                    AND ( (SEQ_NUM > :MBOMLOTASS_N.SEQ_NUM) 
                       OR (SEQ_NUM = :MBOMLOTASS_N.SEQ_NUM AND SERIAL_SEQ_NUM >= :MBOMLOTASS_N.SERIAL_SEQ_NUM) )
                    AND FLOW = :MBOMLOTASS_N.FLOW
                    AND OPER = :MBOMLOTASS_N.OPER
                ORDER BY SEQ_NUM ASC, SERIAL_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MBOMLOTASS_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mbomlotass", sel_type);
}


