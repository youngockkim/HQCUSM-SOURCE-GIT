                            TEST_TYPE,
                            INSPECTOR,
                            SHIFT,
                            IRRMRR,
                            QA_COMMENT,
                            ALARM_CODE,
                            HIST_DEL_FLAG,
                            HIST_DEL_TIME,
                            HIST_DEL_USER,
                            HIST_DEL_COMMENT,
                            QA_CMF_1,
                            QA_CMF_2,
                            QA_CMF_3,
                            QA_CMF_4,
                            QA_CMF_5,
                            QA_CMF_6,
                            QA_CMF_7,
                            QA_CMF_8,
                            QA_CMF_9,
                            QA_CMF_10,
                            RESV_FIELD_1,
                            RESV_FIELD_2,
                            RESV_FIELD_3,
                            RESV_FIELD_4,
