                    :MQCGLOTHIS_N.BACKSIDE_ISSUE_4,
                    :MQCGLOTHIS_N.CP_QTY,
                    :MQCGLOTHIS_N.GOOD_QTY,
                    :MQCGLOTHIS_N.LOT_YIELD,
                    :MQCGLOTHIS_N.UNION_LOT_YIELD
                FROM (
                    SELECT 
                            LOT_ID,
                            HIST_SEQ,
                            QA_HIST_SEQ,
                            TRAN_TIME,
                            FACTORY,
                            MAT_ID,
                            MAT_VER,
