                    QTY_3 = :MQCGSLTDEF_N.QTY_3,
                    DEF_QTY_FLAG = :MQCGSLTDEF_N.DEF_QTY_FLAG,
                    DEF_QTY = :MQCGSLTDEF_N.DEF_QTY,
                    YIELD = :MQCGSLTDEF_N.YIELD,
                    HIST_DEL_FLAG = :MQCGSLTDEF_N.HIST_DEL_FLAG,
                    HIST_DEL_TIME = :MQCGSLTDEF_N.HIST_DEL_TIME,
                    HIST_DEL_USER = :MQCGSLTDEF_N.HIST_DEL_USER,
                    HIST_DEL_COMMENT = :MQCGSLTDEF_N.HIST_DEL_COMMENT,
                    RESV_FIELD_1 = :MQCGSLTDEF_N.RESV_FIELD_1,
                    RESV_FIELD_2 = :MQCGSLTDEF_N.RESV_FIELD_2,
                    RESV_FIELD_3 = :MQCGSLTDEF_N.RESV_FIELD_3,
                    RESV_FIELD_4 = :MQCGSLTDEF_N.RESV_FIELD_4,
                    RESV_FIELD_5 = :MQCGSLTDEF_N.RESV_FIELD_5,
                    RESV_FIELD_6 = :MQCGSLTDEF_N.RESV_FIELD_6,
                    RESV_FIELD_7 = :MQCGSLTDEF_N.RESV_FIELD_7,
                    RESV_FIELD_8 = :MQCGSLTDEF_N.RESV_FIELD_8,
                    RESV_FIELD_9 = :MQCGSLTDEF_N.RESV_FIELD_9,
                    RESV_FIELD_10 = :MQCGSLTDEF_N.RESV_FIELD_10
                WHERE LOT_ID = :MQCGSLTDEF_N.LOT_ID
                    AND HIST_SEQ = :MQCGSLTDEF_N.HIST_SEQ
                    AND SUBLOT_ID = :MQCGSLTDEF_N.SUBLOT_ID
                    AND QA_HIST_SEQ = :MQCGSLTDEF_N.QA_HIST_SEQ
                    AND DEF_CODE = :MQCGSLTDEF_N.DEF_CODE
                    AND LOC_X = :MQCGSLTDEF_N.LOC_X
                    AND LOC_Y = :MQCGSLTDEF_N.LOC_Y
                    AND LOC_Z = :MQCGSLTDEF_N.LOC_Z
                    AND CELL_X = :MQCGSLTDEF_N.CELL_X
                    AND CELL_Y = :MQCGSLTDEF_N.CELL_Y
                    AND CELL_Z = :MQCGSLTDEF_N.CELL_Z;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mqcgsltdef", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mqcgsltdef(int sel_type, struct MQCGSLTDEF_TAG *MQCGSLTDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
    struct MQCGSLTDEF_N_TAG MQCGSLTDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mqcgsltdef(&MQCGSLTDEF_N, MQCGSLTDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MQCGSLTDEF_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    SUBLOT_ID,
                    SUB_LOT_HIST_SEQ,
                    SLOT_NO,
                    QA_HIST_SEQ,
                    TRAN_TIME,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    QA_OPER,
                    RES_ID,
                    CRR_ID,
                    QTY_2,
                    QTY_3,
                    DEF_QTY_FLAG,
                    DEF_CODE,
                    DEF_QTY,
                    YIELD,
                    LOC_X,
                    LOC_Y,
                    LOC_Z,
                    CELL_X,
                    CELL_Y,
                    CELL_Z,
                    HIST_DEL_FLAG,
                    HIST_DEL_TIME,
                    HIST_DEL_USER,
                    HIST_DEL_COMMENT,
                    RESV_FIELD_1,
                    RESV_FIELD_2,
                    RESV_FIELD_3,
                    RESV_FIELD_4,
                    RESV_FIELD_5,
                    RESV_FIELD_6,
                    RESV_FIELD_7,
                    RESV_FIELD_8,
                    RESV_FIELD_9,
                    RESV_FIELD_10
                FROM MQCGSLTDEF
                WHERE LOT_ID = :MQCGSLTDEF_N.LOT_ID
                AND HIST_SEQ = :MQCGSLTDEF_N.HIST_SEQ
                AND QA_HIST_SEQ = :MQCGSLTDEF_N.QA_HIST_SEQ
                ORDER BY 
                    SLOT_NO ASC,
                    DEF_CODE ASC,
                    LOC_X ASC,
                    LOC_Y ASC,
                    LOC_Z ASC,
                    CELL_X ASC,
                    CELL_Y ASC,
                    CELL_Z ASC;
            EXEC SQL OPEN DBC_MQCGSLTDEF_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mqcgsltdef", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mqcgsltdef(int sel_type, struct MQCGSLTDEF_TAG *MQCGSLTDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
    struct MQCGSLTDEF_N_TAG MQCGSLTDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MQCGSLTDEF_CUR_1 INTO
                :MQCGSLTDEF_N.LOT_ID,
                :MQCGSLTDEF_N.HIST_SEQ,
                :MQCGSLTDEF_N.SUBLOT_ID,
                :MQCGSLTDEF_N.SUB_LOT_HIST_SEQ,
                :MQCGSLTDEF_N.SLOT_NO,
                :MQCGSLTDEF_N.QA_HIST_SEQ,
                :MQCGSLTDEF_N.TRAN_TIME,
                :MQCGSLTDEF_N.FACTORY,
                :MQCGSLTDEF_N.MAT_ID,
                :MQCGSLTDEF_N.MAT_VER,
                :MQCGSLTDEF_N.FLOW,
                :MQCGSLTDEF_N.FLOW_SEQ_NUM,
                :MQCGSLTDEF_N.OPER,
                :MQCGSLTDEF_N.QA_OPER,
                :MQCGSLTDEF_N.RES_ID,
                :MQCGSLTDEF_N.CRR_ID,
                :MQCGSLTDEF_N.QTY_2,
                :MQCGSLTDEF_N.QTY_3,
                :MQCGSLTDEF_N.DEF_QTY_FLAG,
                :MQCGSLTDEF_N.DEF_CODE,
                :MQCGSLTDEF_N.DEF_QTY,
                :MQCGSLTDEF_N.YIELD,
                :MQCGSLTDEF_N.LOC_X,
                :MQCGSLTDEF_N.LOC_Y,
                :MQCGSLTDEF_N.LOC_Z,
                :MQCGSLTDEF_N.CELL_X,
                :MQCGSLTDEF_N.CELL_Y,
                :MQCGSLTDEF_N.CELL_Z,
                :MQCGSLTDEF_N.HIST_DEL_FLAG,
                :MQCGSLTDEF_N.HIST_DEL_TIME,
                :MQCGSLTDEF_N.HIST_DEL_USER,
                :MQCGSLTDEF_N.HIST_DEL_COMMENT,
                :MQCGSLTDEF_N.RESV_FIELD_1,
                :MQCGSLTDEF_N.RESV_FIELD_2,
                :MQCGSLTDEF_N.RESV_FIELD_3,
                :MQCGSLTDEF_N.RESV_FIELD_4,
                :MQCGSLTDEF_N.RESV_FIELD_5,
                :MQCGSLTDEF_N.RESV_FIELD_6,
                :MQCGSLTDEF_N.RESV_FIELD_7,
                :MQCGSLTDEF_N.RESV_FIELD_8,
                :MQCGSLTDEF_N.RESV_FIELD_9,
                :MQCGSLTDEF_N.RESV_FIELD_10;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mqcgsltdef(&MQCGSLTDEF_N, MQCGSLTDEF);
    }
    DB_stop_query_timer("DBC_fetch_mqcgsltdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mqcgsltdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MQCGSLTDEF_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mqcgsltdef", sel_type);
}


/* Initialize Function */
void DBC_init_mqcgsltdef(struct MQCGSLTDEF_TAG *MQCGSLTDEF)
{
    /* memset by Space */
    memset(MQCGSLTDEF, ' ', sizeof(struct MQCGSLTDEF_TAG));
    
    MQCGSLTDEF->HIST_SEQ = 0;
    MQCGSLTDEF->SUB_LOT_HIST_SEQ = 0;
    MQCGSLTDEF->SLOT_NO = 0;
    MQCGSLTDEF->QA_HIST_SEQ = 0;
    MQCGSLTDEF->MAT_VER = 0;
    MQCGSLTDEF->FLOW_SEQ_NUM = 0;
    MQCGSLTDEF->QTY_2 = 0;
    MQCGSLTDEF->QTY_3 = 0;
    MQCGSLTDEF->DEF_QTY = 0;
    MQCGSLTDEF->YIELD = 0;
    MQCGSLTDEF->LOC_X = 0;
    MQCGSLTDEF->LOC_Y = 0;
    MQCGSLTDEF->LOC_Z = 0;
    MQCGSLTDEF->CELL_X = 0;
    MQCGSLTDEF->CELL_Y = 0;
    MQCGSLTDEF->CELL_Z = 0;
}


/* Add Null Function */
void DBC_add_null_mqcgsltdef(struct MQCGSLTDEF_N_TAG *MQCGSLTDEF_N, struct MQCGSLTDEF_TAG *MQCGSLTDEF)
{
    /* memset by NULL */
    memset(MQCGSLTDEF_N, '\0', sizeof(struct MQCGSLTDEF_N_TAG));
    
    MEMCPY_AN(MQCGSLTDEF_N->LOT_ID, MQCGSLTDEF->LOT_ID, sizeof(MQCGSLTDEF->LOT_ID));
    MQCGSLTDEF_N->HIST_SEQ = MQCGSLTDEF->HIST_SEQ;
