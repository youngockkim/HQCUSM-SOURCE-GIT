/* Del Null Function */
void DBC_del_null_mqcgsltdef(struct MQCGSLTDEF_N_TAG *MQCGSLTDEF_N, struct MQCGSLTDEF_TAG *MQCGSLTDEF)
{
    MEMCPY_DN(MQCGSLTDEF->LOT_ID, MQCGSLTDEF_N->LOT_ID, sizeof(MQCGSLTDEF->LOT_ID));
    MQCGSLTDEF->HIST_SEQ = MQCGSLTDEF_N->HIST_SEQ;
