    MSVMERRLOG->STATUS_VALUE = MSVMERRLOG_N->STATUS_VALUE[0];
    MEMCPY_DN(MSVMERRLOG->ERROR_MSG, MSVMERRLOG_N->ERROR_MSG, sizeof(MSVMERRLOG->ERROR_MSG));
    MEMCPY_DN(MSVMERRLOG->DB_ERROR_MSG, MSVMERRLOG_N->DB_ERROR_MSG, sizeof(MSVMERRLOG->DB_ERROR_MSG));
