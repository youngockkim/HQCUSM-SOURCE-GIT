            break;
    }
    DB_stop_query_timer("DBC_close_msvmerrlog", sel_type);
}


/* Initialize Function */
void DBC_init_msvmerrlog(struct MSVMERRLOG_TAG *MSVMERRLOG)
{
    /* memset by Space */
    memset(MSVMERRLOG, ' ', sizeof(struct MSVMERRLOG_TAG));
    
    MSVMERRLOG->SEQ_NUM = 0;
    MSVMERRLOG->CONSUME_SEC = 0;
}


/* Add Null Function */
void DBC_add_null_msvmerrlog(struct MSVMERRLOG_N_TAG *MSVMERRLOG_N, struct MSVMERRLOG_TAG *MSVMERRLOG)
{
    /* memset by NULL */
    memset(MSVMERRLOG_N, '\0', sizeof(struct MSVMERRLOG_N_TAG));
    
    MSVMERRLOG_N->SEQ_NUM = MSVMERRLOG->SEQ_NUM;
    MEMCPY_AN(MSVMERRLOG_N->TRAN_TIME, MSVMERRLOG->TRAN_TIME, sizeof(MSVMERRLOG->TRAN_TIME));
    MEMCPY_AN(MSVMERRLOG_N->SYSTEM_NODE, MSVMERRLOG->SYSTEM_NODE, sizeof(MSVMERRLOG->SYSTEM_NODE));
    MEMCPY_AN(MSVMERRLOG_N->SERVER_NAME, MSVMERRLOG->SERVER_NAME, sizeof(MSVMERRLOG->SERVER_NAME));
    MEMCPY_AN(MSVMERRLOG_N->SUBNO, MSVMERRLOG->SUBNO, sizeof(MSVMERRLOG->SUBNO));
    MEMCPY_AN(MSVMERRLOG_N->SERVICE_NAME, MSVMERRLOG->SERVICE_NAME, sizeof(MSVMERRLOG->SERVICE_NAME));
    MEMCPY_AN(MSVMERRLOG_N->FACTORY, MSVMERRLOG->FACTORY, sizeof(MSVMERRLOG->FACTORY));
    MEMCPY_AN(MSVMERRLOG_N->RES_ID, MSVMERRLOG->RES_ID, sizeof(MSVMERRLOG->RES_ID));
    MEMCPY_AN(MSVMERRLOG_N->LOT_ID, MSVMERRLOG->LOT_ID, sizeof(MSVMERRLOG->LOT_ID));
    MEMCPY_AN(MSVMERRLOG_N->MSG_ID, MSVMERRLOG->MSG_ID, sizeof(MSVMERRLOG->MSG_ID));
    MSVMERRLOG_N->STATUS_VALUE[0] = MSVMERRLOG->STATUS_VALUE;
    MEMCPY_AN(MSVMERRLOG_N->ERROR_MSG, MSVMERRLOG->ERROR_MSG, sizeof(MSVMERRLOG->ERROR_MSG));
    MEMCPY_AN(MSVMERRLOG_N->DB_ERROR_MSG, MSVMERRLOG->DB_ERROR_MSG, sizeof(MSVMERRLOG->DB_ERROR_MSG));
    MEMCPY_AN(MSVMERRLOG_N->ERROR_MSG_DETAIL, MSVMERRLOG->ERROR_MSG_DETAIL, sizeof(MSVMERRLOG->ERROR_MSG_DETAIL));
    MEMCPY_AN(MSVMERRLOG_N->IN_MSG, MSVMERRLOG->IN_MSG, sizeof(MSVMERRLOG->IN_MSG));
    MSVMERRLOG_N->CONSUME_SEC = MSVMERRLOG->CONSUME_SEC;
    MEMCPY_AN(MSVMERRLOG_N->ERR_CMF_1, MSVMERRLOG->ERR_CMF_1, sizeof(MSVMERRLOG->ERR_CMF_1));
    MEMCPY_AN(MSVMERRLOG_N->ERR_CMF_2, MSVMERRLOG->ERR_CMF_2, sizeof(MSVMERRLOG->ERR_CMF_2));
    MEMCPY_AN(MSVMERRLOG_N->ERR_CMF_3, MSVMERRLOG->ERR_CMF_3, sizeof(MSVMERRLOG->ERR_CMF_3));
    MEMCPY_AN(MSVMERRLOG_N->ERR_CMF_4, MSVMERRLOG->ERR_CMF_4, sizeof(MSVMERRLOG->ERR_CMF_4));
    MEMCPY_AN(MSVMERRLOG_N->ERR_CMF_5, MSVMERRLOG->ERR_CMF_5, sizeof(MSVMERRLOG->ERR_CMF_5));
    MEMCPY_AN(MSVMERRLOG_N->ERR_CMF_6, MSVMERRLOG->ERR_CMF_6, sizeof(MSVMERRLOG->ERR_CMF_6));
    MEMCPY_AN(MSVMERRLOG_N->ERR_CMF_7, MSVMERRLOG->ERR_CMF_7, sizeof(MSVMERRLOG->ERR_CMF_7));
    MEMCPY_AN(MSVMERRLOG_N->ERR_CMF_8, MSVMERRLOG->ERR_CMF_8, sizeof(MSVMERRLOG->ERR_CMF_8));
    MEMCPY_AN(MSVMERRLOG_N->ERR_CMF_9, MSVMERRLOG->ERR_CMF_9, sizeof(MSVMERRLOG->ERR_CMF_9));
    MEMCPY_AN(MSVMERRLOG_N->ERR_CMF_10, MSVMERRLOG->ERR_CMF_10, sizeof(MSVMERRLOG->ERR_CMF_10));
    MEMCPY_AN(MSVMERRLOG_N->CREATE_USER_ID, MSVMERRLOG->CREATE_USER_ID, sizeof(MSVMERRLOG->CREATE_USER_ID));
    MEMCPY_AN(MSVMERRLOG_N->CREATE_TIME, MSVMERRLOG->CREATE_TIME, sizeof(MSVMERRLOG->CREATE_TIME));
    MEMCPY_AN(MSVMERRLOG_N->UPDATE_USER_ID, MSVMERRLOG->UPDATE_USER_ID, sizeof(MSVMERRLOG->UPDATE_USER_ID));
    MEMCPY_AN(MSVMERRLOG_N->UPDATE_TIME, MSVMERRLOG->UPDATE_TIME, sizeof(MSVMERRLOG->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_msvmerrlog(struct MSVMERRLOG_N_TAG *MSVMERRLOG_N, struct MSVMERRLOG_TAG *MSVMERRLOG)
{
    MSVMERRLOG->SEQ_NUM = MSVMERRLOG_N->SEQ_NUM;
    MEMCPY_DN(MSVMERRLOG->TRAN_TIME, MSVMERRLOG_N->TRAN_TIME, sizeof(MSVMERRLOG->TRAN_TIME));
    MEMCPY_DN(MSVMERRLOG->SYSTEM_NODE, MSVMERRLOG_N->SYSTEM_NODE, sizeof(MSVMERRLOG->SYSTEM_NODE));
    MEMCPY_DN(MSVMERRLOG->SERVER_NAME, MSVMERRLOG_N->SERVER_NAME, sizeof(MSVMERRLOG->SERVER_NAME));
