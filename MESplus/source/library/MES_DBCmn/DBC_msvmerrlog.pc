    MEMCPY_DN(MSVMERRLOG->ERR_CMF_8, MSVMERRLOG_N->ERR_CMF_8, sizeof(MSVMERRLOG->ERR_CMF_8));
    MEMCPY_DN(MSVMERRLOG->ERR_CMF_9, MSVMERRLOG_N->ERR_CMF_9, sizeof(MSVMERRLOG->ERR_CMF_9));
