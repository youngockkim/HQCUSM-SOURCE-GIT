/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_msvmerrlog(int sel_type, struct MSVMERRLOG_TAG *MSVMERRLOG)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSVMERRLOG_N_TAG MSVMERRLOG_N;
        char sql[5120];
        char ts1[100];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_msvmerrlog(&MSVMERRLOG_N, MSVMERRLOG);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            memset( sql, 0x00, sizeof(sql));
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "SEQ_NUM, ");
            sprintf(sql + strlen(sql),   "TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "SYSTEM_NODE, ");
            sprintf(sql + strlen(sql),   "SERVER_NAME, ");
            sprintf(sql + strlen(sql),   "SUBNO, ");
            sprintf(sql + strlen(sql),   "SERVICE_NAME, ");
            sprintf(sql + strlen(sql),   "FACTORY, ");
            sprintf(sql + strlen(sql),   "RES_ID, ");
            sprintf(sql + strlen(sql),   "LOT_ID, ");
            sprintf(sql + strlen(sql),   "MSG_ID, ");
            sprintf(sql + strlen(sql),   "STATUS_VALUE, ");
            sprintf(sql + strlen(sql),   "ERROR_MSG, ");
            sprintf(sql + strlen(sql),   "DB_ERROR_MSG, ");
            sprintf(sql + strlen(sql),   "ERROR_MSG_DETAIL, ");
            sprintf(sql + strlen(sql),   "IN_MSG, ");
            sprintf(sql + strlen(sql),   "CONSUME_SEC, ");
            sprintf(sql + strlen(sql),   "ERR_CMF_1, ");
            sprintf(sql + strlen(sql),   "ERR_CMF_2, ");
            sprintf(sql + strlen(sql),   "ERR_CMF_3, ");
            sprintf(sql + strlen(sql),   "ERR_CMF_4, ");
            sprintf(sql + strlen(sql),   "ERR_CMF_5, ");
            sprintf(sql + strlen(sql),   "ERR_CMF_6, ");
            sprintf(sql + strlen(sql),   "ERR_CMF_7, ");
            sprintf(sql + strlen(sql),   "ERR_CMF_8, ");
            sprintf(sql + strlen(sql),   "ERR_CMF_9, ");
            sprintf(sql + strlen(sql),   "ERR_CMF_10, ");
            sprintf(sql + strlen(sql),   "CREATE_USER_ID, ");
            sprintf(sql + strlen(sql),   "CREATE_TIME, ");
            sprintf(sql + strlen(sql),   "UPDATE_USER_ID, ");
            sprintf(sql + strlen(sql),   "UPDATE_TIME ");
            sprintf(sql + strlen(sql), "FROM MSVMERRLOG WHERE ");

            sprintf(sql + strlen(sql), "TRAN_TIME >= '%s' AND TRAN_TIME <= '%s' ", DBC_Q_COND_N.FROM_TIME, DBC_Q_COND_N.TO_TIME);
            sprintf(sql + strlen(sql), "AND SEQ_NUM <= '%d' ", MSVMERRLOG_N.SEQ_NUM);
            
            if(ISSPACE(MSVMERRLOG->RES_ID, sizeof(MSVMERRLOG->RES_ID)) == DB_FALSE)
            {
                make_valid_quote(ts1, MSVMERRLOG_N.RES_ID);
                sprintf(sql + strlen(sql), "AND RES_ID LIKE '%s%c' ", ts1, '%');
            }
            if(ISSPACE(MSVMERRLOG->MSG_ID, sizeof(MSVMERRLOG->MSG_ID)) == DB_FALSE)
            {
                make_valid_quote(ts1, MSVMERRLOG_N.MSG_ID);
                sprintf(sql + strlen(sql), "AND MSG_ID LIKE '%s%c' ", ts1, '%');
            }
            if(ISSPACE(MSVMERRLOG->SERVER_NAME, sizeof(MSVMERRLOG->SERVER_NAME)) == DB_FALSE)
            {
                make_valid_quote(ts1, MSVMERRLOG_N.SERVER_NAME);
                sprintf(sql + strlen(sql), "AND SERVER_NAME LIKE '%s%c' ", ts1, '%');
            }
            if(ISSPACE(MSVMERRLOG->SERVICE_NAME, sizeof(MSVMERRLOG->SERVICE_NAME)) == DB_FALSE)
            {
                make_valid_quote(ts1, MSVMERRLOG_N.SERVICE_NAME);
                sprintf(sql + strlen(sql), "AND SERVICE_NAME = '%s' ", ts1);
            }
            if(ISSPACE(MSVMERRLOG->LOT_ID, sizeof(MSVMERRLOG->LOT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts1, MSVMERRLOG_N.LOT_ID);
                sprintf(sql + strlen(sql), "AND LOT_ID LIKE '%s%c' ", ts1, '%');
            }
            if(ISSPACE(MSVMERRLOG->DB_ERROR_MSG, sizeof(MSVMERRLOG->DB_ERROR_MSG)) == DB_FALSE)
            {
                make_valid_quote(ts1, MSVMERRLOG_N.DB_ERROR_MSG);
                sprintf(sql + strlen(sql), "AND DB_ERROR_MSG LIKE '%s%c' ", ts1, '%');
            }
            if(MSVMERRLOG->STATUS_VALUE != ' ')
            {
                sprintf(sql + strlen(sql), "AND STATUS_VALUE = '%c' ", MSVMERRLOG->STATUS_VALUE);
            }
            sprintf(sql + strlen(sql), "ORDER BY SEQ_NUM DESC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MSVMERRLOG_CUR_1 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MSVMERRLOG_CUR_1;                 
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_msvmerrlog", sel_type);
}


