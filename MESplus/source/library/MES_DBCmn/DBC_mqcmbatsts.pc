{
    MEMCPY_DN(MQCMBATSTS->FACTORY, MQCMBATSTS_N->FACTORY, sizeof(MQCMBATSTS->FACTORY));
    MEMCPY_DN(MQCMBATSTS->BATCH_ID, MQCMBATSTS_N->BATCH_ID, sizeof(MQCMBATSTS->BATCH_ID));
