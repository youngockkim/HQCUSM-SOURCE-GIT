            EXEC SQL CLOSE DBC_MRASCGRREL_CUR_3;
            break;
        case 4:
            EXEC SQL CLOSE DBC_MRASCGRREL_CUR_4;
            break;
        case 5:
            EXEC SQL CLOSE DBC_MRASCGRREL_CUR_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mrascgrrel", sel_type);
}


/* Initialize Function */
void DBC_init_mrascgrrel(struct MRASCGRREL_TAG *MRASCGRREL)
{
    /* memset by Space */
    memset(MRASCGRREL, ' ', sizeof(struct MRASCGRREL_TAG));
    
    MRASCGRREL->MAT_VER = 0;
    MRASCGRREL->PRI_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mrascgrrel(struct MRASCGRREL_N_TAG *MRASCGRREL_N, struct MRASCGRREL_TAG *MRASCGRREL)
{
    /* memset by NULL */
    memset(MRASCGRREL_N, '\0', sizeof(struct MRASCGRREL_N_TAG));
    
    MEMCPY_AN(MRASCGRREL_N->FACTORY, MRASCGRREL->FACTORY, sizeof(MRASCGRREL->FACTORY));
    MRASCGRREL_N->REL_LEVEL[0] = MRASCGRREL->REL_LEVEL;
    MEMCPY_AN(MRASCGRREL_N->MAT_ID, MRASCGRREL->MAT_ID, sizeof(MRASCGRREL->MAT_ID));
    MRASCGRREL_N->MAT_VER = MRASCGRREL->MAT_VER;
    MEMCPY_AN(MRASCGRREL_N->FLOW, MRASCGRREL->FLOW, sizeof(MRASCGRREL->FLOW));
    MEMCPY_AN(MRASCGRREL_N->OPER, MRASCGRREL->OPER, sizeof(MRASCGRREL->OPER));
    MEMCPY_AN(MRASCGRREL_N->RES_ID, MRASCGRREL->RES_ID, sizeof(MRASCGRREL->RES_ID));
    MEMCPY_AN(MRASCGRREL_N->PORT_ID, MRASCGRREL->PORT_ID, sizeof(MRASCGRREL->PORT_ID));
    MEMCPY_AN(MRASCGRREL_N->CRR_GROUP, MRASCGRREL->CRR_GROUP, sizeof(MRASCGRREL->CRR_GROUP));
    MRASCGRREL_N->PRI_SEQ = MRASCGRREL->PRI_SEQ;
    MEMCPY_AN(MRASCGRREL_N->CREATE_USER_ID, MRASCGRREL->CREATE_USER_ID, sizeof(MRASCGRREL->CREATE_USER_ID));
    MEMCPY_AN(MRASCGRREL_N->CREATE_TIME, MRASCGRREL->CREATE_TIME, sizeof(MRASCGRREL->CREATE_TIME));
    MEMCPY_AN(MRASCGRREL_N->UPDATE_USER_ID, MRASCGRREL->UPDATE_USER_ID, sizeof(MRASCGRREL->UPDATE_USER_ID));
    MEMCPY_AN(MRASCGRREL_N->UPDATE_TIME, MRASCGRREL->UPDATE_TIME, sizeof(MRASCGRREL->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mrascgrrel(struct MRASCGRREL_N_TAG *MRASCGRREL_N, struct MRASCGRREL_TAG *MRASCGRREL)
{
    MEMCPY_DN(MRASCGRREL->FACTORY, MRASCGRREL_N->FACTORY, sizeof(MRASCGRREL->FACTORY));
    MRASCGRREL->REL_LEVEL = MRASCGRREL_N->REL_LEVEL[0];
    MEMCPY_DN(MRASCGRREL->MAT_ID, MRASCGRREL_N->MAT_ID, sizeof(MRASCGRREL->MAT_ID));
    MRASCGRREL->MAT_VER = MRASCGRREL_N->MAT_VER;
    MEMCPY_DN(MRASCGRREL->FLOW, MRASCGRREL_N->FLOW, sizeof(MRASCGRREL->FLOW));
    MEMCPY_DN(MRASCGRREL->OPER, MRASCGRREL_N->OPER, sizeof(MRASCGRREL->OPER));
    MEMCPY_DN(MRASCGRREL->RES_ID, MRASCGRREL_N->RES_ID, sizeof(MRASCGRREL->RES_ID));
    MEMCPY_DN(MRASCGRREL->PORT_ID, MRASCGRREL_N->PORT_ID, sizeof(MRASCGRREL->PORT_ID));
    MEMCPY_DN(MRASCGRREL->CRR_GROUP, MRASCGRREL_N->CRR_GROUP, sizeof(MRASCGRREL->CRR_GROUP));
    MRASCGRREL->PRI_SEQ = MRASCGRREL_N->PRI_SEQ;
    MEMCPY_DN(MRASCGRREL->CREATE_USER_ID, MRASCGRREL_N->CREATE_USER_ID, sizeof(MRASCGRREL->CREATE_USER_ID));
    MEMCPY_DN(MRASCGRREL->CREATE_TIME, MRASCGRREL_N->CREATE_TIME, sizeof(MRASCGRREL->CREATE_TIME));
    MEMCPY_DN(MRASCGRREL->UPDATE_USER_ID, MRASCGRREL_N->UPDATE_USER_ID, sizeof(MRASCGRREL->UPDATE_USER_ID));
    MEMCPY_DN(MRASCGRREL->UPDATE_TIME, MRASCGRREL_N->UPDATE_TIME, sizeof(MRASCGRREL->UPDATE_TIME));
}


