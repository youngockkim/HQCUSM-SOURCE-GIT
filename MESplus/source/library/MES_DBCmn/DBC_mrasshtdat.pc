/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrasshtdat(int sel_type, struct MRASSHTDAT_TAG *MRASSHTDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASSHTDAT_N_TAG MRASSHTDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrasshtdat(&MRASSHTDAT_N, MRASSHTDAT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRASSHTDAT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    SHEET_NAME,
                    DATA_SEQ,
                    DATA_CODE,
                    SHEET_DATA,
                    RESULT_TYPE,
                    CHECK_VALUE,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                FROM MRASSHTDAT
                ORDER BY FACTORY ASC,
                    SHEET_NAME ASC,
                    DATA_SEQ ASC;
            EXEC SQL OPEN DBC_MRASSHTDAT_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MRASSHTDAT_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    SHEET_NAME,
                    DATA_SEQ,
                    DATA_CODE,
                    SHEET_DATA,
                    RESULT_TYPE,
                    CHECK_VALUE,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                  FROM MRASSHTDAT
                 WHERE FACTORY = :MRASSHTDAT_N.FACTORY
                   AND SHEET_NAME = :MRASSHTDAT_N.SHEET_NAME
                   AND DATA_SEQ >= :MRASSHTDAT_N.DATA_SEQ
                ORDER BY DATA_SEQ ASC;
            EXEC SQL OPEN DBC_MRASSHTDAT_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrasshtdat", sel_type);
}


