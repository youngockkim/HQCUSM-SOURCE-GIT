/* SQL CURSOR CLOSE Function */
void DBC_close_mwipmfodef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPMFODEF_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_MWIPMFODEF_CUR_2;
            break;
            
        case 3:
            EXEC SQL CLOSE DBC_MWIPMFODEF_CUR_3;
            break;
            
        case 4:
            EXEC SQL CLOSE DBC_MWIPMFODEF_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MWIPMFODEF_CUR_5;
            break;
        
        case 6:
            EXEC SQL CLOSE DBC_MWIPMFODEF_CUR_6;
            break;

        case 7:
            EXEC SQL CLOSE DBC_MWIPMFODEF_CUR_7;
            break;
        
        case 8:
            EXEC SQL CLOSE DBC_MWIPMFODEF_CUR_8;
            break;

        case 9:
            EXEC SQL CLOSE DBC_MWIPMFODEF_CUR_9;
            break;
        
        case 10:
            EXEC SQL CLOSE DBC_MWIPMFODEF_CUR_10;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipmfodef", sel_type);
}


/* Initialize Function */
void DBC_init_mwipmfodef(struct MWIPMFODEF_TAG *MWIPMFODEF)
{
    /* memset by Space */
    memset(MWIPMFODEF, ' ', sizeof(struct MWIPMFODEF_TAG));
    
    MWIPMFODEF->OPTION_SEQ = 0;
    MWIPMFODEF->MAT_VER = 0;
}


