                    AND RES_TYPE = :MWIPMFODEF_N.RES_TYPE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mwipmfodef", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipmfodef(int sel_type, struct MWIPMFODEF_TAG *MWIPMFODEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPMFODEF_N_TAG MWIPMFODEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipmfodef(&MWIPMFODEF_N, MWIPMFODEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPMFODEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    OPTION_NAME,
                    OPTION_DESC,
                    OPTION_SEQ,
                    REL_LEVEL,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RES_ID,
                    RESG_ID,
                    RES_TYPE,
                    KEY_1,
                    KEY_2,
                    KEY_3,
                    KEY_4,
                    KEY_5,
                    DATA_1,
                    DATA_2,
                    DATA_3,
                    DATA_4,
                    DATA_5,
                    DATA_6,
