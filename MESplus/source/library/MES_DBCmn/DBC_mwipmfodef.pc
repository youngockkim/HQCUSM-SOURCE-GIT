                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPMFODEF
                ORDER BY FACTORY ASC,
                    OPTION_NAME ASC,
                    OPTION_SEQ ASC,
                    REL_LEVEL ASC,
                    MAT_ID ASC,
                    MAT_VER ASC,
                    FLOW ASC,
                    OPER ASC,
                    RES_ID ASC,
                    RESG_ID ASC,
                    RES_TYPE ASC;
            EXEC SQL OPEN DBC_MWIPMFODEF_CUR_1;
            break;
            
        case 2:
            /* Use material version up */
            EXEC SQL DECLARE DBC_MWIPMFODEF_CUR_2 CURSOR FOR
                SELECT 
