                FROM MEDCLOTDAT
                WHERE FACTORY = :MEDCLOTDAT_N.FACTORY
                    AND LOT_ID = :MEDCLOTDAT_N.LOT_ID
                    AND HIST_SEQ = :MEDCLOTDAT_N.HIST_SEQ 
                    AND COL_SEQ = :MEDCLOTDAT_N.COL_SEQ
                    AND COL_SET_ID = :MEDCLOTDAT_N.COL_SET_ID
                    AND CHAR_SEQ_NUM = :MEDCLOTDAT_N.CHAR_SEQ_NUM
                    AND (
                            (UNIT_SEQ_NUM > :MEDCLOTDAT_N.UNIT_SEQ_NUM) OR 
                            (UNIT_SEQ_NUM = :MEDCLOTDAT_N.UNIT_SEQ_NUM AND VALUE_SEQ_NUM >= :MEDCLOTDAT_N.VALUE_SEQ_NUM)
                        )
