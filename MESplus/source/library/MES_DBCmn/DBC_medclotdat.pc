    MEMCPY_AN(MEDCLOTDAT_N->COL_SET_ID, MEDCLOTDAT->COL_SET_ID, sizeof(MEDCLOTDAT->COL_SET_ID));
    MEDCLOTDAT_N->COL_SET_VERSION = MEDCLOTDAT->COL_SET_VERSION;
