                    VALUE_18,
                    VALUE_19,
                    VALUE_20,
                    VALUE_21,
                    VALUE_22,
                    VALUE_23,
                    VALUE_24,
                    VALUE_25,
                    SAMPLE_COUNT,
                    NOMINAL,
                    PROCESS_SIGMA,
                    SPEC_OUT_MASK,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    DELETE_USER_ID,
                    DELETE_TIME
                FROM MEDCLOTDAT
                WHERE LOT_ID = :MEDCLOTDAT_N.LOT_ID
                    AND COL_SET_ID = :MEDCLOTDAT_N.COL_SET_ID
                    AND CHAR_ID = :MEDCLOTDAT_N.CHAR_ID
                    AND UNIT_SEQ_NUM = :MEDCLOTDAT_N.UNIT_SEQ_NUM
                    AND HIST_DEL_FLAG = :MEDCLOTDAT_N.HIST_DEL_FLAG
                    AND (HIST_SEQ, COL_SEQ) IN (
                        SELECT HIST_SEQ, MIN(COL_SEQ)
                        FROM MEDCLOTDAT
                        WHERE LOT_ID = :MEDCLOTDAT_N.LOT_ID
                            AND COL_SET_ID = :MEDCLOTDAT_N.COL_SET_ID
                            AND CHAR_ID = :MEDCLOTDAT_N.CHAR_ID
                            AND UNIT_SEQ_NUM = :MEDCLOTDAT_N.UNIT_SEQ_NUM
                            AND HIST_DEL_FLAG = :MEDCLOTDAT_N.HIST_DEL_FLAG
                            AND HIST_SEQ = (
                                SELECT MIN(HIST_SEQ)
                                FROM MEDCLOTDAT
                                WHERE LOT_ID = :MEDCLOTDAT_N.LOT_ID
                                    AND COL_SET_ID = :MEDCLOTDAT_N.COL_SET_ID
                                    AND CHAR_ID = :MEDCLOTDAT_N.CHAR_ID
                                    AND UNIT_SEQ_NUM = :MEDCLOTDAT_N.UNIT_SEQ_NUM
                                    AND HIST_DEL_FLAG = :MEDCLOTDAT_N.HIST_DEL_FLAG
                            )
                        GROUP BY HIST_SEQ
                    )
                ORDER BY VALUE_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MEDCLOTDAT_CUR_8;
            break;

        case 9:
            EXEC SQL DECLARE DBC_MEDCLOTDAT_CUR_9 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    COL_SEQ,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    MEAS_RES_ID,
                    PROC_FLOW,
                    PROC_OPER,
                    PROC_RES_ID,
                    RECIPE_ID,
                    RECIPE_VERSION,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    CHAR_SEQ_NUM,
