                    DELETE_TIME
                FROM MEDCLOTDAT
                WHERE LOT_ID = :MEDCLOTDAT_N.LOT_ID
                    AND HIST_SEQ = :MEDCLOTDAT_N.HIST_SEQ 
                    AND COL_SEQ = :MEDCLOTDAT_N.COL_SEQ
                ORDER BY COL_SET_ID, CHAR_SEQ_NUM, UNIT_SEQ_NUM, VALUE_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MEDCLOTDAT_CUR_7;
            break;
            
        case 8:
            EXEC SQL DECLARE DBC_MEDCLOTDAT_CUR_8 CURSOR FOR
                SELECT 
