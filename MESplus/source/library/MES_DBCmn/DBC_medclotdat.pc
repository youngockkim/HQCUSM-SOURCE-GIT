                            (CHAR_SEQ_NUM = :MEDCLOTDAT_N.CHAR_SEQ_NUM AND UNIT_SEQ_NUM > :MEDCLOTDAT_N.UNIT_SEQ_NUM) OR 
                            (CHAR_SEQ_NUM = :MEDCLOTDAT_N.CHAR_SEQ_NUM AND UNIT_SEQ_NUM = :MEDCLOTDAT_N.UNIT_SEQ_NUM AND VALUE_SEQ_NUM >= :MEDCLOTDAT_N.VALUE_SEQ_NUM)
                        )
                ORDER BY CHAR_SEQ_NUM, UNIT_SEQ_NUM, VALUE_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MEDCLOTDAT_CUR_4;
            break;
            
        case 5:
            EXEC SQL DECLARE DBC_MEDCLOTDAT_CUR_5 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    COL_SEQ,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
