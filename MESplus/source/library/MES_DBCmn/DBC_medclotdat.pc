                    VALUE_16,
                    VALUE_17,
                    VALUE_18,
                    VALUE_19,
                    VALUE_20,
                    VALUE_21,
                    VALUE_22,
                    VALUE_23,
                    VALUE_24,
                    VALUE_25,
                    SAMPLE_COUNT,
                    NOMINAL,
                    PROCESS_SIGMA,
                    SPEC_OUT_MASK,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    DELETE_USER_ID,
                    DELETE_TIME
                FROM MEDCLOTDAT
                WHERE LOT_ID = :MEDCLOTDAT_N.LOT_ID
                    AND COL_SET_ID = :MEDCLOTDAT_N.COL_SET_ID
                    AND CHAR_ID = :MEDCLOTDAT_N.CHAR_ID
                    AND UNIT_SEQ_NUM = :MEDCLOTDAT_N.UNIT_SEQ_NUM
                    AND HIST_DEL_FLAG = :MEDCLOTDAT_N.HIST_DEL_FLAG
                    AND (HIST_SEQ, COL_SEQ) IN (
                        SELECT HIST_SEQ, MAX(COL_SEQ)
                        FROM MEDCLOTDAT
                        WHERE LOT_ID = :MEDCLOTDAT_N.LOT_ID
                            AND COL_SET_ID = :MEDCLOTDAT_N.COL_SET_ID
                            AND CHAR_ID = :MEDCLOTDAT_N.CHAR_ID
                            AND UNIT_SEQ_NUM = :MEDCLOTDAT_N.UNIT_SEQ_NUM
                            AND HIST_DEL_FLAG = :MEDCLOTDAT_N.HIST_DEL_FLAG
                            AND HIST_SEQ = (
                                SELECT MAX(HIST_SEQ)
                                FROM MEDCLOTDAT
                                WHERE LOT_ID = :MEDCLOTDAT_N.LOT_ID
                                    AND COL_SET_ID = :MEDCLOTDAT_N.COL_SET_ID
                                    AND CHAR_ID = :MEDCLOTDAT_N.CHAR_ID
                                    AND UNIT_SEQ_NUM = :MEDCLOTDAT_N.UNIT_SEQ_NUM
                                    AND HIST_DEL_FLAG = :MEDCLOTDAT_N.HIST_DEL_FLAG
                            )
                        GROUP BY HIST_SEQ
                    )
                ORDER BY VALUE_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MEDCLOTDAT_CUR_9;
            break;
                
            
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_medclotdat", sel_type);
}


