                    VALUE_11 = :MEDCLOTDAT_N.VALUE_11,
                    VALUE_12 = :MEDCLOTDAT_N.VALUE_12,
                    VALUE_13 = :MEDCLOTDAT_N.VALUE_13,
                    VALUE_14 = :MEDCLOTDAT_N.VALUE_14,
                    VALUE_15 = :MEDCLOTDAT_N.VALUE_15,
                    VALUE_16 = :MEDCLOTDAT_N.VALUE_16,
                    VALUE_17 = :MEDCLOTDAT_N.VALUE_17,
                    VALUE_18 = :MEDCLOTDAT_N.VALUE_18,
                    VALUE_19 = :MEDCLOTDAT_N.VALUE_19,
                    VALUE_20 = :MEDCLOTDAT_N.VALUE_20,
                    VALUE_21 = :MEDCLOTDAT_N.VALUE_21,
                    VALUE_22 = :MEDCLOTDAT_N.VALUE_22,
                    VALUE_23 = :MEDCLOTDAT_N.VALUE_23,
                    VALUE_24 = :MEDCLOTDAT_N.VALUE_24,
                    VALUE_25 = :MEDCLOTDAT_N.VALUE_25,
                    SAMPLE_COUNT = :MEDCLOTDAT_N.SAMPLE_COUNT,
                    NOMINAL = :MEDCLOTDAT_N.NOMINAL,
                    PROCESS_SIGMA = :MEDCLOTDAT_N.PROCESS_SIGMA,
                    SPEC_OUT_MASK = :MEDCLOTDAT_N.SPEC_OUT_MASK,
                    CREATE_USER_ID = :MEDCLOTDAT_N.CREATE_USER_ID,
                    CREATE_TIME = :MEDCLOTDAT_N.CREATE_TIME,
                    UPDATE_USER_ID = :MEDCLOTDAT_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MEDCLOTDAT_N.UPDATE_TIME,
                    DELETE_USER_ID = :MEDCLOTDAT_N.DELETE_USER_ID,
                    DELETE_TIME = :MEDCLOTDAT_N.DELETE_TIME
                WHERE LOT_ID = :MEDCLOTDAT_N.LOT_ID
                    AND HIST_SEQ = :MEDCLOTDAT_N.HIST_SEQ
                    AND COL_SEQ = :MEDCLOTDAT_N.COL_SEQ
                    AND COL_SET_ID = :MEDCLOTDAT_N.COL_SET_ID
                    AND CHAR_SEQ_NUM = :MEDCLOTDAT_N.CHAR_SEQ_NUM
                    AND UNIT_SEQ_NUM = :MEDCLOTDAT_N.UNIT_SEQ_NUM
                    AND VALUE_SEQ_NUM = :MEDCLOTDAT_N.VALUE_SEQ_NUM;
            break;

        case 2:
            EXEC SQL UPDATE MEDCLOTDAT SET
                    HIST_DEL_FLAG = 'Y',
                    DELETE_USER_ID = :MEDCLOTDAT_N.DELETE_USER_ID,
                    DELETE_TIME = :MEDCLOTDAT_N.DELETE_TIME
                WHERE LOT_ID = :MEDCLOTDAT_N.LOT_ID
                    AND HIST_SEQ = :MEDCLOTDAT_N.HIST_SEQ;
            break;

        case 3:
            EXEC SQL UPDATE MEDCLOTDAT SET
                    HIST_DEL_FLAG = 'Y',
                    DELETE_USER_ID = :MEDCLOTDAT_N.DELETE_USER_ID,
                    DELETE_TIME = :MEDCLOTDAT_N.DELETE_TIME
                WHERE LOT_ID = :MEDCLOTDAT_N.LOT_ID
                    AND HIST_SEQ = :MEDCLOTDAT_N.HIST_SEQ
                    AND CHAR_SEQ_NUM = :MEDCLOTDAT_N.CHAR_SEQ_NUM;
            break;
            
        case 4:
            EXEC SQL UPDATE MEDCLOTDAT SET
                    HIST_DEL_FLAG = 'Y',
                    DELETE_USER_ID = :MEDCLOTDAT_N.DELETE_USER_ID,
                    DELETE_TIME = :MEDCLOTDAT_N.DELETE_TIME
                WHERE LOT_ID = :MEDCLOTDAT_N.LOT_ID
                    AND HIST_SEQ = :MEDCLOTDAT_N.HIST_SEQ
                    AND CHAR_SEQ_NUM = :MEDCLOTDAT_N.CHAR_SEQ_NUM
                    AND UNIT_SEQ_NUM = :MEDCLOTDAT_N.UNIT_SEQ_NUM;
            break;
            
        case 5:
            EXEC SQL UPDATE MEDCLOTDAT SET
                    HIST_DEL_FLAG = 'Y',
                    DELETE_USER_ID = :MEDCLOTDAT_N.DELETE_USER_ID,
                    DELETE_TIME = :MEDCLOTDAT_N.DELETE_TIME
                WHERE LOT_ID = :MEDCLOTDAT_N.LOT_ID
                    AND HIST_SEQ = :MEDCLOTDAT_N.HIST_SEQ
                    AND COL_SEQ = :MEDCLOTDAT_N.COL_SEQ;
            break;            


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_medclotdat", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_medclotdat(int sel_type, struct MEDCLOTDAT_TAG *MEDCLOTDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MEDCLOTDAT_N_TAG MEDCLOTDAT_N;
        char   sql[5120];
        char   ts[1000];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_medclotdat(&MEDCLOTDAT_N, MEDCLOTDAT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MEDCLOTDAT_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    COL_SEQ,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    MEAS_RES_ID,
                    PROC_FLOW,
                    PROC_OPER,
                    PROC_RES_ID,
                    RECIPE_ID,
                    RECIPE_VERSION,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    CHAR_SEQ_NUM,
                    CHAR_ID,
                    UNIT_SEQ_NUM,
                    UNIT_ID,
                    VALUE_SEQ_NUM,
                    VALUE_TYPE,
                    VALUE_COUNT,
                    VALUE_1,
                    VALUE_2,
                    VALUE_3,
                    VALUE_4,
                    VALUE_5,
                    VALUE_6,
                    VALUE_7,
                    VALUE_8,
                    VALUE_9,
                    VALUE_10,
                    VALUE_11,
                    VALUE_12,
                    VALUE_13,
                    VALUE_14,
                    VALUE_15,
                    VALUE_16,
                    VALUE_17,
                    VALUE_18,
                    VALUE_19,
                    VALUE_20,
                    VALUE_21,
                    VALUE_22,
                    VALUE_23,
                    VALUE_24,
                    VALUE_25,
                    SAMPLE_COUNT,
                    NOMINAL,
                    PROCESS_SIGMA,
                    SPEC_OUT_MASK,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    DELETE_USER_ID,
                    DELETE_TIME
                FROM MEDCLOTDAT
                WHERE LOT_ID = :MEDCLOTDAT_N.LOT_ID
                    AND HIST_SEQ = :MEDCLOTDAT_N.HIST_SEQ
                    AND COL_SEQ = :MEDCLOTDAT_N.COL_SEQ
                    AND CHAR_SEQ_NUM = :MEDCLOTDAT_N.CHAR_SEQ_NUM
                    AND UNIT_SEQ_NUM = :MEDCLOTDAT_N.UNIT_SEQ_NUM
                ORDER BY VALUE_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MEDCLOTDAT_CUR_1;
            break;
        
        case 2:
            EXEC SQL DECLARE DBC_MEDCLOTDAT_CUR_2 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    COL_SEQ,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    MEAS_RES_ID,
                    PROC_FLOW,
                    PROC_OPER,
                    PROC_RES_ID,
                    RECIPE_ID,
                    RECIPE_VERSION,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    CHAR_SEQ_NUM,
                    CHAR_ID,
                    UNIT_SEQ_NUM,
                    UNIT_ID,
                    VALUE_SEQ_NUM,
                    VALUE_TYPE,
                    VALUE_COUNT,
                    VALUE_1,
                    VALUE_2,
                    VALUE_3,
                    VALUE_4,
                    VALUE_5,
                    VALUE_6,
                    VALUE_7,
                    VALUE_8,
                    VALUE_9,
                    VALUE_10,
                    VALUE_11,
                    VALUE_12,
                    VALUE_13,
                    VALUE_14,
                    VALUE_15,
                    VALUE_16,
                    VALUE_17,
                    VALUE_18,
                    VALUE_19,
                    VALUE_20,
                    VALUE_21,
                    VALUE_22,
                    VALUE_23,
                    VALUE_24,
                    VALUE_25,
                    SAMPLE_COUNT,
                    NOMINAL,
                    PROCESS_SIGMA,
                    SPEC_OUT_MASK,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    DELETE_USER_ID,
                    DELETE_TIME
                FROM MEDCLOTDAT
                WHERE LOT_ID = :MEDCLOTDAT_N.LOT_ID
                    AND HIST_SEQ = :MEDCLOTDAT_N.HIST_SEQ
                    AND (HIST_DEL_FLAG = ' ' OR HIST_DEL_FLAG = :MEDCLOTDAT_N.HIST_DEL_FLAG)
                    AND (
                            (COL_SEQ > :MEDCLOTDAT_N.COL_SEQ) OR
                            (COL_SEQ = :MEDCLOTDAT_N.COL_SEQ AND COL_SET_ID > :MEDCLOTDAT_N.COL_SET_ID) OR
                            (COL_SEQ = :MEDCLOTDAT_N.COL_SEQ AND COL_SET_ID = :MEDCLOTDAT_N.COL_SET_ID AND CHAR_SEQ_NUM > :MEDCLOTDAT_N.CHAR_SEQ_NUM) OR
                            (COL_SEQ = :MEDCLOTDAT_N.COL_SEQ AND COL_SET_ID = :MEDCLOTDAT_N.COL_SET_ID AND CHAR_SEQ_NUM = :MEDCLOTDAT_N.CHAR_SEQ_NUM AND UNIT_SEQ_NUM > :MEDCLOTDAT_N.UNIT_SEQ_NUM) OR
                            (COL_SEQ = :MEDCLOTDAT_N.COL_SEQ AND COL_SET_ID = :MEDCLOTDAT_N.COL_SET_ID AND CHAR_SEQ_NUM = :MEDCLOTDAT_N.CHAR_SEQ_NUM AND UNIT_SEQ_NUM = :MEDCLOTDAT_N.UNIT_SEQ_NUM AND VALUE_SEQ_NUM >= :MEDCLOTDAT_N.VALUE_SEQ_NUM)
                        )
                ORDER BY COL_SEQ, COL_SET_ID, CHAR_SEQ_NUM, UNIT_SEQ_NUM, VALUE_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MEDCLOTDAT_CUR_2;
            break;
        
        /*    
        case 2:
            memset(sql, 0x00, sizeof(sql));
            memset(ts, 0x00, sizeof(ts));
            sprintf(sql,               "SELECT * FROM MEDCLOTDAT WHERE ");
           
            make_valid_quote(ts, MEDCLOTDAT_N.LOT_ID);
            sprintf(sql + strlen(sql), "LOT_ID = '%s' AND HIST_SEQ = '%d' ",
                    ts, MEDCLOTDAT_N.HIST_SEQ);
                    
            if(MEDCLOTDAT_N.HIST_DEL_FLAG[0] != 'Y')
            {
                sprintf(sql + strlen(sql), "AND HIST_DEL_FLAG = ' ' ");   
            }
            
            make_valid_quote(ts, MEDCLOTDAT_N.COL_SET_ID);
            
            sprintf(sql + strlen(sql), " AND ((CHAR_SEQ_NUM > '%d') OR (CHAR_SEQ_NUM = '%d' AND UNIT_SEQ_NUM > '%d') ",
                    MEDCLOTDAT_N.CHAR_SEQ_NUM, MEDCLOTDAT_N.CHAR_SEQ_NUM, MEDCLOTDAT_N.UNIT_SEQ_NUM);
            
            sprintf(sql + strlen(sql), " OR (CHAR_SEQ_NUM = '%d' AND UNIT_SEQ_NUM = '%d' AND VALUE_SEQ_NUM >= '%d' )) ",
                    MEDCLOTDAT_N.CHAR_SEQ_NUM, MEDCLOTDAT_N.UNIT_SEQ_NUM, MEDCLOTDAT_N.VALUE_SEQ_NUM);
            
            sprintf(sql + strlen(sql), " ORDER BY COL_SET_ID, CHAR_SEQ_NUM, UNIT_SEQ_NUM, VALUE_SEQ_NUM ASC ");
            
            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MEDCLOTDAT_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MEDCLOTDAT_CUR_2;                 
            break;
        */
        
        case 3:
            memset(sql, 0x00, sizeof(sql));
            memset(ts, 0x00, sizeof(ts));
            
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql), "LOT_ID, HIST_SEQ, COL_SEQ, TRAN_TIME, HIST_DEL_FLAG, FACTORY, MAT_ID, MAT_VER, FLOW, OPER, MEAS_RES_ID, PROC_FLOW, ");
            sprintf(sql + strlen(sql), "PROC_OPER, PROC_RES_ID, RECIPE_ID, RECIPE_VERSION, COL_SET_ID, COL_SET_VERSION, CHAR_SEQ_NUM, CHAR_ID, UNIT_SEQ_NUM, ");
            sprintf(sql + strlen(sql), "UNIT_ID, VALUE_SEQ_NUM, VALUE_TYPE, VALUE_COUNT, VALUE_1, VALUE_2, VALUE_3, VALUE_4, VALUE_5, VALUE_6, VALUE_7, VALUE_8, ");
            sprintf(sql + strlen(sql), "VALUE_9, VALUE_10, VALUE_11, VALUE_12, VALUE_13, VALUE_14, VALUE_15, VALUE_16, VALUE_17, VALUE_18, VALUE_19, VALUE_20, ");
            sprintf(sql + strlen(sql), "VALUE_21, VALUE_22, VALUE_23, VALUE_24, VALUE_25, SAMPLE_COUNT, NOMINAL, PROCESS_SIGMA, SPEC_OUT_MASK, CREATE_USER_ID, ");
            sprintf(sql + strlen(sql), "CREATE_TIME, UPDATE_USER_ID, UPDATE_TIME, DELETE_USER_ID, DELETE_TIME ");            
            sprintf(sql + strlen(sql), "FROM MEDCLOTDAT WHERE ");
            make_valid_quote(ts, MEDCLOTDAT_N.FACTORY);
            sprintf(sql + strlen(sql), "FACTORY = '%s' ", ts);
            
            make_valid_quote(ts, MEDCLOTDAT_N.COL_SET_ID);
            sprintf(sql + strlen(sql), "AND COL_SET_ID = '%s' ", ts);
            
            make_valid_quote(ts, DBC_Q_COND_N.FROM_TIME);
            sprintf(sql + strlen(sql), "AND TRAN_TIME >= '%s' ", ts);
            
            make_valid_quote(ts, DBC_Q_COND_N.TO_TIME);
            sprintf(sql + strlen(sql), "AND TRAN_TIME < '%s'", ts);
            
            if(ISSPACE(MEDCLOTDAT->CHAR_ID, sizeof(MEDCLOTDAT->CHAR_ID)) != DB_TRUE)
            {
                make_valid_quote(ts, MEDCLOTDAT_N.CHAR_ID);
                sprintf(sql + strlen(sql), " AND CHAR_ID = '%s' ", ts);                
            }
            if(ISSPACE(MEDCLOTDAT->MAT_ID, sizeof(MEDCLOTDAT->MAT_ID)) != DB_TRUE)
            {
                make_valid_quote(ts, MEDCLOTDAT_N.MAT_ID);
                sprintf(sql + strlen(sql), " AND MAT_ID = '%s' ", ts);                
            }
            if(ISSPACE(MEDCLOTDAT->FLOW, sizeof(MEDCLOTDAT->FLOW)) != DB_TRUE)
            {
                make_valid_quote(ts, MEDCLOTDAT_N.FLOW);
                sprintf(sql + strlen(sql), " AND FLOW = '%s' ", ts);                
            }
            if(ISSPACE(MEDCLOTDAT->OPER, sizeof(MEDCLOTDAT->OPER)) != DB_TRUE)
            {
                make_valid_quote(ts, MEDCLOTDAT_N.OPER);
                sprintf(sql + strlen(sql), " AND OPER = '%s' ", ts);                
            }
            
            sprintf(sql + strlen(sql), " AND ((HIST_SEQ > '%d') OR ", MEDCLOTDAT_N.HIST_SEQ);
            sprintf(sql + strlen(sql), "      (HIST_SEQ = '%d' AND COL_SEQ > '%d') OR ", MEDCLOTDAT_N.HIST_SEQ, MEDCLOTDAT_N.COL_SEQ);
            sprintf(sql + strlen(sql), "      (HIST_SEQ = '%d' AND COL_SEQ = '%d' AND CHAR_SEQ_NUM > '%d') OR ", MEDCLOTDAT_N.HIST_SEQ, MEDCLOTDAT_N.COL_SEQ, MEDCLOTDAT_N.CHAR_SEQ_NUM);
            sprintf(sql + strlen(sql), "      (HIST_SEQ = '%d' AND COL_SEQ = '%d' AND CHAR_SEQ_NUM = '%d' AND UNIT_SEQ_NUM > '%d') OR ", MEDCLOTDAT_N.HIST_SEQ, MEDCLOTDAT_N.COL_SEQ, MEDCLOTDAT_N.CHAR_SEQ_NUM, MEDCLOTDAT_N.UNIT_SEQ_NUM);
            sprintf(sql + strlen(sql), "      (HIST_SEQ = '%d' AND COL_SEQ = '%d' AND CHAR_SEQ_NUM = '%d' AND UNIT_SEQ_NUM = '%d' AND VALUE_SEQ_NUM >= '%d')) ", MEDCLOTDAT_N.HIST_SEQ, MEDCLOTDAT_N.COL_SEQ, MEDCLOTDAT_N.CHAR_SEQ_NUM, MEDCLOTDAT_N.UNIT_SEQ_NUM, MEDCLOTDAT_N.VALUE_SEQ_NUM);
                                
            sprintf(sql + strlen(sql), " ORDER BY HIST_SEQ, COL_SEQ, CHAR_SEQ_NUM, UNIT_SEQ_NUM, VALUE_SEQ_NUM ASC ");
    
            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MEDCLOTDAT_CUR_3 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MEDCLOTDAT_CUR_3;                 
            break;
            
        case 4:
            EXEC SQL DECLARE DBC_MEDCLOTDAT_CUR_4 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    COL_SEQ,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
