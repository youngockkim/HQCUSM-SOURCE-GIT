/* SQL CURSOR CLOSE Function */
void DBC_close_medclotdat(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MEDCLOTDAT_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_MEDCLOTDAT_CUR_2;
            break;
            
        case 3:
            EXEC SQL CLOSE DBC_MEDCLOTDAT_CUR_3;
            break;
        
        case 4:
            EXEC SQL CLOSE DBC_MEDCLOTDAT_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MEDCLOTDAT_CUR_5;
            break;
            
        case 6:
            EXEC SQL CLOSE DBC_MEDCLOTDAT_CUR_6;
            break;
            
        case 7:
            EXEC SQL CLOSE DBC_MEDCLOTDAT_CUR_7;
            break;
            
        case 8:
            EXEC SQL CLOSE DBC_MEDCLOTDAT_CUR_8;
            break;
            
        case 9:
            EXEC SQL CLOSE DBC_MEDCLOTDAT_CUR_9;
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_medclotdat", sel_type);
}


/* Initialize Function */
void DBC_init_medclotdat(struct MEDCLOTDAT_TAG *MEDCLOTDAT)
{
    /* memset by Space */
    memset(MEDCLOTDAT, ' ', sizeof(struct MEDCLOTDAT_TAG));
    
    MEDCLOTDAT->COL_SEQ = 0;
    MEDCLOTDAT->HIST_SEQ = 0;
    MEDCLOTDAT->MAT_VER = 0;
    MEDCLOTDAT->RECIPE_VERSION = 0;
    MEDCLOTDAT->COL_SET_VERSION = 0;
    MEDCLOTDAT->CHAR_SEQ_NUM = 0;
    MEDCLOTDAT->UNIT_SEQ_NUM = 0;
    MEDCLOTDAT->VALUE_SEQ_NUM = 0;
    MEDCLOTDAT->VALUE_COUNT = 0;
    MEDCLOTDAT->SAMPLE_COUNT = 0;
}


/* Add Null Function */
void DBC_add_null_medclotdat(struct MEDCLOTDAT_N_TAG *MEDCLOTDAT_N, struct MEDCLOTDAT_TAG *MEDCLOTDAT)
{
    /* memset by NULL */
    memset(MEDCLOTDAT_N, '\0', sizeof(struct MEDCLOTDAT_N_TAG));
    
    MEMCPY_AN(MEDCLOTDAT_N->LOT_ID, MEDCLOTDAT->LOT_ID, sizeof(MEDCLOTDAT->LOT_ID));
    MEDCLOTDAT_N->HIST_SEQ = MEDCLOTDAT->HIST_SEQ;
    MEDCLOTDAT_N->COL_SEQ = MEDCLOTDAT->COL_SEQ;
    MEMCPY_AN(MEDCLOTDAT_N->TRAN_TIME, MEDCLOTDAT->TRAN_TIME, sizeof(MEDCLOTDAT->TRAN_TIME));
    MEDCLOTDAT_N->HIST_DEL_FLAG[0] = MEDCLOTDAT->HIST_DEL_FLAG;
