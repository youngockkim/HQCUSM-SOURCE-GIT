                    CHG_FIELD_28,
                    CHG_FIELD_29,
                    CHG_FIELD_30
                FROM MRASTEVDEF
                WHERE FACTORY =: MRASTEVDEF_N.FACTORY
                    AND TOOL_TYPE =: MRASTEVDEF_N.TOOL_TYPE
                    AND SYSTEM_FLAG =: MRASTEVDEF_N.SYSTEM_FLAG
                    AND TOOL_EVENT_ID >=: MRASTEVDEF_N.TOOL_EVENT_ID
                ORDER BY FACTORY ASC,
                    TOOL_TYPE ASC,
                    TOOL_EVENT_ID ASC;
            EXEC SQL OPEN DBC_MRASTEVDEF_CUR_3;
            break;
            
       case 4:
            EXEC SQL DECLARE DBC_MRASTEVDEF_CUR_4 CURSOR FOR
                SELECT DISTINCT FACTORY, TOOL_EVENT_ID, TOOL_EVENT_DESC
                FROM MRASTEVDEF
                WHERE FACTORY =: MRASTEVDEF_N.FACTORY
                ORDER BY TOOL_EVENT_ID ASC;
            EXEC SQL OPEN DBC_MRASTEVDEF_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mrastevdef", sel_type);
}


