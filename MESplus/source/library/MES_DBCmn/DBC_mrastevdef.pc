        case 4:
            EXEC SQL FETCH DBC_MRASTEVDEF_CUR_4 INTO
                :MRASTEVDEF_N.FACTORY,
                :MRASTEVDEF_N.TOOL_EVENT_ID,
                :MRASTEVDEF_N.TOOL_EVENT_DESC;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mrastevdef(&MRASTEVDEF_N, MRASTEVDEF);
    }

    DB_stop_query_timer("DBC_fetch_mrastevdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mrastevdef(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MRASTEVDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MRASTEVDEF_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MRASTEVDEF_CUR_3;
            break;
            
        case 4:
            EXEC SQL CLOSE DBC_MRASTEVDEF_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("DBC_close_mrastevdef", sel_type);
}


/* Initialize Function */
void DBC_init_mrastevdef(struct MRASTEVDEF_TAG *MRASTEVDEF)
{
    /* memset by Space */
    memset(MRASTEVDEF, ' ', sizeof(struct MRASTEVDEF_TAG));
    
}


