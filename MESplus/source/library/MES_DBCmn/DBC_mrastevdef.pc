                    :MRASTEVDEF_N.CHG_FIELD_29,
                    :MRASTEVDEF_N.CHG_FIELD_30
                FROM MRASTEVDEF
                WHERE FACTORY = :MRASTEVDEF_N.FACTORY
                    AND TOOL_TYPE = :MRASTEVDEF_N.TOOL_TYPE
                    AND TOOL_EVENT_ID = :MRASTEVDEF_N.TOOL_EVENT_ID
                FOR UPDATE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mrastevdef(&MRASTEVDEF_N, MRASTEVDEF);
    }

    DB_stop_query_timer("DBC_select_mrastevdef_for_update", sel_type);
}


/* SQL SELECT_SCALAR Function */
double DBC_select_mrastevdef_scalar(int sel_type, struct MRASTEVDEF_TAG *MRASTEVDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASTEVDEF_N_TAG MRASTEVDEF_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrastevdef(&MRASTEVDEF_N, MRASTEVDEF);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MRASTEVDEF
                WHERE FACTORY = :MRASTEVDEF_N.FACTORY
                    AND TOOL_TYPE = :MRASTEVDEF_N.TOOL_TYPE
                    AND TOOL_EVENT_ID = :MRASTEVDEF_N.TOOL_EVENT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mrastevdef_scalar", sel_type);

    return d_value;
}


/* SQL DELETE Function */
void DBC_delete_mrastevdef(int sel_type, struct MRASTEVDEF_TAG *MRASTEVDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASTEVDEF_N_TAG MRASTEVDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrastevdef(&MRASTEVDEF_N, MRASTEVDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM MRASTEVDEF
                WHERE FACTORY = :MRASTEVDEF_N.FACTORY
                    AND TOOL_TYPE = :MRASTEVDEF_N.TOOL_TYPE
                    AND TOOL_EVENT_ID = :MRASTEVDEF_N.TOOL_EVENT_ID;
            break;

        case 2:
            EXEC SQL DELETE FROM MRASTEVDEF
                WHERE FACTORY = :MRASTEVDEF_N.FACTORY
                    AND TOOL_TYPE = :MRASTEVDEF_N.TOOL_TYPE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_delete_mrastevdef", sel_type);
}


