                    KEY_7_ITEM,
                    KEY_8_ITEM,
                    KEY_9_ITEM,
                    KEY_10_ITEM
                FROM MBASCHKLST
				WHERE 1=1
					AND FACTORY = :MBASCHKLST_N.FACTORY
					AND CHKLIST_ID >= :MBASCHKLST_N.CHKLIST_ID
                ORDER BY CHKLIST_ID ASC;
            EXEC SQL OPEN DBC_MBASCHKLST_CUR_101;
            break;
			
		case 102:
            EXEC SQL DECLARE DBC_MBASCHKLST_CUR_102 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    CHKLIST_ID,
                    CHKLIST_DESC,
                    CHKLIST_TYPE,
