{
    MEMCPY_DN(MBASCHKLST->CREATE_USER_ID, MBASCHKLST_N->CREATE_USER_ID, sizeof(MBASCHKLST->CREATE_USER_ID));
    MEMCPY_DN(MBASCHKLST->CREATE_TIME, MBASCHKLST_N->CREATE_TIME, sizeof(MBASCHKLST->CREATE_TIME));
