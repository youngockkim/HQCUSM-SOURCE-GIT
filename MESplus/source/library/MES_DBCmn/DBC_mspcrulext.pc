/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mspcrulext(int sel_type, struct MSPCRULEXT_TAG *MSPCRULEXT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSPCRULEXT_N_TAG MSPCRULEXT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mspcrulext(&MSPCRULEXT_N, MSPCRULEXT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSPCRULEXT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    CHART_ID,
                    XRULE_1,
                    XRULE_2,
                    XRULE_3,
                    XRULE_4,
                    XRULE_5,
                    XRULE_6,
                    XRULE_7,
                    XRULE_8,
                    XRULE_9,
                    XRULE_10,
                    XRULE_11,
                    XRULE_12,
                    XRULE_13,
                    XRULE_14,
                    XRULE_15,
                    XRULE_16,
                    XRULE_17,
                    XRULE_18,
                    XRULE_19,
                    XRULE_20,
                    RRULE_1,
                    RRULE_2,
                    RRULE_3,
                    RRULE_4,
                    RRULE_5,
                    RRULE_6,
                    RRULE_7,
                    RRULE_8,
                    RRULE_9,
                    RRULE_10,
                    RRULE_11,
                    RRULE_12,
                    RRULE_13,
                    RRULE_14,
                    RRULE_15,
                    RRULE_16,
                    RRULE_17,
                    RRULE_18,
                    RRULE_19,
                    RRULE_20
                FROM MSPCRULEXT
                ORDER BY FACTORY ASC,
                    CHART_ID ASC;
            EXEC SQL OPEN DBC_MSPCRULEXT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mspcrulext", sel_type);
}


