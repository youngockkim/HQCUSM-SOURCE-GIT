                :MSPCRULEXT_N.RRULE_16,
                :MSPCRULEXT_N.RRULE_17,
                :MSPCRULEXT_N.RRULE_18,
                :MSPCRULEXT_N.RRULE_19,
                :MSPCRULEXT_N.RRULE_20;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mspcrulext(&MSPCRULEXT_N, MSPCRULEXT);
    }

    DB_stop_query_timer("DBC_fetch_mspcrulext", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mspcrulext(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MSPCRULEXT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("DBC_close_mspcrulext", sel_type);
}


/* Initialize Function */
void DBC_init_mspcrulext(struct MSPCRULEXT_TAG *MSPCRULEXT)
{
    /* memset by Space */
    memset(MSPCRULEXT, ' ', sizeof(struct MSPCRULEXT_TAG));
    
}


