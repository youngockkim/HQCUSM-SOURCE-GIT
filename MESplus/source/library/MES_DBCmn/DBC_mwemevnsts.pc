                    AND EST.LAST_TRAN_TIME < :MWEMEVNSTS_N.LAST_TRAN_TIME
                ORDER BY EST.PROC_EVENT_ID ASC;
            EXEC SQL OPEN DBC_MWEMEVNSTS_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mwemevnsts", sel_type);
}


