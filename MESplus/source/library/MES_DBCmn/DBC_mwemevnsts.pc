/* Initialize Function */
void DBC_init_mwemevnsts(struct MWEMEVNSTS_TAG *MWEMEVNSTS)
{
    /* memset by Space */
    memset(MWEMEVNSTS, ' ', sizeof(struct MWEMEVNSTS_TAG));
    
    MWEMEVNSTS->LAST_HIST_SEQ = 0;
    MWEMEVNSTS->LAST_ACTIVE_HIST_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mwemevnsts(struct MWEMEVNSTS_N_TAG *MWEMEVNSTS_N, struct MWEMEVNSTS_TAG *MWEMEVNSTS)
{
