    MEMCPY_DN(MRTDRESOPR->CREATE_USER_ID, MRTDRESOPR_N->CREATE_USER_ID, sizeof(MRTDRESOPR->CREATE_USER_ID));
    MEMCPY_DN(MRTDRESOPR->CREATE_TIME, MRTDRESOPR_N->CREATE_TIME, sizeof(MRTDRESOPR->CREATE_TIME));
    MEMCPY_DN(MRTDRESOPR->UPDATE_USER_ID, MRTDRESOPR_N->UPDATE_USER_ID, sizeof(MRTDRESOPR->UPDATE_USER_ID));
