/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrtdresopr(int sel_type, struct MRTDRESOPR_TAG *MRTDRESOPR)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRTDRESOPR_N_TAG MRTDRESOPR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrtdresopr(&MRTDRESOPR_N, MRTDRESOPR);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRTDRESOPR_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RELATION_LEVEL,
                    RESG_ID,
                    RES_ID,
                    OPER,
                    DSP_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRTDRESOPR
                ORDER BY FACTORY ASC,
                    RELATION_LEVEL ASC,
                    RESG_ID ASC,
                    RES_ID ASC,
                    OPER ASC;
            EXEC SQL OPEN DBC_MRTDRESOPR_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MRTDRESOPR_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    RELATION_LEVEL,
                    RESG_ID,
                    RES_ID,
                    OPER,
                    DSP_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRTDRESOPR
                WHERE FACTORY = :MRTDRESOPR_N.FACTORY
                    AND DSP_ID = :MRTDRESOPR_N.DSP_ID;
            EXEC SQL OPEN DBC_MRTDRESOPR_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrtdresopr", sel_type);
}


