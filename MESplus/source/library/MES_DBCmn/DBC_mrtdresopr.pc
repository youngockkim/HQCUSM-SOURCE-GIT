    MRTDRESOPR->RELATION_LEVEL = MRTDRESOPR_N->RELATION_LEVEL[0];
    MEMCPY_DN(MRTDRESOPR->RESG_ID, MRTDRESOPR_N->RESG_ID, sizeof(MRTDRESOPR->RESG_ID));
    MEMCPY_DN(MRTDRESOPR->RES_ID, MRTDRESOPR_N->RES_ID, sizeof(MRTDRESOPR->RES_ID));
