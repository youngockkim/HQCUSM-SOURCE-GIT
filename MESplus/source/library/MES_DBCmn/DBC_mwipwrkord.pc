                    AND OPER = :MWIPWRKORD_N.OPER
                    AND WORK_DATE = :MWIPWRKORD_N.WORK_DATE
                    AND WORK_SHIFT = :MWIPWRKORD_N.WORK_SHIFT
                    AND SEQ_NUM = :MWIPWRKORD_N.SEQ_NUM;
            break;
        case 2:
            EXEC SQL UPDATE MWIPWRKORD SET
                    SEQ_NUM = SEQ_NUM - 1
                WHERE FACTORY = :MWIPWRKORD_N.FACTORY
