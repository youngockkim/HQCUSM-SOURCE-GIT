            break; 
            
        case 3:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);

            EXEC SQL UPDATE MWIPWRKORD SET
                    SEQ_NUM = :MWIPWRKORD_N.SEQ_NUM
                WHERE FACTORY = :MWIPWRKORD_N.FACTORY
                    AND RES_OR_OPR_FLAG = :MWIPWRKORD_N.RES_OR_OPR_FLAG
