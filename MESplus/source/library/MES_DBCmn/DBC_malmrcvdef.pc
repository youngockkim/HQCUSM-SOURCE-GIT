/* Add Null Function */
void DBC_add_null_malmrcvdef(struct MALMRCVDEF_N_TAG *MALMRCVDEF_N, struct MALMRCVDEF_TAG *MALMRCVDEF)
{
    /* memset by NULL */
    memset(MALMRCVDEF_N, '\0', sizeof(struct MALMRCVDEF_N_TAG));
    
    MEMCPY_AN(MALMRCVDEF_N->FACTORY, MALMRCVDEF->FACTORY, sizeof(MALMRCVDEF->FACTORY));
