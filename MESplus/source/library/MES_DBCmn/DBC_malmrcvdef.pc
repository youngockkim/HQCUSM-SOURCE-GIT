/* Del Null Function */
void DBC_del_null_malmrcvdef(struct MALMRCVDEF_N_TAG *MALMRCVDEF_N, struct MALMRCVDEF_TAG *MALMRCVDEF)
{
    MEMCPY_DN(MALMRCVDEF->FACTORY, MALMRCVDEF_N->FACTORY, sizeof(MALMRCVDEF->FACTORY));
    MEMCPY_DN(MALMRCVDEF->ALARM_ID, MALMRCVDEF_N->ALARM_ID, sizeof(MALMRCVDEF->ALARM_ID));
