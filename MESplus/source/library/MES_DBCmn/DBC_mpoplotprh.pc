    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MPOPLOTPRH_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOT_ID,
                    SEQ_NUM,
                    WORK_YEAR,
                    WORK_DAYS,
                    WORK_DATE,
                    QTY,
                    MAT_ID,
                    MAT_VER,
                    LABEL_ID,
                    TRAN_USER_ID,
                    TRAN_TIME,
                    ORDER_ID
                FROM MPOPLOTPRH
                ORDER BY FACTORY ASC,
                    LOT_ID ASC,
                    SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MPOPLOTPRH_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MPOPLOTPRH_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOT_ID,
                    SEQ_NUM,
                    WORK_YEAR,
                    WORK_DAYS,
                    WORK_DATE,
                    QTY,
                    MAT_ID,
                    MAT_VER,
                    LABEL_ID,
                    TRAN_USER_ID,
                    TRAN_TIME,
                    ORDER_ID
                FROM MPOPLOTPRH
                WHERE FACTORY =:MPOPLOTPRH_N.FACTORY
                    AND LOT_ID = :MPOPLOTPRH_N.LOT_ID
                ORDER BY LOT_ID ASC;
            EXEC SQL OPEN DBC_MPOPLOTPRH_CUR_2;
            break;


        default:
            DB_error_code = 9999;
