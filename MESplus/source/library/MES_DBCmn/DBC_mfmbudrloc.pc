/* SQL UPDATE Function */
void DBC_update_mfmbudrloc(int sel_type, struct MFMBUDRLOC_TAG *MFMBUDRLOC)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MFMBUDRLOC_N_TAG MFMBUDRLOC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mfmbudrloc(&MFMBUDRLOC_N, MFMBUDRLOC);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MFMBUDRLOC SET
                    SEQ = :MFMBUDRLOC_N.SEQ,
                    LOC_X = :MFMBUDRLOC_N.LOC_X,
                    LOC_Y = :MFMBUDRLOC_N.LOC_Y,
                    LOC_WIDTH = :MFMBUDRLOC_N.LOC_WIDTH,
                    LOC_HEIGHT = :MFMBUDRLOC_N.LOC_HEIGHT,
                    TEXT = :MFMBUDRLOC_N.TEXT,
                    TEXT_SIZE = :MFMBUDRLOC_N.TEXT_SIZE,
                    TEXT_COLOR = :MFMBUDRLOC_N.TEXT_COLOR,
                    TEXT_STYLE = :MFMBUDRLOC_N.TEXT_STYLE,
                    TAG_TYPE = :MFMBUDRLOC_N.TAG_TYPE,
                    BACK_COLOR = :MFMBUDRLOC_N.BACK_COLOR,
                    CREATE_TIME = :MFMBUDRLOC_N.CREATE_TIME,
                    UPDATE_TIME = :MFMBUDRLOC_N.UPDATE_TIME,
                    NO_MOUSE_EVENT = :MFMBUDRLOC_N.NO_MOUSE_EVENT,
                    SIGNAL_FLAG = :MFMBUDRLOC_N.SIGNAL_FLAG,
                    ANGLE = :MFMBUDRLOC_N.ANGLE,
                    RES_SHAPE = :MFMBUDRLOC_N.RES_SHAPE
                WHERE FACTORY = :MFMBUDRLOC_N.FACTORY
                    AND GROUP_ID = :MFMBUDRLOC_N.GROUP_ID
                    AND RES_ID = :MFMBUDRLOC_N.RES_ID
                    AND RES_TYPE = :MFMBUDRLOC_N.RES_TYPE;
            break;

        case 2: 
            EXEC SQL UPDATE MFMBUDRLOC SET
                    LOC_X = :MFMBUDRLOC_N.LOC_WIDTH - LOC_WIDTH
                WHERE FACTORY = :MFMBUDRLOC_N.FACTORY
                    AND GROUP_ID = :MFMBUDRLOC_N.GROUP_ID
                    AND LOC_X + LOC_WIDTH > :MFMBUDRLOC_N.LOC_WIDTH;
            break;            

        case 3:
            EXEC SQL UPDATE MFMBUDRLOC SET
                    LOC_Y = :MFMBUDRLOC_N.LOC_HEIGHT - LOC_HEIGHT
                WHERE FACTORY = :MFMBUDRLOC_N.FACTORY
                    AND GROUP_ID = :MFMBUDRLOC_N.GROUP_ID
                    AND LOC_Y + LOC_HEIGHT > :MFMBUDRLOC_N.LOC_HEIGHT;
            break;            
        
        case 4:
            EXEC SQL UPDATE MFMBUDRLOC SET
                    SEQ = SEQ - 1
                WHERE FACTORY = :MFMBUDRLOC_N.FACTORY
                    AND GROUP_ID = :MFMBUDRLOC_N.GROUP_ID
                    AND SEQ > :MFMBUDRLOC_N.SEQ;
            break;  

        case 5:
            EXEC SQL UPDATE MFMBUDRLOC SET
                    SEQ = SEQ + 1
                WHERE FACTORY = :MFMBUDRLOC_N.FACTORY
                    AND GROUP_ID = :MFMBUDRLOC_N.GROUP_ID
                    AND SEQ < :MFMBUDRLOC_N.SEQ;
            break;  


        case 6:
            EXEC SQL UPDATE MFMBUDRLOC SET
                    SEQ = :MFMBUDRLOC_N.SEQ,
                    LOC_X = :MFMBUDRLOC_N.LOC_X,
                    LOC_Y = :MFMBUDRLOC_N.LOC_Y,
                    LOC_WIDTH = :MFMBUDRLOC_N.LOC_WIDTH,
                    LOC_HEIGHT = :MFMBUDRLOC_N.LOC_HEIGHT,
                    TEXT = :MFMBUDRLOC_N.TEXT,
                    TEXT_SIZE = :MFMBUDRLOC_N.TEXT_SIZE,
                    TEXT_COLOR = :MFMBUDRLOC_N.TEXT_COLOR,
                    TEXT_STYLE = :MFMBUDRLOC_N.TEXT_STYLE,
                    TAG_TYPE = :MFMBUDRLOC_N.TAG_TYPE,
                    BACK_COLOR = :MFMBUDRLOC_N.BACK_COLOR,
                    CREATE_TIME = :MFMBUDRLOC_N.CREATE_TIME,
                    UPDATE_TIME = :MFMBUDRLOC_N.UPDATE_TIME,
                    NO_MOUSE_EVENT = :MFMBUDRLOC_N.NO_MOUSE_EVENT,
                    SIGNAL_FLAG = :MFMBUDRLOC_N.SIGNAL_FLAG,
                    ANGLE = :MFMBUDRLOC_N.ANGLE,
                    RES_SHAPE = :MFMBUDRLOC_N.RES_SHAPE
                WHERE FACTORY = :MFMBUDRLOC_N.FACTORY
                    AND GROUP_ID = :MFMBUDRLOC_N.GROUP_ID
                    AND RES_ID = :MFMBUDRLOC_N.RES_ID
                    AND RES_TYPE = :MFMBUDRLOC_N.RES_TYPE
                    AND MOTHER_RES_ID = :MFMBUDRLOC_N.MOTHER_RES_ID;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mfmbudrloc", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mfmbudrloc(int sel_type, struct MFMBUDRLOC_TAG *MFMBUDRLOC)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MFMBUDRLOC_N_TAG MFMBUDRLOC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mfmbudrloc(&MFMBUDRLOC_N, MFMBUDRLOC);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MFMBUDRLOC_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    GROUP_ID,
                    RES_ID,
                    RES_TYPE,
                    SEQ,
                    LOC_X,
                    LOC_Y,
                    LOC_WIDTH,
                    LOC_HEIGHT,
                    TEXT,
                    TEXT_SIZE,
                    TEXT_COLOR,
                    TEXT_STYLE,
                    TAG_TYPE,
                    BACK_COLOR,
                    CREATE_TIME,
                    UPDATE_TIME,
                    NO_MOUSE_EVENT,
                    SIGNAL_FLAG,
                    MOTHER_RES_ID,
                    ANGLE,
                    RES_SHAPE
                FROM MFMBUDRLOC
                WHERE FACTORY = :MFMBUDRLOC_N.FACTORY 
                AND GROUP_ID = :MFMBUDRLOC_N.GROUP_ID 
                AND RES_ID >= :MFMBUDRLOC_N.RES_ID
                AND MOTHER_RES_ID >= :MFMBUDRLOC_N.MOTHER_RES_ID
                AND RES_TYPE = 'T' 
                ORDER BY RES_ID;
            EXEC SQL OPEN DBC_MFMBUDRLOC_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MFMBUDRLOC_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    GROUP_ID,
                    RES_ID,
                    RES_TYPE,
                    SEQ,
                    LOC_X,
                    LOC_Y,
                    LOC_WIDTH,
                    LOC_HEIGHT,
                    TEXT,
                    TEXT_SIZE,
                    TEXT_COLOR,
                    TEXT_STYLE,
                    TAG_TYPE,
                    BACK_COLOR,
                    CREATE_TIME,
                    UPDATE_TIME,
                    NO_MOUSE_EVENT,
                    SIGNAL_FLAG,
                    MOTHER_RES_ID,
                    ANGLE,
                    RES_SHAPE
                FROM MFMBUDRLOC
                WHERE FACTORY = :MFMBUDRLOC_N.FACTORY 
                AND GROUP_ID = :MFMBUDRLOC_N.GROUP_ID 
                ORDER BY RES_ID;
            EXEC SQL OPEN DBC_MFMBUDRLOC_CUR_2;
            break;
                

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mfmbudrloc", sel_type);
}


