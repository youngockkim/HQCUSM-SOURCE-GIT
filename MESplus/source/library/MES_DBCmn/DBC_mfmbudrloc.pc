    MFMBUDRLOC->LOC_WIDTH = 0;
    MFMBUDRLOC->LOC_HEIGHT = 0;
    MFMBUDRLOC->TEXT_SIZE = 0;
    MFMBUDRLOC->TEXT_COLOR = 0;
    MFMBUDRLOC->TAG_TYPE = 0;
    MFMBUDRLOC->BACK_COLOR = 0;
    MFMBUDRLOC->ANGLE = 0;
}


/* Add Null Function */
void DBC_add_null_mfmbudrloc(struct MFMBUDRLOC_N_TAG *MFMBUDRLOC_N, struct MFMBUDRLOC_TAG *MFMBUDRLOC)
{
    /* memset by NULL */
    memset(MFMBUDRLOC_N, '\0', sizeof(struct MFMBUDRLOC_N_TAG));
    
    MEMCPY_AN(MFMBUDRLOC_N->FACTORY, MFMBUDRLOC->FACTORY, sizeof(MFMBUDRLOC->FACTORY));
    MEMCPY_AN(MFMBUDRLOC_N->GROUP_ID, MFMBUDRLOC->GROUP_ID, sizeof(MFMBUDRLOC->GROUP_ID));
    MEMCPY_AN(MFMBUDRLOC_N->RES_ID, MFMBUDRLOC->RES_ID, sizeof(MFMBUDRLOC->RES_ID));
    MFMBUDRLOC_N->RES_TYPE[0] = MFMBUDRLOC->RES_TYPE;
    MFMBUDRLOC_N->SEQ = MFMBUDRLOC->SEQ;
    MFMBUDRLOC_N->LOC_X = MFMBUDRLOC->LOC_X;
    MFMBUDRLOC_N->LOC_Y = MFMBUDRLOC->LOC_Y;
    MFMBUDRLOC_N->LOC_WIDTH = MFMBUDRLOC->LOC_WIDTH;
    MFMBUDRLOC_N->LOC_HEIGHT = MFMBUDRLOC->LOC_HEIGHT;
    MEMCPY_AN(MFMBUDRLOC_N->TEXT, MFMBUDRLOC->TEXT, sizeof(MFMBUDRLOC->TEXT));
    MFMBUDRLOC_N->TEXT_SIZE = MFMBUDRLOC->TEXT_SIZE;
    MFMBUDRLOC_N->TEXT_COLOR = MFMBUDRLOC->TEXT_COLOR;
    MFMBUDRLOC_N->TEXT_STYLE[0] = MFMBUDRLOC->TEXT_STYLE;
    MFMBUDRLOC_N->TAG_TYPE = MFMBUDRLOC->TAG_TYPE;
    MFMBUDRLOC_N->BACK_COLOR = MFMBUDRLOC->BACK_COLOR;
    MEMCPY_AN(MFMBUDRLOC_N->CREATE_TIME, MFMBUDRLOC->CREATE_TIME, sizeof(MFMBUDRLOC->CREATE_TIME));
    MEMCPY_AN(MFMBUDRLOC_N->UPDATE_TIME, MFMBUDRLOC->UPDATE_TIME, sizeof(MFMBUDRLOC->UPDATE_TIME));
    MFMBUDRLOC_N->NO_MOUSE_EVENT[0] = MFMBUDRLOC->NO_MOUSE_EVENT;
    MFMBUDRLOC_N->SIGNAL_FLAG[0] = MFMBUDRLOC->SIGNAL_FLAG;
    MEMCPY_AN(MFMBUDRLOC_N->MOTHER_RES_ID, MFMBUDRLOC->MOTHER_RES_ID, sizeof(MFMBUDRLOC->MOTHER_RES_ID));
    MFMBUDRLOC_N->ANGLE = MFMBUDRLOC->ANGLE;
    MFMBUDRLOC_N->RES_SHAPE[0] = MFMBUDRLOC->RES_SHAPE;
}


/* Del Null Function */
void DBC_del_null_mfmbudrloc(struct MFMBUDRLOC_N_TAG *MFMBUDRLOC_N, struct MFMBUDRLOC_TAG *MFMBUDRLOC)
{
    MEMCPY_DN(MFMBUDRLOC->FACTORY, MFMBUDRLOC_N->FACTORY, sizeof(MFMBUDRLOC->FACTORY));
    MEMCPY_DN(MFMBUDRLOC->GROUP_ID, MFMBUDRLOC_N->GROUP_ID, sizeof(MFMBUDRLOC->GROUP_ID));
    MEMCPY_DN(MFMBUDRLOC->RES_ID, MFMBUDRLOC_N->RES_ID, sizeof(MFMBUDRLOC->RES_ID));
    MFMBUDRLOC->RES_TYPE = MFMBUDRLOC_N->RES_TYPE[0];
    MFMBUDRLOC->SEQ = MFMBUDRLOC_N->SEQ;
    MFMBUDRLOC->LOC_X = MFMBUDRLOC_N->LOC_X;
    MFMBUDRLOC->LOC_Y = MFMBUDRLOC_N->LOC_Y;
    MFMBUDRLOC->LOC_WIDTH = MFMBUDRLOC_N->LOC_WIDTH;
    MFMBUDRLOC->LOC_HEIGHT = MFMBUDRLOC_N->LOC_HEIGHT;
    MEMCPY_DN(MFMBUDRLOC->TEXT, MFMBUDRLOC_N->TEXT, sizeof(MFMBUDRLOC->TEXT));
    MFMBUDRLOC->TEXT_SIZE = MFMBUDRLOC_N->TEXT_SIZE;
    MFMBUDRLOC->TEXT_COLOR = MFMBUDRLOC_N->TEXT_COLOR;
    MFMBUDRLOC->TEXT_STYLE = MFMBUDRLOC_N->TEXT_STYLE[0];
    MFMBUDRLOC->TAG_TYPE = MFMBUDRLOC_N->TAG_TYPE;
    MFMBUDRLOC->BACK_COLOR = MFMBUDRLOC_N->BACK_COLOR;
    MEMCPY_DN(MFMBUDRLOC->CREATE_TIME, MFMBUDRLOC_N->CREATE_TIME, sizeof(MFMBUDRLOC->CREATE_TIME));
    MEMCPY_DN(MFMBUDRLOC->UPDATE_TIME, MFMBUDRLOC_N->UPDATE_TIME, sizeof(MFMBUDRLOC->UPDATE_TIME));
    MFMBUDRLOC->NO_MOUSE_EVENT = MFMBUDRLOC_N->NO_MOUSE_EVENT[0];
    MFMBUDRLOC->SIGNAL_FLAG = MFMBUDRLOC_N->SIGNAL_FLAG[0];
    MEMCPY_DN(MFMBUDRLOC->MOTHER_RES_ID, MFMBUDRLOC_N->MOTHER_RES_ID, sizeof(MFMBUDRLOC->MOTHER_RES_ID));
    MFMBUDRLOC->ANGLE = MFMBUDRLOC_N->ANGLE;
    MFMBUDRLOC->RES_SHAPE = MFMBUDRLOC_N->RES_SHAPE[0];
}


