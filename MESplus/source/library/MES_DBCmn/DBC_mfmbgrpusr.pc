/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mfmbgrpusr(int sel_type, struct MFMBGRPUSR_TAG *MFMBGRPUSR)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MFMBGRPUSR_N_TAG MFMBGRPUSR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mfmbgrpusr(&MFMBGRPUSR_N, MFMBGRPUSR);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MFMBGRPUSR_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    GROUP_ID,
                    USER_ID
                FROM MFMBGRPUSR
                WHERE FACTORY = :MFMBGRPUSR_N.FACTORY
                    AND GROUP_ID = :MFMBGRPUSR_N.GROUP_ID
                    AND USER_ID >= :MFMBGRPUSR_N.USER_ID
                ORDER BY USER_ID ASC;
            EXEC SQL OPEN DBC_MFMBGRPUSR_CUR_1;
            break;
            
         case 2:
            EXEC SQL DECLARE DBC_MFMBGRPUSR_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    GROUP_ID,
                    USER_ID
                FROM MFMBGRPUSR
                WHERE FACTORY = :MFMBGRPUSR_N.FACTORY
                    AND USER_ID = :MFMBGRPUSR_N.USER_ID
                    AND GROUP_ID >= :MFMBGRPUSR_N.GROUP_ID
                    ORDER BY GROUP_ID ASC;
            EXEC SQL OPEN DBC_MFMBGRPUSR_CUR_2;
            break;   


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mfmbgrpusr", sel_type);
}


