                    AND FLOW = ' '
                    AND OPER = :MBASSCRREL_N.OPER;
            EXEC SQL OPEN DBC_MBASSCRREL_CUR_6;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mbasscrrel", sel_type);
}


