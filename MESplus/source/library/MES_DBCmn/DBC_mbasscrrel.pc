/* SQL CURSOR CLOSE Function */
void DBC_close_mbasscrrel(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MBASSCRREL_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MBASSCRREL_CUR_2;
            break;
        
        case 3:
            EXEC SQL CLOSE DBC_MBASSCRREL_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MBASSCRREL_CUR_4;
            break;
        case 5:
            EXEC SQL CLOSE DBC_MBASSCRREL_CUR_5;
            break;
        case 6:
            EXEC SQL CLOSE DBC_MBASSCRREL_CUR_6;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mbasscrrel", sel_type);
}


/* Initialize Function */
void DBC_init_mbasscrrel(struct MBASSCRREL_TAG *MBASSCRREL)
{
    /* memset by Space */
    memset(MBASSCRREL, ' ', sizeof(struct MBASSCRREL_TAG));
    
    MBASSCRREL->MAT_VER = 0;
    MBASSCRREL->FLOW_SEQ_NUM =0;
}


/* Add Null Function */
void DBC_add_null_mbasscrrel(struct MBASSCRREL_N_TAG *MBASSCRREL_N, struct MBASSCRREL_TAG *MBASSCRREL)
{
    /* memset by NULL */
    memset(MBASSCRREL_N, '\0', sizeof(struct MBASSCRREL_N_TAG));
    
    MEMCPY_AN(MBASSCRREL_N->RELATION_KEY, MBASSCRREL->RELATION_KEY, sizeof(MBASSCRREL->RELATION_KEY));
    MBASSCRREL_N->OPT_LEVEL[0] = MBASSCRREL->OPT_LEVEL;
    MEMCPY_AN(MBASSCRREL_N->FACTORY, MBASSCRREL->FACTORY, sizeof(MBASSCRREL->FACTORY));
    MEMCPY_AN(MBASSCRREL_N->MAT_ID, MBASSCRREL->MAT_ID, sizeof(MBASSCRREL->MAT_ID));
    MBASSCRREL_N->MAT_VER = MBASSCRREL->MAT_VER;
    MEMCPY_AN(MBASSCRREL_N->FLOW, MBASSCRREL->FLOW, sizeof(MBASSCRREL->FLOW));
    MBASSCRREL_N->FLOW_SEQ_NUM = MBASSCRREL->FLOW_SEQ_NUM;
    MEMCPY_AN(MBASSCRREL_N->OPER, MBASSCRREL->OPER, sizeof(MBASSCRREL->OPER));
    MEMCPY_AN(MBASSCRREL_N->RES_ID, MBASSCRREL->RES_ID, sizeof(MBASSCRREL->RES_ID));
    MEMCPY_AN(MBASSCRREL_N->RES_TYPE, MBASSCRREL->RES_TYPE, sizeof(MBASSCRREL->RES_TYPE));
    MEMCPY_AN(MBASSCRREL_N->RESG_ID, MBASSCRREL->RESG_ID, sizeof(MBASSCRREL->RESG_ID));
    MEMCPY_AN(MBASSCRREL_N->SCREEN_ID, MBASSCRREL->SCREEN_ID, sizeof(MBASSCRREL->SCREEN_ID));
    MEMCPY_AN(MBASSCRREL_N->CREATE_USER_ID, MBASSCRREL->CREATE_USER_ID, sizeof(MBASSCRREL->CREATE_USER_ID));
    MEMCPY_AN(MBASSCRREL_N->CREATE_TIME, MBASSCRREL->CREATE_TIME, sizeof(MBASSCRREL->CREATE_TIME));
    MEMCPY_AN(MBASSCRREL_N->UPDATE_USER_ID, MBASSCRREL->UPDATE_USER_ID, sizeof(MBASSCRREL->UPDATE_USER_ID));
    MEMCPY_AN(MBASSCRREL_N->UPDATE_TIME, MBASSCRREL->UPDATE_TIME, sizeof(MBASSCRREL->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mbasscrrel(struct MBASSCRREL_N_TAG *MBASSCRREL_N, struct MBASSCRREL_TAG *MBASSCRREL)
{
    MEMCPY_DN(MBASSCRREL->RELATION_KEY, MBASSCRREL_N->RELATION_KEY, sizeof(MBASSCRREL->RELATION_KEY));
    MBASSCRREL->OPT_LEVEL = MBASSCRREL_N->OPT_LEVEL[0];
    MEMCPY_DN(MBASSCRREL->FACTORY, MBASSCRREL_N->FACTORY, sizeof(MBASSCRREL->FACTORY));
    MEMCPY_DN(MBASSCRREL->MAT_ID, MBASSCRREL_N->MAT_ID, sizeof(MBASSCRREL->MAT_ID));
    MBASSCRREL->MAT_VER = MBASSCRREL_N->MAT_VER;
    MEMCPY_DN(MBASSCRREL->FLOW, MBASSCRREL_N->FLOW, sizeof(MBASSCRREL->FLOW));
    MBASSCRREL->FLOW_SEQ_NUM = MBASSCRREL_N->FLOW_SEQ_NUM;
    MEMCPY_DN(MBASSCRREL->OPER, MBASSCRREL_N->OPER, sizeof(MBASSCRREL->OPER));
    MEMCPY_DN(MBASSCRREL->RES_ID, MBASSCRREL_N->RES_ID, sizeof(MBASSCRREL->RES_ID));
    MEMCPY_DN(MBASSCRREL->RES_TYPE, MBASSCRREL_N->RES_TYPE, sizeof(MBASSCRREL->RES_TYPE));
    MEMCPY_DN(MBASSCRREL->RESG_ID, MBASSCRREL_N->RESG_ID, sizeof(MBASSCRREL->RESG_ID));
    MEMCPY_DN(MBASSCRREL->SCREEN_ID, MBASSCRREL_N->SCREEN_ID, sizeof(MBASSCRREL->SCREEN_ID));
    MEMCPY_DN(MBASSCRREL->CREATE_USER_ID, MBASSCRREL_N->CREATE_USER_ID, sizeof(MBASSCRREL->CREATE_USER_ID));
    MEMCPY_DN(MBASSCRREL->CREATE_TIME, MBASSCRREL_N->CREATE_TIME, sizeof(MBASSCRREL->CREATE_TIME));
    MEMCPY_DN(MBASSCRREL->UPDATE_USER_ID, MBASSCRREL_N->UPDATE_USER_ID, sizeof(MBASSCRREL->UPDATE_USER_ID));
    MEMCPY_DN(MBASSCRREL->UPDATE_TIME, MBASSCRREL_N->UPDATE_TIME, sizeof(MBASSCRREL->UPDATE_TIME));
}



