/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_msvmkeyver(int sel_type, struct MSVMKEYVER_TAG *MSVMKEYVER)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSVMKEYVER_N_TAG MSVMKEYVER_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_msvmkeyver(&MSVMKEYVER_N, MSVMKEYVER);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSVMKEYVER_CUR_1 CURSOR FOR
                SELECT 
                    KEY_NAME,
                    KEY_DESC,
                    KEY_TYPE,
                    LIB_NAME,
                    LIB_VER,
                    SERVICE_NAME,
                    SERVICE_VER,
                    DATA_1,
                    DATA_2,
                    DATA_3,
                    DATA_4,
                    DATA_5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MSVMKEYVER
                WHERE KEY_NAME = :MSVMKEYVER_N.KEY_NAME
                ORDER BY KEY_NAME ASC;
            EXEC SQL OPEN DBC_MSVMKEYVER_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MSVMKEYVER_CUR_2 CURSOR FOR
                SELECT 
                    KEY_NAME,
                    KEY_DESC,
                    KEY_TYPE,
                    LIB_NAME,
                    LIB_VER,
                    SERVICE_NAME,
                    SERVICE_VER,
                    DATA_1,
                    DATA_2,
                    DATA_3,
                    DATA_4,
                    DATA_5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM (
                    SELECT A.*, ROWNUM
                    FROM (
                        SELECT 
                            KEY_NAME,
                            KEY_DESC,
                            KEY_TYPE,
                            LIB_NAME,
                            LIB_VER,
                            SERVICE_NAME,
                            SERVICE_VER,
                            DATA_1,
                            DATA_2,
                            DATA_3,
                            DATA_4,
                            DATA_5,
                            CREATE_USER_ID,
                            CREATE_TIME,
                            UPDATE_USER_ID,
                            UPDATE_TIME
                        FROM MSVMKEYVER
                        WHERE ROWID <= :MSVMKEYVER_N.CREATE_USER_ID
                            AND KEY_NAME LIKE '%' || :MSVMKEYVER_N.KEY_NAME || '%'
                            AND KEY_TYPE LIKE '%' || :MSVMKEYVER_N.KEY_TYPE || '%'
                            AND LIB_NAME LIKE '%' || :MSVMKEYVER_N.LIB_NAME || '%'
                            AND LIB_VER LIKE '%' || :MSVMKEYVER_N.LIB_VER || '%'
                            AND SERVICE_NAME LIKE '%' || :MSVMKEYVER_N.SERVICE_NAME || '%'
                            AND SERVICE_VER LIKE '%' || :MSVMKEYVER_N.CREATE_TIME || '%'
                        ORDER BY KEY_NAME ASC, LIB_NAME ASC, LIB_VER ASC, SERVICE_NAME ASC, SERVICE_VER ASC
                        ) A
                    )
                WHERE ROWNUM >= :MSVMKEYVER_N.SERVICE_VER;

            EXEC SQL OPEN DBC_MSVMKEYVER_CUR_2;
            break;
            
        case 3:
            EXEC SQL DECLARE DBC_MSVMKEYVER_CUR_3 CURSOR FOR
                SELECT 
                    KEY_NAME,
                    KEY_DESC,
                    KEY_TYPE,
                    LIB_NAME,
                    LIB_VER,
                    SERVICE_NAME,
                    SERVICE_VER,
                    DATA_1,
                    DATA_2,
                    DATA_3,
                    DATA_4,
                    DATA_5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM (
                    SELECT A.*, ROWNUM
                    FROM (
                        SELECT 
                            KEY_NAME,
                            KEY_DESC,
                            KEY_TYPE,
                            LIB_NAME,
                            LIB_VER,
                            SERVICE_NAME,
                            SERVICE_VER,
                            DATA_1,
                            DATA_2,
                            DATA_3,
                            DATA_4,
                            DATA_5,
                            CREATE_USER_ID,
                            CREATE_TIME,
                            UPDATE_USER_ID,
                            UPDATE_TIME
                        FROM MSVMKEYVER
                        WHERE ROWID <= :MSVMKEYVER_N.CREATE_USER_ID
                            AND KEY_TYPE = :MSVMKEYVER_N.KEY_TYPE
                            AND DATA_2 = :MSVMKEYVER_N.DATA_2
                        ORDER BY KEY_NAME ASC, LIB_NAME ASC, LIB_VER ASC, SERVICE_NAME ASC, SERVICE_VER ASC
                        ) A
                    )
                WHERE ROWNUM >= :MSVMKEYVER_N.SERVICE_VER;

            EXEC SQL OPEN DBC_MSVMKEYVER_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_msvmkeyver", sel_type);
}


