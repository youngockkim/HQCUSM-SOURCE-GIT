/* Add Null Function */
void DBC_add_null_msvmkeyver(struct MSVMKEYVER_N_TAG *MSVMKEYVER_N, struct MSVMKEYVER_TAG *MSVMKEYVER)
{
    /* memset by NULL */
    memset(MSVMKEYVER_N, '\0', sizeof(struct MSVMKEYVER_N_TAG));
    
    MEMCPY_AN(MSVMKEYVER_N->KEY_NAME, MSVMKEYVER->KEY_NAME, sizeof(MSVMKEYVER->KEY_NAME));
    MEMCPY_AN(MSVMKEYVER_N->KEY_DESC, MSVMKEYVER->KEY_DESC, sizeof(MSVMKEYVER->KEY_DESC));
    MEMCPY_AN(MSVMKEYVER_N->KEY_TYPE, MSVMKEYVER->KEY_TYPE, sizeof(MSVMKEYVER->KEY_TYPE));
    MEMCPY_AN(MSVMKEYVER_N->LIB_NAME, MSVMKEYVER->LIB_NAME, sizeof(MSVMKEYVER->LIB_NAME));
    MEMCPY_AN(MSVMKEYVER_N->LIB_VER, MSVMKEYVER->LIB_VER, sizeof(MSVMKEYVER->LIB_VER));
    MEMCPY_AN(MSVMKEYVER_N->SERVICE_NAME, MSVMKEYVER->SERVICE_NAME, sizeof(MSVMKEYVER->SERVICE_NAME));
    MSVMKEYVER_N->SERVICE_VER = MSVMKEYVER->SERVICE_VER;
    MEMCPY_AN(MSVMKEYVER_N->DATA_1, MSVMKEYVER->DATA_1, sizeof(MSVMKEYVER->DATA_1));
    MEMCPY_AN(MSVMKEYVER_N->DATA_2, MSVMKEYVER->DATA_2, sizeof(MSVMKEYVER->DATA_2));
    MEMCPY_AN(MSVMKEYVER_N->DATA_3, MSVMKEYVER->DATA_3, sizeof(MSVMKEYVER->DATA_3));
    MEMCPY_AN(MSVMKEYVER_N->DATA_4, MSVMKEYVER->DATA_4, sizeof(MSVMKEYVER->DATA_4));
    MEMCPY_AN(MSVMKEYVER_N->DATA_5, MSVMKEYVER->DATA_5, sizeof(MSVMKEYVER->DATA_5));
    MEMCPY_AN(MSVMKEYVER_N->CREATE_USER_ID, MSVMKEYVER->CREATE_USER_ID, sizeof(MSVMKEYVER->CREATE_USER_ID));
    MEMCPY_AN(MSVMKEYVER_N->CREATE_TIME, MSVMKEYVER->CREATE_TIME, sizeof(MSVMKEYVER->CREATE_TIME));
    MEMCPY_AN(MSVMKEYVER_N->UPDATE_USER_ID, MSVMKEYVER->UPDATE_USER_ID, sizeof(MSVMKEYVER->UPDATE_USER_ID));
    MEMCPY_AN(MSVMKEYVER_N->UPDATE_TIME, MSVMKEYVER->UPDATE_TIME, sizeof(MSVMKEYVER->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_msvmkeyver(struct MSVMKEYVER_N_TAG *MSVMKEYVER_N, struct MSVMKEYVER_TAG *MSVMKEYVER)
{
    MEMCPY_DN(MSVMKEYVER->KEY_NAME, MSVMKEYVER_N->KEY_NAME, sizeof(MSVMKEYVER->KEY_NAME));
    MEMCPY_DN(MSVMKEYVER->KEY_DESC, MSVMKEYVER_N->KEY_DESC, sizeof(MSVMKEYVER->KEY_DESC));
    MEMCPY_DN(MSVMKEYVER->KEY_TYPE, MSVMKEYVER_N->KEY_TYPE, sizeof(MSVMKEYVER->KEY_TYPE));
    MEMCPY_DN(MSVMKEYVER->LIB_NAME, MSVMKEYVER_N->LIB_NAME, sizeof(MSVMKEYVER->LIB_NAME));
    MEMCPY_DN(MSVMKEYVER->LIB_VER, MSVMKEYVER_N->LIB_VER, sizeof(MSVMKEYVER->LIB_VER));
    MEMCPY_DN(MSVMKEYVER->SERVICE_NAME, MSVMKEYVER_N->SERVICE_NAME, sizeof(MSVMKEYVER->SERVICE_NAME));
    MSVMKEYVER->SERVICE_VER = MSVMKEYVER_N->SERVICE_VER;
    MEMCPY_DN(MSVMKEYVER->DATA_1, MSVMKEYVER_N->DATA_1, sizeof(MSVMKEYVER->DATA_1));
    MEMCPY_DN(MSVMKEYVER->DATA_2, MSVMKEYVER_N->DATA_2, sizeof(MSVMKEYVER->DATA_2));
    MEMCPY_DN(MSVMKEYVER->DATA_3, MSVMKEYVER_N->DATA_3, sizeof(MSVMKEYVER->DATA_3));
