/* SQL CURSOR CLOSE Function */
void DBC_close_malmmsghis(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MALMMSGHIS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MALMMSGHIS_CUR_2;
            break;
		
		case 101:
            EXEC SQL CLOSE DBC_MALMMSGHIS_CUR_101;
            break;

		case 102:
            EXEC SQL CLOSE DBC_MALMMSGHIS_CUR_102;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_malmmsghis", sel_type);
}


/* Initialize Function */
void DBC_init_malmmsghis(struct MALMMSGHIS_TAG *MALMMSGHIS)
{
    /* memset by Space */
    memset(MALMMSGHIS, ' ', sizeof(struct MALMMSGHIS_TAG));
    MALMMSGHIS->LOT_HIST_SEQ = 0;
    MALMMSGHIS->RES_HIST_SEQ = 0;
    
}


/* Add Null Function */
void DBC_add_null_malmmsghis(struct MALMMSGHIS_N_TAG *MALMMSGHIS_N, struct MALMMSGHIS_TAG *MALMMSGHIS)
{
    /* memset by NULL */
    memset(MALMMSGHIS_N, '\0', sizeof(struct MALMMSGHIS_N_TAG));
    
    MEMCPY_AN(MALMMSGHIS_N->FACTORY, MALMMSGHIS->FACTORY, sizeof(MALMMSGHIS->FACTORY));
    MEMCPY_AN(MALMMSGHIS_N->ALARM_ID, MALMMSGHIS->ALARM_ID, sizeof(MALMMSGHIS->ALARM_ID));
    MALMMSGHIS_N->ALARM_TYPE[0] = MALMMSGHIS->ALARM_TYPE;
    MEMCPY_AN(MALMMSGHIS_N->TRAN_TIME, MALMMSGHIS->TRAN_TIME, sizeof(MALMMSGHIS->TRAN_TIME));
    MEMCPY_AN(MALMMSGHIS_N->LOT_ID, MALMMSGHIS->LOT_ID, sizeof(MALMMSGHIS->LOT_ID));
    MALMMSGHIS_N->LOT_HIST_SEQ = MALMMSGHIS->LOT_HIST_SEQ;
    MEMCPY_AN(MALMMSGHIS_N->RES_ID, MALMMSGHIS->RES_ID, sizeof(MALMMSGHIS->RES_ID));
    MALMMSGHIS_N->RES_HIST_SEQ = MALMMSGHIS->RES_HIST_SEQ;
    MEMCPY_AN(MALMMSGHIS_N->AREA_ID, MALMMSGHIS->AREA_ID, sizeof(MALMMSGHIS->AREA_ID));
    MEMCPY_AN(MALMMSGHIS_N->SUB_AREA_ID, MALMMSGHIS->SUB_AREA_ID, sizeof(MALMMSGHIS->SUB_AREA_ID));
    MEMCPY_AN(MALMMSGHIS_N->SOURCE_ID_1, MALMMSGHIS->SOURCE_ID_1, sizeof(MALMMSGHIS->SOURCE_ID_1));
    MEMCPY_AN(MALMMSGHIS_N->SOURCE_DESC_1, MALMMSGHIS->SOURCE_DESC_1, sizeof(MALMMSGHIS->SOURCE_DESC_1));
