            make_valid_quote(ts, MALMMSGHIS_N.FACTORY);
            sprintf(sql + strlen(sql), "FACTORY='%s'",ts);            
            make_valid_quote(ts, MALMMSGHIS_N.SOURCE_ID_1);
            sprintf(sql + strlen(sql), "  AND SOURCE_ID_1='%s'",ts);            
            make_valid_quote(ts, DBC_Q_COND_N.FROM_TIME);
            sprintf(sql + strlen(sql), "  AND TRAN_TIME >='%s'",ts);
            make_valid_quote(ts, DBC_Q_COND_N.TO_TIME);
            sprintf(sql + strlen(sql), "  AND TRAN_TIME <='%s'",ts); 
            
            if(ISSPACE(MALMMSGHIS->TRAN_TIME, sizeof(MALMMSGHIS->TRAN_TIME)) == DB_FALSE)
            {
                make_valid_quote(ts, MALMMSGHIS_N.TRAN_TIME);
                sprintf(sql + strlen(sql), "  AND TRAN_TIME <='%s'",ts);
            }
            
            if(MALMMSGHIS->CLEAR_FLAG == 'Y')
            {
                sprintf(sql + strlen(sql), " AND CLEAR_FLAG='Y'");
            }
            else if(MALMMSGHIS->CLEAR_FLAG == 'N')
            {
                sprintf(sql + strlen(sql), " AND CLEAR_FLAG=' '");
            }

            if(ISSPACE(MALMMSGHIS->ALARM_ID, sizeof(MALMMSGHIS->ALARM_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MALMMSGHIS_N.ALARM_ID);
                sprintf(sql + strlen(sql), "  AND ALARM_ID ='%s'",ts);
            }
            if(MALMMSGHIS->ALARM_TYPE != ' ')
            {
                sprintf(sql + strlen(sql), " AND ALARM_TYPE='%c'", MALMMSGHIS->ALARM_TYPE);
            }
            if(ISSPACE(MALMMSGHIS->LOT_ID, sizeof(MALMMSGHIS->LOT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MALMMSGHIS_N.LOT_ID);
                sprintf(sql + strlen(sql), "  AND LOT_ID ='%s'",ts);
            }
            if(ISSPACE(MALMMSGHIS->RES_ID, sizeof(MALMMSGHIS->RES_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MALMMSGHIS_N.RES_ID);
                sprintf(sql + strlen(sql), "  AND RES_ID ='%s'",ts);
            }
            if(ISNULLOREMPTY(DBC_Q_COND_N.KEY_1, sizeof(DBC_Q_COND_N.KEY_1)) == DB_FALSE)
            {
                make_valid_quote(ts, DBC_Q_COND_N.KEY_1);
                sprintf(sql + strlen(sql), "  AND RES_ID IN (SELECT RES_ID FROM MRASRESDEF WHERE RES_TYPE = '%s')",ts);
            }
            
            sprintf(sql + strlen(sql), " ORDER BY TRAN_TIME DESC");
 
            EXEC SQL PREPARE S FROM :sql;
            
            
            /*
            LOG_head("DB");
            LOG_add("len", 1, strlen(sql));
            LOG_add("sql", 4, strlen(sql), sql);
            COM_log_write('I', 'S' , 'S');
            */
            
            EXEC SQL DECLARE DBC_MALMMSGHIS_CUR_1 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MALMMSGHIS_CUR_1;  
            break; 

        case 2:  
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "FACTORY, ");
            sprintf(sql + strlen(sql),   "ALARM_ID, ");
            sprintf(sql + strlen(sql),   "ALARM_TYPE, ");
            sprintf(sql + strlen(sql),   "TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "LOT_ID, ");
            sprintf(sql + strlen(sql),   "LOT_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "RES_ID, ");
            sprintf(sql + strlen(sql),   "RES_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "AREA_ID, ");
            sprintf(sql + strlen(sql),   "SUB_AREA_ID, ");
            sprintf(sql + strlen(sql),   "SOURCE_ID_1, ");
            sprintf(sql + strlen(sql),   "SOURCE_DESC_1, ");
            sprintf(sql + strlen(sql),   "SOURCE_ID_2, ");
            sprintf(sql + strlen(sql),   "SOURCE_DESC_2, ");
            sprintf(sql + strlen(sql),   "SOURCE_ID_3, ");
            sprintf(sql + strlen(sql),   "SOURCE_DESC_3, ");
            sprintf(sql + strlen(sql),   "ALARM_LEVEL_FLAG, ");
            sprintf(sql + strlen(sql),   "ALARM_SUBJECT, ");
            sprintf(sql + strlen(sql),   "ALARM_MSG, ");
            sprintf(sql + strlen(sql),   "ACK_FLAG, ");
            sprintf(sql + strlen(sql),   "ACK_TIME, ");
            sprintf(sql + strlen(sql),   "ACK_USER_ID, ");
            sprintf(sql + strlen(sql),   "CLEAR_FLAG, ");
            sprintf(sql + strlen(sql),   "CLEAR_TIME, ");
            sprintf(sql + strlen(sql),   "CLEAR_USER_ID, ");
            sprintf(sql + strlen(sql),   "CLEAR_COMMENT, ");
            sprintf(sql + strlen(sql),   "USER_ID, ");
            sprintf(sql + strlen(sql),   "ALARM_COMMENT_1, ");
            sprintf(sql + strlen(sql),   "ALARM_COMMENT_2, ");
            sprintf(sql + strlen(sql),   "ALARM_COMMENT_3, ");
            sprintf(sql + strlen(sql),   "ALARM_COMMENT_4, ");
            sprintf(sql + strlen(sql),   "ALARM_COMMENT_5, ");
            sprintf(sql + strlen(sql),   "PDF_FILE_NAME, ");
            sprintf(sql + strlen(sql),   "IMAGE_FILE_NAME ");
            sprintf(sql + strlen(sql), "FROM MALMMSGHIS WHERE ");
            make_valid_quote(ts, MALMMSGHIS_N.FACTORY);
            sprintf(sql + strlen(sql), "FACTORY='%s'",ts);                       
            make_valid_quote(ts, DBC_Q_COND_N.FROM_TIME);
            sprintf(sql + strlen(sql), "  AND TRAN_TIME >='%s'",ts);
            make_valid_quote(ts, DBC_Q_COND_N.TO_TIME);
            sprintf(sql + strlen(sql), "  AND TRAN_TIME <='%s'",ts); 
            make_valid_quote(ts, MALMMSGHIS_N.SOURCE_ID_1);
            sprintf(sql + strlen(sql), "  AND (( SOURCE_ID_1 >'%s') OR ",ts); 
            sprintf(sql + strlen(sql), "  ( SOURCE_ID_1 ='%s' ",ts);
            make_valid_quote(ts, MALMMSGHIS_N.TRAN_TIME);
            sprintf(sql + strlen(sql), "  AND TRAN_TIME <='%s' ))",ts);
            
            if(MALMMSGHIS->CLEAR_FLAG == 'Y')
            {
                sprintf(sql + strlen(sql), " AND CLEAR_FLAG='Y'");
            }
            else if(MALMMSGHIS->CLEAR_FLAG == 'N')
            {
                sprintf(sql + strlen(sql), " AND CLEAR_FLAG=' '");
            }

            if(ISSPACE(MALMMSGHIS->ALARM_ID, sizeof(MALMMSGHIS->ALARM_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MALMMSGHIS_N.ALARM_ID);
                sprintf(sql + strlen(sql), "  AND ALARM_ID ='%s'",ts);
            }
            if(MALMMSGHIS->ALARM_TYPE != ' ')
            {
                sprintf(sql + strlen(sql), " AND ALARM_TYPE='%c'", MALMMSGHIS->ALARM_TYPE);
            }
            if(ISSPACE(MALMMSGHIS->LOT_ID, sizeof(MALMMSGHIS->LOT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MALMMSGHIS_N.LOT_ID);
                sprintf(sql + strlen(sql), "  AND LOT_ID ='%s'",ts);
            }
            if(ISSPACE(MALMMSGHIS->RES_ID, sizeof(MALMMSGHIS->RES_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MALMMSGHIS_N.RES_ID);
                sprintf(sql + strlen(sql), "  AND RES_ID ='%s'",ts);
            }
            if(ISNULLOREMPTY(DBC_Q_COND_N.KEY_1, sizeof(DBC_Q_COND_N.KEY_1)) == DB_FALSE)
            {
                make_valid_quote(ts, DBC_Q_COND_N.KEY_1);
                sprintf(sql + strlen(sql), "  AND RES_ID IN (SELECT RES_ID FROM MRASRESDEF WHERE RES_TYPE = '%s')",ts);
            }

            sprintf(sql + strlen(sql), " ORDER BY SOURCE_ID_1 ASC, TRAN_TIME DESC");
 
            EXEC SQL PREPARE S FROM :sql;
            
            
            /*LOG_head("DB");
            LOG_add("len", 1, strlen(sql));
            LOG_add("sql", 4, strlen(sql), sql);
            COM_log_write('I', 'S' , 'S');*/
            
            
            EXEC SQL DECLARE DBC_MALMMSGHIS_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MALMMSGHIS_CUR_2;
            break;

		case 101:  
			EXEC SQL DECLARE DBC_MALMMSGHIS_CUR_101 CURSOR FOR
                SELECT 
                    FACTORY,
                    ALARM_ID,
                    ALARM_TYPE,
                    TRAN_TIME,
                    LOT_ID,
                    LOT_HIST_SEQ,
                    RES_ID,
                    RES_HIST_SEQ,
                    AREA_ID,
                    SUB_AREA_ID,
                    SOURCE_ID_1,
                    SOURCE_DESC_1,
                    SOURCE_ID_2,
                    SOURCE_DESC_2,
                    SOURCE_ID_3,
                    SOURCE_DESC_3,
                    ALARM_LEVEL_FLAG,
                    ALARM_SUBJECT,
                    ALARM_MSG,
                    ACK_FLAG,
                    ACK_TIME,
                    ACK_USER_ID,
                    CLEAR_FLAG,
                    CLEAR_TIME,
                    CLEAR_USER_ID,
                    CLEAR_COMMENT,
                    USER_ID,
                    ALARM_COMMENT_1,
                    ALARM_COMMENT_2,
                    ALARM_COMMENT_3,
                    ALARM_COMMENT_4,
                    ALARM_COMMENT_5,
                    PDF_FILE_NAME,
                    IMAGE_FILE_NAME
                FROM MALMMSGHIS
                WHERE FACTORY = :MALMMSGHIS_N.FACTORY
				  AND RES_ID  = :MALMMSGHIS_N.RES_ID
				  AND ALARM_ID = :MALMMSGHIS_N.ALARM_ID
				  AND SOURCE_ID_1  = :MALMMSGHIS_N.SOURCE_ID_1
				  AND CLEAR_FLAG =  :MALMMSGHIS_N.CLEAR_FLAG
                ORDER BY FACTORY ASC,
                    TRAN_TIME ASC,
                    SOURCE_ID_1 ASC;
            EXEC SQL OPEN DBC_MALMMSGHIS_CUR_101;
            break;

		case 102:  
			EXEC SQL DECLARE DBC_MALMMSGHIS_CUR_102 CURSOR FOR
                SELECT 
                    FACTORY,
                    ALARM_ID,
                    ALARM_TYPE,
                    TRAN_TIME,
                    LOT_ID,
                    LOT_HIST_SEQ,
                    RES_ID,
                    RES_HIST_SEQ,
                    AREA_ID,
                    SUB_AREA_ID,
                    SOURCE_ID_1,
                    SOURCE_DESC_1,
                    SOURCE_ID_2,
                    SOURCE_DESC_2,
                    SOURCE_ID_3,
                    SOURCE_DESC_3,
                    ALARM_LEVEL_FLAG,
                    ALARM_SUBJECT,
                    ALARM_MSG,
                    ACK_FLAG,
                    ACK_TIME,
                    ACK_USER_ID,
                    CLEAR_FLAG,
                    CLEAR_TIME,
                    CLEAR_USER_ID,
                    CLEAR_COMMENT,
                    USER_ID,
                    ALARM_COMMENT_1,
                    ALARM_COMMENT_2,
                    ALARM_COMMENT_3,
                    ALARM_COMMENT_4,
                    ALARM_COMMENT_5,
                    PDF_FILE_NAME,
                    IMAGE_FILE_NAME
                FROM MALMMSGHIS
                WHERE FACTORY = :MALMMSGHIS_N.FACTORY
				  AND RES_ID  = :MALMMSGHIS_N.RES_ID
				  AND ALARM_ID = :MALMMSGHIS_N.ALARM_ID
				  AND SOURCE_ID_1  = :MALMMSGHIS_N.SOURCE_ID_1
				  AND CLEAR_FLAG = ' '  
                ORDER BY FACTORY ASC,
                    TRAN_TIME ASC,
                    SOURCE_ID_1 ASC;
            EXEC SQL OPEN DBC_MALMMSGHIS_CUR_102;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_malmmsghis", sel_type);
}


