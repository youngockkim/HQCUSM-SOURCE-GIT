                sprintf(sql + strlen(sql),      "AND CGC.CHAR_CMF_3 = '%s' ", ts1);
            }
            if(ISSPACE(SPEC_VALUE->CHAR_CMF_4, sizeof(SPEC_VALUE->CHAR_CMF_4)) == DB_FALSE)
            {
                make_valid_quote(ts1, SPEC_VALUE_N.CHAR_CMF_4);
                sprintf(sql + strlen(sql),      "AND CGC.CHAR_CMF_4 = '%s' ", ts1);
            }
            if(ISSPACE(SPEC_VALUE->CHAR_CMF_5, sizeof(SPEC_VALUE->CHAR_CMF_5)) == DB_FALSE)
            {
                make_valid_quote(ts1, SPEC_VALUE_N.CHAR_CMF_5);
                sprintf(sql + strlen(sql),      "AND CGC.CHAR_CMF_5 = '%s' ", ts1);
            }
