    MEMCPY_AN(SPEC_VALUE_N->OPER_2, SPEC_VALUE->OPER_2, sizeof(SPEC_VALUE->OPER_2));
    MEMCPY_AN(SPEC_VALUE_N->OPER_3, SPEC_VALUE->OPER_3, sizeof(SPEC_VALUE->OPER_3));
    MEMCPY_AN(SPEC_VALUE_N->OPER_4, SPEC_VALUE->OPER_4, sizeof(SPEC_VALUE->OPER_4));
    MEMCPY_AN(SPEC_VALUE_N->OPER_5, SPEC_VALUE->OPER_5, sizeof(SPEC_VALUE->OPER_5));
}


/* Del Null Function */
void DBC_del_null_spec_value(struct VIEW_SPEC_VALUE_N_TAG *SPEC_VALUE_N, struct VIEW_SPEC_VALUE_TAG *SPEC_VALUE)
{
    SPEC_VALUE->SEQ = SPEC_VALUE_N->SEQ;
    MEMCPY_DN(SPEC_VALUE->FACTORY, SPEC_VALUE_N->FACTORY, sizeof(SPEC_VALUE->FACTORY));
