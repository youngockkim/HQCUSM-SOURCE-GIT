                sprintf(sql + strlen(sql),      "AND CGC.CHAR_GRP_5 = '%s' ", ts1);
            }
            if(ISSPACE(SPEC_VALUE->CHAR_GRP_6, sizeof(SPEC_VALUE->CHAR_GRP_6)) == DB_FALSE)
