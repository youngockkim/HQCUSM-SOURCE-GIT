            }
            if(ISSPACE(SPEC_VALUE->CHAR_CMF_7, sizeof(SPEC_VALUE->CHAR_CMF_7)) == DB_FALSE)
            {
                make_valid_quote(ts1, SPEC_VALUE_N.CHAR_CMF_7);
                sprintf(sql + strlen(sql),      "AND CGC.CHAR_CMF_7 = '%s' ", ts1);
            }
            if(ISSPACE(SPEC_VALUE->CHAR_CMF_8, sizeof(SPEC_VALUE->CHAR_CMF_8)) == DB_FALSE)
            {
                make_valid_quote(ts1, SPEC_VALUE_N.CHAR_CMF_8);
                sprintf(sql + strlen(sql),      "AND CGC.CHAR_CMF_8 = '%s' ", ts1);
            }
            if(ISSPACE(SPEC_VALUE->CHAR_CMF_9, sizeof(SPEC_VALUE->CHAR_CMF_9)) == DB_FALSE)
            {
                make_valid_quote(ts1, SPEC_VALUE_N.CHAR_CMF_9);
                sprintf(sql + strlen(sql),      "AND CGC.CHAR_CMF_9 = '%s' ", ts1);
            }
            if(ISSPACE(SPEC_VALUE->CHAR_CMF_10, sizeof(SPEC_VALUE->CHAR_CMF_10)) == DB_FALSE)
            {
                make_valid_quote(ts1, SPEC_VALUE_N.CHAR_CMF_10);
                sprintf(sql + strlen(sql),      "AND CGC.CHAR_CMF_10 = '%s' ", ts1);
            }
            sprintf(sql + strlen(sql),      ") ");

            sprintf(sql + strlen(sql),  "ORDER BY %s ) SPEC ) ", s_sort_order);
            sprintf(sql + strlen(sql), "WHERE SEQ >= %d ", SPEC_VALUE_N.SEQ);
            sprintf(sql + strlen(sql), "ORDER BY SEQ ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_SPEC_VALUE_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN DBC_SPEC_VALUE_CUR_2;                 
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_spec_value", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_spec_value(int sel_type, struct VIEW_SPEC_VALUE_TAG *SPEC_VALUE)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct VIEW_SPEC_VALUE_N_TAG SPEC_VALUE_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_SPEC_VALUE_CUR_1 INTO
                :SPEC_VALUE_N.SEQ,
                :SPEC_VALUE_N.FACTORY,
                :SPEC_VALUE_N.MAT_ID,
                :SPEC_VALUE_N.MAT_VER,
                :SPEC_VALUE_N.FLOW,
                :SPEC_VALUE_N.OPER,
                :SPEC_VALUE_N.SPEC_REL_ID,
                :SPEC_VALUE_N.SPEC_REL_VER,
                :SPEC_VALUE_N.APPLY_START_TIME,
                :SPEC_VALUE_N.APPLY_END_TIME,
                :SPEC_VALUE_N.APPROVAL_FLAG, 
                :SPEC_VALUE_N.APPROVAL_USER_ID,
                :SPEC_VALUE_N.APPROVAL_TIME,
                :SPEC_VALUE_N.RELEASE_FLAG,
                :SPEC_VALUE_N.RELEASE_USER_ID,
                :SPEC_VALUE_N.RELEASE_TIME,
                :SPEC_VALUE_N.CHAR_ID,
                :SPEC_VALUE_N.CHAR_DESC,
                :SPEC_VALUE_N.VALUE_TYPE,
                :SPEC_VALUE_N.UNIT,
                :SPEC_VALUE_N.SPEC_REF_TYPE,
                :SPEC_VALUE_N.SPEC_TYPE,
                :SPEC_VALUE_N.VALID_TABLE,
                :SPEC_VALUE_N.TARGET_VALUE,
                :SPEC_VALUE_N.SPEC_OUT_COUNT,
                :SPEC_VALUE_N.UPPER_SPEC_LIMIT,
                :SPEC_VALUE_N.LOWER_SPEC_LIMIT,
                :SPEC_VALUE_N.UPPER_WARN_LIMIT,
                :SPEC_VALUE_N.LOWER_WARN_LIMIT,
                :SPEC_VALUE_N.SPEC_OUT_ALARM,
                :SPEC_VALUE_N.WARN_OUT_ALARM,
                :SPEC_VALUE_N.CUST_SPEC_TYPE,
                :SPEC_VALUE_N.CUST_VALID_TABLE,
                :SPEC_VALUE_N.CUST_TARGET_VALUE,
                :SPEC_VALUE_N.CUST_SPEC_OUT_COUNT,
                :SPEC_VALUE_N.CUST_UPPER_SPEC_LIMIT,
                :SPEC_VALUE_N.CUST_LOWER_SPEC_LIMIT,
                :SPEC_VALUE_N.CUST_UPPER_WARN_LIMIT,
                :SPEC_VALUE_N.CUST_LOWER_WARN_LIMIT,
                :SPEC_VALUE_N.CUST_SPEC_OUT_ALARM,
                :SPEC_VALUE_N.CUST_WARN_OUT_ALARM,
                :SPEC_VALUE_N.USE_CHAR_DIR,
                :SPEC_VALUE_N.TARGET_VALUE_WITH_DIR,
                :SPEC_VALUE_N.TARGET_VALUE_WITH_FILE,
                :SPEC_VALUE_N.TARGET_FILE_EXT,
                :SPEC_VALUE_N.USE_LATEST_FILE_VER,
                :SPEC_VALUE_N.CHAR_GRP_1,
                :SPEC_VALUE_N.CHAR_GRP_2,
                :SPEC_VALUE_N.CHAR_GRP_3,
                :SPEC_VALUE_N.CHAR_GRP_4,
                :SPEC_VALUE_N.CHAR_GRP_5,
                :SPEC_VALUE_N.CHAR_GRP_6,
                :SPEC_VALUE_N.CHAR_GRP_7,
                :SPEC_VALUE_N.CHAR_GRP_8,
                :SPEC_VALUE_N.CHAR_GRP_9,
                :SPEC_VALUE_N.CHAR_GRP_10,
                :SPEC_VALUE_N.CHAR_CMF_1,
                :SPEC_VALUE_N.CHAR_CMF_2,
                :SPEC_VALUE_N.CHAR_CMF_3,
                :SPEC_VALUE_N.CHAR_CMF_4,
                :SPEC_VALUE_N.CHAR_CMF_5,
                :SPEC_VALUE_N.CHAR_CMF_6,
                :SPEC_VALUE_N.CHAR_CMF_7,
                :SPEC_VALUE_N.CHAR_CMF_8,
                :SPEC_VALUE_N.CHAR_CMF_9,
                :SPEC_VALUE_N.CHAR_CMF_10;
            break;

        case 2:
            EXEC SQL FETCH DBC_SPEC_VALUE_CUR_2 INTO
                :SPEC_VALUE_N.SEQ,
                :SPEC_VALUE_N.FACTORY,
                :SPEC_VALUE_N.MAT_ID,
                :SPEC_VALUE_N.MAT_VER,
                :SPEC_VALUE_N.FLOW,
                :SPEC_VALUE_N.OPER,
                :SPEC_VALUE_N.SPEC_REL_ID,
                :SPEC_VALUE_N.SPEC_REL_VER,
                :SPEC_VALUE_N.APPLY_START_TIME,
                :SPEC_VALUE_N.APPLY_END_TIME,
                :SPEC_VALUE_N.APPROVAL_FLAG, 
                :SPEC_VALUE_N.APPROVAL_USER_ID,
                :SPEC_VALUE_N.APPROVAL_TIME,
                :SPEC_VALUE_N.RELEASE_FLAG,
                :SPEC_VALUE_N.RELEASE_USER_ID,
                :SPEC_VALUE_N.RELEASE_TIME,
                :SPEC_VALUE_N.CHAR_ID,
                :SPEC_VALUE_N.CHAR_DESC,
                :SPEC_VALUE_N.VALUE_TYPE,
                :SPEC_VALUE_N.UNIT,
                :SPEC_VALUE_N.SPEC_REF_TYPE,
                :SPEC_VALUE_N.SPEC_TYPE,
                :SPEC_VALUE_N.VALID_TABLE,
                :SPEC_VALUE_N.TARGET_VALUE,
                :SPEC_VALUE_N.SPEC_OUT_COUNT,
                :SPEC_VALUE_N.UPPER_SPEC_LIMIT,
                :SPEC_VALUE_N.LOWER_SPEC_LIMIT,
                :SPEC_VALUE_N.UPPER_WARN_LIMIT,
                :SPEC_VALUE_N.LOWER_WARN_LIMIT,
                :SPEC_VALUE_N.SPEC_OUT_ALARM,
                :SPEC_VALUE_N.WARN_OUT_ALARM,
                :SPEC_VALUE_N.CUST_SPEC_TYPE,
                :SPEC_VALUE_N.CUST_VALID_TABLE,
                :SPEC_VALUE_N.CUST_TARGET_VALUE,
                :SPEC_VALUE_N.CUST_SPEC_OUT_COUNT,
                :SPEC_VALUE_N.CUST_UPPER_SPEC_LIMIT,
                :SPEC_VALUE_N.CUST_LOWER_SPEC_LIMIT,
                :SPEC_VALUE_N.CUST_UPPER_WARN_LIMIT,
                :SPEC_VALUE_N.CUST_LOWER_WARN_LIMIT,
                :SPEC_VALUE_N.CUST_SPEC_OUT_ALARM,
                :SPEC_VALUE_N.CUST_WARN_OUT_ALARM,
                :SPEC_VALUE_N.USE_CHAR_DIR,
                :SPEC_VALUE_N.TARGET_VALUE_WITH_DIR,
                :SPEC_VALUE_N.TARGET_VALUE_WITH_FILE,
                :SPEC_VALUE_N.TARGET_FILE_EXT,
                :SPEC_VALUE_N.USE_LATEST_FILE_VER,
                :SPEC_VALUE_N.CHAR_GRP_1,
                :SPEC_VALUE_N.CHAR_GRP_2,
                :SPEC_VALUE_N.CHAR_GRP_3,
                :SPEC_VALUE_N.CHAR_GRP_4,
                :SPEC_VALUE_N.CHAR_GRP_5,
                :SPEC_VALUE_N.CHAR_GRP_6,
                :SPEC_VALUE_N.CHAR_GRP_7,
                :SPEC_VALUE_N.CHAR_GRP_8,
                :SPEC_VALUE_N.CHAR_GRP_9,
                :SPEC_VALUE_N.CHAR_GRP_10,
                :SPEC_VALUE_N.CHAR_CMF_1,
                :SPEC_VALUE_N.CHAR_CMF_2,
                :SPEC_VALUE_N.CHAR_CMF_3,
                :SPEC_VALUE_N.CHAR_CMF_4,
                :SPEC_VALUE_N.CHAR_CMF_5,
                :SPEC_VALUE_N.CHAR_CMF_6,
                :SPEC_VALUE_N.CHAR_CMF_7,
                :SPEC_VALUE_N.CHAR_CMF_8,
                :SPEC_VALUE_N.CHAR_CMF_9,
                :SPEC_VALUE_N.CHAR_CMF_10;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    if(DB_error_code == 0)
    {
        DBC_del_null_spec_value(&SPEC_VALUE_N, SPEC_VALUE);
    }
    DB_stop_query_timer("DBC_fetch_spec_value", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_spec_value(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_SPEC_VALUE_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_SPEC_VALUE_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_spec_value", sel_type);
}


/* Initialize Function */
void DBC_init_spec_value(struct VIEW_SPEC_VALUE_TAG *SPEC_VALUE)
{
    /* memset by Space */
    memset(SPEC_VALUE, ' ', sizeof(struct VIEW_SPEC_VALUE_TAG));
    
    SPEC_VALUE->SEQ = 0;
    SPEC_VALUE->MAT_VER = 0;
    SPEC_VALUE->SPEC_REL_VER = 0;
    SPEC_VALUE->SPEC_OUT_COUNT = 0;
    SPEC_VALUE->CUST_SPEC_OUT_COUNT = 0;

    SPEC_VALUE->MAT_VER_1 = 0;
    SPEC_VALUE->MAT_VER_2 = 0;
    SPEC_VALUE->MAT_VER_3 = 0;
    SPEC_VALUE->MAT_VER_4 = 0;
    SPEC_VALUE->MAT_VER_5 = 0;
}


/* Add Null Function */
void DBC_add_null_spec_value(struct VIEW_SPEC_VALUE_N_TAG *SPEC_VALUE_N, struct VIEW_SPEC_VALUE_TAG *SPEC_VALUE)
{
    /* memset by NULL */
    memset(SPEC_VALUE_N, '\0', sizeof(struct VIEW_SPEC_VALUE_N_TAG));
    
    SPEC_VALUE_N->SEQ = SPEC_VALUE->SEQ;
    MEMCPY_AN(SPEC_VALUE_N->FACTORY, SPEC_VALUE->FACTORY, sizeof(SPEC_VALUE->FACTORY));
    MEMCPY_AN(SPEC_VALUE_N->MAT_ID, SPEC_VALUE->MAT_ID, sizeof(SPEC_VALUE->MAT_ID));
    SPEC_VALUE_N->MAT_VER = SPEC_VALUE->MAT_VER;
    MEMCPY_AN(SPEC_VALUE_N->FLOW, SPEC_VALUE->FLOW, sizeof(SPEC_VALUE->FLOW));
