                make_valid_quote(ts1, SPEC_VALUE_N.CHAR_CMF_1);
                sprintf(sql + strlen(sql),      "AND CGC.CHAR_CMF_1 = '%s' ", ts1);
            }
            if(ISSPACE(SPEC_VALUE->CHAR_CMF_2, sizeof(SPEC_VALUE->CHAR_CMF_2)) == DB_FALSE)
            {
