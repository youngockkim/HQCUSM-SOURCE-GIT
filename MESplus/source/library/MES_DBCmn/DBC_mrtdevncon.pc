/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrtdevncon(int sel_type, struct MRTDEVNCON_TAG *MRTDEVNCON)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRTDEVNCON_N_TAG MRTDEVNCON_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrtdevncon(&MRTDEVNCON_N, MRTDEVNCON);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRTDEVNCON_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    SERVICE_NAME,
                    SERVICE_SEQ,
                    SERVICE_DESC,
                    CHK_MEMBER,
                    CHK_FLAG,
                    CHK_STS,
                    CHK_TBL,
                    CHK_SQL,
                    DEPENDENT_SEQ,
                    DEPENDENT_COMBINATION,
                    ACTION_ARRAY_1,
                    ACTION_ARRAY_2,
                    ACTION_MEMBER_1,
                    ACTION_MEMBER_2,
                    ACTION_MEMBER_3,
                    ACTION_MEMBER_4,
                    ACTION_FLAG,
                    CUSTOM_ACTION_KEY,
                    UNSELECT_CAPABLE_ONLY_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRTDEVNCON
                WHERE FACTORY = :MRTDEVNCON_N.FACTORY
                    AND (SERVICE_NAME > :MRTDEVNCON_N.SERVICE_NAME
                    OR (SERVICE_NAME = :MRTDEVNCON_N.SERVICE_NAME
                    AND SERVICE_SEQ >= :MRTDEVNCON_N.SERVICE_SEQ))
                ORDER BY SERVICE_NAME ASC,
                    SERVICE_SEQ ASC;
            EXEC SQL OPEN DBC_MRTDEVNCON_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MRTDEVNCON_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    SERVICE_NAME,
                    SERVICE_SEQ,
                    SERVICE_DESC,
                    CHK_MEMBER,
                    CHK_FLAG,
                    CHK_STS,
                    CHK_TBL,
                    CHK_SQL,
                    DEPENDENT_SEQ,
                    DEPENDENT_COMBINATION,
                    ACTION_ARRAY_1,
                    ACTION_ARRAY_2,
                    ACTION_MEMBER_1,
                    ACTION_MEMBER_2,
                    ACTION_MEMBER_3,
                    ACTION_MEMBER_4,
                    ACTION_FLAG,
                    CUSTOM_ACTION_KEY,
                    UNSELECT_CAPABLE_ONLY_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRTDEVNCON
                WHERE FACTORY = :MRTDEVNCON_N.FACTORY
                    AND SERVICE_NAME = :MRTDEVNCON_N.SERVICE_NAME
                ORDER BY 
                    SERVICE_SEQ ASC;
            EXEC SQL OPEN DBC_MRTDEVNCON_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrtdevncon", sel_type);
}


