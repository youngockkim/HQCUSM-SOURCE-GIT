    MEMCPY_AN(MRTDEVNCON_N->CREATE_TIME, MRTDEVNCON->CREATE_TIME, sizeof(MRTDEVNCON->CREATE_TIME));
    MEMCPY_AN(MRTDEVNCON_N->UPDATE_USER_ID, MRTDEVNCON->UPDATE_USER_ID, sizeof(MRTDEVNCON->UPDATE_USER_ID));
    MEMCPY_AN(MRTDEVNCON_N->UPDATE_TIME, MRTDEVNCON->UPDATE_TIME, sizeof(MRTDEVNCON->UPDATE_TIME));
}


