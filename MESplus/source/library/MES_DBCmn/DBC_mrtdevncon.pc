    MEMCPY_AN(MRTDEVNCON_N->CHK_STS, MRTDEVNCON->CHK_STS, sizeof(MRTDEVNCON->CHK_STS));
    MEMCPY_AN(MRTDEVNCON_N->CHK_TBL, MRTDEVNCON->CHK_TBL, sizeof(MRTDEVNCON->CHK_TBL));
    MEMCPY_AN(MRTDEVNCON_N->CHK_SQL, MRTDEVNCON->CHK_SQL, sizeof(MRTDEVNCON->CHK_SQL));
