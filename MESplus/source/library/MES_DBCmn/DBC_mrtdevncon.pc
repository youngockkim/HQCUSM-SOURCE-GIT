    MEMCPY_DN(MRTDEVNCON->ACTION_MEMBER_1, MRTDEVNCON_N->ACTION_MEMBER_1, sizeof(MRTDEVNCON->ACTION_MEMBER_1));
    MEMCPY_DN(MRTDEVNCON->ACTION_MEMBER_2, MRTDEVNCON_N->ACTION_MEMBER_2, sizeof(MRTDEVNCON->ACTION_MEMBER_2));
    MEMCPY_DN(MRTDEVNCON->ACTION_MEMBER_3, MRTDEVNCON_N->ACTION_MEMBER_3, sizeof(MRTDEVNCON->ACTION_MEMBER_3));
    MEMCPY_DN(MRTDEVNCON->ACTION_MEMBER_4, MRTDEVNCON_N->ACTION_MEMBER_4, sizeof(MRTDEVNCON->ACTION_MEMBER_4));
    MRTDEVNCON->ACTION_FLAG = MRTDEVNCON_N->ACTION_FLAG[0];
