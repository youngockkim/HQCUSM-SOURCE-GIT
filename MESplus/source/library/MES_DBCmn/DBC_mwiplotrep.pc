                    END_CMF_20,
                    REPAIR_OPER,
                    REPAIR_RES_ID,
                    REPAIR_CODE_1,
                    REPAIR_CODE_2,
                    REPAIR_CODE_3,
                    REPAIR_COUNT,
                    REPAIR_RET_OPER,
                    REPAIR_USER_ID,
                    REPAIR_COMMENT,
                    RESULT_CODE_1,
                    RESULT_CODE_2,
                    RESULT_CODE_3,
