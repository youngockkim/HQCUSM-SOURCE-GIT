                    USER_COMMENT_3 = :MWIPLOTREP_N.USER_COMMENT_3
                WHERE LOT_ID = :MWIPLOTREP_N.LOT_ID
                    AND HIST_SEQ = :MWIPLOTREP_N.HIST_SEQ;
            break;
            
        case 2:
            EXEC SQL UPDATE MWIPLOTREP SET
                    HIST_DEL_FLAG = :MWIPLOTREP_N.HIST_DEL_FLAG
                WHERE LOT_ID = :MWIPLOTREP_N.LOT_ID
                    AND HIST_SEQ = :MWIPLOTREP_N.HIST_SEQ;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mwiplotrep", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwiplotrep(int sel_type, struct MWIPLOTREP_TAG *MWIPLOTREP)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTREP_N_TAG MWIPLOTREP_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplotrep(&MWIPLOTREP_N, MWIPLOTREP);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPLOTREP_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    REPAIR_TRAN_TIME,
                    REPAIR_END_TRAN_TIME,
                    HIST_DEL_FLAG,
                    REPAIR_END_HIST_SEQ,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_ID,
                    CAUSE_FLOW,
                    CAUSE_OPER,
                    CAUSE_RES_ID,
                    IN_QTY_1,
                    IN_QTY_2,
                    IN_QTY_3,
                    OUT_QTY_1,
                    OUT_QTY_2,
                    OUT_QTY_3,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CMF_11,
                    CMF_12,
                    CMF_13,
                    CMF_14,
                    CMF_15,
                    CMF_16,
                    CMF_17,
                    CMF_18,
                    CMF_19,
                    CMF_20,
                    END_CMF_1,
                    END_CMF_2,
                    END_CMF_3,
                    END_CMF_4,
                    END_CMF_5,
                    END_CMF_6,
                    END_CMF_7,
                    END_CMF_8,
                    END_CMF_9,
                    END_CMF_10,
                    END_CMF_11,
                    END_CMF_12,
                    END_CMF_13,
                    END_CMF_14,
                    END_CMF_15,
                    END_CMF_16,
                    END_CMF_17,
                    END_CMF_18,
                    END_CMF_19,
                    END_CMF_20,
                    REPAIR_OPER,
                    REPAIR_RES_ID,
                    REPAIR_CODE_1,
                    REPAIR_CODE_2,
                    REPAIR_CODE_3,
                    REPAIR_COUNT,
                    REPAIR_RET_OPER,
                    REPAIR_USER_ID,
                    REPAIR_COMMENT,
                    RESULT_CODE_1,
                    RESULT_CODE_2,
                    RESULT_CODE_3,
                    ACTION_CODE_1,
                    ACTION_CODE_2,
                    ACTION_CODE_3,
                    ACTION_USER_ID,
                    ACTION_USER_COMMENT,
                    USER_ID_1,
                    USER_TIME_1,
                    USER_COMMENT_1,
                    USER_ID_2,
                    USER_TIME_2,
                    USER_COMMENT_2,
                    USER_ID_3,
                    USER_TIME_3,
                    USER_COMMENT_3
                FROM MWIPLOTREP
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MWIPLOTREP_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwiplotrep", sel_type);
}


