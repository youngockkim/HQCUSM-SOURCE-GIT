                    HIST_DEL_FLAG,
                    HIST_DEL_TIME,
                    HIST_DEL_USER_ID,
                    HIST_DEL_COMMENT,
                    PROCESS_FLAG
                FROM MTMPLOTHIS
				WHERE PROCESS_FLAG =:MTMPLOTHIS_N.PROCESS_FLAG
				AND   CM_KEY_1 IN ( 'MDL04','MDL05','MDL06','MDL07' )
                ORDER BY TABLE_UPDATE_SEQ ASC;
            EXEC SQL OPEN DBC_MTMPLOTHIS_CUR_103;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mtmplothis", sel_type);
}


