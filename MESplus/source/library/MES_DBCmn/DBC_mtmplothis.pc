							WHEN CREATE_CODE = 'STRING' 
								 AND (SUBSTR(LOT_ID, 5, 1) = 'R' OR SUBSTR(LOT_ID, 5, 1) = 'O')
							THEN 'M2000_OK'
							ELSE OPER 
