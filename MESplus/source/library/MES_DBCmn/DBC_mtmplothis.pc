            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mtmplothis(&MTMPLOTHIS_N, MTMPLOTHIS);
    }
    DB_stop_query_timer("DBC_fetch_mtmplothis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mtmplothis(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MTMPLOTHIS_CUR_1;
            break;

		case 101:
            EXEC SQL CLOSE DBC_MTMPLOTHIS_CUR_101;
            break;

		case 102:
            EXEC SQL CLOSE DBC_MTMPLOTHIS_CUR_102;
            break;

		case 103:
            EXEC SQL CLOSE DBC_MTMPLOTHIS_CUR_103;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mtmplothis", sel_type);
}


/* Initialize Function */
