                    HIST_DEL_COMMENT,
                    PROCESS_FLAG
                FROM MTMPLOTHIS
				WHERE PROCESS_FLAG =:MTMPLOTHIS_N.PROCESS_FLAG
				AND   CM_KEY_1 NOT IN ( 'MDL04','MDL05','MDL06','MDL07' )
                ORDER BY TABLE_UPDATE_SEQ ASC;
            EXEC SQL OPEN DBC_MTMPLOTHIS_CUR_102;
            break;

		case 103:
            EXEC SQL DECLARE DBC_MTMPLOTHIS_CUR_103 CURSOR FOR
                SELECT 
                    TABLE_UPDATE_SEQ,
                    CM_KEY_1,
                    CM_KEY_2,
                    CM_KEY_3,
                    CM_KEY_4,
                    CM_KEY_5,
