/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mpoplbldex(int sel_type, struct MPOPLBLDEX_TAG *MPOPLBLDEX)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MPOPLBLDEX_N_TAG MPOPLBLDEX_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mpoplbldex(&MPOPLBLDEX_N, MPOPLBLDEX);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MPOPLBLDEX_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LABEL_ID,
                    SEQ_NUM,
                    DGN_CMF_1,
                    DGN_CMF_2,
                    DGN_CMF_3,
                    DGN_CMF_4,
                    DGN_CMF_5,
                    DGN_CMF_6,
                    DGN_CMF_7,
                    DGN_CMF_8,
                    DGN_CMF_9,
