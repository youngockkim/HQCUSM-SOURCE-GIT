/* Add Null Function */
void DBC_add_null_mpoplbldex(struct MPOPLBLDEX_N_TAG *MPOPLBLDEX_N, struct MPOPLBLDEX_TAG *MPOPLBLDEX)
{
    /* memset by NULL */
    memset(MPOPLBLDEX_N, '\0', sizeof(struct MPOPLBLDEX_N_TAG));
    
    MEMCPY_AN(MPOPLBLDEX_N->FACTORY, MPOPLBLDEX->FACTORY, sizeof(MPOPLBLDEX->FACTORY));
