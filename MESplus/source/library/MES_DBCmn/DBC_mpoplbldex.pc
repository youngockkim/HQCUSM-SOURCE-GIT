                    DGN_CMF_25,
                    DGN_CMF_26,
                    DGN_CMF_27,
                    DGN_CMF_28,
                    DGN_CMF_29,
                    DGN_CMF_30
                FROM MPOPLBLDEX
                ORDER BY FACTORY ASC,
                    LABEL_ID ASC,
                    SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MPOPLBLDEX_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mpoplbldex", sel_type);
}


