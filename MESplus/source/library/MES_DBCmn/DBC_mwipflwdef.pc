/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipflwdef(int sel_type, struct MWIPFLWDEF_TAG *MWIPFLWDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPFLWDEF_N_TAG MWIPFLWDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipflwdef(&MWIPFLWDEF_N, MWIPFLWDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            if(strcmp(MWIPFLWDEF_N.FLOW_DESC, " ") == 0)
                MWIPFLWDEF_N.FLOW_DESC[0] = '%';
            else
                strcat(MWIPFLWDEF_N.FLOW_DESC, "%");
                
            EXEC SQL DECLARE DBC_MWIPFLWDEF_CUR_1 CURSOR FOR
                SELECT FLOW, FLOW_DESC, FLOW_SHORT_DESC
                FROM MWIPFLWDEF
                WHERE FACTORY = :MWIPFLWDEF_N.FACTORY
                AND FLOW >= :MWIPFLWDEF_N.FLOW
                AND FLOW LIKE :MWIPFLWDEF_N.FLOW_DESC
                ORDER BY FLOW ASC;
            EXEC SQL OPEN DBC_MWIPFLWDEF_CUR_1;
            break;
        
        case 2:
            if(strcmp(MWIPFLWDEF_N.FLOW_DESC, " ") == 0)
                MWIPFLWDEF_N.FLOW_DESC[0] = '%';
            else
                strcat(MWIPFLWDEF_N.FLOW_DESC, "%");
                
            EXEC SQL DECLARE DBC_MWIPFLWDEF_CUR_2 CURSOR FOR
                SELECT FD.FLOW, FD.FLOW_DESC, FD.FLOW_SHORT_DESC, TO_CHAR(MF.FLOW_SEQ_NUM)
                FROM MWIPMATFLW MF, MWIPFLWDEF FD
                WHERE MF.FACTORY = :MWIPFLWDEF_N.FACTORY
                AND MF.MAT_ID = :MWIPFLWDEF_N.FLOW_CMF_1
                AND MF.MAT_VER = TO_NUMBER(:MWIPFLWDEF_N.FLOW_CMF_2)
                AND MF.FLOW_SEQ_NUM >= TO_NUMBER(:MWIPFLWDEF_N.FLOW_CMF_3)
                AND MF.FLOW LIKE :MWIPFLWDEF_N.FLOW_DESC
                AND MF.FACTORY = FD.FACTORY
                AND MF.FLOW = FD.FLOW
                ORDER BY MF.FLOW_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPFLWDEF_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MWIPFLWDEF_CUR_3 CURSOR FOR
                SELECT
                           FD.FACTORY,
                           FD.FLOW,
                           FD.FLOW_DESC,
                           FD.FLOW_GRP_1,
                           FD.FLOW_GRP_2,
                           FD.FLOW_GRP_3,
                           FD.FLOW_GRP_4,
                           FD.FLOW_GRP_5,
                           FD.FLOW_GRP_6,
                           FD.FLOW_GRP_7,
                           FD.FLOW_GRP_8,
                           FD.FLOW_GRP_9,
                           FD.FLOW_GRP_10,
                           FD.FLOW_CMF_1,
                           FD.FLOW_CMF_2,
                           FD.FLOW_CMF_3,
                           FD.FLOW_CMF_4,
                           FD.FLOW_CMF_5,
                           FD.FLOW_CMF_6,
                           FD.FLOW_CMF_7,
                           FD.FLOW_CMF_8,
                           FD.FLOW_CMF_9,
                           FD.FLOW_CMF_10,
                           FD.FLOW_CMF_11,
                           FD.FLOW_CMF_12,
                           FD.FLOW_CMF_13,
                           FD.FLOW_CMF_14,
                           FD.FLOW_CMF_15,
                           FD.FLOW_CMF_16,
                           FD.FLOW_CMF_17,
                           FD.FLOW_CMF_18,
                           FD.FLOW_CMF_19,
                           FD.FLOW_CMF_20,
                           FD.FIRST_OPER,
                           FD.LAST_OPER,
                           FD.CREATE_USER_ID,
                           FD.CREATE_TIME,
                           FD.UPDATE_USER_ID,
                           FD.UPDATE_TIME,
						   FD.FLOW_SHORT_DESC
                FROM MWIPFLWOPR FO, MWIPFLWDEF FD 
                WHERE FO.FACTORY = :MWIPFLWDEF_N.FACTORY
                AND FO.FACTORY = FD.FACTORY
                AND FO.OPER = :MWIPFLWDEF_N.FIRST_OPER
                AND FO.FLOW = FD.FLOW
                AND FO.FLOW >= :MWIPFLWDEF_N.FLOW
                ORDER BY FD.FLOW;
            EXEC SQL OPEN DBC_MWIPFLWDEF_CUR_3;
            break;            

        case 4:
            if(strcmp(MWIPFLWDEF_N.FLOW_DESC, " ") == 0)
                MWIPFLWDEF_N.FLOW_DESC[0] = '%';
            else
                strcat(MWIPFLWDEF_N.FLOW_DESC, "%");
                
            EXEC SQL DECLARE DBC_MWIPFLWDEF_CUR_4 CURSOR FOR
                SELECT 
                    FLOW,
                    FLOW_DESC,
                    FLOW_SHORT_DESC,
                    TO_CHAR(FLOW_SEQ)
                FROM (
                    SELECT FD.FLOW, FD.FLOW_DESC, FD.FLOW_SHORT_DESC, MIN(MF.FLOW_SEQ_NUM) FLOW_SEQ
                    FROM MWIPMATFLW MF, MWIPFLWDEF FD
                    WHERE MF.FACTORY = :MWIPFLWDEF_N.FACTORY
                        AND MF.MAT_ID = :MWIPFLWDEF_N.FLOW_CMF_1
                        AND MF.MAT_VER = TO_NUMBER(:MWIPFLWDEF_N.FLOW_CMF_2)
                        AND MF.FLOW LIKE :MWIPFLWDEF_N.FLOW_DESC
                        AND MF.FACTORY = FD.FACTORY
                        AND MF.FLOW = FD.FLOW
                    GROUP BY FD.FLOW, FD.FLOW_DESC, FD.FLOW_SHORT_DESC
                )
                WHERE FLOW_SEQ >= TO_NUMBER(:MWIPFLWDEF_N.FLOW_CMF_3)
                ORDER BY FLOW_SEQ ASC;
            EXEC SQL OPEN DBC_MWIPFLWDEF_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipflwdef", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mwipflwdef(int sel_type, struct MWIPFLWDEF_TAG *MWIPFLWDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPFLWDEF_N_TAG MWIPFLWDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MWIPFLWDEF_CUR_1 INTO :MWIPFLWDEF_N.FLOW, :MWIPFLWDEF_N.FLOW_DESC, :MWIPFLWDEF_N.FLOW_SHORT_DESC;
            break;

        case 2:
            EXEC SQL FETCH DBC_MWIPFLWDEF_CUR_2 INTO :MWIPFLWDEF_N.FLOW, :MWIPFLWDEF_N.FLOW_DESC, :MWIPFLWDEF_N.FLOW_SHORT_DESC, :MWIPFLWDEF_N.FLOW_CMF_1;
            break;

        case 3:
            EXEC SQL FETCH DBC_MWIPFLWDEF_CUR_3 INTO 
                                                    :MWIPFLWDEF_N.FACTORY,
                                                    :MWIPFLWDEF_N.FLOW,
                                                    :MWIPFLWDEF_N.FLOW_DESC,
                                                    :MWIPFLWDEF_N.FLOW_GRP_1,
                                                    :MWIPFLWDEF_N.FLOW_GRP_2,
                                                    :MWIPFLWDEF_N.FLOW_GRP_3,
                                                    :MWIPFLWDEF_N.FLOW_GRP_4,
                                                    :MWIPFLWDEF_N.FLOW_GRP_5,
                                                    :MWIPFLWDEF_N.FLOW_GRP_6,
                                                    :MWIPFLWDEF_N.FLOW_GRP_7,
                                                    :MWIPFLWDEF_N.FLOW_GRP_8,
                                                    :MWIPFLWDEF_N.FLOW_GRP_9,
                                                    :MWIPFLWDEF_N.FLOW_GRP_10,
                                                    :MWIPFLWDEF_N.FLOW_CMF_1,
                                                    :MWIPFLWDEF_N.FLOW_CMF_2,
                                                    :MWIPFLWDEF_N.FLOW_CMF_3,
                                                    :MWIPFLWDEF_N.FLOW_CMF_4,
                                                    :MWIPFLWDEF_N.FLOW_CMF_5,
                                                    :MWIPFLWDEF_N.FLOW_CMF_6,
                                                    :MWIPFLWDEF_N.FLOW_CMF_7,
                                                    :MWIPFLWDEF_N.FLOW_CMF_8,
                                                    :MWIPFLWDEF_N.FLOW_CMF_9,
                                                    :MWIPFLWDEF_N.FLOW_CMF_10,
                                                    :MWIPFLWDEF_N.FLOW_CMF_11,
                                                    :MWIPFLWDEF_N.FLOW_CMF_12,
                                                    :MWIPFLWDEF_N.FLOW_CMF_13,
                                                    :MWIPFLWDEF_N.FLOW_CMF_14,
                                                    :MWIPFLWDEF_N.FLOW_CMF_15,
                                                    :MWIPFLWDEF_N.FLOW_CMF_16,
                                                    :MWIPFLWDEF_N.FLOW_CMF_17,
                                                    :MWIPFLWDEF_N.FLOW_CMF_18,
                                                    :MWIPFLWDEF_N.FLOW_CMF_19,
                                                    :MWIPFLWDEF_N.FLOW_CMF_20,
                                                    :MWIPFLWDEF_N.FIRST_OPER,
                                                    :MWIPFLWDEF_N.LAST_OPER,
                                                    :MWIPFLWDEF_N.CREATE_USER_ID,
                                                    :MWIPFLWDEF_N.CREATE_TIME,
                                                    :MWIPFLWDEF_N.UPDATE_USER_ID,
                                                    :MWIPFLWDEF_N.UPDATE_TIME,
													:MWIPFLWDEF_N.FLOW_SHORT_DESC;
            break;
        
        case 4:
            EXEC SQL FETCH DBC_MWIPFLWDEF_CUR_4 INTO :MWIPFLWDEF_N.FLOW, :MWIPFLWDEF_N.FLOW_DESC, :MWIPFLWDEF_N.FLOW_SHORT_DESC, :MWIPFLWDEF_N.FLOW_CMF_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwipflwdef(&MWIPFLWDEF_N, MWIPFLWDEF);
    }
    DB_stop_query_timer("DBC_fetch_mwipflwdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwipflwdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPFLWDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWIPFLWDEF_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MWIPFLWDEF_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MWIPFLWDEF_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipflwdef", sel_type);
}


/* Initialize Function */
void DBC_init_mwipflwdef(struct MWIPFLWDEF_TAG *MWIPFLWDEF)
{
    /* memset by Space */
    memset(MWIPFLWDEF, ' ', sizeof(struct MWIPFLWDEF_TAG));
    
}


/* Add Null Function */
