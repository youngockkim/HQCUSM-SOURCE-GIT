/* Del Null Function */
void DBC_del_null_mwipflwdef(struct MWIPFLWDEF_N_TAG *MWIPFLWDEF_N, struct MWIPFLWDEF_TAG *MWIPFLWDEF)
{
    MEMCPY_DN(MWIPFLWDEF->FACTORY, MWIPFLWDEF_N->FACTORY, sizeof(MWIPFLWDEF->FACTORY));
    MEMCPY_DN(MWIPFLWDEF->FLOW, MWIPFLWDEF_N->FLOW, sizeof(MWIPFLWDEF->FLOW));
    MEMCPY_DN(MWIPFLWDEF->FLOW_DESC, MWIPFLWDEF_N->FLOW_DESC, sizeof(MWIPFLWDEF->FLOW_DESC));
    MEMCPY_DN(MWIPFLWDEF->FLOW_GRP_1, MWIPFLWDEF_N->FLOW_GRP_1, sizeof(MWIPFLWDEF->FLOW_GRP_1));
