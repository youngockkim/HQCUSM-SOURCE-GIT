/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipmhdsts(int sel_type, struct MWIPMHDSTS_TAG *MWIPMHDSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPMHDSTS_N_TAG MWIPMHDSTS_N;
    EXEC SQL END DECLARE SECTION;

