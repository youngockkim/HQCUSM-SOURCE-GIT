    DBC_add_null_mwipmhdsts(&MWIPMHDSTS_N, MWIPMHDSTS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPMHDSTS_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HOLD_CODE,
                    FACTORY,
                    HOLD_PASSWORD,
                    HOLD_PRV_GRP_ID,
                    HIST_SEQ,
                    LAST_TRAN_TIME
                FROM MWIPMHDSTS
                WHERE LOT_ID = :MWIPMHDSTS_N.LOT_ID
                ORDER BY HIST_SEQ DESC;
            EXEC SQL OPEN DBC_MWIPMHDSTS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipmhdsts", sel_type);
}


