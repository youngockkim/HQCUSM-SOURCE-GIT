                :MSPMRELCHR_N.TARGET_FILE_EXT,
                :MSPMRELCHR_N.USE_LATEST_FILE_VER;
            break;

        case 2:
            EXEC SQL FETCH DBC_MSPMRELCHR_CUR_2 INTO
                :MSPMRELCHR_N.SPEC_REL_ID,
