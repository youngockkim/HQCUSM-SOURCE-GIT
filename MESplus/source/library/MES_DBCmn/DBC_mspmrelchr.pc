    MEMCPY_AN(MSPMRELCHR_N->CUST_LOWER_SPEC_LIMIT, MSPMRELCHR->CUST_LOWER_SPEC_LIMIT, sizeof(MSPMRELCHR->CUST_LOWER_SPEC_LIMIT));
