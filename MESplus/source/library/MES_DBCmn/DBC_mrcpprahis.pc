/* Add Null Function */
void DBC_add_null_mrcpprahis(struct MRCPPRAHIS_N_TAG *MRCPPRAHIS_N, struct MRCPPRAHIS_TAG *MRCPPRAHIS)
{
    /* memset by NULL */
    memset(MRCPPRAHIS_N, '\0', sizeof(struct MRCPPRAHIS_N_TAG));
    
    MEMCPY_AN(MRCPPRAHIS_N->LOT_ID, MRCPPRAHIS->LOT_ID, sizeof(MRCPPRAHIS->LOT_ID));
    MRCPPRAHIS_N->HIST_SEQ = MRCPPRAHIS->HIST_SEQ;
    MEMCPY_AN(MRCPPRAHIS_N->TRAN_TIME, MRCPPRAHIS->TRAN_TIME, sizeof(MRCPPRAHIS->TRAN_TIME));
    MEMCPY_AN(MRCPPRAHIS_N->TRAN_CODE, MRCPPRAHIS->TRAN_CODE, sizeof(MRCPPRAHIS->TRAN_CODE));
    MEMCPY_AN(MRCPPRAHIS_N->FACTORY, MRCPPRAHIS->FACTORY, sizeof(MRCPPRAHIS->FACTORY));
    MEMCPY_AN(MRCPPRAHIS_N->RES_ID, MRCPPRAHIS->RES_ID, sizeof(MRCPPRAHIS->RES_ID));
    MEMCPY_AN(MRCPPRAHIS_N->SUBRES_ID, MRCPPRAHIS->SUBRES_ID, sizeof(MRCPPRAHIS->SUBRES_ID));
    MEMCPY_AN(MRCPPRAHIS_N->RECIPE, MRCPPRAHIS->RECIPE, sizeof(MRCPPRAHIS->RECIPE));
    MRCPPRAHIS_N->RECIPE_VERSION = MRCPPRAHIS->RECIPE_VERSION;
    MRCPPRAHIS_N->PARA_SEQ = MRCPPRAHIS->PARA_SEQ;
    MEMCPY_AN(MRCPPRAHIS_N->PARA_ID, MRCPPRAHIS->PARA_ID, sizeof(MRCPPRAHIS->PARA_ID));
    MEMCPY_AN(MRCPPRAHIS_N->PARA_VALUE, MRCPPRAHIS->PARA_VALUE, sizeof(MRCPPRAHIS->PARA_VALUE));
    MEMCPY_AN(MRCPPRAHIS_N->PARA_DESC, MRCPPRAHIS->PARA_DESC, sizeof(MRCPPRAHIS->PARA_DESC));
    MRCPPRAHIS_N->MODIFY_FLAG[0] = MRCPPRAHIS->MODIFY_FLAG;
    MEMCPY_AN(MRCPPRAHIS_N->UPDATE_USER_ID, MRCPPRAHIS->UPDATE_USER_ID, sizeof(MRCPPRAHIS->UPDATE_USER_ID));
    MEMCPY_AN(MRCPPRAHIS_N->UPDATE_TIME, MRCPPRAHIS->UPDATE_TIME, sizeof(MRCPPRAHIS->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mrcpprahis(struct MRCPPRAHIS_N_TAG *MRCPPRAHIS_N, struct MRCPPRAHIS_TAG *MRCPPRAHIS)
{
    MEMCPY_DN(MRCPPRAHIS->LOT_ID, MRCPPRAHIS_N->LOT_ID, sizeof(MRCPPRAHIS->LOT_ID));
    MRCPPRAHIS->HIST_SEQ = MRCPPRAHIS_N->HIST_SEQ;
    MEMCPY_DN(MRCPPRAHIS->TRAN_TIME, MRCPPRAHIS_N->TRAN_TIME, sizeof(MRCPPRAHIS->TRAN_TIME));
    MEMCPY_DN(MRCPPRAHIS->TRAN_CODE, MRCPPRAHIS_N->TRAN_CODE, sizeof(MRCPPRAHIS->TRAN_CODE));
    MEMCPY_DN(MRCPPRAHIS->FACTORY, MRCPPRAHIS_N->FACTORY, sizeof(MRCPPRAHIS->FACTORY));
    MEMCPY_DN(MRCPPRAHIS->RES_ID, MRCPPRAHIS_N->RES_ID, sizeof(MRCPPRAHIS->RES_ID));
    MEMCPY_DN(MRCPPRAHIS->SUBRES_ID, MRCPPRAHIS_N->SUBRES_ID, sizeof(MRCPPRAHIS->SUBRES_ID));
    MEMCPY_DN(MRCPPRAHIS->RECIPE, MRCPPRAHIS_N->RECIPE, sizeof(MRCPPRAHIS->RECIPE));
    MRCPPRAHIS->RECIPE_VERSION = MRCPPRAHIS_N->RECIPE_VERSION;
    MRCPPRAHIS->PARA_SEQ = MRCPPRAHIS_N->PARA_SEQ;
    MEMCPY_DN(MRCPPRAHIS->PARA_ID, MRCPPRAHIS_N->PARA_ID, sizeof(MRCPPRAHIS->PARA_ID));
    MEMCPY_DN(MRCPPRAHIS->PARA_VALUE, MRCPPRAHIS_N->PARA_VALUE, sizeof(MRCPPRAHIS->PARA_VALUE));
    MEMCPY_DN(MRCPPRAHIS->PARA_DESC, MRCPPRAHIS_N->PARA_DESC, sizeof(MRCPPRAHIS->PARA_DESC));
    MRCPPRAHIS->MODIFY_FLAG = MRCPPRAHIS_N->MODIFY_FLAG[0];
    MEMCPY_DN(MRCPPRAHIS->UPDATE_USER_ID, MRCPPRAHIS_N->UPDATE_USER_ID, sizeof(MRCPPRAHIS->UPDATE_USER_ID));
    MEMCPY_DN(MRCPPRAHIS->UPDATE_TIME, MRCPPRAHIS_N->UPDATE_TIME, sizeof(MRCPPRAHIS->UPDATE_TIME));
}


