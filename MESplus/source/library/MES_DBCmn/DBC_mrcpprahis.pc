/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrcpprahis(int sel_type, struct MRCPPRAHIS_TAG *MRCPPRAHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRCPPRAHIS_N_TAG MRCPPRAHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrcpprahis(&MRCPPRAHIS_N, MRCPPRAHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            /* 揶쏆늿? hist_seq??揶쏆늾??野껋럩??揶쎛??筌ㅼ뮄????怨쀬뵠????揶쎛筌왖????ㅻ뼄 */
            EXEC SQL DECLARE DBC_MRCPPRAHIS_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    TRAN_CODE,
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    RECIPE,
                    RECIPE_VERSION,
                    PARA_SEQ,
                    PARA_ID,
                    PARA_VALUE,
                    PARA_DESC,
                    MODIFY_FLAG,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRCPPRAHIS
                WHERE  LOT_ID = :MRCPPRAHIS_N.LOT_ID
                   AND TRAN_TIME = (SELECT NVL(MAX(TRAN_TIME), '00000000000000') FROM MRCPPRAHIS
                                    WHERE LOT_ID = :MRCPPRAHIS_N.LOT_ID                                    
                                      AND HIST_SEQ = :MRCPPRAHIS_N.HIST_SEQ
                                   )
                ORDER BY PARA_SEQ ASC;
            EXEC SQL OPEN DBC_MRCPPRAHIS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrcpprahis", sel_type);
}


