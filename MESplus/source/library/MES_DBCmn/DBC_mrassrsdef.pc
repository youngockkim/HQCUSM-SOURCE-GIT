                    AND SUBRES_ID >= :MRASSRSDEF_N.SUBRES_ID
                ORDER BY SUBRES_ID ASC;
            EXEC SQL OPEN DBC_MRASSRSDEF_CUR_5;
            break;
           
		case 101:
            EXEC SQL DECLARE DBC_MRASSRSDEF_CUR_101 CURSOR FOR
                SELECT 
                    A.FACTORY,
                    A.RES_ID,
                    DECODE(NVL(B.SUBRES_ID, ' '), ' ', A.RES_ID, B.SUBRES_ID) SUBRES_ID,
                    DECODE(NVL(B.SUBRES_ID, ' '), ' ', A.RES_STS_7, B.SUBRES_STS_7) SUBRES_STS_7
                 FROM MRASRESDEF A, MRASSRSDEF B
                WHERE A.FACTORY = :MRASSRSDEF_N.FACTORY
                    AND A.FACTORY = B.FACTORY(+)
					AND A.RES_ID = B.RES_ID(+)
					AND A.RES_CMF_10 = 'Y'
                ORDER BY A.RES_ID, B.SUBRES_ID ASC;
            EXEC SQL OPEN DBC_MRASSRSDEF_CUR_101;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrassrsdef", sel_type);
}


