/* SQL UPDATE Function */
void DBC_update_mwiplothis(int sel_type, struct MWIPLOTHIS_TAG *MWIPLOTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTHIS_N_TAG MWIPLOTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplothis(&MWIPLOTHIS_N, MWIPLOTHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MWIPLOTHIS SET
                    TRAN_TIME = :MWIPLOTHIS_N.TRAN_TIME,
                    SYS_TRAN_TIME = :MWIPLOTHIS_N.SYS_TRAN_TIME,
                    TRAN_CODE = :MWIPLOTHIS_N.TRAN_CODE,
                    LOT_DESC = :MWIPLOTHIS_N.LOT_DESC,
