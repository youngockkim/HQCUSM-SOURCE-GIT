                    TRAN_CMF_18 = :MWIPLOTHIS_N.TRAN_CMF_18,
                    TRAN_CMF_19 = :MWIPLOTHIS_N.TRAN_CMF_19,
                    TRAN_CMF_20 = :MWIPLOTHIS_N.TRAN_CMF_20,
                    TRAN_USER_ID = :MWIPLOTHIS_N.TRAN_USER_ID,
                    TRAN_COMMENT = :MWIPLOTHIS_N.TRAN_COMMENT,
                    PREV_ACTIVE_HIST_SEQ = :MWIPLOTHIS_N.PREV_ACTIVE_HIST_SEQ,
                    MULTI_TR_KEY = :MWIPLOTHIS_N.MULTI_TR_KEY,
                    MULTI_TR_SEQ = :MWIPLOTHIS_N.MULTI_TR_SEQ,
                    EXT_HIST_SEQ = :MWIPLOTHIS_N.EXT_HIST_SEQ,
                    HIST_DEL_FLAG = :MWIPLOTHIS_N.HIST_DEL_FLAG,
                    HIST_DEL_TIME = :MWIPLOTHIS_N.HIST_DEL_TIME,
                    HIST_DEL_USER_ID = :MWIPLOTHIS_N.HIST_DEL_USER_ID,
                    HIST_DEL_COMMENT = :MWIPLOTHIS_N.HIST_DEL_COMMENT
                WHERE LOT_ID = :MWIPLOTHIS_N.LOT_ID
                    AND HIST_SEQ = :MWIPLOTHIS_N.HIST_SEQ;
            break;

        case 2:
            EXEC SQL UPDATE MWIPLOTHIS SET
                    CRR_ID = :MWIPLOTHIS_N.CRR_ID
                WHERE LOT_ID = :MWIPLOTHIS_N.LOT_ID
                  AND HIST_SEQ = :MWIPLOTHIS_N.HIST_SEQ;
            break;
                    

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mwiplothis", sel_type);
}


