                    :MWIPLOTHIS_N.HIST_DEL_COMMENT
                FROM MWIPLOTHIS HIS
                WHERE LOT_ID = :MWIPLOTHIS_N.LOT_ID
                    AND HIST_DEL_FLAG = ' '
                    AND TRAN_CODE IN ( 'START', 'END', 'SKIP', 'REWORK','REPAIR','ADAPT')
                    AND OLD_FACTORY = :MWIPLOTHIS_N.OLD_FACTORY
                    AND OLD_OPER = :MWIPLOTHIS_N.OLD_OPER
                    AND ROWNUM = 1;
            break;

