            sprintf(sql + strlen(sql),   "TRAN_CMF_11, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_12, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_13, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_14, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_15, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_16, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_17, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_18, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_19, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_20, ");
            sprintf(sql + strlen(sql),   "TRAN_USER_ID, ");
            sprintf(sql + strlen(sql),   "TRAN_COMMENT, ");
            sprintf(sql + strlen(sql),   "PREV_ACTIVE_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "MULTI_TR_KEY, ");
            sprintf(sql + strlen(sql),   "MULTI_TR_SEQ, ");
            sprintf(sql + strlen(sql),   "EXT_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_FLAG, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_TIME, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_USER_ID, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_COMMENT ");
            sprintf(sql + strlen(sql), "FROM MWIPLOTHIS WHERE ");

            make_valid_quote(ts1, MWIPLOTHIS_N.FACTORY);
            sprintf(sql + strlen(sql), "FACTORY = '%s' ", ts1);

            if(ISSPACE(MWIPLOTHIS->TRAN_TIME, sizeof(MWIPLOTHIS->TRAN_TIME)) == DB_FALSE)
            {
                make_valid_quote(ts1, MWIPLOTHIS_N.TRAN_TIME);
                sprintf(sql + strlen(sql), "AND TRAN_TIME >= '%s' ", ts1);
            }
            
            if(ISSPACE(MWIPLOTHIS->OLD_MAT_ID, sizeof(MWIPLOTHIS->OLD_MAT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts1, MWIPLOTHIS_N.OLD_MAT_ID);
                sprintf(sql + strlen(sql), "AND OLD_MAT_ID = '%s' ", ts1);
                sprintf(sql + strlen(sql), "AND OLD_MAT_VER = '%d' ", MWIPLOTHIS_N.OLD_MAT_VER);
            }
            
            if(ISSPACE(MWIPLOTHIS->OLD_FLOW, sizeof(MWIPLOTHIS->OLD_FLOW)) == DB_FALSE)
            {
                make_valid_quote(ts1, MWIPLOTHIS_N.OLD_FLOW);
                sprintf(sql + strlen(sql), "AND OLD_FLOW = '%s' ", ts1);
            }
            
            if(MWIPLOTHIS_N.OLD_FLOW_SEQ_NUM > 0)
            {
                sprintf(sql + strlen(sql), "AND OLD_FLOW_SEQ_NUM = '%d' ", MWIPLOTHIS_N.OLD_FLOW_SEQ_NUM);
            }
            
            make_valid_quote(ts1, MWIPLOTHIS_N.OLD_OPER);
            sprintf(sql + strlen(sql), "AND OLD_OPER = '%s' ", ts1);
            make_valid_quote(ts1, MWIPLOTHIS_N.HIST_DEL_FLAG);
            sprintf(sql + strlen(sql), "AND HIST_DEL_FLAG = '%s' ", ts1);
            
            sprintf(sql + strlen(sql), "AND TRAN_CODE IN ('END','MOVE','REWORK','REPAIR','ADAPT') ");
            sprintf(sql + strlen(sql), "AND OPER <> OLD_OPER ");
            
            sprintf(sql + strlen(sql), "ORDER BY TRAN_TIME");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MWIPLOTHIS_CUR_12 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MWIPLOTHIS_CUR_12;                 
            break;

        case 13:
