                    FLOW_SEQ_NUM = :MWIPLOTHIS_N.FLOW_SEQ_NUM,
                    OPER = :MWIPLOTHIS_N.OPER,
                    QTY_1 = :MWIPLOTHIS_N.QTY_1,
                    QTY_2 = :MWIPLOTHIS_N.QTY_2,
                    QTY_3 = :MWIPLOTHIS_N.QTY_3,
                    CRR_ID = :MWIPLOTHIS_N.CRR_ID,
