                FROM MWIPLOTHIS
                WHERE FACTORY = :MWIPLOTHIS_N.FACTORY AND
                      OLD_MAT_ID = :MWIPLOTHIS_N.OLD_MAT_ID AND
                      OLD_MAT_VER = :MWIPLOTHIS_N.OLD_MAT_VER AND
                      OLD_FLOW = :MWIPLOTHIS_N.OLD_FLOW AND
                      OLD_FLOW_SEQ_NUM = :MWIPLOTHIS_N.OLD_FLOW_SEQ_NUM AND
                      OLD_OPER = :MWIPLOTHIS_N.OLD_OPER AND
                      TRAN_CODE = :MWIPLOTHIS_N.TRAN_CODE AND
                      HIST_DEL_FLAG = :MWIPLOTHIS_N.HIST_DEL_FLAG
                ORDER BY HIST_SEQ DESC;
            EXEC SQL OPEN DBC_MWIPLOTHIS_CUR_13;
            break;
        
