            sprintf(sql + strlen(sql),   "FROM_TO_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "OLD_FACTORY, ");
            sprintf(sql + strlen(sql),   "OLD_MAT_ID, ");
            sprintf(sql + strlen(sql),   "OLD_MAT_VER, ");
            sprintf(sql + strlen(sql),   "OLD_FLOW, ");
            sprintf(sql + strlen(sql),   "OLD_FLOW_SEQ_NUM, ");
            sprintf(sql + strlen(sql),   "OLD_OPER, ");
            sprintf(sql + strlen(sql),   "OLD_QTY_1, ");
            sprintf(sql + strlen(sql),   "OLD_QTY_2, ");
            sprintf(sql + strlen(sql),   "OLD_QTY_3, ");
            sprintf(sql + strlen(sql),   "OLD_LOT_TYPE, ");
            sprintf(sql + strlen(sql),   "OLD_OWNER_CODE, ");
            sprintf(sql + strlen(sql),   "OLD_CREATE_CODE, ");
            sprintf(sql + strlen(sql),   "OLD_FAC_IN_TIME, ");
            sprintf(sql + strlen(sql),   "OLD_FLOW_IN_TIME, ");
            sprintf(sql + strlen(sql),   "OLD_OPER_IN_TIME, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_1, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_2, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_3, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_4, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_5, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_6, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_7, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_8, ");
