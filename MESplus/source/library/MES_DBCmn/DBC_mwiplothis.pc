            sprintf(sql + strlen(sql),   "RESV_FIELD_2, ");
            sprintf(sql + strlen(sql),   "RESV_FIELD_3, ");
            sprintf(sql + strlen(sql),   "RESV_FIELD_4, ");
            sprintf(sql + strlen(sql),   "RESV_FIELD_5, ");
            sprintf(sql + strlen(sql),   "RESV_FLAG_1, ");
            sprintf(sql + strlen(sql),   "RESV_FLAG_2, ");
            sprintf(sql + strlen(sql),   "RESV_FLAG_3, ");
            sprintf(sql + strlen(sql),   "RESV_FLAG_4, ");
            sprintf(sql + strlen(sql),   "RESV_FLAG_5, ");
            sprintf(sql + strlen(sql),   "FROM_TO_MAT_ID, ");
            sprintf(sql + strlen(sql),   "FROM_TO_MAT_VER, ");
            sprintf(sql + strlen(sql),   "FROM_TO_FLOW, ");
            sprintf(sql + strlen(sql),   "FROM_TO_FLOW_SEQ_NUM, ");
