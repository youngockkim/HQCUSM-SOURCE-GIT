                                                     :MWIPLOTHIS_N.OLD_LOT_TYPE,
                                                     :MWIPLOTHIS_N.OLD_OWNER_CODE,
                                                     :MWIPLOTHIS_N.OLD_CREATE_CODE,
                                                     :MWIPLOTHIS_N.OLD_FAC_IN_TIME,
                                                     :MWIPLOTHIS_N.OLD_FLOW_IN_TIME,
                                                     :MWIPLOTHIS_N.OLD_OPER_IN_TIME,
                                                     :MWIPLOTHIS_N.TRAN_CMF_1,
                                                     :MWIPLOTHIS_N.TRAN_CMF_2,
                                                     :MWIPLOTHIS_N.TRAN_CMF_3,
                                                     :MWIPLOTHIS_N.TRAN_CMF_4,
                                                     :MWIPLOTHIS_N.TRAN_CMF_5,
                                                     :MWIPLOTHIS_N.TRAN_CMF_6,
                                                     :MWIPLOTHIS_N.TRAN_CMF_7,
                                                     :MWIPLOTHIS_N.TRAN_CMF_8,
                                                     :MWIPLOTHIS_N.TRAN_CMF_9,
                                                     :MWIPLOTHIS_N.TRAN_CMF_10,
                                                     :MWIPLOTHIS_N.TRAN_CMF_11,
                                                     :MWIPLOTHIS_N.TRAN_CMF_12,
                                                     :MWIPLOTHIS_N.TRAN_CMF_13,
                                                     :MWIPLOTHIS_N.TRAN_CMF_14,
                                                     :MWIPLOTHIS_N.TRAN_CMF_15,
                                                     :MWIPLOTHIS_N.TRAN_CMF_16,
                                                     :MWIPLOTHIS_N.TRAN_CMF_17,
                                                     :MWIPLOTHIS_N.TRAN_CMF_18,
                                                     :MWIPLOTHIS_N.TRAN_CMF_19,
                                                     :MWIPLOTHIS_N.TRAN_CMF_20,
                                                     :MWIPLOTHIS_N.TRAN_USER_ID,
                                                     :MWIPLOTHIS_N.TRAN_COMMENT,
                                                     :MWIPLOTHIS_N.PREV_ACTIVE_HIST_SEQ,
                                                     :MWIPLOTHIS_N.MULTI_TR_KEY,
                                                     :MWIPLOTHIS_N.MULTI_TR_SEQ,
                                                     :MWIPLOTHIS_N.EXT_HIST_SEQ,
                                                     :MWIPLOTHIS_N.HIST_DEL_FLAG,
                                                     :MWIPLOTHIS_N.HIST_DEL_TIME,
                                                     :MWIPLOTHIS_N.HIST_DEL_USER_ID,
                                                     :MWIPLOTHIS_N.HIST_DEL_COMMENT;
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwiplothis(&MWIPLOTHIS_N, MWIPLOTHIS);
    }
    DB_stop_query_timer("DBC_fetch_mwiplothis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwiplothis(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_3;
            break;
            
        case 4:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_5;
            break;

        case 6:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_6;
            break;

        case 7:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_7;
            break;

        case 8:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_8;
            break;

        case 9:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_9;
            break;
        case 10:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_10;
            break;
            
        /*case 11:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_11;
            break;            
        */
        case 12:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_12;
            break;            

        case 13:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_13;
            break; 
            
        case 14:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_14;
            break;            

        case 15:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_15;
            break;            

        case 16:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_16;
            break;

        case 17:
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_17;
            break;

        case 18: /* Not Allow Duplicate Flow Seq Num Case : Against Case 13 */
            EXEC SQL CLOSE DBC_MWIPLOTHIS_CUR_18;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwiplothis", sel_type);
}


/* Initialize Function */
void DBC_init_mwiplothis(struct MWIPLOTHIS_TAG *MWIPLOTHIS)
{
    /* memset by Space */
    memset(MWIPLOTHIS, ' ', sizeof(struct MWIPLOTHIS_TAG));
    
    MWIPLOTHIS->HIST_SEQ = 0;
    MWIPLOTHIS->MAT_VER = 0;
    MWIPLOTHIS->FLOW_SEQ_NUM = 0;
    MWIPLOTHIS->QTY_1 = 0;
    MWIPLOTHIS->QTY_2 = 0;
    MWIPLOTHIS->QTY_3 = 0;
    MWIPLOTHIS->OPER_IN_QTY_1 = 0;
    MWIPLOTHIS->OPER_IN_QTY_2 = 0;
    MWIPLOTHIS->OPER_IN_QTY_3 = 0;
    MWIPLOTHIS->CREATE_QTY_1 = 0;
    MWIPLOTHIS->CREATE_QTY_2 = 0;
    MWIPLOTHIS->CREATE_QTY_3 = 0;
    MWIPLOTHIS->START_QTY_1 = 0;
    MWIPLOTHIS->START_QTY_2 = 0;
    MWIPLOTHIS->START_QTY_3 = 0;
    MWIPLOTHIS->RWK_COUNT = 0;
    MWIPLOTHIS->RWK_RET_FLOW_SEQ_NUM = 0;
    MWIPLOTHIS->RWK_END_FLOW_SEQ_NUM = 0;
    MWIPLOTHIS->NSTD_RET_FLOW_SEQ_NUM = 0;
    MWIPLOTHIS->BATCH_SEQ = 0;
    MWIPLOTHIS->BOM_SET_VERSION = 0;
    MWIPLOTHIS->BOM_ACTIVE_HIST_SEQ = 0;
    MWIPLOTHIS->BOM_HIST_SEQ = 0;
    MWIPLOTHIS->FROM_TO_MAT_VER = 0;
    MWIPLOTHIS->FROM_TO_FLOW_SEQ_NUM = 0;
    MWIPLOTHIS->FROM_TO_QTY_1 = 0;
    MWIPLOTHIS->FROM_TO_QTY_2 = 0;
    MWIPLOTHIS->FROM_TO_QTY_3 = 0;
    MWIPLOTHIS->FROM_TO_HIST_SEQ = 0;
    MWIPLOTHIS->OLD_MAT_VER = 0;
    MWIPLOTHIS->OLD_FLOW_SEQ_NUM = 0;
    MWIPLOTHIS->OLD_QTY_1 = 0;
    MWIPLOTHIS->OLD_QTY_2 = 0;
    MWIPLOTHIS->OLD_QTY_3 = 0;
    MWIPLOTHIS->PREV_ACTIVE_HIST_SEQ = 0;
    MWIPLOTHIS->MULTI_TR_SEQ = 0;
    MWIPLOTHIS->STR_RET_FLOW_SEQ_NUM = 0;
    MWIPLOTHIS->YIELD_1 = 0;
    MWIPLOTHIS->YIELD_2 = 0;
    MWIPLOTHIS->YIELD_3 = 0;
    MWIPLOTHIS->GOOD_QTY = 0;
    MWIPLOTHIS->EXT_HIST_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mwiplothis(struct MWIPLOTHIS_N_TAG *MWIPLOTHIS_N, struct MWIPLOTHIS_TAG *MWIPLOTHIS)
{
    /* memset by NULL */
    memset(MWIPLOTHIS_N, '\0', sizeof(struct MWIPLOTHIS_N_TAG));
    
    MEMCPY_AN(MWIPLOTHIS_N->LOT_ID, MWIPLOTHIS->LOT_ID, sizeof(MWIPLOTHIS->LOT_ID));
    MWIPLOTHIS_N->HIST_SEQ = MWIPLOTHIS->HIST_SEQ;
