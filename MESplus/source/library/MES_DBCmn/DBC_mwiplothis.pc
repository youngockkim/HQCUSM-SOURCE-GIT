                    :MWIPLOTHIS_N.HIST_DEL_USER_ID,
                    :MWIPLOTHIS_N.HIST_DEL_COMMENT
                FROM MWIPLOTHIS
                WHERE LOT_ID = :MWIPLOTHIS_N.LOT_ID
                    AND HIST_SEQ = :MWIPLOTHIS_N.HIST_SEQ
                FOR UPDATE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwiplothis(&MWIPLOTHIS_N, MWIPLOTHIS);
    }
    DB_stop_query_timer("DBC_select_mwiplothis_for_update", sel_type);
}


/* SQL SELECT_SCALAR Function */
double DBC_select_mwiplothis_scalar(int sel_type, struct MWIPLOTHIS_TAG *MWIPLOTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTHIS_N_TAG MWIPLOTHIS_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    

    DBC_add_null_mwiplothis(&MWIPLOTHIS_N, MWIPLOTHIS);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTHIS
                WHERE LOT_ID = :MWIPLOTHIS_N.LOT_ID
                    AND HIST_SEQ = :MWIPLOTHIS_N.HIST_SEQ;
            break;

        case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTHIS
                WHERE LOT_ID = :MWIPLOTHIS_N.LOT_ID
                    AND HIST_DEL_FLAG = :MWIPLOTHIS_N.HIST_DEL_FLAG
                    AND TRAN_CODE = :MWIPLOTHIS_N.TRAN_CODE
                    AND FLOW_IN_TIME = :MWIPLOTHIS_N.FLOW_IN_TIME
                    AND OLD_FACTORY = :MWIPLOTHIS_N.FACTORY
                    AND OLD_FLOW = :MWIPLOTHIS_N.FLOW
                    AND OLD_FLOW_SEQ_NUM = :MWIPLOTHIS_N.FLOW_SEQ_NUM
                    AND OLD_OPER = :MWIPLOTHIS_N.OPER;
            break;

        case 3: /* Not Allow Duplicate Flow Seq Num Case : Against Case 2 */
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTHIS
                WHERE LOT_ID = :MWIPLOTHIS_N.LOT_ID
                    AND HIST_DEL_FLAG = :MWIPLOTHIS_N.HIST_DEL_FLAG
                    AND TRAN_CODE = :MWIPLOTHIS_N.TRAN_CODE
                    AND FLOW_IN_TIME = :MWIPLOTHIS_N.FLOW_IN_TIME
                    AND OLD_FACTORY = :MWIPLOTHIS_N.FACTORY
                    AND OLD_FLOW = :MWIPLOTHIS_N.FLOW
                    /* AND OLD_FLOW_SEQ_NUM = :MWIPLOTHIS_N.FLOW_SEQ_NUM */
                    AND OLD_OPER = :MWIPLOTHIS_N.OPER;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mwiplothis_scalar", sel_type);
    return d_value;
}


/* SQL DELETE Function */
void DBC_delete_mwiplothis(int sel_type, struct MWIPLOTHIS_TAG *MWIPLOTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTHIS_N_TAG MWIPLOTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplothis(&MWIPLOTHIS_N, MWIPLOTHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM MWIPLOTHIS
                WHERE LOT_ID = :MWIPLOTHIS_N.LOT_ID
                    AND HIST_SEQ = :MWIPLOTHIS_N.HIST_SEQ;
            break;

        case 2:
            EXEC SQL DELETE FROM MWIPLOTHIS
                WHERE LOT_ID = :MWIPLOTHIS_N.LOT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_delete_mwiplothis", sel_type);
}


