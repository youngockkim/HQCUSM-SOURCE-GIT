    EXEC SQL BEGIN DECLARE SECTION;
        struct MSVMSVCURT_N_TAG MSVMSVCURT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_msvmsvcurt(&MSVMSVCURT_N, MSVMSVCURT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSVMSVCURT_CUR_1 CURSOR FOR
                SELECT 
                    MODULE_NAME,
                    SERVICE_NAME,
                    BEFORE,
                    AFTER,
                    OVERRIDE_FLAG,
                    LIB_NAME,
                    LIB_VER,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MSVMSVCURT
                ORDER BY MODULE_NAME ASC,
                    SERVICE_NAME ASC;
            EXEC SQL OPEN DBC_MSVMSVCURT_CUR_1;
            break;

            
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_msvmsvcurt", sel_type);
}


