    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            /* View Rework Flow List by MAT_ID, FLOW, OPER, OPT_LEVEL */
            EXEC SQL DECLARE DBC_MWIPRWKDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RWK_CODE,
