                    AND FLOW = :MWIPRWKDEF_N.FLOW
                    AND OPER = :MWIPRWKDEF_N.OPER
                    AND RWK_CODE = :MWIPRWKDEF_N.RWK_CODE
                ORDER BY RWK_FLOW ASC, RWK_FLOW_SEQ_NUM ASC, RWK_OPER ASC;
            EXEC SQL OPEN DBC_MWIPRWKDEF_CUR_1;
