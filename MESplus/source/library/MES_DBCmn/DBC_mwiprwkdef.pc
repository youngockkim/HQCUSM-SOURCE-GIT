/* SQL CURSOR CLOSE Function */
void DBC_close_mwiprwkdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPRWKDEF_CUR_1;
            break;
        
        case 2:
            EXEC SQL CLOSE DBC_MWIPRWKDEF_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MWIPRWKDEF_CUR_3;
            break;
            
        case 4:
            EXEC SQL CLOSE DBC_MWIPRWKDEF_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MWIPRWKDEF_CUR_5;
            break;

        case 6:
            EXEC SQL CLOSE DBC_MWIPRWKDEF_CUR_6;
            break;
           
        case 7:
            EXEC SQL CLOSE DBC_MWIPRWKDEF_CUR_7;
            break;
        case 8:
            EXEC SQL CLOSE DBC_MWIPRWKDEF_CUR_8;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwiprwkdef", sel_type);
}


/* Initialize Function */
void DBC_init_mwiprwkdef(struct MWIPRWKDEF_TAG *MWIPRWKDEF)
{
    /* memset by Space */
    memset(MWIPRWKDEF, ' ', sizeof(struct MWIPRWKDEF_TAG));
    
    MWIPRWKDEF->MAT_VER = 0;
    MWIPRWKDEF->RWK_FLOW_SEQ_NUM = 0;
    MWIPRWKDEF->RET_FLOW_SEQ_NUM = 0;
}


/* Add Null Function */
void DBC_add_null_mwiprwkdef(struct MWIPRWKDEF_N_TAG *MWIPRWKDEF_N, struct MWIPRWKDEF_TAG *MWIPRWKDEF)
{
    /* memset by NULL */
    memset(MWIPRWKDEF_N, '\0', sizeof(struct MWIPRWKDEF_N_TAG));
    
    MEMCPY_AN(MWIPRWKDEF_N->FACTORY, MWIPRWKDEF->FACTORY, sizeof(MWIPRWKDEF->FACTORY));
    MEMCPY_AN(MWIPRWKDEF_N->MAT_ID, MWIPRWKDEF->MAT_ID, sizeof(MWIPRWKDEF->MAT_ID));
    MWIPRWKDEF_N->MAT_VER = MWIPRWKDEF->MAT_VER;
    MEMCPY_AN(MWIPRWKDEF_N->FLOW, MWIPRWKDEF->FLOW, sizeof(MWIPRWKDEF->FLOW));
    MEMCPY_AN(MWIPRWKDEF_N->OPER, MWIPRWKDEF->OPER, sizeof(MWIPRWKDEF->OPER));
    MEMCPY_AN(MWIPRWKDEF_N->RWK_CODE, MWIPRWKDEF->RWK_CODE, sizeof(MWIPRWKDEF->RWK_CODE));
    MEMCPY_AN(MWIPRWKDEF_N->RWK_FLOW, MWIPRWKDEF->RWK_FLOW, sizeof(MWIPRWKDEF->RWK_FLOW));
    MWIPRWKDEF_N->RWK_FLOW_SEQ_NUM = MWIPRWKDEF->RWK_FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPRWKDEF_N->RWK_OPER, MWIPRWKDEF->RWK_OPER, sizeof(MWIPRWKDEF->RWK_OPER));
    MEMCPY_AN(MWIPRWKDEF_N->RWK_STOP_OPER, MWIPRWKDEF->RWK_STOP_OPER, sizeof(MWIPRWKDEF->RWK_STOP_OPER));
    MWIPRWKDEF_N->OPT_LEVEL[0] = MWIPRWKDEF->OPT_LEVEL;
    MEMCPY_AN(MWIPRWKDEF_N->RET_FLOW, MWIPRWKDEF->RET_FLOW, sizeof(MWIPRWKDEF->RET_FLOW));
    MWIPRWKDEF_N->RET_FLOW_SEQ_NUM = MWIPRWKDEF->RET_FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPRWKDEF_N->RET_OPER, MWIPRWKDEF->RET_OPER, sizeof(MWIPRWKDEF->RET_OPER));
    MWIPRWKDEF_N->RET_CLEAR_FLAG[0] = MWIPRWKDEF->RET_CLEAR_FLAG;
    MEMCPY_AN(MWIPRWKDEF_N->CREATE_USER_ID, MWIPRWKDEF->CREATE_USER_ID, sizeof(MWIPRWKDEF->CREATE_USER_ID));
    MEMCPY_AN(MWIPRWKDEF_N->CREATE_TIME, MWIPRWKDEF->CREATE_TIME, sizeof(MWIPRWKDEF->CREATE_TIME));
    MEMCPY_AN(MWIPRWKDEF_N->UPDATE_USER_ID, MWIPRWKDEF->UPDATE_USER_ID, sizeof(MWIPRWKDEF->UPDATE_USER_ID));
    MEMCPY_AN(MWIPRWKDEF_N->UPDATE_TIME, MWIPRWKDEF->UPDATE_TIME, sizeof(MWIPRWKDEF->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mwiprwkdef(struct MWIPRWKDEF_N_TAG *MWIPRWKDEF_N, struct MWIPRWKDEF_TAG *MWIPRWKDEF)
{
    MEMCPY_DN(MWIPRWKDEF->FACTORY, MWIPRWKDEF_N->FACTORY, sizeof(MWIPRWKDEF->FACTORY));
    MEMCPY_DN(MWIPRWKDEF->MAT_ID, MWIPRWKDEF_N->MAT_ID, sizeof(MWIPRWKDEF->MAT_ID));
    MWIPRWKDEF->MAT_VER = MWIPRWKDEF_N->MAT_VER;
    MEMCPY_DN(MWIPRWKDEF->FLOW, MWIPRWKDEF_N->FLOW, sizeof(MWIPRWKDEF->FLOW));
    MEMCPY_DN(MWIPRWKDEF->OPER, MWIPRWKDEF_N->OPER, sizeof(MWIPRWKDEF->OPER));
    MEMCPY_DN(MWIPRWKDEF->RWK_CODE, MWIPRWKDEF_N->RWK_CODE, sizeof(MWIPRWKDEF->RWK_CODE));
    MEMCPY_DN(MWIPRWKDEF->RWK_FLOW, MWIPRWKDEF_N->RWK_FLOW, sizeof(MWIPRWKDEF->RWK_FLOW));
    MWIPRWKDEF->RWK_FLOW_SEQ_NUM = MWIPRWKDEF_N->RWK_FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPRWKDEF->RWK_OPER, MWIPRWKDEF_N->RWK_OPER, sizeof(MWIPRWKDEF->RWK_OPER));
    MEMCPY_DN(MWIPRWKDEF->RWK_STOP_OPER, MWIPRWKDEF_N->RWK_STOP_OPER, sizeof(MWIPRWKDEF->RWK_STOP_OPER));
    MWIPRWKDEF->OPT_LEVEL = MWIPRWKDEF_N->OPT_LEVEL[0];
    MEMCPY_DN(MWIPRWKDEF->RET_FLOW, MWIPRWKDEF_N->RET_FLOW, sizeof(MWIPRWKDEF->RET_FLOW));
    MWIPRWKDEF->RET_FLOW_SEQ_NUM = MWIPRWKDEF_N->RET_FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPRWKDEF->RET_OPER, MWIPRWKDEF_N->RET_OPER, sizeof(MWIPRWKDEF->RET_OPER));
    MWIPRWKDEF->RET_CLEAR_FLAG = MWIPRWKDEF_N->RET_CLEAR_FLAG[0];
    MEMCPY_DN(MWIPRWKDEF->CREATE_USER_ID, MWIPRWKDEF_N->CREATE_USER_ID, sizeof(MWIPRWKDEF->CREATE_USER_ID));
    MEMCPY_DN(MWIPRWKDEF->CREATE_TIME, MWIPRWKDEF_N->CREATE_TIME, sizeof(MWIPRWKDEF->CREATE_TIME));
    MEMCPY_DN(MWIPRWKDEF->UPDATE_USER_ID, MWIPRWKDEF_N->UPDATE_USER_ID, sizeof(MWIPRWKDEF->UPDATE_USER_ID));
    MEMCPY_DN(MWIPRWKDEF->UPDATE_TIME, MWIPRWKDEF_N->UPDATE_TIME, sizeof(MWIPRWKDEF->UPDATE_TIME));
}



