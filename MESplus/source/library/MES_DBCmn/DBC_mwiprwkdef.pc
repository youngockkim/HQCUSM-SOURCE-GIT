                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RWK_CODE,
                    RWK_FLOW,
                    RWK_FLOW_SEQ_NUM,
                    RWK_OPER,
                    RWK_STOP_OPER,
                    OPT_LEVEL,
                    RET_FLOW,
                    RET_FLOW_SEQ_NUM,
                    RET_OPER,
                    RET_CLEAR_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPRWKDEF
                WHERE FACTORY = :MWIPRWKDEF_N.FACTORY
                    AND OPER = :MWIPRWKDEF_N.OPER;
            EXEC SQL OPEN DBC_MWIPRWKDEF_CUR_6;
            break;

        case 7:
            EXEC SQL DECLARE DBC_MWIPRWKDEF_CUR_7 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RWK_CODE,
                    RWK_FLOW,
                    RWK_FLOW_SEQ_NUM,
                    RWK_OPER,
                    RWK_STOP_OPER,
                    OPT_LEVEL,
                    RET_FLOW,
                    RET_FLOW_SEQ_NUM,
                    RET_OPER,
                    RET_CLEAR_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPRWKDEF
                WHERE FACTORY = :MWIPRWKDEF_N.FACTORY
                    AND MAT_ID = ' '
                    AND MAT_VER = 0
                    AND FLOW = :MWIPRWKDEF_N.FLOW;
            EXEC SQL OPEN DBC_MWIPRWKDEF_CUR_7;
            break;

        case 8:
            EXEC SQL DECLARE DBC_MWIPRWKDEF_CUR_8 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    RWK_CODE,
                    RWK_FLOW,
                    RWK_FLOW_SEQ_NUM,
                    RWK_OPER,
                    RWK_STOP_OPER,
                    OPT_LEVEL,
                    RET_FLOW,
                    RET_FLOW_SEQ_NUM,
                    RET_OPER,
                    RET_CLEAR_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPRWKDEF
                WHERE FACTORY = :MWIPRWKDEF_N.FACTORY
                    AND MAT_ID = ' '
                    AND MAT_VER = 0
                    AND FLOW = ' '
                    AND OPER = :MWIPRWKDEF_N.OPER;
            EXEC SQL OPEN DBC_MWIPRWKDEF_CUR_8;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwiprwkdef", sel_type);
}


