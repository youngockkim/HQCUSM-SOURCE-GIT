/* SQL CURSOR CLOSE Function */
void DBC_close_mwipoprinv(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPOPRINV_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWIPOPRINV_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MWIPOPRINV_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MWIPOPRINV_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MWIPOPRINV_CUR_5;
            break;

        case 6:
            EXEC SQL CLOSE DBC_MWIPOPRINV_CUR_6;
            break;
        case 7:
            EXEC SQL CLOSE DBC_MWIPOPRINV_CUR_7;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipoprinv", sel_type);
}


/* Initialize Function */
void DBC_init_mwipoprinv(struct MWIPOPRINV_TAG *MWIPOPRINV)
{
    /* memset by Space */
    memset(MWIPOPRINV, ' ', sizeof(struct MWIPOPRINV_TAG));
    
    MWIPOPRINV->MAT_VER = 0;
    MWIPOPRINV->SEQ = 0;
    MWIPOPRINV->BACK_COLOR = 0;
}


/* Add Null Function */
void DBC_add_null_mwipoprinv(struct MWIPOPRINV_N_TAG *MWIPOPRINV_N, struct MWIPOPRINV_TAG *MWIPOPRINV)
{
    /* memset by NULL */
    memset(MWIPOPRINV_N, '\0', sizeof(struct MWIPOPRINV_N_TAG));
    
    MEMCPY_AN(MWIPOPRINV_N->FACTORY, MWIPOPRINV->FACTORY, sizeof(MWIPOPRINV->FACTORY));
    MWIPOPRINV_N->REL_LEVEL[0] = MWIPOPRINV->REL_LEVEL;
    MEMCPY_AN(MWIPOPRINV_N->MAT_ID, MWIPOPRINV->MAT_ID, sizeof(MWIPOPRINV->MAT_ID));
    MWIPOPRINV_N->MAT_VER = MWIPOPRINV->MAT_VER;
    MEMCPY_AN(MWIPOPRINV_N->FLOW, MWIPOPRINV->FLOW, sizeof(MWIPOPRINV->FLOW));
