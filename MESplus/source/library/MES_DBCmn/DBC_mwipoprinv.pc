                WHERE FACTORY = :MWIPOPRINV_N.FACTORY
                    AND REL_LEVEL = :MWIPOPRINV_N.REL_LEVEL
                    AND MAT_ID = :MWIPOPRINV_N.MAT_ID
                    AND MAT_VER = :MWIPOPRINV_N.MAT_VER
                    AND FLOW = :MWIPOPRINV_N.FLOW
                    AND OPER = :MWIPOPRINV_N.OPER
                    AND POINT_TYPE = :MWIPOPRINV_N.POINT_TYPE
                    AND SEQ = :MWIPOPRINV_N.SEQ;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mwipoprinv", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipoprinv(int sel_type, struct MWIPOPRINV_TAG *MWIPOPRINV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPOPRINV_N_TAG MWIPOPRINV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipoprinv(&MWIPOPRINV_N, MWIPOPRINV);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPOPRINV_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    REL_LEVEL,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    POINT_TYPE,
                    SEQ,
                    VALUE_TYPE,
                    DATA_1,
                    DATA_2,
                    DATA_3,
                    DATA_4,
                    DATA_5,
                    DISPLAY_TYPE,
                    INPUT_TYPE,
                    REQUIRE_FLAG,
                    BACK_COLOR,
                    INPUT_VALUE_TYPE,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CMF_11,
                    CMF_12,
                    CMF_13,
                    CMF_14,
                    CMF_15,
                    CMF_16,
                    CMF_17,
                    CMF_18,
                    CMF_19,
                    CMF_20,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPOPRINV
                WHERE FACTORY = :MWIPOPRINV_N.FACTORY
                    AND REL_LEVEL = :MWIPOPRINV_N.REL_LEVEL
                    AND MAT_ID = :MWIPOPRINV_N.MAT_ID
                    AND MAT_VER = :MWIPOPRINV_N.MAT_VER
                    AND FLOW = :MWIPOPRINV_N.FLOW
                    AND OPER = :MWIPOPRINV_N.OPER
                    AND SEQ >= :MWIPOPRINV_N.SEQ
                ORDER BY SEQ ASC;
            EXEC SQL OPEN DBC_MWIPOPRINV_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPOPRINV_CUR_2 CURSOR FOR
                SELECT 
