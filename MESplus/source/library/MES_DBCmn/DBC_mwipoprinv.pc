    MWIPOPRINV_N->VALUE_TYPE[0] = MWIPOPRINV->VALUE_TYPE;
    MEMCPY_AN(MWIPOPRINV_N->DATA_1, MWIPOPRINV->DATA_1, sizeof(MWIPOPRINV->DATA_1));
