                    ENTER_DATE,
                    RETIRE_DATE,
                    EMAIL_ID,
                    BIRTHDAY,
                    SEX_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MSECUSRDEF
                WHERE FACTORY = :MSECUSRDEF_N.FACTORY
                    AND SEC_GRP_ID = :MSECUSRDEF_N.SEC_GRP_ID                
                    AND USER_ID >= :MSECUSRDEF_N.USER_ID
                ORDER BY USER_ID ASC;
            EXEC SQL OPEN DBC_MSECUSRDEF_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_msecusrdef", sel_type);
}


