    memset(MSECUSRDEF_N, '\0', sizeof(struct MSECUSRDEF_N_TAG));
    
    MEMCPY_AN(MSECUSRDEF_N->FACTORY, MSECUSRDEF->FACTORY, sizeof(MSECUSRDEF->FACTORY));
