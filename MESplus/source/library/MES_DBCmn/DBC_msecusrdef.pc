/* SQL CURSOR CLOSE Function */
void DBC_close_msecusrdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MSECUSRDEF_CUR_1;
            break;
        case 2:
            EXEC SQL CLOSE DBC_MSECUSRDEF_CUR_2;
            break;
        case 3:
            EXEC SQL CLOSE DBC_MSECUSRDEF_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_msecusrdef", sel_type);
}


/* Initialize Function */
void DBC_init_msecusrdef(struct MSECUSRDEF_TAG *MSECUSRDEF)
{
    /* memset by Space */
    memset(MSECUSRDEF, ' ', sizeof(struct MSECUSRDEF_TAG));
    
}


/* Add Null Function */
void DBC_add_null_msecusrdef(struct MSECUSRDEF_N_TAG *MSECUSRDEF_N, struct MSECUSRDEF_TAG *MSECUSRDEF)
{
