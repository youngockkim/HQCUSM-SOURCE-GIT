/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mbasscrcnd(int sel_type, struct MBASSCRCND_TAG *MBASSCRCND)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBASSCRCND_N_TAG MBASSCRCND_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbasscrcnd(&MBASSCRCND_N, MBASSCRCND);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MBASSCRCND_CUR_1 CURSOR FOR
                SELECT 
                    RELATION_KEY,
                    SEQ_NO,
                    AND_OR,
                    L_BRACKET,
                    COND_TYPE,
                    FIELD_NAME,
                    OPERATOR,
                    VALUE_TYPE,
                    VALUE_1,
                    VALUE_2,
                    R_BRACKET,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MBASSCRCND
                ORDER BY RELATION_KEY ASC,
                    SEQ_NO ASC;
            EXEC SQL OPEN DBC_MBASSCRCND_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MBASSCRCND_CUR_2 CURSOR FOR
                SELECT 
                    RELATION_KEY,
                    SEQ_NO,
                    AND_OR,
                    L_BRACKET,
                    COND_TYPE,
                    FIELD_NAME,
                    OPERATOR,
                    VALUE_TYPE,
                    VALUE_1,
                    VALUE_2,
                    R_BRACKET,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MBASSCRCND
                WHERE RELATION_KEY = :MBASSCRCND_N.RELATION_KEY
                    AND SEQ_NO >= :MBASSCRCND_N.SEQ_NO
                ORDER BY SEQ_NO ASC;
            EXEC SQL OPEN DBC_MBASSCRCND_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
