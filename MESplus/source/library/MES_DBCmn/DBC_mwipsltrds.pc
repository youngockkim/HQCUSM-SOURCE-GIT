    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM MWIPSLTRDS
                WHERE SUBLOT_ID = :MWIPSLTRDS_N.SUBLOT_ID
                    AND HIST_SEQ = :MWIPSLTRDS_N.HIST_SEQ;
