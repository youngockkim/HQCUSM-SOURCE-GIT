                    FROM_FLOW,
                    FROM_FLOW_SEQ_NUM,
                    FROM_OPER,
                    RET_FLOW,
                    RET_FLOW_SEQ_NUM,
                    RET_OPER,
                    RET_CLEAR_FLAG,
                    LOCAL_REWORK_FLAG
        )
        VALUES (
                    :MWIPSLTRDS_N.SUBLOT_ID,
                    :MWIPSLTRDS_N.HIST_SEQ,
                    :MWIPSLTRDS_N.HIST_DEL_FLAG,
                    :MWIPSLTRDS_N.COMPLETE_FLAG,
                    :MWIPSLTRDS_N.COMPLETE_HIST_SEQ,
                    :MWIPSLTRDS_N.RWK_FLOW,
                    :MWIPSLTRDS_N.RWK_FLOW_SEQ_NUM,
                    :MWIPSLTRDS_N.RWK_OPER,
                    :MWIPSLTRDS_N.RWK_STOP_OPER,
                    :MWIPSLTRDS_N.RWK_DEPTH,
                    :MWIPSLTRDS_N.RWK_CODE,
                    :MWIPSLTRDS_N.RWK_TIME,
                    :MWIPSLTRDS_N.RWK_START_HIST_SEQ,
                    :MWIPSLTRDS_N.FROM_FLOW,
                    :MWIPSLTRDS_N.FROM_FLOW_SEQ_NUM,
                    :MWIPSLTRDS_N.FROM_OPER,
                    :MWIPSLTRDS_N.RET_FLOW,
                    :MWIPSLTRDS_N.RET_FLOW_SEQ_NUM,
                    :MWIPSLTRDS_N.RET_OPER,
                    :MWIPSLTRDS_N.RET_CLEAR_FLAG,
                    :MWIPSLTRDS_N.LOCAL_REWORK_FLAG
        );
    DB_stop_query_timer("DBC_insert_mwipsltrds", 0);
}


/* SQL UPDATE Function */
void DBC_update_mwipsltrds(int sel_type, struct MWIPSLTRDS_TAG *MWIPSLTRDS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSLTRDS_N_TAG MWIPSLTRDS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipsltrds(&MWIPSLTRDS_N, MWIPSLTRDS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MWIPSLTRDS SET
                    HIST_DEL_FLAG = :MWIPSLTRDS_N.HIST_DEL_FLAG,
                    COMPLETE_FLAG = :MWIPSLTRDS_N.COMPLETE_FLAG,
                    COMPLETE_HIST_SEQ = :MWIPSLTRDS_N.COMPLETE_HIST_SEQ,
                    RWK_FLOW = :MWIPSLTRDS_N.RWK_FLOW,
                    RWK_FLOW_SEQ_NUM = :MWIPSLTRDS_N.RWK_FLOW_SEQ_NUM,
                    RWK_OPER = :MWIPSLTRDS_N.RWK_OPER,
                    RWK_STOP_OPER = :MWIPSLTRDS_N.RWK_STOP_OPER,
                    RWK_DEPTH = :MWIPSLTRDS_N.RWK_DEPTH,
                    RWK_CODE = :MWIPSLTRDS_N.RWK_CODE,
                    RWK_TIME = :MWIPSLTRDS_N.RWK_TIME,
                    RWK_START_HIST_SEQ = :MWIPSLTRDS_N.RWK_START_HIST_SEQ,
                    FROM_FLOW = :MWIPSLTRDS_N.FROM_FLOW,
                    FROM_FLOW_SEQ_NUM = :MWIPSLTRDS_N.FROM_FLOW_SEQ_NUM,
                    FROM_OPER = :MWIPSLTRDS_N.FROM_OPER,
                    RET_FLOW = :MWIPSLTRDS_N.RET_FLOW,
                    RET_FLOW_SEQ_NUM = :MWIPSLTRDS_N.RET_FLOW_SEQ_NUM,
                    RET_OPER = :MWIPSLTRDS_N.RET_OPER,
                    RET_CLEAR_FLAG = :MWIPSLTRDS_N.RET_CLEAR_FLAG,
                    LOCAL_REWORK_FLAG = :MWIPSLTRDS_N.LOCAL_REWORK_FLAG
                WHERE SUBLOT_ID = :MWIPSLTRDS_N.SUBLOT_ID
                    AND HIST_SEQ = :MWIPSLTRDS_N.HIST_SEQ;
            break;

        case 2:
            EXEC SQL UPDATE MWIPSLTRDS SET
                    COMPLETE_FLAG = 'A',
                    COMPLETE_HIST_SEQ = :MWIPSLTRDS_N.COMPLETE_HIST_SEQ
                WHERE SUBLOT_ID = :MWIPSLTRDS_N.SUBLOT_ID
                    AND HIST_SEQ > :MWIPSLTRDS_N.HIST_SEQ
                    AND HIST_DEL_FLAG = :MWIPSLTRDS_N.HIST_DEL_FLAG
                    AND COMPLETE_FLAG = :MWIPSLTRDS_N.COMPLETE_FLAG;
            break;

        case 3:
            EXEC SQL UPDATE MWIPSLTRDS SET
                    COMPLETE_FLAG = ' ',
                    COMPLETE_HIST_SEQ = 0
                WHERE SUBLOT_ID = :MWIPSLTRDS_N.SUBLOT_ID
                    AND HIST_DEL_FLAG = :MWIPSLTRDS_N.HIST_DEL_FLAG
                    AND COMPLETE_HIST_SEQ = :MWIPSLTRDS_N.COMPLETE_HIST_SEQ;
            break;

        case 4:
            EXEC SQL UPDATE MWIPSLTRDS SET
                    HIST_DEL_FLAG = :MWIPSLTRDS_N.HIST_DEL_FLAG
                WHERE SUBLOT_ID = :MWIPSLTRDS_N.SUBLOT_ID
                    AND HIST_SEQ = :MWIPSLTRDS_N.HIST_SEQ;
            break;



        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mwipsltrds", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipsltrds(int sel_type, struct MWIPSLTRDS_TAG *MWIPSLTRDS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSLTRDS_N_TAG MWIPSLTRDS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipsltrds(&MWIPSLTRDS_N, MWIPSLTRDS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPSLTRDS_CUR_1 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    HIST_SEQ,
                    HIST_DEL_FLAG,
                    COMPLETE_FLAG,
                    COMPLETE_HIST_SEQ,
                    RWK_FLOW,
                    RWK_FLOW_SEQ_NUM,
                    RWK_OPER,
                    RWK_STOP_OPER,
                    RWK_DEPTH,
                    RWK_CODE,
                    RWK_TIME,
                    RWK_START_HIST_SEQ,
                    FROM_FLOW,
                    FROM_FLOW_SEQ_NUM,
                    FROM_OPER,
                    RET_FLOW,
                    RET_FLOW_SEQ_NUM,
                    RET_OPER,
                    RET_CLEAR_FLAG,
                    LOCAL_REWORK_FLAG
                FROM MWIPSLTRDS
                ORDER BY SUBLOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MWIPSLTRDS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipsltrds", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mwipsltrds(int sel_type, struct MWIPSLTRDS_TAG *MWIPSLTRDS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSLTRDS_N_TAG MWIPSLTRDS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MWIPSLTRDS_CUR_1 INTO 
                                                    :MWIPSLTRDS_N.SUBLOT_ID,
                                                    :MWIPSLTRDS_N.HIST_SEQ,
                                                    :MWIPSLTRDS_N.HIST_DEL_FLAG,
                                                    :MWIPSLTRDS_N.COMPLETE_FLAG,
                                                    :MWIPSLTRDS_N.COMPLETE_HIST_SEQ,
                                                    :MWIPSLTRDS_N.RWK_FLOW,
                                                    :MWIPSLTRDS_N.RWK_FLOW_SEQ_NUM,
                                                    :MWIPSLTRDS_N.RWK_OPER,
                                                    :MWIPSLTRDS_N.RWK_STOP_OPER,
                                                    :MWIPSLTRDS_N.RWK_DEPTH,
                                                    :MWIPSLTRDS_N.RWK_CODE,
                                                    :MWIPSLTRDS_N.RWK_TIME,
                                                    :MWIPSLTRDS_N.RWK_START_HIST_SEQ,
                                                    :MWIPSLTRDS_N.FROM_FLOW,
                                                    :MWIPSLTRDS_N.FROM_FLOW_SEQ_NUM,
                                                    :MWIPSLTRDS_N.FROM_OPER,
                                                    :MWIPSLTRDS_N.RET_FLOW,
                                                    :MWIPSLTRDS_N.RET_FLOW_SEQ_NUM,
                                                    :MWIPSLTRDS_N.RET_OPER,
                                                    :MWIPSLTRDS_N.RET_CLEAR_FLAG,
                                                    :MWIPSLTRDS_N.LOCAL_REWORK_FLAG;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwipsltrds(&MWIPSLTRDS_N, MWIPSLTRDS);
    }
    DB_stop_query_timer("DBC_fetch_mwipsltrds", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwipsltrds(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPSLTRDS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipsltrds", sel_type);
}


/* Initialize Function */
void DBC_init_mwipsltrds(struct MWIPSLTRDS_TAG *MWIPSLTRDS)
{
    /* memset by Space */
    memset(MWIPSLTRDS, ' ', sizeof(struct MWIPSLTRDS_TAG));
    
    MWIPSLTRDS->HIST_SEQ = 0;
    MWIPSLTRDS->COMPLETE_HIST_SEQ = 0;
    MWIPSLTRDS->RWK_FLOW_SEQ_NUM = 0;
    MWIPSLTRDS->RWK_DEPTH = 0;
    MWIPSLTRDS->RWK_START_HIST_SEQ = 0;
    MWIPSLTRDS->FROM_FLOW_SEQ_NUM = 0;
    MWIPSLTRDS->RET_FLOW_SEQ_NUM = 0;
}


/* Add Null Function */
void DBC_add_null_mwipsltrds(struct MWIPSLTRDS_N_TAG *MWIPSLTRDS_N, struct MWIPSLTRDS_TAG *MWIPSLTRDS)
{
    /* memset by NULL */
    memset(MWIPSLTRDS_N, '\0', sizeof(struct MWIPSLTRDS_N_TAG));
    
    MEMCPY_AN(MWIPSLTRDS_N->SUBLOT_ID, MWIPSLTRDS->SUBLOT_ID, sizeof(MWIPSLTRDS->SUBLOT_ID));
    MWIPSLTRDS_N->HIST_SEQ = MWIPSLTRDS->HIST_SEQ;
    MWIPSLTRDS_N->HIST_DEL_FLAG[0] = MWIPSLTRDS->HIST_DEL_FLAG;
    MWIPSLTRDS_N->COMPLETE_FLAG[0] = MWIPSLTRDS->COMPLETE_FLAG;
    MWIPSLTRDS_N->COMPLETE_HIST_SEQ = MWIPSLTRDS->COMPLETE_HIST_SEQ;
    MEMCPY_AN(MWIPSLTRDS_N->RWK_FLOW, MWIPSLTRDS->RWK_FLOW, sizeof(MWIPSLTRDS->RWK_FLOW));
    MWIPSLTRDS_N->RWK_FLOW_SEQ_NUM = MWIPSLTRDS->RWK_FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPSLTRDS_N->RWK_OPER, MWIPSLTRDS->RWK_OPER, sizeof(MWIPSLTRDS->RWK_OPER));
    MEMCPY_AN(MWIPSLTRDS_N->RWK_STOP_OPER, MWIPSLTRDS->RWK_STOP_OPER, sizeof(MWIPSLTRDS->RWK_STOP_OPER));
    MWIPSLTRDS_N->RWK_DEPTH = MWIPSLTRDS->RWK_DEPTH;
    MEMCPY_AN(MWIPSLTRDS_N->RWK_CODE, MWIPSLTRDS->RWK_CODE, sizeof(MWIPSLTRDS->RWK_CODE));
    MEMCPY_AN(MWIPSLTRDS_N->RWK_TIME, MWIPSLTRDS->RWK_TIME, sizeof(MWIPSLTRDS->RWK_TIME));
    MWIPSLTRDS_N->RWK_START_HIST_SEQ = MWIPSLTRDS->RWK_START_HIST_SEQ;
    MEMCPY_AN(MWIPSLTRDS_N->FROM_FLOW, MWIPSLTRDS->FROM_FLOW, sizeof(MWIPSLTRDS->FROM_FLOW));
    MWIPSLTRDS_N->FROM_FLOW_SEQ_NUM = MWIPSLTRDS->FROM_FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPSLTRDS_N->FROM_OPER, MWIPSLTRDS->FROM_OPER, sizeof(MWIPSLTRDS->FROM_OPER));
    MEMCPY_AN(MWIPSLTRDS_N->RET_FLOW, MWIPSLTRDS->RET_FLOW, sizeof(MWIPSLTRDS->RET_FLOW));
    MWIPSLTRDS_N->RET_FLOW_SEQ_NUM = MWIPSLTRDS->RET_FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPSLTRDS_N->RET_OPER, MWIPSLTRDS->RET_OPER, sizeof(MWIPSLTRDS->RET_OPER));
    MWIPSLTRDS_N->RET_CLEAR_FLAG[0] = MWIPSLTRDS->RET_CLEAR_FLAG;
    MWIPSLTRDS_N->LOCAL_REWORK_FLAG[0] = MWIPSLTRDS->LOCAL_REWORK_FLAG;
}


/* Del Null Function */
void DBC_del_null_mwipsltrds(struct MWIPSLTRDS_N_TAG *MWIPSLTRDS_N, struct MWIPSLTRDS_TAG *MWIPSLTRDS)
{
    MEMCPY_DN(MWIPSLTRDS->SUBLOT_ID, MWIPSLTRDS_N->SUBLOT_ID, sizeof(MWIPSLTRDS->SUBLOT_ID));
    MWIPSLTRDS->HIST_SEQ = MWIPSLTRDS_N->HIST_SEQ;
    MWIPSLTRDS->HIST_DEL_FLAG = MWIPSLTRDS_N->HIST_DEL_FLAG[0];
    MWIPSLTRDS->COMPLETE_FLAG = MWIPSLTRDS_N->COMPLETE_FLAG[0];
    MWIPSLTRDS->COMPLETE_HIST_SEQ = MWIPSLTRDS_N->COMPLETE_HIST_SEQ;
    MEMCPY_DN(MWIPSLTRDS->RWK_FLOW, MWIPSLTRDS_N->RWK_FLOW, sizeof(MWIPSLTRDS->RWK_FLOW));
    MWIPSLTRDS->RWK_FLOW_SEQ_NUM = MWIPSLTRDS_N->RWK_FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPSLTRDS->RWK_OPER, MWIPSLTRDS_N->RWK_OPER, sizeof(MWIPSLTRDS->RWK_OPER));
    MEMCPY_DN(MWIPSLTRDS->RWK_STOP_OPER, MWIPSLTRDS_N->RWK_STOP_OPER, sizeof(MWIPSLTRDS->RWK_STOP_OPER));
    MWIPSLTRDS->RWK_DEPTH = MWIPSLTRDS_N->RWK_DEPTH;
    MEMCPY_DN(MWIPSLTRDS->RWK_CODE, MWIPSLTRDS_N->RWK_CODE, sizeof(MWIPSLTRDS->RWK_CODE));
    MEMCPY_DN(MWIPSLTRDS->RWK_TIME, MWIPSLTRDS_N->RWK_TIME, sizeof(MWIPSLTRDS->RWK_TIME));
    MWIPSLTRDS->RWK_START_HIST_SEQ = MWIPSLTRDS_N->RWK_START_HIST_SEQ;
    MEMCPY_DN(MWIPSLTRDS->FROM_FLOW, MWIPSLTRDS_N->FROM_FLOW, sizeof(MWIPSLTRDS->FROM_FLOW));
    MWIPSLTRDS->FROM_FLOW_SEQ_NUM = MWIPSLTRDS_N->FROM_FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPSLTRDS->FROM_OPER, MWIPSLTRDS_N->FROM_OPER, sizeof(MWIPSLTRDS->FROM_OPER));
    MEMCPY_DN(MWIPSLTRDS->RET_FLOW, MWIPSLTRDS_N->RET_FLOW, sizeof(MWIPSLTRDS->RET_FLOW));
    MWIPSLTRDS->RET_FLOW_SEQ_NUM = MWIPSLTRDS_N->RET_FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPSLTRDS->RET_OPER, MWIPSLTRDS_N->RET_OPER, sizeof(MWIPSLTRDS->RET_OPER));
    MWIPSLTRDS->RET_CLEAR_FLAG = MWIPSLTRDS_N->RET_CLEAR_FLAG[0];
    MWIPSLTRDS->LOCAL_REWORK_FLAG = MWIPSLTRDS_N->LOCAL_REWORK_FLAG[0];
}


