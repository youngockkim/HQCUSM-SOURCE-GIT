            break;
    }
    DB_stop_query_timer("DBC_delete_mwipsltrds", sel_type);
}


/* SQL INSERT Function */
void DBC_insert_mwipsltrds(struct MWIPSLTRDS_TAG *MWIPSLTRDS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPSLTRDS_N_TAG MWIPSLTRDS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipsltrds(&MWIPSLTRDS_N, MWIPSLTRDS);
    DB_error_code = 0;

    EXEC SQL INSERT INTO MWIPSLTRDS (
                    SUBLOT_ID,
                    HIST_SEQ,
                    HIST_DEL_FLAG,
                    COMPLETE_FLAG,
                    COMPLETE_HIST_SEQ,
                    RWK_FLOW,
                    RWK_FLOW_SEQ_NUM,
