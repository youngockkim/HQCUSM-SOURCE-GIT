                    DATA_19 = :MWIPFATACT_N.DATA_19,
                    DATA_20 = :MWIPFATACT_N.DATA_20,
                    CMF_1 = :MWIPFATACT_N.CMF_1,
                    CMF_2 = :MWIPFATACT_N.CMF_2,
                    CMF_3 = :MWIPFATACT_N.CMF_3,
                    CMF_4 = :MWIPFATACT_N.CMF_4,
                    CMF_5 = :MWIPFATACT_N.CMF_5,
                    CMF_6 = :MWIPFATACT_N.CMF_6,
                    CMF_7 = :MWIPFATACT_N.CMF_7,
                    CMF_8 = :MWIPFATACT_N.CMF_8,
                    CMF_9 = :MWIPFATACT_N.CMF_9,
                    CMF_10 = :MWIPFATACT_N.CMF_10,
                    CMF_11 = :MWIPFATACT_N.CMF_11,
                    CMF_12 = :MWIPFATACT_N.CMF_12,
                    CMF_13 = :MWIPFATACT_N.CMF_13,
                    CMF_14 = :MWIPFATACT_N.CMF_14,
                    CMF_15 = :MWIPFATACT_N.CMF_15,
                    CMF_16 = :MWIPFATACT_N.CMF_16,
                    CMF_17 = :MWIPFATACT_N.CMF_17,
                    CMF_18 = :MWIPFATACT_N.CMF_18,
                    CMF_19 = :MWIPFATACT_N.CMF_19,
                    CMF_20 = :MWIPFATACT_N.CMF_20,
                    TRAN_COMMENT = :MWIPFATACT_N.TRAN_COMMENT,
                    CREATE_USER_ID = :MWIPFATACT_N.CREATE_USER_ID,
                    CREATE_TIME = :MWIPFATACT_N.CREATE_TIME,
                    UPDATE_USER_ID = :MWIPFATACT_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MWIPFATACT_N.UPDATE_TIME,
                    LONG_DATA_1 = :MWIPFATACT_N.LONG_DATA_1,
                    LONG_DATA_2 = :MWIPFATACT_N.LONG_DATA_2
                WHERE POINT_KEY = :MWIPFATACT_N.POINT_KEY
                    AND ACTION_KEY = :MWIPFATACT_N.ACTION_KEY;
            break;

        case 2:
            EXEC SQL UPDATE MWIPFATACT SET
                    POINT_KEY = :MWIPFATACT_N.DATA_1,
                    DEPENDENT_ACTION_KEY = :MWIPFATACT_N.DEPENDENT_ACTION_KEY
                WHERE POINT_KEY = :MWIPFATACT_N.POINT_KEY
                    AND ACTION_KEY = :MWIPFATACT_N.ACTION_KEY;
            break;



        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mwipfatact", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipfatact(int sel_type, struct MWIPFATACT_TAG *MWIPFATACT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPFATACT_N_TAG MWIPFATACT_N;
        char   sql[5120];
        char   ts[100];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipfatact(&MWIPFATACT_N, MWIPFATACT);
    DB_error_code = 0;
    memset(ts, 0x00, sizeof(ts));

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPFATACT_CUR_1 CURSOR FOR
                SELECT 
                    POINT_KEY,
                    ACTION_KEY,
                    TRAN_CODE,
                    ACTION_TYPE,
                    SKIP_SERVICE,
                    DATA_1,
                    DATA_2,
                    DATA_3,
                    DATA_4,
                    DATA_5,
                    DATA_6,
                    DATA_7,
                    DATA_8,
                    DATA_9,
                    DATA_10,
                    DATA_11,
                    DATA_12,
                    DATA_13,
                    DATA_14,
                    DATA_15,
                    DATA_16,
                    DATA_17,
                    DATA_18,
                    DATA_19,
                    DATA_20,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CMF_11,
                    CMF_12,
                    CMF_13,
                    CMF_14,
                    CMF_15,
                    CMF_16,
                    CMF_17,
                    CMF_18,
                    CMF_19,
                    CMF_20,
                    TRAN_COMMENT,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    DEPENDENT_ACTION_KEY,
                    LONG_DATA_1,
                    LONG_DATA_2
                FROM MWIPFATACT
                WHERE POINT_KEY = :MWIPFATACT_N.POINT_KEY
                    AND ACTION_KEY >= :MWIPFATACT_N.ACTION_KEY
                ORDER BY ACTION_KEY ASC;
            EXEC SQL OPEN DBC_MWIPFATACT_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPFATACT_CUR_2 CURSOR FOR
                SELECT 
                    POINT_KEY,
                    ACTION_KEY,
                    TRAN_CODE,
                    ACTION_TYPE,
                    SKIP_SERVICE,
                    DATA_1,
                    DATA_2,
                    DATA_3,
                    DATA_4,
                    DATA_5,
                    DATA_6,
                    DATA_7,
                    DATA_8,
                    DATA_9,
                    DATA_10,
                    DATA_11,
                    DATA_12,
                    DATA_13,
                    DATA_14,
                    DATA_15,
                    DATA_16,
                    DATA_17,
                    DATA_18,
                    DATA_19,
                    DATA_20,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CMF_11,
                    CMF_12,
                    CMF_13,
                    CMF_14,
                    CMF_15,
                    CMF_16,
                    CMF_17,
                    CMF_18,
                    CMF_19,
                    CMF_20,
                    TRAN_COMMENT,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    DEPENDENT_ACTION_KEY,
                    LONG_DATA_1,
                    LONG_DATA_2
                FROM MWIPFATACT
                WHERE POINT_KEY = :MWIPFATACT_N.POINT_KEY
                    AND DEPENDENT_ACTION_KEY = :MWIPFATACT_N.DEPENDENT_ACTION_KEY
                ORDER BY ACTION_KEY ASC;
            EXEC SQL OPEN DBC_MWIPFATACT_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MWIPFATACT_CUR_3 CURSOR FOR
                SELECT DISTINCT SVC.SERVICE_NAME, ACT.TRAN_CODE
                FROM MWIPFATSVC SVC, (
                    SELECT 
                        POINT_KEY,
                        ACTION_KEY,
                        TRAN_CODE,
                        ACTION_TYPE,
                        SKIP_SERVICE,
                        DATA_1,
                        DATA_2,
                        DATA_3,
                        DATA_4,
                        DATA_5,
                        DATA_6,
                        DATA_7,
                        DATA_8,
                        DATA_9,
                        DATA_10,
                        DATA_11,
                        DATA_12,
                        DATA_13,
                        DATA_14,
                        DATA_15,
                        DATA_16,
                        DATA_17,
                        DATA_18,
                        DATA_19,
                        DATA_20,
                        CMF_1,
                        CMF_2,
                        CMF_3,
                        CMF_4,
                        CMF_5,
                        CMF_6,
                        CMF_7,
                        CMF_8,
                        CMF_9,
                        CMF_10,
                        CMF_11,
                        CMF_12,
                        CMF_13,
                        CMF_14,
                        CMF_15,
                        CMF_16,
                        CMF_17,
                        CMF_18,
                        CMF_19,
                        CMF_20,
                        TRAN_COMMENT,
                        CREATE_USER_ID,
                        CREATE_TIME,
                        UPDATE_USER_ID,
                        UPDATE_TIME,
                        DEPENDENT_ACTION_KEY,
                        LONG_DATA_1,
                        LONG_DATA_2
                    FROM MWIPFATACT 
                    WHERE POINT_KEY IN (
                        SELECT POINT_KEY 
                        FROM MWIPFATDEF 
                        WHERE FACTORY = :MWIPFATACT_N.CMF_1
                            AND MAT_ID = :MWIPFATACT_N.CMF_2
                            AND MAT_VER = :MWIPFATACT_N.CMF_3
                            AND FLOW = :MWIPFATACT_N.CMF_4
                            AND OPER = :MWIPFATACT_N.CMF_5
                            AND OPER_POINT = :MWIPFATACT_N.CMF_6
                            AND BA_POINT = :MWIPFATACT_N.CMF_7
                            AND OPT_LEVEL = :MWIPFATACT_N.CMF_8
                        )
                        AND TRAN_CODE != :MWIPFATACT_N.TRAN_CODE
                        AND ACTION_KEY != :MWIPFATACT_N.ACTION_KEY
                    ) ACT
                WHERE SVC.ACTION_KEY = ACT.ACTION_KEY;
            EXEC SQL OPEN DBC_MWIPFATACT_CUR_3;
            break;

        case 4:
            memset( sql, 0x00, sizeof(sql));
            sprintf(sql,               "SELECT POINT_KEY, ACTION_KEY FROM (SELECT DEF.POINT_KEY, ACT.ACTION_KEY, COUNT(CND.ACTION_KEY) AS COND_COUNT ");
            sprintf(sql + strlen(sql), "FROM MWIPFATDEF DEF, MWIPFATACT ACT, MWIPFATSVC SVC, MWIPFATCND CND ");

            make_valid_quote(ts, MWIPFATACT_N.CMF_1);
            sprintf(sql + strlen(sql), "WHERE DEF.FACTORY = '%s' ", ts);

            if(MWIPFATACT->ACTION_TYPE == 'B') // Before Service
            {
                sprintf(sql + strlen(sql), "AND DEF.OPER_POINT = 'A' AND DEF.BA_POINT = 'B' ");
            }
            else if(MWIPFATACT->ACTION_TYPE == 'A') // After Service
            {
                sprintf(sql + strlen(sql), "AND DEF.OPER_POINT = 'A' AND DEF.BA_POINT = 'A' ");
            }
            else if(MWIPFATACT->ACTION_TYPE == 'I') // Oper IN
            {
                sprintf(sql + strlen(sql), "AND DEF.OPER_POINT = 'I' AND DEF.BA_POINT = ' ' ");
            }
            else if(MWIPFATACT->ACTION_TYPE == 'C') // Oper OUT-Before
            {
                sprintf(sql + strlen(sql), "AND DEF.OPER_POINT = 'O' AND DEF.BA_POINT = 'B' ");
            }
            else if(MWIPFATACT->ACTION_TYPE == 'O') // Oper OUT-After
            {
                sprintf(sql + strlen(sql), "AND DEF.OPER_POINT = 'O' AND DEF.BA_POINT = 'A' ");
            }

            sprintf(sql + strlen(sql), "AND DEF.OPT_LEVEL = '%c' ", MWIPFATACT_N.CMF_2[0]);
            make_valid_quote(ts, MWIPFATACT_N.CMF_3);
            sprintf(sql + strlen(sql), "AND DEF.MAT_ID = '%s' ", ts);
            sprintf(sql + strlen(sql), "AND DEF.MAT_VER = '%s' ", MWIPFATACT_N.CMF_4);
            make_valid_quote(ts, MWIPFATACT_N.CMF_5);
            sprintf(sql + strlen(sql), "AND DEF.FLOW = '%s' ", ts);
            make_valid_quote(ts, MWIPFATACT_N.CMF_6);
            sprintf(sql + strlen(sql), "AND DEF.OPER = '%s' ", ts);

            sprintf(sql + strlen(sql), "AND DEF.POINT_KEY = ACT.POINT_KEY ");
            make_valid_quote(ts, MWIPFATACT_N.CMF_7);
            sprintf(sql + strlen(sql), "AND ACT.DEPENDENT_ACTION_KEY = '%s' ", ts);
            sprintf(sql + strlen(sql), "AND ACT.ACTION_KEY = SVC.ACTION_KEY ");
            sprintf(sql + strlen(sql), "AND ACT.ACTION_KEY = CND.ACTION_KEY(+) ");

            make_valid_quote(ts, MWIPFATACT_N.TRAN_COMMENT);
            sprintf(sql + strlen(sql), "AND SVC.SERVICE_NAME = '%s' ", ts);
            sprintf(sql + strlen(sql), "GROUP BY DEF.POINT_KEY, ACT.ACTION_KEY ");
            sprintf(sql + strlen(sql), "ORDER BY COND_COUNT DESC, ACT.ACTION_KEY DESC)");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MWIPFATACT_CUR_4 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MWIPFATACT_CUR_4;                 
            break;

        case 5:
            EXEC SQL DECLARE DBC_MWIPFATACT_CUR_5 CURSOR FOR
                SELECT DISTINCT SVC.SERVICE_NAME, ACT.TRAN_CODE
                FROM MWIPFATSVC SVC, (
                    SELECT 
                        POINT_KEY,
                        ACTION_KEY,
                        TRAN_CODE,
                        ACTION_TYPE,
                        SKIP_SERVICE,
                        DATA_1,
                        DATA_2,
                        DATA_3,
                        DATA_4,
                        DATA_5,
                        DATA_6,
                        DATA_7,
                        DATA_8,
                        DATA_9,
                        DATA_10,
                        DATA_11,
                        DATA_12,
                        DATA_13,
                        DATA_14,
                        DATA_15,
                        DATA_16,
                        DATA_17,
                        DATA_18,
                        DATA_19,
                        DATA_20,
                        CMF_1,
                        CMF_2,
                        CMF_3,
                        CMF_4,
                        CMF_5,
                        CMF_6,
                        CMF_7,
                        CMF_8,
                        CMF_9,
                        CMF_10,
                        CMF_11,
                        CMF_12,
                        CMF_13,
                        CMF_14,
                        CMF_15,
                        CMF_16,
                        CMF_17,
                        CMF_18,
                        CMF_19,
                        CMF_20,
                        TRAN_COMMENT,
                        CREATE_USER_ID,
                        CREATE_TIME,
                        UPDATE_USER_ID,
                        UPDATE_TIME,
                        DEPENDENT_ACTION_KEY,
                        LONG_DATA_1,
                        LONG_DATA_2
                    FROM MWIPFATACT 
                    WHERE POINT_KEY IN (
                        SELECT POINT_KEY 
                        FROM MWIPFATDEF 
                        WHERE FACTORY = :MWIPFATACT_N.CMF_1
                            AND (MAT_ID = :MWIPFATACT_N.CMF_2 OR MAT_ID = ' ')
                            AND (MAT_VER = :MWIPFATACT_N.CMF_3 OR MAT_VER = 0)
                            AND (FLOW = :MWIPFATACT_N.CMF_4 OR FLOW = ' ')
                            AND (OPER = :MWIPFATACT_N.CMF_5 OR OPER = ' ')
                            AND OPER_POINT = :MWIPFATACT_N.CMF_6
                            AND BA_POINT = :MWIPFATACT_N.CMF_7
                        )
                        AND ACTION_TYPE != :MWIPFATACT_N.ACTION_TYPE
                        AND ACTION_KEY != :MWIPFATACT_N.ACTION_KEY
                        AND DEPENDENT_ACTION_KEY = :MWIPFATACT_N.DEPENDENT_ACTION_KEY
                    ) ACT
                WHERE SVC.ACTION_KEY = ACT.ACTION_KEY;
            EXEC SQL OPEN DBC_MWIPFATACT_CUR_5;
            break;

        case 6:
            EXEC SQL DECLARE DBC_MWIPFATACT_CUR_6 CURSOR FOR
                SELECT 
                    POINT_KEY,
                    ACTION_KEY,
                    TRAN_CODE,
                    ACTION_TYPE,
                    SKIP_SERVICE,
                    DATA_1,
                    DATA_2,
                    DATA_3,
                    DATA_4,
                    DATA_5,
                    DATA_6,
                    DATA_7,
                    DATA_8,
                    DATA_9,
                    DATA_10,
                    DATA_11,
                    DATA_12,
                    DATA_13,
                    DATA_14,
                    DATA_15,
                    DATA_16,
                    DATA_17,
                    DATA_18,
                    DATA_19,
                    DATA_20,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CMF_11,
                    CMF_12,
                    CMF_13,
                    CMF_14,
                    CMF_15,
                    CMF_16,
                    CMF_17,
                    CMF_18,
                    CMF_19,
                    CMF_20,
                    TRAN_COMMENT,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    DEPENDENT_ACTION_KEY,
                    LONG_DATA_1,
                    LONG_DATA_2
                FROM MWIPFATACT
                WHERE POINT_KEY = :MWIPFATACT_N.POINT_KEY
                    AND ACTION_KEY >= :MWIPFATACT_N.ACTION_KEY
                    AND DEPENDENT_ACTION_KEY = :MWIPFATACT_N.DEPENDENT_ACTION_KEY
                ORDER BY ACTION_KEY ASC;
            EXEC SQL OPEN DBC_MWIPFATACT_CUR_6;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipfatact", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mwipfatact(int sel_type, struct MWIPFATACT_TAG *MWIPFATACT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPFATACT_N_TAG MWIPFATACT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MWIPFATACT_CUR_1 INTO 
                                                    :MWIPFATACT_N.POINT_KEY,
                                                    :MWIPFATACT_N.ACTION_KEY,
                                                    :MWIPFATACT_N.TRAN_CODE,
