            break;

        case 4:
            EXEC SQL FETCH DBC_MWIPFATACT_CUR_4 INTO :MWIPFATACT_N.POINT_KEY, :MWIPFATACT_N.ACTION_KEY;
            break;
        
        case 5:
            EXEC SQL FETCH DBC_MWIPFATACT_CUR_5 INTO :MWIPFATACT_N.TRAN_COMMENT, :MWIPFATACT_N.TRAN_CODE;
            break;

        case 6:
            EXEC SQL FETCH DBC_MWIPFATACT_CUR_6 INTO 
                                                    :MWIPFATACT_N.POINT_KEY,
                                                    :MWIPFATACT_N.ACTION_KEY,
                                                    :MWIPFATACT_N.TRAN_CODE,
