                                                    :MWIPFATACT_N.DATA_1,
                                                    :MWIPFATACT_N.DATA_2,
                                                    :MWIPFATACT_N.DATA_3,
                                                    :MWIPFATACT_N.DATA_4,
                                                    :MWIPFATACT_N.DATA_5,
                                                    :MWIPFATACT_N.DATA_6,
                                                    :MWIPFATACT_N.DATA_7,
                                                    :MWIPFATACT_N.DATA_8,
                                                    :MWIPFATACT_N.DATA_9,
                                                    :MWIPFATACT_N.DATA_10,
                                                    :MWIPFATACT_N.DATA_11,
                                                    :MWIPFATACT_N.DATA_12,
                                                    :MWIPFATACT_N.DATA_13,
                                                    :MWIPFATACT_N.DATA_14,
                                                    :MWIPFATACT_N.DATA_15,
                                                    :MWIPFATACT_N.DATA_16,
                                                    :MWIPFATACT_N.DATA_17,
                                                    :MWIPFATACT_N.DATA_18,
                                                    :MWIPFATACT_N.DATA_19,
                                                    :MWIPFATACT_N.DATA_20,
                                                    :MWIPFATACT_N.CMF_1,
                                                    :MWIPFATACT_N.CMF_2,
                                                    :MWIPFATACT_N.CMF_3,
                                                    :MWIPFATACT_N.CMF_4,
                                                    :MWIPFATACT_N.CMF_5,
                                                    :MWIPFATACT_N.CMF_6,
                                                    :MWIPFATACT_N.CMF_7,
                                                    :MWIPFATACT_N.CMF_8,
                                                    :MWIPFATACT_N.CMF_9,
                                                    :MWIPFATACT_N.CMF_10,
                                                    :MWIPFATACT_N.CMF_11,
                                                    :MWIPFATACT_N.CMF_12,
                                                    :MWIPFATACT_N.CMF_13,
                                                    :MWIPFATACT_N.CMF_14,
                                                    :MWIPFATACT_N.CMF_15,
                                                    :MWIPFATACT_N.CMF_16,
                                                    :MWIPFATACT_N.CMF_17,
                                                    :MWIPFATACT_N.CMF_18,
                                                    :MWIPFATACT_N.CMF_19,
                                                    :MWIPFATACT_N.CMF_20,
                                                    :MWIPFATACT_N.TRAN_COMMENT,
                                                    :MWIPFATACT_N.CREATE_USER_ID,
                                                    :MWIPFATACT_N.CREATE_TIME,
                                                    :MWIPFATACT_N.UPDATE_USER_ID,
                                                    :MWIPFATACT_N.UPDATE_TIME,
                                                    :MWIPFATACT_N.DEPENDENT_ACTION_KEY,
                                                    :MWIPFATACT_N.LONG_DATA_1,
                                                    :MWIPFATACT_N.LONG_DATA_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwipfatact(&MWIPFATACT_N, MWIPFATACT);
    }
    DB_stop_query_timer("DBC_fetch_mwipfatact", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwipfatact(int sel_type)
{
    DB_error_code = 0;
    DB_start_query_timer();

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPFATACT_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWIPFATACT_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MWIPFATACT_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MWIPFATACT_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MWIPFATACT_CUR_5;
            break;

        case 6:
            EXEC SQL CLOSE DBC_MWIPFATACT_CUR_6;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipfatact", sel_type);
}


/* Initialize Function */
void DBC_init_mwipfatact(struct MWIPFATACT_TAG *MWIPFATACT)
{
    /* memset by Space */
    memset(MWIPFATACT, ' ', sizeof(struct MWIPFATACT_TAG));
    
}


