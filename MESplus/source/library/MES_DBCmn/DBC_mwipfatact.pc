                                                    :MWIPFATACT_N.LONG_DATA_1,
                                                    :MWIPFATACT_N.LONG_DATA_2;
            break;

        case 2:
            EXEC SQL FETCH DBC_MWIPFATACT_CUR_2 INTO 
                                                    :MWIPFATACT_N.POINT_KEY,
                                                    :MWIPFATACT_N.ACTION_KEY,
                                                    :MWIPFATACT_N.TRAN_CODE,
                                                    :MWIPFATACT_N.ACTION_TYPE,
