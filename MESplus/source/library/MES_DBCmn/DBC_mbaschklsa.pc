/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mbaschklsa(int sel_type, struct MBASCHKLSA_TAG *MBASCHKLSA)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBASCHKLSA_N_TAG MBASCHKLSA_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbaschklsa(&MBASCHKLSA_N, MBASCHKLSA);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MBASCHKLSA_CUR_1 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    CHKLIST_ID,
                    REL_KEY,
                    HIST_SEQ,
                    QUERY_ID,
                    TRAN_TIME,
                    TRAN_USER_ID,
                    ANSWER
                FROM MBASCHKLSA
                ORDER BY FACTORY ASC,
                    CHKLIST_ID ASC,
                    HIST_SEQ ASC,
                    QUERY_ID ASC;
            EXEC SQL OPEN DBC_MBASCHKLSA_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MBASCHKLSA_CUR_2 CURSOR FOR
                SELECT 
                    LSA.CREATE_USER_ID,
                    LSA.CREATE_TIME,
                    LSA.UPDATE_USER_ID,
                    LSA.UPDATE_TIME,
                    LSA.FACTORY,
                    LSA.CHKLIST_ID,
                    LSA.REL_KEY,
                    LSA.HIST_SEQ,
                    LSA.QUERY_ID,
                    LSA.TRAN_TIME,
                    LSA.TRAN_USER_ID,
                    LSA.ANSWER,
                    LSQ.DISP_SEQ,
                    LSQ.REQUIRE_FLAG
                FROM MBASCHKLSA LSA, MBASCHKLSQ LSQ
                WHERE LSA.FACTORY = :MBASCHKLSA_N.FACTORY
                AND LSA.CHKLIST_ID = :MBASCHKLSA_N.CHKLIST_ID
                AND LSA.HIST_SEQ = :MBASCHKLSA_N.HIST_SEQ
                AND LSA.QUERY_ID >= :MBASCHKLSA_N.QUERY_ID
                AND LSQ.FACTORY = LSA.FACTORY
                AND LSQ.CHKLIST_ID = LSA.CHKLIST_ID
                AND LSQ.QUERY_ID = LSA.QUERY_ID
                ORDER BY LSQ.DISP_SEQ ASC;
            EXEC SQL OPEN DBC_MBASCHKLSA_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mbaschklsa", sel_type);
}


