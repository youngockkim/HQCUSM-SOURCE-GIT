    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MEDCCHRFML_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MEDCCHRFML_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_medcchrfml", sel_type);
}


/* Initialize Function */
void DBC_init_medcchrfml(struct MEDCCHRFML_TAG *MEDCCHRFML)
{
    /* memset by Space */
    memset(MEDCCHRFML, ' ', sizeof(struct MEDCCHRFML_TAG));
    
    MEDCCHRFML->COL_SET_VERSION = 0;
    MEDCCHRFML->SEQ_NUM = 0;
    MEDCCHRFML->USE_COL_SET_VERSION = 0;
    MEDCCHRFML->USE_UNIT_SEQ = 0;
    MEDCCHRFML->USE_VALUE_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_medcchrfml(struct MEDCCHRFML_N_TAG *MEDCCHRFML_N, struct MEDCCHRFML_TAG *MEDCCHRFML)
{
    /* memset by NULL */
    memset(MEDCCHRFML_N, '\0', sizeof(struct MEDCCHRFML_N_TAG));
    
    MEMCPY_AN(MEDCCHRFML_N->FACTORY, MEDCCHRFML->FACTORY, sizeof(MEDCCHRFML->FACTORY));
    MEMCPY_AN(MEDCCHRFML_N->COL_SET_ID, MEDCCHRFML->COL_SET_ID, sizeof(MEDCCHRFML->COL_SET_ID));
    MEDCCHRFML_N->COL_SET_VERSION = MEDCCHRFML->COL_SET_VERSION;
    MEMCPY_AN(MEDCCHRFML_N->CHAR_ID, MEDCCHRFML->CHAR_ID, sizeof(MEDCCHRFML->CHAR_ID));
    MEDCCHRFML_N->SEQ_NUM = MEDCCHRFML->SEQ_NUM;
    MEMCPY_AN(MEDCCHRFML_N->VALUE_TYPE, MEDCCHRFML->VALUE_TYPE, sizeof(MEDCCHRFML->VALUE_TYPE));
    MEMCPY_AN(MEDCCHRFML_N->USE_COL_SET_ID, MEDCCHRFML->USE_COL_SET_ID, sizeof(MEDCCHRFML->USE_COL_SET_ID));
    MEDCCHRFML_N->USE_COL_SET_VERSION = MEDCCHRFML->USE_COL_SET_VERSION;
    MEMCPY_AN(MEDCCHRFML_N->USE_CHAR_ID, MEDCCHRFML->USE_CHAR_ID, sizeof(MEDCCHRFML->USE_CHAR_ID));
    MEDCCHRFML_N->USE_UNIT_SEQ = MEDCCHRFML->USE_UNIT_SEQ;
    MEMCPY_AN(MEDCCHRFML_N->CALC_TYPE, MEDCCHRFML->CALC_TYPE, sizeof(MEDCCHRFML->CALC_TYPE));
    MEDCCHRFML_N->USE_VALUE_SEQ = MEDCCHRFML->USE_VALUE_SEQ;
    MEMCPY_AN(MEDCCHRFML_N->CONST_VALUE, MEDCCHRFML->CONST_VALUE, sizeof(MEDCCHRFML->CONST_VALUE));
    MEDCCHRFML_N->USE_FIRST_DATA[0] = MEDCCHRFML->USE_FIRST_DATA;
    MEDCCHRFML_N->USE_LAST_DATA[0] = MEDCCHRFML->USE_LAST_DATA;
    MEDCCHRFML_N->OVERRIDE_LOT[0] = MEDCCHRFML->OVERRIDE_LOT;
    MEDCCHRFML_N->OVERRIDE_RES[0] = MEDCCHRFML->OVERRIDE_RES;
    MEMCPY_AN(MEDCCHRFML_N->OPERATOR, MEDCCHRFML->OPERATOR, sizeof(MEDCCHRFML->OPERATOR));
    MEMCPY_AN(MEDCCHRFML_N->BRACKET, MEDCCHRFML->BRACKET, sizeof(MEDCCHRFML->BRACKET));
    MEMCPY_AN(MEDCCHRFML_N->RESV_FIELD_1, MEDCCHRFML->RESV_FIELD_1, sizeof(MEDCCHRFML->RESV_FIELD_1));
    MEMCPY_AN(MEDCCHRFML_N->RESV_FIELD_2, MEDCCHRFML->RESV_FIELD_2, sizeof(MEDCCHRFML->RESV_FIELD_2));
    MEMCPY_AN(MEDCCHRFML_N->RESV_FIELD_3, MEDCCHRFML->RESV_FIELD_3, sizeof(MEDCCHRFML->RESV_FIELD_3));
    MEMCPY_AN(MEDCCHRFML_N->RESV_FIELD_4, MEDCCHRFML->RESV_FIELD_4, sizeof(MEDCCHRFML->RESV_FIELD_4));
    MEMCPY_AN(MEDCCHRFML_N->RESV_FIELD_5, MEDCCHRFML->RESV_FIELD_5, sizeof(MEDCCHRFML->RESV_FIELD_5));
    MEMCPY_AN(MEDCCHRFML_N->CREATE_USER_ID, MEDCCHRFML->CREATE_USER_ID, sizeof(MEDCCHRFML->CREATE_USER_ID));
    MEMCPY_AN(MEDCCHRFML_N->CREATE_TIME, MEDCCHRFML->CREATE_TIME, sizeof(MEDCCHRFML->CREATE_TIME));
    MEMCPY_AN(MEDCCHRFML_N->UPDATE_USER_ID, MEDCCHRFML->UPDATE_USER_ID, sizeof(MEDCCHRFML->UPDATE_USER_ID));
    MEMCPY_AN(MEDCCHRFML_N->UPDATE_TIME, MEDCCHRFML->UPDATE_TIME, sizeof(MEDCCHRFML->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_medcchrfml(struct MEDCCHRFML_N_TAG *MEDCCHRFML_N, struct MEDCCHRFML_TAG *MEDCCHRFML)
{
    MEMCPY_DN(MEDCCHRFML->FACTORY, MEDCCHRFML_N->FACTORY, sizeof(MEDCCHRFML->FACTORY));
    MEMCPY_DN(MEDCCHRFML->COL_SET_ID, MEDCCHRFML_N->COL_SET_ID, sizeof(MEDCCHRFML->COL_SET_ID));
    MEDCCHRFML->COL_SET_VERSION = MEDCCHRFML_N->COL_SET_VERSION;
    MEMCPY_DN(MEDCCHRFML->CHAR_ID, MEDCCHRFML_N->CHAR_ID, sizeof(MEDCCHRFML->CHAR_ID));
    MEDCCHRFML->SEQ_NUM = MEDCCHRFML_N->SEQ_NUM;
    MEMCPY_DN(MEDCCHRFML->VALUE_TYPE, MEDCCHRFML_N->VALUE_TYPE, sizeof(MEDCCHRFML->VALUE_TYPE));
    MEMCPY_DN(MEDCCHRFML->USE_COL_SET_ID, MEDCCHRFML_N->USE_COL_SET_ID, sizeof(MEDCCHRFML->USE_COL_SET_ID));
    MEDCCHRFML->USE_COL_SET_VERSION = MEDCCHRFML_N->USE_COL_SET_VERSION;
    MEMCPY_DN(MEDCCHRFML->USE_CHAR_ID, MEDCCHRFML_N->USE_CHAR_ID, sizeof(MEDCCHRFML->USE_CHAR_ID));
    MEDCCHRFML->USE_UNIT_SEQ = MEDCCHRFML_N->USE_UNIT_SEQ;
    MEMCPY_DN(MEDCCHRFML->CALC_TYPE, MEDCCHRFML_N->CALC_TYPE, sizeof(MEDCCHRFML->CALC_TYPE));
    MEDCCHRFML->USE_VALUE_SEQ = MEDCCHRFML_N->USE_VALUE_SEQ;
    MEMCPY_DN(MEDCCHRFML->CONST_VALUE, MEDCCHRFML_N->CONST_VALUE, sizeof(MEDCCHRFML->CONST_VALUE));
    MEDCCHRFML->USE_FIRST_DATA = MEDCCHRFML_N->USE_FIRST_DATA[0];
    MEDCCHRFML->USE_LAST_DATA = MEDCCHRFML_N->USE_LAST_DATA[0];
    MEDCCHRFML->OVERRIDE_LOT = MEDCCHRFML_N->OVERRIDE_LOT[0];
    MEDCCHRFML->OVERRIDE_RES = MEDCCHRFML_N->OVERRIDE_RES[0];
    MEMCPY_DN(MEDCCHRFML->OPERATOR, MEDCCHRFML_N->OPERATOR, sizeof(MEDCCHRFML->OPERATOR));
    MEMCPY_DN(MEDCCHRFML->BRACKET, MEDCCHRFML_N->BRACKET, sizeof(MEDCCHRFML->BRACKET));
    MEMCPY_DN(MEDCCHRFML->RESV_FIELD_1, MEDCCHRFML_N->RESV_FIELD_1, sizeof(MEDCCHRFML->RESV_FIELD_1));
    MEMCPY_DN(MEDCCHRFML->RESV_FIELD_2, MEDCCHRFML_N->RESV_FIELD_2, sizeof(MEDCCHRFML->RESV_FIELD_2));
    MEMCPY_DN(MEDCCHRFML->RESV_FIELD_3, MEDCCHRFML_N->RESV_FIELD_3, sizeof(MEDCCHRFML->RESV_FIELD_3));
    MEMCPY_DN(MEDCCHRFML->RESV_FIELD_4, MEDCCHRFML_N->RESV_FIELD_4, sizeof(MEDCCHRFML->RESV_FIELD_4));
    MEMCPY_DN(MEDCCHRFML->RESV_FIELD_5, MEDCCHRFML_N->RESV_FIELD_5, sizeof(MEDCCHRFML->RESV_FIELD_5));
    MEMCPY_DN(MEDCCHRFML->CREATE_USER_ID, MEDCCHRFML_N->CREATE_USER_ID, sizeof(MEDCCHRFML->CREATE_USER_ID));
    MEMCPY_DN(MEDCCHRFML->CREATE_TIME, MEDCCHRFML_N->CREATE_TIME, sizeof(MEDCCHRFML->CREATE_TIME));
    MEMCPY_DN(MEDCCHRFML->UPDATE_USER_ID, MEDCCHRFML_N->UPDATE_USER_ID, sizeof(MEDCCHRFML->UPDATE_USER_ID));
    MEMCPY_DN(MEDCCHRFML->UPDATE_TIME, MEDCCHRFML_N->UPDATE_TIME, sizeof(MEDCCHRFML->UPDATE_TIME));
}


