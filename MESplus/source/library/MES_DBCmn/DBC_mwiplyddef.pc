/* SQL CURSOR CLOSE Function */
void DBC_close_mwiplyddef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPLYDDEF_CUR_1;
            break;

        case 2:
			 EXEC SQL CLOSE DBC_MWIPLYDDEF_CUR_2;
            break;

        case 3:
			 EXEC SQL CLOSE DBC_MWIPLYDDEF_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwiplyddef", sel_type);
}


/* Initialize Function */
void DBC_init_mwiplyddef(struct MWIPLYDDEF_TAG *MWIPLYDDEF)
{
    /* memset by Space */
    memset(MWIPLYDDEF, ' ', sizeof(struct MWIPLYDDEF_TAG));
    
    MWIPLYDDEF->MAT_VER = 0;
    MWIPLYDDEF->FLOW_SEQ_NUM = 0;
    MWIPLYDDEF->TOT_UPPER_YIELD = 0;
    MWIPLYDDEF->TOT_LOWER_YIELD = 0;
}


/* Add Null Function */
void DBC_add_null_mwiplyddef(struct MWIPLYDDEF_N_TAG *MWIPLYDDEF_N, struct MWIPLYDDEF_TAG *MWIPLYDDEF)
{
    /* memset by NULL */
    memset(MWIPLYDDEF_N, '\0', sizeof(struct MWIPLYDDEF_N_TAG));
    
    MEMCPY_AN(MWIPLYDDEF_N->FACTORY, MWIPLYDDEF->FACTORY, sizeof(MWIPLYDDEF->FACTORY));
    MEMCPY_AN(MWIPLYDDEF_N->MAT_ID, MWIPLYDDEF->MAT_ID, sizeof(MWIPLYDDEF->MAT_ID));
    MWIPLYDDEF_N->MAT_VER = MWIPLYDDEF->MAT_VER;
    MEMCPY_AN(MWIPLYDDEF_N->FLOW, MWIPLYDDEF->FLOW, sizeof(MWIPLYDDEF->FLOW));
    MWIPLYDDEF_N->FLOW_SEQ_NUM = MWIPLYDDEF->FLOW_SEQ_NUM;
