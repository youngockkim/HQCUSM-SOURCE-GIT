                    AND LOT_CMF_3 = :MWIPLYDDEF_N.LOT_CMF_3
                    AND LOT_CMF_4 = :MWIPLYDDEF_N.LOT_CMF_4
                    AND LOT_CMF_5 = :MWIPLYDDEF_N.LOT_CMF_5
                    AND LOT_CMF_6 = :MWIPLYDDEF_N.LOT_CMF_6
                    AND LOT_CMF_7 = :MWIPLYDDEF_N.LOT_CMF_7
                    AND LOT_CMF_8 = :MWIPLYDDEF_N.LOT_CMF_8
                    AND LOT_CMF_9 = :MWIPLYDDEF_N.LOT_CMF_9
                    AND LOT_CMF_10 = :MWIPLYDDEF_N.LOT_CMF_10
                    AND LOT_CMF_11 = :MWIPLYDDEF_N.LOT_CMF_11
                    AND LOT_CMF_12 = :MWIPLYDDEF_N.LOT_CMF_12
                    AND LOT_CMF_13 = :MWIPLYDDEF_N.LOT_CMF_13
                    AND LOT_CMF_14 = :MWIPLYDDEF_N.LOT_CMF_14
                    AND LOT_CMF_15 = :MWIPLYDDEF_N.LOT_CMF_15
                    AND LOT_CMF_16 = :MWIPLYDDEF_N.LOT_CMF_16
                    AND LOT_CMF_17 = :MWIPLYDDEF_N.LOT_CMF_17
                    AND LOT_CMF_18 = :MWIPLYDDEF_N.LOT_CMF_18
                    AND LOT_CMF_19 = :MWIPLYDDEF_N.LOT_CMF_19
                    AND LOT_CMF_20 = :MWIPLYDDEF_N.LOT_CMF_20
                ORDER BY FACTORY ASC,
                    MAT_ID ASC,
                    MAT_VER ASC,
                    FLOW ASC,
                    FLOW_SEQ_NUM ASC,
                    OPER ASC,
                    RES_ID ASC,
                    SUBRES_ID ASC,
                    LOT_CMF_1 ASC,
                    LOT_CMF_2 ASC,
                    LOT_CMF_3 ASC,
                    LOT_CMF_4 ASC,
                    LOT_CMF_5 ASC,
                    LOT_CMF_6 ASC,
                    LOT_CMF_7 ASC,
                    LOT_CMF_8 ASC,
                    LOT_CMF_9 ASC,
                    LOT_CMF_10 ASC,
                    LOT_CMF_11 ASC,
                    LOT_CMF_12 ASC,
                    LOT_CMF_13 ASC,
                    LOT_CMF_14 ASC,
                    LOT_CMF_15 ASC,
                    LOT_CMF_16 ASC,
                    LOT_CMF_17 ASC,
                    LOT_CMF_18 ASC,
                    LOT_CMF_19 ASC,
                    LOT_CMF_20 ASC,
                    KEY_CODE ASC;
            EXEC SQL OPEN DBC_MWIPLYDDEF_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwiplyddef", sel_type);
}


