/* SQL UPDATE Function */
void DBC_update_mwiplyddef(int sel_type, struct MWIPLYDDEF_TAG *MWIPLYDDEF)
{
	EXEC SQL BEGIN DECLARE SECTION;
    struct MWIPLYDDEF_N_TAG MWIPLYDDEF_N;
	EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiplyddef(&MWIPLYDDEF_N, MWIPLYDDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MWIPLYDDEF SET
                    YIELD_TYPE = :MWIPLYDDEF_N.YIELD_TYPE,
					CV_TYPE = :MWIPLYDDEF_N.CV_TYPE,
                    UNIT = :MWIPLYDDEF_N.UNIT,
