/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mqcmbatdft(int sel_type, struct MQCMBATDFT_TAG *MQCMBATDFT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MQCMBATDFT_N_TAG MQCMBATDFT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mqcmbatdft(&MQCMBATDFT_N, MQCMBATDFT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MQCMBATDFT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    BATCH_ID,
                    BATCH_HIST_SEQ,
                    INSP_ITEM,
                    DEFECT_CODE,
                    INSP_SET_ID,
                    INSP_SET_VERSION,
                    INSP_METHOD,
                    DEFECT_GROUP,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    INSP_SEQ,
                    USER_ID,
                    TRAN_TIME
                FROM MQCMBATDFT
                WHERE FACTORY = :MQCMBATDFT_N.FACTORY
                    AND BATCH_ID = :MQCMBATDFT_N.BATCH_ID
                    AND BATCH_HIST_SEQ = :MQCMBATDFT_N.BATCH_HIST_SEQ
                    AND INSP_SET_ID = :MQCMBATDFT_N.INSP_SET_ID
                    AND INSP_SET_VERSION = :MQCMBATDFT_N.INSP_SET_VERSION
                    AND INSP_ITEM = :MQCMBATDFT_N.INSP_ITEM
                ORDER BY FACTORY ASC,
                    BATCH_ID ASC,
                    BATCH_HIST_SEQ ASC,
                    INSP_ITEM ASC,
                    DEFECT_CODE ASC;
            EXEC SQL OPEN DBC_MQCMBATDFT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mqcmbatdft", sel_type);
}


