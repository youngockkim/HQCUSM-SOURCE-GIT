/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipbatrul(int sel_type, struct MWIPBATRUL_TAG *MWIPBATRUL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPBATRUL_N_TAG MWIPBATRUL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipbatrul(&MWIPBATRUL_N, MWIPBATRUL);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPBATRUL_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    CRT_RULE_ID,
                    CRT_RULE_DESC,
                    GEN_RULE_ID,
                    OVERRIDE_FLAG,
                    BATCH_TYPE,
                    MIX_LOT_FLAG,
                    MIN_QTIME,
                    BATCH_COUNT,
                    UNDER_FLAG,
                    MATCH_ITEM,
                    NPW_COUNT,
                    NPW_POSITION,
                    CUSTOM_RULE,
                    CUSTOM_RULE_FOR_CHECK,
                    SEND_LOT_TO_CUSTOM_RULE_FLAG,
                    MAX_SEND_LOT_COUNT,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPBATRUL
                WHERE FACTORY = :MWIPBATRUL_N.FACTORY
                    AND CRT_RULE_ID >= :MWIPBATRUL_N.CRT_RULE_ID
                ORDER BY CRT_RULE_ID ASC;
            EXEC SQL OPEN DBC_MWIPBATRUL_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipbatrul", sel_type);
}


