    MEMCPY_DN(MWIPBATRUL->NPW_POSITION, MWIPBATRUL_N->NPW_POSITION, sizeof(MWIPBATRUL->NPW_POSITION));
    
    MEMCPY_DN(MWIPBATRUL->CUSTOM_RULE, MWIPBATRUL_N->CUSTOM_RULE, sizeof(MWIPBATRUL->CUSTOM_RULE));
    MEMCPY_DN(MWIPBATRUL->CUSTOM_RULE_FOR_CHECK, MWIPBATRUL_N->CUSTOM_RULE_FOR_CHECK, sizeof(MWIPBATRUL->CUSTOM_RULE_FOR_CHECK));
    MWIPBATRUL->SEND_LOT_TO_CUSTOM_RULE_FLAG = MWIPBATRUL_N->SEND_LOT_TO_CUSTOM_RULE_FLAG[0];
    MWIPBATRUL->MAX_SEND_LOT_COUNT = MWIPBATRUL_N->MAX_SEND_LOT_COUNT;
        
    MEMCPY_DN(MWIPBATRUL->CREATE_USER_ID, MWIPBATRUL_N->CREATE_USER_ID, sizeof(MWIPBATRUL->CREATE_USER_ID));
    MEMCPY_DN(MWIPBATRUL->CREATE_TIME, MWIPBATRUL_N->CREATE_TIME, sizeof(MWIPBATRUL->CREATE_TIME));
    MEMCPY_DN(MWIPBATRUL->UPDATE_USER_ID, MWIPBATRUL_N->UPDATE_USER_ID, sizeof(MWIPBATRUL->UPDATE_USER_ID));
    MEMCPY_DN(MWIPBATRUL->UPDATE_TIME, MWIPBATRUL_N->UPDATE_TIME, sizeof(MWIPBATRUL->UPDATE_TIME));
}


