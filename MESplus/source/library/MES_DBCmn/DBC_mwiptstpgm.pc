                    AND RES_GRP_10 = :MWIPTSTPGM_N.RES_GRP_10
                    AND (APPLY_START_TIME = ' ' OR APPLY_START_TIME < :MWIPTSTPGM_N.APPLY_START_TIME) 
                    AND (APPLY_END_TIME = ' ' OR APPLY_END_TIME > :MWIPTSTPGM_N.APPLY_START_TIME)
                    AND RELEASE_FLAG = 'Y';
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mwiptstpgm_scalar", sel_type);

    return d_value;
}


