/* Del Null Function */
void DBC_del_null_mwiptstpgm(struct MWIPTSTPGM_N_TAG *MWIPTSTPGM_N, struct MWIPTSTPGM_TAG *MWIPTSTPGM)
{
    MEMCPY_DN(MWIPTSTPGM->CREATE_USER_ID, MWIPTSTPGM_N->CREATE_USER_ID, sizeof(MWIPTSTPGM->CREATE_USER_ID));
    MEMCPY_DN(MWIPTSTPGM->CREATE_TIME, MWIPTSTPGM_N->CREATE_TIME, sizeof(MWIPTSTPGM->CREATE_TIME));
    MEMCPY_DN(MWIPTSTPGM->UPDATE_USER_ID, MWIPTSTPGM_N->UPDATE_USER_ID, sizeof(MWIPTSTPGM->UPDATE_USER_ID));
    MEMCPY_DN(MWIPTSTPGM->UPDATE_TIME, MWIPTSTPGM_N->UPDATE_TIME, sizeof(MWIPTSTPGM->UPDATE_TIME));
    MEMCPY_DN(MWIPTSTPGM->FACTORY, MWIPTSTPGM_N->FACTORY, sizeof(MWIPTSTPGM->FACTORY));
    MWIPTSTPGM->REL_LEVEL = MWIPTSTPGM_N->REL_LEVEL[0];
    MEMCPY_DN(MWIPTSTPGM->MAT_ID, MWIPTSTPGM_N->MAT_ID, sizeof(MWIPTSTPGM->MAT_ID));
    MWIPTSTPGM->MAT_VER = MWIPTSTPGM_N->MAT_VER;
    MEMCPY_DN(MWIPTSTPGM->FLOW, MWIPTSTPGM_N->FLOW, sizeof(MWIPTSTPGM->FLOW));
    MWIPTSTPGM->FLOW_SEQ_NUM = MWIPTSTPGM_N->FLOW_SEQ_NUM;
