/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwiptstpgm(int sel_type, struct MWIPTSTPGM_TAG *MWIPTSTPGM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPTSTPGM_N_TAG MWIPTSTPGM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwiptstpgm(&MWIPTSTPGM_N, MWIPTSTPGM);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPTSTPGM_CUR_1 CURSOR FOR
                SELECT * FROM (
                    SELECT ROWNUM ROWSEQ, PGM.* FROM (
                        SELECT 
                            LOT_CMF_1,
                            LOT_CMF_2,
                            LOT_CMF_3,
                            LOT_CMF_4,
                            LOT_CMF_5,
                            LOT_CMF_6,
                            LOT_CMF_7,
                            LOT_CMF_8,
                            LOT_CMF_9,
                            LOT_CMF_10,
                            RES_GRP_1,
                            RES_GRP_2,
                            RES_GRP_3,
                            RES_GRP_4,
                            RES_GRP_5,
                            RES_GRP_6,
                            RES_GRP_7,
                            RES_GRP_8,
                            RES_GRP_9,
                            RES_GRP_10
                        FROM MWIPTSTPGM
                        WHERE FACTORY = :MWIPTSTPGM_N.FACTORY
                            AND REL_LEVEL = :MWIPTSTPGM_N.REL_LEVEL
                            AND MAT_ID = :MWIPTSTPGM_N.MAT_ID
                            AND MAT_VER = :MWIPTSTPGM_N.MAT_VER
                            AND FLOW = :MWIPTSTPGM_N.FLOW
                            AND FLOW_SEQ_NUM = :MWIPTSTPGM_N.FLOW_SEQ_NUM
                            AND OPER = :MWIPTSTPGM_N.OPER
                            AND RES_ID = :MWIPTSTPGM_N.RES_ID
                            AND RESG_ID = :MWIPTSTPGM_N.RESG_ID
                            AND RES_TYPE = :MWIPTSTPGM_N.RES_TYPE
                        GROUP BY 
                            LOT_CMF_1,
                            LOT_CMF_2,
                            LOT_CMF_3,
                            LOT_CMF_4,
                            LOT_CMF_5,
                            LOT_CMF_6,
                            LOT_CMF_7,
                            LOT_CMF_8,
                            LOT_CMF_9,
                            LOT_CMF_10,
                            RES_GRP_1,
                            RES_GRP_2,
                            RES_GRP_3,
                            RES_GRP_4,
                            RES_GRP_5,
                            RES_GRP_6,
                            RES_GRP_7,
                            RES_GRP_8,
                            RES_GRP_9,
                            RES_GRP_10
                        ORDER BY
                            LOT_CMF_1  ASC,
                            LOT_CMF_2  ASC,
                            LOT_CMF_3  ASC,
                            LOT_CMF_4  ASC,
                            LOT_CMF_5  ASC,
                            LOT_CMF_6  ASC,
                            LOT_CMF_7  ASC,
                            LOT_CMF_8  ASC,
                            LOT_CMF_9  ASC,
                            LOT_CMF_10 ASC,
                            RES_GRP_1  ASC,
                            RES_GRP_2  ASC,
                            RES_GRP_3  ASC,
                            RES_GRP_4  ASC,
                            RES_GRP_5  ASC,
                            RES_GRP_6  ASC,
                            RES_GRP_7  ASC,
                            RES_GRP_8  ASC,
                            RES_GRP_9  ASC,
                            RES_GRP_10 ASC
                        ) PGM
                    )
                WHERE ROWSEQ >= :DBC_Q_COND_N.FROM_SEQ
                ORDER BY ROWSEQ ASC;
            EXEC SQL OPEN DBC_MWIPTSTPGM_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPTSTPGM_CUR_2 CURSOR FOR
                SELECT 
                    TEST_VERSION,
                    DESCRIPTION
                FROM MWIPTSTPGM
                WHERE FACTORY = :MWIPTSTPGM_N.FACTORY
                    AND REL_LEVEL = :MWIPTSTPGM_N.REL_LEVEL
                    AND MAT_ID = :MWIPTSTPGM_N.MAT_ID
                    AND MAT_VER = :MWIPTSTPGM_N.MAT_VER
                    AND FLOW = :MWIPTSTPGM_N.FLOW
                    AND FLOW_SEQ_NUM = :MWIPTSTPGM_N.FLOW_SEQ_NUM
                    AND OPER = :MWIPTSTPGM_N.OPER
                    AND RES_ID = :MWIPTSTPGM_N.RES_ID
                    AND RESG_ID = :MWIPTSTPGM_N.RESG_ID
                    AND RES_TYPE = :MWIPTSTPGM_N.RES_TYPE
                    AND LOT_CMF_1 = :MWIPTSTPGM_N.LOT_CMF_1
                    AND LOT_CMF_2 = :MWIPTSTPGM_N.LOT_CMF_2
                    AND LOT_CMF_3 = :MWIPTSTPGM_N.LOT_CMF_3
                    AND LOT_CMF_4 = :MWIPTSTPGM_N.LOT_CMF_4
                    AND LOT_CMF_5 = :MWIPTSTPGM_N.LOT_CMF_5
                    AND LOT_CMF_6 = :MWIPTSTPGM_N.LOT_CMF_6
                    AND LOT_CMF_7 = :MWIPTSTPGM_N.LOT_CMF_7
                    AND LOT_CMF_8 = :MWIPTSTPGM_N.LOT_CMF_8
                    AND LOT_CMF_9 = :MWIPTSTPGM_N.LOT_CMF_9
                    AND LOT_CMF_10 = :MWIPTSTPGM_N.LOT_CMF_10
                    AND RES_GRP_1 = :MWIPTSTPGM_N.RES_GRP_1
                    AND RES_GRP_2 = :MWIPTSTPGM_N.RES_GRP_2
                    AND RES_GRP_3 = :MWIPTSTPGM_N.RES_GRP_3
                    AND RES_GRP_4 = :MWIPTSTPGM_N.RES_GRP_4
                    AND RES_GRP_5 = :MWIPTSTPGM_N.RES_GRP_5
                    AND RES_GRP_6 = :MWIPTSTPGM_N.RES_GRP_6
                    AND RES_GRP_7 = :MWIPTSTPGM_N.RES_GRP_7
                    AND RES_GRP_8 = :MWIPTSTPGM_N.RES_GRP_8
                    AND RES_GRP_9 = :MWIPTSTPGM_N.RES_GRP_9
                    AND RES_GRP_10 = :MWIPTSTPGM_N.RES_GRP_10
                    AND TEST_VERSION >= :MWIPTSTPGM_N.TEST_VERSION
                ORDER BY
                    TEST_VERSION DESC;
            EXEC SQL OPEN DBC_MWIPTSTPGM_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MWIPTSTPGM_CUR_3 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    REL_LEVEL,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_ID,
                    RESG_ID,
                    RES_TYPE,
                    LOT_CMF_1,
                    LOT_CMF_2,
                    LOT_CMF_3,
                    LOT_CMF_4,
                    LOT_CMF_5,
                    LOT_CMF_6,
                    LOT_CMF_7,
                    LOT_CMF_8,
                    LOT_CMF_9,
                    LOT_CMF_10,
                    RES_GRP_1,
                    RES_GRP_2,
                    RES_GRP_3,
                    RES_GRP_4,
                    RES_GRP_5,
                    RES_GRP_6,
                    RES_GRP_7,
                    RES_GRP_8,
                    RES_GRP_9,
                    RES_GRP_10,
                    TEST_VERSION,
                    TEST_PGM_NAME,
                    TEST_PGM_VER,
                    DESCRIPTION,
                    TEST_TIME,
                    INDEX_TIME,
                    TEST_TEMP,
                    PROGRAM_DIR,
                    APPLY_START_TIME,
                    APPLY_END_TIME,
                    APPROVAL_FLAG,
                    APPROVAL_USER_ID,
                    APPROVAL_TIME,
                    RELEASE_FLAG,
                    RELEASE_USER_ID,
                    RELEASE_TIME,
                    TEST_PGM_CMF_1,
                    TEST_PGM_CMF_2,
                    TEST_PGM_CMF_3,
                    TEST_PGM_CMF_4,
                    TEST_PGM_CMF_5,
                    TEST_PGM_CMF_6,
                    TEST_PGM_CMF_7,
                    TEST_PGM_CMF_8,
                    TEST_PGM_CMF_9,
                    TEST_PGM_CMF_10,
                    TEST_PGM_CMF_11,
                    TEST_PGM_CMF_12,
                    TEST_PGM_CMF_13,
                    TEST_PGM_CMF_14,
                    TEST_PGM_CMF_15,
                    TEST_PGM_CMF_16,
                    TEST_PGM_CMF_17,
                    TEST_PGM_CMF_18,
                    TEST_PGM_CMF_19,
                    TEST_PGM_CMF_20
                FROM MWIPTSTPGM
                WHERE FACTORY = :MWIPTSTPGM_N.FACTORY
                    AND MAT_ID = :MWIPTSTPGM_N.MAT_ID
                    AND MAT_VER = :MWIPTSTPGM_N.MAT_VER
                    AND FLOW = :MWIPTSTPGM_N.FLOW
                    AND FLOW_SEQ_NUM = :MWIPTSTPGM_N.FLOW_SEQ_NUM
                    AND OPER = :MWIPTSTPGM_N.OPER
                    AND RES_ID = :MWIPTSTPGM_N.RES_ID
                    AND RESG_ID = :MWIPTSTPGM_N.RESG_ID
                    AND RES_TYPE = :MWIPTSTPGM_N.RES_TYPE
                    AND LOT_CMF_1 = :MWIPTSTPGM_N.LOT_CMF_1
                    AND LOT_CMF_2 = :MWIPTSTPGM_N.LOT_CMF_2
                    AND LOT_CMF_3 = :MWIPTSTPGM_N.LOT_CMF_3
                    AND LOT_CMF_4 = :MWIPTSTPGM_N.LOT_CMF_4
                    AND LOT_CMF_5 = :MWIPTSTPGM_N.LOT_CMF_5
                    AND LOT_CMF_6 = :MWIPTSTPGM_N.LOT_CMF_6
                    AND LOT_CMF_7 = :MWIPTSTPGM_N.LOT_CMF_7
                    AND LOT_CMF_8 = :MWIPTSTPGM_N.LOT_CMF_8
                    AND LOT_CMF_9 = :MWIPTSTPGM_N.LOT_CMF_9
                    AND LOT_CMF_10 = :MWIPTSTPGM_N.LOT_CMF_10
                    AND RES_GRP_1 = :MWIPTSTPGM_N.RES_GRP_1
                    AND RES_GRP_2 = :MWIPTSTPGM_N.RES_GRP_2
                    AND RES_GRP_3 = :MWIPTSTPGM_N.RES_GRP_3
                    AND RES_GRP_4 = :MWIPTSTPGM_N.RES_GRP_4
                    AND RES_GRP_5 = :MWIPTSTPGM_N.RES_GRP_5
                    AND RES_GRP_6 = :MWIPTSTPGM_N.RES_GRP_6
                    AND RES_GRP_7 = :MWIPTSTPGM_N.RES_GRP_7
                    AND RES_GRP_8 = :MWIPTSTPGM_N.RES_GRP_8
                    AND RES_GRP_9 = :MWIPTSTPGM_N.RES_GRP_9
                    AND RES_GRP_10 = :MWIPTSTPGM_N.RES_GRP_10
                    AND (APPLY_START_TIME = ' ' OR APPLY_START_TIME < :MWIPTSTPGM_N.APPLY_START_TIME) 
                    AND (APPLY_END_TIME = ' ' OR APPLY_END_TIME > :MWIPTSTPGM_N.APPLY_START_TIME)
                    AND RELEASE_FLAG = 'Y'
                ORDER BY
                    TEST_VERSION DESC;
            EXEC SQL OPEN DBC_MWIPTSTPGM_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mwiptstpgm", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mwiptstpgm(int sel_type, struct MWIPTSTPGM_TAG *MWIPTSTPGM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPTSTPGM_N_TAG MWIPTSTPGM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MWIPTSTPGM_CUR_1 INTO
                :DBC_Q_COND_N.FROM_SEQ,
                :MWIPTSTPGM_N.LOT_CMF_1,
                :MWIPTSTPGM_N.LOT_CMF_2,
                :MWIPTSTPGM_N.LOT_CMF_3,
                :MWIPTSTPGM_N.LOT_CMF_4,
                :MWIPTSTPGM_N.LOT_CMF_5,
                :MWIPTSTPGM_N.LOT_CMF_6,
                :MWIPTSTPGM_N.LOT_CMF_7,
                :MWIPTSTPGM_N.LOT_CMF_8,
                :MWIPTSTPGM_N.LOT_CMF_9,
                :MWIPTSTPGM_N.LOT_CMF_10,
                :MWIPTSTPGM_N.RES_GRP_1,
                :MWIPTSTPGM_N.RES_GRP_2,
                :MWIPTSTPGM_N.RES_GRP_3,
                :MWIPTSTPGM_N.RES_GRP_4,
                :MWIPTSTPGM_N.RES_GRP_5,
                :MWIPTSTPGM_N.RES_GRP_6,
                :MWIPTSTPGM_N.RES_GRP_7,
                :MWIPTSTPGM_N.RES_GRP_8,
                :MWIPTSTPGM_N.RES_GRP_9,
                :MWIPTSTPGM_N.RES_GRP_10;

                DB_del_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);
            break;

        case 2:
            EXEC SQL FETCH DBC_MWIPTSTPGM_CUR_2 INTO
                :MWIPTSTPGM_N.TEST_VERSION,
                :MWIPTSTPGM_N.DESCRIPTION;
            break;

        case 3:
            EXEC SQL FETCH DBC_MWIPTSTPGM_CUR_3 INTO
                    :MWIPTSTPGM_N.CREATE_USER_ID,
                    :MWIPTSTPGM_N.CREATE_TIME,
                    :MWIPTSTPGM_N.UPDATE_USER_ID,
                    :MWIPTSTPGM_N.UPDATE_TIME,
                    :MWIPTSTPGM_N.FACTORY,
                    :MWIPTSTPGM_N.REL_LEVEL,
                    :MWIPTSTPGM_N.MAT_ID,
                    :MWIPTSTPGM_N.MAT_VER,
                    :MWIPTSTPGM_N.FLOW,
                    :MWIPTSTPGM_N.FLOW_SEQ_NUM,
                    :MWIPTSTPGM_N.OPER,
                    :MWIPTSTPGM_N.RES_ID,
                    :MWIPTSTPGM_N.RESG_ID,
                    :MWIPTSTPGM_N.RES_TYPE,
                    :MWIPTSTPGM_N.LOT_CMF_1,
                    :MWIPTSTPGM_N.LOT_CMF_2,
                    :MWIPTSTPGM_N.LOT_CMF_3,
                    :MWIPTSTPGM_N.LOT_CMF_4,
                    :MWIPTSTPGM_N.LOT_CMF_5,
                    :MWIPTSTPGM_N.LOT_CMF_6,
                    :MWIPTSTPGM_N.LOT_CMF_7,
                    :MWIPTSTPGM_N.LOT_CMF_8,
                    :MWIPTSTPGM_N.LOT_CMF_9,
                    :MWIPTSTPGM_N.LOT_CMF_10,
                    :MWIPTSTPGM_N.RES_GRP_1,
                    :MWIPTSTPGM_N.RES_GRP_2,
                    :MWIPTSTPGM_N.RES_GRP_3,
                    :MWIPTSTPGM_N.RES_GRP_4,
                    :MWIPTSTPGM_N.RES_GRP_5,
                    :MWIPTSTPGM_N.RES_GRP_6,
                    :MWIPTSTPGM_N.RES_GRP_7,
                    :MWIPTSTPGM_N.RES_GRP_8,
                    :MWIPTSTPGM_N.RES_GRP_9,
                    :MWIPTSTPGM_N.RES_GRP_10,
                    :MWIPTSTPGM_N.TEST_VERSION,
                    :MWIPTSTPGM_N.TEST_PGM_NAME,
                    :MWIPTSTPGM_N.TEST_PGM_VER,
                    :MWIPTSTPGM_N.DESCRIPTION,
                    :MWIPTSTPGM_N.TEST_TIME,
                    :MWIPTSTPGM_N.INDEX_TIME,
                    :MWIPTSTPGM_N.TEST_TEMP,
                    :MWIPTSTPGM_N.PROGRAM_DIR,
                    :MWIPTSTPGM_N.APPLY_START_TIME,
                    :MWIPTSTPGM_N.APPLY_END_TIME,
                    :MWIPTSTPGM_N.APPROVAL_FLAG,
                    :MWIPTSTPGM_N.APPROVAL_USER_ID,
                    :MWIPTSTPGM_N.APPROVAL_TIME,
                    :MWIPTSTPGM_N.RELEASE_FLAG,
                    :MWIPTSTPGM_N.RELEASE_USER_ID,
                    :MWIPTSTPGM_N.RELEASE_TIME,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_1,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_2,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_3,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_4,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_5,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_6,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_7,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_8,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_9,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_10,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_11,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_12,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_13,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_14,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_15,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_16,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_17,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_18,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_19,
                    :MWIPTSTPGM_N.TEST_PGM_CMF_20;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwiptstpgm(&MWIPTSTPGM_N, MWIPTSTPGM);
    }

    DB_stop_query_timer("DBC_fetch_mwiptstpgm", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwiptstpgm(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPTSTPGM_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWIPTSTPGM_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MWIPTSTPGM_CUR_3;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("DBC_close_mwiptstpgm", sel_type);
}


/* Initialize Function */
void DBC_init_mwiptstpgm(struct MWIPTSTPGM_TAG *MWIPTSTPGM)
{
    /* memset by Space */
    memset(MWIPTSTPGM, ' ', sizeof(struct MWIPTSTPGM_TAG));
    
    MWIPTSTPGM->MAT_VER = 0;
    MWIPTSTPGM->FLOW_SEQ_NUM = 0;
    MWIPTSTPGM->TEST_VERSION = 0;
}


