    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrtddspres(&MRTDDSPRES_N, MRTDDSPRES);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRTDDSPRES_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    DSP_ID,
                    RES_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRTDDSPRES
                WHERE FACTORY = :MRTDDSPRES_N.FACTORY
                    AND DSP_ID = :MRTDDSPRES_N.DSP_ID
                    AND RES_ID >= :MRTDDSPRES_N.RES_ID
                ORDER BY RES_ID ASC;
            EXEC SQL OPEN DBC_MRTDDSPRES_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrtddspres", sel_type);
}


