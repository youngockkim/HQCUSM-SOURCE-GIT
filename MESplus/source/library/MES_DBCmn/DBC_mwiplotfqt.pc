                :MWIPLOTFQT_N.LOT_CMF_1,
                :MWIPLOTFQT_N.LOT_CMF_2,
                :MWIPLOTFQT_N.LOT_CMF_3,
                :MWIPLOTFQT_N.LOT_CMF_4,
                :MWIPLOTFQT_N.LOT_CMF_5,
                :MWIPLOTFQT_N.LOT_CMF_6,
                :MWIPLOTFQT_N.LOT_CMF_7,
                :MWIPLOTFQT_N.LOT_CMF_8,
                :MWIPLOTFQT_N.LOT_CMF_9,
                :MWIPLOTFQT_N.LOT_CMF_10,
                :MWIPLOTFQT_N.LOT_CMF_11,
                :MWIPLOTFQT_N.LOT_CMF_12,
                :MWIPLOTFQT_N.LOT_CMF_13,
                :MWIPLOTFQT_N.LOT_CMF_14,
                :MWIPLOTFQT_N.LOT_CMF_15,
                :MWIPLOTFQT_N.LOT_CMF_16,
                :MWIPLOTFQT_N.LOT_CMF_17,
                :MWIPLOTFQT_N.LOT_CMF_18,
                :MWIPLOTFQT_N.LOT_CMF_19,
                :MWIPLOTFQT_N.LOT_CMF_20;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwiplotfqt(&MWIPLOTFQT_N, MWIPLOTFQT);
    }

    DB_stop_query_timer("DBC_fetch_mwiplotfqt", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwiplotfqt(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPLOTFQT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("DBC_close_mwiplotfqt", sel_type);
}


/* Initialize Function */
void DBC_init_mwiplotfqt(struct MWIPLOTFQT_TAG *MWIPLOTFQT)
{
    /* memset by Space */
    memset(MWIPLOTFQT, ' ', sizeof(struct MWIPLOTFQT_TAG));
    
    MWIPLOTFQT->SEQ_NUM = 0;
    MWIPLOTFQT->FROM_HIST_SEQ = 0;
    MWIPLOTFQT->FROM_MAT_VER = 0;
    MWIPLOTFQT->FROM_FLOW_SEQ_NUM = 0;
    MWIPLOTFQT->MAT_VER = 0;
    MWIPLOTFQT->FLOW_SEQ_NUM = 0;
}


