/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipbindef(int sel_type, struct MWIPBINDEF_TAG *MWIPBINDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPBINDEF_N_TAG MWIPBINDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipbindef(&MWIPBINDEF_N, MWIPBINDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPBINDEF_CUR_1 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    BIN_ID,
                    BIN_DESC,
                    BIN_DEF_GRP_1,
                    BIN_DEF_GRP_2,
                    BIN_DEF_GRP_3,
                    BIN_DEF_GRP_4,
                    BIN_DEF_GRP_5,
                    BIN_DEF_GRP_6,
                    BIN_DEF_GRP_7,
                    BIN_DEF_GRP_8,
                    BIN_DEF_GRP_9,
                    BIN_DEF_GRP_10,
                    BIN_DEF_CMF_1,
                    BIN_DEF_CMF_2,
                    BIN_DEF_CMF_3,
                    BIN_DEF_CMF_4,
                    BIN_DEF_CMF_5,
                    BIN_DEF_CMF_6,
                    BIN_DEF_CMF_7,
                    BIN_DEF_CMF_8,
                    BIN_DEF_CMF_9,
                    BIN_DEF_CMF_10,
                    APPROVAL_REQUIRE_FLAG,
                    APPROVAL_USER_ID,
                    DELETE_FLAG,
                    DELETE_USER_ID,
                    DELETE_TIME
                FROM MWIPBINDEF
                WHERE FACTORY = :MWIPBINDEF_N.FACTORY
                    AND BIN_ID >= :MWIPBINDEF_N.BIN_ID
                    AND BIN_ID LIKE :MWIPBINDEF_N.BIN_DESC
                    AND DELETE_FLAG LIKE :MWIPBINDEF_N.DELETE_FLAG
                ORDER BY BIN_ID ASC;
            EXEC SQL OPEN DBC_MWIPBINDEF_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
