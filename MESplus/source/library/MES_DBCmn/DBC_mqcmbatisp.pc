/* Del Null Function */
void DBC_del_null_mqcmbatisp(struct MQCMBATISP_N_TAG *MQCMBATISP_N, struct MQCMBATISP_TAG *MQCMBATISP)
{
    MEMCPY_DN(MQCMBATISP->FACTORY, MQCMBATISP_N->FACTORY, sizeof(MQCMBATISP->FACTORY));
    MEMCPY_DN(MQCMBATISP->BATCH_ID, MQCMBATISP_N->BATCH_ID, sizeof(MQCMBATISP->BATCH_ID));
