                SELECT 
                    FACTORY,
                    BATCH_ID,
                    BATCH_HIST_SEQ,
                    INSP_ITEM,
                    INSP_SET_ID,
                    INSP_SET_VERSION,
                    INSP_SEQ,
                    INSP_METHOD,
                    SAMPLE_QTY,
