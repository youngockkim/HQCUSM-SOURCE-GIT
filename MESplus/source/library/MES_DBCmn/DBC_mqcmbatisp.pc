    MEMCPY_DN(MQCMBATISP->INSP_METHOD, MQCMBATISP_N->INSP_METHOD, sizeof(MQCMBATISP->INSP_METHOD));
    MQCMBATISP->SAMPLE_QTY = MQCMBATISP_N->SAMPLE_QTY;
    MQCMBATISP->TEST_QTY = MQCMBATISP_N->TEST_QTY;
    MQCMBATISP->DEFECT_QTY = MQCMBATISP_N->DEFECT_QTY;
    MQCMBATISP->RESULT_FLAG = MQCMBATISP_N->RESULT_FLAG[0];
    MEMCPY_DN(MQCMBATISP->ISP_CMF_1, MQCMBATISP_N->ISP_CMF_1, sizeof(MQCMBATISP->ISP_CMF_1));
    MEMCPY_DN(MQCMBATISP->ISP_CMF_2, MQCMBATISP_N->ISP_CMF_2, sizeof(MQCMBATISP->ISP_CMF_2));
    MEMCPY_DN(MQCMBATISP->ISP_CMF_3, MQCMBATISP_N->ISP_CMF_3, sizeof(MQCMBATISP->ISP_CMF_3));
