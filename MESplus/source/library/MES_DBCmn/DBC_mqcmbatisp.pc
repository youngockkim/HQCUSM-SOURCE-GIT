    MEMCPY_DN(MQCMBATISP->ISP_CMF_6, MQCMBATISP_N->ISP_CMF_6, sizeof(MQCMBATISP->ISP_CMF_6));
    MEMCPY_DN(MQCMBATISP->ISP_CMF_7, MQCMBATISP_N->ISP_CMF_7, sizeof(MQCMBATISP->ISP_CMF_7));
