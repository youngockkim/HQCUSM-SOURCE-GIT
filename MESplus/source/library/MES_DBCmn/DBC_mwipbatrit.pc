}


/* Add Null Function */
void DBC_add_null_mwipbatrit(struct MWIPBATRIT_N_TAG *MWIPBATRIT_N, struct MWIPBATRIT_TAG *MWIPBATRIT)
{
    /* memset by NULL */
    memset(MWIPBATRIT_N, '\0', sizeof(struct MWIPBATRIT_N_TAG));
    
    MEMCPY_AN(MWIPBATRIT_N->FACTORY, MWIPBATRIT->FACTORY, sizeof(MWIPBATRIT->FACTORY));
    MEMCPY_AN(MWIPBATRIT_N->RSV_BATCH_ID, MWIPBATRIT->RSV_BATCH_ID, sizeof(MWIPBATRIT->RSV_BATCH_ID));
    MWIPBATRIT_N->SEQ_NUM = MWIPBATRIT->SEQ_NUM;
    MEMCPY_AN(MWIPBATRIT_N->ITEM_ID, MWIPBATRIT->ITEM_ID, sizeof(MWIPBATRIT->ITEM_ID));
    MWIPBATRIT_N->ITEM_TYPE[0] = MWIPBATRIT->ITEM_TYPE;
    MEMCPY_AN(MWIPBATRIT_N->CREATE_USER_ID, MWIPBATRIT->CREATE_USER_ID, sizeof(MWIPBATRIT->CREATE_USER_ID));
    MEMCPY_AN(MWIPBATRIT_N->CREATE_TIME, MWIPBATRIT->CREATE_TIME, sizeof(MWIPBATRIT->CREATE_TIME));
    MEMCPY_AN(MWIPBATRIT_N->UPDATE_USER_ID, MWIPBATRIT->UPDATE_USER_ID, sizeof(MWIPBATRIT->UPDATE_USER_ID));
    MEMCPY_AN(MWIPBATRIT_N->UPDATE_TIME, MWIPBATRIT->UPDATE_TIME, sizeof(MWIPBATRIT->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mwipbatrit(struct MWIPBATRIT_N_TAG *MWIPBATRIT_N, struct MWIPBATRIT_TAG *MWIPBATRIT)
{
    MEMCPY_DN(MWIPBATRIT->FACTORY, MWIPBATRIT_N->FACTORY, sizeof(MWIPBATRIT->FACTORY));
    MEMCPY_DN(MWIPBATRIT->RSV_BATCH_ID, MWIPBATRIT_N->RSV_BATCH_ID, sizeof(MWIPBATRIT->RSV_BATCH_ID));
    MWIPBATRIT->SEQ_NUM = MWIPBATRIT_N->SEQ_NUM;
    MEMCPY_DN(MWIPBATRIT->ITEM_ID, MWIPBATRIT_N->ITEM_ID, sizeof(MWIPBATRIT->ITEM_ID));
    MWIPBATRIT->ITEM_TYPE = MWIPBATRIT_N->ITEM_TYPE[0];
    MEMCPY_DN(MWIPBATRIT->CREATE_USER_ID, MWIPBATRIT_N->CREATE_USER_ID, sizeof(MWIPBATRIT->CREATE_USER_ID));
    MEMCPY_DN(MWIPBATRIT->CREATE_TIME, MWIPBATRIT_N->CREATE_TIME, sizeof(MWIPBATRIT->CREATE_TIME));
    MEMCPY_DN(MWIPBATRIT->UPDATE_USER_ID, MWIPBATRIT_N->UPDATE_USER_ID, sizeof(MWIPBATRIT->UPDATE_USER_ID));
    MEMCPY_DN(MWIPBATRIT->UPDATE_TIME, MWIPBATRIT_N->UPDATE_TIME, sizeof(MWIPBATRIT->UPDATE_TIME));
}


