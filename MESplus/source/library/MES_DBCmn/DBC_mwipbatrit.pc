/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipbatrit(int sel_type, struct MWIPBATRIT_TAG *MWIPBATRIT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPBATRIT_N_TAG MWIPBATRIT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipbatrit(&MWIPBATRIT_N, MWIPBATRIT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPBATRIT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RSV_BATCH_ID,
                    SEQ_NUM,
                    ITEM_ID,
                    ITEM_TYPE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPBATRIT
                WHERE FACTORY = :MWIPBATRIT_N.FACTORY
                    AND RSV_BATCH_ID = :MWIPBATRIT_N.RSV_BATCH_ID
                ORDER BY SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPBATRIT_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPBATRIT_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    RSV_BATCH_ID,
                    SEQ_NUM,
                    ITEM_ID,
                    ITEM_TYPE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPBATRIT
                WHERE FACTORY = :MWIPBATRIT_N.FACTORY
                    AND RSV_BATCH_ID = :MWIPBATRIT_N.RSV_BATCH_ID
                    AND ITEM_TYPE <> 'N'
                ORDER BY SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPBATRIT_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MWIPBATRIT_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    RSV_BATCH_ID,
                    SEQ_NUM,
                    ITEM_ID,
                    ITEM_TYPE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPBATRIT
                WHERE FACTORY = :MWIPBATRIT_N.FACTORY
                    AND ITEM_ID = :MWIPBATRIT_N.ITEM_ID
                    AND ITEM_TYPE = :MWIPBATRIT_N.ITEM_TYPE
                ORDER BY CREATE_TIME ASC;
            EXEC SQL OPEN DBC_MWIPBATRIT_CUR_3;
            break;

        case 4: /* RES_ID 嚥???됰튋??RSV_BATCH_ID List */
            EXEC SQL DECLARE DBC_MWIPBATRIT_CUR_4 CURSOR FOR
                SELECT 
                    FACTORY,
                    RSV_BATCH_ID,
                    SEQ_NUM,
                    ITEM_ID,
                    ITEM_TYPE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPBATRIT
                WHERE FACTORY = :MWIPBATRIT_N.FACTORY
                    AND ITEM_ID = :MWIPBATRIT_N.ITEM_ID
                    AND ITEM_TYPE = :MWIPBATRIT_N.ITEM_TYPE
                    AND RSV_BATCH_ID IN (
                        SELECT RSV_BATCH_ID 
                        FROM MWIPBATRSV
                        WHERE FACTORY = :MWIPBATRIT_N.FACTORY
                            AND RES_ID = :MWIPBATRIT_N.RSV_BATCH_ID
                    )
                ORDER BY RSV_BATCH_ID ASC;
            EXEC SQL OPEN DBC_MWIPBATRIT_CUR_4;
            break;
            
        case 5: /* RESG_ID 嚥???됰튋??RSV_BATCH_ID List */
            EXEC SQL DECLARE DBC_MWIPBATRIT_CUR_5 CURSOR FOR
                SELECT 
                    FACTORY,
                    RSV_BATCH_ID,
                    SEQ_NUM,
                    ITEM_ID,
                    ITEM_TYPE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPBATRIT
                WHERE FACTORY = :MWIPBATRIT_N.FACTORY
                    AND ITEM_ID = :MWIPBATRIT_N.ITEM_ID
                    AND ITEM_TYPE = :MWIPBATRIT_N.ITEM_TYPE
                    AND RSV_BATCH_ID IN (
                        SELECT RSV.RSV_BATCH_ID 
                        FROM MWIPBATRSV RSV, MRASRSGRES RES
                        WHERE RES.FACTORY = :MWIPBATRIT_N.FACTORY
                            AND RES.RES_ID = :MWIPBATRIT_N.RSV_BATCH_ID
                            AND RSV.FACTORY = RES.FACTORY
                            AND RSV.RESG_ID = RES.RESG_ID
                    )
                ORDER BY RSV_BATCH_ID ASC;
            EXEC SQL OPEN DBC_MWIPBATRIT_CUR_5;
            break;

        case 6: /* RES_TYPE 嚥???됰튋??RSV_BATCH_ID List */
            EXEC SQL DECLARE DBC_MWIPBATRIT_CUR_6 CURSOR FOR
                SELECT 
                    FACTORY,
                    RSV_BATCH_ID,
                    SEQ_NUM,
                    ITEM_ID,
                    ITEM_TYPE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPBATRIT
                WHERE FACTORY = :MWIPBATRIT_N.FACTORY
                    AND ITEM_ID = :MWIPBATRIT_N.ITEM_ID
                    AND ITEM_TYPE = :MWIPBATRIT_N.ITEM_TYPE
                    AND RSV_BATCH_ID IN (
                        SELECT RSV.RSV_BATCH_ID 
                        FROM MWIPBATRSV RSV, MRASRESDEF RES
                        WHERE RES.FACTORY = :MWIPBATRIT_N.FACTORY
                            AND RES.RES_ID = :MWIPBATRIT_N.RSV_BATCH_ID
                            AND RSV.FACTORY = RES.FACTORY
                            AND RSV.RES_TYPE = RES.RES_TYPE
                    )
                ORDER BY RSV_BATCH_ID ASC;
            EXEC SQL OPEN DBC_MWIPBATRIT_CUR_6;
            break;



        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipbatrit", sel_type);
}


