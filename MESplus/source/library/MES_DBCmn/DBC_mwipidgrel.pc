/* SQL CURSOR CLOSE Function */
void DBC_close_mwipidgrel(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPIDGREL_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_MWIPIDGREL_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MWIPIDGREL_CUR_3;
            break;
        case 4:
            EXEC SQL CLOSE DBC_MWIPIDGREL_CUR_4;
            break;
        case 5:
            EXEC SQL CLOSE DBC_MWIPIDGREL_CUR_5;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipidgrel", sel_type);
}


/* Initialize Function */
void DBC_init_mwipidgrel(struct MWIPIDGREL_TAG *MWIPIDGREL)
{
    /* memset by Space */
    memset(MWIPIDGREL, ' ', sizeof(struct MWIPIDGREL_TAG));
    
    MWIPIDGREL->MAT_VER = 0;
}


/* Add Null Function */
void DBC_add_null_mwipidgrel(struct MWIPIDGREL_N_TAG *MWIPIDGREL_N, struct MWIPIDGREL_TAG *MWIPIDGREL)
{
    /* memset by NULL */
    memset(MWIPIDGREL_N, '\0', sizeof(struct MWIPIDGREL_N_TAG));
    
    MEMCPY_AN(MWIPIDGREL_N->FACTORY, MWIPIDGREL->FACTORY, sizeof(MWIPIDGREL->FACTORY));
    MWIPIDGREL_N->REL_LEVEL[0] = MWIPIDGREL->REL_LEVEL;
    MEMCPY_AN(MWIPIDGREL_N->MAT_ID, MWIPIDGREL->MAT_ID, sizeof(MWIPIDGREL->MAT_ID));
    MWIPIDGREL_N->MAT_VER = MWIPIDGREL->MAT_VER;
    MEMCPY_AN(MWIPIDGREL_N->FLOW, MWIPIDGREL->FLOW, sizeof(MWIPIDGREL->FLOW));
    MEMCPY_AN(MWIPIDGREL_N->OPER, MWIPIDGREL->OPER, sizeof(MWIPIDGREL->OPER));
    MEMCPY_AN(MWIPIDGREL_N->RES_TYPE, MWIPIDGREL->RES_TYPE, sizeof(MWIPIDGREL->RES_TYPE));
    MEMCPY_AN(MWIPIDGREL_N->RESG_ID, MWIPIDGREL->RESG_ID, sizeof(MWIPIDGREL->RESG_ID));
    MEMCPY_AN(MWIPIDGREL_N->RES_ID, MWIPIDGREL->RES_ID, sizeof(MWIPIDGREL->RES_ID));
    MEMCPY_AN(MWIPIDGREL_N->TRAN_CODE, MWIPIDGREL->TRAN_CODE, sizeof(MWIPIDGREL->TRAN_CODE));
    MEMCPY_AN(MWIPIDGREL_N->KEY_1, MWIPIDGREL->KEY_1, sizeof(MWIPIDGREL->KEY_1));
    MEMCPY_AN(MWIPIDGREL_N->KEY_2, MWIPIDGREL->KEY_2, sizeof(MWIPIDGREL->KEY_2));
    MEMCPY_AN(MWIPIDGREL_N->KEY_3, MWIPIDGREL->KEY_3, sizeof(MWIPIDGREL->KEY_3));
    MEMCPY_AN(MWIPIDGREL_N->KEY_4, MWIPIDGREL->KEY_4, sizeof(MWIPIDGREL->KEY_4));
    MEMCPY_AN(MWIPIDGREL_N->KEY_5, MWIPIDGREL->KEY_5, sizeof(MWIPIDGREL->KEY_5));
    MEMCPY_AN(MWIPIDGREL_N->RULE_ID, MWIPIDGREL->RULE_ID, sizeof(MWIPIDGREL->RULE_ID));
    MEMCPY_AN(MWIPIDGREL_N->CREATE_USER_ID, MWIPIDGREL->CREATE_USER_ID, sizeof(MWIPIDGREL->CREATE_USER_ID));
    MEMCPY_AN(MWIPIDGREL_N->CREATE_TIME, MWIPIDGREL->CREATE_TIME, sizeof(MWIPIDGREL->CREATE_TIME));
    MEMCPY_AN(MWIPIDGREL_N->UPDATE_USER_ID, MWIPIDGREL->UPDATE_USER_ID, sizeof(MWIPIDGREL->UPDATE_USER_ID));
    MEMCPY_AN(MWIPIDGREL_N->UPDATE_TIME, MWIPIDGREL->UPDATE_TIME, sizeof(MWIPIDGREL->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mwipidgrel(struct MWIPIDGREL_N_TAG *MWIPIDGREL_N, struct MWIPIDGREL_TAG *MWIPIDGREL)
{
    MEMCPY_DN(MWIPIDGREL->FACTORY, MWIPIDGREL_N->FACTORY, sizeof(MWIPIDGREL->FACTORY));
    MWIPIDGREL->REL_LEVEL = MWIPIDGREL_N->REL_LEVEL[0];
    MEMCPY_DN(MWIPIDGREL->MAT_ID, MWIPIDGREL_N->MAT_ID, sizeof(MWIPIDGREL->MAT_ID));
    MWIPIDGREL->MAT_VER = MWIPIDGREL_N->MAT_VER;
    MEMCPY_DN(MWIPIDGREL->FLOW, MWIPIDGREL_N->FLOW, sizeof(MWIPIDGREL->FLOW));
    MEMCPY_DN(MWIPIDGREL->OPER, MWIPIDGREL_N->OPER, sizeof(MWIPIDGREL->OPER));
    MEMCPY_DN(MWIPIDGREL->RES_TYPE, MWIPIDGREL_N->RES_TYPE, sizeof(MWIPIDGREL->RES_TYPE));
    MEMCPY_DN(MWIPIDGREL->RESG_ID, MWIPIDGREL_N->RESG_ID, sizeof(MWIPIDGREL->RESG_ID));
    MEMCPY_DN(MWIPIDGREL->RES_ID, MWIPIDGREL_N->RES_ID, sizeof(MWIPIDGREL->RES_ID));
    MEMCPY_DN(MWIPIDGREL->TRAN_CODE, MWIPIDGREL_N->TRAN_CODE, sizeof(MWIPIDGREL->TRAN_CODE));
    MEMCPY_DN(MWIPIDGREL->KEY_1, MWIPIDGREL_N->KEY_1, sizeof(MWIPIDGREL->KEY_1));
    MEMCPY_DN(MWIPIDGREL->KEY_2, MWIPIDGREL_N->KEY_2, sizeof(MWIPIDGREL->KEY_2));
    MEMCPY_DN(MWIPIDGREL->KEY_3, MWIPIDGREL_N->KEY_3, sizeof(MWIPIDGREL->KEY_3));
    MEMCPY_DN(MWIPIDGREL->KEY_4, MWIPIDGREL_N->KEY_4, sizeof(MWIPIDGREL->KEY_4));
    MEMCPY_DN(MWIPIDGREL->KEY_5, MWIPIDGREL_N->KEY_5, sizeof(MWIPIDGREL->KEY_5));
    MEMCPY_DN(MWIPIDGREL->RULE_ID, MWIPIDGREL_N->RULE_ID, sizeof(MWIPIDGREL->RULE_ID));
    MEMCPY_DN(MWIPIDGREL->CREATE_USER_ID, MWIPIDGREL_N->CREATE_USER_ID, sizeof(MWIPIDGREL->CREATE_USER_ID));
    MEMCPY_DN(MWIPIDGREL->CREATE_TIME, MWIPIDGREL_N->CREATE_TIME, sizeof(MWIPIDGREL->CREATE_TIME));
    MEMCPY_DN(MWIPIDGREL->UPDATE_USER_ID, MWIPIDGREL_N->UPDATE_USER_ID, sizeof(MWIPIDGREL->UPDATE_USER_ID));
    MEMCPY_DN(MWIPIDGREL->UPDATE_TIME, MWIPIDGREL_N->UPDATE_TIME, sizeof(MWIPIDGREL->UPDATE_TIME));
}


