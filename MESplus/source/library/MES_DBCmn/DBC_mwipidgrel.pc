                    KEY_4,
                    KEY_5,
                    RULE_ID,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPIDGREL
                WHERE FACTORY = :MWIPIDGREL_N.FACTORY
                    AND MAT_ID = ' '
                    AND MAT_VER = 0
                    AND FLOW = ' '
                    AND OPER = :MWIPIDGREL_N.OPER;
            EXEC SQL OPEN DBC_MWIPIDGREL_CUR_5;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipidgrel", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mwipidgrel(int sel_type, struct MWIPIDGREL_TAG *MWIPIDGREL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPIDGREL_N_TAG MWIPIDGREL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MWIPIDGREL_CUR_1 INTO 
