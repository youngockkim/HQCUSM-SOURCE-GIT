                                                    :MWIPIDGREL_N.TRAN_CODE,
                                                    :MWIPIDGREL_N.KEY_1,
                                                    :MWIPIDGREL_N.KEY_2,
                                                    :MWIPIDGREL_N.KEY_3,
                                                    :MWIPIDGREL_N.KEY_4,
                                                    :MWIPIDGREL_N.KEY_5,
                                                    :MWIPIDGREL_N.RULE_ID,
                                                    :MWIPIDGREL_N.CREATE_USER_ID,
                                                    :MWIPIDGREL_N.CREATE_TIME,
                                                    :MWIPIDGREL_N.UPDATE_USER_ID,
                                                    :MWIPIDGREL_N.UPDATE_TIME;
            break;
        case 5:
            EXEC SQL FETCH DBC_MWIPIDGREL_CUR_5 INTO 
                                                    :MWIPIDGREL_N.FACTORY,
                                                    :MWIPIDGREL_N.REL_LEVEL,
                                                    :MWIPIDGREL_N.MAT_ID,
                                                    :MWIPIDGREL_N.MAT_VER,
                                                    :MWIPIDGREL_N.FLOW,
                                                    :MWIPIDGREL_N.OPER,
                                                    :MWIPIDGREL_N.RES_TYPE,
                                                    :MWIPIDGREL_N.RESG_ID,
                                                    :MWIPIDGREL_N.RES_ID,
