                                                    :MWIPIDGREL_N.CREATE_TIME,
                                                    :MWIPIDGREL_N.UPDATE_USER_ID,
                                                    :MWIPIDGREL_N.UPDATE_TIME;
            break;
        case 4:
            EXEC SQL FETCH DBC_MWIPIDGREL_CUR_4 INTO 
