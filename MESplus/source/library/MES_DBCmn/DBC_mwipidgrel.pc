            break;
            
        case 2:
            EXEC SQL FETCH DBC_MWIPIDGREL_CUR_2 INTO :MWIPIDGREL_N.RULE_ID;
            break;

        case 3:
            EXEC SQL FETCH DBC_MWIPIDGREL_CUR_3 INTO 
                                                    :MWIPIDGREL_N.FACTORY,
                                                    :MWIPIDGREL_N.REL_LEVEL,
                                                    :MWIPIDGREL_N.MAT_ID,
