            EXEC SQL UPDATE MWIPMATFLW SET
                    OPT_FLOW_GROUP = :MWIPMATFLW_N.OPT_FLOW_GROUP,
                    OPT_FLOW_OPTION_FLAG = :MWIPMATFLW_N.OPT_FLOW_OPTION_FLAG,
                    FLOW_SEQ_NUM = :MWIPMATFLW_N.FLOW_SEQ_NUM,
                    PREV_FLOW = :MWIPMATFLW_N.PREV_FLOW,
                    PREV_FLOW_SEQ_NUM = :MWIPMATFLW_N.PREV_FLOW_SEQ_NUM,
                    NEXT_FLOW = :MWIPMATFLW_N.NEXT_FLOW,
                    NEXT_FLOW_SEQ_NUM = :MWIPMATFLW_N.NEXT_FLOW_SEQ_NUM,
                    CREATE_USER_ID = :MWIPMATFLW_N.CREATE_USER_ID,
                    CREATE_TIME = :MWIPMATFLW_N.CREATE_TIME,
                    UPDATE_USER_ID = :MWIPMATFLW_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MWIPMATFLW_N.UPDATE_TIME
                WHERE FACTORY = :MWIPMATFLW_N.FACTORY
                    AND MAT_ID = :MWIPMATFLW_N.MAT_ID
                    AND MAT_VER = :MWIPMATFLW_N.MAT_VER
                    AND FLOW = :MWIPMATFLW_N.FLOW
                    AND FLOW_SEQ_NUM = :MWIPMATFLW_N.FLOW_SEQ_NUM;
            break;
        case 2:
            EXEC SQL UPDATE MWIPMATFLW SET
                    FLOW_SEQ_NUM = FLOW_SEQ_NUM + 1,
                    PREV_FLOW_SEQ_NUM = PREV_FLOW_SEQ_NUM + 1,
                    NEXT_FLOW_SEQ_NUM = NEXT_FLOW_SEQ_NUM + 1
                WHERE FACTORY = :MWIPMATFLW_N.FACTORY
                    AND MAT_ID = :MWIPMATFLW_N.MAT_ID
                    AND MAT_VER = :MWIPMATFLW_N.MAT_VER
                    AND FLOW_SEQ_NUM >= :MWIPMATFLW_N.FLOW_SEQ_NUM;

            EXEC SQL UPDATE MWIPMATFLW SET
                    NEXT_FLOW_SEQ_NUM = 0
                WHERE FACTORY = :MWIPMATFLW_N.FACTORY
                    AND MAT_ID = :MWIPMATFLW_N.MAT_ID
                    AND MAT_VER = :MWIPMATFLW_N.MAT_VER
                    AND NEXT_FLOW = ' ';
            break;
        case 3:
            EXEC SQL UPDATE MWIPMATFLW SET
                    FLOW_SEQ_NUM = FLOW_SEQ_NUM - 1,
                    PREV_FLOW_SEQ_NUM = PREV_FLOW_SEQ_NUM - 1,
                    NEXT_FLOW_SEQ_NUM = NEXT_FLOW_SEQ_NUM - 1
                WHERE FACTORY = :MWIPMATFLW_N.FACTORY
                    AND MAT_ID = :MWIPMATFLW_N.MAT_ID
                    AND MAT_VER = :MWIPMATFLW_N.MAT_VER
                    AND FLOW_SEQ_NUM >= :MWIPMATFLW_N.FLOW_SEQ_NUM;

            EXEC SQL UPDATE MWIPMATFLW SET
                    NEXT_FLOW_SEQ_NUM = 0
                WHERE FACTORY = :MWIPMATFLW_N.FACTORY
                    AND MAT_ID = :MWIPMATFLW_N.MAT_ID
                    AND MAT_VER = :MWIPMATFLW_N.MAT_VER
                    AND NEXT_FLOW = ' ';
            break;            

        case 4:
            EXEC SQL UPDATE MWIPMATFLW SET
                    PREV_FLOW = :MWIPMATFLW_N.PREV_FLOW,
                    PREV_FLOW_SEQ_NUM = :MWIPMATFLW_N.PREV_FLOW_SEQ_NUM
                WHERE FACTORY = :MWIPMATFLW_N.FACTORY
                    AND MAT_ID = :MWIPMATFLW_N.MAT_ID
                    AND MAT_VER = :MWIPMATFLW_N.MAT_VER
                    AND FLOW = :MWIPMATFLW_N.FLOW
                    AND FLOW_SEQ_NUM = :MWIPMATFLW_N.FLOW_SEQ_NUM;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mwipmatflw", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipmatflw(int sel_type, struct MWIPMATFLW_TAG *MWIPMATFLW)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPMATFLW_N_TAG MWIPMATFLW_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipmatflw(&MWIPMATFLW_N, MWIPMATFLW);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPMATFLW_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPT_FLOW_GROUP,
                    OPT_FLOW_OPTION_FLAG,
                    FLOW_SEQ_NUM,
                    PREV_FLOW,
                    PREV_FLOW_SEQ_NUM,
                    NEXT_FLOW,
                    NEXT_FLOW_SEQ_NUM,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPMATFLW
                WHERE FACTORY = :MWIPMATFLW_N.FACTORY
                    AND MAT_ID = :MWIPMATFLW_N.MAT_ID
                    AND MAT_VER = :MWIPMATFLW_N.MAT_VER
                ORDER BY FLOW_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPMATFLW_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPMATFLW_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPT_FLOW_GROUP,
                    OPT_FLOW_OPTION_FLAG,
                    FLOW_SEQ_NUM,
                    PREV_FLOW,
                    PREV_FLOW_SEQ_NUM,
                    NEXT_FLOW,
                    NEXT_FLOW_SEQ_NUM,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPMATFLW
                WHERE FACTORY = :MWIPMATFLW_N.FACTORY
                    AND MAT_ID = :MWIPMATFLW_N.MAT_ID
                    AND MAT_VER = :MWIPMATFLW_N.MAT_VER
                    AND FLOW = :MWIPMATFLW_N.FLOW
                    AND FLOW_SEQ_NUM >= :MWIPMATFLW_N.FLOW_SEQ_NUM
                ORDER BY FLOW_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPMATFLW_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MWIPMATFLW_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPT_FLOW_GROUP,
                    OPT_FLOW_OPTION_FLAG,
                    FLOW_SEQ_NUM,
                    PREV_FLOW,
                    PREV_FLOW_SEQ_NUM,
                    NEXT_FLOW,
                    NEXT_FLOW_SEQ_NUM,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPMATFLW
                WHERE FACTORY = :MWIPMATFLW_N.FACTORY
                    AND MAT_ID = :MWIPMATFLW_N.MAT_ID
                    AND MAT_VER = :MWIPMATFLW_N.MAT_VER
                    AND FLOW_SEQ_NUM >= :MWIPMATFLW_N.FLOW_SEQ_NUM
                ORDER BY FLOW_SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MWIPMATFLW_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mwipmatflw", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mwipmatflw(int sel_type, struct MWIPMATFLW_TAG *MWIPMATFLW)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPMATFLW_N_TAG MWIPMATFLW_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MWIPMATFLW_CUR_1 INTO 
                                                    :MWIPMATFLW_N.FACTORY,
                                                    :MWIPMATFLW_N.MAT_ID,
                                                    :MWIPMATFLW_N.MAT_VER,
                                                    :MWIPMATFLW_N.FLOW,
                                                    :MWIPMATFLW_N.OPT_FLOW_GROUP,
                                                    :MWIPMATFLW_N.OPT_FLOW_OPTION_FLAG,
                                                    :MWIPMATFLW_N.FLOW_SEQ_NUM,
                                                    :MWIPMATFLW_N.PREV_FLOW,
                                                    :MWIPMATFLW_N.PREV_FLOW_SEQ_NUM,
                                                    :MWIPMATFLW_N.NEXT_FLOW,
                                                    :MWIPMATFLW_N.NEXT_FLOW_SEQ_NUM,
                                                    :MWIPMATFLW_N.CREATE_USER_ID,
                                                    :MWIPMATFLW_N.CREATE_TIME,
                                                    :MWIPMATFLW_N.UPDATE_USER_ID,
                                                    :MWIPMATFLW_N.UPDATE_TIME;
            break;

        case 2:
            EXEC SQL FETCH DBC_MWIPMATFLW_CUR_2 INTO 
                                                    :MWIPMATFLW_N.FACTORY,
                                                    :MWIPMATFLW_N.MAT_ID,
                                                    :MWIPMATFLW_N.MAT_VER,
                                                    :MWIPMATFLW_N.FLOW,
                                                    :MWIPMATFLW_N.OPT_FLOW_GROUP,
                                                    :MWIPMATFLW_N.OPT_FLOW_OPTION_FLAG,
                                                    :MWIPMATFLW_N.FLOW_SEQ_NUM,
                                                    :MWIPMATFLW_N.PREV_FLOW,
                                                    :MWIPMATFLW_N.PREV_FLOW_SEQ_NUM,
                                                    :MWIPMATFLW_N.NEXT_FLOW,
                                                    :MWIPMATFLW_N.NEXT_FLOW_SEQ_NUM,
                                                    :MWIPMATFLW_N.CREATE_USER_ID,
                                                    :MWIPMATFLW_N.CREATE_TIME,
                                                    :MWIPMATFLW_N.UPDATE_USER_ID,
                                                    :MWIPMATFLW_N.UPDATE_TIME;
            break;

        case 3:
            EXEC SQL FETCH DBC_MWIPMATFLW_CUR_3 INTO 
                                                    :MWIPMATFLW_N.FACTORY,
                                                    :MWIPMATFLW_N.MAT_ID,
                                                    :MWIPMATFLW_N.MAT_VER,
                                                    :MWIPMATFLW_N.FLOW,
                                                    :MWIPMATFLW_N.OPT_FLOW_GROUP,
                                                    :MWIPMATFLW_N.OPT_FLOW_OPTION_FLAG,
                                                    :MWIPMATFLW_N.FLOW_SEQ_NUM,
                                                    :MWIPMATFLW_N.PREV_FLOW,
                                                    :MWIPMATFLW_N.PREV_FLOW_SEQ_NUM,
                                                    :MWIPMATFLW_N.NEXT_FLOW,
                                                    :MWIPMATFLW_N.NEXT_FLOW_SEQ_NUM,
                                                    :MWIPMATFLW_N.CREATE_USER_ID,
                                                    :MWIPMATFLW_N.CREATE_TIME,
                                                    :MWIPMATFLW_N.UPDATE_USER_ID,
                                                    :MWIPMATFLW_N.UPDATE_TIME;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwipmatflw(&MWIPMATFLW_N, MWIPMATFLW);
    }
    DB_stop_query_timer("DBC_fetch_mwipmatflw", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mwipmatflw(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPMATFLW_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWIPMATFLW_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MWIPMATFLW_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mwipmatflw", sel_type);
}


/* Initialize Function */
void DBC_init_mwipmatflw(struct MWIPMATFLW_TAG *MWIPMATFLW)
{
    /* memset by Space */
    memset(MWIPMATFLW, ' ', sizeof(struct MWIPMATFLW_TAG));
    
    MWIPMATFLW->MAT_VER = 0;
    MWIPMATFLW->FLOW_SEQ_NUM = 0;
    MWIPMATFLW->PREV_FLOW_SEQ_NUM = 0;
    MWIPMATFLW->NEXT_FLOW_SEQ_NUM = 0;
}


/* Add Null Function */
void DBC_add_null_mwipmatflw(struct MWIPMATFLW_N_TAG *MWIPMATFLW_N, struct MWIPMATFLW_TAG *MWIPMATFLW)
{
    /* memset by NULL */
    memset(MWIPMATFLW_N, '\0', sizeof(struct MWIPMATFLW_N_TAG));
    
    MEMCPY_AN(MWIPMATFLW_N->FACTORY, MWIPMATFLW->FACTORY, sizeof(MWIPMATFLW->FACTORY));
    MEMCPY_AN(MWIPMATFLW_N->MAT_ID, MWIPMATFLW->MAT_ID, sizeof(MWIPMATFLW->MAT_ID));
    MWIPMATFLW_N->MAT_VER = MWIPMATFLW->MAT_VER;
    MEMCPY_AN(MWIPMATFLW_N->FLOW, MWIPMATFLW->FLOW, sizeof(MWIPMATFLW->FLOW));
    MEMCPY_AN(MWIPMATFLW_N->OPT_FLOW_GROUP, MWIPMATFLW->OPT_FLOW_GROUP, sizeof(MWIPMATFLW->OPT_FLOW_GROUP));
    MWIPMATFLW_N->OPT_FLOW_OPTION_FLAG[0] = MWIPMATFLW->OPT_FLOW_OPTION_FLAG;
    MWIPMATFLW_N->FLOW_SEQ_NUM = MWIPMATFLW->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPMATFLW_N->PREV_FLOW, MWIPMATFLW->PREV_FLOW, sizeof(MWIPMATFLW->PREV_FLOW));
    MWIPMATFLW_N->PREV_FLOW_SEQ_NUM = MWIPMATFLW->PREV_FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPMATFLW_N->NEXT_FLOW, MWIPMATFLW->NEXT_FLOW, sizeof(MWIPMATFLW->NEXT_FLOW));
    MWIPMATFLW_N->NEXT_FLOW_SEQ_NUM = MWIPMATFLW->NEXT_FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPMATFLW_N->CREATE_USER_ID, MWIPMATFLW->CREATE_USER_ID, sizeof(MWIPMATFLW->CREATE_USER_ID));
    MEMCPY_AN(MWIPMATFLW_N->CREATE_TIME, MWIPMATFLW->CREATE_TIME, sizeof(MWIPMATFLW->CREATE_TIME));
    MEMCPY_AN(MWIPMATFLW_N->UPDATE_USER_ID, MWIPMATFLW->UPDATE_USER_ID, sizeof(MWIPMATFLW->UPDATE_USER_ID));
    MEMCPY_AN(MWIPMATFLW_N->UPDATE_TIME, MWIPMATFLW->UPDATE_TIME, sizeof(MWIPMATFLW->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mwipmatflw(struct MWIPMATFLW_N_TAG *MWIPMATFLW_N, struct MWIPMATFLW_TAG *MWIPMATFLW)
{
    MEMCPY_DN(MWIPMATFLW->FACTORY, MWIPMATFLW_N->FACTORY, sizeof(MWIPMATFLW->FACTORY));
    MEMCPY_DN(MWIPMATFLW->MAT_ID, MWIPMATFLW_N->MAT_ID, sizeof(MWIPMATFLW->MAT_ID));
    MWIPMATFLW->MAT_VER = MWIPMATFLW_N->MAT_VER;
    MEMCPY_DN(MWIPMATFLW->FLOW, MWIPMATFLW_N->FLOW, sizeof(MWIPMATFLW->FLOW));
    MEMCPY_DN(MWIPMATFLW->OPT_FLOW_GROUP, MWIPMATFLW_N->OPT_FLOW_GROUP, sizeof(MWIPMATFLW->OPT_FLOW_GROUP));
    MWIPMATFLW->OPT_FLOW_OPTION_FLAG = MWIPMATFLW_N->OPT_FLOW_OPTION_FLAG[0];
    MWIPMATFLW->FLOW_SEQ_NUM = MWIPMATFLW_N->FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPMATFLW->PREV_FLOW, MWIPMATFLW_N->PREV_FLOW, sizeof(MWIPMATFLW->PREV_FLOW));
    MWIPMATFLW->PREV_FLOW_SEQ_NUM = MWIPMATFLW_N->PREV_FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPMATFLW->NEXT_FLOW, MWIPMATFLW_N->NEXT_FLOW, sizeof(MWIPMATFLW->NEXT_FLOW));
    MWIPMATFLW->NEXT_FLOW_SEQ_NUM = MWIPMATFLW_N->NEXT_FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPMATFLW->CREATE_USER_ID, MWIPMATFLW_N->CREATE_USER_ID, sizeof(MWIPMATFLW->CREATE_USER_ID));
    MEMCPY_DN(MWIPMATFLW->CREATE_TIME, MWIPMATFLW_N->CREATE_TIME, sizeof(MWIPMATFLW->CREATE_TIME));
    MEMCPY_DN(MWIPMATFLW->UPDATE_USER_ID, MWIPMATFLW_N->UPDATE_USER_ID, sizeof(MWIPMATFLW->UPDATE_USER_ID));
    MEMCPY_DN(MWIPMATFLW->UPDATE_TIME, MWIPMATFLW_N->UPDATE_TIME, sizeof(MWIPMATFLW->UPDATE_TIME));
}



