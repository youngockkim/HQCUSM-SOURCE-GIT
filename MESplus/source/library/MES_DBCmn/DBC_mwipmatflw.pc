/* SQL SELECT_SCALAR Function */
double DBC_select_mwipmatflw_scalar(int sel_type, struct MWIPMATFLW_TAG *MWIPMATFLW)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPMATFLW_N_TAG MWIPMATFLW_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    

    DBC_add_null_mwipmatflw(&MWIPMATFLW_N, MWIPMATFLW);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPMATFLW
                WHERE FACTORY = :MWIPMATFLW_N.FACTORY
                    AND MAT_ID = :MWIPMATFLW_N.MAT_ID
                    AND MAT_VER = :MWIPMATFLW_N.MAT_VER;
            break;
        
        case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPMATFLW
                WHERE FACTORY = :MWIPMATFLW_N.FACTORY
                    AND FLOW = :MWIPMATFLW_N.FLOW;
            break;

        case 3:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPMATFLW
                WHERE FACTORY = :MWIPMATFLW_N.FACTORY
                    AND MAT_ID = :MWIPMATFLW_N.MAT_ID
                    AND MAT_VER = :MWIPMATFLW_N.MAT_VER
                    AND FLOW = :MWIPMATFLW_N.FLOW;
            break;

        case 4:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM (
                  SELECT DISTINCT MAT_ID, MAT_VER 
                  FROM MWIPMATFLW 
                  WHERE FACTORY = :MWIPMATFLW_N.FACTORY
                  GROUP BY MAT_ID, MAT_VER, FLOW
                  HAVING COUNT(*) > 1
                );
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mwipmatflw_scalar", sel_type);
    return d_value;
}


