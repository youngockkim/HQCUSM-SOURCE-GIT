/* SQL CURSOR CLOSE Function */
void DBC_close_mrastoldef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MRASTOLDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MRASTOLDEF_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MRASTOLDEF_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MRASTOLDEF_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MRASTOLDEF_CUR_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mrastoldef", sel_type);
}


/* Initialize Function */
void DBC_init_mrastoldef(struct MRASTOLDEF_TAG *MRASTOLDEF)
{
    /* memset by Space */
    memset(MRASTOLDEF, ' ', sizeof(struct MRASTOLDEF_TAG));
    
    MRASTOLDEF->MAT_VER = 0;
    MRASTOLDEF->CELL_COUNT_X = 0;
    MRASTOLDEF->CELL_COUNT_Y = 0;
    MRASTOLDEF->CELL_COUNT_Z = 0;
    MRASTOLDEF->CELL_SIZE_X = 0;
    MRASTOLDEF->CELL_SIZE_Y = 0;
    MRASTOLDEF->CELL_SIZE_Z = 0;
    MRASTOLDEF->LAST_HIST_SEQ = 0;
    MRASTOLDEF->LAST_ACTIVE_HIST_SEQ = 0;
}


