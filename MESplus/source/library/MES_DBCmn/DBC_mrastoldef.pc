/* Del Null Function */
void DBC_del_null_mrastoldef(struct MRASTOLDEF_N_TAG *MRASTOLDEF_N, struct MRASTOLDEF_TAG *MRASTOLDEF)
{
    MEMCPY_DN(MRASTOLDEF->FACTORY, MRASTOLDEF_N->FACTORY, sizeof(MRASTOLDEF->FACTORY));
    MEMCPY_DN(MRASTOLDEF->TOOL_ID, MRASTOLDEF_N->TOOL_ID, sizeof(MRASTOLDEF->TOOL_ID));
    MEMCPY_DN(MRASTOLDEF->TOOL_DESC, MRASTOLDEF_N->TOOL_DESC, sizeof(MRASTOLDEF->TOOL_DESC));
    MEMCPY_DN(MRASTOLDEF->TOOL_TYPE, MRASTOLDEF_N->TOOL_TYPE, sizeof(MRASTOLDEF->TOOL_TYPE));
    MEMCPY_DN(MRASTOLDEF->TOOL_GRP, MRASTOLDEF_N->TOOL_GRP, sizeof(MRASTOLDEF->TOOL_GRP));
    MEMCPY_DN(MRASTOLDEF->TOOL_SET_ID, MRASTOLDEF_N->TOOL_SET_ID, sizeof(MRASTOLDEF->TOOL_SET_ID));
