                    TOOL_STS_8 = :MRASTOLDEF_N.TOOL_STS_8,
                    TOOL_STS_9 = :MRASTOLDEF_N.TOOL_STS_9,
                    TOOL_STS_10 = :MRASTOLDEF_N.TOOL_STS_10,
                    TOOL_STS_11 = :MRASTOLDEF_N.TOOL_STS_11,
                    TOOL_STS_12 = :MRASTOLDEF_N.TOOL_STS_12,
                    TOOL_STS_13 = :MRASTOLDEF_N.TOOL_STS_13,
                    TOOL_STS_14 = :MRASTOLDEF_N.TOOL_STS_14,
                    TOOL_STS_15 = :MRASTOLDEF_N.TOOL_STS_15,
                    TOOL_STS_16 = :MRASTOLDEF_N.TOOL_STS_16,
                    TOOL_STS_17 = :MRASTOLDEF_N.TOOL_STS_17,
                    TOOL_STS_18 = :MRASTOLDEF_N.TOOL_STS_18,
                    TOOL_STS_19 = :MRASTOLDEF_N.TOOL_STS_19,
                    TOOL_STS_20 = :MRASTOLDEF_N.TOOL_STS_20,
                    TOOL_STS_21 = :MRASTOLDEF_N.TOOL_STS_21,
                    TOOL_STS_22 = :MRASTOLDEF_N.TOOL_STS_22,
                    TOOL_STS_23 = :MRASTOLDEF_N.TOOL_STS_23,
                    TOOL_STS_24 = :MRASTOLDEF_N.TOOL_STS_24,
                    TOOL_STS_25 = :MRASTOLDEF_N.TOOL_STS_25,
                    TOOL_STS_26 = :MRASTOLDEF_N.TOOL_STS_26,
                    TOOL_STS_27 = :MRASTOLDEF_N.TOOL_STS_27,
                    TOOL_STS_28 = :MRASTOLDEF_N.TOOL_STS_28,
                    TOOL_STS_29 = :MRASTOLDEF_N.TOOL_STS_29,
                    TOOL_STS_30 = :MRASTOLDEF_N.TOOL_STS_30,
                    LAST_HIST_SEQ = :MRASTOLDEF_N.LAST_HIST_SEQ,
                    LAST_ACTIVE_HIST_SEQ = :MRASTOLDEF_N.LAST_ACTIVE_HIST_SEQ,
                    LAST_TOOL_EVENT_ID = :MRASTOLDEF_N.LAST_TOOL_EVENT_ID,
                    LAST_TRAN_TIME = :MRASTOLDEF_N.LAST_TRAN_TIME,
                    DELETE_FLAG = :MRASTOLDEF_N.DELETE_FLAG,
                    TOOL_COMMENT = :MRASTOLDEF_N.TOOL_COMMENT,
                    CREATE_USER_ID = :MRASTOLDEF_N.CREATE_USER_ID,
                    CREATE_TIME = :MRASTOLDEF_N.CREATE_TIME,
                    UPDATE_USER_ID = :MRASTOLDEF_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MRASTOLDEF_N.UPDATE_TIME
                WHERE FACTORY = :MRASTOLDEF_N.FACTORY
                    AND TOOL_ID = :MRASTOLDEF_N.TOOL_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mrastoldef", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrastoldef(int sel_type, struct MRASTOLDEF_TAG *MRASTOLDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASTOLDEF_N_TAG MRASTOLDEF_N;
        char   sql[5120];
        char   ts[1000];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrastoldef(&MRASTOLDEF_N, MRASTOLDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRASTOLDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    TOOL_ID,
                    TOOL_DESC,
                    TOOL_TYPE,
                    TOOL_GRP,
                    TOOL_SET_ID,
                    TOOL_SET_LOCATION,
                    TOOL_STATUS,
                    LOT_ID,
                    SUBLOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    AREA_ID,
                    SUB_AREA_ID,
                    TOOL_LOCATION,
                    VENDOR_ID,
                    VENDOR_TOOL_ID,
                    CELL_COUNT_X,
                    CELL_COUNT_Y,
                    CELL_COUNT_Z,
                    CELL_SIZE_X,
                    CELL_SIZE_Y,
                    CELL_SIZE_Z,
                    GRADE,
                    TOOL_STS_1,
                    TOOL_STS_2,
                    TOOL_STS_3,
                    TOOL_STS_4,
                    TOOL_STS_5,
                    TOOL_STS_6,
                    TOOL_STS_7,
                    TOOL_STS_8,
                    TOOL_STS_9,
                    TOOL_STS_10,
                    TOOL_STS_11,
                    TOOL_STS_12,
                    TOOL_STS_13,
                    TOOL_STS_14,
                    TOOL_STS_15,
                    TOOL_STS_16,
                    TOOL_STS_17,
                    TOOL_STS_18,
                    TOOL_STS_19,
                    TOOL_STS_20,
                    TOOL_STS_21,
                    TOOL_STS_22,
                    TOOL_STS_23,
                    TOOL_STS_24,
                    TOOL_STS_25,
                    TOOL_STS_26,
                    TOOL_STS_27,
                    TOOL_STS_28,
                    TOOL_STS_29,
                    TOOL_STS_30,
                    LAST_HIST_SEQ,
                    LAST_ACTIVE_HIST_SEQ,
                    LAST_TOOL_EVENT_ID,
                    LAST_TRAN_TIME,
                    DELETE_FLAG,
                    TOOL_COMMENT,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRASTOLDEF
                WHERE FACTORY = :MRASTOLDEF_N.FACTORY
                AND TOOL_ID >= :MRASTOLDEF_N.TOOL_ID
                ORDER BY FACTORY ASC,
                    TOOL_ID ASC;
            EXEC SQL OPEN DBC_MRASTOLDEF_CUR_1;
            break;

        case 2:
            sprintf(sql,               "SELECT FACTORY, TOOL_TYPE, TOOL_DESC, TOOL_ID, DELETE_FLAG FROM MRASTOLDEF WHERE ");
            make_valid_quote(ts, MRASTOLDEF_N.FACTORY);
            sprintf(sql + strlen(sql), "FACTORY = '%s' ", ts);
            
            if(ISSPACE(MRASTOLDEF->TOOL_ID, sizeof(MRASTOLDEF->TOOL_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.TOOL_ID);
                sprintf(sql + strlen(sql), "AND TOOL_ID >= '%s' ", ts);
            }
            
            if(MRASTOLDEF->DELETE_FLAG == ' ') 
            {
                /* Do Nothing */
            }
            else if(MRASTOLDEF->DELETE_FLAG == 'N')
            {
                sprintf(sql + strlen(sql), "AND DELETE_FLAG = ' ' ");   
            }
            else if(MRASTOLDEF->DELETE_FLAG == 'Y')
            {
                sprintf(sql + strlen(sql), "AND DELETE_FLAG <> ' ' ");   
            }
            else
            {
                sprintf(sql + strlen(sql), "AND DELETE_FLAG = '%c' ", MRASTOLDEF_N.DELETE_FLAG[0]);   
            }
            sprintf(sql + strlen(sql), "ORDER BY FACTORY, TOOL_ID ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MRASTOLDEF_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MRASTOLDEF_CUR_2;
            break;
            
        case 3:
            sprintf(sql,               "SELECT FACTORY, TOOL_TYPE, TOOL_DESC, TOOL_ID, DELETE_FLAG FROM MRASTOLDEF WHERE ");
            make_valid_quote(ts, MRASTOLDEF_N.FACTORY);
            sprintf(sql + strlen(sql), "FACTORY = '%s' ", ts);
            make_valid_quote(ts, MRASTOLDEF_N.TOOL_TYPE);
            sprintf(sql + strlen(sql), "AND TOOL_TYPE = '%s' ", ts);
            if(ISSPACE(MRASTOLDEF->TOOL_ID, sizeof(MRASTOLDEF->TOOL_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.TOOL_ID);
                sprintf(sql + strlen(sql), "AND TOOL_ID >= '%s' ", ts);
            }
            if(MRASTOLDEF->DELETE_FLAG == ' ') 
            {
                /* Do Nothing */
            }
            else if(MRASTOLDEF->DELETE_FLAG == 'N')
            {
                sprintf(sql + strlen(sql), "AND DELETE_FLAG = ' ' ");   
            }
            else if(MRASTOLDEF->DELETE_FLAG == 'Y')
            {
                sprintf(sql + strlen(sql), "AND DELETE_FLAG <> ' ' ");   
            }
            else
            {
                sprintf(sql + strlen(sql), "AND DELETE_FLAG = '%c' ", MRASTOLDEF_N.DELETE_FLAG[0]);   
            }
            sprintf(sql + strlen(sql), "ORDER BY FACTORY, TOOL_ID ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MRASTOLDEF_CUR_3 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MRASTOLDEF_CUR_3;
            break;

        case 4:
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "FACTORY, ");
            sprintf(sql + strlen(sql),   "TOOL_ID, ");
            sprintf(sql + strlen(sql),   "TOOL_DESC, ");
            sprintf(sql + strlen(sql),   "TOOL_TYPE, ");
            sprintf(sql + strlen(sql),   "TOOL_GRP, ");
            sprintf(sql + strlen(sql),   "TOOL_SET_ID, ");
            sprintf(sql + strlen(sql),   "TOOL_SET_LOCATION, ");
            sprintf(sql + strlen(sql),   "TOOL_STATUS, ");
            sprintf(sql + strlen(sql),   "LOT_ID, ");
            sprintf(sql + strlen(sql),   "SUBLOT_ID, ");
            sprintf(sql + strlen(sql),   "RES_ID, ");
            sprintf(sql + strlen(sql),   "SUBRES_ID, ");
            sprintf(sql + strlen(sql),   "MAT_ID, ");
            sprintf(sql + strlen(sql),   "MAT_VER, ");
            sprintf(sql + strlen(sql),   "FLOW, ");
            sprintf(sql + strlen(sql),   "OPER, ");
            sprintf(sql + strlen(sql),   "AREA_ID, ");
            sprintf(sql + strlen(sql),   "SUB_AREA_ID, ");
            sprintf(sql + strlen(sql),   "TOOL_LOCATION, ");
            sprintf(sql + strlen(sql),   "VENDOR_ID, ");
            sprintf(sql + strlen(sql),   "VENDOR_TOOL_ID, ");
            sprintf(sql + strlen(sql),   "CELL_COUNT_X, ");
            sprintf(sql + strlen(sql),   "CELL_COUNT_Y, ");
            sprintf(sql + strlen(sql),   "CELL_COUNT_Z, ");
            sprintf(sql + strlen(sql),   "CELL_SIZE_X, ");
            sprintf(sql + strlen(sql),   "CELL_SIZE_Y, ");
            sprintf(sql + strlen(sql),   "CELL_SIZE_Z, ");
            sprintf(sql + strlen(sql),   "GRADE, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_1, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_2, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_3, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_4, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_5, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_6, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_7, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_8, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_9, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_10, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_11, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_12, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_13, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_14, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_15, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_16, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_17, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_18, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_19, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_20, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_21, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_22, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_23, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_24, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_25, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_26, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_27, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_28, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_29, ");
            sprintf(sql + strlen(sql),   "TOOL_STS_30, ");
            sprintf(sql + strlen(sql),   "LAST_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "LAST_ACTIVE_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "LAST_TOOL_EVENT_ID, ");
            sprintf(sql + strlen(sql),   "LAST_TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "DELETE_FLAG, ");
            sprintf(sql + strlen(sql),   "TOOL_COMMENT, ");
            sprintf(sql + strlen(sql),   "CREATE_USER_ID, ");
            sprintf(sql + strlen(sql),   "CREATE_TIME, ");
            sprintf(sql + strlen(sql),   "UPDATE_USER_ID, ");
            sprintf(sql + strlen(sql),   "UPDATE_TIME ");
            sprintf(sql + strlen(sql), "FROM MRASTOLDEF WHERE ");
            make_valid_quote(ts, MRASTOLDEF_N.FACTORY);
            sprintf(sql + strlen(sql), "FACTORY = '%s' ", ts);
            if(ISSPACE(MRASTOLDEF->TOOL_TYPE, sizeof(MRASTOLDEF->TOOL_TYPE)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.TOOL_TYPE);
                sprintf(sql + strlen(sql), "AND TOOL_TYPE = '%s' ", ts);
            }
            if(ISSPACE(MRASTOLDEF->TOOL_GRP, sizeof(MRASTOLDEF->TOOL_GRP)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.TOOL_GRP);
                sprintf(sql + strlen(sql), "AND TOOL_GRP = '%s' ", ts);
            }
            if(ISSPACE(MRASTOLDEF->TOOL_SET_ID, sizeof(MRASTOLDEF->TOOL_SET_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.TOOL_SET_ID);
                sprintf(sql + strlen(sql), "AND TOOL_SET_ID = '%s' ", ts);
            }
            if(ISSPACE(MRASTOLDEF->TOOL_STATUS, sizeof(MRASTOLDEF->TOOL_STATUS)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.TOOL_STATUS);
                sprintf(sql + strlen(sql), "AND TOOL_STATUS = '%s' ", ts);
            }
            if(ISSPACE(MRASTOLDEF->LOT_ID, sizeof(MRASTOLDEF->LOT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.LOT_ID);
                sprintf(sql + strlen(sql), "AND LOT_ID = '%s' ", ts);
            }
            if(ISSPACE(MRASTOLDEF->SUBLOT_ID, sizeof(MRASTOLDEF->SUBLOT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.SUBLOT_ID);
                sprintf(sql + strlen(sql), "AND SUBLOT_ID = '%s' ", ts);
            }
            if(ISSPACE(MRASTOLDEF->RES_ID, sizeof(MRASTOLDEF->RES_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.RES_ID);
                sprintf(sql + strlen(sql), "AND RES_ID = '%s' ", ts);
            }
            if(ISSPACE(MRASTOLDEF->SUBRES_ID, sizeof(MRASTOLDEF->SUBRES_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.SUBRES_ID);
                sprintf(sql + strlen(sql), "AND SUBRES_ID = '%s' ", ts);
            }
            if(ISSPACE(MRASTOLDEF->MAT_ID, sizeof(MRASTOLDEF->MAT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.MAT_ID);
                sprintf(sql + strlen(sql), "AND MAT_ID = '%s' ", ts);
            }
            /* Mod for V42 */
            if(MRASTOLDEF->MAT_VER != 0)
            {
                sprintf(sql + strlen(sql), "AND MAT_VER = '%d' ", MRASTOLDEF->MAT_VER);
            }
            if(ISSPACE(MRASTOLDEF->FLOW, sizeof(MRASTOLDEF->FLOW)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.FLOW);
                sprintf(sql + strlen(sql), "AND FLOW = '%s' ", ts);
            }
            if(ISSPACE(MRASTOLDEF->OPER, sizeof(MRASTOLDEF->OPER)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.OPER);
                sprintf(sql + strlen(sql), "AND OPER = '%s' ", ts);
            }
            if(ISSPACE(MRASTOLDEF->AREA_ID, sizeof(MRASTOLDEF->AREA_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.AREA_ID);
                sprintf(sql + strlen(sql), "AND AREA_ID = '%s' ", ts);
            }
            if(ISSPACE(MRASTOLDEF->SUB_AREA_ID, sizeof(MRASTOLDEF->SUB_AREA_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.SUB_AREA_ID);
                sprintf(sql + strlen(sql), "AND SUB_AREA_ID = '%s' ", ts);
            }
            if(ISSPACE(MRASTOLDEF->VENDOR_ID, sizeof(MRASTOLDEF->VENDOR_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.VENDOR_ID);
                sprintf(sql + strlen(sql), "AND VENDOR_ID = '%s' ", ts);
            }
            if(MRASTOLDEF->GRADE != ' ')
            {
                sprintf(sql + strlen(sql), "AND GRADE = '%c' ", MRASTOLDEF_N.GRADE[0]);
            }
            if(MRASTOLDEF->DELETE_FLAG == ' ') 
            {
                /* Do Nothing */
            }
            else if(MRASTOLDEF->DELETE_FLAG == 'N')
            {
                sprintf(sql + strlen(sql), "AND DELETE_FLAG = ' ' ");   
            }
            else if(MRASTOLDEF->DELETE_FLAG == 'Y')
            {
                sprintf(sql + strlen(sql), "AND DELETE_FLAG <> ' ' ");   
            }
            else
            {
                sprintf(sql + strlen(sql), "AND DELETE_FLAG = '%c' ", MRASTOLDEF_N.DELETE_FLAG[0]);   
            }
            if(ISSPACE(MRASTOLDEF->TOOL_ID, sizeof(MRASTOLDEF->TOOL_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, MRASTOLDEF_N.TOOL_ID);
                sprintf(sql + strlen(sql), "AND TOOL_ID >= '%s' ", ts);
            }
            sprintf(sql + strlen(sql), "ORDER BY FACTORY, TOOL_ID ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MRASTOLDEF_CUR_4 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MRASTOLDEF_CUR_4;
            break;

        case 5:
            EXEC SQL DECLARE DBC_MRASTOLDEF_CUR_5 CURSOR FOR
                SELECT 
                    FACTORY,
                    TOOL_ID,
                    TOOL_DESC,
                    TOOL_TYPE,
                    TOOL_GRP,
                    TOOL_SET_ID,
                    TOOL_SET_LOCATION,
                    TOOL_STATUS,
                    LOT_ID,
                    SUBLOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPER,
                    AREA_ID,
                    SUB_AREA_ID,
                    TOOL_LOCATION,
                    VENDOR_ID,
                    VENDOR_TOOL_ID,
                    CELL_COUNT_X,
                    CELL_COUNT_Y,
                    CELL_COUNT_Z,
                    CELL_SIZE_X,
                    CELL_SIZE_Y,
                    CELL_SIZE_Z,
                    GRADE,
                    TOOL_STS_1,
                    TOOL_STS_2,
                    TOOL_STS_3,
                    TOOL_STS_4,
                    TOOL_STS_5,
                    TOOL_STS_6,
                    TOOL_STS_7,
                    TOOL_STS_8,
                    TOOL_STS_9,
                    TOOL_STS_10,
                    TOOL_STS_11,
                    TOOL_STS_12,
                    TOOL_STS_13,
                    TOOL_STS_14,
                    TOOL_STS_15,
                    TOOL_STS_16,
                    TOOL_STS_17,
                    TOOL_STS_18,
                    TOOL_STS_19,
                    TOOL_STS_20,
                    TOOL_STS_21,
                    TOOL_STS_22,
                    TOOL_STS_23,
                    TOOL_STS_24,
                    TOOL_STS_25,
                    TOOL_STS_26,
                    TOOL_STS_27,
                    TOOL_STS_28,
                    TOOL_STS_29,
                    TOOL_STS_30,
                    LAST_HIST_SEQ,
                    LAST_ACTIVE_HIST_SEQ,
                    LAST_TOOL_EVENT_ID,
                    LAST_TRAN_TIME,
                    DELETE_FLAG,
                    TOOL_COMMENT,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRASTOLDEF
                WHERE FACTORY = :MRASTOLDEF_N.FACTORY
                    AND ((TOOL_TYPE = :MRASTOLDEF_N.TOOL_TYPE AND TOOL_ID >= :MRASTOLDEF_N.TOOL_ID) OR TOOL_TYPE > :MRASTOLDEF_N.TOOL_TYPE)
                    AND TOOL_TYPE IN (
                        SELECT DISTINCT DATA_1 
                        FROM MWIPOPRINV
                        WHERE FACTORY = :MRASTOLDEF_N.FACTORY
                            AND REL_LEVEL = :MRASTOLDEF_N.GRADE
                            AND MAT_ID = :MRASTOLDEF_N.MAT_ID
                            AND MAT_VER = :MRASTOLDEF_N.MAT_VER
                            AND FLOW = :MRASTOLDEF_N.FLOW
                            AND OPER = :MRASTOLDEF_N.OPER
                            AND POINT_TYPE LIKE :MRASTOLDEF_N.DELETE_FLAG

                        )
                    AND DELETE_FLAG = ' '
                ORDER BY TOOL_TYPE ASC, TOOL_ID ASC;
            EXEC SQL OPEN DBC_MRASTOLDEF_CUR_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrastoldef", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mrastoldef(int sel_type, struct MRASTOLDEF_TAG *MRASTOLDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASTOLDEF_N_TAG MRASTOLDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MRASTOLDEF_CUR_1 INTO 
                                                    :MRASTOLDEF_N.FACTORY,
                                                    :MRASTOLDEF_N.TOOL_ID,
                                                    :MRASTOLDEF_N.TOOL_DESC,
                                                    :MRASTOLDEF_N.TOOL_TYPE,
                                                    :MRASTOLDEF_N.TOOL_GRP,
                                                    :MRASTOLDEF_N.TOOL_SET_ID,
                                                    :MRASTOLDEF_N.TOOL_SET_LOCATION,
                                                    :MRASTOLDEF_N.TOOL_STATUS,
                                                    :MRASTOLDEF_N.LOT_ID,
                                                    :MRASTOLDEF_N.SUBLOT_ID,
                                                    :MRASTOLDEF_N.RES_ID,
                                                    :MRASTOLDEF_N.SUBRES_ID,
                                                    :MRASTOLDEF_N.MAT_ID,
                                                    :MRASTOLDEF_N.MAT_VER,
                                                    :MRASTOLDEF_N.FLOW,
                                                    :MRASTOLDEF_N.OPER,
                                                    :MRASTOLDEF_N.AREA_ID,
                                                    :MRASTOLDEF_N.SUB_AREA_ID,
                                                    :MRASTOLDEF_N.TOOL_LOCATION,
                                                    :MRASTOLDEF_N.VENDOR_ID,
                                                    :MRASTOLDEF_N.VENDOR_TOOL_ID,
