/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mqcmbathis(int sel_type, struct MQCMBATHIS_TAG *MQCMBATHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MQCMBATHIS_N_TAG MQCMBATHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mqcmbathis(&MQCMBATHIS_N, MQCMBATHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MQCMBATHIS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    BATCH_ID,
                    HIST_SEQ,
                    INSP_METHOD,
                    MAT_ID,
                    MAT_VER,
                    ORDER_ID,
                    RES_ID,
                    INSP_SET_ID,
                    INSP_SET_VERSION,
                    ITEM_COUNT,
                    TOT_QTY_1,
                    TOT_QTY_2,
                    TOT_QTY_3,
                    INSP_STEP,
                    TRAN_CODE,
                    FINAL_DECISION,
                    SPLIT_FROM_BATCH,
                    MERGE_TO_BATCH,
                    ITEM_RESULT_SEQ,
                    INSP_SEQ,
                    BAT_CMF_1,
                    BAT_CMF_2,
                    BAT_CMF_3,
                    BAT_CMF_4,
                    BAT_CMF_5,
                    BAT_CMF_6,
                    BAT_CMF_7,
                    BAT_CMF_8,
                    BAT_CMF_9,
                    BAT_CMF_10,
                    HIS_COMMENT,
                    USER_ID,
                    TRAN_TIME
                FROM MQCMBATHIS
                WHERE FACTORY =:MQCMBATHIS_N.FACTORY
                  AND BATCH_ID =:MQCMBATHIS_N.BATCH_ID
                  AND HIST_SEQ >=:MQCMBATHIS_N.HIST_SEQ
                ORDER BY HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MQCMBATHIS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mqcmbathis", sel_type);
}


