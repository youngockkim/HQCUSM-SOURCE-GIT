void DBC_add_null_mqcmbathis(struct MQCMBATHIS_N_TAG *MQCMBATHIS_N, struct MQCMBATHIS_TAG *MQCMBATHIS)
{
    /* memset by NULL */
    memset(MQCMBATHIS_N, '\0', sizeof(struct MQCMBATHIS_N_TAG));
    
    MEMCPY_AN(MQCMBATHIS_N->FACTORY, MQCMBATHIS->FACTORY, sizeof(MQCMBATHIS->FACTORY));
    MEMCPY_AN(MQCMBATHIS_N->BATCH_ID, MQCMBATHIS->BATCH_ID, sizeof(MQCMBATHIS->BATCH_ID));
    MQCMBATHIS_N->HIST_SEQ = MQCMBATHIS->HIST_SEQ;
    MEMCPY_AN(MQCMBATHIS_N->INSP_METHOD, MQCMBATHIS->INSP_METHOD, sizeof(MQCMBATHIS->INSP_METHOD));
    MEMCPY_AN(MQCMBATHIS_N->MAT_ID, MQCMBATHIS->MAT_ID, sizeof(MQCMBATHIS->MAT_ID));
    MQCMBATHIS_N->MAT_VER = MQCMBATHIS->MAT_VER;
    MEMCPY_AN(MQCMBATHIS_N->ORDER_ID, MQCMBATHIS->ORDER_ID, sizeof(MQCMBATHIS->ORDER_ID));
    MEMCPY_AN(MQCMBATHIS_N->RES_ID, MQCMBATHIS->RES_ID, sizeof(MQCMBATHIS->RES_ID));
    MEMCPY_AN(MQCMBATHIS_N->INSP_SET_ID, MQCMBATHIS->INSP_SET_ID, sizeof(MQCMBATHIS->INSP_SET_ID));
    MQCMBATHIS_N->INSP_SET_VERSION = MQCMBATHIS->INSP_SET_VERSION;
    MQCMBATHIS_N->ITEM_COUNT = MQCMBATHIS->ITEM_COUNT;
    MQCMBATHIS_N->TOT_QTY_1 = MQCMBATHIS->TOT_QTY_1;
    MQCMBATHIS_N->TOT_QTY_2 = MQCMBATHIS->TOT_QTY_2;
    MQCMBATHIS_N->TOT_QTY_3 = MQCMBATHIS->TOT_QTY_3;
    MEMCPY_AN(MQCMBATHIS_N->INSP_STEP, MQCMBATHIS->INSP_STEP, sizeof(MQCMBATHIS->INSP_STEP));
    MEMCPY_AN(MQCMBATHIS_N->TRAN_CODE, MQCMBATHIS->TRAN_CODE, sizeof(MQCMBATHIS->TRAN_CODE));
    MEMCPY_AN(MQCMBATHIS_N->FINAL_DECISION, MQCMBATHIS->FINAL_DECISION, sizeof(MQCMBATHIS->FINAL_DECISION));
    MEMCPY_AN(MQCMBATHIS_N->SPLIT_FROM_BATCH, MQCMBATHIS->SPLIT_FROM_BATCH, sizeof(MQCMBATHIS->SPLIT_FROM_BATCH));
    MEMCPY_AN(MQCMBATHIS_N->MERGE_TO_BATCH, MQCMBATHIS->MERGE_TO_BATCH, sizeof(MQCMBATHIS->MERGE_TO_BATCH));
    MQCMBATHIS_N->ITEM_RESULT_SEQ = MQCMBATHIS->ITEM_RESULT_SEQ;
    MQCMBATHIS_N->INSP_SEQ = MQCMBATHIS->INSP_SEQ;
    MEMCPY_AN(MQCMBATHIS_N->BAT_CMF_1, MQCMBATHIS->BAT_CMF_1, sizeof(MQCMBATHIS->BAT_CMF_1));
    MEMCPY_AN(MQCMBATHIS_N->BAT_CMF_2, MQCMBATHIS->BAT_CMF_2, sizeof(MQCMBATHIS->BAT_CMF_2));
    MEMCPY_AN(MQCMBATHIS_N->BAT_CMF_3, MQCMBATHIS->BAT_CMF_3, sizeof(MQCMBATHIS->BAT_CMF_3));
    MEMCPY_AN(MQCMBATHIS_N->BAT_CMF_4, MQCMBATHIS->BAT_CMF_4, sizeof(MQCMBATHIS->BAT_CMF_4));
    MEMCPY_AN(MQCMBATHIS_N->BAT_CMF_5, MQCMBATHIS->BAT_CMF_5, sizeof(MQCMBATHIS->BAT_CMF_5));
    MEMCPY_AN(MQCMBATHIS_N->BAT_CMF_6, MQCMBATHIS->BAT_CMF_6, sizeof(MQCMBATHIS->BAT_CMF_6));
    MEMCPY_AN(MQCMBATHIS_N->BAT_CMF_7, MQCMBATHIS->BAT_CMF_7, sizeof(MQCMBATHIS->BAT_CMF_7));
    MEMCPY_AN(MQCMBATHIS_N->BAT_CMF_8, MQCMBATHIS->BAT_CMF_8, sizeof(MQCMBATHIS->BAT_CMF_8));
    MEMCPY_AN(MQCMBATHIS_N->BAT_CMF_9, MQCMBATHIS->BAT_CMF_9, sizeof(MQCMBATHIS->BAT_CMF_9));
    MEMCPY_AN(MQCMBATHIS_N->BAT_CMF_10, MQCMBATHIS->BAT_CMF_10, sizeof(MQCMBATHIS->BAT_CMF_10));
    MEMCPY_AN(MQCMBATHIS_N->HIS_COMMENT, MQCMBATHIS->HIS_COMMENT, sizeof(MQCMBATHIS->HIS_COMMENT));
    MEMCPY_AN(MQCMBATHIS_N->USER_ID, MQCMBATHIS->USER_ID, sizeof(MQCMBATHIS->USER_ID));
    MEMCPY_AN(MQCMBATHIS_N->TRAN_TIME, MQCMBATHIS->TRAN_TIME, sizeof(MQCMBATHIS->TRAN_TIME));
}


/* Del Null Function */
void DBC_del_null_mqcmbathis(struct MQCMBATHIS_N_TAG *MQCMBATHIS_N, struct MQCMBATHIS_TAG *MQCMBATHIS)
{
    MEMCPY_DN(MQCMBATHIS->FACTORY, MQCMBATHIS_N->FACTORY, sizeof(MQCMBATHIS->FACTORY));
    MEMCPY_DN(MQCMBATHIS->BATCH_ID, MQCMBATHIS_N->BATCH_ID, sizeof(MQCMBATHIS->BATCH_ID));
