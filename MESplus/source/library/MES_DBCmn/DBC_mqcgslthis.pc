                    AND SUBLOT_ID = :MQCGSLTHIS_N.SUBLOT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_mqcgslthis", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mqcgslthis(int sel_type, struct MQCGSLTHIS_TAG *MQCGSLTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    struct MQCGSLTHIS_N_TAG MQCGSLTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mqcgslthis(&MQCGSLTHIS_N, MQCGSLTHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MQCGSLTHIS_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    QA_HIST_SEQ,
                    SUBLOT_ID,
                    SLOT_NO,
                    SUB_LOT_HIST_SEQ,
                    TRAN_TIME,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    QA_OPER,
                    RES_ID,
                    CRR_ID,
                    QTY_2,
                    QTY_3,
                    PASS_FLAG,
                    SMP_SIZE,
                    DEF_QTY,
                    YIELD,
                    TEST_TYPE,
                    INSPECTOR,
                    SHIFT,
                    IRRMRR,
                    QA_COMMENT,
                    ALARM_CODE,
                    HIST_DEL_FLAG,
                    HIST_DEL_TIME,
                    HIST_DEL_USER,
                    HIST_DEL_COMMENT,
                    QA_CMF_1,
                    QA_CMF_2,
                    QA_CMF_3,
                    QA_CMF_4,
                    QA_CMF_5,
                    QA_CMF_6,
                    QA_CMF_7,
                    QA_CMF_8,
                    QA_CMF_9,
                    QA_CMF_10,
                    RESV_FIELD_1,
                    RESV_FIELD_2,
                    RESV_FIELD_3,
                    RESV_FIELD_4,
                    RESV_FIELD_5,
                    RESV_FIELD_6,
                    RESV_FIELD_7,
                    RESV_FIELD_8,
                    RESV_FIELD_9,
                    RESV_FIELD_10,
                    CP_QTY,
                    GOOD_QTY,
                    IC_TOTAL_LIMIT,
                    IC_OTHER_LIMIT,
                    TOTAL_DEFECT_LIMIT,
                    FIRST_DEFECT_LIMIT
                FROM MQCGSLTHIS
                WHERE LOT_ID = :MQCGSLTHIS_N.LOT_ID
                AND HIST_SEQ = :MQCGSLTHIS_N.HIST_SEQ
                AND QA_HIST_SEQ = :MQCGSLTHIS_N.QA_HIST_SEQ
                ORDER BY SLOT_NO ASC;
            EXEC SQL OPEN DBC_MQCGSLTHIS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mqcgslthis", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mqcgslthis(int sel_type, struct MQCGSLTHIS_TAG *MQCGSLTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    struct MQCGSLTHIS_N_TAG MQCGSLTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MQCGSLTHIS_CUR_1 INTO
                :MQCGSLTHIS_N.LOT_ID,
                :MQCGSLTHIS_N.HIST_SEQ,
                :MQCGSLTHIS_N.QA_HIST_SEQ,
                :MQCGSLTHIS_N.SUBLOT_ID,
                :MQCGSLTHIS_N.SLOT_NO,
                :MQCGSLTHIS_N.SUB_LOT_HIST_SEQ,
                :MQCGSLTHIS_N.TRAN_TIME,
                :MQCGSLTHIS_N.FACTORY,
                :MQCGSLTHIS_N.MAT_ID,
                :MQCGSLTHIS_N.MAT_VER,
                :MQCGSLTHIS_N.FLOW,
                :MQCGSLTHIS_N.FLOW_SEQ_NUM,
                :MQCGSLTHIS_N.OPER,
                :MQCGSLTHIS_N.QA_OPER,
                :MQCGSLTHIS_N.RES_ID,
                :MQCGSLTHIS_N.CRR_ID,
                :MQCGSLTHIS_N.QTY_2,
                :MQCGSLTHIS_N.QTY_3,
                :MQCGSLTHIS_N.PASS_FLAG,
                :MQCGSLTHIS_N.SMP_SIZE,
                :MQCGSLTHIS_N.DEF_QTY,
                :MQCGSLTHIS_N.YIELD,
                :MQCGSLTHIS_N.TEST_TYPE,
                :MQCGSLTHIS_N.INSPECTOR,
                :MQCGSLTHIS_N.SHIFT,
                :MQCGSLTHIS_N.IRRMRR,
                :MQCGSLTHIS_N.QA_COMMENT,
                :MQCGSLTHIS_N.ALARM_CODE,
                :MQCGSLTHIS_N.HIST_DEL_FLAG,
                :MQCGSLTHIS_N.HIST_DEL_TIME,
                :MQCGSLTHIS_N.HIST_DEL_USER,
                :MQCGSLTHIS_N.HIST_DEL_COMMENT,
                :MQCGSLTHIS_N.QA_CMF_1,
                :MQCGSLTHIS_N.QA_CMF_2,
                :MQCGSLTHIS_N.QA_CMF_3,
                :MQCGSLTHIS_N.QA_CMF_4,
                :MQCGSLTHIS_N.QA_CMF_5,
                :MQCGSLTHIS_N.QA_CMF_6,
                :MQCGSLTHIS_N.QA_CMF_7,
                :MQCGSLTHIS_N.QA_CMF_8,
                :MQCGSLTHIS_N.QA_CMF_9,
                :MQCGSLTHIS_N.QA_CMF_10,
                :MQCGSLTHIS_N.RESV_FIELD_1,
                :MQCGSLTHIS_N.RESV_FIELD_2,
                :MQCGSLTHIS_N.RESV_FIELD_3,
                :MQCGSLTHIS_N.RESV_FIELD_4,
                :MQCGSLTHIS_N.RESV_FIELD_5,
                :MQCGSLTHIS_N.RESV_FIELD_6,
                :MQCGSLTHIS_N.RESV_FIELD_7,
                :MQCGSLTHIS_N.RESV_FIELD_8,
                :MQCGSLTHIS_N.RESV_FIELD_9,
                :MQCGSLTHIS_N.RESV_FIELD_10,
                :MQCGSLTHIS_N.CP_QTY,
                :MQCGSLTHIS_N.GOOD_QTY,
                :MQCGSLTHIS_N.IC_TOTAL_LIMIT,
                :MQCGSLTHIS_N.IC_OTHER_LIMIT,
                :MQCGSLTHIS_N.TOTAL_DEFECT_LIMIT,
                :MQCGSLTHIS_N.FIRST_DEFECT_LIMIT;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mqcgslthis(&MQCGSLTHIS_N, MQCGSLTHIS);
    }
    DB_stop_query_timer("DBC_fetch_mqcgslthis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mqcgslthis(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MQCGSLTHIS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mqcgslthis", sel_type);
}


/* Initialize Function */
void DBC_init_mqcgslthis(struct MQCGSLTHIS_TAG *MQCGSLTHIS)
{
    /* memset by Space */
    memset(MQCGSLTHIS, ' ', sizeof(struct MQCGSLTHIS_TAG));
    
    MQCGSLTHIS->HIST_SEQ = 0;
    MQCGSLTHIS->QA_HIST_SEQ = 0;
    MQCGSLTHIS->SLOT_NO = 0;
    MQCGSLTHIS->SUB_LOT_HIST_SEQ = 0;
    MQCGSLTHIS->MAT_VER = 0;
    MQCGSLTHIS->FLOW_SEQ_NUM = 0;
    MQCGSLTHIS->QTY_2 = 0;
    MQCGSLTHIS->QTY_3 = 0;
    MQCGSLTHIS->SMP_SIZE = 0;
    MQCGSLTHIS->DEF_QTY = 0;
    MQCGSLTHIS->YIELD = 0;
    MQCGSLTHIS->CP_QTY = 0;
    MQCGSLTHIS->GOOD_QTY = 0;
    MQCGSLTHIS->IC_TOTAL_LIMIT = 0;
    MQCGSLTHIS->IC_OTHER_LIMIT = 0;
    MQCGSLTHIS->TOTAL_DEFECT_LIMIT = 0;
    MQCGSLTHIS->FIRST_DEFECT_LIMIT = 0;
}


/* Add Null Function */
void DBC_add_null_mqcgslthis(struct MQCGSLTHIS_N_TAG *MQCGSLTHIS_N, struct MQCGSLTHIS_TAG *MQCGSLTHIS)
{
    /* memset by NULL */
    memset(MQCGSLTHIS_N, '\0', sizeof(struct MQCGSLTHIS_N_TAG));
    
    MEMCPY_AN(MQCGSLTHIS_N->LOT_ID, MQCGSLTHIS->LOT_ID, sizeof(MQCGSLTHIS->LOT_ID));
    MQCGSLTHIS_N->HIST_SEQ = MQCGSLTHIS->HIST_SEQ;
    MQCGSLTHIS_N->QA_HIST_SEQ = MQCGSLTHIS->QA_HIST_SEQ;
    MEMCPY_AN(MQCGSLTHIS_N->SUBLOT_ID, MQCGSLTHIS->SUBLOT_ID, sizeof(MQCGSLTHIS->SUBLOT_ID));
    MQCGSLTHIS_N->SLOT_NO = MQCGSLTHIS->SLOT_NO;
    MQCGSLTHIS_N->SUB_LOT_HIST_SEQ = MQCGSLTHIS->SUB_LOT_HIST_SEQ;
    MEMCPY_AN(MQCGSLTHIS_N->TRAN_TIME, MQCGSLTHIS->TRAN_TIME, sizeof(MQCGSLTHIS->TRAN_TIME));
    MEMCPY_AN(MQCGSLTHIS_N->FACTORY, MQCGSLTHIS->FACTORY, sizeof(MQCGSLTHIS->FACTORY));
    MEMCPY_AN(MQCGSLTHIS_N->MAT_ID, MQCGSLTHIS->MAT_ID, sizeof(MQCGSLTHIS->MAT_ID));
    MQCGSLTHIS_N->MAT_VER = MQCGSLTHIS->MAT_VER;
    MEMCPY_AN(MQCGSLTHIS_N->FLOW, MQCGSLTHIS->FLOW, sizeof(MQCGSLTHIS->FLOW));
