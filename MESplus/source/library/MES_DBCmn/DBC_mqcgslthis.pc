    MEMCPY_AN(MQCGSLTHIS_N->RESV_FIELD_9, MQCGSLTHIS->RESV_FIELD_9, sizeof(MQCGSLTHIS->RESV_FIELD_9));
    MEMCPY_AN(MQCGSLTHIS_N->RESV_FIELD_10, MQCGSLTHIS->RESV_FIELD_10, sizeof(MQCGSLTHIS->RESV_FIELD_10));
