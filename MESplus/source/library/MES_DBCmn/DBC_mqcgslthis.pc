    MQCGSLTHIS_N->FIRST_DEFECT_LIMIT = MQCGSLTHIS->FIRST_DEFECT_LIMIT;
}


/* Del Null Function */
void DBC_del_null_mqcgslthis(struct MQCGSLTHIS_N_TAG *MQCGSLTHIS_N, struct MQCGSLTHIS_TAG *MQCGSLTHIS)
{
    MEMCPY_DN(MQCGSLTHIS->LOT_ID, MQCGSLTHIS_N->LOT_ID, sizeof(MQCGSLTHIS->LOT_ID));
    MQCGSLTHIS->HIST_SEQ = MQCGSLTHIS_N->HIST_SEQ;
    MQCGSLTHIS->QA_HIST_SEQ = MQCGSLTHIS_N->QA_HIST_SEQ;
    MEMCPY_DN(MQCGSLTHIS->SUBLOT_ID, MQCGSLTHIS_N->SUBLOT_ID, sizeof(MQCGSLTHIS->SUBLOT_ID));
    MQCGSLTHIS->SLOT_NO = MQCGSLTHIS_N->SLOT_NO;
