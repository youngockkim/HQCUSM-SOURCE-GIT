/* SQL UPDATE Function */
void DBC_update_mrastoltye(int sel_type, struct MRASTOLTYE_TAG *MRASTOLTYE)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASTOLTYE_N_TAG MRASTOLTYE_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrastoltye(&MRASTOLTYE_N, MRASTOLTYE);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
