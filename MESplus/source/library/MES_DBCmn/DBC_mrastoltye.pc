            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mrastoltye(&MRASTOLTYE_N, MRASTOLTYE);
    }
    DB_stop_query_timer("DBC_fetch_mrastoltye", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mrastoltye(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MRASTOLTYE_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MRASTOLTYE_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MRASTOLTYE_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mrastoltye", sel_type);
}


