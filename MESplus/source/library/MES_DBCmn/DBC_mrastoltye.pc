                    :MRASTOLTYE_N.UPDATE_USER_ID,
                    :MRASTOLTYE_N.UPDATE_TIME
                FROM MRASTOLTYE
                WHERE FACTORY = :MRASTOLTYE_N.FACTORY
                    AND TOOL_TYPE = :MRASTOLTYE_N.TOOL_TYPE
                FOR UPDATE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mrastoltye(&MRASTOLTYE_N, MRASTOLTYE);
    }
    DB_stop_query_timer("DBC_select_mrastoltye_for_update", sel_type);
}


/* SQL SELECT_SCALAR Function */
double DBC_select_mrastoltye_scalar(int sel_type, struct MRASTOLTYE_TAG *MRASTOLTYE)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASTOLTYE_N_TAG MRASTOLTYE_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrastoltye(&MRASTOLTYE_N, MRASTOLTYE);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MRASTOLTYE
                WHERE FACTORY = :MRASTOLTYE_N.FACTORY
                    AND TOOL_TYPE = :MRASTOLTYE_N.TOOL_TYPE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_select_mrastoltye_scalar", sel_type);
    return d_value;
}


/* SQL DELETE Function */
void DBC_delete_mrastoltye(int sel_type, struct MRASTOLTYE_TAG *MRASTOLTYE)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASTOLTYE_N_TAG MRASTOLTYE_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrastoltye(&MRASTOLTYE_N, MRASTOLTYE);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM MRASTOLTYE
                WHERE FACTORY = :MRASTOLTYE_N.FACTORY
                    AND TOOL_TYPE = :MRASTOLTYE_N.TOOL_TYPE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_delete_mrastoltye", sel_type);
}


