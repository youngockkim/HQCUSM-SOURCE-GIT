    MEMCPY_DN(MRCPSLPHIS->TRAN_TIME, MRCPSLPHIS_N->TRAN_TIME, sizeof(MRCPSLPHIS->TRAN_TIME));
    MEMCPY_DN(MRCPSLPHIS->TRAN_CODE, MRCPSLPHIS_N->TRAN_CODE, sizeof(MRCPSLPHIS->TRAN_CODE));
    MEMCPY_DN(MRCPSLPHIS->FACTORY, MRCPSLPHIS_N->FACTORY, sizeof(MRCPSLPHIS->FACTORY));
    MEMCPY_DN(MRCPSLPHIS->RES_ID, MRCPSLPHIS_N->RES_ID, sizeof(MRCPSLPHIS->RES_ID));
    MEMCPY_DN(MRCPSLPHIS->SUBRES_ID, MRCPSLPHIS_N->SUBRES_ID, sizeof(MRCPSLPHIS->SUBRES_ID));
    MEMCPY_DN(MRCPSLPHIS->RECIPE, MRCPSLPHIS_N->RECIPE, sizeof(MRCPSLPHIS->RECIPE));
    MRCPSLPHIS->RECIPE_VERSION = MRCPSLPHIS_N->RECIPE_VERSION;
    MRCPSLPHIS->PARA_SEQ = MRCPSLPHIS_N->PARA_SEQ;
    MEMCPY_DN(MRCPSLPHIS->PARA_ID, MRCPSLPHIS_N->PARA_ID, sizeof(MRCPSLPHIS->PARA_ID));
    MEMCPY_DN(MRCPSLPHIS->PARA_VALUE, MRCPSLPHIS_N->PARA_VALUE, sizeof(MRCPSLPHIS->PARA_VALUE));
    MEMCPY_DN(MRCPSLPHIS->PARA_DESC, MRCPSLPHIS_N->PARA_DESC, sizeof(MRCPSLPHIS->PARA_DESC));
    MRCPSLPHIS->MODIFY_FLAG = MRCPSLPHIS_N->MODIFY_FLAG[0];
    MEMCPY_DN(MRCPSLPHIS->UPDATE_USER_ID, MRCPSLPHIS_N->UPDATE_USER_ID, sizeof(MRCPSLPHIS->UPDATE_USER_ID));
    MEMCPY_DN(MRCPSLPHIS->UPDATE_TIME, MRCPSLPHIS_N->UPDATE_TIME, sizeof(MRCPSLPHIS->UPDATE_TIME));
}


