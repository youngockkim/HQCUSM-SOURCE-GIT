/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrcpslphis(int sel_type, struct MRCPSLPHIS_TAG *MRCPSLPHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRCPSLPHIS_N_TAG MRCPSLPHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrcpslphis(&MRCPSLPHIS_N, MRCPSLPHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRCPSLPHIS_CUR_1 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    TRAN_CODE,
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    RECIPE,
                    RECIPE_VERSION,
                    PARA_SEQ,
                    PARA_ID,
                    PARA_VALUE,
                    PARA_DESC,
                    MODIFY_FLAG,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRCPSLPHIS
                WHERE SUBLOT_ID = :MRCPSLPHIS_N.SUBLOT_ID
                  AND TRAN_TIME = (SELECT NVL(MAX(TRAN_TIME), '00000000000000') FROM MRCPSLPHIS
                                   WHERE SUBLOT_ID = :MRCPSLPHIS_N.SUBLOT_ID
                                     AND HIST_SEQ = :MRCPSLPHIS_N.HIST_SEQ
                                  )
                ORDER BY PARA_SEQ ASC;
            EXEC SQL OPEN DBC_MRCPSLPHIS_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MRCPSLPHIS_CUR_2 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    TRAN_CODE,
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    RECIPE,
                    RECIPE_VERSION,
                    PARA_SEQ,
                    PARA_ID,
                    PARA_VALUE,
                    PARA_DESC,
                    MODIFY_FLAG,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRCPSLPHIS
                WHERE LOT_ID = :MRCPSLPHIS_N.LOT_ID
                  AND TRAN_TIME = (SELECT NVL(MAX(TRAN_TIME), '00000000000000') FROM MRCPSLPHIS
                                   WHERE SUBLOT_ID = :MRCPSLPHIS_N.LOT_ID
                                     AND HIST_SEQ = :MRCPSLPHIS_N.HIST_SEQ
                                  )
                ORDER BY SUBLOT_ID ASC,
                    PARA_SEQ ASC;
            EXEC SQL OPEN DBC_MRCPSLPHIS_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrcpslphis", sel_type);
}


