        case 1:
            EXEC SQL DECLARE DBC_MEDCCOLCHE_CUR_1 CURSOR FOR
                SELECT 
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    FACTORY,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    CHAR_ID,
