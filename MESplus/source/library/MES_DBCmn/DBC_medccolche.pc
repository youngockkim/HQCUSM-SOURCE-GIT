                    AND COL_SET_ID = :MEDCCOLCHE_N.COL_SET_ID
                    AND COL_SET_VERSION = :MEDCCOLCHE_N.COL_SET_VERSION
                ORDER BY CHAR_ID ASC;
            EXEC SQL OPEN DBC_MEDCCOLCHE_CUR_1;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
