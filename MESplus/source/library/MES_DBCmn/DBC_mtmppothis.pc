                :MTMPPOTHIS_N.SYS_TRAN_TIME,
                :MTMPPOTHIS_N.TRS_STATE,
                :MTMPPOTHIS_N.ASC_STATE,
                :MTMPPOTHIS_N.ASC_OBJ_ID,
                :MTMPPOTHIS_N.ACC_STATE,
                :MTMPPOTHIS_N.RSV_STATE,
                :MTMPPOTHIS_N.RSV_OBJ_ID,
                :MTMPPOTHIS_N.LOT_ID,
                :MTMPPOTHIS_N.CRR_ID,
                :MTMPPOTHIS_N.BCR_STATUS_FLAG,
                :MTMPPOTHIS_N.TRAN_CMF_1,
                :MTMPPOTHIS_N.TRAN_CMF_2,
                :MTMPPOTHIS_N.TRAN_CMF_3,
                :MTMPPOTHIS_N.TRAN_CMF_4,
                :MTMPPOTHIS_N.TRAN_CMF_5,
                :MTMPPOTHIS_N.TRAN_CMF_6,
                :MTMPPOTHIS_N.TRAN_CMF_7,
                :MTMPPOTHIS_N.TRAN_CMF_8,
                :MTMPPOTHIS_N.TRAN_CMF_9,
                :MTMPPOTHIS_N.TRAN_CMF_10,
                :MTMPPOTHIS_N.TRAN_CMF_11,
                :MTMPPOTHIS_N.TRAN_CMF_12,
                :MTMPPOTHIS_N.TRAN_CMF_13,
                :MTMPPOTHIS_N.TRAN_CMF_14,
                :MTMPPOTHIS_N.TRAN_CMF_15,
                :MTMPPOTHIS_N.TRAN_CMF_16,
                :MTMPPOTHIS_N.TRAN_CMF_17,
                :MTMPPOTHIS_N.TRAN_CMF_18,
                :MTMPPOTHIS_N.TRAN_CMF_19,
                :MTMPPOTHIS_N.TRAN_CMF_20,
                :MTMPPOTHIS_N.TRAN_USER_ID,
                :MTMPPOTHIS_N.TRAN_COMMENT,
                :MTMPPOTHIS_N.PROCESS_FLAG;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mtmppothis(&MTMPPOTHIS_N, MTMPPOTHIS);
    }

    DB_stop_query_timer("DBC_fetch_mtmppothis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mtmppothis(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MTMPPOTHIS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("DBC_close_mtmppothis", sel_type);
}


/* Initialize Function */
void DBC_init_mtmppothis(struct MTMPPOTHIS_TAG *MTMPPOTHIS)
{
    /* memset by Space */
    memset(MTMPPOTHIS, ' ', sizeof(struct MTMPPOTHIS_TAG));
    
    MTMPPOTHIS->TABLE_UPDATE_SEQ = 0;
    MTMPPOTHIS->HIST_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mtmppothis(struct MTMPPOTHIS_N_TAG *MTMPPOTHIS_N, struct MTMPPOTHIS_TAG *MTMPPOTHIS)
{
    /* memset by NULL */
    memset(MTMPPOTHIS_N, '\0', sizeof(struct MTMPPOTHIS_N_TAG));
    
    MTMPPOTHIS_N->TABLE_UPDATE_SEQ = MTMPPOTHIS->TABLE_UPDATE_SEQ;
    MEMCPY_AN(MTMPPOTHIS_N->CM_KEY_1, MTMPPOTHIS->CM_KEY_1, sizeof(MTMPPOTHIS->CM_KEY_1));
