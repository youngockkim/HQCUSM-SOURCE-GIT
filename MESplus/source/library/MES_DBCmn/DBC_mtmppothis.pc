/* Del Null Function */
void DBC_del_null_mtmppothis(struct MTMPPOTHIS_N_TAG *MTMPPOTHIS_N, struct MTMPPOTHIS_TAG *MTMPPOTHIS)
{
    MTMPPOTHIS->TABLE_UPDATE_SEQ = MTMPPOTHIS_N->TABLE_UPDATE_SEQ;
