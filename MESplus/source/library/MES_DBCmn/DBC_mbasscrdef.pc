/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mbasscrdef(int sel_type, struct MBASSCRDEF_TAG *MBASSCRDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MBASSCRDEF_N_TAG MBASSCRDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mbasscrdef(&MBASSCRDEF_N, MBASSCRDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MBASSCRDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    SCREEN_ID,
                    SCREEN_DESC,
                    SCREEN_GROUP,
                    MODULE_NAME,
                    SERVICE_NAME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MBASSCRDEF
                ORDER BY SCREEN_ID ASC;
            EXEC SQL OPEN DBC_MBASSCRDEF_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MBASSCRDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    SCREEN_ID,
                    SCREEN_DESC,
                    SCREEN_GROUP,
                    MODULE_NAME,
                    SERVICE_NAME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MBASSCRDEF
                WHERE FACTORY LIKE :MBASSCRDEF_N.FACTORY
                AND SCREEN_GROUP LIKE :MBASSCRDEF_N.SCREEN_GROUP
                AND SCREEN_ID >= :MBASSCRDEF_N.SCREEN_ID
                ORDER BY SCREEN_ID ASC;
            EXEC SQL OPEN DBC_MBASSCRDEF_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mbasscrdef", sel_type);
}


