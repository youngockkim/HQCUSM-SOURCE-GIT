                :RESLOCDETAIL_N.RES_STS_8,
                :RESLOCDETAIL_N.RES_STS_9,
                :RESLOCDETAIL_N.RES_STS_10,
                :RESLOCDETAIL_N.LOT_ID,
                :RESLOCDETAIL_N.SUBLOT_ID,
                :RESLOCDETAIL_N.CRR_ID,
                :RESLOCDETAIL_N.RES_CTRL_MODE,
                :RESLOCDETAIL_N.RES_PROC_MODE,
                :RESLOCDETAIL_N.LAST_RECIPE_ID,
                :RESLOCDETAIL_N.PROC_COUNT,
                :RESLOCDETAIL_N.LAST_START_TIME,
                :RESLOCDETAIL_N.LAST_END_TIME,
                :RESLOCDETAIL_N.LAST_DOWN_TIME,
                :RESLOCDETAIL_N.LAST_DOWN_HIST_SEQ,
                :RESLOCDETAIL_N.LAST_EVENT_ID,
                :RESLOCDETAIL_N.LAST_EVENT_TIME,
                :RESLOCDETAIL_N.LAST_ACTIVE_HIST_SEQ,
                :RESLOCDETAIL_N.LAST_HIST_SEQ,
                :RESLOCDETAIL_N.RES_TAG_FLAG,
                :RESLOCDETAIL_N.LAYOUT_ID,
                :RESLOCDETAIL_N.SEQ,
                :RESLOCDETAIL_N.LOC_X,
                :RESLOCDETAIL_N.LOC_Y,
                :RESLOCDETAIL_N.LOC_WIDTH,
                :RESLOCDETAIL_N.LOC_HEIGHT,
                :RESLOCDETAIL_N.TEXT,
                :RESLOCDETAIL_N.TEXT_SIZE,
                :RESLOCDETAIL_N.TEXT_COLOR,
                :RESLOCDETAIL_N.TEXT_STYLE,
                :RESLOCDETAIL_N.TAG_TYPE,
                :RESLOCDETAIL_N.BACK_COLOR,
                :RESLOCDETAIL_N.NO_MOUSE_EVENT,
                :RESLOCDETAIL_N.SIGNAL_FLAG,
                :RESLOCDETAIL_N.ANGLE,
                :RESLOCDETAIL_N.RES_SHAPE;
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    if(DB_error_code == 0)
    {
        DBC_del_null_reslocdetail(&RESLOCDETAIL_N, RESLOCDETAIL);
    }
    DB_stop_query_timer("DBC_fetch_reslocdetail", sel_type);
}

/* SQL CURSOR CLOSE Function */
void DBC_close_reslocdetail(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_RESLOCDETAIL_CUR_1;
            break;
            
       
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_reslocdetail", sel_type);
}

/* Initialize Function */
void DBC_init_reslocdetail(struct RESLOCDETAIL_TAG *RESLOCDETAIL)
{
    /* memset by Space */
    memset(RESLOCDETAIL, ' ', sizeof(struct RESLOCDETAIL_TAG));
    
    RESLOCDETAIL->MAX_PROC_COUNT = 0;
    RESLOCDETAIL->PROC_COUNT = 0;
    RESLOCDETAIL->LAST_DOWN_HIST_SEQ = 0;
    RESLOCDETAIL->LAST_ACTIVE_HIST_SEQ = 0;
    RESLOCDETAIL->LAST_HIST_SEQ = 0;
    RESLOCDETAIL->LOC_X = 0;
    RESLOCDETAIL->LOC_Y = 0;
    RESLOCDETAIL->LOC_WIDTH = 0;
    RESLOCDETAIL->LOC_HEIGHT = 0;
    RESLOCDETAIL->TEXT_SIZE = 0;
    RESLOCDETAIL->TEXT_COLOR = 0;
    RESLOCDETAIL->TAG_TYPE = 0;
    RESLOCDETAIL->BACK_COLOR = 0;
    RESLOCDETAIL->SEQ = 0;
    RESLOCDETAIL->ANGLE = 0;
}

/* Add Null Function */
void DBC_add_null_reslocdetail(struct RESLOCDETAIL_N_TAG *RESLOCDETAIL_N, struct RESLOCDETAIL_TAG *RESLOCDETAIL)
{ 
    /* memset by NULL */
    memset(RESLOCDETAIL_N, '\0', sizeof(struct RESLOCDETAIL_N_TAG));
    
    MEMCPY_AN(RESLOCDETAIL_N->FACTORY, RESLOCDETAIL->FACTORY, sizeof(RESLOCDETAIL->FACTORY));
    MEMCPY_AN(RESLOCDETAIL_N->RES_ID, RESLOCDETAIL->RES_ID, sizeof(RESLOCDETAIL->RES_ID));
    MEMCPY_AN(RESLOCDETAIL_N->RES_DESC, RESLOCDETAIL->RES_DESC, sizeof(RESLOCDETAIL->RES_DESC));
