                :POTDETAIL_N.SIGNAL_FLAG,
                :POTDETAIL_N.ANGLE,
                :POTDETAIL_N.RES_SHAPE;
            break;
            
            case 2:
            EXEC SQL FETCH DBC_POTDETAIL_CUR_2 INTO 
                :POTDETAIL_N.FACTORY,
                :POTDETAIL_N.RES_ID,
                :POTDETAIL_N.RES_TYPE,
                :POTDETAIL_N.SUBRES_ID,
                :POTDETAIL_N.PORT_ID,
