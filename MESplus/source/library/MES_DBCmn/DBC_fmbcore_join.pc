    MEMCPY_DN(RESDETAIL->RES_STS_1, RESDETAIL_N->RES_STS_1, sizeof(RESDETAIL->RES_STS_1));
    MEMCPY_DN(RESDETAIL->RES_STS_2, RESDETAIL_N->RES_STS_2, sizeof(RESDETAIL->RES_STS_2));
