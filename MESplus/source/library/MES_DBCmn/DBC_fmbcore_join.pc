/* Del Null Function */
void DBC_del_null_srsdetail(struct SRSDETAIL_N_TAG *SRSDETAIL_N, struct SRSDETAIL_TAG *SRSDETAIL)
{
    MEMCPY_DN(SRSDETAIL->FACTORY, SRSDETAIL_N->FACTORY, sizeof(SRSDETAIL->FACTORY));
    MEMCPY_DN(SRSDETAIL->RES_ID, SRSDETAIL_N->RES_ID, sizeof(SRSDETAIL->RES_ID));
    SRSDETAIL->RES_TYPE, SRSDETAIL_N->RES_TYPE[0];
    MEMCPY_DN(SRSDETAIL->SUBRES_ID, SRSDETAIL_N->SUBRES_ID, sizeof(SRSDETAIL->SUBRES_ID));
    MEMCPY_DN(SRSDETAIL->SUBRES_DESC, SRSDETAIL_N->SUBRES_DESC, sizeof(SRSDETAIL->SUBRES_DESC));
