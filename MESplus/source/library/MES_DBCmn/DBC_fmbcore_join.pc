/* Del Null Function */
void DBC_del_null_potdetail(struct POTDETAIL_N_TAG *POTDETAIL_N, struct POTDETAIL_TAG *POTDETAIL)
{
    MEMCPY_DN(POTDETAIL->FACTORY, POTDETAIL_N->FACTORY, sizeof(POTDETAIL->FACTORY));
    MEMCPY_DN(POTDETAIL->RES_ID, POTDETAIL_N->RES_ID, sizeof(POTDETAIL->RES_ID));
    POTDETAIL->PORT_TYPE = POTDETAIL_N->PORT_TYPE[0];
    MEMCPY_DN(POTDETAIL->SUBRES_ID, POTDETAIL_N->SUBRES_ID, sizeof(POTDETAIL->SUBRES_ID));
    MEMCPY_DN(POTDETAIL->MOTHER_RES_ID, POTDETAIL_N->MOTHER_RES_ID, sizeof(POTDETAIL->MOTHER_RES_ID));
    MEMCPY_DN(POTDETAIL->PORT_ID, POTDETAIL_N->PORT_ID, sizeof(POTDETAIL->PORT_ID));
    POTDETAIL->PORT_SEQ = POTDETAIL_N->PORT_SEQ;
    MEMCPY_DN(POTDETAIL->LAYOUT_ID, POTDETAIL_N->LAYOUT_ID, sizeof(POTDETAIL->LAYOUT_ID));
    POTDETAIL->SEQ = POTDETAIL_N->SEQ;
    POTDETAIL->LOC_X = POTDETAIL_N->LOC_X;
    POTDETAIL->LOC_Y = POTDETAIL_N->LOC_Y;
    POTDETAIL->LOC_WIDTH = POTDETAIL_N->LOC_WIDTH;
    POTDETAIL->LOC_HEIGHT = POTDETAIL_N->LOC_HEIGHT;
    MEMCPY_DN(POTDETAIL->TEXT, POTDETAIL_N->TEXT, sizeof(POTDETAIL->TEXT));
    POTDETAIL->TEXT_SIZE = POTDETAIL_N->TEXT_SIZE;
