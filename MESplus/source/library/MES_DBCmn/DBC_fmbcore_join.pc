/* Add Null Function */
void DBC_add_null_udrloc_list(struct UDRLOC_LIST_N_TAG *UDRLOC_LIST_N, struct UDRLOC_LIST_TAG *UDRLOC_LIST)
{ 
    /* memset by NULL */
    memset(UDRLOC_LIST_N, '\0', sizeof(struct UDRLOC_LIST_N_TAG));

    MEMCPY_AN(UDRLOC_LIST_N->FACTORY ,UDRLOC_LIST->FACTORY ,sizeof(UDRLOC_LIST->FACTORY ));
    MEMCPY_AN(UDRLOC_LIST_N->GROUP_ID ,UDRLOC_LIST->GROUP_ID ,sizeof(UDRLOC_LIST->GROUP_ID ));
    MEMCPY_AN(UDRLOC_LIST_N->RES_ID ,UDRLOC_LIST->RES_ID ,sizeof(UDRLOC_LIST->RES_ID ));
    MEMCPY_AN(UDRLOC_LIST_N->MOTHER_RES_ID ,UDRLOC_LIST->MOTHER_RES_ID ,sizeof(UDRLOC_LIST->MOTHER_RES_ID ));
    MEMCPY_AN(UDRLOC_LIST_N->RES_DESC ,UDRLOC_LIST->RES_DESC,sizeof(UDRLOC_LIST->RES_DESC));
    UDRLOC_LIST_N->ATTACHED_FLAG[0]= UDRLOC_LIST->ATTACHED_FLAG;
    UDRLOC_LIST_N->UP_DOWN_FLAG[0]= UDRLOC_LIST->UP_DOWN_FLAG;
}


/* Del Null Function */
void DBC_del_null_udrloc_list(struct UDRLOC_LIST_N_TAG *UDRLOC_LIST_N, struct UDRLOC_LIST_TAG *UDRLOC_LIST)
{
    MEMCPY_DN(UDRLOC_LIST->FACTORY ,UDRLOC_LIST_N->FACTORY ,sizeof(UDRLOC_LIST->FACTORY ));
    MEMCPY_DN(UDRLOC_LIST->GROUP_ID ,UDRLOC_LIST_N->GROUP_ID ,sizeof(UDRLOC_LIST->GROUP_ID ));
    MEMCPY_DN(UDRLOC_LIST->RES_ID ,UDRLOC_LIST_N->RES_ID ,sizeof(UDRLOC_LIST->RES_ID ));
    MEMCPY_DN(UDRLOC_LIST->MOTHER_RES_ID ,UDRLOC_LIST_N->MOTHER_RES_ID ,sizeof(UDRLOC_LIST->MOTHER_RES_ID ));
    MEMCPY_DN(UDRLOC_LIST->RES_DESC ,UDRLOC_LIST_N->RES_DESC,sizeof(UDRLOC_LIST->RES_DESC));
    UDRLOC_LIST->ATTACHED_FLAG = UDRLOC_LIST_N->ATTACHED_FLAG[0];
    UDRLOC_LIST->UP_DOWN_FLAG = UDRLOC_LIST_N->UP_DOWN_FLAG[0];
}               

/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_resdetail(int sel_type, struct RESDETAIL_TAG *RESDETAIL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RESDETAIL_N_TAG RESDETAIL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_resdetail(&RESDETAIL_N, RESDETAIL);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_RESDETAIL_CUR_1 CURSOR FOR 
                SELECT A.FACTORY, A.RES_ID, A.RES_TYPE, A.LAYOUT_ID, A.SEQ, A.LOC_X, A.LOC_Y, A.LOC_WIDTH, A.LOC_HEIGHT, A.TEXT,
                    A.TEXT_SIZE, A.TEXT_COLOR, A.TEXT_STYLE, A.TAG_TYPE, A.BACK_COLOR, A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID,
                    A.UPDATE_TIME, A.NO_MOUSE_EVENT, A.SIGNAL_FLAG, A.MOTHER_RES_ID, A.ANGLE, A.RES_SHAPE, 
                    B.RES_DESC, B.RES_TYPE, B.AREA_ID,B.SUB_AREA_ID, B.RES_LOCATION, B.PROC_RULE, B.MAX_PROC_COUNT, 
                    B.RES_UP_DOWN_FLAG, B.RES_PRI_STS, B.RES_STS_1, B.RES_STS_2, B.RES_STS_3, B.RES_STS_4, B.RES_STS_5, 
                    B.RES_STS_6, B.RES_STS_7, B.RES_STS_8, B.RES_STS_9, B.RES_STS_10, B.RES_CTRL_MODE, B.RES_PROC_MODE, B.LAST_RECIPE_ID, 
                    B.PROC_COUNT, B.LAST_START_TIME, B.LAST_END_TIME, B.LAST_DOWN_TIME, B.LAST_DOWN_HIST_SEQ, B.LAST_EVENT_ID,
                    B.LAST_EVENT_TIME, B.LAST_ACTIVE_HIST_SEQ, B.LAST_HIST_SEQ 
                FROM MFMBRESLOC A, MRASRESDEF B 
                WHERE A.FACTORY = :RESDETAIL_N.FACTORY 
                    AND A.LAYOUT_ID = :RESDETAIL_N.LAYOUT_ID
                    AND A.FACTORY = B.FACTORY 
                    AND A.RES_ID = B.RES_ID
                    AND A.RES_TYPE = 'R'
                    AND B.DELETE_FLAG <> 'Y'
                    AND A.SEQ >= :RESDETAIL_N.SEQ 
                ORDER BY A.SEQ;
            EXEC SQL OPEN DBC_RESDETAIL_CUR_1;
            break;
        case 2:
            EXEC SQL DECLARE DBC_RESDETAIL_CUR_2 CURSOR FOR 
                SELECT * 
                FROM (
                    SELECT A.FACTORY, A.RES_ID, A.RES_TYPE, A.LAYOUT_ID, A.SEQ, A.LOC_X, A.LOC_Y, A.LOC_WIDTH, A.LOC_HEIGHT, A.TEXT,
                        A.TEXT_SIZE, A.TEXT_COLOR, A.TEXT_STYLE, A.TAG_TYPE, A.BACK_COLOR, A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID,
                        A.UPDATE_TIME, A.NO_MOUSE_EVENT, A.SIGNAL_FLAG, A.MOTHER_RES_ID, A.ANGLE, A.RES_SHAPE, 
                        B.RES_DESC, B.RES_TYPE RTYPE, B.AREA_ID,B.SUB_AREA_ID, B.RES_LOCATION, B.PROC_RULE, B.MAX_PROC_COUNT, 
                        B.RES_UP_DOWN_FLAG, B.RES_PRI_STS, B.RES_STS_1, B.RES_STS_2, B.RES_STS_3, B.RES_STS_4, B.RES_STS_5, 
                        B.RES_STS_6, B.RES_STS_7, B.RES_STS_8, B.RES_STS_9, B.RES_STS_10, B.RES_CTRL_MODE, B.RES_PROC_MODE, B.LAST_RECIPE_ID, 
                        B.PROC_COUNT, B.LAST_START_TIME, B.LAST_END_TIME, B.LAST_DOWN_TIME, B.LAST_DOWN_HIST_SEQ, B.LAST_EVENT_ID,
                        B.LAST_EVENT_TIME, B.LAST_ACTIVE_HIST_SEQ, B.LAST_HIST_SEQ, B.LOT_ID
                    FROM MFMBRESLOC A, MRASRESDEF B 
                    WHERE A.FACTORY = :RESDETAIL_N.FACTORY 
                        AND LAYOUT_ID =  :RESDETAIL_N.LAYOUT_ID
                        AND A.FACTORY = B.FACTORY 
                        AND A.RES_ID = B.RES_ID
                        AND A.RES_TYPE = 'R'
                        AND B.DELETE_FLAG <> 'Y'
                    UNION
                    SELECT A.FACTORY, A.RES_ID, A.RES_TYPE, A.LAYOUT_ID, A.SEQ, A.LOC_X, A.LOC_Y, A.LOC_WIDTH, A.LOC_HEIGHT, A.TEXT,
                        A.TEXT_SIZE, A.TEXT_COLOR, A.TEXT_STYLE, A.TAG_TYPE, A.BACK_COLOR, A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID,
                        A.UPDATE_TIME, A.NO_MOUSE_EVENT, A.SIGNAL_FLAG, A.MOTHER_RES_ID, A.ANGLE, A.RES_SHAPE, 
                        ' ',' ',' ' RTYPE,' ',' ',' ',0,' ',' ',' ',' ',' ',' ',' ',' ',' ',' ',' ',' ',' ',' ',
                         ' ',0,' ',' ',' ',0,' ',' ',0,0,' '
                        FROM MFMBRESLOC A
                        WHERE A.FACTORY = :RESDETAIL_N.FACTORY
                        AND A.LAYOUT_ID = :RESDETAIL_N.LAYOUT_ID
                        AND A.RES_TYPE = 'T'
                    )
                WHERE SEQ <= :RESDETAIL_N.SEQ 
                ORDER BY SEQ DESC;
            EXEC SQL OPEN DBC_RESDETAIL_CUR_2;
            break;
 

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_resdetail", sel_type);
}           

/* SQL CURSOR FETCH Function */
void DBC_fetch_resdetail(int sel_type, struct RESDETAIL_TAG *RESDETAIL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RESDETAIL_N_TAG RESDETAIL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_RESDETAIL_CUR_1 INTO 
                :RESDETAIL_N.FACTORY,
                :RESDETAIL_N.RES_ID,
                :RESDETAIL_N.RES_TAG_FLAG,
                :RESDETAIL_N.LAYOUT_ID,
                :RESDETAIL_N.SEQ,
                :RESDETAIL_N.LOC_X,
                :RESDETAIL_N.LOC_Y,
                :RESDETAIL_N.LOC_WIDTH,
                :RESDETAIL_N.LOC_HEIGHT,
                :RESDETAIL_N.TEXT,
                :RESDETAIL_N.TEXT_SIZE,
                :RESDETAIL_N.TEXT_COLOR,
                :RESDETAIL_N.TEXT_STYLE,
                :RESDETAIL_N.TAG_TYPE,
                :RESDETAIL_N.BACK_COLOR,
                :RESDETAIL_N.CREATE_USER_ID,
                :RESDETAIL_N.CREATE_TIME,
                :RESDETAIL_N.UPDATE_USER_ID,
                :RESDETAIL_N.UPDATE_TIME,
                :RESDETAIL_N.NO_MOUSE_EVENT,
                :RESDETAIL_N.SIGNAL_FLAG,
                :RESDETAIL_N.MOTHER_RES_ID,
                :RESDETAIL_N.ANGLE,
                :RESDETAIL_N.RES_SHAPE,
                :RESDETAIL_N.RES_DESC,
                :RESDETAIL_N.RES_TYPE,
                :RESDETAIL_N.AREA_ID,
                :RESDETAIL_N.SUB_AREA_ID,
                :RESDETAIL_N.RES_LOCATION,
                :RESDETAIL_N.PROC_RULE,
                :RESDETAIL_N.MAX_PROC_COUNT,
                :RESDETAIL_N.RES_UP_DOWN_FLAG,
                :RESDETAIL_N.RES_PRI_STS,
                :RESDETAIL_N.RES_STS_1,
                :RESDETAIL_N.RES_STS_2,
                :RESDETAIL_N.RES_STS_3,
                :RESDETAIL_N.RES_STS_4,
                :RESDETAIL_N.RES_STS_5,
                :RESDETAIL_N.RES_STS_6,
                :RESDETAIL_N.RES_STS_7,
                :RESDETAIL_N.RES_STS_8,
                :RESDETAIL_N.RES_STS_9,
                :RESDETAIL_N.RES_STS_10,
                :RESDETAIL_N.RES_CTRL_MODE,
                :RESDETAIL_N.RES_PROC_MODE,
                :RESDETAIL_N.LAST_RECIPE_ID,
                :RESDETAIL_N.PROC_COUNT,
                :RESDETAIL_N.LAST_START_TIME,
                :RESDETAIL_N.LAST_END_TIME,
                :RESDETAIL_N.LAST_DOWN_TIME,
                :RESDETAIL_N.LAST_DOWN_HIST_SEQ,
                :RESDETAIL_N.LAST_EVENT_ID,
                :RESDETAIL_N.LAST_EVENT_TIME,
                :RESDETAIL_N.LAST_ACTIVE_HIST_SEQ,
                :RESDETAIL_N.LAST_HIST_SEQ;
            break;
        case 2:
            EXEC SQL FETCH DBC_RESDETAIL_CUR_2 INTO 
                :RESDETAIL_N.FACTORY,
                :RESDETAIL_N.RES_ID,
                :RESDETAIL_N.RES_TAG_FLAG,
                :RESDETAIL_N.LAYOUT_ID,
                :RESDETAIL_N.SEQ,
                :RESDETAIL_N.LOC_X,
                :RESDETAIL_N.LOC_Y,
                :RESDETAIL_N.LOC_WIDTH,
                :RESDETAIL_N.LOC_HEIGHT,
                :RESDETAIL_N.TEXT,
                :RESDETAIL_N.TEXT_SIZE,
                :RESDETAIL_N.TEXT_COLOR,
                :RESDETAIL_N.TEXT_STYLE,
                :RESDETAIL_N.TAG_TYPE,
                :RESDETAIL_N.BACK_COLOR,
                :RESDETAIL_N.CREATE_USER_ID,
                :RESDETAIL_N.CREATE_TIME,
                :RESDETAIL_N.UPDATE_USER_ID,
                :RESDETAIL_N.UPDATE_TIME,
                :RESDETAIL_N.NO_MOUSE_EVENT,
                :RESDETAIL_N.SIGNAL_FLAG,
                :RESDETAIL_N.MOTHER_RES_ID,
                :RESDETAIL_N.ANGLE,
                :RESDETAIL_N.RES_SHAPE,
                :RESDETAIL_N.RES_DESC,
                :RESDETAIL_N.RES_TYPE,
                :RESDETAIL_N.AREA_ID,
                :RESDETAIL_N.SUB_AREA_ID,
                :RESDETAIL_N.RES_LOCATION,
                :RESDETAIL_N.PROC_RULE,
                :RESDETAIL_N.MAX_PROC_COUNT,
                :RESDETAIL_N.RES_UP_DOWN_FLAG,
                :RESDETAIL_N.RES_PRI_STS,
                :RESDETAIL_N.RES_STS_1,
                :RESDETAIL_N.RES_STS_2,
                :RESDETAIL_N.RES_STS_3,
                :RESDETAIL_N.RES_STS_4,
                :RESDETAIL_N.RES_STS_5,
                :RESDETAIL_N.RES_STS_6,
                :RESDETAIL_N.RES_STS_7,
                :RESDETAIL_N.RES_STS_8,
                :RESDETAIL_N.RES_STS_9,
                :RESDETAIL_N.RES_STS_10,
                :RESDETAIL_N.RES_CTRL_MODE,
                :RESDETAIL_N.RES_PROC_MODE,
                :RESDETAIL_N.LAST_RECIPE_ID,
                :RESDETAIL_N.PROC_COUNT,
                :RESDETAIL_N.LAST_START_TIME,
                :RESDETAIL_N.LAST_END_TIME,
                :RESDETAIL_N.LAST_DOWN_TIME,
                :RESDETAIL_N.LAST_DOWN_HIST_SEQ,
                :RESDETAIL_N.LAST_EVENT_ID,
                :RESDETAIL_N.LAST_EVENT_TIME,
                :RESDETAIL_N.LAST_ACTIVE_HIST_SEQ,
                :RESDETAIL_N.LAST_HIST_SEQ,
                :RESDETAIL_N.LOT_ID;
            break;            


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    if(DB_error_code == 0)
    {
        DBC_del_null_resdetail(&RESDETAIL_N, RESDETAIL);
    }
    DB_stop_query_timer("DBC_fetch_resdetail", sel_type);
}

/* SQL CURSOR CLOSE Function */
void DBC_close_resdetail(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_RESDETAIL_CUR_1;
            break;
        case 2:
            EXEC SQL CLOSE DBC_RESDETAIL_CUR_2;
            break;    
       

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_resdetail", sel_type);
}

/* Initialize Function */
void DBC_init_resdetail(struct RESDETAIL_TAG *RESDETAIL)
{
    /* memset by Space */
    memset(RESDETAIL, ' ', sizeof(struct RESDETAIL_TAG));
    RESDETAIL->LOC_X = 0;
    RESDETAIL->LOC_Y = 0;
    RESDETAIL->LOC_WIDTH = 0;
    RESDETAIL->LOC_HEIGHT = 0;
    RESDETAIL->TEXT_SIZE = 0;
    RESDETAIL->TEXT_COLOR = 0;
    RESDETAIL->TAG_TYPE = 0;
    RESDETAIL->BACK_COLOR = 0;  
    RESDETAIL->SEQ = 0;  
    RESDETAIL->MAX_PROC_COUNT = 0;
    RESDETAIL->PROC_COUNT = 0;
    RESDETAIL->LAST_DOWN_HIST_SEQ = 0;
    RESDETAIL->LAST_ACTIVE_HIST_SEQ = 0;
    RESDETAIL->LAST_HIST_SEQ = 0;
    RESDETAIL->ANGLE = 0;
}

/* Add Null Function */
void DBC_add_null_resdetail(struct RESDETAIL_N_TAG *RESDETAIL_N, struct RESDETAIL_TAG *RESDETAIL)
{ 
    /* memset by NULL */
    memset(RESDETAIL_N, '\0', sizeof(struct RESDETAIL_N_TAG));

    MEMCPY_AN(RESDETAIL_N->FACTORY, RESDETAIL->FACTORY, sizeof(RESDETAIL->FACTORY));
    MEMCPY_AN(RESDETAIL_N->RES_ID, RESDETAIL->RES_ID, sizeof(RESDETAIL->RES_ID));
    RESDETAIL_N->RES_TAG_FLAG[0] = RESDETAIL->RES_TAG_FLAG;
    MEMCPY_AN(RESDETAIL_N->LAYOUT_ID, RESDETAIL->LAYOUT_ID, sizeof(RESDETAIL->LAYOUT_ID));
    RESDETAIL_N->SEQ = RESDETAIL->SEQ;
    RESDETAIL_N->LOC_X = RESDETAIL->LOC_X;
    RESDETAIL_N->LOC_Y = RESDETAIL->LOC_Y;
    RESDETAIL_N->LOC_WIDTH = RESDETAIL->LOC_WIDTH;
    RESDETAIL_N->LOC_HEIGHT = RESDETAIL->LOC_HEIGHT;
    MEMCPY_AN(RESDETAIL_N->TEXT, RESDETAIL->TEXT, sizeof(RESDETAIL->TEXT));
    RESDETAIL_N->TEXT_SIZE = RESDETAIL->TEXT_SIZE;
    RESDETAIL_N->TEXT_COLOR = RESDETAIL->TEXT_COLOR;
    RESDETAIL_N->TEXT_STYLE[0] = RESDETAIL->TEXT_STYLE;
    RESDETAIL_N->TAG_TYPE = RESDETAIL->TAG_TYPE;
    RESDETAIL_N->BACK_COLOR = RESDETAIL->BACK_COLOR;
    MEMCPY_AN(RESDETAIL_N->CREATE_USER_ID, RESDETAIL->CREATE_USER_ID, sizeof(RESDETAIL->CREATE_USER_ID));
    MEMCPY_AN(RESDETAIL_N->CREATE_TIME, RESDETAIL->CREATE_TIME, sizeof(RESDETAIL->CREATE_TIME));
    MEMCPY_AN(RESDETAIL_N->UPDATE_USER_ID, RESDETAIL->UPDATE_USER_ID, sizeof(RESDETAIL->UPDATE_USER_ID));
    MEMCPY_AN(RESDETAIL_N->UPDATE_TIME, RESDETAIL->UPDATE_TIME, sizeof(RESDETAIL->UPDATE_TIME));
    RESDETAIL_N->NO_MOUSE_EVENT[0] = RESDETAIL->NO_MOUSE_EVENT;
    RESDETAIL_N->SIGNAL_FLAG[0] = RESDETAIL->SIGNAL_FLAG;
    MEMCPY_AN(RESDETAIL_N->MOTHER_RES_ID, RESDETAIL->MOTHER_RES_ID, sizeof(RESDETAIL->MOTHER_RES_ID));
    MEMCPY_AN(RESDETAIL_N->RES_DESC, RESDETAIL->RES_DESC, sizeof(RESDETAIL->RES_DESC));
    MEMCPY_AN(RESDETAIL_N->RES_TYPE, RESDETAIL->RES_TYPE, sizeof(RESDETAIL->RES_TYPE));
    MEMCPY_AN(RESDETAIL_N->AREA_ID, RESDETAIL->AREA_ID, sizeof(RESDETAIL->AREA_ID));
    MEMCPY_AN(RESDETAIL_N->SUB_AREA_ID, RESDETAIL->SUB_AREA_ID, sizeof(RESDETAIL->SUB_AREA_ID));
    MEMCPY_AN(RESDETAIL_N->RES_LOCATION, RESDETAIL->RES_LOCATION, sizeof(RESDETAIL->RES_LOCATION));
    RESDETAIL_N->PROC_RULE[0] = RESDETAIL->PROC_RULE;
    RESDETAIL_N->MAX_PROC_COUNT = RESDETAIL->MAX_PROC_COUNT;
    RESDETAIL_N->RES_UP_DOWN_FLAG[0] = RESDETAIL->RES_UP_DOWN_FLAG;
    MEMCPY_AN(RESDETAIL_N->RES_PRI_STS, RESDETAIL->RES_PRI_STS, sizeof(RESDETAIL->RES_PRI_STS));
    MEMCPY_AN(RESDETAIL_N->RES_STS_1, RESDETAIL->RES_STS_1, sizeof(RESDETAIL->RES_STS_1));
    MEMCPY_AN(RESDETAIL_N->RES_STS_2, RESDETAIL->RES_STS_2, sizeof(RESDETAIL->RES_STS_2));
    MEMCPY_AN(RESDETAIL_N->RES_STS_3, RESDETAIL->RES_STS_3, sizeof(RESDETAIL->RES_STS_3));
    MEMCPY_AN(RESDETAIL_N->RES_STS_4, RESDETAIL->RES_STS_4, sizeof(RESDETAIL->RES_STS_4));
    MEMCPY_AN(RESDETAIL_N->RES_STS_5, RESDETAIL->RES_STS_5, sizeof(RESDETAIL->RES_STS_5));
    MEMCPY_AN(RESDETAIL_N->RES_STS_6, RESDETAIL->RES_STS_6, sizeof(RESDETAIL->RES_STS_6));
    MEMCPY_AN(RESDETAIL_N->RES_STS_7, RESDETAIL->RES_STS_7, sizeof(RESDETAIL->RES_STS_7));
    MEMCPY_AN(RESDETAIL_N->RES_STS_8, RESDETAIL->RES_STS_8, sizeof(RESDETAIL->RES_STS_8));
    MEMCPY_AN(RESDETAIL_N->RES_STS_9, RESDETAIL->RES_STS_9, sizeof(RESDETAIL->RES_STS_9));
    MEMCPY_AN(RESDETAIL_N->RES_STS_10, RESDETAIL->RES_STS_10, sizeof(RESDETAIL->RES_STS_10));
    MEMCPY_AN(RESDETAIL_N->LOT_ID, RESDETAIL->LOT_ID, sizeof(RESDETAIL->LOT_ID));
    MEMCPY_AN(RESDETAIL_N->SUBLOT_ID, RESDETAIL->SUBLOT_ID, sizeof(RESDETAIL->SUBLOT_ID));
    MEMCPY_AN(RESDETAIL_N->CRR_ID, RESDETAIL->CRR_ID, sizeof(RESDETAIL->CRR_ID));
    MEMCPY_AN(RESDETAIL_N->RES_CTRL_MODE, RESDETAIL->RES_CTRL_MODE, sizeof(RESDETAIL->RES_CTRL_MODE));
    MEMCPY_AN(RESDETAIL_N->RES_PROC_MODE, RESDETAIL->RES_PROC_MODE, sizeof(RESDETAIL->RES_PROC_MODE));
    MEMCPY_AN(RESDETAIL_N->LAST_RECIPE_ID, RESDETAIL->LAST_RECIPE_ID, sizeof(RESDETAIL->LAST_RECIPE_ID));
    RESDETAIL_N->PROC_COUNT = RESDETAIL->PROC_COUNT;
    MEMCPY_AN(RESDETAIL_N->LAST_START_TIME, RESDETAIL->LAST_START_TIME, sizeof(RESDETAIL->LAST_START_TIME));
    MEMCPY_AN(RESDETAIL_N->LAST_END_TIME, RESDETAIL->LAST_END_TIME, sizeof(RESDETAIL->LAST_END_TIME));
    MEMCPY_AN(RESDETAIL_N->LAST_DOWN_TIME, RESDETAIL->LAST_DOWN_TIME, sizeof(RESDETAIL->LAST_DOWN_TIME));
    RESDETAIL_N->LAST_DOWN_HIST_SEQ = RESDETAIL->LAST_DOWN_HIST_SEQ;
    MEMCPY_AN(RESDETAIL_N->LAST_EVENT_ID, RESDETAIL->LAST_EVENT_ID, sizeof(RESDETAIL->LAST_EVENT_ID));
    MEMCPY_AN(RESDETAIL_N->LAST_EVENT_TIME, RESDETAIL->LAST_EVENT_TIME, sizeof(RESDETAIL->LAST_EVENT_TIME));
    RESDETAIL_N->LAST_ACTIVE_HIST_SEQ = RESDETAIL->LAST_ACTIVE_HIST_SEQ;
    RESDETAIL_N->LAST_HIST_SEQ = RESDETAIL->LAST_HIST_SEQ;    
    RESDETAIL_N->ANGLE = RESDETAIL->ANGLE;
    RESDETAIL_N->RES_SHAPE[0] = RESDETAIL->RES_SHAPE;
}


/* Del Null Function */
void DBC_del_null_resdetail(struct RESDETAIL_N_TAG *RESDETAIL_N, struct RESDETAIL_TAG *RESDETAIL)
{
    MEMCPY_DN(RESDETAIL->FACTORY, RESDETAIL_N->FACTORY, sizeof(RESDETAIL->FACTORY));
    MEMCPY_DN(RESDETAIL->RES_ID, RESDETAIL_N->RES_ID, sizeof(RESDETAIL->RES_ID));
    RESDETAIL->RES_TAG_FLAG = RESDETAIL_N->RES_TAG_FLAG[0];
    MEMCPY_DN(RESDETAIL->LAYOUT_ID, RESDETAIL_N->LAYOUT_ID, sizeof(RESDETAIL->LAYOUT_ID));
    RESDETAIL->SEQ = RESDETAIL_N->SEQ;
    RESDETAIL->LOC_X = RESDETAIL_N->LOC_X;
    RESDETAIL->LOC_Y = RESDETAIL_N->LOC_Y;
    RESDETAIL->LOC_WIDTH = RESDETAIL_N->LOC_WIDTH;
    RESDETAIL->LOC_HEIGHT = RESDETAIL_N->LOC_HEIGHT;
    MEMCPY_DN(RESDETAIL->TEXT, RESDETAIL_N->TEXT, sizeof(RESDETAIL->TEXT));
    RESDETAIL->TEXT_SIZE = RESDETAIL_N->TEXT_SIZE;
    RESDETAIL->TEXT_COLOR = RESDETAIL_N->TEXT_COLOR;
    RESDETAIL->TEXT_STYLE = RESDETAIL_N->TEXT_STYLE[0];
    RESDETAIL->TAG_TYPE = RESDETAIL_N->TAG_TYPE;
