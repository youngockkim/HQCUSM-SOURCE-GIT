    MEMCPY_DN(RESINFO->LAST_EVENT_TIME, RESINFO_N->LAST_EVENT_TIME, sizeof(RESINFO->LAST_EVENT_TIME));
    RESINFO->LAST_ACTIVE_HIST_SEQ = RESINFO_N->LAST_ACTIVE_HIST_SEQ;
    RESINFO->LAST_HIST_SEQ = RESINFO_N->LAST_HIST_SEQ;    
}              

/* SQL SELECT Function */
void DBC_select_udrinfo(int sel_type, struct UDRINFO_TAG *UDRINFO)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct UDRINFO_N_TAG UDRINFO_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_udrinfo(&UDRINFO_N, UDRINFO);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT A.FACTORY, A.GROUP_ID, A.RES_ID, A.RES_TYPE, A.SEQ, A.LOC_X, A.LOC_Y, A.LOC_WIDTH, A.LOC_HEIGHT, A.TEXT, A.TEXT_SIZE, A.TEXT_COLOR, A.TEXT_STYLE,
                    A.TAG_TYPE, A.BACK_COLOR, A.CREATE_TIME, A.UPDATE_TIME, A.NO_MOUSE_EVENT, A.SIGNAL_FLAG, A.MOTHER_RES_ID, A.ANGLE, A.RES_SHAPE, 
                    B.RES_DESC, B.RES_TYPE, B.AREA_ID,B.SUB_AREA_ID, B.RES_LOCATION, B.PROC_RULE, B.MAX_PROC_COUNT, 
                    B.RES_UP_DOWN_FLAG, B.RES_PRI_STS, B.RES_STS_1, B.RES_STS_2, B.RES_STS_3, B.RES_STS_4, B.RES_STS_5, 
                    B.RES_STS_6, B.RES_STS_7, B.RES_STS_8, B.RES_STS_9, B.RES_STS_10, B.LOT_ID, B.SUBLOT_ID, B.CRR_ID, B.RES_CTRL_MODE, B.RES_PROC_MODE, B.LAST_RECIPE_ID, 
                    B.PROC_COUNT, B.LAST_START_TIME, B.LAST_END_TIME, B.LAST_DOWN_TIME, B.LAST_DOWN_HIST_SEQ, B.LAST_EVENT_ID,
                    B.LAST_EVENT_TIME, B.LAST_ACTIVE_HIST_SEQ, B.LAST_HIST_SEQ 
                INTO 
                    :UDRINFO_N.FACTORY,
                    :UDRINFO_N.GROUP_ID,
                    :UDRINFO_N.RES_ID,
                    :UDRINFO_N.RES_TYPE,
                    :UDRINFO_N.SEQ,
                    :UDRINFO_N.LOC_X,
                    :UDRINFO_N.LOC_Y,
                    :UDRINFO_N.LOC_WIDTH,
                    :UDRINFO_N.LOC_HEIGHT,
                    :UDRINFO_N.TEXT,
                    :UDRINFO_N.TEXT_SIZE,
                    :UDRINFO_N.TEXT_COLOR,
                    :UDRINFO_N.TEXT_STYLE,
                    :UDRINFO_N.TAG_TYPE,
                    :UDRINFO_N.BACK_COLOR,
                    :UDRINFO_N.CREATE_TIME,
                    :UDRINFO_N.UPDATE_TIME,
                    :UDRINFO_N.NO_MOUSE_EVENT,
                    :UDRINFO_N.SIGNAL_FLAG,
                    :UDRINFO_N.MOTHER_RES_ID,
                    :UDRINFO_N.ANGLE,
                    :UDRINFO_N.RES_SHAPE,
                    :UDRINFO_N.RES_DESC,
                    :UDRINFO_N.RES_TYPE,
                    :UDRINFO_N.AREA_ID,
                    :UDRINFO_N.SUB_AREA_ID,
                    :UDRINFO_N.RES_LOCATION,
                    :UDRINFO_N.PROC_RULE,
                    :UDRINFO_N.MAX_PROC_COUNT,
                    :UDRINFO_N.RES_UP_DOWN_FLAG,
                    :UDRINFO_N.RES_PRI_STS,
                    :UDRINFO_N.RES_STS_1,
                    :UDRINFO_N.RES_STS_2,
                    :UDRINFO_N.RES_STS_3,
                    :UDRINFO_N.RES_STS_4,
                    :UDRINFO_N.RES_STS_5,
                    :UDRINFO_N.RES_STS_6,
                    :UDRINFO_N.RES_STS_7,
                    :UDRINFO_N.RES_STS_8,
                    :UDRINFO_N.RES_STS_9,
                    :UDRINFO_N.RES_STS_10,
                    :UDRINFO_N.LOT_ID,
                    :UDRINFO_N.SUBLOT_ID,
                    :UDRINFO_N.CRR_ID,
                    :UDRINFO_N.RES_CTRL_MODE,
                    :UDRINFO_N.RES_PROC_MODE,
                    :UDRINFO_N.LAST_RECIPE_ID,
                    :UDRINFO_N.PROC_COUNT,
                    :UDRINFO_N.LAST_START_TIME,
                    :UDRINFO_N.LAST_END_TIME,
                    :UDRINFO_N.LAST_DOWN_TIME,
                    :UDRINFO_N.LAST_DOWN_HIST_SEQ,
                    :UDRINFO_N.LAST_EVENT_ID,
                    :UDRINFO_N.LAST_EVENT_TIME,
                    :UDRINFO_N.LAST_ACTIVE_HIST_SEQ,
                    :UDRINFO_N.LAST_HIST_SEQ
                FROM MFMBUDRLOC A, MRASRESDEF B
                WHERE A.FACTORY = :UDRINFO_N.FACTORY
                    AND A.FACTORY = B.FACTORY
                    AND A.RES_ID = B.RES_ID
                    AND A.RES_ID = :UDRINFO_N.RES_ID
                    AND A.GROUP_ID = :UDRINFO_N.GROUP_ID
                    AND A.RES_TYPE = 'R';
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_udrinfo(&UDRINFO_N, UDRINFO);
    }
    DB_stop_query_timer("DBC_select_udrinfo", sel_type);
}

/* Initialize Function */
void DBC_init_udrinfo(struct UDRINFO_TAG *UDRINFO)
{
    /* memset by Space */
    memset(UDRINFO, ' ', sizeof(struct UDRINFO_TAG));
    UDRINFO->LOC_X = 0;
    UDRINFO->LOC_Y = 0;
    UDRINFO->LOC_WIDTH = 0;
    UDRINFO->LOC_HEIGHT = 0;
    UDRINFO->TEXT_SIZE = 0;
    UDRINFO->TEXT_COLOR = 0;
    UDRINFO->TAG_TYPE = 0;
    UDRINFO->BACK_COLOR = 0;   
    UDRINFO->SEQ = 0; 
    UDRINFO->MAX_PROC_COUNT = 0;
    UDRINFO->PROC_COUNT = 0;
    UDRINFO->LAST_DOWN_HIST_SEQ = 0;
    UDRINFO->LAST_ACTIVE_HIST_SEQ = 0;
    UDRINFO->LAST_HIST_SEQ = 0;
    UDRINFO->ANGLE = 0;
}

/* Add Null Function */
void DBC_add_null_udrinfo(struct UDRINFO_N_TAG *UDRINFO_N, struct UDRINFO_TAG *UDRINFO)
{ 
    /* memset by NULL */
    memset(UDRINFO_N, '\0', sizeof(struct UDRINFO_N_TAG));

    MEMCPY_AN(UDRINFO_N->FACTORY, UDRINFO->FACTORY, sizeof(UDRINFO->FACTORY));
    MEMCPY_AN(UDRINFO_N->GROUP_ID, UDRINFO->GROUP_ID, sizeof(UDRINFO->GROUP_ID));
    MEMCPY_AN(UDRINFO_N->RES_ID, UDRINFO->RES_ID, sizeof(UDRINFO->RES_ID));
    UDRINFO_N->RES_TAG_FLAG[0] = UDRINFO->RES_TAG_FLAG;
    UDRINFO_N->SEQ = UDRINFO->SEQ;
    UDRINFO_N->LOC_X = UDRINFO->LOC_X;
    UDRINFO_N->LOC_Y = UDRINFO->LOC_Y;
    UDRINFO_N->LOC_WIDTH = UDRINFO->LOC_WIDTH;
    UDRINFO_N->LOC_HEIGHT = UDRINFO->LOC_HEIGHT;
    MEMCPY_AN(UDRINFO_N->TEXT, UDRINFO->TEXT, sizeof(UDRINFO->TEXT));
    UDRINFO_N->TEXT_SIZE = UDRINFO->TEXT_SIZE;
    UDRINFO_N->TEXT_COLOR = UDRINFO->TEXT_COLOR;
    UDRINFO_N->TEXT_STYLE[0] = UDRINFO->TEXT_STYLE;
    UDRINFO_N->TAG_TYPE = UDRINFO->TAG_TYPE;
    UDRINFO_N->BACK_COLOR = UDRINFO->BACK_COLOR;
    MEMCPY_AN(UDRINFO_N->CREATE_TIME, UDRINFO->CREATE_TIME, sizeof(UDRINFO->CREATE_TIME));
    MEMCPY_AN(UDRINFO_N->UPDATE_TIME, UDRINFO->UPDATE_TIME, sizeof(UDRINFO->UPDATE_TIME));
    UDRINFO_N->NO_MOUSE_EVENT[0] = UDRINFO->NO_MOUSE_EVENT;
    UDRINFO_N->SIGNAL_FLAG[0] = UDRINFO->SIGNAL_FLAG;
    MEMCPY_AN(UDRINFO_N->MOTHER_RES_ID, UDRINFO->MOTHER_RES_ID, sizeof(UDRINFO->MOTHER_RES_ID));
    UDRINFO_N->ANGLE = UDRINFO->ANGLE;
    UDRINFO_N->RES_SHAPE[0] = UDRINFO->RES_SHAPE; 
    MEMCPY_AN(UDRINFO_N->RES_DESC, UDRINFO->RES_DESC, sizeof(UDRINFO->RES_DESC));
    MEMCPY_AN(UDRINFO_N->RES_TYPE, UDRINFO->RES_TYPE, sizeof(UDRINFO->RES_TYPE));
    MEMCPY_AN(UDRINFO_N->AREA_ID, UDRINFO->AREA_ID, sizeof(UDRINFO->AREA_ID));
    MEMCPY_AN(UDRINFO_N->SUB_AREA_ID, UDRINFO->SUB_AREA_ID, sizeof(UDRINFO->SUB_AREA_ID));
    MEMCPY_AN(UDRINFO_N->RES_LOCATION, UDRINFO->RES_LOCATION, sizeof(UDRINFO->RES_LOCATION));
    UDRINFO_N->PROC_RULE[0] = UDRINFO->PROC_RULE;
    UDRINFO_N->MAX_PROC_COUNT = UDRINFO->MAX_PROC_COUNT;
    UDRINFO_N->RES_UP_DOWN_FLAG[0] = UDRINFO->RES_UP_DOWN_FLAG;
    MEMCPY_AN(UDRINFO_N->RES_PRI_STS, UDRINFO->RES_PRI_STS, sizeof(UDRINFO->RES_PRI_STS));
    MEMCPY_AN(UDRINFO_N->RES_STS_1, UDRINFO->RES_STS_1, sizeof(UDRINFO->RES_STS_1));
    MEMCPY_AN(UDRINFO_N->RES_STS_2, UDRINFO->RES_STS_2, sizeof(UDRINFO->RES_STS_2));
    MEMCPY_AN(UDRINFO_N->RES_STS_3, UDRINFO->RES_STS_3, sizeof(UDRINFO->RES_STS_3));
    MEMCPY_AN(UDRINFO_N->RES_STS_4, UDRINFO->RES_STS_4, sizeof(UDRINFO->RES_STS_4));
    MEMCPY_AN(UDRINFO_N->RES_STS_5, UDRINFO->RES_STS_5, sizeof(UDRINFO->RES_STS_5));
    MEMCPY_AN(UDRINFO_N->RES_STS_6, UDRINFO->RES_STS_6, sizeof(UDRINFO->RES_STS_6));
    MEMCPY_AN(UDRINFO_N->RES_STS_7, UDRINFO->RES_STS_7, sizeof(UDRINFO->RES_STS_7));
    MEMCPY_AN(UDRINFO_N->RES_STS_8, UDRINFO->RES_STS_8, sizeof(UDRINFO->RES_STS_8));
    MEMCPY_AN(UDRINFO_N->RES_STS_9, UDRINFO->RES_STS_9, sizeof(UDRINFO->RES_STS_9));
    MEMCPY_AN(UDRINFO_N->RES_STS_10, UDRINFO->RES_STS_10, sizeof(UDRINFO->RES_STS_10));
    MEMCPY_AN(UDRINFO_N->LOT_ID, UDRINFO->LOT_ID, sizeof(UDRINFO->LOT_ID));
    MEMCPY_AN(UDRINFO_N->SUBLOT_ID, UDRINFO->SUBLOT_ID, sizeof(UDRINFO->SUBLOT_ID));
    MEMCPY_AN(UDRINFO_N->CRR_ID, UDRINFO->CRR_ID, sizeof(UDRINFO->CRR_ID));
    MEMCPY_AN(UDRINFO_N->RES_CTRL_MODE, UDRINFO->RES_CTRL_MODE, sizeof(UDRINFO->RES_CTRL_MODE));
    MEMCPY_AN(UDRINFO_N->RES_PROC_MODE, UDRINFO->RES_PROC_MODE, sizeof(UDRINFO->RES_PROC_MODE));
    MEMCPY_AN(UDRINFO_N->LAST_RECIPE_ID, UDRINFO->LAST_RECIPE_ID, sizeof(UDRINFO->LAST_RECIPE_ID));
    UDRINFO_N->PROC_COUNT = UDRINFO->PROC_COUNT;
    MEMCPY_AN(UDRINFO_N->LAST_START_TIME, UDRINFO->LAST_START_TIME, sizeof(UDRINFO->LAST_START_TIME));
    MEMCPY_AN(UDRINFO_N->LAST_END_TIME, UDRINFO->LAST_END_TIME, sizeof(UDRINFO->LAST_END_TIME));
    MEMCPY_AN(UDRINFO_N->LAST_DOWN_TIME, UDRINFO->LAST_DOWN_TIME, sizeof(UDRINFO->LAST_DOWN_TIME));
    UDRINFO_N->LAST_DOWN_HIST_SEQ = UDRINFO->LAST_DOWN_HIST_SEQ;
    MEMCPY_AN(UDRINFO_N->LAST_EVENT_ID, UDRINFO->LAST_EVENT_ID, sizeof(UDRINFO->LAST_EVENT_ID));
    MEMCPY_AN(UDRINFO_N->LAST_EVENT_TIME, UDRINFO->LAST_EVENT_TIME, sizeof(UDRINFO->LAST_EVENT_TIME));
    UDRINFO_N->LAST_ACTIVE_HIST_SEQ = UDRINFO->LAST_ACTIVE_HIST_SEQ;
    UDRINFO_N->LAST_HIST_SEQ = UDRINFO->LAST_HIST_SEQ;   
    
}


/* Del Null Function */
void DBC_del_null_udrinfo(struct UDRINFO_N_TAG *UDRINFO_N, struct UDRINFO_TAG *UDRINFO)
{
    MEMCPY_DN(UDRINFO->FACTORY, UDRINFO_N->FACTORY, sizeof(UDRINFO->FACTORY));
    MEMCPY_DN(UDRINFO->GROUP_ID, UDRINFO_N->GROUP_ID, sizeof(UDRINFO->GROUP_ID));
    MEMCPY_DN(UDRINFO->RES_ID, UDRINFO_N->RES_ID, sizeof(UDRINFO->RES_ID));
    UDRINFO->RES_TAG_FLAG = UDRINFO_N->RES_TAG_FLAG[0];
    UDRINFO->SEQ = UDRINFO_N->SEQ;
