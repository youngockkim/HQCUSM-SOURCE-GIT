    UDTDETAIL_N->CELL_COUNT_X = UDTDETAIL->CELL_COUNT_X;
    UDTDETAIL_N->CELL_COUNT_Y = UDTDETAIL->CELL_COUNT_Y;
    UDTDETAIL_N->CELL_COUNT_Z = UDTDETAIL->CELL_COUNT_Z;
    UDTDETAIL_N->CELL_SIZE_X  = UDTDETAIL->CELL_SIZE_X;
