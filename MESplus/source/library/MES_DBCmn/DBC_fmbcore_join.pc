/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_rescolor(int sel_type, struct RESCOLOR_TAG *RESCOLOR)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RESCOLOR_N_TAG RESCOLOR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_rescolor(&RESCOLOR_N, RESCOLOR);
    DB_error_code = 0;

    switch(sel_type)
    {
         case 1:
            EXEC SQL DECLARE DBC_RESCOLOR_CUR_1 CURSOR FOR 
                SELECT A.FACTORY, NVL(B.RES_TYPE , ' '), A.EVENT_ID,  NVL(B.COLOR , 0)
                FROM MRASEVNDEF A, MFMBEVTCLR B
                WHERE A.FACTORY = :RESCOLOR_N.FACTORY 
                AND B.RES_TYPE =  :RESCOLOR_N.RES_TYPE 
                AND A.FACTORY = B.FACTORY(+) 
                AND A.EVENT_ID = B.EVENT_ID(+) 
                AND A.EVENT_ID >= :RESCOLOR_N.EVENT_ID  
                ORDER BY A.EVENT_ID;
            EXEC SQL OPEN DBC_RESCOLOR_CUR_1;
            break;
 

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_rescolor", sel_type);
}           

/* SQL CURSOR FETCH Function */
void DBC_fetch_rescolor(int sel_type, struct RESCOLOR_TAG *RESCOLOR)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RESCOLOR_N_TAG RESCOLOR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_RESCOLOR_CUR_1 INTO
                                                :RESCOLOR_N.FACTORY,
                                                :RESCOLOR_N.RES_TYPE,
                                                :RESCOLOR_N.EVENT_ID,
                                                :RESCOLOR_N.COLOR;
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    if(DB_error_code == 0)
    {
        DBC_del_null_rescolor(&RESCOLOR_N, RESCOLOR);
    }
    DB_stop_query_timer("DBC_fetch_rescolor", sel_type);
}

/* SQL CURSOR CLOSE Function */
void DBC_close_rescolor(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_RESCOLOR_CUR_1;
            break;
            
       
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_rescolor", sel_type);
}

/* Initialize Function */
void DBC_init_rescolor(struct RESCOLOR_TAG *RESCOLOR)
{
    /* memset by Space */
    memset(RESCOLOR, ' ', sizeof(struct RESCOLOR_TAG));
    
    RESCOLOR->COLOR = 0;

}

/* Add Null Function */
void DBC_add_null_rescolor(struct RESCOLOR_N_TAG *RESCOLOR_N, struct RESCOLOR_TAG *RESCOLOR)
{ 
    /* memset by NULL */
    memset(RESCOLOR_N, '\0', sizeof(struct RESCOLOR_N_TAG));
    
    MEMCPY_AN(RESCOLOR_N->FACTORY, RESCOLOR->FACTORY, sizeof(RESCOLOR->FACTORY));
    MEMCPY_AN(RESCOLOR_N->RES_TYPE, RESCOLOR->RES_TYPE, sizeof(RESCOLOR->RES_TYPE));
    MEMCPY_AN(RESCOLOR_N->EVENT_ID, RESCOLOR->EVENT_ID, sizeof(RESCOLOR->EVENT_ID));
    RESCOLOR_N->COLOR = RESCOLOR->COLOR;
        
}


/* Del Null Function */
void DBC_del_null_rescolor(struct RESCOLOR_N_TAG *RESCOLOR_N, struct RESCOLOR_TAG *RESCOLOR)
{
    MEMCPY_DN(RESCOLOR->FACTORY, RESCOLOR_N->FACTORY, sizeof(RESCOLOR->FACTORY));
    MEMCPY_DN(RESCOLOR->RES_TYPE, RESCOLOR_N->RES_TYPE, sizeof(RESCOLOR->RES_TYPE));
    MEMCPY_DN(RESCOLOR->EVENT_ID, RESCOLOR_N->EVENT_ID, sizeof(RESCOLOR->EVENT_ID));
    RESCOLOR->COLOR = RESCOLOR_N->COLOR;
}          


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_resimage(int sel_type, struct RESIMAGE_TAG *RESIMAGE)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RESIMAGE_N_TAG RESIMAGE_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_resimage(&RESIMAGE_N, RESIMAGE);
    DB_error_code = 0;

    switch(sel_type)
    {
         case 1:
            EXEC SQL DECLARE DBC_RESIMAGE_CUR_1 CURSOR FOR 
                SELECT A.FACTORY, A.RES_ID, NVL(B.RES_TYPE,' '),A.RES_ID, A.RES_DESC, NVL(B.IMAGE_IDX , -1)
                FROM MRASRESDEF A, MFMBRESIMG B
                WHERE A.FACTORY = :RESIMAGE_N.FACTORY 
                AND A.FACTORY = B.FACTORY(+)
                AND B.RES_TYPE(+) = 'RES' 
                AND A.RES_ID = B.RES_ID(+) 
                AND A.DELETE_FLAG <> 'Y'
                AND A.RES_ID >= :RESIMAGE_N.RES_ID 
                ORDER BY A.RES_ID;

            EXEC SQL OPEN DBC_RESIMAGE_CUR_1;
            break;
 
        case 101:
            EXEC SQL DECLARE DBC_RESIMAGE_CUR_101 CURSOR FOR 
                SELECT A.FACTORY, A.RES_ID ,NVL(B.RES_TYPE,' ') , A.SUBRES_ID, A.SUBRES_DESC, NVL(B.IMAGE_IDX , -1)
                FROM MRASSRSDEF A, MFMBRESIMG B
                WHERE A.FACTORY = :RESIMAGE_N.FACTORY
                AND A.RES_ID = :RESIMAGE_N.RES_ID 
                AND A.FACTORY = B.FACTORY(+) 
                AND A.RES_ID = B.RES_ID(+) 
                AND A.SUBRES_ID = B.SUBRES_ID(+) 
                AND A.DELETE_FLAG <> 'Y'
                AND A.SUBRES_ID >= :RESIMAGE_N.SUBRES_ID  
                ORDER BY A.SUBRES_ID;

            EXEC SQL OPEN DBC_RESIMAGE_CUR_101;
            break;
            
        case 102:
            EXEC SQL DECLARE DBC_RESIMAGE_CUR_102 CURSOR FOR 
                SELECT A.FACTORY, A.RES_ID , NVL(B.RES_TYPE,' '), A.PORT_ID, A.PORT_DESC, NVL(B.IMAGE_IDX , -1)
                FROM MRASPOTDEF A, MFMBRESIMG B
                WHERE A.FACTORY = :RESIMAGE_N.FACTORY 
                AND A.RES_ID = :RESIMAGE_N.RES_ID
                AND A.FACTORY = B.FACTORY(+) 
                AND A.RES_ID = B.RES_ID(+) 
                AND A.PORT_ID = B.SUBRES_ID(+) 
                AND A.PORT_ID >= :RESIMAGE_N.SUBRES_ID  
                ORDER BY A.PORT_ID;

            EXEC SQL OPEN DBC_RESIMAGE_CUR_102;
            break;
            
        case 103:
            EXEC SQL DECLARE DBC_RESIMAGE_CUR_103 CURSOR FOR 
                SELECT A.FACTORY,  A.TOOL_ID , NVL(B.RES_TYPE,' '), A.TOOL_ID, A.TOOL_DESC, NVL(B.IMAGE_IDX , -1)
                FROM MRASTOLDEF A, MFMBRESIMG B
                WHERE A.FACTORY = :RESIMAGE_N.FACTORY 
                AND A.FACTORY = B.FACTORY(+) 
                AND A.TOOL_ID = B.RES_ID(+) 
                AND A.DELETE_FLAG <> 'Y'
                AND A.TOOL_ID >= :RESIMAGE_N.RES_ID  
                ORDER BY A.TOOL_ID;
            EXEC SQL OPEN DBC_RESIMAGE_CUR_103;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_resimage", sel_type);
}           

/* SQL CURSOR FETCH Function */
void DBC_fetch_resimage(int sel_type, struct RESIMAGE_TAG *RESIMAGE)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RESIMAGE_N_TAG RESIMAGE_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_RESIMAGE_CUR_1 INTO
                                                :RESIMAGE_N.FACTORY,
                                                :RESIMAGE_N.RES_ID,
                                                :RESIMAGE_N.RES_TYPE,
                                                :RESIMAGE_N.SUBRES_ID,
                                                :RESIMAGE_N.RES_DESC,
                                                :RESIMAGE_N.IMAGE_IDX;
            break;
        case 101:
            EXEC SQL FETCH DBC_RESIMAGE_CUR_101 INTO
                                                :RESIMAGE_N.FACTORY,
                                                :RESIMAGE_N.RES_ID,
                                                :RESIMAGE_N.RES_TYPE,
                                                :RESIMAGE_N.SUBRES_ID,
                                                :RESIMAGE_N.RES_DESC,
                                                :RESIMAGE_N.IMAGE_IDX;
            break;
        case 102:
            EXEC SQL FETCH DBC_RESIMAGE_CUR_102 INTO
                                                :RESIMAGE_N.FACTORY,
                                                :RESIMAGE_N.RES_ID,
                                                :RESIMAGE_N.RES_TYPE,
                                                :RESIMAGE_N.SUBRES_ID,
                                                :RESIMAGE_N.RES_DESC,
                                                :RESIMAGE_N.IMAGE_IDX;
            break;
        case 103:
            EXEC SQL FETCH DBC_RESIMAGE_CUR_103 INTO
                                                :RESIMAGE_N.FACTORY,
                                                :RESIMAGE_N.RES_ID,
                                                :RESIMAGE_N.RES_TYPE,
                                                :RESIMAGE_N.SUBRES_ID,
                                                :RESIMAGE_N.RES_DESC,
                                                :RESIMAGE_N.IMAGE_IDX;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    if(DB_error_code == 0)
    {
        DBC_del_null_resimage(&RESIMAGE_N, RESIMAGE);
    }
    DB_stop_query_timer("DBC_fetch_resimage", sel_type);
}

/* SQL CURSOR CLOSE Function */
void DBC_close_resimage(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_RESIMAGE_CUR_1;
            break;

        case 101:
            EXEC SQL CLOSE DBC_RESIMAGE_CUR_101;
            break;
            
        case 102:
            EXEC SQL CLOSE DBC_RESIMAGE_CUR_102;
            break;
            
        case 103:
            EXEC SQL CLOSE DBC_RESIMAGE_CUR_103;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_resimage", sel_type);
}

/* Initialize Function */
void DBC_init_resimage(struct RESIMAGE_TAG *RESIMAGE)
{
    /* memset by Space */
    memset(RESIMAGE, ' ', sizeof(struct RESIMAGE_TAG));
    
    RESIMAGE->IMAGE_IDX = 0;

}

/* Add Null Function */
void DBC_add_null_resimage(struct RESIMAGE_N_TAG *RESIMAGE_N, struct RESIMAGE_TAG *RESIMAGE)
{ 
    /* memset by NULL */
    memset(RESIMAGE_N, '\0', sizeof(struct RESIMAGE_N_TAG));
    
    MEMCPY_AN(RESIMAGE_N->FACTORY, RESIMAGE->FACTORY, sizeof(RESIMAGE->FACTORY));
    MEMCPY_AN(RESIMAGE_N->RES_ID, RESIMAGE->RES_ID, sizeof(RESIMAGE->RES_ID));
    MEMCPY_AN(RESIMAGE_N->RES_TYPE, RESIMAGE->RES_TYPE, sizeof(RESIMAGE->RES_TYPE));
    MEMCPY_AN(RESIMAGE_N->SUBRES_ID, RESIMAGE->SUBRES_ID, sizeof(RESIMAGE->SUBRES_ID));
    MEMCPY_AN(RESIMAGE_N->RES_DESC, RESIMAGE->RES_DESC, sizeof(RESIMAGE->RES_DESC));
    RESIMAGE_N->IMAGE_IDX = RESIMAGE->IMAGE_IDX;
  
}


/* Del Null Function */
void DBC_del_null_resimage(struct RESIMAGE_N_TAG *RESIMAGE_N, struct RESIMAGE_TAG *RESIMAGE)
{
    MEMCPY_DN(RESIMAGE->FACTORY, RESIMAGE_N->FACTORY, sizeof(RESIMAGE->FACTORY));
    MEMCPY_DN(RESIMAGE->RES_ID, RESIMAGE_N->RES_ID, sizeof(RESIMAGE->RES_ID));
    MEMCPY_DN(RESIMAGE->RES_TYPE, RESIMAGE_N->RES_TYPE, sizeof(RESIMAGE->RES_TYPE));
    MEMCPY_DN(RESIMAGE->RES_ID, RESIMAGE_N->SUBRES_ID, sizeof(RESIMAGE->SUBRES_ID));
    MEMCPY_DN(RESIMAGE->RES_DESC, RESIMAGE_N->RES_DESC, sizeof(RESIMAGE->RES_DESC));
    RESIMAGE->IMAGE_IDX = RESIMAGE_N->IMAGE_IDX;
 }
/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_tolloc_list(int sel_type, struct TOLLOC_LIST_TAG *TOLLOC_LIST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct TOLLOC_LIST_N_TAG TOLLOC_LIST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_tolloc_list(&TOLLOC_LIST_N, TOLLOC_LIST);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_TOLLOC_LIST_CUR_1 CURSOR FOR 
                SELECT * FROM (SELECT A.TOOL_ID, 'Y' ATTACHED, B.LAYOUT_ID LAYOUT_ID,A.TOOL_DESC
                FROM MRASTOLDEF A, MFMBRESLOC B 
                WHERE
                A.FACTORY = :TOLLOC_LIST_N.FACTORY 
                AND A.FACTORY = B.FACTORY
                AND B.RES_TYPE = 'L'
                UNION
                SELECT TOOL_ID, 'N' ATTACHED, ' ' LAYOUT_ID, TOOL_DESC
                FROM MRASTOLDEF WHERE
                FACTORY = :TOLLOC_LIST_N.FACTORY 
                AND DELETE_FLAG = ' '
                AND TOOL_ID NOT IN (SELECT RES_ID FROM MFMBRESLOC WHERE FACTORY = :TOLLOC_LIST_N.FACTORY)) C
                WHERE TOOL_ID >= :TOLLOC_LIST_N.TOOL_ID
                ORDER BY TOOL_ID;

            EXEC SQL OPEN DBC_TOLLOC_LIST_CUR_1;
            break;
   
        case 2:
            EXEC SQL DECLARE DBC_TOLLOC_LIST_CUR_2 CURSOR FOR 
                SELECT TOOL_ID, TOOL_DESC,TOOL_TYPE
                FROM MRASTOLDEF WHERE
                FACTORY = :TOLLOC_LIST_N.FACTORY
                AND DELETE_FLAG = ' '
                AND TOOL_ID NOT IN (SELECT RES_ID FROM MFMBRESLOC WHERE FACTORY = :TOLLOC_LIST_N.FACTORY) 
                AND TOOL_ID >= :TOLLOC_LIST_N.TOOL_ID
                ORDER BY TOOL_ID;

            EXEC SQL OPEN DBC_TOLLOC_LIST_CUR_2;
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_tolloc_list", sel_type);
}           

/* SQL CURSOR FETCH Function */
void DBC_fetch_tolloc_list(int sel_type, struct TOLLOC_LIST_TAG *TOLLOC_LIST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct TOLLOC_LIST_N_TAG TOLLOC_LIST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_TOLLOC_LIST_CUR_1 INTO 
                :TOLLOC_LIST_N.TOOL_ID,
                :TOLLOC_LIST_N.ATTACHED_FLAG,
                :TOLLOC_LIST_N.LAYOUT_ID,
                :TOLLOC_LIST_N.TOOL_DESC;
            break;

        case 2:
            EXEC SQL FETCH DBC_TOLLOC_LIST_CUR_2 INTO 
                :TOLLOC_LIST_N.TOOL_ID,
                :TOLLOC_LIST_N.TOOL_DESC,
                :TOLLOC_LIST_N.TOOL_TYPE;
            break;
            
                            
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    if(DB_error_code == 0)
    {
        DBC_del_null_tolloc_list(&TOLLOC_LIST_N, TOLLOC_LIST);
    }
    DB_stop_query_timer("DBC_fetch_tolloc_list", sel_type);
}

/* SQL CURSOR CLOSE Function */
void DBC_close_tolloc_list(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_TOLLOC_LIST_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_TOLLOC_LIST_CUR_2;
            break;
      

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_tolloc_list", sel_type);
}

/* Initialize Function */
void DBC_init_tolloc_list(struct TOLLOC_LIST_TAG *TOLLOC_LIST)
{
    /* memset by Space */
    memset(TOLLOC_LIST, ' ', sizeof(struct TOLLOC_LIST_TAG));

}

/* Add Null Function */
void DBC_add_null_tolloc_list(struct TOLLOC_LIST_N_TAG *TOLLOC_LIST_N, struct TOLLOC_LIST_TAG *TOLLOC_LIST)
{ 
    /* memset by NULL */
    memset(TOLLOC_LIST_N, '\0', sizeof(struct TOLLOC_LIST_N_TAG));
    
    MEMCPY_AN(TOLLOC_LIST_N->FACTORY ,TOLLOC_LIST->FACTORY ,sizeof(TOLLOC_LIST->FACTORY));
    MEMCPY_AN(TOLLOC_LIST_N->TOOL_ID ,TOLLOC_LIST->TOOL_ID ,sizeof(TOLLOC_LIST->TOOL_ID));
    MEMCPY_AN(TOLLOC_LIST_N->TOOL_DESC ,TOLLOC_LIST->TOOL_DESC,sizeof(TOLLOC_LIST->TOOL_DESC));
    TOLLOC_LIST_N->ATTACHED_FLAG[0]= TOLLOC_LIST->ATTACHED_FLAG;
    MEMCPY_AN(TOLLOC_LIST_N->LAYOUT_ID ,TOLLOC_LIST->LAYOUT_ID,sizeof(TOLLOC_LIST->LAYOUT_ID));
}


/* Del Null Function */
void DBC_del_null_tolloc_list(struct TOLLOC_LIST_N_TAG *TOLLOC_LIST_N, struct TOLLOC_LIST_TAG *TOLLOC_LIST)
{
    MEMCPY_DN(TOLLOC_LIST->FACTORY ,TOLLOC_LIST_N->FACTORY ,sizeof(TOLLOC_LIST->FACTORY ));
    MEMCPY_DN(TOLLOC_LIST->TOOL_ID ,TOLLOC_LIST_N->TOOL_ID ,sizeof(TOLLOC_LIST->TOOL_ID ));
    MEMCPY_DN(TOLLOC_LIST->TOOL_DESC ,TOLLOC_LIST_N->TOOL_DESC,sizeof(TOLLOC_LIST->TOOL_DESC));
    TOLLOC_LIST->ATTACHED_FLAG = TOLLOC_LIST_N->ATTACHED_FLAG[0];
    MEMCPY_DN(TOLLOC_LIST->LAYOUT_ID ,TOLLOC_LIST_N->LAYOUT_ID,sizeof(TOLLOC_LIST->LAYOUT_ID));
}   

/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_potloc_list(int sel_type, struct POTLOC_LIST_TAG *POTLOC_LIST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct POTLOC_LIST_N_TAG POTLOC_LIST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_potloc_list(&POTLOC_LIST_N, POTLOC_LIST);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_POTLOC_LIST_CUR_1 CURSOR FOR 
                SELECT * FROM (SELECT A.RES_ID, A.PORT_ID, A.PORT_DESC, 'Y' ATTACHED, B.LAYOUT_ID LAYOUT_ID, A.SUBRES_ID
                FROM MRASPOTDEF A, MFMBRESLOC B 
                WHERE
                A.FACTORY = :POTLOC_LIST_N.FACTORY 
                AND A.FACTORY = B.FACTORY 
                AND A.PORT_ID = B.RES_ID
                AND A.RES_ID =  B.MOTHER_RES_ID
                AND B.RES_TYPE = 'P'
                UNION
                SELECT RES_ID, PORT_ID, PORT_DESC, 'N' ATTACHED, ' ' LAYOUT_ID, SUBRES_ID
                FROM MRASPOTDEF WHERE
                FACTORY = :POTLOC_LIST_N.FACTORY
                AND (PORT_ID,RES_ID)NOT IN (SELECT RES_ID,MOTHER_RES_ID FROM MFMBRESLOC WHERE FACTORY = :POTLOC_LIST_N.FACTORY)) C
                WHERE PORT_ID >= :POTLOC_LIST_N.PORT_ID
                AND RES_ID = :POTLOC_LIST_N.RES_ID
                ORDER BY PORT_ID;
            EXEC SQL OPEN DBC_POTLOC_LIST_CUR_1;
            break;
   
        case 2:
            EXEC SQL DECLARE DBC_POTLOC_LIST_CUR_2 CURSOR FOR 
                SELECT PORT_ID, PORT_DESC, RES_ID
                FROM MRASPOTDEF WHERE
                FACTORY = :POTLOC_LIST_N.FACTORY
                AND RES_ID = :POTLOC_LIST_N.RES_ID
                AND (PORT_ID,RES_ID) NOT IN (SELECT RES_ID,MOTHER_RES_ID FROM MFMBRESLOC WHERE FACTORY = :POTLOC_LIST_N.FACTORY) 
                AND PORT_ID >= :POTLOC_LIST_N.PORT_ID
                ORDER BY PORT_ID;

            EXEC SQL OPEN DBC_POTLOC_LIST_CUR_2;
            break;
         
         case 3:
            EXEC SQL DECLARE DBC_POTLOC_LIST_CUR_3 CURSOR FOR 
                SELECT DISTINCT A.RES_ID, B.RES_DESC, B.RES_UP_DOWN_FLAG
                FROM MRASPOTDEF A, MRASRESDEF B  WHERE
                A.FACTORY = B.FACTORY
                AND A.RES_ID = B.RES_ID
                AND A.RES_ID IN (
                    SELECT RES_ID FROM (
                        SELECT A.RES_ID, 'Y' ATTACHED
                        FROM MRASPOTDEF A, MFMBRESLOC B 
                        WHERE A.FACTORY = :POTLOC_LIST_N.FACTORY 
                            AND A.FACTORY = B.FACTORY 
                            AND A.PORT_ID = B.RES_ID
                            AND B.RES_TYPE = 'P'
                            AND A.RES_ID = B.MOTHER_RES_ID
                        UNION
                        SELECT RES_ID, 'N' ATTACHED
                        FROM MRASPOTDEF 
                        WHERE FACTORY = :POTLOC_LIST_N.FACTORY
                            AND (PORT_ID, RES_ID) NOT IN (
                                SELECT RES_ID, MOTHER_RES_ID 
                                FROM MFMBRESLOC 
                                WHERE FACTORY = :POTLOC_LIST_N.FACTORY
                                )
                        ) C
                    WHERE ATTACHED = 'N'
                    )
                ORDER BY A.RES_ID;
            EXEC SQL OPEN DBC_POTLOC_LIST_CUR_3;
            break;    
          
          case 4:
            EXEC SQL DECLARE DBC_POTLOC_LIST_CUR_4 CURSOR FOR 
                SELECT * FROM (SELECT A.RES_ID, A.PORT_ID, A.PORT_DESC, 'Y' ATTACHED, B.LAYOUT_ID LAYOUT_ID, A.SUBRES_ID
                FROM MRASPOTDEF A, MFMBRESLOC B 
                WHERE
                A.FACTORY = :POTLOC_LIST_N.FACTORY 
                AND A.FACTORY = B.FACTORY 
                AND A.PORT_ID = B.RES_ID
                AND A.RES_ID =  B.MOTHER_RES_ID
                AND B.RES_TYPE = 'P'
                AND B.LAYOUT_ID = :POTLOC_LIST_N.LAYOUT_ID
                UNION
                SELECT RES_ID, PORT_ID, PORT_DESC, 'N' ATTACHED, ' ' LAYOUT_ID, SUBRES_ID
                FROM MRASPOTDEF WHERE
                FACTORY = :POTLOC_LIST_N.FACTORY
                AND (PORT_ID,RES_ID)NOT IN (SELECT RES_ID,MOTHER_RES_ID FROM MFMBRESLOC WHERE FACTORY = :POTLOC_LIST_N.FACTORY)
                UNION
                SELECT A.RES_ID, A.PORT_ID, A.PORT_DESC, 'N' ATTACHED, B.LAYOUT_ID LAYOUT_ID, A.SUBRES_ID
                FROM MRASPOTDEF A, MFMBRESLOC B 
                WHERE
                A.FACTORY = :POTLOC_LIST_N.FACTORY
                AND A.FACTORY = B.FACTORY 
                AND A.PORT_ID = B.RES_ID
                AND A.RES_ID =  B.MOTHER_RES_ID
                AND B.RES_TYPE = 'P'
                AND B.LAYOUT_ID <>  :POTLOC_LIST_N.LAYOUT_ID
                ) C
                WHERE PORT_ID >= :POTLOC_LIST_N.PORT_ID
                AND RES_ID = :POTLOC_LIST_N.RES_ID
                ORDER BY ATTACHED DESC,PORT_ID;
            EXEC SQL OPEN DBC_POTLOC_LIST_CUR_4;
            break;   


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_potloc_list", sel_type);
}           

/* SQL CURSOR FETCH Function */
void DBC_fetch_potloc_list(int sel_type, struct POTLOC_LIST_TAG *POTLOC_LIST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct POTLOC_LIST_N_TAG POTLOC_LIST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_POTLOC_LIST_CUR_1 INTO 
                :POTLOC_LIST_N.RES_ID,
                :POTLOC_LIST_N.PORT_ID,
                :POTLOC_LIST_N.PORT_DESC,
                :POTLOC_LIST_N.ATTACHED_FLAG,
                :POTLOC_LIST_N.LAYOUT_ID,
                :POTLOC_LIST_N.SUBRES_ID;
            break;

        case 2:
            EXEC SQL FETCH DBC_POTLOC_LIST_CUR_2 INTO 
                :POTLOC_LIST_N.PORT_ID,
                :POTLOC_LIST_N.PORT_DESC,
                :POTLOC_LIST_N.RES_ID;
            break;
            
       case 3:
            EXEC SQL FETCH DBC_POTLOC_LIST_CUR_3 INTO 
                :POTLOC_LIST_N.RES_ID,
                :POTLOC_LIST_N.RES_DESC,
                :POTLOC_LIST_N.RES_UP_DOWN_FLAG;
            break;
            
        case 4:
            EXEC SQL FETCH DBC_POTLOC_LIST_CUR_4 INTO 
                :POTLOC_LIST_N.RES_ID,
                :POTLOC_LIST_N.PORT_ID,
                :POTLOC_LIST_N.PORT_DESC,
                :POTLOC_LIST_N.ATTACHED_FLAG,
                :POTLOC_LIST_N.LAYOUT_ID,
                :POTLOC_LIST_N.SUBRES_ID;
            break;            
        

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    if(DB_error_code == 0)
    {
        DBC_del_null_potloc_list(&POTLOC_LIST_N, POTLOC_LIST);
    }
    DB_stop_query_timer("DBC_fetch_potloc_list", sel_type);
}

/* SQL CURSOR CLOSE Function */
void DBC_close_potloc_list(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_POTLOC_LIST_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_POTLOC_LIST_CUR_2;
            break;
       
       case 3:
            EXEC SQL CLOSE DBC_POTLOC_LIST_CUR_3;
            break; 
            
       case 4:
            EXEC SQL CLOSE DBC_POTLOC_LIST_CUR_4;
            break;      
      

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_potloc_list", sel_type);
}

/* Initialize Function */
void DBC_init_potloc_list(struct POTLOC_LIST_TAG *POTLOC_LIST)
{
    /* memset by Space */
    memset(POTLOC_LIST, ' ', sizeof(struct POTLOC_LIST_TAG));

}

/* Add Null Function */
void DBC_add_null_potloc_list(struct POTLOC_LIST_N_TAG *POTLOC_LIST_N, struct POTLOC_LIST_TAG *POTLOC_LIST)
{ 
    /* memset by NULL */
    memset(POTLOC_LIST_N, '\0', sizeof(struct POTLOC_LIST_N_TAG));

