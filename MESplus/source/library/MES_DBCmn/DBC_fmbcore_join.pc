    MEMCPY_AN(UDPDETAIL_N->CREATE_TIME, UDPDETAIL->CREATE_TIME, sizeof(UDPDETAIL->CREATE_TIME));
    MEMCPY_AN(UDPDETAIL_N->UPDATE_TIME, UDPDETAIL->UPDATE_TIME, sizeof(UDPDETAIL->UPDATE_TIME));
    UDPDETAIL_N->NO_MOUSE_EVENT[0] = UDPDETAIL->NO_MOUSE_EVENT;
