/* SQL CURSOR CLOSE Function */
void DBC_close_udtdetail(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_UDTDETAIL_CUR_1;
            break;
        
        case 2:
            EXEC SQL CLOSE DBC_UDTDETAIL_CUR_2;
            break;    
       

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_udtdetail", sel_type);
}

/* Initialize Function */
void DBC_init_udtdetail(struct UDTDETAIL_TAG *UDTDETAIL)
{
    /* memset by Space */
    memset(UDTDETAIL, ' ', sizeof(struct UDTDETAIL_TAG));
    UDTDETAIL->LOC_X = 0;
    UDTDETAIL->LOC_Y = 0;
    UDTDETAIL->LOC_WIDTH = 0;
    UDTDETAIL->LOC_HEIGHT = 0;
    UDTDETAIL->TEXT_SIZE = 0;
    UDTDETAIL->TEXT_COLOR = 0;
    UDTDETAIL->TAG_TYPE = 0;
    UDTDETAIL->BACK_COLOR = 0;  
    UDTDETAIL->SEQ = 0;  
    UDTDETAIL->LAST_HIST_SEQ = 0;
    UDTDETAIL->LAST_ACTIVE_HIST_SEQ = 0;
    UDTDETAIL->LAST_HIST_SEQ = 0;
    UDTDETAIL->ANGLE = 0;
}

/* Add Null Function */
void DBC_add_null_udtdetail(struct UDTDETAIL_N_TAG *UDTDETAIL_N, struct UDTDETAIL_TAG *UDTDETAIL)
{ 
    /* memset by NULL */
    memset(UDTDETAIL_N, '\0', sizeof(struct UDTDETAIL_N_TAG));

    MEMCPY_AN(UDTDETAIL_N->FACTORY, UDTDETAIL->FACTORY, sizeof(UDTDETAIL->FACTORY));
    MEMCPY_AN(UDTDETAIL_N->RES_ID, UDTDETAIL->RES_ID, sizeof(UDTDETAIL->RES_ID));
    MEMCPY_AN(UDTDETAIL_N->RES_TYPE, UDTDETAIL->RES_TYPE, sizeof(UDTDETAIL->RES_TYPE));
    MEMCPY_AN(UDTDETAIL_N->GROUP_ID, UDTDETAIL->GROUP_ID, sizeof(UDTDETAIL->GROUP_ID));
    UDTDETAIL_N->SEQ = UDTDETAIL->SEQ;
    UDTDETAIL_N->LOC_X = UDTDETAIL->LOC_X;
    UDTDETAIL_N->LOC_Y = UDTDETAIL->LOC_Y;
    UDTDETAIL_N->LOC_WIDTH = UDTDETAIL->LOC_WIDTH;
    UDTDETAIL_N->LOC_HEIGHT = UDTDETAIL->LOC_HEIGHT;
    MEMCPY_AN(UDTDETAIL_N->TEXT, UDTDETAIL->TEXT, sizeof(UDTDETAIL->TEXT));
    UDTDETAIL_N->TEXT_SIZE = UDTDETAIL->TEXT_SIZE;
    UDTDETAIL_N->TEXT_COLOR = UDTDETAIL->TEXT_COLOR;
    UDTDETAIL_N->TEXT_STYLE[0] = UDTDETAIL->TEXT_STYLE;
    UDTDETAIL_N->TAG_TYPE = UDTDETAIL->TAG_TYPE;
    UDTDETAIL_N->BACK_COLOR = UDTDETAIL->BACK_COLOR;
