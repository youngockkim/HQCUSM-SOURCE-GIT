    MEMCPY_AN(RESLOCDETAIL_N->UPDATE_USER_ID, RESLOCDETAIL->UPDATE_USER_ID, sizeof(RESLOCDETAIL->UPDATE_USER_ID));
    MEMCPY_AN(RESLOCDETAIL_N->UPDATE_TIME, RESLOCDETAIL->UPDATE_TIME, sizeof(RESLOCDETAIL->UPDATE_TIME));
    RESLOCDETAIL_N->RES_UP_DOWN_FLAG[0] = RESLOCDETAIL->RES_UP_DOWN_FLAG;
