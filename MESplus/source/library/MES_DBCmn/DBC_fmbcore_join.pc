    MEMCPY_DN(RESDETAIL->RES_DESC, RESDETAIL_N->RES_DESC, sizeof(RESDETAIL->RES_DESC));
    MEMCPY_DN(RESDETAIL->RES_TYPE, RESDETAIL_N->RES_TYPE, sizeof(RESDETAIL->RES_TYPE));
    MEMCPY_DN(RESDETAIL->AREA_ID, RESDETAIL_N->AREA_ID, sizeof(RESDETAIL->AREA_ID));
