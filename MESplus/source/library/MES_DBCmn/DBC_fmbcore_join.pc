/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_potdetail(int sel_type, struct POTDETAIL_TAG *POTDETAIL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct POTDETAIL_N_TAG POTDETAIL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_potdetail(&POTDETAIL_N, POTDETAIL);
    DB_error_code = 0;

 
    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_POTDETAIL_CUR_1 CURSOR FOR 
                SELECT A.FACTORY, B.RES_ID, A.RES_TYPE, B.SUBRES_ID, B.PORT_ID, B.PORT_SEQ, A.LAYOUT_ID, A.SEQ,
                    A.LOC_X, A.LOC_Y, A.LOC_WIDTH, A.LOC_HEIGHT, A.TEXT, A.TEXT_SIZE, A.TEXT_COLOR, A.TEXT_STYLE, A.TAG_TYPE, A.BACK_COLOR,
                    B.PORT_DESC, B.TRS_STATE, B.LOT_ID, B.CRR_ID, B.BCR_STATUS_FLAG, B.PORT_TYPE, B.PORT_BATCH_FLAG, B.ADD_PORT_TYPE,
                    B.PORT_LEVEL, B.PORT_CMF_1, B.PORT_CMF_2, B.PORT_CMF_3, B.PORT_CMF_4, B.PORT_CMF_5, B.PORT_CMF_6, B.PORT_CMF_7, B.PORT_CMF_8,
                    B.PORT_CMF_9, B.PORT_CMF_10, B.PORT_CMF_11, B.PORT_CMF_12, B.PORT_CMF_13, B.PORT_CMF_14, B.PORT_CMF_15, B.PORT_CMF_16, B.PORT_CMF_17,
                    B.PORT_CMF_18, B.PORT_CMF_19, B.PORT_CMF_20, B.LAST_HIST_SEQ, A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME, A.NO_MOUSE_EVENT, 
                    A.SIGNAL_FLAG,A.ANGLE,A.RES_SHAPE
                FROM MFMBRESLOC A, MRASPOTDEF B 
                WHERE A.FACTORY = :POTDETAIL_N.FACTORY 
                    AND A.LAYOUT_ID =  :POTDETAIL_N.LAYOUT_ID
                    AND A.FACTORY = B.FACTORY 
                    AND A.RES_ID = B.PORT_ID
                    AND A.MOTHER_RES_ID = B.RES_ID 
                    AND A.RES_TYPE = 'P'
                    AND A.SEQ >= :POTDETAIL_N.SEQ 
                ORDER BY A.SEQ;
            EXEC SQL OPEN DBC_POTDETAIL_CUR_1;
            break;
            
        case 2:
             EXEC SQL DECLARE DBC_POTDETAIL_CUR_2 CURSOR FOR 
                SELECT A.FACTORY, B.RES_ID, A.RES_TYPE, B.SUBRES_ID, B.PORT_ID, B.PORT_SEQ, A.LAYOUT_ID, A.SEQ, A.MOTHER_RES_ID,
                    A.LOC_X, A.LOC_Y, A.LOC_WIDTH, A.LOC_HEIGHT, A.TEXT, A.TEXT_SIZE, A.TEXT_COLOR, A.TEXT_STYLE, A.TAG_TYPE, A.BACK_COLOR,
                    B.PORT_DESC, B.TRS_STATE, B.LOT_ID, B.CRR_ID, B.BCR_STATUS_FLAG, B.PORT_TYPE, B.PORT_BATCH_FLAG, B.ADD_PORT_TYPE,
                    B.PORT_LEVEL, B.PORT_CMF_1, B.PORT_CMF_2, B.PORT_CMF_3, B.PORT_CMF_4, B.PORT_CMF_5, B.PORT_CMF_6, B.PORT_CMF_7, B.PORT_CMF_8,
                    B.PORT_CMF_9, B.PORT_CMF_10, B.PORT_CMF_11, B.PORT_CMF_12, B.PORT_CMF_13, B.PORT_CMF_14, B.PORT_CMF_15, B.PORT_CMF_16, B.PORT_CMF_17,
                    B.PORT_CMF_18, B.PORT_CMF_19, B.PORT_CMF_20, B.LAST_HIST_SEQ, A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME, A.NO_MOUSE_EVENT, 
                    A.SIGNAL_FLAG,A.ANGLE,A.RES_SHAPE
                FROM MFMBRESLOC A, MRASPOTDEF B 
                WHERE A.FACTORY = :POTDETAIL_N.FACTORY 
                    AND A.LAYOUT_ID =  :POTDETAIL_N.LAYOUT_ID
                    AND A.FACTORY = B.FACTORY
                    AND A.MOTHER_RES_ID = B.RES_ID 
                    AND B.PORT_ID = A.RES_ID
                    AND A.RES_TYPE = 'P'
                    AND A.SEQ <= :POTDETAIL_N.SEQ 
                ORDER BY A.SEQ DESC;
            EXEC SQL OPEN DBC_POTDETAIL_CUR_2;
            
        break;    
         

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_potdetail", sel_type);
}

/* SQL CURSOR FETCH Function */
void DBC_fetch_potdetail(int sel_type, struct POTDETAIL_TAG *POTDETAIL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct POTDETAIL_N_TAG POTDETAIL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_POTDETAIL_CUR_1 INTO 
                :POTDETAIL_N.FACTORY,
                :POTDETAIL_N.RES_ID,
