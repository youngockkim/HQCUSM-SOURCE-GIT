                :SRSDETAIL_N.SUBRES_UP_DOWN_FLAG,
                :SRSDETAIL_N.SUBRES_PRI_STS,
                :SRSDETAIL_N.SUBRES_STS_1,
                :SRSDETAIL_N.SUBRES_STS_2,
                :SRSDETAIL_N.SUBRES_STS_3,
                :SRSDETAIL_N.SUBRES_STS_4,
                :SRSDETAIL_N.SUBRES_STS_5,
                :SRSDETAIL_N.SUBRES_STS_6,
                :SRSDETAIL_N.SUBRES_STS_7,
                :SRSDETAIL_N.SUBRES_STS_8,
                :SRSDETAIL_N.SUBRES_STS_9,
                :SRSDETAIL_N.SUBRES_STS_10,
                :SRSDETAIL_N.LOT_ID,
                :SRSDETAIL_N.SUBLOT_ID,
                :SRSDETAIL_N.CRR_ID,
                :SRSDETAIL_N.LAST_EVENT_ID,
                :SRSDETAIL_N.LAST_EVENT_TIME,
                :SRSDETAIL_N.LAST_ACTIVE_HIST_SEQ,
                :SRSDETAIL_N.LAST_HIST_SEQ,
                :SRSDETAIL_N.CREATE_USER_ID,
                :SRSDETAIL_N.CREATE_TIME,
                :SRSDETAIL_N.UPDATE_USER_ID,
                :SRSDETAIL_N.UPDATE_TIME,
                :SRSDETAIL_N.NO_MOUSE_EVENT,
                :SRSDETAIL_N.SIGNAL_FLAG,
                :SRSDETAIL_N.ANGLE,
                :SRSDETAIL_N.RES_SHAPE;
            break;                  


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    if(DB_error_code == 0)
    {
        DBC_del_null_srsdetail(&SRSDETAIL_N, SRSDETAIL);
    }
    DB_stop_query_timer("DBC_fetch_srsdetail", sel_type);
}

/* SQL CURSOR CLOSE Function */
void DBC_close_srsdetail(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_SRSDETAIL_CUR_1;
            break;
        
        case 2:
            EXEC SQL CLOSE DBC_SRSDETAIL_CUR_2;
            break;    
       

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_srsdetail", sel_type);
}

/* Initialize Function */
void DBC_init_srsdetail(struct SRSDETAIL_TAG *SRSDETAIL)
{
    /* memset by Space */
    memset(SRSDETAIL, ' ', sizeof(struct SRSDETAIL_TAG));
    SRSDETAIL->LOC_X = 0;
    SRSDETAIL->LOC_Y = 0;
    SRSDETAIL->LOC_WIDTH = 0;
    SRSDETAIL->LOC_HEIGHT = 0;
    SRSDETAIL->TEXT_SIZE = 0;
    SRSDETAIL->TEXT_COLOR = 0;
    SRSDETAIL->TAG_TYPE = 0;
    SRSDETAIL->BACK_COLOR = 0;  
    SRSDETAIL->SEQ = 0;  
    SRSDETAIL->LAST_HIST_SEQ = 0;
    SRSDETAIL->LAST_ACTIVE_HIST_SEQ = 0;
    SRSDETAIL->LAST_HIST_SEQ = 0;
    SRSDETAIL->ANGLE = 0;
}

/* Add Null Function */
void DBC_add_null_srsdetail(struct SRSDETAIL_N_TAG *SRSDETAIL_N, struct SRSDETAIL_TAG *SRSDETAIL)
{ 
    /* memset by NULL */
    memset(SRSDETAIL_N, '\0', sizeof(struct SRSDETAIL_N_TAG));

    MEMCPY_AN(SRSDETAIL_N->FACTORY, SRSDETAIL->FACTORY, sizeof(SRSDETAIL->FACTORY));
    MEMCPY_AN(SRSDETAIL_N->RES_ID, SRSDETAIL->RES_ID, sizeof(SRSDETAIL->RES_ID));
    SRSDETAIL_N->RES_TYPE[0], SRSDETAIL->RES_TYPE;
