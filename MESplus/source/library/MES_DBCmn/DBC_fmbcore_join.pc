    UDPDETAIL_N->ANGLE = UDPDETAIL->ANGLE;
    UDPDETAIL_N->RES_SHAPE[0] = UDPDETAIL->RES_SHAPE;
}


/* Del Null Function */
void DBC_del_null_udpdetail(struct UDPDETAIL_N_TAG *UDPDETAIL_N, struct UDPDETAIL_TAG *UDPDETAIL)
{
    MEMCPY_DN(UDPDETAIL->FACTORY, UDPDETAIL_N->FACTORY, sizeof(UDPDETAIL->FACTORY));
    MEMCPY_DN(UDPDETAIL->RES_ID, UDPDETAIL_N->RES_ID, sizeof(UDPDETAIL->RES_ID));
    UDPDETAIL->PORT_TYPE = UDPDETAIL_N->PORT_TYPE[0];
    MEMCPY_DN(UDPDETAIL->SUBRES_ID, UDPDETAIL_N->SUBRES_ID, sizeof(UDPDETAIL->SUBRES_ID));
    MEMCPY_DN(UDPDETAIL->PORT_ID, UDPDETAIL_N->PORT_ID, sizeof(UDPDETAIL->PORT_ID));
    UDPDETAIL->PORT_SEQ = UDPDETAIL_N->PORT_SEQ;
