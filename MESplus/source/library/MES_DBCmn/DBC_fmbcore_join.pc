                :RESLOCDETAIL_N.MAX_PROC_COUNT,
                :RESLOCDETAIL_N.BATCH_COND_1,
                :RESLOCDETAIL_N.BATCH_COND_2,
                :RESLOCDETAIL_N.PM_SCH_ENABLE_FLAG,
                :RESLOCDETAIL_N.UNIT_BASE_ST_FLAG,
                :RESLOCDETAIL_N.SEC_CHK_FLAG,
                :RESLOCDETAIL_N.GATHER_ALARM_FLAG,
                :RESLOCDETAIL_N.DELETE_FLAG,
                :RESLOCDETAIL_N.DELETE_USER_ID,
                :RESLOCDETAIL_N.DELETE_TIME,
                :RESLOCDETAIL_N.CREATE_USER_ID,
                :RESLOCDETAIL_N.CREATE_TIME,
                :RESLOCDETAIL_N.UPDATE_USER_ID,
                :RESLOCDETAIL_N.UPDATE_TIME,
                :RESLOCDETAIL_N.RES_UP_DOWN_FLAG,
                :RESLOCDETAIL_N.RES_PRI_STS,
                :RESLOCDETAIL_N.RES_STS_1,
                :RESLOCDETAIL_N.RES_STS_2,
                :RESLOCDETAIL_N.RES_STS_3,
                :RESLOCDETAIL_N.RES_STS_4,
