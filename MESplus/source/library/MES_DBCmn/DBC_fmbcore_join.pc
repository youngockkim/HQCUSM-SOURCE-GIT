    MEMCPY_DN(RESDETAIL->RES_STS_7, RESDETAIL_N->RES_STS_7, sizeof(RESDETAIL->RES_STS_7));
    MEMCPY_DN(RESDETAIL->RES_STS_8, RESDETAIL_N->RES_STS_8, sizeof(RESDETAIL->RES_STS_8));
