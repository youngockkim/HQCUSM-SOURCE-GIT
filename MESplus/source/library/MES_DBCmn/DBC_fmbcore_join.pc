            break;
    }

    if(DB_error_code == 0)
    {
        DBC_del_null_udsdetail(&UDSDETAIL_N, UDSDETAIL);
    }
    DB_stop_query_timer("DBC_fetch_udsdetail", sel_type);
}

/* SQL CURSOR CLOSE Function */
void DBC_close_udsdetail(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_UDSDETAIL_CUR_1;
            break;
        
        case 2:
            EXEC SQL CLOSE DBC_UDSDETAIL_CUR_2;
            break;    
       

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_udsdetail", sel_type);
}

/* Initialize Function */
void DBC_init_udsdetail(struct UDSDETAIL_TAG *UDSDETAIL)
{
    /* memset by Space */
    memset(UDSDETAIL, ' ', sizeof(struct UDSDETAIL_TAG));
    UDSDETAIL->LOC_X = 0;
    UDSDETAIL->LOC_Y = 0;
    UDSDETAIL->LOC_WIDTH = 0;
    UDSDETAIL->LOC_HEIGHT = 0;
    UDSDETAIL->TEXT_SIZE = 0;
    UDSDETAIL->TEXT_COLOR = 0;
    UDSDETAIL->TAG_TYPE = 0;
    UDSDETAIL->BACK_COLOR = 0;  
    UDSDETAIL->SEQ = 0;  
    UDSDETAIL->LAST_HIST_SEQ = 0;
    UDSDETAIL->LAST_ACTIVE_HIST_SEQ = 0;
    UDSDETAIL->LAST_HIST_SEQ = 0;
    UDSDETAIL->ANGLE = 0;
}

/* Add Null Function */
void DBC_add_null_udsdetail(struct UDSDETAIL_N_TAG *UDSDETAIL_N, struct UDSDETAIL_TAG *UDSDETAIL)
{ 
    /* memset by NULL */
    memset(UDSDETAIL_N, '\0', sizeof(struct UDSDETAIL_N_TAG));

    MEMCPY_AN(UDSDETAIL_N->FACTORY, UDSDETAIL->FACTORY, sizeof(UDSDETAIL->FACTORY));
    MEMCPY_AN(UDSDETAIL_N->RES_ID, UDSDETAIL->RES_ID, sizeof(UDSDETAIL->RES_ID));
    UDSDETAIL_N->RES_TYPE[0], UDSDETAIL->RES_TYPE;
    MEMCPY_AN(UDSDETAIL_N->SUBRES_ID, UDSDETAIL->SUBRES_ID, sizeof(UDSDETAIL->SUBRES_ID));
    MEMCPY_AN(UDSDETAIL_N->SUBRES_DESC, UDSDETAIL->SUBRES_DESC, sizeof(UDSDETAIL->SUBRES_DESC));
    MEMCPY_AN(UDSDETAIL_N->SUBRES_TYPE, UDSDETAIL->SUBRES_TYPE, sizeof(UDSDETAIL->SUBRES_TYPE));
    MEMCPY_AN(UDSDETAIL_N->GROUP_ID, UDSDETAIL->GROUP_ID, sizeof(UDSDETAIL->GROUP_ID));
    UDSDETAIL_N->SEQ = UDSDETAIL->SEQ;
    UDSDETAIL_N->LOC_X = UDSDETAIL->LOC_X;
    UDSDETAIL_N->LOC_Y = UDSDETAIL->LOC_Y;
    UDSDETAIL_N->LOC_WIDTH = UDSDETAIL->LOC_WIDTH;
    UDSDETAIL_N->LOC_HEIGHT = UDSDETAIL->LOC_HEIGHT;
