    DB_stop_query_timer("DBC_fetch_potdetail", sel_type);
}

/* SQL CURSOR CLOSE Function */
void DBC_close_potdetail(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_POTDETAIL_CUR_1;
            break;
        
        case 2:
            EXEC SQL CLOSE DBC_POTDETAIL_CUR_2;
            break;    
       

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_potdetail", sel_type);
}

/* Initialize Function */
void DBC_init_potdetail(struct POTDETAIL_TAG *POTDETAIL)
{
    /* memset by Space */
    memset(POTDETAIL, ' ', sizeof(struct POTDETAIL_TAG));
    POTDETAIL->LOC_X = 0;
    POTDETAIL->LOC_Y = 0;
    POTDETAIL->LOC_WIDTH = 0;
    POTDETAIL->LOC_HEIGHT = 0;
    POTDETAIL->TEXT_SIZE = 0;
    POTDETAIL->TEXT_COLOR = 0;
    POTDETAIL->TAG_TYPE = 0;
    POTDETAIL->BACK_COLOR = 0;  
    POTDETAIL->SEQ = 0;  
    POTDETAIL->LAST_HIST_SEQ = 0;
    POTDETAIL->PORT_SEQ = 0;
    POTDETAIL->ANGLE = 0;
}

/* Add Null Function */
void DBC_add_null_potdetail(struct POTDETAIL_N_TAG *POTDETAIL_N, struct POTDETAIL_TAG *POTDETAIL)
{ 
    /* memset by NULL */
    memset(POTDETAIL_N, '\0', sizeof(struct POTDETAIL_N_TAG));

    MEMCPY_AN(POTDETAIL_N->FACTORY, POTDETAIL->FACTORY, sizeof(POTDETAIL->FACTORY));
    MEMCPY_AN(POTDETAIL_N->RES_ID, POTDETAIL->RES_ID, sizeof(POTDETAIL->RES_ID));
    POTDETAIL_N->PORT_TYPE[0] = POTDETAIL->PORT_TYPE;
    MEMCPY_AN(POTDETAIL_N->MOTHER_RES_ID, POTDETAIL->MOTHER_RES_ID, sizeof(POTDETAIL->MOTHER_RES_ID));
    MEMCPY_AN(POTDETAIL_N->SUBRES_ID, POTDETAIL->SUBRES_ID, sizeof(POTDETAIL->SUBRES_ID));
    MEMCPY_AN(POTDETAIL_N->PORT_ID, POTDETAIL->PORT_ID, sizeof(POTDETAIL->PORT_ID));
    POTDETAIL_N->PORT_SEQ = POTDETAIL->PORT_SEQ;
    MEMCPY_AN(POTDETAIL_N->LAYOUT_ID, POTDETAIL->LAYOUT_ID, sizeof(POTDETAIL->LAYOUT_ID));
    POTDETAIL_N->SEQ = POTDETAIL->SEQ;
    POTDETAIL_N->LOC_X = POTDETAIL->LOC_X;
    POTDETAIL_N->LOC_Y = POTDETAIL->LOC_Y;
    POTDETAIL_N->LOC_WIDTH = POTDETAIL->LOC_WIDTH;
    POTDETAIL_N->LOC_HEIGHT = POTDETAIL->LOC_HEIGHT;
    MEMCPY_AN(POTDETAIL_N->TEXT, POTDETAIL->TEXT, sizeof(POTDETAIL->TEXT));
