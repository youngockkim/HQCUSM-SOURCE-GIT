/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_srsdetail(int sel_type, struct SRSDETAIL_TAG *SRSDETAIL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct SRSDETAIL_N_TAG SRSDETAIL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_srsdetail(&SRSDETAIL_N, SRSDETAIL);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_SRSDETAIL_CUR_1 CURSOR FOR 
                SELECT A.FACTORY, B.RES_ID, A.RES_TYPE, B.SUBRES_ID, B.SUBRES_DESC, B.SUBRES_TYPE, A.LAYOUT_ID, A.SEQ,
                    A.LOC_X, A.LOC_Y, A.LOC_WIDTH, A.LOC_HEIGHT, A.TEXT, A.TEXT_SIZE, A.TEXT_COLOR, A.TEXT_STYLE,
                    A.TAG_TYPE, A.BACK_COLOR, B.USE_FAC_PRT_FLAG, B.RES_STS_PRT_1, B.RES_STS_PRT_2, B.RES_STS_PRT_3,
                    B.RES_STS_PRT_4, B.RES_STS_PRT_5, B.RES_STS_PRT_6, B.RES_STS_PRT_7, B.RES_STS_PRT_8, B.RES_STS_PRT_9,
                    B.RES_STS_PRT_10, B.SUBRES_CMF_1, B.SUBRES_CMF_2, B.SUBRES_CMF_3, B.SUBRES_CMF_4, B.SUBRES_CMF_5, B.SUBRES_CMF_6,
                    B.SUBRES_CMF_7, B.SUBRES_CMF_8, B.SUBRES_CMF_9, B.SUBRES_CMF_10, B.SUBRES_CMF_11, B.SUBRES_CMF_12, B.SUBRES_CMF_13,
                    B.SUBRES_CMF_14, B.SUBRES_CMF_15, B.SUBRES_CMF_16, B.SUBRES_CMF_17, B.SUBRES_CMF_18, B.SUBRES_CMF_19, B.SUBRES_CMF_20,B.CHAMBER_TYPE_FLAG, B.CHAMBER_GRP_ID,B.SUBRES_LOCATION, B.DELETE_FLAG,
                    B.SUBRES_UP_DOWN_FLAG, B.SUBRES_PRI_STS, B.SUBRES_STS_1, B.SUBRES_STS_2, B.SUBRES_STS_3, B.SUBRES_STS_4, B.SUBRES_STS_5, B.SUBRES_STS_6,
                    B.SUBRES_STS_7, B.SUBRES_STS_8, B.SUBRES_STS_9, B.SUBRES_STS_10, B.LOT_ID, B.SUBLOT_ID, B.CRR_ID, B.LAST_EVENT_ID, B.LAST_EVENT_TIME,
                    B.LAST_ACTIVE_HIST_SEQ, B.LAST_HIST_SEQ, A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME, A.NO_MOUSE_EVENT, A.SIGNAL_FLAG,A.ANGLE,A.RES_SHAPE
                FROM MFMBRESLOC A, MRASSRSDEF B 
                WHERE A.FACTORY = :SRSDETAIL_N.FACTORY 
                    AND LAYOUT_ID =  :SRSDETAIL_N.LAYOUT_ID
                    AND A.FACTORY = B.FACTORY 
                    AND A.RES_ID = B.SUBRES_ID
                    AND A.MOTHER_RES_ID = B.RES_ID
                    AND A.RES_TYPE = 'S'
                    AND B.DELETE_FLAG <> 'Y'
                    AND A.SEQ >= :SRSDETAIL_N.SEQ 
                ORDER BY A.SEQ;
            EXEC SQL OPEN DBC_SRSDETAIL_CUR_1;
            break;
            
        case 2:
             EXEC SQL DECLARE DBC_SRSDETAIL_CUR_2 CURSOR FOR 
                SELECT A.FACTORY, B.RES_ID, A.RES_TYPE, B.SUBRES_ID, B.SUBRES_DESC, B.SUBRES_TYPE, A.LAYOUT_ID, A.SEQ,
                    A.LOC_X, A.LOC_Y, A.LOC_WIDTH, A.LOC_HEIGHT, A.TEXT, A.TEXT_SIZE, A.TEXT_COLOR, A.TEXT_STYLE,
                    A.TAG_TYPE, A.BACK_COLOR, B.USE_FAC_PRT_FLAG, B.RES_STS_PRT_1, B.RES_STS_PRT_2, B.RES_STS_PRT_3,
                    B.RES_STS_PRT_4, B.RES_STS_PRT_5, B.RES_STS_PRT_6, B.RES_STS_PRT_7, B.RES_STS_PRT_8, B.RES_STS_PRT_9,
                    B.RES_STS_PRT_10, B.SUBRES_CMF_1, B.SUBRES_CMF_2, B.SUBRES_CMF_3, B.SUBRES_CMF_4, B.SUBRES_CMF_5, B.SUBRES_CMF_6,
                    B.SUBRES_CMF_7, B.SUBRES_CMF_8, B.SUBRES_CMF_9, B.SUBRES_CMF_10, B.SUBRES_CMF_11, B.SUBRES_CMF_12, B.SUBRES_CMF_13,
                    B.SUBRES_CMF_14, B.SUBRES_CMF_15, B.SUBRES_CMF_16, B.SUBRES_CMF_17, B.SUBRES_CMF_18, B.SUBRES_CMF_19, B.SUBRES_CMF_20, B.CHAMBER_TYPE_FLAG, B.CHAMBER_GRP_ID, B.SUBRES_LOCATION, B.DELETE_FLAG, 
                    B.SUBRES_UP_DOWN_FLAG, B.SUBRES_PRI_STS, B.SUBRES_STS_1, B.SUBRES_STS_2, B.SUBRES_STS_3, B.SUBRES_STS_4, B.SUBRES_STS_5, B.SUBRES_STS_6,
                    B.SUBRES_STS_7, B.SUBRES_STS_8, B.SUBRES_STS_9, B.SUBRES_STS_10, B.LOT_ID, B.SUBLOT_ID, B.CRR_ID, B.LAST_EVENT_ID, B.LAST_EVENT_TIME,
                    B.LAST_ACTIVE_HIST_SEQ, B.LAST_HIST_SEQ, A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME, A.NO_MOUSE_EVENT, A.SIGNAL_FLAG,A.ANGLE,A.RES_SHAPE
                FROM MFMBRESLOC A, MRASSRSDEF B 
                WHERE A.FACTORY = :SRSDETAIL_N.FACTORY 
                    AND LAYOUT_ID =  :SRSDETAIL_N.LAYOUT_ID
                    AND A.FACTORY = B.FACTORY 
                    AND A.RES_ID = B.SUBRES_ID
                    AND A.MOTHER_RES_ID = B.RES_ID
                    AND A.RES_TYPE = 'S'
                    AND B.DELETE_FLAG <> 'Y'
                    AND A.SEQ <= :SRSDETAIL_N.SEQ 
                ORDER BY A.SEQ DESC;
            EXEC SQL OPEN DBC_SRSDETAIL_CUR_2;
            
        break;    
         

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_srsdetail", sel_type);
}

/* SQL CURSOR FETCH Function */
void DBC_fetch_srsdetail(int sel_type, struct SRSDETAIL_TAG *SRSDETAIL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct SRSDETAIL_N_TAG SRSDETAIL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_SRSDETAIL_CUR_1 INTO 
                :SRSDETAIL_N.FACTORY,
                :SRSDETAIL_N.RES_ID,
                :SRSDETAIL_N.RES_TYPE,
                :SRSDETAIL_N.SUBRES_ID,
                :SRSDETAIL_N.SUBRES_DESC,
                :SRSDETAIL_N.SUBRES_TYPE,
                :SRSDETAIL_N.LAYOUT_ID,
                :SRSDETAIL_N.SEQ,
                :SRSDETAIL_N.LOC_X,
                :SRSDETAIL_N.LOC_Y,
                :SRSDETAIL_N.LOC_WIDTH,
                :SRSDETAIL_N.LOC_HEIGHT,
                :SRSDETAIL_N.TEXT,
                :SRSDETAIL_N.TEXT_SIZE,
                :SRSDETAIL_N.TEXT_COLOR,
                :SRSDETAIL_N.TEXT_STYLE,
                :SRSDETAIL_N.TAG_TYPE,
                :SRSDETAIL_N.BACK_COLOR,
                :SRSDETAIL_N.USE_FAC_PRT_FLAG,
                :SRSDETAIL_N.RES_STS_PRT_1,
                :SRSDETAIL_N.RES_STS_PRT_2,
                :SRSDETAIL_N.RES_STS_PRT_3,
                :SRSDETAIL_N.RES_STS_PRT_4,
                :SRSDETAIL_N.RES_STS_PRT_5,
                :SRSDETAIL_N.RES_STS_PRT_6,
                :SRSDETAIL_N.RES_STS_PRT_7,
                :SRSDETAIL_N.RES_STS_PRT_8,
                :SRSDETAIL_N.RES_STS_PRT_9,
                :SRSDETAIL_N.RES_STS_PRT_10,
                :SRSDETAIL_N.SUBRES_CMF_1,
                :SRSDETAIL_N.SUBRES_CMF_2,
                :SRSDETAIL_N.SUBRES_CMF_3,
                :SRSDETAIL_N.SUBRES_CMF_4,
                :SRSDETAIL_N.SUBRES_CMF_5,
                :SRSDETAIL_N.SUBRES_CMF_6,
