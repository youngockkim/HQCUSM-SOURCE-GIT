    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_UDRLOC_LIST_CUR_1 CURSOR FOR 
                SELECT RES_ID, RES_DESC, ATTACHED, RES_UP_DOWN_FLAG 
                FROM (
                    SELECT A.RES_ID, A.RES_DESC, 'Y' ATTACHED, A.RES_UP_DOWN_FLAG 
                    FROM MRASRESDEF A, MFMBUDRLOC B 
                    WHERE A.FACTORY = :UDRLOC_LIST_N.FACTORY 
                        AND A.FACTORY = B.FACTORY 
                        AND B.GROUP_ID = :UDRLOC_LIST_N.GROUP_ID 
                        AND A.RES_ID = B.RES_ID
                        AND B.RES_TYPE = 'R'
                    UNION
                    SELECT RES_ID, RES_DESC, 'N' ATTACHED, RES_UP_DOWN_FLAG 
