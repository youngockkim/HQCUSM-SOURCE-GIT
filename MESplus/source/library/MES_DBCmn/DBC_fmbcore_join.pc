    MEMCPY_DN(POTDETAIL->CRR_ID, POTDETAIL_N->CRR_ID, sizeof(POTDETAIL->CRR_ID));
    POTDETAIL->BCR_STATUS_FLAG = POTDETAIL_N->BCR_STATUS_FLAG[0];
