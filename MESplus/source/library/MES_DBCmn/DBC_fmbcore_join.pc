/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_udtdetail(int sel_type, struct UDTDETAIL_TAG *UDTDETAIL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct UDTDETAIL_N_TAG UDTDETAIL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_udtdetail(&UDTDETAIL_N, UDTDETAIL);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_UDTDETAIL_CUR_1 CURSOR FOR 
                SELECT A.FACTORY , B.RES_ID, A.RES_TYPE, B.TOOL_TYPE, A.GROUP_ID, A.SEQ, A.LOC_X, A.LOC_Y, A.LOC_WIDTH, A.LOC_HEIGHT, A.TEXT, 
                    A.TEXT_SIZE, A.TEXT_COLOR, A.TEXT_STYLE,A.TAG_TYPE, A.BACK_COLOR, A.NO_MOUSE_EVENT,
                    A.SIGNAL_FLAG, A.ANGLE,A.RES_SHAPE, B.TOOL_ID, B.TOOL_GRP, B.TOOL_SET_ID, B.TOOL_SET_LOCATION, B.TOOL_STATUS, B.LOT_ID, B.SUBLOT_ID,
                    B.MAT_ID, B.MAT_VER, B.FLOW, B.OPER, B.AREA_ID, B.SUB_AREA_ID, B.TOOL_LOCATION, B.VENDOR_ID, B.VENDOR_TOOL_ID,
                    B.CELL_COUNT_X, B.CELL_COUNT_Y, B.CELL_COUNT_Z, B.CELL_SIZE_X, B.CELL_SIZE_Y, B.CELL_SIZE_Z, B.GRADE, B.TOOL_STS_1, B.TOOL_STS_2,
                    B.TOOL_STS_3, B.TOOL_STS_4, B.TOOL_STS_5, B.TOOL_STS_6, B.TOOL_STS_7, B.TOOL_STS_8, B.TOOL_STS_9, B.TOOL_STS_10,B.TOOL_STS_11,
                    B.TOOL_STS_12,B.TOOL_STS_13, B.TOOL_STS_14,B.TOOL_STS_15,B.TOOL_STS_16,B.TOOL_STS_17,B.TOOL_STS_18,B.TOOL_STS_19,B.TOOL_STS_20,B.TOOL_STS_21,
                    B.TOOL_STS_22, B.TOOL_STS_23,B.TOOL_STS_24,B.TOOL_STS_25,B.TOOL_STS_26,B.TOOL_STS_27,B.TOOL_STS_28,B.TOOL_STS_29,
                    B.TOOL_STS_30, B.LAST_HIST_SEQ, B.LAST_ACTIVE_HIST_SEQ, B.LAST_TOOL_EVENT_ID, B.LAST_TRAN_TIME, B.DELETE_FLAG, B.TOOL_COMMENT,
                    A.CREATE_TIME, A.UPDATE_TIME
                FROM MFMBUDRLOC A, MRASTOLDEF B 
                WHERE A.FACTORY = :UDTDETAIL_N.FACTORY 
                    AND A.GROUP_ID =  :UDTDETAIL_N.GROUP_ID
                    AND A.FACTORY = B.FACTORY 
                    AND A.RES_ID = B.TOOL_ID
                    AND A.RES_TYPE = 'L'
                    AND B.DELETE_FLAG <> 'Y'
                    AND A.SEQ >= :UDTDETAIL_N.SEQ 
                ORDER BY A.SEQ;
            EXEC SQL OPEN DBC_UDTDETAIL_CUR_1;
            break;
            
        case 2:
             EXEC SQL DECLARE DBC_UDTDETAIL_CUR_2 CURSOR FOR 
                SELECT A.FACTORY, B.RES_ID, A.RES_TYPE, B.TOOL_TYPE, A.GROUP_ID, A.SEQ, A.LOC_X, A.LOC_Y, A.LOC_WIDTH, A.LOC_HEIGHT, A.TEXT, 
                    A.TEXT_SIZE, A.TEXT_COLOR, A.TEXT_STYLE,A.TAG_TYPE, A.BACK_COLOR, A.NO_MOUSE_EVENT,
                    A.SIGNAL_FLAG,A.ANGLE,A.RES_SHAPE, B.TOOL_ID, B.TOOL_GRP, B.TOOL_SET_ID, B.TOOL_SET_LOCATION, B.TOOL_STATUS, B.LOT_ID, B.SUBLOT_ID,
                    B.MAT_ID, B.MAT_VER, B.FLOW, B.OPER, B.AREA_ID, B.SUB_AREA_ID, B.TOOL_LOCATION, B.VENDOR_ID, B.VENDOR_TOOL_ID,
                    B.CELL_COUNT_X, B.CELL_COUNT_Y, B.CELL_COUNT_Z, B.CELL_SIZE_X, B.CELL_SIZE_Y, B.CELL_SIZE_Z, B.GRADE, B.TOOL_STS_1, B.TOOL_STS_2,
                    B.TOOL_STS_3, B.TOOL_STS_4, B.TOOL_STS_5, B.TOOL_STS_6, B.TOOL_STS_7, B.TOOL_STS_8, B.TOOL_STS_9, B.TOOL_STS_10,B.TOOL_STS_11,
                    B.TOOL_STS_12,B.TOOL_STS_13, B.TOOL_STS_14,B.TOOL_STS_15,B.TOOL_STS_16,B.TOOL_STS_17,B.TOOL_STS_18,B.TOOL_STS_19,B.TOOL_STS_20,B.TOOL_STS_21,
                    B.TOOL_STS_22, B.TOOL_STS_23,B.TOOL_STS_24,B.TOOL_STS_25,B.TOOL_STS_26,B.TOOL_STS_27,B.TOOL_STS_28,B.TOOL_STS_29,
                    B.TOOL_STS_30, B.LAST_HIST_SEQ, B.LAST_ACTIVE_HIST_SEQ, B.LAST_TOOL_EVENT_ID, B.LAST_TRAN_TIME, B.DELETE_FLAG, B.TOOL_COMMENT,
                    A.CREATE_TIME, A.UPDATE_TIME
                FROM MFMBUDRLOC A, MRASTOLDEF B 
                WHERE A.FACTORY = :UDTDETAIL_N.FACTORY 
                    AND A.GROUP_ID =  :UDTDETAIL_N.GROUP_ID
                    AND A.FACTORY = B.FACTORY 
                    AND A.RES_ID = B.TOOL_ID
                    AND A.RES_TYPE = 'L'
                    AND B.DELETE_FLAG <> 'Y'
                    AND A.SEQ <= :UDTDETAIL_N.SEQ 
                ORDER BY A.SEQ DESC;
            EXEC SQL OPEN DBC_UDTDETAIL_CUR_2;
            
        break;    
         

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_udtdetail", sel_type);
}

