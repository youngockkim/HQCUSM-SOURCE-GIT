        case 2:
            EXEC SQL DECLARE DBC_UDRLOC_LIST_CUR_2 CURSOR FOR 
                SELECT RES_ID, RES_DESC, RES_UP_DOWN_FLAG
                FROM MRASRESDEF
                WHERE FACTORY = :UDRLOC_LIST_N.FACTORY
