/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_resloc_list(int sel_type, struct RESLOC_LIST_TAG *RESLOC_LIST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RESLOC_LIST_N_TAG RESLOC_LIST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_resloc_list(&RESLOC_LIST_N, RESLOC_LIST);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_RESLOC_LIST_CUR_1 CURSOR FOR 
                SELECT RES_ID, RES_DESC, ATTACHED, LAYOUT_ID, RES_UP_DOWN_FLAG
                FROM (
                    SELECT A.RES_ID, A.RES_DESC, 'Y' ATTACHED, B.LAYOUT_ID LAYOUT_ID, A.RES_UP_DOWN_FLAG
                    FROM MRASRESDEF A, MFMBRESLOC B 
                    WHERE A.FACTORY = :RESLOC_LIST_N.FACTORY 
                        AND A.FACTORY = B.FACTORY 
                        AND A.RES_ID = B.RES_ID
                        AND B.RES_TYPE = 'R'
                    UNION
                    SELECT RES_ID, RES_DESC, 'N' ATTACHED, ' ' LAYOUT_ID, RES_UP_DOWN_FLAG
                    FROM MRASRESDEF 
                    WHERE FACTORY = :RESLOC_LIST_N.FACTORY 
                        AND DELETE_FLAG <> 'Y'
                        AND RES_ID NOT IN (SELECT RES_ID FROM MFMBRESLOC WHERE FACTORY = :RESLOC_LIST_N.FACTORY)
                    ) C
                WHERE RES_ID >= :RESLOC_LIST_N.RES_ID 
                ORDER BY RES_ID;

            EXEC SQL OPEN DBC_RESLOC_LIST_CUR_1;
            break;
   
        case 2:
            EXEC SQL DECLARE DBC_RESLOC_LIST_CUR_2 CURSOR FOR 
                SELECT RES_ID, RES_DESC, RES_UP_DOWN_FLAG
                FROM MRASRESDEF
                WHERE FACTORY = :RESLOC_LIST_N.FACTORY
                    AND DELETE_FLAG <> 'Y'
                    AND RES_ID NOT IN (SELECT RES_ID FROM MFMBRESLOC WHERE FACTORY = :RESLOC_LIST_N.FACTORY) 
                    AND RES_ID >= :RESLOC_LIST_N.RES_ID
                ORDER BY RES_ID;

            EXEC SQL OPEN DBC_RESLOC_LIST_CUR_2;
            break; 


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_resloc_list", sel_type);
}           

