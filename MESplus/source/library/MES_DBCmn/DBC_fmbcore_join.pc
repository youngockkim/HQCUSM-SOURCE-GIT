    RESINFO->SIGNAL_FLAG = RESINFO_N->SIGNAL_FLAG[0];
    MEMCPY_DN(RESINFO->MOTHER_RES_ID, RESINFO_N->MOTHER_RES_ID, sizeof(RESINFO->MOTHER_RES_ID));
    RESINFO->ANGLE = RESINFO_N->ANGLE;
    RESINFO->RES_SHAPE = RESINFO_N->RES_SHAPE[0];
    MEMCPY_DN(RESINFO->RES_DESC, RESINFO_N->RES_DESC, sizeof(RESINFO->RES_DESC));
    MEMCPY_DN(RESINFO->RES_TYPE, RESINFO_N->RES_TYPE, sizeof(RESINFO->RES_TYPE));
    MEMCPY_DN(RESINFO->RES_GRP_1, RESINFO_N->RES_GRP_1, sizeof(RESINFO->RES_GRP_1));
    MEMCPY_DN(RESINFO->RES_GRP_2, RESINFO_N->RES_GRP_2, sizeof(RESINFO->RES_GRP_2));
