/* Del Null Function */
void DBC_del_null_resinfo(struct RESINFO_N_TAG *RESINFO_N, struct RESINFO_TAG *RESINFO)
{
    MEMCPY_DN(RESINFO->FACTORY, RESINFO_N->FACTORY, sizeof(RESINFO->FACTORY));
    MEMCPY_DN(RESINFO->RES_ID, RESINFO_N->RES_ID, sizeof(RESINFO->RES_ID));
    RESINFO->RES_TAG_FLAG = RESINFO_N->RES_TAG_FLAG[0];
    MEMCPY_DN(RESINFO->LAYOUT_ID, RESINFO_N->LAYOUT_ID, sizeof(RESINFO->LAYOUT_ID));
    RESINFO->SEQ = RESINFO_N->SEQ;
    RESINFO->LOC_X = RESINFO_N->LOC_X;
    RESINFO->LOC_Y = RESINFO_N->LOC_Y;
    RESINFO->LOC_WIDTH = RESINFO_N->LOC_WIDTH;
    RESINFO->LOC_HEIGHT = RESINFO_N->LOC_HEIGHT;
    MEMCPY_DN(RESINFO->TEXT, RESINFO_N->TEXT, sizeof(RESINFO->TEXT));
    RESINFO->TEXT_SIZE = RESINFO_N->TEXT_SIZE;
    RESINFO->TEXT_COLOR = RESINFO_N->TEXT_COLOR;
    RESINFO->TEXT_STYLE = RESINFO_N->TEXT_STYLE[0];
    RESINFO->TAG_TYPE = RESINFO_N->TAG_TYPE;
    RESINFO->BACK_COLOR = RESINFO_N->BACK_COLOR;
    MEMCPY_DN(RESINFO->CREATE_USER_ID, RESINFO_N->CREATE_USER_ID, sizeof(RESINFO->CREATE_USER_ID));
    MEMCPY_DN(RESINFO->CREATE_TIME, RESINFO_N->CREATE_TIME, sizeof(RESINFO->CREATE_TIME));
    MEMCPY_DN(RESINFO->UPDATE_USER_ID, RESINFO_N->UPDATE_USER_ID, sizeof(RESINFO->UPDATE_USER_ID));
    MEMCPY_DN(RESINFO->UPDATE_TIME, RESINFO_N->UPDATE_TIME, sizeof(RESINFO->UPDATE_TIME));
