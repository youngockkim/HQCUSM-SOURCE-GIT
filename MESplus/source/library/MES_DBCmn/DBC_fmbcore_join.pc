/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_udsloc_list(int sel_type, struct UDSLOC_LIST_TAG *UDSLOC_LIST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct UDSLOC_LIST_N_TAG UDSLOC_LIST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_udsloc_list(&UDSLOC_LIST_N, UDSLOC_LIST);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_UDSLOC_LIST_CUR_1 CURSOR FOR 
                SELECT * FROM (SELECT A.RES_ID, A.SUBRES_ID, A.SUBRES_DESC, 'Y' ATTACHED, B.GROUP_ID GROUP_ID, A.SUBRES_UP_DOWN_FLAG
                FROM MRASSRSDEF A, MFMBUDRLOC B 
                WHERE
                A.FACTORY = :UDSLOC_LIST_N.FACTORY 
                AND A.FACTORY = B.FACTORY 
                AND B.GROUP_ID = :UDSLOC_LIST_N.GROUP_ID 
                AND A.SUBRES_ID = B.RES_ID
                AND B.RES_TYPE = 'S'
                UNION
                SELECT RES_ID, SUBRES_ID, SUBRES_DESC, 'N' ATTACHED, ' ' GROUP_ID, SUBRES_UP_DOWN_FLAG
                FROM MRASSRSDEF WHERE
                FACTORY = :UDSLOC_LIST_N.FACTORY
                AND DELETE_FLAG <> 'Y'
                AND (SUBRES_ID,RES_ID) NOT IN (SELECT RES_ID,MOTHER_RES_ID FROM MFMBUDRLOC WHERE FACTORY = :UDSLOC_LIST_N.FACTORY AND GROUP_ID = :UDSLOC_LIST_N.GROUP_ID))
                WHERE SUBRES_ID >= :UDSLOC_LIST_N.SUBRES_ID 
                AND RES_ID = :UDSLOC_LIST_N.RES_ID 
                ORDER BY SUBRES_ID;
            EXEC SQL OPEN DBC_UDSLOC_LIST_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_UDSLOC_LIST_CUR_2 CURSOR FOR 
                SELECT SUBRES_ID, SUBRES_DESC, SUBRES_UP_DOWN_FLAG
                FROM MRASSRSDEF WHERE
                FACTORY = :UDSLOC_LIST_N.FACTORY
                AND DELETE_FLAG <> 'Y'
                AND (SUBRES_ID,RES_ID) NOT IN (SELECT RES_ID,MOTHER_RES_ID FROM MFMBUDRLOC WHERE FACTORY = :UDSLOC_LIST_N.FACTORY AND GROUP_ID = :UDSLOC_LIST_N.GROUP_ID)
                AND SUBRES_ID >= :UDSLOC_LIST_N.SUBRES_ID 
                ORDER BY SUBRES_ID;

            EXEC SQL OPEN DBC_UDSLOC_LIST_CUR_2;
            break; 
         
         case 3:
            EXEC SQL DECLARE DBC_UDSLOC_LIST_CUR_3 CURSOR FOR 
                SELECT DISTINCT A.RES_ID, B.RES_DESC, B.RES_UP_DOWN_FLAG
                FROM MRASSRSDEF A, MRASRESDEF B
                WHERE A.FACTORY = B.FACTORY
                    AND A.RES_ID = B.RES_ID
                    AND A.RES_ID IN (
                    SELECT RES_ID 
                    FROM (
                        SELECT A.RES_ID, 'Y' ATTACHED
                        FROM MRASSRSDEF A, MFMBUDRLOC B 
                        WHERE A.FACTORY = :UDSLOC_LIST_N.FACTORY 
                            AND B.GROUP_ID = :UDSLOC_LIST_N.GROUP_ID 
                            AND A.FACTORY = B.FACTORY 
                            AND A.SUBRES_ID = B.RES_ID
                            AND B.RES_TYPE = 'S'
                        UNION
                        SELECT RES_ID, 'N' ATTACHED
                        FROM MRASSRSDEF 
                        WHERE FACTORY = :UDSLOC_LIST_N.FACTORY 
                            AND DELETE_FLAG <> 'Y'
                            AND (SUBRES_ID,RES_ID) NOT IN (
                                SELECT RES_ID, MOTHER_RES_ID 
                                FROM MFMBUDRLOC 
                                WHERE FACTORY = :UDSLOC_LIST_N.FACTORY 
                                    AND GROUP_ID = :UDSLOC_LIST_N.GROUP_ID
                                )
                        ) C
                    WHERE ATTACHED = 'N'
                    )
                ORDER BY A.RES_ID;
            EXEC SQL OPEN DBC_UDSLOC_LIST_CUR_3;
            break;             
             

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_udsloc_list", sel_type);
}           

/* SQL CURSOR FETCH Function */
void DBC_fetch_udsloc_list(int sel_type, struct UDSLOC_LIST_TAG *UDSLOC_LIST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct UDSLOC_LIST_N_TAG UDSLOC_LIST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_UDSLOC_LIST_CUR_1 INTO 
                :UDSLOC_LIST_N.RES_ID,
                :UDSLOC_LIST_N.SUBRES_ID,
                :UDSLOC_LIST_N.SUBRES_DESC,
                :UDSLOC_LIST_N.ATTACHED_FLAG,
                :UDSLOC_LIST_N.GROUP_ID,
                :UDSLOC_LIST_N.SUBRES_UP_DOWN_FLAG;
            break;
        
        case 2:
            EXEC SQL FETCH DBC_UDSLOC_LIST_CUR_2 INTO 
                :UDSLOC_LIST_N.SUBRES_ID,
                :UDSLOC_LIST_N.SUBRES_DESC,
                :UDSLOC_LIST_N.SUBRES_UP_DOWN_FLAG;
            break;            
            
        case 3:
            EXEC SQL FETCH DBC_UDSLOC_LIST_CUR_3 INTO 
                :UDSLOC_LIST_N.RES_ID,
                :UDSLOC_LIST_N.RES_DESC,
                :UDSLOC_LIST_N.RES_UP_DOWN_FLAG;
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    if(DB_error_code == 0)
    {
        DBC_del_null_udsloc_list(&UDSLOC_LIST_N, UDSLOC_LIST);
    }
    DB_stop_query_timer("DBC_fetch_udsloc_list", sel_type);
}

/* SQL CURSOR CLOSE Function */
void DBC_close_udsloc_list(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_UDSLOC_LIST_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_UDSLOC_LIST_CUR_2;
            break;
       
        case 3:
            EXEC SQL CLOSE DBC_UDSLOC_LIST_CUR_3;
            break;    
      

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_udsloc_list", sel_type);
}

/* Initialize Function */
void DBC_init_udsloc_list(struct UDSLOC_LIST_TAG *UDSLOC_LIST)
{
    /* memset by Space */
    memset(UDSLOC_LIST, ' ', sizeof(struct UDSLOC_LIST_TAG));

}

/* Add Null Function */
void DBC_add_null_udsloc_list(struct UDSLOC_LIST_N_TAG *UDSLOC_LIST_N, struct UDSLOC_LIST_TAG *UDSLOC_LIST)
{ 
    /* memset by NULL */
    memset(UDSLOC_LIST_N, '\0', sizeof(struct UDSLOC_LIST_N_TAG));

    MEMCPY_AN(UDSLOC_LIST_N->FACTORY ,UDSLOC_LIST->FACTORY ,sizeof(UDSLOC_LIST->FACTORY ));
    MEMCPY_AN(UDSLOC_LIST_N->RES_ID ,UDSLOC_LIST->RES_ID ,sizeof(UDSLOC_LIST->RES_ID ));
    MEMCPY_AN(UDSLOC_LIST_N->MOTHER_RES_ID ,UDSLOC_LIST->MOTHER_RES_ID ,sizeof(UDSLOC_LIST->MOTHER_RES_ID ));
    MEMCPY_AN(UDSLOC_LIST_N->RES_DESC ,UDSLOC_LIST->RES_DESC,sizeof(UDSLOC_LIST->RES_DESC));
    MEMCPY_AN(UDSLOC_LIST_N->SUBRES_ID ,UDSLOC_LIST->SUBRES_ID ,sizeof(UDSLOC_LIST->SUBRES_ID ));
    MEMCPY_AN(UDSLOC_LIST_N->SUBRES_DESC ,UDSLOC_LIST->SUBRES_DESC,sizeof(UDSLOC_LIST->SUBRES_DESC));
    UDSLOC_LIST_N->ATTACHED_FLAG[0]= UDSLOC_LIST->ATTACHED_FLAG;
    MEMCPY_AN(UDSLOC_LIST_N->GROUP_ID ,UDSLOC_LIST->GROUP_ID,sizeof(UDSLOC_LIST->GROUP_ID));
    UDSLOC_LIST_N->RES_UP_DOWN_FLAG[0]= UDSLOC_LIST->RES_UP_DOWN_FLAG;
    UDSLOC_LIST_N->SUBRES_UP_DOWN_FLAG[0]= UDSLOC_LIST->SUBRES_UP_DOWN_FLAG;
}


/* Del Null Function */
void DBC_del_null_udsloc_list(struct UDSLOC_LIST_N_TAG *UDSLOC_LIST_N, struct UDSLOC_LIST_TAG *UDSLOC_LIST)
{
    MEMCPY_DN(UDSLOC_LIST->FACTORY ,UDSLOC_LIST_N->FACTORY ,sizeof(UDSLOC_LIST->FACTORY ));
    MEMCPY_DN(UDSLOC_LIST->RES_ID ,UDSLOC_LIST_N->RES_ID ,sizeof(UDSLOC_LIST->RES_ID ));
    MEMCPY_DN(UDSLOC_LIST->MOTHER_RES_ID ,UDSLOC_LIST_N->MOTHER_RES_ID ,sizeof(UDSLOC_LIST->MOTHER_RES_ID ));
    MEMCPY_DN(UDSLOC_LIST->RES_DESC ,UDSLOC_LIST_N->RES_DESC,sizeof(UDSLOC_LIST->RES_DESC));
    MEMCPY_DN(UDSLOC_LIST->SUBRES_ID ,UDSLOC_LIST_N->SUBRES_ID ,sizeof(UDSLOC_LIST->SUBRES_ID ));
    MEMCPY_DN(UDSLOC_LIST->SUBRES_DESC ,UDSLOC_LIST_N->SUBRES_DESC,sizeof(UDSLOC_LIST->SUBRES_DESC));
    UDSLOC_LIST->ATTACHED_FLAG = UDSLOC_LIST_N->ATTACHED_FLAG[0];
    MEMCPY_DN(UDSLOC_LIST->GROUP_ID ,UDSLOC_LIST_N->GROUP_ID,sizeof(UDSLOC_LIST->GROUP_ID));
    UDSLOC_LIST->RES_UP_DOWN_FLAG = UDSLOC_LIST_N->RES_UP_DOWN_FLAG[0];
    UDSLOC_LIST->SUBRES_UP_DOWN_FLAG = UDSLOC_LIST_N->SUBRES_UP_DOWN_FLAG[0];
}               

/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_udtloc_list(int sel_type, struct UDTLOC_LIST_TAG *UDTLOC_LIST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct UDTLOC_LIST_N_TAG UDTLOC_LIST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_udtloc_list(&UDTLOC_LIST_N, UDTLOC_LIST);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_UDTLOC_LIST_CUR_1 CURSOR FOR 
                SELECT * FROM (SELECT A.TOOL_ID, A.TOOL_DESC, 'Y' ATTACHED
                FROM MRASTOLDEF A, MFMBUDRLOC B 
                WHERE
                A.FACTORY = :UDTLOC_LIST_N.FACTORY 
                AND A.FACTORY = B.FACTORY 
                AND B.GROUP_ID = :UDTLOC_LIST_N.GROUP_ID 
                AND A.TOOL_ID = B.RES_ID
                AND B.RES_TYPE = 'L'
                UNION
                SELECT TOOL_ID, TOOL_DESC, 'N' ATTACHED
                FROM MRASTOLDEF WHERE
                FACTORY = :UDTLOC_LIST_N.FACTORY
                AND DELETE_FLAG <> 'Y'
                AND TOOL_ID NOT IN (SELECT RES_ID FROM MFMBUDRLOC WHERE FACTORY = :UDTLOC_LIST_N.FACTORY AND GROUP_ID = :UDTLOC_LIST_N.GROUP_ID))
                WHERE TOOL_ID >= :UDTLOC_LIST_N.TOOL_ID 
                ORDER BY TOOL_ID;

            EXEC SQL OPEN DBC_UDTLOC_LIST_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_UDTLOC_LIST_CUR_2 CURSOR FOR 
                SELECT TOOL_ID, TOOL_DESC
                FROM MRASTOLDEF WHERE
                FACTORY = :UDTLOC_LIST_N.FACTORY
                AND DELETE_FLAG <> 'Y'
                AND TOOL_ID NOT IN (SELECT RES_ID FROM MFMBUDRLOC WHERE FACTORY = :UDTLOC_LIST_N.FACTORY AND GROUP_ID = :UDTLOC_LIST_N.GROUP_ID)
                AND TOOL_ID >= :UDTLOC_LIST_N.TOOL_ID 
                ORDER BY TOOL_ID;

            EXEC SQL OPEN DBC_UDTLOC_LIST_CUR_2;
            break; 


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_udtloc_list", sel_type);
}           

/* SQL CURSOR FETCH Function */
void DBC_fetch_udtloc_list(int sel_type, struct UDTLOC_LIST_TAG *UDTLOC_LIST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct UDTLOC_LIST_N_TAG UDTLOC_LIST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_UDTLOC_LIST_CUR_1 INTO 
                :UDTLOC_LIST_N.TOOL_ID,
                :UDTLOC_LIST_N.TOOL_DESC,
                :UDTLOC_LIST_N.ATTACHED_FLAG;
            break;
        
        case 2:
            EXEC SQL FETCH DBC_UDTLOC_LIST_CUR_2 INTO 
                :UDTLOC_LIST_N.TOOL_ID,
                :UDTLOC_LIST_N.TOOL_DESC;
            break;            
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    if(DB_error_code == 0)
    {
        DBC_del_null_udtloc_list(&UDTLOC_LIST_N, UDTLOC_LIST);
    }
    DB_stop_query_timer("DBC_fetch_udtloc_list", sel_type);
}

/* SQL CURSOR CLOSE Function */
void DBC_close_udtloc_list(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_UDTLOC_LIST_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_UDTLOC_LIST_CUR_2;
            break;
       

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_udtloc_list", sel_type);
}

/* Initialize Function */
void DBC_init_udtloc_list(struct UDTLOC_LIST_TAG *UDTLOC_LIST)
{
    /* memset by Space */
    memset(UDTLOC_LIST, ' ', sizeof(struct UDTLOC_LIST_TAG));

}

/* Add Null Function */
void DBC_add_null_udtloc_list(struct UDTLOC_LIST_N_TAG *UDTLOC_LIST_N, struct UDTLOC_LIST_TAG *UDTLOC_LIST)
{ 
    /* memset by NULL */
    memset(UDTLOC_LIST_N, '\0', sizeof(struct UDTLOC_LIST_N_TAG));

    MEMCPY_AN(UDTLOC_LIST_N->FACTORY ,UDTLOC_LIST->FACTORY ,sizeof(UDTLOC_LIST->FACTORY ));
    MEMCPY_AN(UDTLOC_LIST_N->GROUP_ID ,UDTLOC_LIST->GROUP_ID ,sizeof(UDTLOC_LIST->GROUP_ID ));
    MEMCPY_AN(UDTLOC_LIST_N->TOOL_ID ,UDTLOC_LIST->TOOL_ID ,sizeof(UDTLOC_LIST->TOOL_ID ));
    MEMCPY_AN(UDTLOC_LIST_N->TOOL_DESC ,UDTLOC_LIST->TOOL_DESC,sizeof(UDTLOC_LIST->TOOL_DESC));
    UDTLOC_LIST_N->ATTACHED_FLAG[0]= UDTLOC_LIST->ATTACHED_FLAG;
}


/* Del Null Function */
void DBC_del_null_udtloc_list(struct UDTLOC_LIST_N_TAG *UDTLOC_LIST_N, struct UDTLOC_LIST_TAG *UDTLOC_LIST)
{
    MEMCPY_DN(UDTLOC_LIST->FACTORY ,UDTLOC_LIST_N->FACTORY ,sizeof(UDTLOC_LIST->FACTORY ));
    MEMCPY_DN(UDTLOC_LIST->GROUP_ID ,UDTLOC_LIST_N->GROUP_ID ,sizeof(UDTLOC_LIST->GROUP_ID ));
    MEMCPY_DN(UDTLOC_LIST->TOOL_ID ,UDTLOC_LIST_N->TOOL_ID ,sizeof(UDTLOC_LIST->TOOL_ID ));
    MEMCPY_DN(UDTLOC_LIST->TOOL_DESC ,UDTLOC_LIST_N->TOOL_DESC,sizeof(UDTLOC_LIST->TOOL_DESC));
    UDTLOC_LIST->ATTACHED_FLAG = UDTLOC_LIST_N->ATTACHED_FLAG[0];
}
