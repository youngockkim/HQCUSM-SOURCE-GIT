    UDRDETAIL->ANGLE = UDRDETAIL_N->ANGLE;
    UDRDETAIL->RES_SHAPE = UDRDETAIL_N->RES_SHAPE[0];
}              

/* SQL SELECT Function */
void DBC_select_resinfo(int sel_type, struct RESINFO_TAG *RESINFO)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RESINFO_N_TAG RESINFO_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_resinfo(&RESINFO_N, RESINFO);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT A.FACTORY, A.RES_ID, A.RES_TYPE, A.LAYOUT_ID, A.SEQ, A.LOC_X, A.LOC_Y, A.LOC_WIDTH, A.LOC_HEIGHT, A.TEXT, A.TEXT_SIZE, A.TEXT_COLOR,
                    A.TEXT_STYLE, A.TAG_TYPE, A.BACK_COLOR, A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME, A.NO_MOUSE_EVENT, A.SIGNAL_FLAG,
                    A.MOTHER_RES_ID, A.ANGLE, A.RES_SHAPE,
                    B.RES_DESC, B.RES_TYPE, B.RES_GRP_1, B.RES_GRP_2, B.RES_GRP_3, B.RES_GRP_4, B.RES_GRP_5, 
                    B.RES_GRP_6, B.RES_GRP_7, B.RES_GRP_8, B.RES_GRP_9, B.RES_GRP_10, B.USE_FAC_PRT_FLAG, B.RES_STS_PRT_1, B.RES_STS_PRT_2,
                    B.RES_STS_PRT_3, B.RES_STS_PRT_4, B.RES_STS_PRT_5,B.RES_STS_PRT_6, B.RES_STS_PRT_7, B.RES_STS_PRT_8, B.RES_STS_PRT_9, 
                    B.RES_STS_PRT_10, B.RES_CMF_1, B.RES_CMF_2, B.RES_CMF_3, B.RES_CMF_4, B.RES_CMF_5,B.RES_CMF_6, B.RES_CMF_7, B.RES_CMF_8, 
                    B.RES_CMF_9, B.RES_CMF_10, B.AREA_ID,B.SUB_AREA_ID, B.RES_LOCATION, B.PROC_RULE, B.MAX_PROC_COUNT, B.BATCH_COND_1,
                    B.BATCH_COND_2, B.PM_SCH_ENABLE_FLAG, B.UNIT_BASE_ST_FLAG, B.SEC_CHK_FLAG, B.DELETE_FLAG, B.DELETE_USER_ID, B.DELETE_TIME,
                    B.CREATE_USER_ID, B.CREATE_TIME, B.UPDATE_USER_ID, B.UPDATE_TIME, B.RES_UP_DOWN_FLAG, 
                    B.RES_PRI_STS, B.RES_STS_1, B.RES_STS_2, B.RES_STS_3, B.RES_STS_4, B.RES_STS_5, B.RES_STS_6, B.RES_STS_7, B.RES_STS_8, 
                    B.RES_STS_9, B.RES_STS_10, B.LOT_ID, B.SUBLOT_ID, B.CRR_ID, B.RES_CTRL_MODE, B.RES_PROC_MODE, B.LAST_RECIPE_ID,B.PROC_COUNT, B.LAST_START_TIME, B.LAST_END_TIME, 
                    B.LAST_DOWN_TIME, B.LAST_DOWN_HIST_SEQ, B.LAST_EVENT_ID,B.LAST_EVENT_TIME, B.LAST_ACTIVE_HIST_SEQ, B.LAST_HIST_SEQ 
                INTO 
                    :RESINFO_N.FACTORY,
                    :RESINFO_N.RES_ID,
                    :RESINFO_N.RES_TAG_FLAG,
                    :RESINFO_N.LAYOUT_ID,
                    :RESINFO_N.SEQ,
                    :RESINFO_N.LOC_X,
                    :RESINFO_N.LOC_Y,
                    :RESINFO_N.LOC_WIDTH,
                    :RESINFO_N.LOC_HEIGHT,
                    :RESINFO_N.TEXT,
                    :RESINFO_N.TEXT_SIZE,
                    :RESINFO_N.TEXT_COLOR,
                    :RESINFO_N.TEXT_STYLE,
                    :RESINFO_N.TAG_TYPE,
                    :RESINFO_N.BACK_COLOR,
                    :RESINFO_N.CREATE_USER_ID,
                    :RESINFO_N.CREATE_TIME,
                    :RESINFO_N.UPDATE_USER_ID,
                    :RESINFO_N.UPDATE_TIME,
                    :RESINFO_N.NO_MOUSE_EVENT,
                    :RESINFO_N.SIGNAL_FLAG,
                    :RESINFO_N.MOTHER_RES_ID,
                    :RESINFO_N.ANGLE,
                    :RESINFO_N.RES_SHAPE,
                    :RESINFO_N.RES_DESC,
                    :RESINFO_N.RES_TYPE,
                    :RESINFO_N.RES_GRP_1,
                    :RESINFO_N.RES_GRP_2,
                    :RESINFO_N.RES_GRP_3,
                    :RESINFO_N.RES_GRP_4,
                    :RESINFO_N.RES_GRP_5,
                    :RESINFO_N.RES_GRP_6,
                    :RESINFO_N.RES_GRP_7,
                    :RESINFO_N.RES_GRP_8,
                    :RESINFO_N.RES_GRP_9,
                    :RESINFO_N.RES_GRP_10,
                    :RESINFO_N.USE_FAC_PRT_FLAG,
                    :RESINFO_N.RES_STS_PRT_1,
                    :RESINFO_N.RES_STS_PRT_2,
                    :RESINFO_N.RES_STS_PRT_3,
                    :RESINFO_N.RES_STS_PRT_4,
                    :RESINFO_N.RES_STS_PRT_5,
                    :RESINFO_N.RES_STS_PRT_6,
                    :RESINFO_N.RES_STS_PRT_7,
                    :RESINFO_N.RES_STS_PRT_8,
                    :RESINFO_N.RES_STS_PRT_9,
                    :RESINFO_N.RES_STS_PRT_10,
                    :RESINFO_N.RES_CMF_1,
                    :RESINFO_N.RES_CMF_2,
                    :RESINFO_N.RES_CMF_3,
                    :RESINFO_N.RES_CMF_4,
                    :RESINFO_N.RES_CMF_5,
                    :RESINFO_N.RES_CMF_6,
                    :RESINFO_N.RES_CMF_7,
                    :RESINFO_N.RES_CMF_8,
                    :RESINFO_N.RES_CMF_9,
                    :RESINFO_N.RES_CMF_10,
                    :RESINFO_N.AREA_ID,
                    :RESINFO_N.SUB_AREA_ID,
                    :RESINFO_N.RES_LOCATION,
                    :RESINFO_N.PROC_RULE,
                    :RESINFO_N.MAX_PROC_COUNT,
                    :RESINFO_N.BATCH_COND_1,
                    :RESINFO_N.BATCH_COND_2,
                    :RESINFO_N.PM_SCH_ENABLE_FLAG,
                    :RESINFO_N.UNIT_BASE_ST_FLAG,
                    :RESINFO_N.SEC_CHK_FLAG,
                    :RESINFO_N.DELETE_FLAG,
                    :RESINFO_N.DELETE_USER_ID,
                    :RESINFO_N.DELETE_TIME,
                    :RESINFO_N.RES_CREATE_USER_ID,
                    :RESINFO_N.RES_CREATE_TIME,
                    :RESINFO_N.RES_UPDATE_USER_ID,
                    :RESINFO_N.RES_UPDATE_TIME,
                    :RESINFO_N.RES_UP_DOWN_FLAG,
                    :RESINFO_N.RES_PRI_STS,
                    :RESINFO_N.RES_STS_1,
                    :RESINFO_N.RES_STS_2,
                    :RESINFO_N.RES_STS_3,
                    :RESINFO_N.RES_STS_4,
                    :RESINFO_N.RES_STS_5,
                    :RESINFO_N.RES_STS_6,
                    :RESINFO_N.RES_STS_7,
                    :RESINFO_N.RES_STS_8,
                    :RESINFO_N.RES_STS_9,
                    :RESINFO_N.RES_STS_10,
                    :RESINFO_N.LOT_ID,
                    :RESINFO_N.SUBLOT_ID,
                    :RESINFO_N.CRR_ID,
                    :RESINFO_N.RES_CTRL_MODE,
                    :RESINFO_N.RES_PROC_MODE,
                    :RESINFO_N.LAST_RECIPE_ID,
                    :RESINFO_N.PROC_COUNT,
                    :RESINFO_N.LAST_START_TIME,
                    :RESINFO_N.LAST_END_TIME,
                    :RESINFO_N.LAST_DOWN_TIME,
                    :RESINFO_N.LAST_DOWN_HIST_SEQ,
                    :RESINFO_N.LAST_EVENT_ID,
                    :RESINFO_N.LAST_EVENT_TIME,
                    :RESINFO_N.LAST_ACTIVE_HIST_SEQ,
                    :RESINFO_N.LAST_HIST_SEQ
                FROM MFMBRESLOC A, MRASRESDEF B
                WHERE A.FACTORY = :RESINFO_N.FACTORY
                    AND A.FACTORY = B.FACTORY
                    AND A.RES_ID = B.RES_ID
                    AND A.RES_ID = :RESINFO_N.RES_ID
                    AND A.RES_TYPE = 'R';
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_resinfo(&RESINFO_N, RESINFO);
    }
    DB_stop_query_timer("DBC_select_resinfo", sel_type);
}

/* Initialize Function */
void DBC_init_resinfo(struct RESINFO_TAG *RESINFO)
{
    /* memset by Space */
    memset(RESINFO, ' ', sizeof(struct RESINFO_TAG));
    RESINFO->LOC_X = 0;
    RESINFO->LOC_Y = 0;
    RESINFO->LOC_WIDTH = 0;
    RESINFO->LOC_HEIGHT = 0;
    RESINFO->TEXT_SIZE = 0;
    RESINFO->TEXT_COLOR = 0;
    RESINFO->TAG_TYPE = 0;
    RESINFO->BACK_COLOR = 0;   
    RESINFO->SEQ = 0; 
    RESINFO->MAX_PROC_COUNT = 0;
    RESINFO->PROC_COUNT = 0;
    RESINFO->LAST_DOWN_HIST_SEQ = 0;
    RESINFO->LAST_ACTIVE_HIST_SEQ = 0;
    RESINFO->LAST_HIST_SEQ = 0;
    RESINFO->ANGLE = 0;
}

/* Add Null Function */
void DBC_add_null_resinfo(struct RESINFO_N_TAG *RESINFO_N, struct RESINFO_TAG *RESINFO)
{ 
    /* memset by NULL */
    memset(RESINFO_N, '\0', sizeof(struct RESINFO_N_TAG));

    MEMCPY_AN(RESINFO_N->FACTORY, RESINFO->FACTORY, sizeof(RESINFO->FACTORY));
    MEMCPY_AN(RESINFO_N->RES_ID, RESINFO->RES_ID, sizeof(RESINFO->RES_ID));
    RESINFO_N->RES_TAG_FLAG[0] = RESINFO->RES_TAG_FLAG;
    MEMCPY_AN(RESINFO_N->LAYOUT_ID, RESINFO->LAYOUT_ID, sizeof(RESINFO->LAYOUT_ID));
    RESINFO_N->SEQ = RESINFO->SEQ;
    RESINFO_N->LOC_X = RESINFO->LOC_X;
    RESINFO_N->LOC_Y = RESINFO->LOC_Y;
    RESINFO_N->LOC_WIDTH = RESINFO->LOC_WIDTH;
    RESINFO_N->LOC_HEIGHT = RESINFO->LOC_HEIGHT;
    MEMCPY_AN(RESINFO_N->TEXT, RESINFO->TEXT, sizeof(RESINFO->TEXT));
    RESINFO_N->TEXT_SIZE = RESINFO->TEXT_SIZE;
    RESINFO_N->TEXT_COLOR = RESINFO->TEXT_COLOR;
    RESINFO_N->TEXT_STYLE[0] = RESINFO->TEXT_STYLE;
    RESINFO_N->TAG_TYPE = RESINFO->TAG_TYPE;
