    RESLOC_LIST_N->UP_DOWN_FLAG[0]= RESLOC_LIST->UP_DOWN_FLAG;
}


/* Del Null Function */
void DBC_del_null_resloc_list(struct RESLOC_LIST_N_TAG *RESLOC_LIST_N, struct RESLOC_LIST_TAG *RESLOC_LIST)
{
