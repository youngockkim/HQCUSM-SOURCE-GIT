/* SQL CURSOR CLOSE Function */
void DBC_close_udpdetail(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_UDPDETAIL_CUR_1;
            break;
        
        case 2:
            EXEC SQL CLOSE DBC_UDPDETAIL_CUR_2;
            break;    
       

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_udpdetail", sel_type);
}

/* Initialize Function */
void DBC_init_udpdetail(struct UDPDETAIL_TAG *UDPDETAIL)
{
    /* memset by Space */
    memset(UDPDETAIL, ' ', sizeof(struct UDPDETAIL_TAG));
    UDPDETAIL->LOC_X = 0;
    UDPDETAIL->LOC_Y = 0;
    UDPDETAIL->LOC_WIDTH = 0;
    UDPDETAIL->LOC_HEIGHT = 0;
    UDPDETAIL->TEXT_SIZE = 0;
    UDPDETAIL->TEXT_COLOR = 0;
    UDPDETAIL->TAG_TYPE = 0;
    UDPDETAIL->BACK_COLOR = 0;  
    UDPDETAIL->SEQ = 0;  
    UDPDETAIL->LAST_HIST_SEQ = 0;
    UDPDETAIL->PORT_SEQ = 0;
    UDPDETAIL->ANGLE = 0;
}

/* Add Null Function */
void DBC_add_null_udpdetail(struct UDPDETAIL_N_TAG *UDPDETAIL_N, struct UDPDETAIL_TAG *UDPDETAIL)
{ 
    /* memset by NULL */
    memset(UDPDETAIL_N, '\0', sizeof(struct UDPDETAIL_N_TAG));

    MEMCPY_AN(UDPDETAIL_N->FACTORY, UDPDETAIL->FACTORY, sizeof(UDPDETAIL->FACTORY));
    MEMCPY_AN(UDPDETAIL_N->RES_ID, UDPDETAIL->RES_ID, sizeof(UDPDETAIL->RES_ID));
    UDPDETAIL_N->PORT_TYPE[0] = UDPDETAIL->PORT_TYPE;
    MEMCPY_AN(UDPDETAIL_N->SUBRES_ID, UDPDETAIL->SUBRES_ID, sizeof(UDPDETAIL->SUBRES_ID));
    MEMCPY_AN(UDPDETAIL_N->PORT_ID, UDPDETAIL->PORT_ID, sizeof(UDPDETAIL->PORT_ID));
    UDPDETAIL_N->PORT_SEQ = UDPDETAIL->PORT_SEQ;
    MEMCPY_AN(UDPDETAIL_N->GROUP_ID, UDPDETAIL->GROUP_ID, sizeof(UDPDETAIL->GROUP_ID));
    UDPDETAIL_N->SEQ = UDPDETAIL->SEQ;
    UDPDETAIL_N->LOC_X = UDPDETAIL->LOC_X;
    UDPDETAIL_N->LOC_Y = UDPDETAIL->LOC_Y;
    UDPDETAIL_N->LOC_WIDTH = UDPDETAIL->LOC_WIDTH;
    UDPDETAIL_N->LOC_HEIGHT = UDPDETAIL->LOC_HEIGHT;
    MEMCPY_AN(UDPDETAIL_N->TEXT, UDPDETAIL->TEXT, sizeof(UDPDETAIL->TEXT));
    UDPDETAIL_N->TEXT_SIZE = UDPDETAIL->TEXT_SIZE;
    UDPDETAIL_N->TEXT_COLOR = UDPDETAIL->TEXT_COLOR;
    UDPDETAIL_N->TEXT_STYLE[0] = UDPDETAIL->TEXT_STYLE;
    UDPDETAIL_N->TAG_TYPE = UDPDETAIL->TAG_TYPE;
    UDPDETAIL_N->BACK_COLOR = UDPDETAIL->BACK_COLOR;
    MEMCPY_AN(UDPDETAIL_N->PORT_DESC, UDPDETAIL->PORT_DESC, sizeof(UDPDETAIL->PORT_DESC));
    MEMCPY_AN(UDPDETAIL_N->PORT_STATUS, UDPDETAIL->PORT_STATUS, sizeof(UDPDETAIL->PORT_STATUS));
    MEMCPY_AN(UDPDETAIL_N->LOT_ID, UDPDETAIL->LOT_ID, sizeof(UDPDETAIL->LOT_ID));
    MEMCPY_AN(UDPDETAIL_N->CRR_ID, UDPDETAIL->CRR_ID, sizeof(UDPDETAIL->CRR_ID));
    UDPDETAIL_N->BCR_STATUS_FLAG[0] = UDPDETAIL->BCR_STATUS_FLAG;
    UDPDETAIL_N->PORT_TYPE[0] = UDPDETAIL->PORT_TYPE;
