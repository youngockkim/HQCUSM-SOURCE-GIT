    UDRINFO->PROC_COUNT = UDRINFO_N->PROC_COUNT;
    MEMCPY_DN(UDRINFO->LAST_START_TIME, UDRINFO_N->LAST_START_TIME, sizeof(UDRINFO->LAST_START_TIME));
    MEMCPY_DN(UDRINFO->LAST_END_TIME, UDRINFO_N->LAST_END_TIME, sizeof(UDRINFO->LAST_END_TIME));
    MEMCPY_DN(UDRINFO->LAST_DOWN_TIME, UDRINFO_N->LAST_DOWN_TIME, sizeof(UDRINFO->LAST_DOWN_TIME));
    UDRINFO->LAST_DOWN_HIST_SEQ = UDRINFO_N->LAST_DOWN_HIST_SEQ;
    MEMCPY_DN(UDRINFO->LAST_EVENT_ID, UDRINFO_N->LAST_EVENT_ID, sizeof(UDRINFO->LAST_EVENT_ID));
    MEMCPY_DN(UDRINFO->LAST_EVENT_TIME, UDRINFO_N->LAST_EVENT_TIME, sizeof(UDRINFO->LAST_EVENT_TIME));
    UDRINFO->LAST_ACTIVE_HIST_SEQ = UDRINFO_N->LAST_ACTIVE_HIST_SEQ;
    UDRINFO->LAST_HIST_SEQ = UDRINFO_N->LAST_HIST_SEQ;    
}              

/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_reslocdetail(int sel_type, struct RESLOCDETAIL_TAG *RESLOCDETAIL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RESLOCDETAIL_N_TAG RESLOCDETAIL_N;
        char   sql[5120];
        char   ts[100];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_reslocdetail(&RESLOCDETAIL_N, RESLOCDETAIL);
    DB_error_code = 0;
    
    memset( ts, 0x00, sizeof(ts));

    switch(sel_type)
    {
        case 1:
            sprintf(sql, "SELECT * FROM (SELECT ");
            sprintf(sql + strlen(sql), "A.FACTORY,A.RES_ID,A.RES_DESC,A.RES_TYPE,A.RES_GRP_1,A.RES_GRP_2,A.RES_GRP_3,A.RES_GRP_4,A.RES_GRP_5,A.RES_GRP_6,A.RES_GRP_7, ");
            sprintf(sql + strlen(sql), "A.RES_GRP_8,A.RES_GRP_9,A.RES_GRP_10,A.USE_FAC_PRT_FLAG,A.RES_STS_PRT_1,A.RES_STS_PRT_2,A.RES_STS_PRT_3,A.RES_STS_PRT_4,  ");
            sprintf(sql + strlen(sql), "A.RES_STS_PRT_5,A.RES_STS_PRT_6,A.RES_STS_PRT_7,A.RES_STS_PRT_8,A.RES_STS_PRT_9,A.RES_STS_PRT_10,A.RES_CMF_1,A.RES_CMF_2, ");
            sprintf(sql + strlen(sql), "A.RES_CMF_3,A.RES_CMF_4,A.RES_CMF_5,A.RES_CMF_6,A.RES_CMF_7,A.RES_CMF_8,A.RES_CMF_9,A.RES_CMF_10,A.RES_CMF_11,A.RES_CMF_12, ");
            sprintf(sql + strlen(sql), "A.RES_CMF_13,A.RES_CMF_14,A.RES_CMF_15,A.RES_CMF_16,A.RES_CMF_17,A.RES_CMF_18,A.RES_CMF_19,A.RES_CMF_20,A.AREA_ID,A.SUB_AREA_ID, ");
            sprintf(sql + strlen(sql), "A.RES_LOCATION,A.PROC_RULE,A.MAX_PROC_COUNT,A.BATCH_COND_1,A.BATCH_COND_2,A.PM_SCH_ENABLE_FLAG,A.UNIT_BASE_ST_FLAG,A.SEC_CHK_FLAG, ");
            sprintf(sql + strlen(sql), "A.GATHER_ALARM_FLAG,A.DELETE_FLAG,A.DELETE_USER_ID,A.DELETE_TIME,A.CREATE_USER_ID,A.CREATE_TIME,A.UPDATE_USER_ID,A.UPDATE_TIME, ");
            sprintf(sql + strlen(sql), "A.RES_UP_DOWN_FLAG,A.RES_PRI_STS,A.RES_STS_1,A.RES_STS_2,A.RES_STS_3,A.RES_STS_4,A.RES_STS_5,A.RES_STS_6,A.RES_STS_7,A.RES_STS_8, ");
            sprintf(sql + strlen(sql), "A.RES_STS_9,A.RES_STS_10,A.LOT_ID,A.SUBLOT_ID,A.CRR_ID,A.RES_CTRL_MODE,A.RES_PROC_MODE,A.LAST_RECIPE_ID,A.PROC_COUNT,A.LAST_START_TIME, ");
            sprintf(sql + strlen(sql), "A.LAST_END_TIME,A.LAST_DOWN_TIME,A.LAST_DOWN_HIST_SEQ,A.LAST_EVENT_ID,A.LAST_EVENT_TIME,A.LAST_ACTIVE_HIST_SEQ,A.LAST_HIST_SEQ, ");
            sprintf(sql + strlen(sql), "NVL(B.RES_TYPE, ' ') RES_TAG, NVL(B.LAYOUT_ID, ' '), NVL(B.SEQ, 0), NVL(B.LOC_X, 0), NVL(B.LOC_Y, 0), NVL(B.LOC_WIDTH, 0), NVL(B.LOC_HEIGHT, 0), ");
            sprintf(sql + strlen(sql), "NVL(B.TEXT, ' '), NVL(B.TEXT_SIZE, 0), NVL(B.TEXT_COLOR, 0), NVL(B.TEXT_STYLE, ' '), NVL(B.TAG_TYPE, 0), NVL(B.BACK_COLOR, 0), NVL(B.NO_MOUSE_EVENT, ' '), NVL(B.SIGNAL_FLAG, ' '),  NVL(B.ANGLE, 0),  NVL(B.RES_SHAPE, ' ') ");
            sprintf(sql + strlen(sql), "FROM MRASRESDEF A, MFMBRESLOC B WHERE ");
            
            make_valid_quote(ts, RESLOCDETAIL_N.FACTORY);
            
            sprintf(sql + strlen(sql), "A.FACTORY = '%s' ", ts);
            if(RESLOCDETAIL->DELETE_FLAG != 'Y')
            {
                sprintf(sql + strlen(sql), " AND A.DELETE_FLAG = ' '");
            }
            if(ISSPACE(RESLOCDETAIL->RES_TYPE, sizeof(RESLOCDETAIL->RES_TYPE)) == DB_FALSE)
            {
                make_valid_quote(ts, RESLOCDETAIL_N.RES_TYPE);
                sprintf(sql + strlen(sql), "AND A.RES_TYPE = '%s' ", ts);
            }
            if(ISSPACE(RESLOCDETAIL->AREA_ID, sizeof(RESLOCDETAIL->AREA_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, RESLOCDETAIL_N.AREA_ID);
                sprintf(sql + strlen(sql), "AND A.AREA_ID = '%s' ", ts);
            }
            if(ISSPACE(RESLOCDETAIL->SUB_AREA_ID, sizeof(RESLOCDETAIL->SUB_AREA_ID)) == DB_FALSE)
            {
                make_valid_quote(ts, RESLOCDETAIL_N.SUB_AREA_ID);
                sprintf(sql + strlen(sql), "AND A.SUB_AREA_ID = '%s' ", ts);
            }
            sprintf(sql + strlen(sql), " AND A.FACTORY = B.FACTORY(+) AND A.RES_ID = B.RES_ID(+)) ");
            make_valid_quote(ts, RESLOCDETAIL_N.RES_ID);
            sprintf(sql + strlen(sql), " WHERE RES_TAG <> 'T' AND RES_ID >= '%s' ",ts);
            sprintf(sql + strlen(sql), " ORDER BY RES_ID ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_RESLOCDETAIL_CUR_1 CURSOR FOR S; 
            EXEC SQL OPEN DBC_RESLOCDETAIL_CUR_1;                 
            break;
 

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_reslocdetail", sel_type);
}           

/* SQL CURSOR FETCH Function */
void DBC_fetch_reslocdetail(int sel_type, struct RESLOCDETAIL_TAG *RESLOCDETAIL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RESLOCDETAIL_N_TAG RESLOCDETAIL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_RESLOCDETAIL_CUR_1 INTO
                :RESLOCDETAIL_N.FACTORY,
                :RESLOCDETAIL_N.RES_ID,
                :RESLOCDETAIL_N.RES_DESC,
