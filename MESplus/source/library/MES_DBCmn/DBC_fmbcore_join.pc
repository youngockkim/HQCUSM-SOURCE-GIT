    MEMCPY_DN(RESDETAIL->CRR_ID, RESDETAIL_N->CRR_ID, sizeof(RESDETAIL->CRR_ID));
    MEMCPY_DN(RESDETAIL->RES_CTRL_MODE, RESDETAIL_N->RES_CTRL_MODE, sizeof(RESDETAIL->RES_CTRL_MODE));
    MEMCPY_DN(RESDETAIL->RES_PROC_MODE, RESDETAIL_N->RES_PROC_MODE, sizeof(RESDETAIL->RES_PROC_MODE));
    MEMCPY_DN(RESDETAIL->LAST_RECIPE_ID, RESDETAIL_N->LAST_RECIPE_ID, sizeof(RESDETAIL->LAST_RECIPE_ID));
    RESDETAIL->PROC_COUNT = RESDETAIL_N->PROC_COUNT;
