/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_udrdetail(int sel_type, struct UDRDETAIL_TAG *UDRDETAIL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct UDRDETAIL_N_TAG UDRDETAIL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_udrdetail(&UDRDETAIL_N, UDRDETAIL);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_UDRDETAIL_CUR_1 CURSOR FOR 
                SELECT A.FACTORY, A.GROUP_ID, A.RES_ID, A.RES_TYPE, A.SEQ, A.LOC_X, A.LOC_Y, A.LOC_WIDTH, A.LOC_HEIGHT, A.TEXT, A.TEXT_SIZE, A.TEXT_COLOR,
                    A.TEXT_STYLE, A.TAG_TYPE, A.BACK_COLOR, A.CREATE_TIME, A.UPDATE_TIME, A.NO_MOUSE_EVENT, A.SIGNAL_FLAG, A.MOTHER_RES_ID, A.ANGLE, A.RES_SHAPE,
                    B.RES_DESC, B.RES_TYPE, B.AREA_ID,B.SUB_AREA_ID, B.RES_LOCATION, B.PROC_RULE, B.MAX_PROC_COUNT, 
                    B.RES_UP_DOWN_FLAG, B.RES_PRI_STS, B.RES_STS_1, B.RES_STS_2, B.RES_STS_3, B.RES_STS_4, B.RES_STS_5, 
                    B.RES_STS_6, B.RES_STS_7, B.RES_STS_8, B.RES_STS_9, B.RES_STS_10, B.RES_CTRL_MODE, B.RES_PROC_MODE, B.LAST_RECIPE_ID, 
                    B.PROC_COUNT, B.LAST_START_TIME, B.LAST_END_TIME, B.LAST_DOWN_TIME, B.LAST_DOWN_HIST_SEQ, B.LAST_EVENT_ID,
                    B.LAST_EVENT_TIME, B.LAST_ACTIVE_HIST_SEQ, B.LAST_HIST_SEQ 
                FROM MFMBUDRLOC A, MRASRESDEF B 
                WHERE A.FACTORY = :UDRDETAIL_N.FACTORY 
                    AND A.GROUP_ID = :UDRDETAIL_N.GROUP_ID 
                    AND A.FACTORY = B.FACTORY 
                    AND A.RES_ID = B.RES_ID
                    AND A.RES_TYPE = 'R'
                    AND B.DELETE_FLAG <> 'Y'
                    AND A.SEQ >= :UDRDETAIL_N.SEQ 
                ORDER BY A.SEQ;

            EXEC SQL OPEN DBC_UDRDETAIL_CUR_1;
            break;

         case 2:
            EXEC SQL DECLARE DBC_UDRDETAIL_CUR_2 CURSOR FOR 
                SELECT * 
                FROM (
                    SELECT A.FACTORY, A.GROUP_ID, A.RES_ID, A.RES_TYPE, A.SEQ, A.LOC_X, A.LOC_Y, A.LOC_WIDTH, A.LOC_HEIGHT, A.TEXT, A.TEXT_SIZE, A.TEXT_COLOR,
                        A.TEXT_STYLE, A.TAG_TYPE, A.BACK_COLOR, A.CREATE_TIME, A.UPDATE_TIME, A.NO_MOUSE_EVENT, A.SIGNAL_FLAG, A.MOTHER_RES_ID, A.ANGLE, A.RES_SHAPE,
                        B.RES_DESC, B.RES_TYPE RTYPE, B.AREA_ID,B.SUB_AREA_ID, B.RES_LOCATION, B.PROC_RULE, B.MAX_PROC_COUNT, 
                        B.RES_UP_DOWN_FLAG, B.RES_PRI_STS, B.RES_STS_1, B.RES_STS_2, B.RES_STS_3, B.RES_STS_4, B.RES_STS_5, 
                        B.RES_STS_6, B.RES_STS_7, B.RES_STS_8, B.RES_STS_9, B.RES_STS_10, B.RES_CTRL_MODE, B.RES_PROC_MODE, B.LAST_RECIPE_ID, 
                        B.PROC_COUNT, B.LAST_START_TIME, B.LAST_END_TIME, B.LAST_DOWN_TIME, B.LAST_DOWN_HIST_SEQ, B.LAST_EVENT_ID,
                        B.LAST_EVENT_TIME, B.LAST_ACTIVE_HIST_SEQ, B.LAST_HIST_SEQ 
                    FROM MFMBUDRLOC A, MRASRESDEF B 
                    WHERE A.FACTORY = :UDRDETAIL_N.FACTORY 
                        AND A.GROUP_ID = :UDRDETAIL_N.GROUP_ID 
                        AND A.FACTORY = B.FACTORY 
                        AND A.RES_ID = B.RES_ID
                        AND A.RES_TYPE = 'R'
                        AND B.DELETE_FLAG <> 'Y'
                    UNION
                    SELECT A.FACTORY, A.GROUP_ID, A.RES_ID, A.RES_TYPE, A.SEQ, A.LOC_X, A.LOC_Y, A.LOC_WIDTH, A.LOC_HEIGHT, A.TEXT, A.TEXT_SIZE, A.TEXT_COLOR,
                        A.TEXT_STYLE, A.TAG_TYPE, A.BACK_COLOR, A.CREATE_TIME, A.UPDATE_TIME, A.NO_MOUSE_EVENT, A.SIGNAL_FLAG, A.MOTHER_RES_ID, A.ANGLE, A.RES_SHAPE,
                        ' ',' ',' ' RTYPE,' ',' ',' ',0,' ',' ',' ',' ',' ',' ',' ',' ',' ',' ',' ',' ',' ',' ',' ',0,' ',' ',' ',0,' ',' ',0,0
                    FROM MFMBUDRLOC A
                    WHERE A.FACTORY = :UDRDETAIL_N.FACTORY 
                        AND A.GROUP_ID = :UDRDETAIL_N.GROUP_ID 
                        AND A.RES_TYPE = 'T'
                    )
                WHERE SEQ <= :UDRDETAIL_N.SEQ 
                ORDER BY SEQ DESC;

            EXEC SQL OPEN DBC_UDRDETAIL_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_udrdetail", sel_type);
}           

/* SQL CURSOR FETCH Function */
void DBC_fetch_udrdetail(int sel_type, struct UDRDETAIL_TAG *UDRDETAIL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct UDRDETAIL_N_TAG UDRDETAIL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_UDRDETAIL_CUR_1 INTO 
                :UDRDETAIL_N.FACTORY,
                :UDRDETAIL_N.GROUP_ID,
                :UDRDETAIL_N.RES_ID,
                :UDRDETAIL_N.RES_TAG_FLAG,
                :UDRDETAIL_N.SEQ,
                :UDRDETAIL_N.LOC_X,
                :UDRDETAIL_N.LOC_Y,
                :UDRDETAIL_N.LOC_WIDTH,
                :UDRDETAIL_N.LOC_HEIGHT,
                :UDRDETAIL_N.TEXT,
                :UDRDETAIL_N.TEXT_SIZE,
                :UDRDETAIL_N.TEXT_COLOR,
                :UDRDETAIL_N.TEXT_STYLE,
                :UDRDETAIL_N.TAG_TYPE,
                :UDRDETAIL_N.BACK_COLOR,
                :UDRDETAIL_N.CREATE_TIME,
                :UDRDETAIL_N.UPDATE_TIME,
                :UDRDETAIL_N.NO_MOUSE_EVENT,
                :UDRDETAIL_N.SIGNAL_FLAG,                
                :UDRDETAIL_N.MOTHER_RES_ID,
                :UDRDETAIL_N.ANGLE,
                :UDRDETAIL_N.RES_SHAPE,
                :UDRDETAIL_N.RES_DESC,
                :UDRDETAIL_N.RES_TYPE,
                :UDRDETAIL_N.AREA_ID,
                :UDRDETAIL_N.SUB_AREA_ID,
                :UDRDETAIL_N.RES_LOCATION,
                :UDRDETAIL_N.PROC_RULE,
                :UDRDETAIL_N.MAX_PROC_COUNT,
                :UDRDETAIL_N.RES_UP_DOWN_FLAG,
                :UDRDETAIL_N.RES_PRI_STS,
                :UDRDETAIL_N.RES_STS_1,
                :UDRDETAIL_N.RES_STS_2,
                :UDRDETAIL_N.RES_STS_3,
                :UDRDETAIL_N.RES_STS_4,
                :UDRDETAIL_N.RES_STS_5,
                :UDRDETAIL_N.RES_STS_6,
                :UDRDETAIL_N.RES_STS_7,
                :UDRDETAIL_N.RES_STS_8,
                :UDRDETAIL_N.RES_STS_9,
                :UDRDETAIL_N.RES_STS_10,
                :UDRDETAIL_N.RES_CTRL_MODE,
                :UDRDETAIL_N.RES_PROC_MODE,
                :UDRDETAIL_N.LAST_RECIPE_ID,
                :UDRDETAIL_N.PROC_COUNT,
                :UDRDETAIL_N.LAST_START_TIME,
                :UDRDETAIL_N.LAST_END_TIME,
                :UDRDETAIL_N.LAST_DOWN_TIME,
                :UDRDETAIL_N.LAST_DOWN_HIST_SEQ,
                :UDRDETAIL_N.LAST_EVENT_ID,
                :UDRDETAIL_N.LAST_EVENT_TIME,
                :UDRDETAIL_N.LAST_ACTIVE_HIST_SEQ,
                :UDRDETAIL_N.LAST_HIST_SEQ;
            break;
        case 2:
            EXEC SQL FETCH DBC_UDRDETAIL_CUR_2 INTO 
                :UDRDETAIL_N.FACTORY,
                :UDRDETAIL_N.GROUP_ID,
                :UDRDETAIL_N.RES_ID,
                :UDRDETAIL_N.RES_TAG_FLAG,
                :UDRDETAIL_N.SEQ,
                :UDRDETAIL_N.LOC_X,
                :UDRDETAIL_N.LOC_Y,
                :UDRDETAIL_N.LOC_WIDTH,
                :UDRDETAIL_N.LOC_HEIGHT,
                :UDRDETAIL_N.TEXT,
                :UDRDETAIL_N.TEXT_SIZE,
                :UDRDETAIL_N.TEXT_COLOR,
                :UDRDETAIL_N.TEXT_STYLE,
                :UDRDETAIL_N.TAG_TYPE,
                :UDRDETAIL_N.BACK_COLOR,
                :UDRDETAIL_N.CREATE_TIME,
                :UDRDETAIL_N.UPDATE_TIME,
                :UDRDETAIL_N.NO_MOUSE_EVENT,
                :UDRDETAIL_N.SIGNAL_FLAG,
                :UDRDETAIL_N.MOTHER_RES_ID,
                :UDRDETAIL_N.ANGLE,
                :UDRDETAIL_N.RES_SHAPE,
                :UDRDETAIL_N.RES_DESC,
                :UDRDETAIL_N.RES_TYPE,
                :UDRDETAIL_N.AREA_ID,
                :UDRDETAIL_N.SUB_AREA_ID,
                :UDRDETAIL_N.RES_LOCATION,
                :UDRDETAIL_N.PROC_RULE,
                :UDRDETAIL_N.MAX_PROC_COUNT,
                :UDRDETAIL_N.RES_UP_DOWN_FLAG,
                :UDRDETAIL_N.RES_PRI_STS,
                :UDRDETAIL_N.RES_STS_1,
                :UDRDETAIL_N.RES_STS_2,
                :UDRDETAIL_N.RES_STS_3,
                :UDRDETAIL_N.RES_STS_4,
                :UDRDETAIL_N.RES_STS_5,
                :UDRDETAIL_N.RES_STS_6,
                :UDRDETAIL_N.RES_STS_7,
                :UDRDETAIL_N.RES_STS_8,
                :UDRDETAIL_N.RES_STS_9,
                :UDRDETAIL_N.RES_STS_10,
                :UDRDETAIL_N.RES_CTRL_MODE,
                :UDRDETAIL_N.RES_PROC_MODE,
                :UDRDETAIL_N.LAST_RECIPE_ID,
                :UDRDETAIL_N.PROC_COUNT,
                :UDRDETAIL_N.LAST_START_TIME,
                :UDRDETAIL_N.LAST_END_TIME,
                :UDRDETAIL_N.LAST_DOWN_TIME,
                :UDRDETAIL_N.LAST_DOWN_HIST_SEQ,
                :UDRDETAIL_N.LAST_EVENT_ID,
                :UDRDETAIL_N.LAST_EVENT_TIME,
                :UDRDETAIL_N.LAST_ACTIVE_HIST_SEQ,
                :UDRDETAIL_N.LAST_HIST_SEQ;
            break;
                        

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    if(DB_error_code == 0)
    {
        DBC_del_null_udrdetail(&UDRDETAIL_N, UDRDETAIL);
    }
    DB_stop_query_timer("DBC_fetch_udrdetail", sel_type);
}

/* SQL CURSOR CLOSE Function */
void DBC_close_udrdetail(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_UDRDETAIL_CUR_1;
            break;
        case 2:
            EXEC SQL CLOSE DBC_UDRDETAIL_CUR_2;
            break;    
       

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_udrdetail", sel_type);
}

/* Initialize Function */
void DBC_init_udrdetail(struct UDRDETAIL_TAG *UDRDETAIL)
{
    /* memset by Space */
    memset(UDRDETAIL, ' ', sizeof(struct UDRDETAIL_TAG));
    UDRDETAIL->LOC_X = 0;
    UDRDETAIL->LOC_Y = 0;
    UDRDETAIL->LOC_WIDTH = 0;
    UDRDETAIL->LOC_HEIGHT = 0;
    UDRDETAIL->TEXT_SIZE = 0;
    UDRDETAIL->TEXT_COLOR = 0;
    UDRDETAIL->TAG_TYPE = 0;
    UDRDETAIL->BACK_COLOR = 0;    
    UDRDETAIL->SEQ = 0;
    UDRDETAIL->MAX_PROC_COUNT = 0;
    UDRDETAIL->PROC_COUNT = 0;
    UDRDETAIL->LAST_DOWN_HIST_SEQ = 0;
    UDRDETAIL->LAST_ACTIVE_HIST_SEQ = 0;
    UDRDETAIL->LAST_HIST_SEQ = 0;
    UDRDETAIL->ANGLE = 0;
}

/* Add Null Function */
void DBC_add_null_udrdetail(struct UDRDETAIL_N_TAG *UDRDETAIL_N, struct UDRDETAIL_TAG *UDRDETAIL)
{ 
    /* memset by NULL */
    memset(UDRDETAIL_N, '\0', sizeof(struct UDRDETAIL_N_TAG));

    MEMCPY_AN(UDRDETAIL_N->FACTORY, UDRDETAIL->FACTORY, sizeof(UDRDETAIL->FACTORY));
    MEMCPY_AN(UDRDETAIL_N->GROUP_ID, UDRDETAIL->GROUP_ID, sizeof(UDRDETAIL->GROUP_ID));
    MEMCPY_AN(UDRDETAIL_N->RES_ID, UDRDETAIL->RES_ID, sizeof(UDRDETAIL->RES_ID));
    UDRDETAIL_N->RES_TAG_FLAG[0] = UDRDETAIL->RES_TAG_FLAG;
    UDRDETAIL_N->SEQ = UDRDETAIL->SEQ;
    UDRDETAIL_N->LOC_X = UDRDETAIL->LOC_X;
    UDRDETAIL_N->LOC_Y = UDRDETAIL->LOC_Y;
    UDRDETAIL_N->LOC_WIDTH = UDRDETAIL->LOC_WIDTH;
    UDRDETAIL_N->LOC_HEIGHT = UDRDETAIL->LOC_HEIGHT;
    MEMCPY_AN(UDRDETAIL_N->TEXT, UDRDETAIL->TEXT, sizeof(UDRDETAIL->TEXT));
    UDRDETAIL_N->TEXT_SIZE = UDRDETAIL->TEXT_SIZE;
    UDRDETAIL_N->TEXT_COLOR = UDRDETAIL->TEXT_COLOR;
    UDRDETAIL_N->TEXT_STYLE[0] = UDRDETAIL->TEXT_STYLE;
    UDRDETAIL_N->TAG_TYPE = UDRDETAIL->TAG_TYPE;
    UDRDETAIL_N->BACK_COLOR = UDRDETAIL->BACK_COLOR;
    MEMCPY_AN(UDRDETAIL_N->CREATE_TIME, UDRDETAIL->CREATE_TIME, sizeof(UDRDETAIL->CREATE_TIME));
    MEMCPY_AN(UDRDETAIL_N->UPDATE_TIME, UDRDETAIL->UPDATE_TIME, sizeof(UDRDETAIL->UPDATE_TIME));
    UDRDETAIL_N->NO_MOUSE_EVENT[0] = UDRDETAIL->NO_MOUSE_EVENT;
    UDRDETAIL_N->SIGNAL_FLAG[0] = UDRDETAIL->SIGNAL_FLAG;
    MEMCPY_AN(UDRDETAIL_N->MOTHER_RES_ID, UDRDETAIL->MOTHER_RES_ID, sizeof(UDRDETAIL->MOTHER_RES_ID));
    MEMCPY_AN(UDRDETAIL_N->RES_DESC, UDRDETAIL->RES_DESC, sizeof(UDRDETAIL->RES_DESC));
    MEMCPY_AN(UDRDETAIL_N->RES_TYPE, UDRDETAIL->RES_TYPE, sizeof(UDRDETAIL->RES_TYPE));
    MEMCPY_AN(UDRDETAIL_N->AREA_ID, UDRDETAIL->AREA_ID, sizeof(UDRDETAIL->AREA_ID));
    MEMCPY_AN(UDRDETAIL_N->SUB_AREA_ID, UDRDETAIL->SUB_AREA_ID, sizeof(UDRDETAIL->SUB_AREA_ID));
    MEMCPY_AN(UDRDETAIL_N->RES_LOCATION, UDRDETAIL->RES_LOCATION, sizeof(UDRDETAIL->RES_LOCATION));
    UDRDETAIL_N->PROC_RULE[0] = UDRDETAIL->PROC_RULE;
    UDRDETAIL_N->MAX_PROC_COUNT = UDRDETAIL->MAX_PROC_COUNT;
    UDRDETAIL_N->RES_UP_DOWN_FLAG[0] = UDRDETAIL->RES_UP_DOWN_FLAG;
    MEMCPY_AN(UDRDETAIL_N->RES_PRI_STS, UDRDETAIL->RES_PRI_STS, sizeof(UDRDETAIL->RES_PRI_STS));
    MEMCPY_AN(UDRDETAIL_N->RES_STS_1, UDRDETAIL->RES_STS_1, sizeof(UDRDETAIL->RES_STS_1));
    MEMCPY_AN(UDRDETAIL_N->RES_STS_2, UDRDETAIL->RES_STS_2, sizeof(UDRDETAIL->RES_STS_2));
    MEMCPY_AN(UDRDETAIL_N->RES_STS_3, UDRDETAIL->RES_STS_3, sizeof(UDRDETAIL->RES_STS_3));
    MEMCPY_AN(UDRDETAIL_N->RES_STS_4, UDRDETAIL->RES_STS_4, sizeof(UDRDETAIL->RES_STS_4));
    MEMCPY_AN(UDRDETAIL_N->RES_STS_5, UDRDETAIL->RES_STS_5, sizeof(UDRDETAIL->RES_STS_5));
    MEMCPY_AN(UDRDETAIL_N->RES_STS_6, UDRDETAIL->RES_STS_6, sizeof(UDRDETAIL->RES_STS_6));
    MEMCPY_AN(UDRDETAIL_N->RES_STS_7, UDRDETAIL->RES_STS_7, sizeof(UDRDETAIL->RES_STS_7));
    MEMCPY_AN(UDRDETAIL_N->RES_STS_8, UDRDETAIL->RES_STS_8, sizeof(UDRDETAIL->RES_STS_8));
    MEMCPY_AN(UDRDETAIL_N->RES_STS_9, UDRDETAIL->RES_STS_9, sizeof(UDRDETAIL->RES_STS_9));
    MEMCPY_AN(UDRDETAIL_N->RES_STS_10, UDRDETAIL->RES_STS_10, sizeof(UDRDETAIL->RES_STS_10));
    MEMCPY_AN(UDRDETAIL_N->LOT_ID, UDRDETAIL->LOT_ID, sizeof(UDRDETAIL->LOT_ID));
    MEMCPY_AN(UDRDETAIL_N->SUBLOT_ID, UDRDETAIL->SUBLOT_ID, sizeof(UDRDETAIL->SUBLOT_ID));
    MEMCPY_AN(UDRDETAIL_N->CRR_ID, UDRDETAIL->CRR_ID, sizeof(UDRDETAIL->CRR_ID));
    MEMCPY_AN(UDRDETAIL_N->RES_CTRL_MODE, UDRDETAIL->RES_CTRL_MODE, sizeof(UDRDETAIL->RES_CTRL_MODE));
    MEMCPY_AN(UDRDETAIL_N->RES_PROC_MODE, UDRDETAIL->RES_PROC_MODE, sizeof(UDRDETAIL->RES_PROC_MODE));
    MEMCPY_AN(UDRDETAIL_N->LAST_RECIPE_ID, UDRDETAIL->LAST_RECIPE_ID, sizeof(UDRDETAIL->LAST_RECIPE_ID));
    UDRDETAIL_N->PROC_COUNT = UDRDETAIL->PROC_COUNT;
    MEMCPY_AN(UDRDETAIL_N->LAST_START_TIME, UDRDETAIL->LAST_START_TIME, sizeof(UDRDETAIL->LAST_START_TIME));
    MEMCPY_AN(UDRDETAIL_N->LAST_END_TIME, UDRDETAIL->LAST_END_TIME, sizeof(UDRDETAIL->LAST_END_TIME));
    MEMCPY_AN(UDRDETAIL_N->LAST_DOWN_TIME, UDRDETAIL->LAST_DOWN_TIME, sizeof(UDRDETAIL->LAST_DOWN_TIME));
    UDRDETAIL_N->LAST_DOWN_HIST_SEQ = UDRDETAIL->LAST_DOWN_HIST_SEQ;
    MEMCPY_AN(UDRDETAIL_N->LAST_EVENT_ID, UDRDETAIL->LAST_EVENT_ID, sizeof(UDRDETAIL->LAST_EVENT_ID));
    MEMCPY_AN(UDRDETAIL_N->LAST_EVENT_TIME, UDRDETAIL->LAST_EVENT_TIME, sizeof(UDRDETAIL->LAST_EVENT_TIME));
    UDRDETAIL_N->LAST_ACTIVE_HIST_SEQ = UDRDETAIL->LAST_ACTIVE_HIST_SEQ;
    UDRDETAIL_N->LAST_HIST_SEQ = UDRDETAIL->LAST_HIST_SEQ;   
    UDRDETAIL_N->ANGLE = UDRDETAIL->ANGLE;
    UDRDETAIL_N->RES_SHAPE[0] = UDRDETAIL->RES_SHAPE; 
}


/* Del Null Function */
void DBC_del_null_udrdetail(struct UDRDETAIL_N_TAG *UDRDETAIL_N, struct UDRDETAIL_TAG *UDRDETAIL)
{
    MEMCPY_DN(UDRDETAIL->FACTORY, UDRDETAIL_N->FACTORY, sizeof(UDRDETAIL->FACTORY));
    MEMCPY_DN(UDRDETAIL->GROUP_ID, UDRDETAIL_N->GROUP_ID, sizeof(UDRDETAIL->GROUP_ID));
    MEMCPY_DN(UDRDETAIL->RES_ID, UDRDETAIL_N->RES_ID, sizeof(UDRDETAIL->RES_ID));
    UDRDETAIL->RES_TAG_FLAG = UDRDETAIL_N->RES_TAG_FLAG[0];
