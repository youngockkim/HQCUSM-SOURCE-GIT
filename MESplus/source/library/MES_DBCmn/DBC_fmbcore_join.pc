                :RESLOCDETAIL_N.RES_CMF_6,
                :RESLOCDETAIL_N.RES_CMF_7,
                :RESLOCDETAIL_N.RES_CMF_8,
                :RESLOCDETAIL_N.RES_CMF_9,
                :RESLOCDETAIL_N.RES_CMF_10,
                :RESLOCDETAIL_N.RES_CMF_11,
