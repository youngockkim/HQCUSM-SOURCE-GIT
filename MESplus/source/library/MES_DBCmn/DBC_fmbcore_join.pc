    MEMCPY_AN(POTLOC_LIST_N->RES_ID ,POTLOC_LIST->RES_ID ,sizeof(POTLOC_LIST->RES_ID ));
    MEMCPY_AN(POTLOC_LIST_N->PORT_ID ,POTLOC_LIST->PORT_ID ,sizeof(POTLOC_LIST->PORT_ID ));
    MEMCPY_AN(POTLOC_LIST_N->SUBRES_ID ,POTLOC_LIST->SUBRES_ID,sizeof(POTLOC_LIST->SUBRES_ID));
    MEMCPY_AN(POTLOC_LIST_N->RES_DESC ,POTLOC_LIST->RES_DESC,sizeof(POTLOC_LIST->RES_DESC));
    MEMCPY_AN(POTLOC_LIST_N->PORT_DESC ,POTLOC_LIST->PORT_DESC,sizeof(POTLOC_LIST->PORT_DESC));
    POTLOC_LIST_N->ATTACHED_FLAG[0] = POTLOC_LIST->ATTACHED_FLAG;
    MEMCPY_AN(POTLOC_LIST_N->LAYOUT_ID ,POTLOC_LIST->LAYOUT_ID,sizeof(POTLOC_LIST->LAYOUT_ID));
}


/* Del Null Function */
void DBC_del_null_potloc_list(struct POTLOC_LIST_N_TAG *POTLOC_LIST_N, struct POTLOC_LIST_TAG *POTLOC_LIST)
{
    MEMCPY_DN(POTLOC_LIST->FACTORY ,POTLOC_LIST_N->FACTORY ,sizeof(POTLOC_LIST->FACTORY ));
    MEMCPY_AN(POTLOC_LIST->RES_ID ,POTLOC_LIST_N->RES_ID ,sizeof(POTLOC_LIST->RES_ID ));
    MEMCPY_DN(POTLOC_LIST->PORT_ID ,POTLOC_LIST_N->PORT_ID ,sizeof(POTLOC_LIST->PORT_ID ));
    MEMCPY_DN(POTLOC_LIST->RES_DESC ,POTLOC_LIST_N->RES_DESC,sizeof(POTLOC_LIST->RES_DESC));
    MEMCPY_DN(POTLOC_LIST->SUBRES_ID ,POTLOC_LIST_N->SUBRES_ID,sizeof(POTLOC_LIST->SUBRES_ID));
    MEMCPY_DN(POTLOC_LIST->PORT_DESC ,POTLOC_LIST_N->PORT_DESC,sizeof(POTLOC_LIST->PORT_DESC));
    POTLOC_LIST->ATTACHED_FLAG = POTLOC_LIST_N->ATTACHED_FLAG[0];
    MEMCPY_DN(POTLOC_LIST->LAYOUT_ID ,POTLOC_LIST_N->LAYOUT_ID,sizeof(POTLOC_LIST->LAYOUT_ID));
}   


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_udploc_list(int sel_type, struct UDPLOC_LIST_TAG *UDPLOC_LIST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct UDPLOC_LIST_N_TAG UDPLOC_LIST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_udploc_list(&UDPLOC_LIST_N, UDPLOC_LIST);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_UDPLOC_LIST_CUR_1 CURSOR FOR 
                SELECT * FROM (
                    SELECT 
                        A.RES_ID, 
                        A.PORT_ID, 
                        A.PORT_DESC, 
                        'Y' ATTACHED, 
                        B.GROUP_ID LAYOUT_ID, 
                        A.SUBRES_ID
                    FROM MRASPOTDEF A, MFMBUDRLOC B 
                    WHERE A.FACTORY = :UDPLOC_LIST_N.FACTORY 
                      AND A.FACTORY = B.FACTORY 
                      AND A.PORT_ID = B.RES_ID
                      AND B.GROUP_ID = :UDPLOC_LIST_N.GROUP_ID
                      AND B.RES_TYPE = 'P'
                      AND A.RES_ID = B.MOTHER_RES_ID
                    UNION
                    SELECT 
                        RES_ID, 
                        PORT_ID, 
                        PORT_DESC, 
                        'N' ATTACHED, ' ' GROUP_ID,
                        SUBRES_ID
                    FROM MRASPOTDEF 
                    WHERE FACTORY = :UDPLOC_LIST_N.FACTORY
                      AND (PORT_ID, RES_ID) NOT IN (
                                                    SELECT RES_ID, MOTHER_RES_ID 
                                                    FROM MFMBUDRLOC 
                                                    WHERE FACTORY = :UDPLOC_LIST_N.FACTORY 
                                                      AND GROUP_ID = :UDPLOC_LIST_N.GROUP_ID)
                ) C
                WHERE PORT_ID >= :UDPLOC_LIST_N.PORT_ID
                AND RES_ID = :UDPLOC_LIST_N.RES_ID
                ORDER BY PORT_ID;
            EXEC SQL OPEN DBC_UDPLOC_LIST_CUR_1;
            break;
   
        case 2:
            EXEC SQL DECLARE DBC_UDPLOC_LIST_CUR_2 CURSOR FOR 
                SELECT PORT_ID, PORT_DESC, SUBRES_ID
                FROM MRASPOTDEF WHERE
                FACTORY = :UDPLOC_LIST_N.FACTORY
                AND (PORT_ID,RES_ID) NOT IN (SELECT RES_ID,MOTHER_RES_ID FROM MFMBUDRLOC WHERE FACTORY = :UDPLOC_LIST_N.FACTORY AND GROUP_ID = :UDPLOC_LIST_N.GROUP_ID) 
                AND PORT_ID >= :UDPLOC_LIST_N.PORT_ID
                ORDER BY PORT_ID;

            EXEC SQL OPEN DBC_UDPLOC_LIST_CUR_2;
            break;
         
         case 3:
            EXEC SQL DECLARE DBC_UDPLOC_LIST_CUR_3 CURSOR FOR 
                SELECT DISTINCT A.RES_ID, B.RES_DESC, A.SUBRES_ID
                FROM MRASPOTDEF A, MRASRESDEF B
                WHERE A.FACTORY = B.FACTORY
                    AND A.RES_ID = B.RES_ID
                    AND A.RES_ID IN (
                    SELECT RES_ID 
                    FROM (
                        SELECT A.RES_ID, 'Y' ATTACHED
                        FROM MRASPOTDEF A, MFMBUDRLOC B 
                        WHERE A.FACTORY = :UDPLOC_LIST_N.FACTORY 
                            AND A.FACTORY = B.FACTORY 
                            AND A.PORT_ID = B.RES_ID
                            AND B.GROUP_ID = :UDPLOC_LIST_N.GROUP_ID
                            AND B.RES_TYPE = 'P'
                            AND A.RES_ID = B.MOTHER_RES_ID
                        UNION
                        SELECT RES_ID, 'N' ATTACHED
                        FROM MRASPOTDEF 
                        WHERE (PORT_ID, RES_ID) NOT IN (
                            SELECT RES_ID, MOTHER_RES_ID 
                            FROM MFMBUDRLOC 
                            WHERE FACTORY = :UDPLOC_LIST_N.FACTORY 
                                AND GROUP_ID = :UDPLOC_LIST_N.GROUP_ID
                            )
                        AND FACTORY = :UDPLOC_LIST_N.FACTORY
                    ) C
                    WHERE ATTACHED = 'N'
                )
                ORDER BY A.RES_ID;
            EXEC SQL OPEN DBC_UDPLOC_LIST_CUR_3;
            break;    
             

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_udploc_list", sel_type);
}           

/* SQL CURSOR FETCH Function */
void DBC_fetch_udploc_list(int sel_type, struct UDPLOC_LIST_TAG *UDPLOC_LIST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct UDPLOC_LIST_N_TAG UDPLOC_LIST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_UDPLOC_LIST_CUR_1 INTO 
                :UDPLOC_LIST_N.RES_ID,
                :UDPLOC_LIST_N.PORT_ID,
                :UDPLOC_LIST_N.PORT_DESC,
                :UDPLOC_LIST_N.ATTACHED_FLAG,
                :UDPLOC_LIST_N.GROUP_ID,
                :UDPLOC_LIST_N.SUBRES_ID;
            break;

        case 2:
            EXEC SQL FETCH DBC_UDPLOC_LIST_CUR_2 INTO 
                :UDPLOC_LIST_N.PORT_ID,
                :UDPLOC_LIST_N.PORT_DESC,
                :UDPLOC_LIST_N.SUBRES_ID;
            break;
            
       case 3:
            EXEC SQL FETCH DBC_UDPLOC_LIST_CUR_3 INTO 
                :UDPLOC_LIST_N.RES_ID,
                :UDPLOC_LIST_N.RES_DESC,
                :UDPLOC_LIST_N.SUBRES_ID;
            break;            


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    if(DB_error_code == 0)
    {
        DBC_del_null_udploc_list(&UDPLOC_LIST_N, UDPLOC_LIST);
    }
    DB_stop_query_timer("DBC_fetch_udploc_list", sel_type);
}

/* SQL CURSOR CLOSE Function */
void DBC_close_udploc_list(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_UDPLOC_LIST_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_UDPLOC_LIST_CUR_2;
            break;
       
       case 3:
            EXEC SQL CLOSE DBC_UDPLOC_LIST_CUR_3;
            break;     
      

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_udploc_list", sel_type);
}

/* Initialize Function */
void DBC_init_udploc_list(struct UDPLOC_LIST_TAG *UDPLOC_LIST)
{
    /* memset by Space */
    memset(UDPLOC_LIST, ' ', sizeof(struct UDPLOC_LIST_TAG));

}

/* Add Null Function */
void DBC_add_null_udploc_list(struct UDPLOC_LIST_N_TAG *UDPLOC_LIST_N, struct UDPLOC_LIST_TAG *UDPLOC_LIST)
{ 
    /* memset by NULL */
    memset(UDPLOC_LIST_N, '\0', sizeof(struct UDPLOC_LIST_N_TAG));

    MEMCPY_AN(UDPLOC_LIST_N->FACTORY ,UDPLOC_LIST->FACTORY ,sizeof(UDPLOC_LIST->FACTORY ));
    MEMCPY_AN(UDPLOC_LIST_N->RES_ID ,UDPLOC_LIST->RES_ID ,sizeof(UDPLOC_LIST->RES_ID ));
    MEMCPY_AN(UDPLOC_LIST_N->MOTHER_RES_ID ,UDPLOC_LIST->MOTHER_RES_ID ,sizeof(UDPLOC_LIST->MOTHER_RES_ID ));
    MEMCPY_AN(UDPLOC_LIST_N->PORT_ID ,UDPLOC_LIST->PORT_ID ,sizeof(UDPLOC_LIST->PORT_ID ));
    MEMCPY_AN(UDPLOC_LIST_N->SUBRES_ID ,UDPLOC_LIST->SUBRES_ID,sizeof(UDPLOC_LIST->SUBRES_ID));
    MEMCPY_AN(UDPLOC_LIST_N->RES_DESC ,UDPLOC_LIST->RES_DESC,sizeof(UDPLOC_LIST->RES_DESC));
    MEMCPY_AN(UDPLOC_LIST_N->PORT_DESC ,UDPLOC_LIST->PORT_DESC,sizeof(UDPLOC_LIST->PORT_DESC));
    UDPLOC_LIST_N->ATTACHED_FLAG[0] = UDPLOC_LIST->ATTACHED_FLAG;
    MEMCPY_AN(UDPLOC_LIST_N->GROUP_ID ,UDPLOC_LIST->GROUP_ID,sizeof(UDPLOC_LIST->GROUP_ID));
}


/* Del Null Function */
void DBC_del_null_udploc_list(struct UDPLOC_LIST_N_TAG *UDPLOC_LIST_N, struct UDPLOC_LIST_TAG *UDPLOC_LIST)
{
    MEMCPY_DN(UDPLOC_LIST->FACTORY ,UDPLOC_LIST_N->FACTORY ,sizeof(UDPLOC_LIST->FACTORY ));
    MEMCPY_AN(UDPLOC_LIST->RES_ID ,UDPLOC_LIST_N->RES_ID ,sizeof(UDPLOC_LIST->RES_ID ));
    MEMCPY_DN(UDPLOC_LIST->PORT_ID ,UDPLOC_LIST_N->PORT_ID ,sizeof(UDPLOC_LIST->PORT_ID ));
    MEMCPY_DN(UDPLOC_LIST->RES_DESC ,UDPLOC_LIST_N->RES_DESC,sizeof(UDPLOC_LIST->RES_DESC));
    MEMCPY_DN(UDPLOC_LIST->SUBRES_ID ,UDPLOC_LIST_N->SUBRES_ID,sizeof(UDPLOC_LIST->SUBRES_ID));
    MEMCPY_DN(UDPLOC_LIST->PORT_DESC ,UDPLOC_LIST_N->PORT_DESC,sizeof(UDPLOC_LIST->PORT_DESC));
    UDPLOC_LIST->ATTACHED_FLAG = UDPLOC_LIST_N->ATTACHED_FLAG[0];
    MEMCPY_DN(UDPLOC_LIST->GROUP_ID ,UDPLOC_LIST_N->GROUP_ID,sizeof(UDPLOC_LIST->GROUP_ID));
}   


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_srsloc_list(int sel_type, struct SRSLOC_LIST_TAG *SRSLOC_LIST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct SRSLOC_LIST_N_TAG SRSLOC_LIST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_srsloc_list(&SRSLOC_LIST_N, SRSLOC_LIST);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_SRSLOC_LIST_CUR_1 CURSOR FOR 
                SELECT * FROM (SELECT A.RES_ID, A.SUBRES_ID, A.SUBRES_DESC, 'Y' ATTACHED, B.LAYOUT_ID LAYOUT_ID, A.SUBRES_UP_DOWN_FLAG
                FROM MRASSRSDEF A, MFMBRESLOC B 
                WHERE
                A.FACTORY = :SRSLOC_LIST_N.FACTORY 
                AND A.FACTORY = B.FACTORY
                AND A.SUBRES_ID = B.RES_ID
                AND A.RES_ID =  B.MOTHER_RES_ID
                AND B.RES_TYPE = 'S'
                UNION
                SELECT RES_ID, SUBRES_ID, SUBRES_DESC, 'N' ATTACHED, ' ' LAYOUT_ID, SUBRES_UP_DOWN_FLAG
                FROM MRASSRSDEF WHERE
                FACTORY = :SRSLOC_LIST_N.FACTORY
                AND DELETE_FLAG <> 'Y'
                AND (SUBRES_ID,RES_ID) NOT IN (SELECT RES_ID,MOTHER_RES_ID FROM MFMBRESLOC WHERE FACTORY = :SRSLOC_LIST_N.FACTORY)) C
                WHERE SUBRES_ID >= :SRSLOC_LIST_N.SUBRES_ID
                AND RES_ID = :SRSLOC_LIST_N.RES_ID 
                ORDER BY SUBRES_ID;
            EXEC SQL OPEN DBC_SRSLOC_LIST_CUR_1;
            break;
   
        case 2:
            EXEC SQL DECLARE DBC_SRSLOC_LIST_CUR_2 CURSOR FOR 
                SELECT RES_ID,SUBRES_ID, SUBRES_DESC, SUBRES_UP_DOWN_FLAG
                FROM MRASSRSDEF WHERE
                FACTORY = :SRSLOC_LIST_N.FACTORY
                AND DELETE_FLAG <> 'Y'
                AND RES_ID = :SRSLOC_LIST_N.RES_ID
                AND (SUBRES_ID,RES_ID) NOT IN (SELECT RES_ID,MOTHER_RES_ID FROM MFMBRESLOC WHERE FACTORY = :SRSLOC_LIST_N.FACTORY) 
                AND SUBRES_ID >= :SRSLOC_LIST_N.SUBRES_ID
                ORDER BY SUBRES_ID;

            EXEC SQL OPEN DBC_SRSLOC_LIST_CUR_2;
            break;
         
         case 3:
            EXEC SQL DECLARE DBC_SRSLOC_LIST_CUR_3 CURSOR FOR 
               SELECT DISTINCT A.RES_ID, B.RES_DESC, B.RES_UP_DOWN_FLAG
                FROM MRASSRSDEF A, MRASRESDEF B
                WHERE A.FACTORY = B.FACTORY
                    AND A.RES_ID = B.RES_ID
                    AND A.RES_ID IN (
                        SELECT RES_ID 
                        FROM (
                            SELECT A.RES_ID, 'Y' ATTACHED
                            FROM MRASSRSDEF A, MFMBRESLOC B 
                            WHERE A.FACTORY = :SRSLOC_LIST_N.FACTORY 
                                AND A.FACTORY = B.FACTORY 
                                AND A.SUBRES_ID = B.RES_ID
                                AND A.RES_ID =  B.MOTHER_RES_ID
                                AND B.RES_TYPE = 'S'
                            UNION
                            SELECT RES_ID, 'N' ATTACHED
                            FROM MRASSRSDEF 
                            WHERE FACTORY = :SRSLOC_LIST_N.FACTORY 
                                AND DELETE_FLAG <> 'Y'
                                AND (SUBRES_ID,RES_ID) NOT IN (
                                    SELECT RES_ID, MOTHER_RES_ID 
                                    FROM MFMBRESLOC 
                                    WHERE FACTORY = :SRSLOC_LIST_N.FACTORY 
                                    )
                            ) C
                        WHERE ATTACHED = 'N'
                )
                ORDER BY A.RES_ID;
            EXEC SQL OPEN DBC_SRSLOC_LIST_CUR_3;
            break;             
        
        case 4:
            EXEC SQL DECLARE DBC_SRSLOC_LIST_CUR_4 CURSOR FOR 
                SELECT * FROM (SELECT A.RES_ID, A.SUBRES_ID, A.SUBRES_DESC, 'Y' ATTACHED, B.LAYOUT_ID LAYOUT_ID
                FROM MRASSRSDEF A, MFMBRESLOC B 
                WHERE
                A.FACTORY = :SRSLOC_LIST_N.FACTORY 
                AND A.FACTORY = B.FACTORY
                AND A.SUBRES_ID = B.RES_ID
                AND A.RES_ID =  B.MOTHER_RES_ID
                AND B.RES_TYPE = 'S'
                AND B.LAYOUT_ID = :SRSLOC_LIST_N.LAYOUT_ID
                UNION
                SELECT RES_ID, SUBRES_ID, SUBRES_DESC, 'N' ATTACHED, ' ' LAYOUT_ID
                FROM MRASSRSDEF WHERE
                FACTORY = :SRSLOC_LIST_N.FACTORY
                AND DELETE_FLAG <> 'Y'
                AND (SUBRES_ID,RES_ID) NOT IN (SELECT RES_ID,MOTHER_RES_ID FROM MFMBRESLOC WHERE FACTORY = :SRSLOC_LIST_N.FACTORY)
                UNION
                SELECT A.RES_ID, A.SUBRES_ID, A.SUBRES_DESC, 'N' ATTACHED, B.LAYOUT_ID LAYOUT_ID
                FROM MRASSRSDEF A, MFMBRESLOC B 
                WHERE
                A.FACTORY = :SRSLOC_LIST_N.FACTORY 
                AND A.FACTORY = B.FACTORY
                AND A.SUBRES_ID = B.RES_ID
                AND A.RES_ID =  B.MOTHER_RES_ID
                AND B.RES_TYPE = 'S'
                AND B.LAYOUT_ID <> :SRSLOC_LIST_N.LAYOUT_ID
                ) C
                WHERE SUBRES_ID >= :SRSLOC_LIST_N.SUBRES_ID
                AND RES_ID = :SRSLOC_LIST_N.RES_ID 
                ORDER BY ATTACHED DESC, SUBRES_ID;
            EXEC SQL OPEN DBC_SRSLOC_LIST_CUR_4;
            break;     


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_srsloc_list", sel_type);
}           

/* SQL CURSOR FETCH Function */
void DBC_fetch_srsloc_list(int sel_type, struct SRSLOC_LIST_TAG *SRSLOC_LIST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct SRSLOC_LIST_N_TAG SRSLOC_LIST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_SRSLOC_LIST_CUR_1 INTO 
                :SRSLOC_LIST_N.RES_ID,
                :SRSLOC_LIST_N.SUBRES_ID,
                :SRSLOC_LIST_N.SUBRES_DESC,
                :SRSLOC_LIST_N.ATTACHED_FLAG,
                :SRSLOC_LIST_N.LAYOUT_ID,
                :SRSLOC_LIST_N.SUBRES_UP_DOWN_FLAG;
            break;

        case 2:
            EXEC SQL FETCH DBC_SRSLOC_LIST_CUR_2 INTO 
                :SRSLOC_LIST_N.RES_ID,
                :SRSLOC_LIST_N.SUBRES_ID,
                :SRSLOC_LIST_N.SUBRES_DESC,
                :SRSLOC_LIST_N.SUBRES_UP_DOWN_FLAG;
            break;
            
        case 3:
            EXEC SQL FETCH DBC_SRSLOC_LIST_CUR_3 INTO 
                :SRSLOC_LIST_N.RES_ID,
                :SRSLOC_LIST_N.RES_DESC,
                :SRSLOC_LIST_N.RES_UP_DOWN_FLAG;
            break;
        
        case 4:
            EXEC SQL FETCH DBC_SRSLOC_LIST_CUR_4 INTO 
                :SRSLOC_LIST_N.RES_ID,
                :SRSLOC_LIST_N.SUBRES_ID,
                :SRSLOC_LIST_N.SUBRES_DESC,
                :SRSLOC_LIST_N.ATTACHED_FLAG,
                :SRSLOC_LIST_N.LAYOUT_ID;
            break;    
                            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    if(DB_error_code == 0)
    {
        DBC_del_null_srsloc_list(&SRSLOC_LIST_N, SRSLOC_LIST);
    }
    DB_stop_query_timer("DBC_fetch_srsloc_list", sel_type);
}

/* SQL CURSOR CLOSE Function */
void DBC_close_srsloc_list(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_SRSLOC_LIST_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_SRSLOC_LIST_CUR_2;
            break;
            
        case 3:
            EXEC SQL CLOSE DBC_SRSLOC_LIST_CUR_3;
            break;    
      
        case 4:
            EXEC SQL CLOSE DBC_SRSLOC_LIST_CUR_4;
            break; 


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_srsloc_list", sel_type);
}

