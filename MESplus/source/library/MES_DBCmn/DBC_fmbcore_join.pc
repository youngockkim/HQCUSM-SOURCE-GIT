    }

    if(DB_error_code == 0)
    {
        DBC_del_null_toldetail(&TOLDETAIL_N, TOLDETAIL);
    }
    DB_stop_query_timer("DBC_fetch_toldetail", sel_type);
}

/* SQL CURSOR CLOSE Function */
void DBC_close_toldetail(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_TOLDETAIL_CUR_1;
            break;
        
        case 2:
            EXEC SQL CLOSE DBC_TOLDETAIL_CUR_2;
            break;    
       

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_toldetail", sel_type);
}

/* Initialize Function */
void DBC_init_toldetail(struct TOLDETAIL_TAG *TOLDETAIL)
{
    /* memset by Space */
    memset(TOLDETAIL, ' ', sizeof(struct TOLDETAIL_TAG));
    TOLDETAIL->LOC_X = 0;
    TOLDETAIL->LOC_Y = 0;
    TOLDETAIL->LOC_WIDTH = 0;
    TOLDETAIL->LOC_HEIGHT = 0;
    TOLDETAIL->TEXT_SIZE = 0;
    TOLDETAIL->TEXT_COLOR = 0;
    TOLDETAIL->TAG_TYPE = 0;
    TOLDETAIL->BACK_COLOR = 0;  
    TOLDETAIL->SEQ = 0;  
    TOLDETAIL->LAST_HIST_SEQ = 0;
    TOLDETAIL->LAST_ACTIVE_HIST_SEQ = 0;
    TOLDETAIL->LAST_HIST_SEQ = 0;
    TOLDETAIL->ANGLE = 0;
}

/* Add Null Function */
void DBC_add_null_toldetail(struct TOLDETAIL_N_TAG *TOLDETAIL_N, struct TOLDETAIL_TAG *TOLDETAIL)
{ 
    /* memset by NULL */
    memset(TOLDETAIL_N, '\0', sizeof(struct TOLDETAIL_N_TAG));

    MEMCPY_AN(TOLDETAIL_N->FACTORY, TOLDETAIL->FACTORY, sizeof(TOLDETAIL->FACTORY));
    MEMCPY_AN(TOLDETAIL_N->RES_ID, TOLDETAIL->RES_ID, sizeof(TOLDETAIL->RES_ID));
    MEMCPY_AN(TOLDETAIL_N->RES_TYPE, TOLDETAIL->RES_TYPE, sizeof(TOLDETAIL->RES_TYPE));
    MEMCPY_AN(TOLDETAIL_N->LAYOUT_ID, TOLDETAIL->LAYOUT_ID, sizeof(TOLDETAIL->LAYOUT_ID));
    TOLDETAIL_N->SEQ = TOLDETAIL->SEQ;
    TOLDETAIL_N->LOC_X = TOLDETAIL->LOC_X;
    TOLDETAIL_N->LOC_Y = TOLDETAIL->LOC_Y;
    TOLDETAIL_N->LOC_WIDTH = TOLDETAIL->LOC_WIDTH;
    TOLDETAIL_N->LOC_HEIGHT = TOLDETAIL->LOC_HEIGHT;
    MEMCPY_AN(TOLDETAIL_N->TEXT, TOLDETAIL->TEXT, sizeof(TOLDETAIL->TEXT));
    TOLDETAIL_N->TEXT_SIZE = TOLDETAIL->TEXT_SIZE;
    TOLDETAIL_N->TEXT_COLOR = TOLDETAIL->TEXT_COLOR;
    TOLDETAIL_N->TEXT_STYLE[0] = TOLDETAIL->TEXT_STYLE;
    TOLDETAIL_N->TAG_TYPE = TOLDETAIL->TAG_TYPE;
    TOLDETAIL_N->BACK_COLOR = TOLDETAIL->BACK_COLOR;
    MEMCPY_AN(TOLDETAIL_N->CREATE_USER_ID, TOLDETAIL->CREATE_USER_ID, sizeof(TOLDETAIL->CREATE_USER_ID));
    MEMCPY_AN(TOLDETAIL_N->CREATE_TIME, TOLDETAIL->CREATE_TIME, sizeof(TOLDETAIL->CREATE_TIME));
    MEMCPY_AN(TOLDETAIL_N->UPDATE_USER_ID, TOLDETAIL->UPDATE_USER_ID, sizeof(TOLDETAIL->UPDATE_USER_ID));
    MEMCPY_AN(TOLDETAIL_N->UPDATE_TIME, TOLDETAIL->UPDATE_TIME, sizeof(TOLDETAIL->UPDATE_TIME));
    TOLDETAIL_N->NO_MOUSE_EVENT[0] = TOLDETAIL->NO_MOUSE_EVENT;
    MEMCPY_AN(TOLDETAIL_N->TOOL_ID, TOLDETAIL->TOOL_ID, sizeof(TOLDETAIL->TOOL_ID));
    TOLDETAIL_N->SIGNAL_FLAG[0] = TOLDETAIL->SIGNAL_FLAG;
    MEMCPY_AN(TOLDETAIL_N->SUBRES_ID, TOLDETAIL->SUBRES_ID, sizeof(TOLDETAIL->SUBRES_ID));
    MEMCPY_AN(TOLDETAIL_N->TOOL_GRP, TOLDETAIL->TOOL_GRP, sizeof(TOLDETAIL->TOOL_GRP));
    MEMCPY_AN(TOLDETAIL_N->TOOL_SET_ID, TOLDETAIL->TOOL_SET_ID, sizeof(TOLDETAIL->TOOL_SET_ID));
    MEMCPY_AN(TOLDETAIL_N->TOOL_SET_LOCATION, TOLDETAIL->TOOL_SET_LOCATION, sizeof(TOLDETAIL->TOOL_SET_LOCATION));
    MEMCPY_AN(TOLDETAIL_N->TOOL_STATUS, TOLDETAIL->TOOL_STATUS, sizeof(TOLDETAIL->TOOL_STATUS));
    MEMCPY_AN(TOLDETAIL_N->LOT_ID, TOLDETAIL->LOT_ID, sizeof(TOLDETAIL->LOT_ID));
    MEMCPY_AN(TOLDETAIL_N->SUBLOT_ID, TOLDETAIL->SUBLOT_ID, sizeof(TOLDETAIL->SUBLOT_ID));
    MEMCPY_AN(TOLDETAIL_N->MAT_ID, TOLDETAIL->MAT_ID, sizeof(TOLDETAIL->MAT_ID));
    TOLDETAIL_N->MAT_VER = TOLDETAIL->MAT_VER;
    MEMCPY_AN(TOLDETAIL_N->FLOW, TOLDETAIL->FLOW, sizeof(TOLDETAIL->FLOW));
    MEMCPY_AN(TOLDETAIL_N->OPER, TOLDETAIL->OPER, sizeof(TOLDETAIL->OPER));
    MEMCPY_AN(TOLDETAIL_N->AREA_ID, TOLDETAIL->AREA_ID, sizeof(TOLDETAIL->AREA_ID));
    MEMCPY_AN(TOLDETAIL_N->SUB_AREA_ID, TOLDETAIL->SUB_AREA_ID, sizeof(TOLDETAIL->SUB_AREA_ID));
    MEMCPY_AN(TOLDETAIL_N->TOOL_LOCATION, TOLDETAIL->TOOL_LOCATION, sizeof(TOLDETAIL->TOOL_LOCATION));
    MEMCPY_AN(TOLDETAIL_N->VENDOR_ID, TOLDETAIL->VENDOR_ID, sizeof(TOLDETAIL->VENDOR_ID));
    MEMCPY_AN(TOLDETAIL_N->VENDOR_TOOL_ID, TOLDETAIL->VENDOR_TOOL_ID, sizeof(TOLDETAIL->VENDOR_TOOL_ID));
    TOLDETAIL_N->CELL_COUNT_X = TOLDETAIL->CELL_COUNT_X;
    TOLDETAIL_N->CELL_COUNT_Y = TOLDETAIL->CELL_COUNT_Y;
    TOLDETAIL_N->CELL_COUNT_Z = TOLDETAIL->CELL_COUNT_Z;
    TOLDETAIL_N->CELL_SIZE_X  = TOLDETAIL->CELL_SIZE_X;
    TOLDETAIL_N->CELL_SIZE_Y  = TOLDETAIL->CELL_SIZE_Y;
    TOLDETAIL_N->CELL_SIZE_Z  = TOLDETAIL->CELL_SIZE_Z;
    TOLDETAIL_N->GRADE[0] = TOLDETAIL->GRADE;
    MEMCPY_AN(TOLDETAIL_N->TOOL_STS_1, TOLDETAIL->TOOL_STS_1, sizeof(TOLDETAIL->TOOL_STS_1));
    MEMCPY_AN(TOLDETAIL_N->TOOL_STS_2, TOLDETAIL->TOOL_STS_2, sizeof(TOLDETAIL->TOOL_STS_2));
    MEMCPY_AN(TOLDETAIL_N->TOOL_STS_3, TOLDETAIL->TOOL_STS_3, sizeof(TOLDETAIL->TOOL_STS_3));
    MEMCPY_AN(TOLDETAIL_N->TOOL_STS_4, TOLDETAIL->TOOL_STS_4, sizeof(TOLDETAIL->TOOL_STS_4));
    MEMCPY_AN(TOLDETAIL_N->TOOL_STS_5, TOLDETAIL->TOOL_STS_5, sizeof(TOLDETAIL->TOOL_STS_5));
    MEMCPY_AN(TOLDETAIL_N->TOOL_STS_6, TOLDETAIL->TOOL_STS_6, sizeof(TOLDETAIL->TOOL_STS_6));
    MEMCPY_AN(TOLDETAIL_N->TOOL_STS_7, TOLDETAIL->TOOL_STS_7, sizeof(TOLDETAIL->TOOL_STS_7));
    MEMCPY_AN(TOLDETAIL_N->TOOL_STS_8, TOLDETAIL->TOOL_STS_8, sizeof(TOLDETAIL->TOOL_STS_8));
    MEMCPY_AN(TOLDETAIL_N->TOOL_STS_9, TOLDETAIL->TOOL_STS_9, sizeof(TOLDETAIL->TOOL_STS_9));
    MEMCPY_AN(TOLDETAIL_N->TOOL_STS_10, TOLDETAIL->TOOL_STS_10, sizeof(TOLDETAIL->TOOL_STS_10));
    TOLDETAIL_N->LAST_HIST_SEQ = TOLDETAIL -> LAST_HIST_SEQ;
    TOLDETAIL_N->LAST_ACTIVE_HIST_SEQ = TOLDETAIL->LAST_ACTIVE_HIST_SEQ;
    MEMCPY_AN(TOLDETAIL_N->LAST_TOOL_EVENT_ID, TOLDETAIL->LAST_TOOL_EVENT_ID, sizeof(TOLDETAIL->LAST_TOOL_EVENT_ID));
    MEMCPY_AN(TOLDETAIL_N->LAST_TRAN_TIME, TOLDETAIL->LAST_TRAN_TIME, sizeof(TOLDETAIL->LAST_TRAN_TIME));
    TOLDETAIL_N->DELETE_FLAG[0]= TOLDETAIL->DELETE_FLAG;
    MEMCPY_AN(TOLDETAIL_N->TOOL_COMMENT, TOLDETAIL->TOOL_COMMENT, sizeof(TOLDETAIL->TOOL_COMMENT));
    TOLDETAIL_N->TOOL_UP_DOWN_FLAG[0]= TOLDETAIL->TOOL_UP_DOWN_FLAG;
    MEMCPY_AN(TOLDETAIL_N->TOOL_TYPE, TOLDETAIL->TOOL_TYPE, sizeof(TOLDETAIL->TOOL_TYPE));
    TOLDETAIL_N->ANGLE = TOLDETAIL->ANGLE;
    TOLDETAIL_N->RES_SHAPE[0] = TOLDETAIL->RES_SHAPE;
}


/* Del Null Function */
void DBC_del_null_toldetail(struct TOLDETAIL_N_TAG *TOLDETAIL_N, struct TOLDETAIL_TAG *TOLDETAIL)
{
    MEMCPY_DN(TOLDETAIL->FACTORY, TOLDETAIL_N->FACTORY, sizeof(TOLDETAIL->FACTORY));
    MEMCPY_DN(TOLDETAIL->RES_ID, TOLDETAIL_N->RES_ID, sizeof(TOLDETAIL->RES_ID));
    MEMCPY_DN(TOLDETAIL->RES_TYPE, TOLDETAIL_N->RES_TYPE, sizeof(TOLDETAIL->RES_TYPE));
    MEMCPY_DN(TOLDETAIL->LAYOUT_ID, TOLDETAIL_N->LAYOUT_ID, sizeof(TOLDETAIL->LAYOUT_ID));
    TOLDETAIL->SEQ = TOLDETAIL_N->SEQ;
    TOLDETAIL->LOC_X = TOLDETAIL_N->LOC_X;
    TOLDETAIL->LOC_Y = TOLDETAIL_N->LOC_Y;
    TOLDETAIL->LOC_WIDTH = TOLDETAIL_N->LOC_WIDTH;
    TOLDETAIL->LOC_HEIGHT = TOLDETAIL_N->LOC_HEIGHT;
    MEMCPY_DN(TOLDETAIL->TEXT, TOLDETAIL_N->TEXT, sizeof(TOLDETAIL->TEXT));
    TOLDETAIL->TEXT_SIZE = TOLDETAIL_N->TEXT_SIZE;
    TOLDETAIL->TEXT_COLOR = TOLDETAIL_N->TEXT_COLOR;
    TOLDETAIL->TEXT_STYLE = TOLDETAIL_N->TEXT_STYLE[0];
    TOLDETAIL->TAG_TYPE = TOLDETAIL_N->TAG_TYPE;
    TOLDETAIL->BACK_COLOR = TOLDETAIL_N->BACK_COLOR;
    MEMCPY_DN(TOLDETAIL->CREATE_USER_ID, TOLDETAIL_N->CREATE_USER_ID, sizeof(TOLDETAIL->CREATE_USER_ID));
    MEMCPY_DN(TOLDETAIL->CREATE_TIME, TOLDETAIL_N->CREATE_TIME, sizeof(TOLDETAIL->CREATE_TIME));
    MEMCPY_DN(TOLDETAIL->UPDATE_USER_ID, TOLDETAIL_N->UPDATE_USER_ID, sizeof(TOLDETAIL->UPDATE_USER_ID));
    MEMCPY_DN(TOLDETAIL->UPDATE_TIME, TOLDETAIL_N->UPDATE_TIME, sizeof(TOLDETAIL->UPDATE_TIME));
    TOLDETAIL->NO_MOUSE_EVENT = TOLDETAIL_N->NO_MOUSE_EVENT[0];
    MEMCPY_DN(TOLDETAIL->TOOL_ID, TOLDETAIL_N->TOOL_ID, sizeof(TOLDETAIL->TOOL_ID));
    TOLDETAIL->SIGNAL_FLAG = TOLDETAIL_N->SIGNAL_FLAG[0];
    MEMCPY_DN(TOLDETAIL->SUBRES_ID, TOLDETAIL_N->SUBRES_ID, sizeof(TOLDETAIL->SUBRES_ID));
    MEMCPY_DN(TOLDETAIL->TOOL_GRP, TOLDETAIL_N->TOOL_GRP, sizeof(TOLDETAIL->TOOL_GRP));
    MEMCPY_DN(TOLDETAIL->TOOL_SET_ID, TOLDETAIL_N->TOOL_SET_ID, sizeof(TOLDETAIL->TOOL_SET_ID));
    MEMCPY_DN(TOLDETAIL->TOOL_SET_LOCATION, TOLDETAIL_N->TOOL_SET_LOCATION, sizeof(TOLDETAIL->TOOL_SET_LOCATION));
    MEMCPY_DN(TOLDETAIL->TOOL_STATUS, TOLDETAIL_N->TOOL_STATUS, sizeof(TOLDETAIL->TOOL_STATUS));
    MEMCPY_DN(TOLDETAIL->LOT_ID, TOLDETAIL_N->LOT_ID, sizeof(TOLDETAIL->LOT_ID));
    MEMCPY_DN(TOLDETAIL->SUBLOT_ID, TOLDETAIL_N->SUBLOT_ID, sizeof(TOLDETAIL->SUBLOT_ID));
    MEMCPY_DN(TOLDETAIL->MAT_ID, TOLDETAIL_N->MAT_ID, sizeof(TOLDETAIL->MAT_ID));
