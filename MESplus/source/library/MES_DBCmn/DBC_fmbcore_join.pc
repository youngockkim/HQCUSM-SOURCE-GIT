    SRSLOC_LIST_N->RES_UP_DOWN_FLAG[0]= SRSLOC_LIST->RES_UP_DOWN_FLAG;
    SRSLOC_LIST_N->SUBRES_UP_DOWN_FLAG[0]= SRSLOC_LIST->SUBRES_UP_DOWN_FLAG;
}


/* Del Null Function */
void DBC_del_null_srsloc_list(struct SRSLOC_LIST_N_TAG *SRSLOC_LIST_N, struct SRSLOC_LIST_TAG *SRSLOC_LIST)
{
    MEMCPY_DN(SRSLOC_LIST->FACTORY ,SRSLOC_LIST_N->FACTORY ,sizeof(SRSLOC_LIST->FACTORY ));
