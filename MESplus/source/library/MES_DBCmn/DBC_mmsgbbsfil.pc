/* Add Null Function */
void DBC_add_null_mmsgbbsfil(struct MMSGBBSFIL_N_TAG *MMSGBBSFIL_N, struct MMSGBBSFIL_TAG *MMSGBBSFIL)
{
    /* memset by NULL */
    memset(MMSGBBSFIL_N, '\0', sizeof(struct MMSGBBSFIL_N_TAG));
    
    MEMCPY_AN(MMSGBBSFIL_N->FACTORY, MMSGBBSFIL->FACTORY, sizeof(MMSGBBSFIL->FACTORY));
    MEMCPY_AN(MMSGBBSFIL_N->MAIN_MENU_ID, MMSGBBSFIL->MAIN_MENU_ID, sizeof(MMSGBBSFIL->MAIN_MENU_ID));
    MEMCPY_AN(MMSGBBSFIL_N->SUB_MENU_ID, MMSGBBSFIL->SUB_MENU_ID, sizeof(MMSGBBSFIL->SUB_MENU_ID));
    MMSGBBSFIL_N->BBS_SEQ = MMSGBBSFIL->BBS_SEQ;
    MMSGBBSFIL_N->FILE_SEQ = MMSGBBSFIL->FILE_SEQ;
    MEMCPY_AN(MMSGBBSFIL_N->SAVE_FILE_NAME, MMSGBBSFIL->SAVE_FILE_NAME, sizeof(MMSGBBSFIL->SAVE_FILE_NAME));
    MEMCPY_AN(MMSGBBSFIL_N->ORG_FILE_NAME, MMSGBBSFIL->ORG_FILE_NAME, sizeof(MMSGBBSFIL->ORG_FILE_NAME));
    MEMCPY_AN(MMSGBBSFIL_N->CREATE_USER_ID, MMSGBBSFIL->CREATE_USER_ID, sizeof(MMSGBBSFIL->CREATE_USER_ID));
