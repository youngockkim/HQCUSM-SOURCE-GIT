/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mmsgbbsfil(int sel_type, struct MMSGBBSFIL_TAG *MMSGBBSFIL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MMSGBBSFIL_N_TAG MMSGBBSFIL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mmsgbbsfil(&MMSGBBSFIL_N, MMSGBBSFIL);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MMSGBBSFIL_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    MAIN_MENU_ID,
                    SUB_MENU_ID,
                    BBS_SEQ,
                    FILE_SEQ,
                    SAVE_FILE_NAME,
                    ORG_FILE_NAME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MMSGBBSFIL
                WHERE FACTORY = :MMSGBBSFIL_N.FACTORY
                    AND MAIN_MENU_ID = :MMSGBBSFIL_N.MAIN_MENU_ID
                    AND SUB_MENU_ID = :MMSGBBSFIL_N.SUB_MENU_ID
                    AND BBS_SEQ = :MMSGBBSFIL_N.BBS_SEQ
                ORDER BY 
                    FILE_SEQ ASC;
            EXEC SQL OPEN DBC_MMSGBBSFIL_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mmsgbbsfil", sel_type);
}


