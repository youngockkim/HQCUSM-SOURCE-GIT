                WHERE FACTORY = :MMSGBBSFIL_N.FACTORY
                    AND MAIN_MENU_ID = :MMSGBBSFIL_N.MAIN_MENU_ID
                    AND SUB_MENU_ID = :MMSGBBSFIL_N.SUB_MENU_ID
                    AND BBS_SEQ = :MMSGBBSFIL_N.BBS_SEQ
