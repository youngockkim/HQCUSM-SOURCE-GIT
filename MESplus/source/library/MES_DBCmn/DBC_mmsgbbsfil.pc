    MEMCPY_DN(MMSGBBSFIL->SAVE_FILE_NAME, MMSGBBSFIL_N->SAVE_FILE_NAME, sizeof(MMSGBBSFIL->SAVE_FILE_NAME));
    MEMCPY_DN(MMSGBBSFIL->ORG_FILE_NAME, MMSGBBSFIL_N->ORG_FILE_NAME, sizeof(MMSGBBSFIL->ORG_FILE_NAME));
    MEMCPY_DN(MMSGBBSFIL->CREATE_USER_ID, MMSGBBSFIL_N->CREATE_USER_ID, sizeof(MMSGBBSFIL->CREATE_USER_ID));
    MEMCPY_DN(MMSGBBSFIL->CREATE_TIME, MMSGBBSFIL_N->CREATE_TIME, sizeof(MMSGBBSFIL->CREATE_TIME));
    MEMCPY_DN(MMSGBBSFIL->UPDATE_USER_ID, MMSGBBSFIL_N->UPDATE_USER_ID, sizeof(MMSGBBSFIL->UPDATE_USER_ID));
