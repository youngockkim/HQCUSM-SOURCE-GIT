    MEMCPY_AN(MMSGBBSFIL_N->UPDATE_TIME, MMSGBBSFIL->UPDATE_TIME, sizeof(MMSGBBSFIL->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mmsgbbsfil(struct MMSGBBSFIL_N_TAG *MMSGBBSFIL_N, struct MMSGBBSFIL_TAG *MMSGBBSFIL)
{
    MEMCPY_DN(MMSGBBSFIL->FACTORY, MMSGBBSFIL_N->FACTORY, sizeof(MMSGBBSFIL->FACTORY));
    MEMCPY_DN(MMSGBBSFIL->MAIN_MENU_ID, MMSGBBSFIL_N->MAIN_MENU_ID, sizeof(MMSGBBSFIL->MAIN_MENU_ID));
    MEMCPY_DN(MMSGBBSFIL->SUB_MENU_ID, MMSGBBSFIL_N->SUB_MENU_ID, sizeof(MMSGBBSFIL->SUB_MENU_ID));
    MMSGBBSFIL->BBS_SEQ = MMSGBBSFIL_N->BBS_SEQ;
