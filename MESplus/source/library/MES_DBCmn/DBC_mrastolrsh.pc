                    AND RES_ID = :MRASTOLRSH_N.RES_ID
                    AND HIST_SEQ = :MRASTOLRSH_N.HIST_SEQ
                ORDER BY TOOL_ID ASC,
                    TOOL_HIST_SEQ ASC;
