    MEMCPY_DN(MRCPSLTPRA->PARA_VALUE, MRCPSLTPRA_N->PARA_VALUE, sizeof(MRCPSLTPRA->PARA_VALUE));
    MEMCPY_DN(MRCPSLTPRA->PARA_DESC, MRCPSLTPRA_N->PARA_DESC, sizeof(MRCPSLTPRA->PARA_DESC));
