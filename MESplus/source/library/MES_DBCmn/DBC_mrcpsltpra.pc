    MEMCPY_DN(MRCPSLTPRA->RECIPE, MRCPSLTPRA_N->RECIPE, sizeof(MRCPSLTPRA->RECIPE));
    MRCPSLTPRA->RECIPE_VERSION = MRCPSLTPRA_N->RECIPE_VERSION;
