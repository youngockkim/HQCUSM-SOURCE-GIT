/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrcpsltpra(int sel_type, struct MRCPSLTPRA_TAG *MRCPSLTPRA)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRCPSLTPRA_N_TAG MRCPSLTPRA_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrcpsltpra(&MRCPSLTPRA_N, MRCPSLTPRA);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRCPSLTPRA_CUR_1 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    LOT_ID,
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    RECIPE,
                    RECIPE_VERSION,
                    PARA_SEQ,
                    PARA_ID,
                    PARA_VALUE,
                    PARA_DESC,
                    MODIFY_FLAG,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRCPSLTPRA
                WHERE SUBLOT_ID = :MRCPSLTPRA_N.SUBLOT_ID
                ORDER BY SUBLOT_ID ASC,
                    PARA_SEQ ASC;
            EXEC SQL OPEN DBC_MRCPSLTPRA_CUR_1;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrcpsltpra", sel_type);
}


