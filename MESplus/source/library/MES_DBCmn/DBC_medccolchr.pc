                    :MEDCCOLCHR_N.BLANK_REC_SAVE_FLAG,
                    :MEDCCOLCHR_N.DISPLAY_PRECISION,
                    :MEDCCOLCHR_N.DEF_UNIT_FLAG,
                    :MEDCCOLCHR_N.DEF_UNIT_OVR_FLAG,
                    :MEDCCOLCHR_N.DEF_VALUE,
                    :MEDCCOLCHR_N.UNIT_TBL,
                    :MEDCCOLCHR_N.VALUE_TBL,
                    :MEDCCOLCHR_N.SPEC_OUT_COUNT,
                    :MEDCCOLCHR_N.SPEC_TYPE,
                    :MEDCCOLCHR_N.TARGET_VALUE,
                    :MEDCCOLCHR_N.UPPER_SPEC_LIMIT,
                    :MEDCCOLCHR_N.LOWER_SPEC_LIMIT,
                    :MEDCCOLCHR_N.UPPER_WARN_LIMIT,
                    :MEDCCOLCHR_N.LOWER_WARN_LIMIT,
                    :MEDCCOLCHR_N.UPPER_CUST_LIMIT,
                    :MEDCCOLCHR_N.LOWER_CUST_LIMIT,
                    :MEDCCOLCHR_N.SPEC_INFO,
                    :MEDCCOLCHR_N.SPEC_OUT_ALARM,
                    :MEDCCOLCHR_N.WARN_OUT_ALARM,
                    :MEDCCOLCHR_N.DERIVED_PARAM_FLAG,
                    :MEDCCOLCHR_N.DERIVED_PARAMETER,
                    :MEDCCOLCHR_N.DATA_TYPE,
                    :MEDCCOLCHR_N.CREATE_USER_ID,
                    :MEDCCOLCHR_N.CREATE_TIME,
                    :MEDCCOLCHR_N.UPDATE_USER_ID,
                    :MEDCCOLCHR_N.UPDATE_TIME,
                    :MEDCCOLCHR_N.NO_USE_SPM_VALUE_FLAG
        );
    DB_stop_query_timer("DBC_insert_medccolchr", 0);
}


/* SQL UPDATE Function */
void DBC_update_medccolchr(int sel_type, struct MEDCCOLCHR_TAG *MEDCCOLCHR)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MEDCCOLCHR_N_TAG MEDCCOLCHR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_medccolchr(&MEDCCOLCHR_N, MEDCCOLCHR);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MEDCCOLCHR SET
                    SEQ_NUM = :MEDCCOLCHR_N.SEQ_NUM,
                    UNIT_COUNT = :MEDCCOLCHR_N.UNIT_COUNT,
                    VALUE_COUNT = :MEDCCOLCHR_N.VALUE_COUNT,
                    OPT_INPUT_FLAG = :MEDCCOLCHR_N.OPT_INPUT_FLAG,
                    BLANK_REC_SAVE_FLAG = :MEDCCOLCHR_N.BLANK_REC_SAVE_FLAG,
                    DISPLAY_PRECISION = :MEDCCOLCHR_N.DISPLAY_PRECISION,
                    DEF_UNIT_FLAG = :MEDCCOLCHR_N.DEF_UNIT_FLAG,
                    DEF_UNIT_OVR_FLAG = :MEDCCOLCHR_N.DEF_UNIT_OVR_FLAG,
                    DEF_VALUE = :MEDCCOLCHR_N.DEF_VALUE,
                    UNIT_TBL = :MEDCCOLCHR_N.UNIT_TBL,
                    VALUE_TBL = :MEDCCOLCHR_N.VALUE_TBL,
                    SPEC_OUT_COUNT = :MEDCCOLCHR_N.SPEC_OUT_COUNT,
                    SPEC_TYPE = :MEDCCOLCHR_N.SPEC_TYPE,
                    TARGET_VALUE = :MEDCCOLCHR_N.TARGET_VALUE,
                    UPPER_SPEC_LIMIT = :MEDCCOLCHR_N.UPPER_SPEC_LIMIT,
                    LOWER_SPEC_LIMIT = :MEDCCOLCHR_N.LOWER_SPEC_LIMIT,
                    UPPER_WARN_LIMIT = :MEDCCOLCHR_N.UPPER_WARN_LIMIT,
                    LOWER_WARN_LIMIT = :MEDCCOLCHR_N.LOWER_WARN_LIMIT,
                    UPPER_CUST_LIMIT = :MEDCCOLCHR_N.UPPER_CUST_LIMIT,
                    LOWER_CUST_LIMIT = :MEDCCOLCHR_N.LOWER_CUST_LIMIT,
                    SPEC_INFO = :MEDCCOLCHR_N.SPEC_INFO,
                    SPEC_OUT_ALARM = :MEDCCOLCHR_N.SPEC_OUT_ALARM,
                    WARN_OUT_ALARM = :MEDCCOLCHR_N.WARN_OUT_ALARM,
                    DERIVED_PARAM_FLAG = :MEDCCOLCHR_N.DERIVED_PARAM_FLAG,
                    DERIVED_PARAMETER = :MEDCCOLCHR_N.DERIVED_PARAMETER,
                    DATA_TYPE = :MEDCCOLCHR_N.DATA_TYPE,
                    CREATE_USER_ID = :MEDCCOLCHR_N.CREATE_USER_ID,
                    CREATE_TIME = :MEDCCOLCHR_N.CREATE_TIME,
                    UPDATE_USER_ID = :MEDCCOLCHR_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MEDCCOLCHR_N.UPDATE_TIME,
                    NO_USE_SPM_VALUE_FLAG = :MEDCCOLCHR_N.NO_USE_SPM_VALUE_FLAG
                WHERE FACTORY = :MEDCCOLCHR_N.FACTORY
                    AND COL_SET_ID = :MEDCCOLCHR_N.COL_SET_ID
                    AND COL_SET_VERSION = :MEDCCOLCHR_N.COL_SET_VERSION
                    AND CHAR_ID = :MEDCCOLCHR_N.CHAR_ID;
            break;
 
        case 2:
            EXEC SQL UPDATE MEDCCOLCHR SET
                    CHAR_ID = :MEDCCOLCHR_N.CHAR_ID,
                    UNIT_COUNT = :MEDCCOLCHR_N.UNIT_COUNT,
                    VALUE_COUNT = :MEDCCOLCHR_N.VALUE_COUNT,
                    OPT_INPUT_FLAG = :MEDCCOLCHR_N.OPT_INPUT_FLAG,
                    BLANK_REC_SAVE_FLAG = :MEDCCOLCHR_N.BLANK_REC_SAVE_FLAG,
                    DISPLAY_PRECISION = :MEDCCOLCHR_N.DISPLAY_PRECISION,
                    DEF_UNIT_FLAG = :MEDCCOLCHR_N.DEF_UNIT_FLAG,
                    DEF_UNIT_OVR_FLAG = :MEDCCOLCHR_N.DEF_UNIT_OVR_FLAG,
                    DEF_VALUE = :MEDCCOLCHR_N.DEF_VALUE,
                    UNIT_TBL = :MEDCCOLCHR_N.UNIT_TBL,
                    VALUE_TBL = :MEDCCOLCHR_N.VALUE_TBL,
                    SPEC_OUT_COUNT = :MEDCCOLCHR_N.SPEC_OUT_COUNT,
                    SPEC_TYPE = :MEDCCOLCHR_N.SPEC_TYPE,
                    TARGET_VALUE = :MEDCCOLCHR_N.TARGET_VALUE,
                    UPPER_SPEC_LIMIT = :MEDCCOLCHR_N.UPPER_SPEC_LIMIT,
                    LOWER_SPEC_LIMIT = :MEDCCOLCHR_N.LOWER_SPEC_LIMIT,
                    UPPER_WARN_LIMIT = :MEDCCOLCHR_N.UPPER_WARN_LIMIT,
                    LOWER_WARN_LIMIT = :MEDCCOLCHR_N.LOWER_WARN_LIMIT,
                    UPPER_CUST_LIMIT = :MEDCCOLCHR_N.UPPER_CUST_LIMIT,
                    LOWER_CUST_LIMIT = :MEDCCOLCHR_N.LOWER_CUST_LIMIT,
                    SPEC_INFO = :MEDCCOLCHR_N.SPEC_INFO,
                    SPEC_OUT_ALARM = :MEDCCOLCHR_N.SPEC_OUT_ALARM,
                    WARN_OUT_ALARM = :MEDCCOLCHR_N.WARN_OUT_ALARM,
                    DERIVED_PARAM_FLAG = :MEDCCOLCHR_N.DERIVED_PARAM_FLAG,
                    DERIVED_PARAMETER = :MEDCCOLCHR_N.DERIVED_PARAMETER,
                    DATA_TYPE = :MEDCCOLCHR_N.DATA_TYPE,
                    CREATE_USER_ID = :MEDCCOLCHR_N.CREATE_USER_ID,
                    CREATE_TIME = :MEDCCOLCHR_N.CREATE_TIME,
                    UPDATE_USER_ID = :MEDCCOLCHR_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MEDCCOLCHR_N.UPDATE_TIME,
                    NO_USE_SPM_VALUE_FLAG = :MEDCCOLCHR_N.NO_USE_SPM_VALUE_FLAG
                WHERE FACTORY = :MEDCCOLCHR_N.FACTORY
                    AND COL_SET_ID = :MEDCCOLCHR_N.COL_SET_ID
                    AND COL_SET_VERSION = :MEDCCOLCHR_N.COL_SET_VERSION
                    AND SEQ_NUM = :MEDCCOLCHR_N.SEQ_NUM;
            break;

    
        case 3:
            EXEC SQL UPDATE MEDCCOLCHR SET
                    SEQ_NUM = SEQ_NUM - 1
                WHERE FACTORY = :MEDCCOLCHR_N.FACTORY
                    AND COL_SET_ID = :MEDCCOLCHR_N.COL_SET_ID
                    AND COL_SET_VERSION = :MEDCCOLCHR_N.COL_SET_VERSION
                    AND SEQ_NUM > :MEDCCOLCHR_N.SEQ_NUM;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_update_medccolchr", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_medccolchr(int sel_type, struct MEDCCOLCHR_TAG *MEDCCOLCHR)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MEDCCOLCHR_N_TAG MEDCCOLCHR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_medccolchr(&MEDCCOLCHR_N, MEDCCOLCHR);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MEDCCOLCHR_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    CHAR_ID,
                    SEQ_NUM,
                    UNIT_COUNT,
                    VALUE_COUNT,
                    OPT_INPUT_FLAG,
                    BLANK_REC_SAVE_FLAG,
                    DISPLAY_PRECISION,
                    DEF_UNIT_FLAG,
                    DEF_UNIT_OVR_FLAG,
                    DEF_VALUE,
                    UNIT_TBL,
                    VALUE_TBL,
                    SPEC_OUT_COUNT,
                    SPEC_TYPE,
                    TARGET_VALUE,
                    UPPER_SPEC_LIMIT,
                    LOWER_SPEC_LIMIT,
                    UPPER_WARN_LIMIT,
                    LOWER_WARN_LIMIT,
                    UPPER_CUST_LIMIT,
                    LOWER_CUST_LIMIT,
                    SPEC_INFO,
                    SPEC_OUT_ALARM,
                    WARN_OUT_ALARM,
                    DERIVED_PARAM_FLAG,
                    DERIVED_PARAMETER,
                    DATA_TYPE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    NO_USE_SPM_VALUE_FLAG
                FROM MEDCCOLCHR
                WHERE FACTORY = :MEDCCOLCHR_N.FACTORY
                ORDER BY COL_SET_ID ASC;
            EXEC SQL OPEN DBC_MEDCCOLCHR_CUR_1;
            
            break;

        case 2:
            EXEC SQL DECLARE DBC_MEDCCOLCHR_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    CHAR_ID,
                    SEQ_NUM,
                    UNIT_COUNT,
                    VALUE_COUNT,
                    OPT_INPUT_FLAG,
                    BLANK_REC_SAVE_FLAG,
                    DISPLAY_PRECISION,
                    DEF_UNIT_FLAG,
                    DEF_UNIT_OVR_FLAG,
                    DEF_VALUE,
                    UNIT_TBL,
                    VALUE_TBL,
                    SPEC_OUT_COUNT,
                    SPEC_TYPE,
                    TARGET_VALUE,
                    UPPER_SPEC_LIMIT,
                    LOWER_SPEC_LIMIT,
                    UPPER_WARN_LIMIT,
                    LOWER_WARN_LIMIT,
                    UPPER_CUST_LIMIT,
                    LOWER_CUST_LIMIT,
                    SPEC_INFO,
                    SPEC_OUT_ALARM,
                    WARN_OUT_ALARM,
                    DERIVED_PARAM_FLAG,
                    DERIVED_PARAMETER,
                    DATA_TYPE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    NO_USE_SPM_VALUE_FLAG
                FROM MEDCCOLCHR
                WHERE FACTORY = :MEDCCOLCHR_N.FACTORY
                    AND COL_SET_ID = :MEDCCOLCHR_N.COL_SET_ID
                ORDER BY COL_SET_VERSION ASC;
            EXEC SQL OPEN DBC_MEDCCOLCHR_CUR_2;
            break;
            
        case 3:
            EXEC SQL DECLARE DBC_MEDCCOLCHR_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    CHAR_ID,
                    SEQ_NUM,
                    UNIT_COUNT,
                    VALUE_COUNT,
                    OPT_INPUT_FLAG,
                    BLANK_REC_SAVE_FLAG,
                    DISPLAY_PRECISION,
                    DEF_UNIT_FLAG,
                    DEF_UNIT_OVR_FLAG,
                    DEF_VALUE,
                    UNIT_TBL,
                    VALUE_TBL,
                    SPEC_OUT_COUNT,
                    SPEC_TYPE,
                    TARGET_VALUE,
                    UPPER_SPEC_LIMIT,
                    LOWER_SPEC_LIMIT,
                    UPPER_WARN_LIMIT,
                    LOWER_WARN_LIMIT,
                    UPPER_CUST_LIMIT,
                    LOWER_CUST_LIMIT,
                    SPEC_INFO,
                    SPEC_OUT_ALARM,
                    WARN_OUT_ALARM,
                    DERIVED_PARAM_FLAG,
                    DERIVED_PARAMETER,
                    DATA_TYPE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    NO_USE_SPM_VALUE_FLAG
                FROM MEDCCOLCHR
                WHERE FACTORY = :MEDCCOLCHR_N.FACTORY
                    AND COL_SET_ID = :MEDCCOLCHR_N.COL_SET_ID
                    AND COL_SET_VERSION = :MEDCCOLCHR_N.COL_SET_VERSION
                ORDER BY SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MEDCCOLCHR_CUR_3;
            break;
            
        case 4:
            EXEC SQL DECLARE DBC_MEDCCOLCHR_CUR_4 CURSOR FOR
                SELECT 
                    FACTORY,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    CHAR_ID,
                    SEQ_NUM,
                    UNIT_COUNT,
                    VALUE_COUNT,
                    OPT_INPUT_FLAG,
                    BLANK_REC_SAVE_FLAG,
                    DISPLAY_PRECISION,
                    DEF_UNIT_FLAG,
                    DEF_UNIT_OVR_FLAG,
                    DEF_VALUE,
                    UNIT_TBL,
                    VALUE_TBL,
                    SPEC_OUT_COUNT,
                    SPEC_TYPE,
                    TARGET_VALUE,
                    UPPER_SPEC_LIMIT,
                    LOWER_SPEC_LIMIT,
                    UPPER_WARN_LIMIT,
                    LOWER_WARN_LIMIT,
                    UPPER_CUST_LIMIT,
                    LOWER_CUST_LIMIT,
                    SPEC_INFO,
                    SPEC_OUT_ALARM,
                    WARN_OUT_ALARM,
                    DERIVED_PARAM_FLAG,
                    DERIVED_PARAMETER,
                    DATA_TYPE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    NO_USE_SPM_VALUE_FLAG
                FROM MEDCCOLCHR
                WHERE FACTORY = :MEDCCOLCHR_N.FACTORY
                    AND COL_SET_ID = :MEDCCOLCHR_N.COL_SET_ID
                    AND COL_SET_VERSION = :MEDCCOLCHR_N.COL_SET_VERSION
                    AND CHAR_ID >= :MEDCCOLCHR_N.CHAR_ID
                ORDER BY SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MEDCCOLCHR_CUR_4;
            break;

        case 5:
            EXEC SQL DECLARE DBC_MEDCCOLCHR_CUR_5 CURSOR FOR
                SELECT DISTINCT CHAR_ID, FACTORY
                FROM MEDCCOLCHR
                WHERE FACTORY = :MEDCCOLCHR_N.FACTORY
                    AND COL_SET_ID = :MEDCCOLCHR_N.COL_SET_ID
                ORDER BY CHAR_ID ASC;
            EXEC SQL OPEN DBC_MEDCCOLCHR_CUR_5;
            break;

        case 6:
            EXEC SQL DECLARE DBC_MEDCCOLCHR_CUR_6 CURSOR FOR
                SELECT 
                    FACTORY,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    CHAR_ID,
                    SEQ_NUM,
                    UNIT_COUNT,
                    VALUE_COUNT,
                    OPT_INPUT_FLAG,
                    BLANK_REC_SAVE_FLAG,
                    DISPLAY_PRECISION,
                    DEF_UNIT_FLAG,
                    DEF_UNIT_OVR_FLAG,
                    DEF_VALUE,
                    UNIT_TBL,
                    VALUE_TBL,
                    SPEC_OUT_COUNT,
                    SPEC_TYPE,
                    TARGET_VALUE,
                    UPPER_SPEC_LIMIT,
                    LOWER_SPEC_LIMIT,
                    UPPER_WARN_LIMIT,
                    LOWER_WARN_LIMIT,
                    UPPER_CUST_LIMIT,
                    LOWER_CUST_LIMIT,
                    SPEC_INFO,
                    SPEC_OUT_ALARM,
                    WARN_OUT_ALARM,
                    DERIVED_PARAM_FLAG,
                    DERIVED_PARAMETER,
                    DATA_TYPE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    NO_USE_SPM_VALUE_FLAG
                FROM MEDCCOLCHR
                WHERE FACTORY = :MEDCCOLCHR_N.FACTORY
                    AND COL_SET_ID = :MEDCCOLCHR_N.COL_SET_ID
                    AND COL_SET_VERSION = :MEDCCOLCHR_N.COL_SET_VERSION
                    AND DERIVED_PARAM_FLAG = :MEDCCOLCHR_N.DERIVED_PARAM_FLAG
                ORDER BY CHAR_ID ASC;
            EXEC SQL OPEN DBC_MEDCCOLCHR_CUR_6;
            break;
      
        case 7:
            EXEC SQL DECLARE DBC_MEDCCOLCHR_CUR_7 CURSOR FOR
                SELECT
                           A.FACTORY,
                           A.COL_SET_ID,
                           A.COL_SET_VERSION,
                           A.CHAR_ID,
                           A.SEQ_NUM,
                           A.UNIT_COUNT,
                           A.VALUE_COUNT,
                           A.OPT_INPUT_FLAG,
                           A.BLANK_REC_SAVE_FLAG,
                           A.DISPLAY_PRECISION,
                           A.DEF_UNIT_FLAG,
                           A.DEF_UNIT_OVR_FLAG,
                           A.DEF_VALUE,
                           A.UNIT_TBL,
                           A.VALUE_TBL,
                           A.SPEC_OUT_COUNT,
                           A.SPEC_TYPE,
                           A.TARGET_VALUE,
                           A.UPPER_SPEC_LIMIT,
                           A.LOWER_SPEC_LIMIT,
                           A.UPPER_WARN_LIMIT,
                           A.LOWER_WARN_LIMIT,
                           A.UPPER_CUST_LIMIT,
                           A.LOWER_CUST_LIMIT,
                           A.SPEC_INFO,
                           A.SPEC_OUT_ALARM,
                           A.WARN_OUT_ALARM,
                           A.DERIVED_PARAM_FLAG,
                           A.DERIVED_PARAMETER,
                           A.DATA_TYPE,
                           A.CREATE_USER_ID,
                           A.CREATE_TIME,
                           A.UPDATE_USER_ID,
                           A.UPDATE_TIME,
                           A.NO_USE_SPM_VALUE_FLAG
                FROM MEDCCOLCHR A, MEDCCHRDEF B
                WHERE A.FACTORY = :MEDCCOLCHR_N.FACTORY
                    AND A.FACTORY = B.FACTORY
                    AND A.COL_SET_ID = :MEDCCOLCHR_N.COL_SET_ID
                    AND A.COL_SET_VERSION = :MEDCCOLCHR_N.COL_SET_VERSION
                    AND A.CHAR_ID = B.CHAR_ID
                    AND B.VALUE_TYPE = 'N'
                ORDER BY A.SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MEDCCOLCHR_CUR_7;
            break;  
                     
        case 8:
            EXEC SQL DECLARE DBC_MEDCCOLCHR_CUR_8 CURSOR FOR
                SELECT
                           A.FACTORY,
                           A.COL_SET_ID,
                           A.COL_SET_VERSION,
                           A.CHAR_ID,
                           A.SEQ_NUM,
                           A.UNIT_COUNT,
                           A.VALUE_COUNT,
                           A.OPT_INPUT_FLAG,
                           A.BLANK_REC_SAVE_FLAG,
                           A.DISPLAY_PRECISION,
                           A.DEF_UNIT_FLAG,
                           A.DEF_UNIT_OVR_FLAG,
                           A.DEF_VALUE,
                           A.UNIT_TBL,
                           A.VALUE_TBL,
                           A.SPEC_OUT_COUNT,
                           A.SPEC_TYPE,
                           A.TARGET_VALUE,
                           A.UPPER_SPEC_LIMIT,
                           A.LOWER_SPEC_LIMIT,
                           A.UPPER_WARN_LIMIT,
                           A.LOWER_WARN_LIMIT,
                           A.UPPER_CUST_LIMIT,
                           A.LOWER_CUST_LIMIT,
                           A.SPEC_INFO,
                           A.SPEC_OUT_ALARM,
                           A.WARN_OUT_ALARM,
                           A.DERIVED_PARAM_FLAG,
                           A.DERIVED_PARAMETER,
                           A.DATA_TYPE,
                           A.CREATE_USER_ID,
                           A.CREATE_TIME,
                           A.UPDATE_USER_ID,
                           A.UPDATE_TIME,
                           A.NO_USE_SPM_VALUE_FLAG
                FROM MEDCCOLCHR A, MEDCCHRDEF B
                WHERE A.FACTORY = :MEDCCOLCHR_N.FACTORY
                    AND A.FACTORY = B.FACTORY
                    AND A.COL_SET_ID = :MEDCCOLCHR_N.COL_SET_ID
                    AND A.COL_SET_VERSION = :MEDCCOLCHR_N.COL_SET_VERSION
                    AND A.CHAR_ID = B.CHAR_ID
                    AND B.VALUE_TYPE = 'A'
                ORDER BY A.SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MEDCCOLCHR_CUR_8;
            break;  
                        

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_medccolchr", sel_type);
}


