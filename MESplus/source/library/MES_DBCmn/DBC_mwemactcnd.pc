                    OPERATOR,
                    VALUE_TYPE,
                    VALUE_1,
                    VALUE_2,
                    R_BRACKET
                FROM MWEMACTCND
                WHERE FACTORY = :MWEMACTCND_N.FACTORY
                    AND WORK_PROC_TYPE = :MWEMACTCND_N.WORK_PROC_TYPE
                    AND ACTION_ID = :MWEMACTCND_N.ACTION_ID
                ORDER BY SEQ_NO ASC;
            EXEC SQL OPEN DBC_MWEMACTCND_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
