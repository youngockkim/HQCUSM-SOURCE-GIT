    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWEMACTCND_CUR_1 CURSOR FOR
                SELECT 
                    CREATE_TIME,
                    CREATE_USER_ID,
                    UPDATE_TIME,
                    UPDATE_USER_ID,
                    FACTORY,
                    WORK_PROC_TYPE,
                    ACTION_ID,
                    SEQ_NO,
                    AND_OR,
                    L_BRACKET,
                    COND_TYPE,
                    FIELD_NAME_1,
                    FIELD_NAME_2,
