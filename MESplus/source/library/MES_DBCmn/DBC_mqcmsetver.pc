/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mqcmsetver(int sel_type, struct MQCMSETVER_TAG *MQCMSETVER)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MQCMSETVER_N_TAG MQCMSETVER_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mqcmsetver(&MQCMSETVER_N, MQCMSETVER);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MQCMSETVER_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    INSP_SET_ID,
                    INSP_SET_VERSION,
                    APPLY_START_TIME,
                    APPLY_END_TIME,
                    APPROVAL_FLAG,
                    APPROVAL_USER_ID,
                    APPROVAL_TIME,
                    RELEASE_FLAG,
                    RELEASE_USER_ID,
                    RELEASE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MQCMSETVER
                WHERE FACTORY = :MQCMSETVER_N.FACTORY
                    AND INSP_SET_ID = :MQCMSETVER_N.INSP_SET_ID
                    AND INSP_SET_VERSION >= :MQCMSETVER_N.INSP_SET_VERSION
                ORDER BY FACTORY ASC,
                    INSP_SET_ID ASC,
                    INSP_SET_VERSION ASC;
            EXEC SQL OPEN DBC_MQCMSETVER_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE DBC_MQCMSETVER_CUR_2 CURSOR FOR
                SELECT INSP_SET_ID, INSP_SET_VERSION 
                FROM MQCMSETVER
                WHERE FACTORY = :MQCMSETVER_N.FACTORY
                    AND INSP_SET_ID = :MQCMSETVER_N.INSP_SET_ID
                    AND (APPLY_START_TIME = ' ' OR APPLY_START_TIME < :MQCMSETVER_N.APPLY_START_TIME)
                    AND (APPLY_END_TIME = ' ' OR APPLY_END_TIME > :MQCMSETVER_N.APPLY_END_TIME)
                    AND RELEASE_FLAG = 'Y'
                ORDER BY INSP_SET_VERSION DESC;
            EXEC SQL OPEN DBC_MQCMSETVER_CUR_2;
            break;
            
        case 51:
            EXEC SQL DECLARE DBC_MQCMSETVER_CUR_51 CURSOR FOR
                SELECT SV.INSP_SET_ID, SV.INSP_SET_VERSION 
                FROM MQCMSETVER SV, MQCMBATSTS LS
                WHERE LS.FACTORY = :MQCMSETVER_N.FACTORY
                    AND SV.FACTORY = LS.FACTORY
                    AND SV.INSP_SET_ID = LS.INSP_SET_ID
                    AND LS.BATCH_ID = :MQCMSETVER_N.INSP_SET_ID
                    AND SV.RELEASE_FLAG = 'Y'
                    AND (SV.APPLY_START_TIME = ' ' OR SV.APPLY_START_TIME < :MQCMSETVER_N.APPLY_START_TIME)
                    AND (SV.APPLY_END_TIME = ' ' OR SV.APPLY_END_TIME > :MQCMSETVER_N.APPLY_END_TIME)
                ORDER BY SV.INSP_SET_VERSION DESC;
            EXEC SQL OPEN DBC_MQCMSETVER_CUR_51;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mqcmsetver", sel_type);
}


