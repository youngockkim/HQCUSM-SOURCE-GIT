    DB_stop_query_timer("DBC_update_mrastoldft", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mrastoldft(int sel_type, struct MRASTOLDFT_TAG *MRASTOLDFT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASTOLDFT_N_TAG MRASTOLDFT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mrastoldft(&MRASTOLDFT_N, MRASTOLDFT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MRASTOLDFT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    TOOL_ID,
                    TOOL_TYPE,
                    TOOL_EVENT_ID,
                    HIST_SEQ,
                    HIST_DEL_FLAG,
                    DEFECT_CODE,
                    DEFECT_QTY,
                    CELL_X,
                    CELL_Y,
                    CELL_Z,
                    LOC_X,
                    LOC_Y,
                    LOC_Z,
                    TRAN_TIME,
                    TRAN_USER_ID,
                    CLEAN_FLAG,
                    CLEAN_HIST_SEQ,
                    CLEAN_USER_ID,
                    CLEAN_TIME,
                    LOT_ID,
                    SUBLOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    CAUSE_FLOW,
                    CAUSE_OPER,
                    CAUSE_RES_ID,
                    CAUSE_SUBRES_ID,
                    CHK_USER_ID1,
                    CHK_USER_ID2,
                    ATTACH_FILE_1,
                    ATTACH_FILE_2,
                    ATTACH_FILE_3,
                    ATTACH_FILE_4,
                    ATTACH_FILE_5,
                    DEFECT_COMMENT
                FROM MRASTOLDFT
                WHERE FACTORY = :MRASTOLDFT_N.FACTORY 
                    AND TOOL_ID = :MRASTOLDFT_N.TOOL_ID
                    AND (HIST_SEQ > :MRASTOLDFT_N.HIST_SEQ
                        OR (HIST_SEQ = :MRASTOLDFT_N.HIST_SEQ AND DEFECT_CODE > :MRASTOLDFT_N.DEFECT_CODE)
                        OR (HIST_SEQ = :MRASTOLDFT_N.HIST_SEQ AND DEFECT_CODE = :MRASTOLDFT_N.DEFECT_CODE AND LOC_X > :MRASTOLDFT_N.LOC_X)
                        OR (HIST_SEQ = :MRASTOLDFT_N.HIST_SEQ AND DEFECT_CODE = :MRASTOLDFT_N.DEFECT_CODE AND LOC_X = :MRASTOLDFT_N.LOC_X AND LOC_Y > :MRASTOLDFT_N.LOC_Y)
                        OR (HIST_SEQ = :MRASTOLDFT_N.HIST_SEQ AND DEFECT_CODE = :MRASTOLDFT_N.DEFECT_CODE AND LOC_X = :MRASTOLDFT_N.LOC_X AND LOC_Y = :MRASTOLDFT_N.LOC_Y AND LOC_Z >= :MRASTOLDFT_N.LOC_Z))
                ORDER BY FACTORY ASC,
                    TOOL_ID ASC,
                    HIST_SEQ ASC,
                    DEFECT_CODE ASC,
                    LOC_X ASC,
                    LOC_Y ASC,
                    LOC_Z ASC;
            EXEC SQL OPEN DBC_MRASTOLDFT_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MRASTOLDFT_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    TOOL_ID,
                    TOOL_TYPE,
                    TOOL_EVENT_ID,
                    HIST_SEQ,
                    HIST_DEL_FLAG,
                    DEFECT_CODE,
                    DEFECT_QTY,
                    CELL_X,
                    CELL_Y,
                    CELL_Z,
                    LOC_X,
                    LOC_Y,
                    LOC_Z,
                    TRAN_TIME,
                    TRAN_USER_ID,
                    CLEAN_FLAG,
                    CLEAN_HIST_SEQ,
                    CLEAN_USER_ID,
                    CLEAN_TIME,
                    LOT_ID,
                    SUBLOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    CAUSE_FLOW,
                    CAUSE_OPER,
                    CAUSE_RES_ID,
                    CAUSE_SUBRES_ID,
                    CHK_USER_ID1,
                    CHK_USER_ID2,
                    ATTACH_FILE_1,
                    ATTACH_FILE_2,
                    ATTACH_FILE_3,
                    ATTACH_FILE_4,
                    ATTACH_FILE_5,
                    DEFECT_COMMENT
                FROM MRASTOLDFT
                WHERE FACTORY = :MRASTOLDFT_N.FACTORY 
                    AND TOOL_ID = :MRASTOLDFT_N.TOOL_ID
                    AND HIST_SEQ = :MRASTOLDFT_N.HIST_SEQ
                    AND (DEFECT_CODE > :MRASTOLDFT_N.DEFECT_CODE
                        OR (DEFECT_CODE = :MRASTOLDFT_N.DEFECT_CODE AND LOC_X > :MRASTOLDFT_N.LOC_X)
                        OR (DEFECT_CODE = :MRASTOLDFT_N.DEFECT_CODE AND LOC_X = :MRASTOLDFT_N.LOC_X AND LOC_Y > :MRASTOLDFT_N.LOC_Y)
                        OR (DEFECT_CODE = :MRASTOLDFT_N.DEFECT_CODE AND LOC_X = :MRASTOLDFT_N.LOC_X AND LOC_Y = :MRASTOLDFT_N.LOC_Y AND LOC_Z >= :MRASTOLDFT_N.LOC_Z))
                ORDER BY FACTORY ASC,
                    TOOL_ID ASC,
                    HIST_SEQ ASC,
                    DEFECT_CODE ASC,
                    LOC_X ASC,
                    LOC_Y ASC,
                    LOC_Z ASC;
            EXEC SQL OPEN DBC_MRASTOLDFT_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE DBC_MRASTOLDFT_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    TOOL_ID,
                    TOOL_TYPE,
                    TOOL_EVENT_ID,
                    HIST_SEQ,
                    HIST_DEL_FLAG,
                    DEFECT_CODE,
                    DEFECT_QTY,
                    CELL_X,
                    CELL_Y,
                    CELL_Z,
                    LOC_X,
                    LOC_Y,
                    LOC_Z,
                    TRAN_TIME,
                    TRAN_USER_ID,
                    CLEAN_FLAG,
                    CLEAN_HIST_SEQ,
                    CLEAN_USER_ID,
                    CLEAN_TIME,
                    LOT_ID,
                    SUBLOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    CAUSE_FLOW,
                    CAUSE_OPER,
                    CAUSE_RES_ID,
                    CAUSE_SUBRES_ID,
                    CHK_USER_ID1,
                    CHK_USER_ID2,
                    ATTACH_FILE_1,
                    ATTACH_FILE_2,
                    ATTACH_FILE_3,
                    ATTACH_FILE_4,
                    ATTACH_FILE_5,
                    DEFECT_COMMENT
                FROM MRASTOLDFT
                WHERE FACTORY = :MRASTOLDFT_N.FACTORY 
                    AND TOOL_ID = :MRASTOLDFT_N.TOOL_ID
                    AND CELL_X = :MRASTOLDFT_N.CELL_X
                    AND CELL_Y = :MRASTOLDFT_N.CELL_Y
                    AND CELL_Z = :MRASTOLDFT_N.CELL_Z
                    AND (HIST_SEQ > :MRASTOLDFT_N.HIST_SEQ
                        OR (HIST_SEQ = :MRASTOLDFT_N.HIST_SEQ AND DEFECT_CODE > :MRASTOLDFT_N.DEFECT_CODE)
                        OR (HIST_SEQ = :MRASTOLDFT_N.HIST_SEQ AND DEFECT_CODE = :MRASTOLDFT_N.DEFECT_CODE AND LOC_X > :MRASTOLDFT_N.LOC_X)
                        OR (HIST_SEQ = :MRASTOLDFT_N.HIST_SEQ AND DEFECT_CODE = :MRASTOLDFT_N.DEFECT_CODE AND LOC_X = :MRASTOLDFT_N.LOC_X AND LOC_Y > :MRASTOLDFT_N.LOC_Y)
                        OR (HIST_SEQ = :MRASTOLDFT_N.HIST_SEQ AND DEFECT_CODE = :MRASTOLDFT_N.DEFECT_CODE AND LOC_X = :MRASTOLDFT_N.LOC_X AND LOC_Y = :MRASTOLDFT_N.LOC_Y AND LOC_Z >= :MRASTOLDFT_N.LOC_Z))
                ORDER BY FACTORY ASC,
                    TOOL_ID ASC,
                    HIST_SEQ ASC,
                    DEFECT_CODE ASC,
                    LOC_X ASC,
                    LOC_Y ASC,
                    LOC_Z ASC;
            EXEC SQL OPEN DBC_MRASTOLDFT_CUR_3;
            break;

        case 4:
            EXEC SQL DECLARE DBC_MRASTOLDFT_CUR_4 CURSOR FOR
                SELECT 
                    FACTORY,
                    TOOL_ID,
                    TOOL_TYPE,
                    TOOL_EVENT_ID,
                    HIST_SEQ,
                    HIST_DEL_FLAG,
                    DEFECT_CODE,
                    DEFECT_QTY,
                    CELL_X,
                    CELL_Y,
                    CELL_Z,
                    LOC_X,
                    LOC_Y,
                    LOC_Z,
                    TRAN_TIME,
                    TRAN_USER_ID,
                    CLEAN_FLAG,
                    CLEAN_HIST_SEQ,
                    CLEAN_USER_ID,
                    CLEAN_TIME,
                    LOT_ID,
                    SUBLOT_ID,
                    RES_ID,
                    SUBRES_ID,
                    CAUSE_FLOW,
                    CAUSE_OPER,
                    CAUSE_RES_ID,
                    CAUSE_SUBRES_ID,
                    CHK_USER_ID1,
                    CHK_USER_ID2,
                    ATTACH_FILE_1,
                    ATTACH_FILE_2,
                    ATTACH_FILE_3,
                    ATTACH_FILE_4,
                    ATTACH_FILE_5,
                    DEFECT_COMMENT
                FROM MRASTOLDFT
                WHERE FACTORY = :MRASTOLDFT_N.FACTORY 
                    AND TOOL_ID = :MRASTOLDFT_N.TOOL_ID
                    AND DEFECT_CODE = :MRASTOLDFT_N.DEFECT_CODE
                    AND (HIST_SEQ > :MRASTOLDFT_N.HIST_SEQ
                        OR (HIST_SEQ = :MRASTOLDFT_N.HIST_SEQ AND LOC_X > :MRASTOLDFT_N.LOC_X)
                        OR (HIST_SEQ = :MRASTOLDFT_N.HIST_SEQ AND LOC_X = :MRASTOLDFT_N.LOC_X AND LOC_Y > :MRASTOLDFT_N.LOC_Y)
                        OR (HIST_SEQ = :MRASTOLDFT_N.HIST_SEQ AND LOC_X = :MRASTOLDFT_N.LOC_X AND LOC_Y = :MRASTOLDFT_N.LOC_Y AND LOC_Z >= :MRASTOLDFT_N.LOC_Z))
                ORDER BY FACTORY ASC,
                    TOOL_ID ASC,
                    HIST_SEQ ASC,
                    DEFECT_CODE ASC,
                    LOC_X ASC,
                    LOC_Y ASC,
                    LOC_Z ASC;
            EXEC SQL OPEN DBC_MRASTOLDFT_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mrastoldft", sel_type);
}


