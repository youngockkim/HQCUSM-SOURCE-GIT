/* SQL CURSOR CLOSE Function */
void DBC_close_mrastoldft(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MRASTOLDFT_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MRASTOLDFT_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MRASTOLDFT_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MRASTOLDFT_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mrastoldft", sel_type);
}


/* Initialize Function */
void DBC_init_mrastoldft(struct MRASTOLDFT_TAG *MRASTOLDFT)
{
    /* memset by Space */
    memset(MRASTOLDFT, ' ', sizeof(struct MRASTOLDFT_TAG));
    
    MRASTOLDFT->HIST_SEQ = 0;
    MRASTOLDFT->DEFECT_QTY = 0;
    MRASTOLDFT->CELL_X = 0;
    MRASTOLDFT->CELL_Y = 0;
    MRASTOLDFT->CELL_Z = 0;
    MRASTOLDFT->LOC_X = 0;
    MRASTOLDFT->LOC_Y = 0;
    MRASTOLDFT->LOC_Z = 0;
    MRASTOLDFT->CLEAN_HIST_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mrastoldft(struct MRASTOLDFT_N_TAG *MRASTOLDFT_N, struct MRASTOLDFT_TAG *MRASTOLDFT)
{
    /* memset by NULL */
    memset(MRASTOLDFT_N, '\0', sizeof(struct MRASTOLDFT_N_TAG));
    
    MEMCPY_AN(MRASTOLDFT_N->FACTORY, MRASTOLDFT->FACTORY, sizeof(MRASTOLDFT->FACTORY));
    MEMCPY_AN(MRASTOLDFT_N->TOOL_ID, MRASTOLDFT->TOOL_ID, sizeof(MRASTOLDFT->TOOL_ID));
    MEMCPY_AN(MRASTOLDFT_N->TOOL_TYPE, MRASTOLDFT->TOOL_TYPE, sizeof(MRASTOLDFT->TOOL_TYPE));
    MEMCPY_AN(MRASTOLDFT_N->TOOL_EVENT_ID, MRASTOLDFT->TOOL_EVENT_ID, sizeof(MRASTOLDFT->TOOL_EVENT_ID));
    MRASTOLDFT_N->HIST_SEQ = MRASTOLDFT->HIST_SEQ;
    MRASTOLDFT_N->HIST_DEL_FLAG[0] = MRASTOLDFT->HIST_DEL_FLAG;
    MEMCPY_AN(MRASTOLDFT_N->DEFECT_CODE, MRASTOLDFT->DEFECT_CODE, sizeof(MRASTOLDFT->DEFECT_CODE));
    MRASTOLDFT_N->DEFECT_QTY = MRASTOLDFT->DEFECT_QTY;
    MRASTOLDFT_N->CELL_X = MRASTOLDFT->CELL_X;
    MRASTOLDFT_N->CELL_Y = MRASTOLDFT->CELL_Y;
    MRASTOLDFT_N->CELL_Z = MRASTOLDFT->CELL_Z;
    MRASTOLDFT_N->LOC_X = MRASTOLDFT->LOC_X;
    MRASTOLDFT_N->LOC_Y = MRASTOLDFT->LOC_Y;
    MRASTOLDFT_N->LOC_Z = MRASTOLDFT->LOC_Z;
    MEMCPY_AN(MRASTOLDFT_N->TRAN_TIME, MRASTOLDFT->TRAN_TIME, sizeof(MRASTOLDFT->TRAN_TIME));
    MEMCPY_AN(MRASTOLDFT_N->TRAN_USER_ID, MRASTOLDFT->TRAN_USER_ID, sizeof(MRASTOLDFT->TRAN_USER_ID));
    MRASTOLDFT_N->CLEAN_FLAG[0] = MRASTOLDFT->CLEAN_FLAG;
    MRASTOLDFT_N->CLEAN_HIST_SEQ = MRASTOLDFT->CLEAN_HIST_SEQ;
    MEMCPY_AN(MRASTOLDFT_N->CLEAN_USER_ID, MRASTOLDFT->CLEAN_USER_ID, sizeof(MRASTOLDFT->CLEAN_USER_ID));
    MEMCPY_AN(MRASTOLDFT_N->CLEAN_TIME, MRASTOLDFT->CLEAN_TIME, sizeof(MRASTOLDFT->CLEAN_TIME));
    MEMCPY_AN(MRASTOLDFT_N->LOT_ID, MRASTOLDFT->LOT_ID, sizeof(MRASTOLDFT->LOT_ID));
    MEMCPY_AN(MRASTOLDFT_N->SUBLOT_ID, MRASTOLDFT->SUBLOT_ID, sizeof(MRASTOLDFT->SUBLOT_ID));
    MEMCPY_AN(MRASTOLDFT_N->RES_ID, MRASTOLDFT->RES_ID, sizeof(MRASTOLDFT->RES_ID));
    MEMCPY_AN(MRASTOLDFT_N->SUBRES_ID, MRASTOLDFT->SUBRES_ID, sizeof(MRASTOLDFT->SUBRES_ID));
