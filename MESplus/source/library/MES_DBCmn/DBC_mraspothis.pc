                    TRAN_CMF_8,
                    TRAN_CMF_9,
                    TRAN_CMF_10,
                    TRAN_CMF_11,
                    TRAN_CMF_12,
                    TRAN_CMF_13,
                    TRAN_CMF_14,
                    TRAN_CMF_15,
                    TRAN_CMF_16,
                    TRAN_CMF_17,
                    TRAN_CMF_18,
                    TRAN_CMF_19,
                    TRAN_CMF_20,
                    TRAN_USER_ID,
                    TRAN_COMMENT
                FROM MRASPOTHIS
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SUBRES_ID ASC,
                    PORT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MRASPOTHIS_CUR_1;
            break;
            
        case 2:
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "FACTORY, ");
            sprintf(sql + strlen(sql),   "RES_ID, ");
            sprintf(sql + strlen(sql),   "SUBRES_ID, ");
            sprintf(sql + strlen(sql),   "PORT_ID, ");
            sprintf(sql + strlen(sql),   "HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "TRAN_CODE, ");
            sprintf(sql + strlen(sql),   "TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "SYS_TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "TRS_STATE, ");
            sprintf(sql + strlen(sql),   "ASC_STATE, ");
            sprintf(sql + strlen(sql),   "ASC_OBJ_ID, ");
            sprintf(sql + strlen(sql),   "ACC_STATE, ");
            sprintf(sql + strlen(sql),   "RSV_STATE, ");
            sprintf(sql + strlen(sql),   "RSV_OBJ_ID, ");
            sprintf(sql + strlen(sql),   "LOT_ID, ");
            sprintf(sql + strlen(sql),   "CRR_ID, ");
            sprintf(sql + strlen(sql),   "BCR_STATUS_FLAG, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_1, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_2, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_3, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_4, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_5, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_6, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_7, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_8, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_9, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_10, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_11, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_12, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_13, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_14, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_15, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_16, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_17, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_18, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_19, ");
            sprintf(sql + strlen(sql),   "TRAN_CMF_20, ");
            sprintf(sql + strlen(sql),   "TRAN_USER_ID, ");
            sprintf(sql + strlen(sql),   "TRAN_COMMENT ");
            sprintf(sql + strlen(sql), "FROM MRASPOTHIS ");

            make_valid_quote(ts, MRASPOTHIS_N.FACTORY);
            sprintf(sql + strlen(sql), "WHERE FACTORY = '%s' ", ts);
            
            make_valid_quote(ts, MRASPOTHIS_N.RES_ID);
            sprintf(sql + strlen(sql), "AND RES_ID = '%s' ", ts);
            
            make_valid_quote(ts, MRASPOTHIS_N.SUBRES_ID);
            sprintf(sql + strlen(sql), "AND SUBRES_ID = '%s' ", ts);
            
            make_valid_quote(ts, MRASPOTHIS_N.PORT_ID);
            sprintf(sql + strlen(sql), "AND PORT_ID = '%s' ", ts);
            
            sprintf(sql + strlen(sql), "AND HIST_SEQ <= '%d' ", MRASPOTHIS_N.HIST_SEQ);

            if(ISSPACE(DBC_Q_COND.FROM_TIME, sizeof(DBC_Q_COND.FROM_TIME)) == DB_FALSE)
            {
                make_valid_quote(ts, DBC_Q_COND_N.FROM_TIME);
                sprintf(sql + strlen(sql), "AND TRAN_TIME >= '%s' ", ts);
            }
            if(ISSPACE(DBC_Q_COND.TO_TIME, sizeof(DBC_Q_COND.TO_TIME)) == DB_FALSE)
            {
                make_valid_quote(ts, DBC_Q_COND_N.TO_TIME);
                sprintf(sql + strlen(sql), "AND TRAN_TIME <= '%s' ", ts);
            }
            
            sprintf(sql + strlen(sql), "ORDER BY HIST_SEQ DESC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE DBC_MRASPOTHIS_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN DBC_MRASPOTHIS_CUR_2;                 
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_mraspothis", sel_type);
}


/* SQL CURSOR FETCH Function */
void DBC_fetch_mraspothis(int sel_type, struct MRASPOTHIS_TAG *MRASPOTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASPOTHIS_N_TAG MRASPOTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH DBC_MRASPOTHIS_CUR_1 INTO 
                                                    :MRASPOTHIS_N.FACTORY,
                                                    :MRASPOTHIS_N.RES_ID,
                                                    :MRASPOTHIS_N.SUBRES_ID,
                                                    :MRASPOTHIS_N.PORT_ID,
                                                    :MRASPOTHIS_N.HIST_SEQ,
                                                    :MRASPOTHIS_N.TRAN_CODE,
                                                    :MRASPOTHIS_N.TRAN_TIME,
                                                    :MRASPOTHIS_N.SYS_TRAN_TIME,
                                                    :MRASPOTHIS_N.TRS_STATE,
                                                    :MRASPOTHIS_N.ASC_STATE,
                                                    :MRASPOTHIS_N.ASC_OBJ_ID,
                                                    :MRASPOTHIS_N.ACC_STATE,
                                                    :MRASPOTHIS_N.RSV_STATE,
                                                    :MRASPOTHIS_N.RSV_OBJ_ID,
                                                    :MRASPOTHIS_N.LOT_ID,
                                                    :MRASPOTHIS_N.CRR_ID,
                                                    :MRASPOTHIS_N.BCR_STATUS_FLAG,
                                                    :MRASPOTHIS_N.TRAN_CMF_1,
                                                    :MRASPOTHIS_N.TRAN_CMF_2,
                                                    :MRASPOTHIS_N.TRAN_CMF_3,
                                                    :MRASPOTHIS_N.TRAN_CMF_4,
                                                    :MRASPOTHIS_N.TRAN_CMF_5,
                                                    :MRASPOTHIS_N.TRAN_CMF_6,
                                                    :MRASPOTHIS_N.TRAN_CMF_7,
                                                    :MRASPOTHIS_N.TRAN_CMF_8,
                                                    :MRASPOTHIS_N.TRAN_CMF_9,
                                                    :MRASPOTHIS_N.TRAN_CMF_10,
                                                    :MRASPOTHIS_N.TRAN_CMF_11,
                                                    :MRASPOTHIS_N.TRAN_CMF_12,
                                                    :MRASPOTHIS_N.TRAN_CMF_13,
                                                    :MRASPOTHIS_N.TRAN_CMF_14,
                                                    :MRASPOTHIS_N.TRAN_CMF_15,
                                                    :MRASPOTHIS_N.TRAN_CMF_16,
                                                    :MRASPOTHIS_N.TRAN_CMF_17,
                                                    :MRASPOTHIS_N.TRAN_CMF_18,
                                                    :MRASPOTHIS_N.TRAN_CMF_19,
                                                    :MRASPOTHIS_N.TRAN_CMF_20,
                                                    :MRASPOTHIS_N.TRAN_USER_ID,
                                                    :MRASPOTHIS_N.TRAN_COMMENT;
            break;

        case 2:
            EXEC SQL FETCH DBC_MRASPOTHIS_CUR_2 INTO 
                                                    :MRASPOTHIS_N.FACTORY,
                                                    :MRASPOTHIS_N.RES_ID,
                                                    :MRASPOTHIS_N.SUBRES_ID,
                                                    :MRASPOTHIS_N.PORT_ID,
                                                    :MRASPOTHIS_N.HIST_SEQ,
                                                    :MRASPOTHIS_N.TRAN_CODE,
                                                    :MRASPOTHIS_N.TRAN_TIME,
                                                    :MRASPOTHIS_N.SYS_TRAN_TIME,
                                                    :MRASPOTHIS_N.TRS_STATE,
                                                    :MRASPOTHIS_N.ASC_STATE,
                                                    :MRASPOTHIS_N.ASC_OBJ_ID,
                                                    :MRASPOTHIS_N.ACC_STATE,
                                                    :MRASPOTHIS_N.RSV_STATE,
                                                    :MRASPOTHIS_N.RSV_OBJ_ID,
                                                    :MRASPOTHIS_N.LOT_ID,
                                                    :MRASPOTHIS_N.CRR_ID,
                                                    :MRASPOTHIS_N.BCR_STATUS_FLAG,
                                                    :MRASPOTHIS_N.TRAN_CMF_1,
                                                    :MRASPOTHIS_N.TRAN_CMF_2,
                                                    :MRASPOTHIS_N.TRAN_CMF_3,
                                                    :MRASPOTHIS_N.TRAN_CMF_4,
                                                    :MRASPOTHIS_N.TRAN_CMF_5,
                                                    :MRASPOTHIS_N.TRAN_CMF_6,
                                                    :MRASPOTHIS_N.TRAN_CMF_7,
                                                    :MRASPOTHIS_N.TRAN_CMF_8,
                                                    :MRASPOTHIS_N.TRAN_CMF_9,
                                                    :MRASPOTHIS_N.TRAN_CMF_10,
                                                    :MRASPOTHIS_N.TRAN_CMF_11,
                                                    :MRASPOTHIS_N.TRAN_CMF_12,
                                                    :MRASPOTHIS_N.TRAN_CMF_13,
                                                    :MRASPOTHIS_N.TRAN_CMF_14,
                                                    :MRASPOTHIS_N.TRAN_CMF_15,
                                                    :MRASPOTHIS_N.TRAN_CMF_16,
                                                    :MRASPOTHIS_N.TRAN_CMF_17,
                                                    :MRASPOTHIS_N.TRAN_CMF_18,
                                                    :MRASPOTHIS_N.TRAN_CMF_19,
                                                    :MRASPOTHIS_N.TRAN_CMF_20,
                                                    :MRASPOTHIS_N.TRAN_USER_ID,
                                                    :MRASPOTHIS_N.TRAN_COMMENT;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mraspothis(&MRASPOTHIS_N, MRASPOTHIS);
    }
    DB_stop_query_timer("DBC_fetch_mraspothis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void DBC_close_mraspothis(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MRASPOTHIS_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE DBC_MRASPOTHIS_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("DBC_close_mraspothis", sel_type);
}


/* Initialize Function */
void DBC_init_mraspothis(struct MRASPOTHIS_TAG *MRASPOTHIS)
{
    /* memset by Space */
    memset(MRASPOTHIS, ' ', sizeof(struct MRASPOTHIS_TAG));
    
    MRASPOTHIS->HIST_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_mraspothis(struct MRASPOTHIS_N_TAG *MRASPOTHIS_N, struct MRASPOTHIS_TAG *MRASPOTHIS)
{
    /* memset by NULL */
    memset(MRASPOTHIS_N, '\0', sizeof(struct MRASPOTHIS_N_TAG));
    
    MEMCPY_AN(MRASPOTHIS_N->FACTORY, MRASPOTHIS->FACTORY, sizeof(MRASPOTHIS->FACTORY));
    MEMCPY_AN(MRASPOTHIS_N->RES_ID, MRASPOTHIS->RES_ID, sizeof(MRASPOTHIS->RES_ID));
    MEMCPY_AN(MRASPOTHIS_N->SUBRES_ID, MRASPOTHIS->SUBRES_ID, sizeof(MRASPOTHIS->SUBRES_ID));
    MEMCPY_AN(MRASPOTHIS_N->PORT_ID, MRASPOTHIS->PORT_ID, sizeof(MRASPOTHIS->PORT_ID));
    MRASPOTHIS_N->HIST_SEQ = MRASPOTHIS->HIST_SEQ;
