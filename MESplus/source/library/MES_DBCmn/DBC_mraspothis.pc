    MEMCPY_AN(MRASPOTHIS_N->TRAN_TIME, MRASPOTHIS->TRAN_TIME, sizeof(MRASPOTHIS->TRAN_TIME));
    MEMCPY_AN(MRASPOTHIS_N->SYS_TRAN_TIME, MRASPOTHIS->SYS_TRAN_TIME, sizeof(MRASPOTHIS->SYS_TRAN_TIME));
    MEMCPY_AN(MRASPOTHIS_N->TRS_STATE, MRASPOTHIS->TRS_STATE, sizeof(MRASPOTHIS->TRS_STATE));
