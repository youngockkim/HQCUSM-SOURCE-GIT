/* Del Null Function */
void DBC_del_null_mraspothis(struct MRASPOTHIS_N_TAG *MRASPOTHIS_N, struct MRASPOTHIS_TAG *MRASPOTHIS)
{
    MEMCPY_DN(MRASPOTHIS->FACTORY, MRASPOTHIS_N->FACTORY, sizeof(MRASPOTHIS->FACTORY));
    MEMCPY_DN(MRASPOTHIS->RES_ID, MRASPOTHIS_N->RES_ID, sizeof(MRASPOTHIS->RES_ID));
    MEMCPY_DN(MRASPOTHIS->SUBRES_ID, MRASPOTHIS_N->SUBRES_ID, sizeof(MRASPOTHIS->SUBRES_ID));
    MEMCPY_DN(MRASPOTHIS->PORT_ID, MRASPOTHIS_N->PORT_ID, sizeof(MRASPOTHIS->PORT_ID));
    MRASPOTHIS->HIST_SEQ = MRASPOTHIS_N->HIST_SEQ;
    MEMCPY_DN(MRASPOTHIS->TRAN_CODE, MRASPOTHIS_N->TRAN_CODE, sizeof(MRASPOTHIS->TRAN_CODE));
    MEMCPY_DN(MRASPOTHIS->TRAN_TIME, MRASPOTHIS_N->TRAN_TIME, sizeof(MRASPOTHIS->TRAN_TIME));
    MEMCPY_DN(MRASPOTHIS->SYS_TRAN_TIME, MRASPOTHIS_N->SYS_TRAN_TIME, sizeof(MRASPOTHIS->SYS_TRAN_TIME));
