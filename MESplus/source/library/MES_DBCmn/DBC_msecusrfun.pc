/* Add Null Function */
void DBC_add_null_msecusrfun(struct MSECUSRFUN_N_TAG *MSECUSRFUN_N, struct MSECUSRFUN_TAG *MSECUSRFUN)
{
    /* memset by NULL */
    memset(MSECUSRFUN_N, '\0', sizeof(struct MSECUSRFUN_N_TAG));
    
    MEMCPY_AN(MSECUSRFUN_N->FACTORY, MSECUSRFUN->FACTORY, sizeof(MSECUSRFUN->FACTORY));
    MEMCPY_AN(MSECUSRFUN_N->PROGRAM_ID, MSECUSRFUN->PROGRAM_ID, sizeof(MSECUSRFUN->PROGRAM_ID));
    MEMCPY_AN(MSECUSRFUN_N->USER_ID, MSECUSRFUN->USER_ID, sizeof(MSECUSRFUN->USER_ID));
    MSECUSRFUN_N->SEQ_NUM = MSECUSRFUN->SEQ_NUM;
    MEMCPY_AN(MSECUSRFUN_N->FUNC_NAME, MSECUSRFUN->FUNC_NAME, sizeof(MSECUSRFUN->FUNC_NAME));
    MEMCPY_AN(MSECUSRFUN_N->USER_FUNC_DESC, MSECUSRFUN->USER_FUNC_DESC, sizeof(MSECUSRFUN->USER_FUNC_DESC));
}


/* Del Null Function */
void DBC_del_null_msecusrfun(struct MSECUSRFUN_N_TAG *MSECUSRFUN_N, struct MSECUSRFUN_TAG *MSECUSRFUN)
{
    MEMCPY_DN(MSECUSRFUN->FACTORY, MSECUSRFUN_N->FACTORY, sizeof(MSECUSRFUN->FACTORY));
    MEMCPY_DN(MSECUSRFUN->PROGRAM_ID, MSECUSRFUN_N->PROGRAM_ID, sizeof(MSECUSRFUN->PROGRAM_ID));
    MEMCPY_DN(MSECUSRFUN->USER_ID, MSECUSRFUN_N->USER_ID, sizeof(MSECUSRFUN->USER_ID));
    MSECUSRFUN->SEQ_NUM = MSECUSRFUN_N->SEQ_NUM;
    MEMCPY_DN(MSECUSRFUN->FUNC_NAME, MSECUSRFUN_N->FUNC_NAME, sizeof(MSECUSRFUN->FUNC_NAME));
    MEMCPY_DN(MSECUSRFUN->USER_FUNC_DESC, MSECUSRFUN_N->USER_FUNC_DESC, sizeof(MSECUSRFUN->USER_FUNC_DESC));
}



