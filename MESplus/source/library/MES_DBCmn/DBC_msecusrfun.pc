/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_msecusrfun(int sel_type, struct MSECUSRFUN_TAG *MSECUSRFUN)
{
    EXEC SQL BEGIN DECLARE SECTION;
       struct MSECUSRFUN_N_TAG MSECUSRFUN_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_msecusrfun(&MSECUSRFUN_N, MSECUSRFUN);
    DB_error_code = 0;
    
    DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);

    switch(sel_type)
    {
        /* Seq_Num ?? 揶쏆늽援??獄쏅쵐肉???덈뮉 野껉퍔??SEQ 筌앹빓? ??쀪텢??*/
        case 1:
            EXEC SQL DECLARE DBC_MSECUSRFUN_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    PROGRAM_ID,
                    USER_ID,
                    SEQ_NUM,
                    FUNC_NAME,
                    USER_FUNC_DESC
                FROM MSECUSRFUN
                WHERE FACTORY = :MSECUSRFUN_N.FACTORY
                    AND PROGRAM_ID = :MSECUSRFUN_N.PROGRAM_ID
                    AND USER_ID = :MSECUSRFUN_N.USER_ID
                    AND SEQ_NUM >= :DBC_Q_COND_N.FROM_SEQ
                ORDER BY SEQ_NUM DESC;
            EXEC SQL OPEN DBC_MSECUSRFUN_CUR_1;
            break;

        /* Seq_Num ?? 揶쏆늽援??獄쏅쵐肉???덈뮉 野껉퍔??SEQ 揶쏅Ŋ????쀪텢??*/
        case 2:
            EXEC SQL DECLARE DBC_MSECUSRFUN_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    PROGRAM_ID,
                    USER_ID,
                    SEQ_NUM,
                    FUNC_NAME,
                    USER_FUNC_DESC
                FROM MSECUSRFUN
                WHERE FACTORY = :MSECUSRFUN_N.FACTORY
                    AND PROGRAM_ID = :MSECUSRFUN_N.PROGRAM_ID
                    AND USER_ID = :MSECUSRFUN_N.USER_ID
                    AND SEQ_NUM >= :DBC_Q_COND_N.FROM_SEQ
                ORDER BY SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MSECUSRFUN_CUR_2;
            break;

        /* 獄쏅쵐肉???덈뮉椰??袁⑥쨮 ?????野껋럩??域????????덈뮉 野?(獄쏅쵐?앮에????곫묾??袁る퉸) */
        case 3:
            EXEC SQL DECLARE DBC_MSECUSRFUN_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    PROGRAM_ID,
                    USER_ID,
                    SEQ_NUM,
                    FUNC_NAME,
                    USER_FUNC_DESC
                FROM MSECUSRFUN
                WHERE FACTORY = :MSECUSRFUN_N.FACTORY
                    AND PROGRAM_ID = :MSECUSRFUN_N.PROGRAM_ID
                    AND USER_ID = :MSECUSRFUN_N.USER_ID
                    AND SEQ_NUM >= :DBC_Q_COND_N.FROM_SEQ
                    AND SEQ_NUM < :DBC_Q_COND_N.TO_SEQ
                ORDER BY SEQ_NUM DESC;
            EXEC SQL OPEN DBC_MSECUSRFUN_CUR_3;
            break;

        /* ?袁⑸퓠 ??덈뮉椰??袁⑥삋嚥??????野껋럩??域????????덈뮉 野?(?袁⑥쨮 ???곫묾??袁る퉸) */
        case 4:
            EXEC SQL DECLARE DBC_MSECUSRFUN_CUR_4 CURSOR FOR
                SELECT 
                    FACTORY,
                    PROGRAM_ID,
                    USER_ID,
                    SEQ_NUM,
                    FUNC_NAME,
                    USER_FUNC_DESC
                FROM MSECUSRFUN
                WHERE FACTORY = :MSECUSRFUN_N.FACTORY
                    AND PROGRAM_ID = :MSECUSRFUN_N.PROGRAM_ID
                    AND USER_ID = :MSECUSRFUN_N.USER_ID
                    AND SEQ_NUM > :DBC_Q_COND_N.FROM_SEQ
                    AND SEQ_NUM <= :DBC_Q_COND_N.TO_SEQ
                ORDER BY SEQ_NUM ASC;
            EXEC SQL OPEN DBC_MSECUSRFUN_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_msecusrfun", sel_type);
