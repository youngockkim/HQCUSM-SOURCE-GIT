    MEMCPY_AN(MSPCCHTMFO_N->MAT_ID, MSPCCHTMFO->MAT_ID, sizeof(MSPCCHTMFO->MAT_ID));
    MSPCCHTMFO_N->MAT_VER = MSPCCHTMFO->MAT_VER;
    MEMCPY_AN(MSPCCHTMFO_N->FLOW, MSPCCHTMFO->FLOW, sizeof(MSPCCHTMFO->FLOW));
    MEMCPY_AN(MSPCCHTMFO_N->OPER, MSPCCHTMFO->OPER, sizeof(MSPCCHTMFO->OPER));
    MSPCCHTMFO_N->OPT_LEVEL[0] = MSPCCHTMFO->OPT_LEVEL;
    MEMCPY_AN(MSPCCHTMFO_N->CHART_ID, MSPCCHTMFO->CHART_ID, sizeof(MSPCCHTMFO->CHART_ID));
    MSPCCHTMFO_N->CHART_FLAG[0] = MSPCCHTMFO->CHART_FLAG;
    MSPCCHTMFO_N->OVR_FLAG[0] = MSPCCHTMFO->OVR_FLAG;
    MEMCPY_AN(MSPCCHTMFO_N->CREATE_USER_ID, MSPCCHTMFO->CREATE_USER_ID, sizeof(MSPCCHTMFO->CREATE_USER_ID));
    MEMCPY_AN(MSPCCHTMFO_N->CREATE_TIME, MSPCCHTMFO->CREATE_TIME, sizeof(MSPCCHTMFO->CREATE_TIME));
    MEMCPY_AN(MSPCCHTMFO_N->UPDATE_USER_ID, MSPCCHTMFO->UPDATE_USER_ID, sizeof(MSPCCHTMFO->UPDATE_USER_ID));
    MEMCPY_AN(MSPCCHTMFO_N->UPDATE_TIME, MSPCCHTMFO->UPDATE_TIME, sizeof(MSPCCHTMFO->UPDATE_TIME));
}


/* Del Null Function */
void DBC_del_null_mspcchtmfo(struct MSPCCHTMFO_N_TAG *MSPCCHTMFO_N, struct MSPCCHTMFO_TAG *MSPCCHTMFO)
{
    MEMCPY_DN(MSPCCHTMFO->FACTORY, MSPCCHTMFO_N->FACTORY, sizeof(MSPCCHTMFO->FACTORY));
    MEMCPY_DN(MSPCCHTMFO->MAT_ID, MSPCCHTMFO_N->MAT_ID, sizeof(MSPCCHTMFO->MAT_ID));
    MSPCCHTMFO->MAT_VER = MSPCCHTMFO_N->MAT_VER;
    MEMCPY_DN(MSPCCHTMFO->FLOW, MSPCCHTMFO_N->FLOW, sizeof(MSPCCHTMFO->FLOW));
    MEMCPY_DN(MSPCCHTMFO->OPER, MSPCCHTMFO_N->OPER, sizeof(MSPCCHTMFO->OPER));
    MSPCCHTMFO->OPT_LEVEL = MSPCCHTMFO_N->OPT_LEVEL[0];
    MEMCPY_DN(MSPCCHTMFO->CHART_ID, MSPCCHTMFO_N->CHART_ID, sizeof(MSPCCHTMFO->CHART_ID));
    MSPCCHTMFO->CHART_FLAG = MSPCCHTMFO_N->CHART_FLAG[0];
    MSPCCHTMFO->OVR_FLAG = MSPCCHTMFO_N->OVR_FLAG[0];
    MEMCPY_DN(MSPCCHTMFO->CREATE_USER_ID, MSPCCHTMFO_N->CREATE_USER_ID, sizeof(MSPCCHTMFO->CREATE_USER_ID));
    MEMCPY_DN(MSPCCHTMFO->CREATE_TIME, MSPCCHTMFO_N->CREATE_TIME, sizeof(MSPCCHTMFO->CREATE_TIME));
    MEMCPY_DN(MSPCCHTMFO->UPDATE_USER_ID, MSPCCHTMFO_N->UPDATE_USER_ID, sizeof(MSPCCHTMFO->UPDATE_USER_ID));
    MEMCPY_DN(MSPCCHTMFO->UPDATE_TIME, MSPCCHTMFO_N->UPDATE_TIME, sizeof(MSPCCHTMFO->UPDATE_TIME));
}


