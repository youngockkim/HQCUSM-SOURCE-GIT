/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_msecusrext(int sel_type, struct MSECUSREXT_TAG *MSECUSREXT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MSECUSREXT_N_TAG MSECUSREXT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_msecusrext(&MSECUSREXT_N, MSECUSREXT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MSECUSREXT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    USER_ID,
                    ENCODE_PASSWORD,
                    PASSWORD_CHANGE_DATE,
                    PASSWORD_CHANGE_PERIOD,
                    CHANGE_PASSWORD_FLAG,
                    PASSWORD_FAIL_COUNT,
                    OLD_PASSWORD_1,
                    OLD_PASSWORD_2,
                    OLD_PASSWORD_3,
                    OLD_PASSWORD_4,
                    OLD_PASSWORD_5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MSECUSREXT
                WHERE FACTORY = :MSECUSREXT_N.FACTORY
                ORDER BY USER_ID ASC;
            EXEC SQL OPEN DBC_MSECUSREXT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("DBC_open_msecusrext", sel_type);
}


