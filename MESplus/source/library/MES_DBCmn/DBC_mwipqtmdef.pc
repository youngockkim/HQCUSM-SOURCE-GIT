                            UPDATE_TIME,
                            LOT_CMF_1,
                            LOT_CMF_2,
                            LOT_CMF_3,
                            LOT_CMF_4,
                            LOT_CMF_5,
                            LOT_CMF_6,
                            LOT_CMF_7,
                            LOT_CMF_8,
