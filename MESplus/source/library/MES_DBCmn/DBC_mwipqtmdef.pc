/* SQL CURSOR CLOSE Function */
void DBC_close_mwipqtmdef(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE DBC_MWIPQTMDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE DBC_MWIPQTMDEF_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE DBC_MWIPQTMDEF_CUR_3;
            break;

        case 4:
            EXEC SQL CLOSE DBC_MWIPQTMDEF_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE DBC_MWIPQTMDEF_CUR_5;
            break;

