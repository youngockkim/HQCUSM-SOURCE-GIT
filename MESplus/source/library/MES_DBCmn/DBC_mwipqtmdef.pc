                    AND (LOT_CMF_5 = :MWIPQTMDEF_N.LOT_CMF_5 OR LOT_CMF_5 = ' ')
                    AND (LOT_CMF_6 = :MWIPQTMDEF_N.LOT_CMF_6 OR LOT_CMF_6 = ' ')
