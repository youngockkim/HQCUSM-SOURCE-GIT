                        AND PRIORITY = :MWIPQTMDEF_N.PRIORITY
                    FOR UPDATE;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        DBC_del_null_mwipqtmdef(&MWIPQTMDEF_N, MWIPQTMDEF);
    }

    DB_stop_query_timer("DBC_select_mwipqtmdef_for_update", sel_type);
}


