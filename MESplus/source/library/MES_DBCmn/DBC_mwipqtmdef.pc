        case 15:
            EXEC SQL CLOSE DBC_MWIPQTMDEF_CUR_15;
            break;

        case 16:
            EXEC SQL CLOSE DBC_MWIPQTMDEF_CUR_16;
            break;

        case 17:
            EXEC SQL CLOSE DBC_MWIPQTMDEF_CUR_17;
            break;

        case 18: /* Not Allow Duplicate Flow Seq Num Case : Against Case 12 */
            EXEC SQL CLOSE DBC_MWIPQTMDEF_CUR_18;
            break;

        case 19: /* Not Allow Duplicate Flow Seq Num Case : Against Case 13 */
            EXEC SQL CLOSE DBC_MWIPQTMDEF_CUR_19;
            break;

        case 20: /* Not Allow Duplicate Flow Seq Num Case : Against Case 16 */
            EXEC SQL CLOSE DBC_MWIPQTMDEF_CUR_20;
