                    LOT_CMF_16,
                    LOT_CMF_17,
                    LOT_CMF_18,
                    LOT_CMF_19,
                    LOT_CMF_20
                FROM (
                    SELECT ROWNUM ROWSEQ, QT.*
                    FROM (
                        SELECT 
                            FACTORY,
                            MAT_ID,
                            MAT_VER,
                            FLOW,
                            FLOW_SEQ_NUM,
