                    AND (LOT_CMF_10 = :MWIPQTMDEF_N.LOT_CMF_10 OR LOT_CMF_10 = ' ')
                    AND (LOT_CMF_11 = :MWIPQTMDEF_N.LOT_CMF_11 OR LOT_CMF_11 = ' ')
                    AND (LOT_CMF_12 = :MWIPQTMDEF_N.LOT_CMF_12 OR LOT_CMF_12 = ' ')
                    AND (LOT_CMF_13 = :MWIPQTMDEF_N.LOT_CMF_13 OR LOT_CMF_13 = ' ')
                    AND (LOT_CMF_14 = :MWIPQTMDEF_N.LOT_CMF_14 OR LOT_CMF_14 = ' ')
                    AND (LOT_CMF_15 = :MWIPQTMDEF_N.LOT_CMF_15 OR LOT_CMF_15 = ' ')
                    AND (LOT_CMF_16 = :MWIPQTMDEF_N.LOT_CMF_16 OR LOT_CMF_16 = ' ')
                    AND (LOT_CMF_17 = :MWIPQTMDEF_N.LOT_CMF_17 OR LOT_CMF_17 = ' ')
                    AND (LOT_CMF_18 = :MWIPQTMDEF_N.LOT_CMF_18 OR LOT_CMF_18 = ' ')
                    AND (LOT_CMF_19 = :MWIPQTMDEF_N.LOT_CMF_19 OR LOT_CMF_19 = ' ')
                    AND (LOT_CMF_20 = :MWIPQTMDEF_N.LOT_CMF_20 OR LOT_CMF_20 = ' ')
                ORDER BY PRIORITY;
            EXEC SQL OPEN DBC_MWIPQTMDEF_CUR_20;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("DBC_open_mwipqtmdef", sel_type);
}

/* SQL CURSOR DECLARE & OPEN Function */
void DBC_open_mwipqtmdef_rownum(int sel_type, struct MWIPQTMDEF_TAG *MWIPQTMDEF, int next_seq)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPQTMDEF_N_TAG MWIPQTMDEF_N;
        int i_next_seq;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_mwipqtmdef(&MWIPQTMDEF_N, MWIPQTMDEF);
    DB_error_code = 0;
    i_next_seq = next_seq;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE DBC_MWIPQTMDEF_CUR_ROWNUM_1 CURSOR FOR
                SELECT ROWSEQ,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    FROM_FACTORY,
                    FROM_FLOW,
                    FROM_FLOW_SEQ_NUM,
