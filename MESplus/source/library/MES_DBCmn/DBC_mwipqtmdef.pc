/* Initialize Function */
void DBC_init_mwipqtmdef(struct MWIPQTMDEF_TAG *MWIPQTMDEF)
{
    /* memset by Space */
    memset(MWIPQTMDEF, ' ', sizeof(struct MWIPQTMDEF_TAG));
    
    MWIPQTMDEF->MAT_VER = 0;
    MWIPQTMDEF->FLOW_SEQ_NUM = 0;
    MWIPQTMDEF->FROM_FLOW_SEQ_NUM = 0;
    MWIPQTMDEF->UPPER_WARN_QUE_TIME = 0;
    MWIPQTMDEF->LOWER_WARN_QUE_TIME = 0;
    MWIPQTMDEF->UPPER_ERR_QUE_TIME = 0;
    MWIPQTMDEF->LOWER_ERR_QUE_TIME = 0;
    MWIPQTMDEF->PRIORITY = 0;
    MWIPQTMDEF->VIO_LIMIT_NUM = 0;
}


/* Add Null Function */
void DBC_add_null_mwipqtmdef(struct MWIPQTMDEF_N_TAG *MWIPQTMDEF_N, struct MWIPQTMDEF_TAG *MWIPQTMDEF)
{
    /* memset by NULL */
    memset(MWIPQTMDEF_N, '\0', sizeof(struct MWIPQTMDEF_N_TAG));
    
