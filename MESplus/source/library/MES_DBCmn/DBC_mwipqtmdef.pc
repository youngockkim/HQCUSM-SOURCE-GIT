                    AND MAT_VER = :MWIPQTMDEF_N.MAT_VER
                    AND FROM_FLOW = :MWIPQTMDEF_N.FROM_FLOW
                    /* AND FROM_FLOW_SEQ_NUM = :MWIPQTMDEF_N.FROM_FLOW_SEQ_NUM */
                    AND FROM_OPER = :MWIPQTMDEF_N.FROM_OPER
                    AND FROM_POINT_FLAG = :MWIPQTMDEF_N.FROM_POINT_FLAG
                    AND (LOT_CMF_1 = :MWIPQTMDEF_N.LOT_CMF_1 OR LOT_CMF_1 = ' ')
                    AND (LOT_CMF_2 = :MWIPQTMDEF_N.LOT_CMF_2 OR LOT_CMF_2 = ' ')
