                FROM MWIPLOTCMB
                WHERE LOT_ID = :MWIPLOTCMB_N.LOT_ID
                    AND FROM_TO_FLAG = :MWIPLOTCMB_N.FROM_TO_FLAG
                ORDER BY HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MWIPLOTCMB_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
