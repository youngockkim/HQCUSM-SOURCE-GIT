    MEMCPY_AN(MWIPLOTCMB_N->LOT_ID, MWIPLOTCMB->LOT_ID, sizeof(MWIPLOTCMB->LOT_ID));
    MWIPLOTCMB_N->HIST_SEQ = MWIPLOTCMB->HIST_SEQ;
