                WHERE LOT_ID = :MWIPLOTCMB_N.LOT_ID
                ORDER BY HIST_SEQ ASC;
            EXEC SQL OPEN DBC_MWIPLOTCMB_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE DBC_MWIPLOTCMB_CUR_2 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
