void DBC_del_null_mwiplotlos(struct MWIPLOTLOS_N_TAG *MWIPLOTLOS_N, struct MWIPLOTLOS_TAG *MWIPLOTLOS)
{
    MEMCPY_DN(MWIPLOTLOS->LOT_ID, MWIPLOTLOS_N->LOT_ID, sizeof(MWIPLOTLOS->LOT_ID));
