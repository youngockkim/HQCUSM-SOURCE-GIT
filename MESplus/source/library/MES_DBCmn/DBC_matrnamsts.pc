    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DBC_add_null_matrnamsts(&MATRNAMSTS_N, MATRNAMSTS);
    memset(s_next_key, 0x00, sizeof(s_next_key));
    strcpy(s_next_key, next_key);

    DB_error_code = 0;

    switch(sel_type)
    {
        case 2: /* only for LOT, SUBLOT */
            EXEC SQL DECLARE DBC_MATRNAMSTS_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    ATTR_TYPE,
                    ATTR_NAME,
                    ATTR_KEY,
                    KEY_HIST_SEQ,
                    ATTR_VALUE,
                    NULL_FLAG,
                    LAST_TRAN_TIME,
                    LAST_ACTIVE_HIST_SEQ,
                    LAST_HIST_SEQ
                FROM MATRNAMSTS
                WHERE ATTR_TYPE = :MATRNAMSTS_N.ATTR_TYPE
                    AND ATTR_NAME = :MATRNAMSTS_N.ATTR_NAME
                    AND ATTR_KEY LIKE :MATRNAMSTS_N.ATTR_KEY
                    AND ATTR_VALUE LIKE :MATRNAMSTS_N.ATTR_VALUE
                    AND ATTR_KEY >= :s_next_key
                ORDER BY ATTR_KEY ASC;
            EXEC SQL OPEN DBC_MATRNAMSTS_CUR_2;
            break;



        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
