/* Initialize Function */
void DBC_init_matrnamsts(struct MATRNAMSTS_TAG *MATRNAMSTS)
{
    /* memset by Space */
    memset(MATRNAMSTS, ' ', sizeof(struct MATRNAMSTS_TAG));
    
    MATRNAMSTS->KEY_HIST_SEQ = 0;
    MATRNAMSTS->LAST_ACTIVE_HIST_SEQ = 0;
    MATRNAMSTS->LAST_HIST_SEQ = 0;
}


/* Add Null Function */
void DBC_add_null_matrnamsts(struct MATRNAMSTS_N_TAG *MATRNAMSTS_N, struct MATRNAMSTS_TAG *MATRNAMSTS)
{
    /* memset by NULL */
    memset(MATRNAMSTS_N, '\0', sizeof(struct MATRNAMSTS_N_TAG));
    
    MEMCPY_AN(MATRNAMSTS_N->FACTORY, MATRNAMSTS->FACTORY, sizeof(MATRNAMSTS->FACTORY));
    MEMCPY_AN(MATRNAMSTS_N->ATTR_TYPE, MATRNAMSTS->ATTR_TYPE, sizeof(MATRNAMSTS->ATTR_TYPE));
    MEMCPY_AN(MATRNAMSTS_N->ATTR_NAME, MATRNAMSTS->ATTR_NAME, sizeof(MATRNAMSTS->ATTR_NAME));
    MEMCPY_AN(MATRNAMSTS_N->ATTR_KEY, MATRNAMSTS->ATTR_KEY, sizeof(MATRNAMSTS->ATTR_KEY));
    MATRNAMSTS_N->KEY_HIST_SEQ = MATRNAMSTS->KEY_HIST_SEQ;
    MEMCPY_AN(MATRNAMSTS_N->ATTR_VALUE, MATRNAMSTS->ATTR_VALUE, sizeof(MATRNAMSTS->ATTR_VALUE));
    MATRNAMSTS_N->NULL_FLAG[0] = MATRNAMSTS->NULL_FLAG;
    MEMCPY_AN(MATRNAMSTS_N->LAST_TRAN_TIME, MATRNAMSTS->LAST_TRAN_TIME, sizeof(MATRNAMSTS->LAST_TRAN_TIME));
    MATRNAMSTS_N->LAST_ACTIVE_HIST_SEQ = MATRNAMSTS->LAST_ACTIVE_HIST_SEQ;
    MATRNAMSTS_N->LAST_HIST_SEQ = MATRNAMSTS->LAST_HIST_SEQ;
}


/* Del Null Function */
void DBC_del_null_matrnamsts(struct MATRNAMSTS_N_TAG *MATRNAMSTS_N, struct MATRNAMSTS_TAG *MATRNAMSTS)
{
    MEMCPY_DN(MATRNAMSTS->FACTORY, MATRNAMSTS_N->FACTORY, sizeof(MATRNAMSTS->FACTORY));
    MEMCPY_DN(MATRNAMSTS->ATTR_TYPE, MATRNAMSTS_N->ATTR_TYPE, sizeof(MATRNAMSTS->ATTR_TYPE));
    MEMCPY_DN(MATRNAMSTS->ATTR_NAME, MATRNAMSTS_N->ATTR_NAME, sizeof(MATRNAMSTS->ATTR_NAME));
    MEMCPY_DN(MATRNAMSTS->ATTR_KEY, MATRNAMSTS_N->ATTR_KEY, sizeof(MATRNAMSTS->ATTR_KEY));
    MATRNAMSTS->KEY_HIST_SEQ = MATRNAMSTS_N->KEY_HIST_SEQ;
    MEMCPY_DN(MATRNAMSTS->ATTR_VALUE, MATRNAMSTS_N->ATTR_VALUE, sizeof(MATRNAMSTS->ATTR_VALUE));
    MATRNAMSTS->NULL_FLAG = MATRNAMSTS_N->NULL_FLAG[0];
    MEMCPY_DN(MATRNAMSTS->LAST_TRAN_TIME, MATRNAMSTS_N->LAST_TRAN_TIME, sizeof(MATRNAMSTS->LAST_TRAN_TIME));
    MATRNAMSTS->LAST_ACTIVE_HIST_SEQ = MATRNAMSTS_N->LAST_ACTIVE_HIST_SEQ;
    MATRNAMSTS->LAST_HIST_SEQ = MATRNAMSTS_N->LAST_HIST_SEQ;
}


