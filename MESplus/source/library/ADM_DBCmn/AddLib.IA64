echo "==============================================================================================="
echo PROC Compile $1.pc
proc PARSE=FULL $1.pc include="/oracle/app/11g/rac/rdbms/public" include="/home/mesplus/V520/source/library/MES_DBCmn" include="/home/mesplus/V520/source/library/ADM_DBCmn"

echo CC Compile
cc +DD64 -c -w $1.c -I/oracle/app/11g/rac/precomp/public -I/oracle/app/11g/rac/rdbms/public -I/home/mesplus/V520/source/library/ADM_DBCmn -I/home/mesplus/V520/inc/dbinc 

echo Insert to library            
ar r libADM_DBCmn.a $1.o 

echo Copy Head file
cp $1.h ../../../inc/dbinc
#cp DBC_common.h ../../../inc/dbinc

echo Copy Library
cp libADM_DBCmn.a ../../../lib
rm -f $1.o $1.c $1.lis

echo ""
