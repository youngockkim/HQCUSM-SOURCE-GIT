/* SQL CURSOR DECLARE & OPEN Function */
void ADB_open_marcloghis(int sel_type, struct MARCLOGHIS_TAG *MARCLOGHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MARCLOGHIS_N_TAG MARCLOGHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    ADB_add_null_marcloghis(&MARCLOGHIS_N, MARCLOGHIS);
    DB_error_code = 0;
    
    switch(sel_type)
    {
        case 1:

            EXEC SQL DECLARE ADB_MARCLOGHIS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    MODULE,
                    LOG,
                    SEQ_NUM,
                    CREATE_TIME,
                    CONTENT,
                    RESV_FLAG1,
                    RESV_FLAG2,
                    RESV_FLAG3,
                    RESV_FLAG4,
                    RESV_FLAG5,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                FROM MARCLOGHIS
                WHERE LOG = :MARCLOGHIS_N.LOG
                    AND SEQ_NUM >= :MARCLOGHIS_N.SEQ_NUM
                ORDER BY FACTORY ASC,
                    LOG ASC,
                    SEQ_NUM ASC;
            EXEC SQL OPEN ADB_MARCLOGHIS_CUR_1;
            break;
            
        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("ADB_open_marcloghis", sel_type);
}


