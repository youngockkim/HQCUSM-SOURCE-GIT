/* Add Null Function */
void ADB_add_null_marcloghis(struct MARCLOGHIS_N_TAG *MARCLOGHIS_N, struct MARCLOGHIS_TAG *MARCLOGHIS)
{
    /* memset by NULL */
    memset(MARCLOGHIS_N, '\0', sizeof(struct MARCLOGHIS_N_TAG));
    
    MEMCPY_AN(MARCLOGHIS_N->FACTORY, MARCLOGHIS->FACTORY, sizeof(MARCLOGHIS->FACTORY));
    MEMCPY_AN(MARCLOGHIS_N->MODULE, MARCLOGHIS->MODULE, sizeof(MARCLOGHIS->MODULE));
    MEMCPY_AN(MARCLOGHIS_N->LOG, MARCLOGHIS->LOG, sizeof(MARCLOGHIS->LOG));
    MARCLOGHIS_N->SEQ_NUM = MARCLOGHIS->SEQ_NUM;
    MEMCPY_AN(MARCLOGHIS_N->CREATE_TIME, MARCLOGHIS->CREATE_TIME, sizeof(MARCLOGHIS->CREATE_TIME));
    MEMCPY_AN(MARCLOGHIS_N->CONTENT, MARCLOGHIS->CONTENT, sizeof(MARCLOGHIS->CONTENT));
    MARCLOGHIS_N->RESV_FLAG1[0] = MARCLOGHIS->RESV_FLAG1;
    MARCLOGHIS_N->RESV_FLAG2[0] = MARCLOGHIS->RESV_FLAG2;
    MARCLOGHIS_N->RESV_FLAG3[0] = MARCLOGHIS->RESV_FLAG3;
    MARCLOGHIS_N->RESV_FLAG4[0] = MARCLOGHIS->RESV_FLAG4;
    MARCLOGHIS_N->RESV_FLAG5[0] = MARCLOGHIS->RESV_FLAG5;
    MEMCPY_AN(MARCLOGHIS_N->RESV_FIELD1, MARCLOGHIS->RESV_FIELD1, sizeof(MARCLOGHIS->RESV_FIELD1));
    MEMCPY_AN(MARCLOGHIS_N->RESV_FIELD2, MARCLOGHIS->RESV_FIELD2, sizeof(MARCLOGHIS->RESV_FIELD2));
    MEMCPY_AN(MARCLOGHIS_N->RESV_FIELD3, MARCLOGHIS->RESV_FIELD3, sizeof(MARCLOGHIS->RESV_FIELD3));
    MEMCPY_AN(MARCLOGHIS_N->RESV_FIELD4, MARCLOGHIS->RESV_FIELD4, sizeof(MARCLOGHIS->RESV_FIELD4));
    MEMCPY_AN(MARCLOGHIS_N->RESV_FIELD5, MARCLOGHIS->RESV_FIELD5, sizeof(MARCLOGHIS->RESV_FIELD5));
}


/* Del Null Function */
void ADB_del_null_marcloghis(struct MARCLOGHIS_N_TAG *MARCLOGHIS_N, struct MARCLOGHIS_TAG *MARCLOGHIS)
{
    MEMCPY_DN(MARCLOGHIS->FACTORY, MARCLOGHIS_N->FACTORY, sizeof(MARCLOGHIS->FACTORY));
    MEMCPY_DN(MARCLOGHIS->MODULE, MARCLOGHIS_N->MODULE, sizeof(MARCLOGHIS->MODULE));
    MEMCPY_DN(MARCLOGHIS->LOG, MARCLOGHIS_N->LOG, sizeof(MARCLOGHIS->LOG));
    MARCLOGHIS->SEQ_NUM = MARCLOGHIS_N->SEQ_NUM;
    MEMCPY_DN(MARCLOGHIS->CREATE_TIME, MARCLOGHIS_N->CREATE_TIME, sizeof(MARCLOGHIS->CREATE_TIME));
    MEMCPY_DN(MARCLOGHIS->CONTENT, MARCLOGHIS_N->CONTENT, sizeof(MARCLOGHIS->CONTENT));
    MARCLOGHIS->RESV_FLAG1 = MARCLOGHIS_N->RESV_FLAG1[0];
    MARCLOGHIS->RESV_FLAG2 = MARCLOGHIS_N->RESV_FLAG2[0];
    MARCLOGHIS->RESV_FLAG3 = MARCLOGHIS_N->RESV_FLAG3[0];
    MARCLOGHIS->RESV_FLAG4 = MARCLOGHIS_N->RESV_FLAG4[0];
    MARCLOGHIS->RESV_FLAG5 = MARCLOGHIS_N->RESV_FLAG5[0];
    MEMCPY_DN(MARCLOGHIS->RESV_FIELD1, MARCLOGHIS_N->RESV_FIELD1, sizeof(MARCLOGHIS->RESV_FIELD1));
    MEMCPY_DN(MARCLOGHIS->RESV_FIELD2, MARCLOGHIS_N->RESV_FIELD2, sizeof(MARCLOGHIS->RESV_FIELD2));
    MEMCPY_DN(MARCLOGHIS->RESV_FIELD3, MARCLOGHIS_N->RESV_FIELD3, sizeof(MARCLOGHIS->RESV_FIELD3));
    MEMCPY_DN(MARCLOGHIS->RESV_FIELD4, MARCLOGHIS_N->RESV_FIELD4, sizeof(MARCLOGHIS->RESV_FIELD4));
    MEMCPY_DN(MARCLOGHIS->RESV_FIELD5, MARCLOGHIS_N->RESV_FIELD5, sizeof(MARCLOGHIS->RESV_FIELD5));
}


