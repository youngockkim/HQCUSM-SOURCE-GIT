    GET_OPTDETAIL_N->TERM = GET_OPTDETAIL->TERM;
    GET_OPTDETAIL_N->DAYS = GET_OPTDETAIL->DAYS;
    GET_OPTDETAIL_N->SPD_TIME = GET_OPTDETAIL->SPD_TIME;
