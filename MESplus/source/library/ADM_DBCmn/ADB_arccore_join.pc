    GET_OPTDETAIL_N->MED_TYPE[0] = GET_OPTDETAIL->MED_TYPE;
    GET_OPTDETAIL_N->ROL_FLAG[0] = GET_OPTDETAIL->ROL_FLAG;
    GET_OPTDETAIL_N->MAS_DEL_FLAG[0] = GET_OPTDETAIL->MAS_DEL_FLAG;
    MEMCPY_AN(GET_OPTDETAIL_N->RUN_VALUE, GET_OPTDETAIL->RUN_VALUE, sizeof(GET_OPTDETAIL->RUN_VALUE));

}


