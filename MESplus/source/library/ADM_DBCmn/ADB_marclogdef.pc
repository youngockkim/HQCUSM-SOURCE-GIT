    MARCLOGDEF_N->STATUS_FLAG[0] = MARCLOGDEF->STATUS_FLAG;
    MEMCPY_AN(MARCLOGDEF_N->CREATE_TIME, MARCLOGDEF->CREATE_TIME, sizeof(MARCLOGDEF->CREATE_TIME));
    MEMCPY_AN(MARCLOGDEF_N->END_TIME, MARCLOGDEF->END_TIME, sizeof(MARCLOGDEF->END_TIME));
    MARCLOGDEF_N->RESV_FLAG1[0] = MARCLOGDEF->RESV_FLAG1;
    MARCLOGDEF_N->RESV_FLAG2[0] = MARCLOGDEF->RESV_FLAG2;
    MARCLOGDEF_N->RESV_FLAG3[0] = MARCLOGDEF->RESV_FLAG3;
    MARCLOGDEF_N->RESV_FLAG4[0] = MARCLOGDEF->RESV_FLAG4;
    MARCLOGDEF_N->RESV_FLAG5[0] = MARCLOGDEF->RESV_FLAG5;
