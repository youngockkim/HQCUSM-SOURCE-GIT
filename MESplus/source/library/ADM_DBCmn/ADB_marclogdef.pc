/* Add Null Function */
void ADB_add_null_marclogdef(struct MARCLOGDEF_N_TAG *MARCLOGDEF_N, struct MARCLOGDEF_TAG *MARCLOGDEF)
{
    /* memset by NULL */
    memset(MARCLOGDEF_N, '\0', sizeof(struct MARCLOGDEF_N_TAG));
    
