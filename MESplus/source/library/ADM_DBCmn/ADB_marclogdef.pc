/* Del Null Function */
void ADB_del_null_marclogdef(struct MARCLOGDEF_N_TAG *MARCLOGDEF_N, struct MARCLOGDEF_TAG *MARCLOGDEF)
{
    MEMCPY_DN(MARCLOGDEF->FACTORY, MARCLOGDEF_N->FACTORY, sizeof(MARCLOGDEF->FACTORY));
