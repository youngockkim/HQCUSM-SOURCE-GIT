    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE ADB_MARCLOGDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    MODULE,
                    LOG,
                    STATUS_FLAG,
                    CREATE_TIME,
                    END_TIME,
                    RESV_FLAG1,
                    RESV_FLAG2,
                    RESV_FLAG3,
                    RESV_FLAG4,
                    RESV_FLAG5,
                    RESV_FIELD1,
                    RESV_FIELD2,
                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5
                FROM MARCLOGDEF
                ORDER BY FACTORY ASC,
                    MODULE ASC,
                    LOG ASC;
            EXEC SQL OPEN ADB_MARCLOGDEF_CUR_1;
            break;
            
        case 2:
            DB_add_null_condition(&DBC_Q_COND, &DBC_Q_COND_N);

            memset( sql, 0x00, sizeof(sql));
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "FACTORY, ");
            sprintf(sql + strlen(sql),   "MODULE, ");
            sprintf(sql + strlen(sql),   "LOG, ");
            sprintf(sql + strlen(sql),   "STATUS_FLAG, ");
            sprintf(sql + strlen(sql),   "CREATE_TIME, ");
            sprintf(sql + strlen(sql),   "END_TIME, ");
            sprintf(sql + strlen(sql),   "RESV_FLAG1, ");
            sprintf(sql + strlen(sql),   "RESV_FLAG2, ");
            sprintf(sql + strlen(sql),   "RESV_FLAG3, ");
            sprintf(sql + strlen(sql),   "RESV_FLAG4, ");
            sprintf(sql + strlen(sql),   "RESV_FLAG5, ");
            sprintf(sql + strlen(sql),   "RESV_FIELD1, ");
            sprintf(sql + strlen(sql),   "RESV_FIELD2, ");
            sprintf(sql + strlen(sql),   "RESV_FIELD3, ");
            sprintf(sql + strlen(sql),   "RESV_FIELD4, ");
            sprintf(sql + strlen(sql),   "RESV_FIELD5 ");
            sprintf(sql + strlen(sql), "FROM MARCLOGDEF WHERE ");

            make_valid_quote(ts1, MARCLOGDEF_N.LOG);
            sprintf(sql + strlen(sql), "LOG >= '%s' ", ts1);

            make_valid_quote(ts1, DBC_Q_COND_N.FROM_TIME);
            make_valid_quote(ts2, DBC_Q_COND_N.TO_TIME);
            sprintf(sql + strlen(sql), "AND CREATE_TIME >= '%s' AND CREATE_TIME < '%s' ", ts1, ts2);
            sprintf(sql + strlen(sql), "ORDER BY CREATE_TIME ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE ADB_MARCLOGDEF_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN ADB_MARCLOGDEF_CUR_2;                 
