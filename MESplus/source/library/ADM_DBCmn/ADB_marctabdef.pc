/* SQL CURSOR CLOSE Function */
void ADB_close_marctabdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE ADB_MARCTABDEF_CUR_1;
            break;
            
        case 2:
            EXEC SQL CLOSE ADB_MARCTABDEF_CUR_2;
            break;
            
        case 3:
            EXEC SQL CLOSE ADB_MARCTABDEF_CUR_3;
            break;
            
        case 4:
            EXEC SQL CLOSE ADB_MARCTABDEF_CUR_4;
            break;

        case 5:
            EXEC SQL CLOSE ADB_MARCTABDEF_CUR_5;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("ADB_close_marctabdef", sel_type);
}


/* Initialize Function */
void ADB_init_marctabdef(struct MARCTABDEF_TAG *MARCTABDEF)
{
    /* memset by Space */
    memset(MARCTABDEF, ' ', sizeof(struct MARCTABDEF_TAG));
    
}


/* Add Null Function */
void ADB_add_null_marctabdef(struct MARCTABDEF_N_TAG *MARCTABDEF_N, struct MARCTABDEF_TAG *MARCTABDEF)
{
    /* memset by NULL */
    memset(MARCTABDEF_N, '\0', sizeof(struct MARCTABDEF_N_TAG));
    
    MEMCPY_AN(MARCTABDEF_N->FACTORY, MARCTABDEF->FACTORY, sizeof(MARCTABDEF->FACTORY));
    MEMCPY_AN(MARCTABDEF_N->TBL_NAME, MARCTABDEF->TBL_NAME, sizeof(MARCTABDEF->TBL_NAME));
    MARCTABDEF_N->TBL_TYPE[0] = MARCTABDEF->TBL_TYPE;
    MEMCPY_AN(MARCTABDEF_N->MODULE, MARCTABDEF->MODULE, sizeof(MARCTABDEF->MODULE));
    MEMCPY_AN(MARCTABDEF_N->KEY_FIELD1, MARCTABDEF->KEY_FIELD1, sizeof(MARCTABDEF->KEY_FIELD1));
    MEMCPY_AN(MARCTABDEF_N->KEY_FIELD2, MARCTABDEF->KEY_FIELD2, sizeof(MARCTABDEF->KEY_FIELD2));
    MEMCPY_AN(MARCTABDEF_N->KEY_FIELD3, MARCTABDEF->KEY_FIELD3, sizeof(MARCTABDEF->KEY_FIELD3));
    MEMCPY_AN(MARCTABDEF_N->KEY_FIELD4, MARCTABDEF->KEY_FIELD4, sizeof(MARCTABDEF->KEY_FIELD4));
    MEMCPY_AN(MARCTABDEF_N->KEY_FIELD5, MARCTABDEF->KEY_FIELD5, sizeof(MARCTABDEF->KEY_FIELD5));
    MEMCPY_AN(MARCTABDEF_N->TERM_FIELD, MARCTABDEF->TERM_FIELD, sizeof(MARCTABDEF->TERM_FIELD));
    MEMCPY_AN(MARCTABDEF_N->WHERE_CND, MARCTABDEF->WHERE_CND, sizeof(MARCTABDEF->WHERE_CND));
    MARCTABDEF_N->RESV_FLAG1[0] = MARCTABDEF->RESV_FLAG1;
    MARCTABDEF_N->RESV_FLAG2[0] = MARCTABDEF->RESV_FLAG2;
    MARCTABDEF_N->RESV_FLAG3[0] = MARCTABDEF->RESV_FLAG3;
    MARCTABDEF_N->RESV_FLAG4[0] = MARCTABDEF->RESV_FLAG4;
    MARCTABDEF_N->RESV_FLAG5[0] = MARCTABDEF->RESV_FLAG5;
    MEMCPY_AN(MARCTABDEF_N->RESV_FIELD1, MARCTABDEF->RESV_FIELD1, sizeof(MARCTABDEF->RESV_FIELD1));
    MEMCPY_AN(MARCTABDEF_N->RESV_FIELD2, MARCTABDEF->RESV_FIELD2, sizeof(MARCTABDEF->RESV_FIELD2));
    MEMCPY_AN(MARCTABDEF_N->RESV_FIELD3, MARCTABDEF->RESV_FIELD3, sizeof(MARCTABDEF->RESV_FIELD3));
    MEMCPY_AN(MARCTABDEF_N->RESV_FIELD4, MARCTABDEF->RESV_FIELD4, sizeof(MARCTABDEF->RESV_FIELD4));
    MEMCPY_AN(MARCTABDEF_N->RESV_FIELD5, MARCTABDEF->RESV_FIELD5, sizeof(MARCTABDEF->RESV_FIELD5));
}


/* Del Null Function */
void ADB_del_null_marctabdef(struct MARCTABDEF_N_TAG *MARCTABDEF_N, struct MARCTABDEF_TAG *MARCTABDEF)
{
    MEMCPY_DN(MARCTABDEF->FACTORY, MARCTABDEF_N->FACTORY, sizeof(MARCTABDEF->FACTORY));
    MEMCPY_DN(MARCTABDEF->TBL_NAME, MARCTABDEF_N->TBL_NAME, sizeof(MARCTABDEF->TBL_NAME));
    MARCTABDEF->TBL_TYPE = MARCTABDEF_N->TBL_TYPE[0];
    MEMCPY_DN(MARCTABDEF->MODULE, MARCTABDEF_N->MODULE, sizeof(MARCTABDEF->MODULE));
    MEMCPY_DN(MARCTABDEF->KEY_FIELD1, MARCTABDEF_N->KEY_FIELD1, sizeof(MARCTABDEF->KEY_FIELD1));
    MEMCPY_DN(MARCTABDEF->KEY_FIELD2, MARCTABDEF_N->KEY_FIELD2, sizeof(MARCTABDEF->KEY_FIELD2));
    MEMCPY_DN(MARCTABDEF->KEY_FIELD3, MARCTABDEF_N->KEY_FIELD3, sizeof(MARCTABDEF->KEY_FIELD3));
    MEMCPY_DN(MARCTABDEF->KEY_FIELD4, MARCTABDEF_N->KEY_FIELD4, sizeof(MARCTABDEF->KEY_FIELD4));
    MEMCPY_DN(MARCTABDEF->KEY_FIELD5, MARCTABDEF_N->KEY_FIELD5, sizeof(MARCTABDEF->KEY_FIELD5));
    MEMCPY_DN(MARCTABDEF->TERM_FIELD, MARCTABDEF_N->TERM_FIELD, sizeof(MARCTABDEF->TERM_FIELD));
    MEMCPY_DN(MARCTABDEF->WHERE_CND, MARCTABDEF_N->WHERE_CND, sizeof(MARCTABDEF->WHERE_CND));
    MARCTABDEF->RESV_FLAG1 = MARCTABDEF_N->RESV_FLAG1[0];
    MARCTABDEF->RESV_FLAG2 = MARCTABDEF_N->RESV_FLAG2[0];
    MARCTABDEF->RESV_FLAG3 = MARCTABDEF_N->RESV_FLAG3[0];
    MARCTABDEF->RESV_FLAG4 = MARCTABDEF_N->RESV_FLAG4[0];
    MARCTABDEF->RESV_FLAG5 = MARCTABDEF_N->RESV_FLAG5[0];
    MEMCPY_DN(MARCTABDEF->RESV_FIELD1, MARCTABDEF_N->RESV_FIELD1, sizeof(MARCTABDEF->RESV_FIELD1));
    MEMCPY_DN(MARCTABDEF->RESV_FIELD2, MARCTABDEF_N->RESV_FIELD2, sizeof(MARCTABDEF->RESV_FIELD2));
    MEMCPY_DN(MARCTABDEF->RESV_FIELD3, MARCTABDEF_N->RESV_FIELD3, sizeof(MARCTABDEF->RESV_FIELD3));
    MEMCPY_DN(MARCTABDEF->RESV_FIELD4, MARCTABDEF_N->RESV_FIELD4, sizeof(MARCTABDEF->RESV_FIELD4));
    MEMCPY_DN(MARCTABDEF->RESV_FIELD5, MARCTABDEF_N->RESV_FIELD5, sizeof(MARCTABDEF->RESV_FIELD5));
}


