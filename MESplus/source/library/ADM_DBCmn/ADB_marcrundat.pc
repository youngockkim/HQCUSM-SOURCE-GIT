/* Add Null Function */
void ADB_add_null_marcrundat(struct MARCRUNDAT_N_TAG *MARCRUNDAT_N, struct MARCRUNDAT_TAG *MARCRUNDAT)
{
    /* memset by NULL */
    memset(MARCRUNDAT_N, '\0', sizeof(struct MARCRUNDAT_N_TAG));
    
    MEMCPY_AN(MARCRUNDAT_N->FACTORY, MARCRUNDAT->FACTORY, sizeof(MARCRUNDAT->FACTORY));
    MEMCPY_AN(MARCRUNDAT_N->MODULE, MARCRUNDAT->MODULE, sizeof(MARCRUNDAT->MODULE));
    MEMCPY_AN(MARCRUNDAT_N->CREATE_TIME, MARCRUNDAT->CREATE_TIME, sizeof(MARCRUNDAT->CREATE_TIME));
    MARCRUNDAT_N->RESV_FLAG1[0] = MARCRUNDAT->RESV_FLAG1;
    MARCRUNDAT_N->RESV_FLAG2[0] = MARCRUNDAT->RESV_FLAG2;
    MEMCPY_AN(MARCRUNDAT_N->RESV_FIELD1, MARCRUNDAT->RESV_FIELD1, sizeof(MARCRUNDAT->RESV_FIELD1));
    MEMCPY_AN(MARCRUNDAT_N->RESV_FIELD2, MARCRUNDAT->RESV_FIELD2, sizeof(MARCRUNDAT->RESV_FIELD2));
}


/* Del Null Function */
void ADB_del_null_marcrundat(struct MARCRUNDAT_N_TAG *MARCRUNDAT_N, struct MARCRUNDAT_TAG *MARCRUNDAT)
{
    MEMCPY_DN(MARCRUNDAT->FACTORY, MARCRUNDAT_N->FACTORY, sizeof(MARCRUNDAT->FACTORY));
    MEMCPY_DN(MARCRUNDAT->MODULE, MARCRUNDAT_N->MODULE, sizeof(MARCRUNDAT->MODULE));
    MEMCPY_DN(MARCRUNDAT->CREATE_TIME, MARCRUNDAT_N->CREATE_TIME, sizeof(MARCRUNDAT->CREATE_TIME));
    MARCRUNDAT->RESV_FLAG1 = MARCRUNDAT_N->RESV_FLAG1[0];
    MARCRUNDAT->RESV_FLAG2 = MARCRUNDAT_N->RESV_FLAG2[0];
    MEMCPY_DN(MARCRUNDAT->RESV_FIELD1, MARCRUNDAT_N->RESV_FIELD1, sizeof(MARCRUNDAT->RESV_FIELD1));
    MEMCPY_DN(MARCRUNDAT->RESV_FIELD2, MARCRUNDAT_N->RESV_FIELD2, sizeof(MARCRUNDAT->RESV_FIELD2));
}


