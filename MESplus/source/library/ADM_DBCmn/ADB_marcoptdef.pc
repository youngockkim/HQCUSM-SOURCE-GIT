    DB_start_query_timer();

    ADB_add_null_marcoptdef(&MARCOPTDEF_N, MARCOPTDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE ADB_MARCOPTDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    MODULE,
                    TERM,
                    DAYS,
                    SPD_TIME,
                    MOD_TYPE,
                    MED_TYPE,
                    ROL_FLAG,
                    MAS_DEL_FLAG,
                    RESV_FLAG1,
                    RESV_FLAG2,
                    RESV_FLAG3,
                    RESV_FLAG4,
                    RESV_FLAG5,
                    RESV_FIELD1,
