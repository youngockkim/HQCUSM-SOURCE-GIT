    MEMCPY_AN(MARCOPTDEF_N->FACTORY, MARCOPTDEF->FACTORY, sizeof(MARCOPTDEF->FACTORY));
    MEMCPY_AN(MARCOPTDEF_N->MODULE, MARCOPTDEF->MODULE, sizeof(MARCOPTDEF->MODULE));
    MARCOPTDEF_N->TERM = MARCOPTDEF->TERM;
    MARCOPTDEF_N->DAYS = MARCOPTDEF->DAYS;
    MARCOPTDEF_N->SPD_TIME = MARCOPTDEF->SPD_TIME;
    MARCOPTDEF_N->MOD_TYPE[0] = MARCOPTDEF->MOD_TYPE;
    MARCOPTDEF_N->MED_TYPE[0] = MARCOPTDEF->MED_TYPE;
    MARCOPTDEF_N->ROL_FLAG[0] = MARCOPTDEF->ROL_FLAG;
    MARCOPTDEF_N->MAS_DEL_FLAG[0] = MARCOPTDEF->MAS_DEL_FLAG;
    MARCOPTDEF_N->RESV_FLAG1[0] = MARCOPTDEF->RESV_FLAG1;
    MARCOPTDEF_N->RESV_FLAG2[0] = MARCOPTDEF->RESV_FLAG2;
