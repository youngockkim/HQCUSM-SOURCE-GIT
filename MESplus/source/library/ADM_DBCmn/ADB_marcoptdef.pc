                    RESV_FIELD3,
                    RESV_FIELD4,
                    RESV_FIELD5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MARCOPTDEF
                WHERE FACTORY = :MARCOPTDEF_N.FACTORY
                    AND MODULE >= :MARCOPTDEF_N.MODULE
                ORDER BY FACTORY ASC,
                    MODULE ASC;
            EXEC SQL OPEN ADB_MARCOPTDEF_CUR_1;
            break;
            
        case 2:
            EXEC SQL DECLARE ADB_MARCOPTDEF_CUR_2 CURSOR FOR 
                SELECT 
                    FACTORY,
                    MODULE,
                    TERM,
                    DAYS,
