    MARCOPTDEF_N->RESV_FLAG4[0] = MARCOPTDEF->RESV_FLAG4;
    MARCOPTDEF_N->RESV_FLAG5[0] = MARCOPTDEF->RESV_FLAG5;
    MEMCPY_AN(MARCOPTDEF_N->RESV_FIELD1, MARCOPTDEF->RESV_FIELD1, sizeof(MARCOPTDEF->RESV_FIELD1));
    MEMCPY_AN(MARCOPTDEF_N->RESV_FIELD2, MARCOPTDEF->RESV_FIELD2, sizeof(MARCOPTDEF->RESV_FIELD2));
    MEMCPY_AN(MARCOPTDEF_N->RESV_FIELD3, MARCOPTDEF->RESV_FIELD3, sizeof(MARCOPTDEF->RESV_FIELD3));
    MEMCPY_AN(MARCOPTDEF_N->RESV_FIELD4, MARCOPTDEF->RESV_FIELD4, sizeof(MARCOPTDEF->RESV_FIELD4));
    MEMCPY_AN(MARCOPTDEF_N->RESV_FIELD5, MARCOPTDEF->RESV_FIELD5, sizeof(MARCOPTDEF->RESV_FIELD5));
    MEMCPY_AN(MARCOPTDEF_N->CREATE_USER_ID, MARCOPTDEF->CREATE_USER_ID, sizeof(MARCOPTDEF->CREATE_USER_ID));
    MEMCPY_AN(MARCOPTDEF_N->CREATE_TIME, MARCOPTDEF->CREATE_TIME, sizeof(MARCOPTDEF->CREATE_TIME));
    MEMCPY_AN(MARCOPTDEF_N->UPDATE_USER_ID, MARCOPTDEF->UPDATE_USER_ID, sizeof(MARCOPTDEF->UPDATE_USER_ID));
    MEMCPY_AN(MARCOPTDEF_N->UPDATE_TIME, MARCOPTDEF->UPDATE_TIME, sizeof(MARCOPTDEF->UPDATE_TIME));
}


/* Del Null Function */
void ADB_del_null_marcoptdef(struct MARCOPTDEF_N_TAG *MARCOPTDEF_N, struct MARCOPTDEF_TAG *MARCOPTDEF)
{
    MEMCPY_DN(MARCOPTDEF->FACTORY, MARCOPTDEF_N->FACTORY, sizeof(MARCOPTDEF->FACTORY));
    MEMCPY_DN(MARCOPTDEF->MODULE, MARCOPTDEF_N->MODULE, sizeof(MARCOPTDEF->MODULE));
    MARCOPTDEF->TERM = MARCOPTDEF_N->TERM;
    MARCOPTDEF->DAYS = MARCOPTDEF_N->DAYS;
    MARCOPTDEF->SPD_TIME = MARCOPTDEF_N->SPD_TIME;
    MARCOPTDEF->MOD_TYPE = MARCOPTDEF_N->MOD_TYPE[0];
    MARCOPTDEF->MED_TYPE = MARCOPTDEF_N->MED_TYPE[0];
    MARCOPTDEF->ROL_FLAG = MARCOPTDEF_N->ROL_FLAG[0];
    MARCOPTDEF->MAS_DEL_FLAG = MARCOPTDEF_N->MAS_DEL_FLAG[0];
    MARCOPTDEF->RESV_FLAG1 = MARCOPTDEF_N->RESV_FLAG1[0];
    MARCOPTDEF->RESV_FLAG2 = MARCOPTDEF_N->RESV_FLAG2[0];
    MARCOPTDEF->RESV_FLAG3 = MARCOPTDEF_N->RESV_FLAG3[0];
    MARCOPTDEF->RESV_FLAG4 = MARCOPTDEF_N->RESV_FLAG4[0];
    MARCOPTDEF->RESV_FLAG5 = MARCOPTDEF_N->RESV_FLAG5[0];
    MEMCPY_DN(MARCOPTDEF->RESV_FIELD1, MARCOPTDEF_N->RESV_FIELD1, sizeof(MARCOPTDEF->RESV_FIELD1));
    MEMCPY_DN(MARCOPTDEF->RESV_FIELD2, MARCOPTDEF_N->RESV_FIELD2, sizeof(MARCOPTDEF->RESV_FIELD2));
    MEMCPY_DN(MARCOPTDEF->RESV_FIELD3, MARCOPTDEF_N->RESV_FIELD3, sizeof(MARCOPTDEF->RESV_FIELD3));
    MEMCPY_DN(MARCOPTDEF->RESV_FIELD4, MARCOPTDEF_N->RESV_FIELD4, sizeof(MARCOPTDEF->RESV_FIELD4));
    MEMCPY_DN(MARCOPTDEF->RESV_FIELD5, MARCOPTDEF_N->RESV_FIELD5, sizeof(MARCOPTDEF->RESV_FIELD5));
    MEMCPY_DN(MARCOPTDEF->CREATE_USER_ID, MARCOPTDEF_N->CREATE_USER_ID, sizeof(MARCOPTDEF->CREATE_USER_ID));
    MEMCPY_DN(MARCOPTDEF->CREATE_TIME, MARCOPTDEF_N->CREATE_TIME, sizeof(MARCOPTDEF->CREATE_TIME));
    MEMCPY_DN(MARCOPTDEF->UPDATE_USER_ID, MARCOPTDEF_N->UPDATE_USER_ID, sizeof(MARCOPTDEF->UPDATE_USER_ID));
    MEMCPY_DN(MARCOPTDEF->UPDATE_TIME, MARCOPTDEF_N->UPDATE_TIME, sizeof(MARCOPTDEF->UPDATE_TIME));
}



