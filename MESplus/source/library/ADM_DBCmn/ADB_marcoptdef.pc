                    UPDATE_TIME
                FROM MARCOPTDEF 
                WHERE FACTORY = :MARCOPTDEF_N.FACTORY ;        
            EXEC SQL OPEN ADB_MARCOPTDEF_CUR_2;
            break;
        
        case 3:
            EXEC SQL DECLARE ADB_MARCOPTDEF_CUR_3 CURSOR FOR 
                SELECT 
                    FACTORY,
                    MODULE,
                    TERM,
                    DAYS,
                    SPD_TIME,
                    MOD_TYPE,
                    MED_TYPE,
                    ROL_FLAG,
                    MAS_DEL_FLAG,
                    RESV_FLAG1,
                    RESV_FLAG2,
                    RESV_FLAG3,
                    RESV_FLAG4,
