                                                        :MTMPRESHIS_BAK_N.LAST_DOWN_HIST_SEQ,
                                                        :MTMPRESHIS_BAK_N.HIST_START_SEQ,
                                                        :MTMPRESHIS_BAK_N.HIST_DEL_FLAG,
                                                        :MTMPRESHIS_BAK_N.HIST_DEL_TIME,
                                                        :MTMPRESHIS_BAK_N.HIST_DEL_USER_ID,
                                                        :MTMPRESHIS_BAK_N.HIST_DEL_COMMENT,
                                                        :MTMPRESHIS_BAK_N.PROCESS_FLAG;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_mtmpreshis_bak(&MTMPRESHIS_BAK_N, MTMPRESHIS_BAK);
    }
    DB_stop_query_timer("RPT_fetch_mtmpreshis_bak", sel_type);
}


/* SQL CURSOR CLOSE Function */
void RPT_close_mtmpreshis_bak(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_MTMPRESHIS_BAK_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_mtmpreshis_bak", sel_type);
}


/* Initialize Function */
void RPT_init_mtmpreshis_bak(struct MTMPRESHIS_BAK_TAG *MTMPRESHIS_BAK)
{
    /* memset by Space */
    memset(MTMPRESHIS_BAK, ' ', sizeof(struct MTMPRESHIS_BAK_TAG));
    
    MTMPRESHIS_BAK->TABLE_UPDATE_SEQ = 0;
    MTMPRESHIS_BAK->HIST_SEQ = 0;
