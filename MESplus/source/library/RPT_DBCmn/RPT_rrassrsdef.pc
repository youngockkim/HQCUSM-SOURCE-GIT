			DECODE(TRIM(SUBRES_STS_8), '', NULL, SUBRES_STS_8),
			DECODE(TRIM(SUBRES_STS_9), '', NULL, SUBRES_STS_9),
			DECODE(TRIM(SUBRES_STS_10), '', NULL, SUBRES_STS_10),
			DECODE(TRIM(LOT_ID), '', NULL, LOT_ID),
			DECODE(TRIM(SUBLOT_ID), '', NULL, SUBLOT_ID),
			DECODE(TRIM(CRR_ID), '', NULL, CRR_ID),
			DECODE(TRIM(LAST_EVENT_ID), '', NULL, LAST_EVENT_ID),
			DECODE(TRIM(LAST_EVENT_TIME), '', NULL, TO_DATE(LAST_EVENT_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(LAST_ACTIVE_HIST_SEQ), '', NULL, LAST_ACTIVE_HIST_SEQ),
			DECODE(TRIM(LAST_HIST_SEQ), '', NULL, LAST_HIST_SEQ)
		FROM MRASSRSDEF
        WHERE FACTORY = :RRASSRSDEF_N.FACTORY
          AND RES_ID = :RRASSRSDEF_N.RES_ID
          AND SUBRES_ID = :RRASSRSDEF_N.SUBRES_ID;
    DB_stop_query_timer("RPT_select_insert_rrassrsdef", 0);
}


