                    DECODE(LAST_EVENT_ID, NULL, 'Y', ' '), NVL(LAST_EVENT_ID, ' '),
                    DECODE(LAST_EVENT_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(LAST_EVENT_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(LAST_ACTIVE_HIST_SEQ, NULL, 'Y', ' '), NVL(LAST_ACTIVE_HIST_SEQ, '0'),
                    DECODE(LAST_HIST_SEQ, NULL, 'Y', ' '), NVL(LAST_HIST_SEQ, '0')
                FROM RRASSRSDEF
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SUBRES_ID ASC;
            EXEC SQL OPEN RPT_RRASSRSDEF_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rrassrsdef", sel_type);
}


