/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rrassrsdef(int sel_type, struct RRASSRSDEF_TAG *RRASSRSDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASSRSDEF_N_TAG RRASSRSDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrassrsdef(&RRASSRSDEF_N, RRASSRSDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RRASSRSDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    DECODE(SUBRES_DESC, NULL, 'Y', ' '), NVL(SUBRES_DESC, ' '),
                    DECODE(PARENTS_SUBRES_ID, NULL, 'Y', ' '), NVL(PARENTS_SUBRES_ID, ' '),
                    DECODE(SUBRES_TYPE, NULL, 'Y', ' '), NVL(SUBRES_TYPE, ' '),
                    DECODE(USE_FAC_PRT_FLAG, NULL, 'Y', ' '), NVL(USE_FAC_PRT_FLAG, ' '),
                    DECODE(RES_STS_PRT_1, NULL, 'Y', ' '), NVL(RES_STS_PRT_1, ' '),
                    DECODE(RES_STS_PRT_2, NULL, 'Y', ' '), NVL(RES_STS_PRT_2, ' '),
