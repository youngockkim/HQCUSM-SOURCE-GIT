void RPT_select_insert_rrassrsdef(struct RRASSRSDEF_TAG *RRASSRSDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASSRSDEF_N_TAG RRASSRSDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrassrsdef(&RRASSRSDEF_N, RRASSRSDEF);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RRASSRSDEF
		SELECT
			FACTORY,
			RES_ID,
			SUBRES_ID,
			DECODE(TRIM(SUBRES_DESC), '', NULL, SUBRES_DESC),
			DECODE(TRIM(PARENTS_SUBRES_ID), '', NULL, PARENTS_SUBRES_ID),
			DECODE(TRIM(SUBRES_TYPE), '', NULL, SUBRES_TYPE),
			DECODE(TRIM(USE_FAC_PRT_FLAG), '', NULL, USE_FAC_PRT_FLAG),
			DECODE(TRIM(RES_STS_PRT_1), '', NULL, RES_STS_PRT_1),
			DECODE(TRIM(RES_STS_PRT_2), '', NULL, RES_STS_PRT_2),
			DECODE(TRIM(RES_STS_PRT_3), '', NULL, RES_STS_PRT_3),
			DECODE(TRIM(RES_STS_PRT_4), '', NULL, RES_STS_PRT_4),
			DECODE(TRIM(RES_STS_PRT_5), '', NULL, RES_STS_PRT_5),
