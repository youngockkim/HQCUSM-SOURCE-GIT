                    RWK_FLAG = DECODE(:RWIPLOTLSM_N.RWK_FLAG.IS_NULL, 'Y', NULL, :RWIPLOTLSM_N.RWK_FLAG.VALUE),
                    HIST_DEL_TIME = DECODE(:RWIPLOTLSM_N.HIST_DEL_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTLSM_N.HIST_DEL_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    UNIT = DECODE(:RWIPLOTLSM_N.UNIT.IS_NULL, 'Y', NULL, :RWIPLOTLSM_N.UNIT.VALUE)
                WHERE LOT_ID = :RWIPLOTLSM_N.LOT_ID
                    AND HIST_SEQ = :RWIPLOTLSM_N.HIST_SEQ
                    AND QTY_FLAG = :RWIPLOTLSM_N.QTY_FLAG
                    AND SEQ_NUM = :RWIPLOTLSM_N.SEQ_NUM;
            break;

        case 2:
            EXEC SQL UPDATE RWIPLOTLSM SET
                    HIST_DEL_FLAG = DECODE(:RWIPLOTLSM_N.HIST_DEL_FLAG.IS_NULL, 'Y', 'N', :RWIPLOTLSM_N.HIST_DEL_FLAG.VALUE),
                    HIST_DEL_TIME = DECODE(:RWIPLOTLSM_N.HIST_DEL_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTLSM_N.HIST_DEL_TIME.VALUE, 'YYYYMMDDHH24MISS'))
                WHERE LOT_ID = :RWIPLOTLSM_N.LOT_ID
                    AND HIST_SEQ = :RWIPLOTLSM_N.HIST_SEQ;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_update_rwiplotlsm", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rwiplotlsm(int sel_type, struct RWIPLOTLSM_TAG *RWIPLOTLSM)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTLSM_N_TAG RWIPLOTLSM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplotlsm(&RWIPLOTLSM_N, RWIPLOTLSM);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RWIPLOTLSM_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    QTY_FLAG,
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(HIST_DEL_FLAG, NULL, 'Y', ' '), NVL(HIST_DEL_FLAG, 'N'),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '),
                    DECODE(MAT_ID, NULL, 'Y', ' '), NVL(MAT_ID, ' '),
                    DECODE(MAT_VER, NULL, 'Y', ' '), NVL(MAT_VER, '0'),
                    DECODE(FLOW, NULL, 'Y', ' '), NVL(FLOW, ' '),
                    DECODE(FLOW_SEQ_NUM, NULL, 'Y', ' '), NVL(FLOW_SEQ_NUM, '0'),
                    DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
                    DECODE(RES_ID, NULL, 'Y', ' '), NVL(RES_ID, ' '),
                    SEQ_NUM,
                    DECODE(LOSS_CODE, NULL, 'Y', ' '), NVL(LOSS_CODE, ' '),
                    DECODE(LOSS_QTY, NULL, 'Y', ' '), NVL(LOSS_QTY, '0'),
                    DECODE(RWK_FLAG, NULL, 'Y', ' '), NVL(RWK_FLAG, ' '),
                    DECODE(HIST_DEL_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(HIST_DEL_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(UNIT, NULL, 'Y', ' '), NVL(UNIT, ' ')
                FROM RWIPLOTLSM
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC,
                    QTY_FLAG ASC,
                    SEQ_NUM ASC;
            EXEC SQL OPEN RPT_RWIPLOTLSM_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rwiplotlsm", sel_type);
}


/* SQL CURSOR FETCH Function */
void RPT_fetch_rwiplotlsm(int sel_type, struct RWIPLOTLSM_TAG *RWIPLOTLSM)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTLSM_N_TAG RWIPLOTLSM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_RWIPLOTLSM_CUR_1 INTO
                :RWIPLOTLSM_N.LOT_ID,
                :RWIPLOTLSM_N.HIST_SEQ,
                :RWIPLOTLSM_N.QTY_FLAG,
                :RWIPLOTLSM_N.TRAN_TIME.IS_NULL, :RWIPLOTLSM_N.TRAN_TIME.VALUE,
                :RWIPLOTLSM_N.HIST_DEL_FLAG.IS_NULL, :RWIPLOTLSM_N.HIST_DEL_FLAG.VALUE,
                :RWIPLOTLSM_N.FACTORY.IS_NULL, :RWIPLOTLSM_N.FACTORY.VALUE,
                :RWIPLOTLSM_N.MAT_ID.IS_NULL, :RWIPLOTLSM_N.MAT_ID.VALUE,
                :RWIPLOTLSM_N.MAT_VER.IS_NULL, :RWIPLOTLSM_N.MAT_VER.VALUE,
                :RWIPLOTLSM_N.FLOW.IS_NULL, :RWIPLOTLSM_N.FLOW.VALUE,
                :RWIPLOTLSM_N.FLOW_SEQ_NUM.IS_NULL, :RWIPLOTLSM_N.FLOW_SEQ_NUM.VALUE,
                :RWIPLOTLSM_N.OPER.IS_NULL, :RWIPLOTLSM_N.OPER.VALUE,
                :RWIPLOTLSM_N.RES_ID.IS_NULL, :RWIPLOTLSM_N.RES_ID.VALUE,
                :RWIPLOTLSM_N.SEQ_NUM,
                :RWIPLOTLSM_N.LOSS_CODE.IS_NULL, :RWIPLOTLSM_N.LOSS_CODE.VALUE,
                :RWIPLOTLSM_N.LOSS_QTY.IS_NULL, :RWIPLOTLSM_N.LOSS_QTY.VALUE,
                :RWIPLOTLSM_N.RWK_FLAG.IS_NULL, :RWIPLOTLSM_N.RWK_FLAG.VALUE,
                :RWIPLOTLSM_N.HIST_DEL_TIME.IS_NULL, :RWIPLOTLSM_N.HIST_DEL_TIME.VALUE,
                :RWIPLOTLSM_N.UNIT.IS_NULL, :RWIPLOTLSM_N.UNIT.VALUE;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rwiplotlsm(&RWIPLOTLSM_N, RWIPLOTLSM);
    }
    DB_stop_query_timer("RPT_fetch_rwiplotlsm", sel_type);
}


