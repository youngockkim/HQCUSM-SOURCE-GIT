void RPT_close_rwiplotlsm(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_RWIPLOTLSM_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_rwiplotlsm", sel_type);
}


/* Initialize Function */
void RPT_init_rwiplotlsm(struct RWIPLOTLSM_TAG *RWIPLOTLSM)
{
    /* memset by Space */
    memset(RWIPLOTLSM, ' ', sizeof(struct RWIPLOTLSM_TAG));
    
    RWIPLOTLSM->HIST_SEQ = 0;
    RWIPLOTLSM->TRAN_TIME.IS_NULL = 'Y';
    RWIPLOTLSM->HIST_DEL_FLAG.IS_NULL = 'Y';
    RWIPLOTLSM->FACTORY.IS_NULL = 'Y';
    RWIPLOTLSM->MAT_ID.IS_NULL = 'Y';
    RWIPLOTLSM->MAT_VER.VALUE = 0;
    RWIPLOTLSM->MAT_VER.IS_NULL = 'Y';
    RWIPLOTLSM->FLOW.IS_NULL = 'Y';
    RWIPLOTLSM->FLOW_SEQ_NUM.VALUE = 0;
    RWIPLOTLSM->FLOW_SEQ_NUM.IS_NULL = 'Y';
    RWIPLOTLSM->OPER.IS_NULL = 'Y';
    RWIPLOTLSM->RES_ID.IS_NULL = 'Y';
    RWIPLOTLSM->SEQ_NUM = 0;
    RWIPLOTLSM->LOSS_CODE.IS_NULL = 'Y';
    RWIPLOTLSM->LOSS_QTY.VALUE = 0;
    RWIPLOTLSM->LOSS_QTY.IS_NULL = 'Y';
    RWIPLOTLSM->RWK_FLAG.IS_NULL = 'Y';
    RWIPLOTLSM->HIST_DEL_TIME.IS_NULL = 'Y';
    RWIPLOTLSM->UNIT.IS_NULL = 'Y';
}


/* Add Null Function */
void RPT_add_null_rwiplotlsm(struct RWIPLOTLSM_N_TAG *RWIPLOTLSM_N, struct RWIPLOTLSM_TAG *RWIPLOTLSM)
{
    /* memset by NULL */
    memset(RWIPLOTLSM_N, '\0', sizeof(struct RWIPLOTLSM_N_TAG));
    
    MEMCPY_AN(RWIPLOTLSM_N->LOT_ID, RWIPLOTLSM->LOT_ID, sizeof(RWIPLOTLSM->LOT_ID));
    RWIPLOTLSM_N->HIST_SEQ = RWIPLOTLSM->HIST_SEQ;
    RWIPLOTLSM_N->QTY_FLAG[0] = RWIPLOTLSM->QTY_FLAG;
    RWIPLOTLSM_N->TRAN_TIME.IS_NULL[0] = RWIPLOTLSM->TRAN_TIME.IS_NULL;
    MEMCPY_AN(RWIPLOTLSM_N->TRAN_TIME.VALUE, RWIPLOTLSM->TRAN_TIME.VALUE, sizeof(RWIPLOTLSM->TRAN_TIME.VALUE));
    RWIPLOTLSM_N->HIST_DEL_FLAG.IS_NULL[0] = RWIPLOTLSM->HIST_DEL_FLAG.IS_NULL;
    RWIPLOTLSM_N->HIST_DEL_FLAG.VALUE[0] = RWIPLOTLSM->HIST_DEL_FLAG.VALUE;
    RWIPLOTLSM_N->FACTORY.IS_NULL[0] = RWIPLOTLSM->FACTORY.IS_NULL;
    MEMCPY_AN(RWIPLOTLSM_N->FACTORY.VALUE, RWIPLOTLSM->FACTORY.VALUE, sizeof(RWIPLOTLSM->FACTORY.VALUE));
    RWIPLOTLSM_N->MAT_ID.IS_NULL[0] = RWIPLOTLSM->MAT_ID.IS_NULL;
    MEMCPY_AN(RWIPLOTLSM_N->MAT_ID.VALUE, RWIPLOTLSM->MAT_ID.VALUE, sizeof(RWIPLOTLSM->MAT_ID.VALUE));
    RWIPLOTLSM_N->MAT_VER.IS_NULL[0] = RWIPLOTLSM->MAT_VER.IS_NULL;
    RWIPLOTLSM_N->MAT_VER.VALUE = RWIPLOTLSM->MAT_VER.VALUE;
    RWIPLOTLSM_N->FLOW.IS_NULL[0] = RWIPLOTLSM->FLOW.IS_NULL;
    MEMCPY_AN(RWIPLOTLSM_N->FLOW.VALUE, RWIPLOTLSM->FLOW.VALUE, sizeof(RWIPLOTLSM->FLOW.VALUE));
    RWIPLOTLSM_N->FLOW_SEQ_NUM.IS_NULL[0] = RWIPLOTLSM->FLOW_SEQ_NUM.IS_NULL;
    RWIPLOTLSM_N->FLOW_SEQ_NUM.VALUE = RWIPLOTLSM->FLOW_SEQ_NUM.VALUE;
    RWIPLOTLSM_N->OPER.IS_NULL[0] = RWIPLOTLSM->OPER.IS_NULL;
    MEMCPY_AN(RWIPLOTLSM_N->OPER.VALUE, RWIPLOTLSM->OPER.VALUE, sizeof(RWIPLOTLSM->OPER.VALUE));
    RWIPLOTLSM_N->RES_ID.IS_NULL[0] = RWIPLOTLSM->RES_ID.IS_NULL;
    MEMCPY_AN(RWIPLOTLSM_N->RES_ID.VALUE, RWIPLOTLSM->RES_ID.VALUE, sizeof(RWIPLOTLSM->RES_ID.VALUE));
    RWIPLOTLSM_N->SEQ_NUM = RWIPLOTLSM->SEQ_NUM;
    RWIPLOTLSM_N->LOSS_CODE.IS_NULL[0] = RWIPLOTLSM->LOSS_CODE.IS_NULL;
    MEMCPY_AN(RWIPLOTLSM_N->LOSS_CODE.VALUE, RWIPLOTLSM->LOSS_CODE.VALUE, sizeof(RWIPLOTLSM->LOSS_CODE.VALUE));
    RWIPLOTLSM_N->LOSS_QTY.IS_NULL[0] = RWIPLOTLSM->LOSS_QTY.IS_NULL;
    RWIPLOTLSM_N->LOSS_QTY.VALUE = RWIPLOTLSM->LOSS_QTY.VALUE;
    RWIPLOTLSM_N->RWK_FLAG.IS_NULL[0] = RWIPLOTLSM->RWK_FLAG.IS_NULL;
    RWIPLOTLSM_N->RWK_FLAG.VALUE[0] = RWIPLOTLSM->RWK_FLAG.VALUE;
    RWIPLOTLSM_N->HIST_DEL_TIME.IS_NULL[0] = RWIPLOTLSM->HIST_DEL_TIME.IS_NULL;
    MEMCPY_AN(RWIPLOTLSM_N->HIST_DEL_TIME.VALUE, RWIPLOTLSM->HIST_DEL_TIME.VALUE, sizeof(RWIPLOTLSM->HIST_DEL_TIME.VALUE));
    RWIPLOTLSM_N->UNIT.IS_NULL[0] = RWIPLOTLSM->UNIT.IS_NULL;
    MEMCPY_AN(RWIPLOTLSM_N->UNIT.VALUE, RWIPLOTLSM->UNIT.VALUE, sizeof(RWIPLOTLSM->UNIT.VALUE));
}


/* Del Null Function */
void RPT_del_null_rwiplotlsm(struct RWIPLOTLSM_N_TAG *RWIPLOTLSM_N, struct RWIPLOTLSM_TAG *RWIPLOTLSM)
{
    MEMCPY_DN(RWIPLOTLSM->LOT_ID, RWIPLOTLSM_N->LOT_ID, sizeof(RWIPLOTLSM->LOT_ID));
    RWIPLOTLSM->HIST_SEQ = RWIPLOTLSM_N->HIST_SEQ;
    RWIPLOTLSM->QTY_FLAG = RWIPLOTLSM_N->QTY_FLAG[0];
    RWIPLOTLSM->TRAN_TIME.IS_NULL = RWIPLOTLSM_N->TRAN_TIME.IS_NULL[0];
    MEMCPY_DN(RWIPLOTLSM->TRAN_TIME.VALUE, RWIPLOTLSM_N->TRAN_TIME.VALUE, sizeof(RWIPLOTLSM->TRAN_TIME.VALUE));
    RWIPLOTLSM->HIST_DEL_FLAG.IS_NULL = RWIPLOTLSM_N->HIST_DEL_FLAG.IS_NULL[0];
    RWIPLOTLSM->HIST_DEL_FLAG.VALUE = RWIPLOTLSM_N->HIST_DEL_FLAG.VALUE[0];
    RWIPLOTLSM->FACTORY.IS_NULL = RWIPLOTLSM_N->FACTORY.IS_NULL[0];
    MEMCPY_DN(RWIPLOTLSM->FACTORY.VALUE, RWIPLOTLSM_N->FACTORY.VALUE, sizeof(RWIPLOTLSM->FACTORY.VALUE));
    RWIPLOTLSM->MAT_ID.IS_NULL = RWIPLOTLSM_N->MAT_ID.IS_NULL[0];
    MEMCPY_DN(RWIPLOTLSM->MAT_ID.VALUE, RWIPLOTLSM_N->MAT_ID.VALUE, sizeof(RWIPLOTLSM->MAT_ID.VALUE));
    RWIPLOTLSM->MAT_VER.IS_NULL = RWIPLOTLSM_N->MAT_VER.IS_NULL[0];
    RWIPLOTLSM->MAT_VER.VALUE = RWIPLOTLSM_N->MAT_VER.VALUE;
    RWIPLOTLSM->FLOW.IS_NULL = RWIPLOTLSM_N->FLOW.IS_NULL[0];
    MEMCPY_DN(RWIPLOTLSM->FLOW.VALUE, RWIPLOTLSM_N->FLOW.VALUE, sizeof(RWIPLOTLSM->FLOW.VALUE));
    RWIPLOTLSM->FLOW_SEQ_NUM.IS_NULL = RWIPLOTLSM_N->FLOW_SEQ_NUM.IS_NULL[0];
    RWIPLOTLSM->FLOW_SEQ_NUM.VALUE = RWIPLOTLSM_N->FLOW_SEQ_NUM.VALUE;
    RWIPLOTLSM->OPER.IS_NULL = RWIPLOTLSM_N->OPER.IS_NULL[0];
    MEMCPY_DN(RWIPLOTLSM->OPER.VALUE, RWIPLOTLSM_N->OPER.VALUE, sizeof(RWIPLOTLSM->OPER.VALUE));
    RWIPLOTLSM->RES_ID.IS_NULL = RWIPLOTLSM_N->RES_ID.IS_NULL[0];
    MEMCPY_DN(RWIPLOTLSM->RES_ID.VALUE, RWIPLOTLSM_N->RES_ID.VALUE, sizeof(RWIPLOTLSM->RES_ID.VALUE));
    RWIPLOTLSM->SEQ_NUM = RWIPLOTLSM_N->SEQ_NUM;
    RWIPLOTLSM->LOSS_CODE.IS_NULL = RWIPLOTLSM_N->LOSS_CODE.IS_NULL[0];
    MEMCPY_DN(RWIPLOTLSM->LOSS_CODE.VALUE, RWIPLOTLSM_N->LOSS_CODE.VALUE, sizeof(RWIPLOTLSM->LOSS_CODE.VALUE));
    RWIPLOTLSM->LOSS_QTY.IS_NULL = RWIPLOTLSM_N->LOSS_QTY.IS_NULL[0];
    RWIPLOTLSM->LOSS_QTY.VALUE = RWIPLOTLSM_N->LOSS_QTY.VALUE;
    RWIPLOTLSM->RWK_FLAG.IS_NULL = RWIPLOTLSM_N->RWK_FLAG.IS_NULL[0];
    RWIPLOTLSM->RWK_FLAG.VALUE = RWIPLOTLSM_N->RWK_FLAG.VALUE[0];
    RWIPLOTLSM->HIST_DEL_TIME.IS_NULL = RWIPLOTLSM_N->HIST_DEL_TIME.IS_NULL[0];
    MEMCPY_DN(RWIPLOTLSM->HIST_DEL_TIME.VALUE, RWIPLOTLSM_N->HIST_DEL_TIME.VALUE, sizeof(RWIPLOTLSM->HIST_DEL_TIME.VALUE));
    RWIPLOTLSM->UNIT.IS_NULL = RWIPLOTLSM_N->UNIT.IS_NULL[0];
    MEMCPY_DN(RWIPLOTLSM->UNIT.VALUE, RWIPLOTLSM_N->UNIT.VALUE, sizeof(RWIPLOTLSM->UNIT.VALUE));
}


