    DB_start_query_timer();

    RPT_add_null_rwiplotlsm(&RWIPLOTLSM_N, RWIPLOTLSM);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RWIPLOTLSM( 
                    LOT_ID, 
                    HIST_SEQ, 
                    QTY_FLAG, 
                    TRAN_TIME, 
                    HIST_DEL_FLAG, 
                    FACTORY, 
                    MAT_ID, 
                    MAT_VER, 
                    FLOW, 
                    FLOW_SEQ_NUM, 
                    OPER, 
                    RES_ID, 
                    SEQ_NUM, 
                    LOSS_CODE, 
                    LOSS_QTY, 
                    RWK_FLAG, 
                    HIST_DEL_TIME,
                    UNIT
         ) 
        VALUES (
                    :RWIPLOTLSM_N.LOT_ID,
                    :RWIPLOTLSM_N.HIST_SEQ,
                    :RWIPLOTLSM_N.QTY_FLAG,
                    DECODE(:RWIPLOTLSM_N.TRAN_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTLSM_N.TRAN_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    DECODE(:RWIPLOTLSM_N.HIST_DEL_FLAG.IS_NULL, 'Y', 'N', :RWIPLOTLSM_N.HIST_DEL_FLAG.VALUE),
                    DECODE(:RWIPLOTLSM_N.FACTORY.IS_NULL, 'Y', NULL, :RWIPLOTLSM_N.FACTORY.VALUE),
                    DECODE(:RWIPLOTLSM_N.MAT_ID.IS_NULL, 'Y', NULL, :RWIPLOTLSM_N.MAT_ID.VALUE),
                    DECODE(:RWIPLOTLSM_N.MAT_VER.IS_NULL, 'Y', NULL, :RWIPLOTLSM_N.MAT_VER.VALUE),
                    DECODE(:RWIPLOTLSM_N.FLOW.IS_NULL, 'Y', NULL, :RWIPLOTLSM_N.FLOW.VALUE),
                    DECODE(:RWIPLOTLSM_N.FLOW_SEQ_NUM.IS_NULL, 'Y', NULL, :RWIPLOTLSM_N.FLOW_SEQ_NUM.VALUE),
                    DECODE(:RWIPLOTLSM_N.OPER.IS_NULL, 'Y', NULL, :RWIPLOTLSM_N.OPER.VALUE),
                    DECODE(:RWIPLOTLSM_N.RES_ID.IS_NULL, 'Y', NULL, :RWIPLOTLSM_N.RES_ID.VALUE),
                    :RWIPLOTLSM_N.SEQ_NUM,
                    DECODE(:RWIPLOTLSM_N.LOSS_CODE.IS_NULL, 'Y', NULL, :RWIPLOTLSM_N.LOSS_CODE.VALUE),
                    DECODE(:RWIPLOTLSM_N.LOSS_QTY.IS_NULL, 'Y', NULL, :RWIPLOTLSM_N.LOSS_QTY.VALUE),
                    DECODE(:RWIPLOTLSM_N.RWK_FLAG.IS_NULL, 'Y', NULL, :RWIPLOTLSM_N.RWK_FLAG.VALUE),
                    DECODE(:RWIPLOTLSM_N.HIST_DEL_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTLSM_N.HIST_DEL_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    DECODE(:RWIPLOTLSM_N.UNIT.IS_NULL, 'Y', NULL, :RWIPLOTLSM_N.UNIT.VALUE)
         );
