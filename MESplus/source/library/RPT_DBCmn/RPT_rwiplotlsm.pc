/* SQL INSERT-SELECT Function */
/* Added By Shyun (2006. 2. 9) */
void RPT_insert_select_rwiplotlsm(struct RWIPLOTLSM_TAG *RWIPLOTLSM) 
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTLSM_N_TAG RWIPLOTLSM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplotlsm(&RWIPLOTLSM_N, RWIPLOTLSM);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RWIPLOTLSM
		SELECT   
			A.LOT_ID,
			A.HIST_SEQ,
			A.QTY_FLAG,
			DECODE(TRIM(A.TRAN_TIME), '', NULL, TO_DATE(A.TRAN_TIME, 'YYYYMMDDHH24MISS')), 
			DECODE(TRIM(A.HIST_DEL_FLAG), '', 'N', A.HIST_DEL_FLAG), 
			DECODE(TRIM(A.FACTORY), '', NULL, A.FACTORY), 
			DECODE(TRIM(A.MAT_ID), '', NULL, A.MAT_ID), 
			DECODE(TRIM(A.MAT_VER), '', NULL, A.MAT_VER), 
			DECODE(TRIM(A.FLOW), '', NULL, A.FLOW), 
			DECODE(TRIM(A.FLOW_SEQ_NUM), '', NULL, A.FLOW_SEQ_NUM), 
			DECODE(TRIM(A.OPER), '', NULL, A.OPER), 
			DECODE(TRIM(A.RES_ID), '', NULL, A.RES_ID), 
			A.SEQ_NUM,
			DECODE(TRIM(A.LOSS_CODE), '', NULL, A.LOSS_CODE),
			DECODE(TRIM(A.LOSS_QTY), '', NULL, A.LOSS_QTY),
			DECODE(TRIM(B.RWK_FLAG), '', 'F', 'R'),
			DECODE(TRIM(B.HIST_DEL_TIME), '', NULL, TO_DATE(B.HIST_DEL_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(A.QTY_FLAG), '', NULL, (DECODE(TRIM(A.QTY_FLAG), '1', DECODE(TRIM(C.UNIT_1), '', NULL, C.UNIT_1), 
			(DECODE(TRIM(A.QTY_FLAG), '2', DECODE(TRIM(C.UNIT_2), '', NULL, C.UNIT_2), 
			(DECODE(TRIM(A.QTY_FLAG), '3', DECODE(TRIM(C.UNIT_3), '', NULL, C.UNIT_3)))))))) 
		FROM MWIPLOTLSM A, MWIPLOTHIS B, MWIPOPRDEF C
        WHERE A.LOT_ID = :RWIPLOTLSM_N.LOT_ID
          AND A.HIST_SEQ = :RWIPLOTLSM_N.HIST_SEQ
		  AND A.LOT_ID = B.LOT_ID(+) AND A.HIST_SEQ = B.HIST_SEQ(+)
		  AND A.FACTORY = C.FACTORY AND A.OPER = C.OPER;
    DB_stop_query_timer("RPT_insert_select_rwiplotlsm", 0);
}
