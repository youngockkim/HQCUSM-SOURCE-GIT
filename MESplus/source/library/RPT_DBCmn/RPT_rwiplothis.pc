                    DECODE(DATE_UPDATED, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_UPDATED, 'YYYYMMDDHH24MISS'), ' ')
                FROM RWIPLOTHIS
                WHERE LOT_ID = :RWIPLOTHIS_N.LOT_ID
                    AND HIST_DEL_FLAG = DECODE(:RWIPLOTHIS_N.HIST_DEL_FLAG.IS_NULL, 'Y', 'N', :RWIPLOTHIS_N.HIST_DEL_FLAG.VALUE)
                ORDER BY HIST_SEQ DESC;
            EXEC SQL OPEN RPT_RWIPLOTHIS_CUR_3;
            break;

        case 4: /* queue time batch */
            EXEC SQL DECLARE RPT_RWIPLOTHIS_CUR_4 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
