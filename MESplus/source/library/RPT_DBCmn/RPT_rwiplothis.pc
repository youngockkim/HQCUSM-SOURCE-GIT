{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTHIS_N_TAG RWIPLOTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplothis(&RWIPLOTHIS_N, RWIPLOTHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE RWIPLOTHIS SET
                    TRAN_TIME = DECODE(:RWIPLOTHIS_N.TRAN_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTHIS_N.TRAN_TIME.VALUE, 'YYYYMMDDHH24MISS')),
