                    DECODE(DATE_UPDATED, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_UPDATED, 'YYYYMMDDHH24MISS'), ' ')
                FROM RWIPLOTHIS
                WHERE TRAN_TIME >= DECODE(:RWIPLOTHIS_N.HIST_DEL_FLAG.VALUE, 'N', NULL, TO_DATE(:RWIPLOTHIS_N.HIST_DEL_FLAG.VALUE, 'YYYYMMDDHH24MISS')) AND
                      FACTORY = DECODE(:RWIPLOTHIS_N.FACTORY.IS_NULL, 'Y', NULL, :RWIPLOTHIS_N.FACTORY.VALUE) AND
                      OLD_MAT_ID = DECODE(:RWIPLOTHIS_N.OLD_MAT_ID.IS_NULL, 'Y', NULL, :RWIPLOTHIS_N.OLD_MAT_ID.VALUE) AND
                      OLD_FLOW = DECODE(:RWIPLOTHIS_N.OLD_FLOW.IS_NULL, 'Y', NULL, :RWIPLOTHIS_N.OLD_FLOW.VALUE) AND
                      OLD_OPER = DECODE(:RWIPLOTHIS_N.OLD_OPER.IS_NULL, 'Y', NULL, :RWIPLOTHIS_N.OLD_OPER.VALUE) AND
                      TRAN_CODE = DECODE(:RWIPLOTHIS_N.TRAN_CODE.IS_NULL, 'Y', NULL, :RWIPLOTHIS_N.TRAN_CODE.VALUE) AND
                      HIST_DEL_FLAG = DECODE(:RWIPLOTHIS_N.HIST_DEL_FLAG.IS_NULL, 'Y', 'N', :RWIPLOTHIS_N.HIST_DEL_FLAG.VALUE)
                ORDER BY TRAN_TIME;
            EXEC SQL OPEN RPT_RWIPLOTHIS_CUR_4;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rwiplothis", sel_type);
}


/* SQL CURSOR FETCH Function */
void RPT_fetch_rwiplothis(int sel_type, struct RWIPLOTHIS_TAG *RWIPLOTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTHIS_N_TAG RWIPLOTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_RWIPLOTHIS_CUR_1 INTO
                :RWIPLOTHIS_N.LOT_ID,
                :RWIPLOTHIS_N.HIST_SEQ,
                :RWIPLOTHIS_N.TRAN_TIME.IS_NULL, :RWIPLOTHIS_N.TRAN_TIME.VALUE,
                :RWIPLOTHIS_N.SYS_TRAN_TIME.IS_NULL, :RWIPLOTHIS_N.SYS_TRAN_TIME.VALUE,
                :RWIPLOTHIS_N.TRAN_CODE.IS_NULL, :RWIPLOTHIS_N.TRAN_CODE.VALUE,
                :RWIPLOTHIS_N.LOT_DESC.IS_NULL, :RWIPLOTHIS_N.LOT_DESC.VALUE,
                :RWIPLOTHIS_N.FACTORY.IS_NULL, :RWIPLOTHIS_N.FACTORY.VALUE,
                :RWIPLOTHIS_N.MAT_ID.IS_NULL, :RWIPLOTHIS_N.MAT_ID.VALUE,
                :RWIPLOTHIS_N.MAT_VER.IS_NULL, :RWIPLOTHIS_N.MAT_VER.VALUE,
                :RWIPLOTHIS_N.FLOW.IS_NULL, :RWIPLOTHIS_N.FLOW.VALUE,
                :RWIPLOTHIS_N.FLOW_SEQ_NUM.IS_NULL, :RWIPLOTHIS_N.FLOW_SEQ_NUM.VALUE,
