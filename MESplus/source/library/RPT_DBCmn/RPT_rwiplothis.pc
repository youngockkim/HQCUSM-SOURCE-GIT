                    :RWIPLOTHIS_N.TRAN_CMF_19.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_19.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_20.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_20.VALUE, 
                    :RWIPLOTHIS_N.TRAN_USER_ID.IS_NULL, :RWIPLOTHIS_N.TRAN_USER_ID.VALUE, 
                    :RWIPLOTHIS_N.TRAN_COMMENT.IS_NULL, :RWIPLOTHIS_N.TRAN_COMMENT.VALUE, 
                    :RWIPLOTHIS_N.PREV_ACTIVE_HIST_SEQ.IS_NULL, :RWIPLOTHIS_N.PREV_ACTIVE_HIST_SEQ.VALUE, 
                    :RWIPLOTHIS_N.MULTI_TR_KEY.IS_NULL, :RWIPLOTHIS_N.MULTI_TR_KEY.VALUE, 
                    :RWIPLOTHIS_N.MULTI_TR_SEQ.IS_NULL, :RWIPLOTHIS_N.MULTI_TR_SEQ.VALUE, 
                    :RWIPLOTHIS_N.EXT_HIST_SEQ.IS_NULL, :RWIPLOTHIS_N.EXT_HIST_SEQ.VALUE, 
                    :RWIPLOTHIS_N.HIST_DEL_FLAG.IS_NULL, :RWIPLOTHIS_N.HIST_DEL_FLAG.VALUE, 
                    :RWIPLOTHIS_N.HIST_DEL_TIME.IS_NULL, :RWIPLOTHIS_N.HIST_DEL_TIME.VALUE, 
                    :RWIPLOTHIS_N.HIST_DEL_USER_ID.IS_NULL, :RWIPLOTHIS_N.HIST_DEL_USER_ID.VALUE, 
                    :RWIPLOTHIS_N.HIST_DEL_COMMENT.IS_NULL, :RWIPLOTHIS_N.HIST_DEL_COMMENT.VALUE, 
                    :RWIPLOTHIS_N.SHIFT.IS_NULL, :RWIPLOTHIS_N.SHIFT.VALUE, 
                    :RWIPLOTHIS_N.PRODUCT_GRP.IS_NULL, :RWIPLOTHIS_N.PRODUCT_GRP.VALUE, 
                    :RWIPLOTHIS_N.YIELD_WORK_CELL.IS_NULL, :RWIPLOTHIS_N.YIELD_WORK_CELL.VALUE, 
                    :RWIPLOTHIS_N.YIELD_SECTION.IS_NULL, :RWIPLOTHIS_N.YIELD_SECTION.VALUE, 
                    :RWIPLOTHIS_N.DATE_CREATED.IS_NULL, :RWIPLOTHIS_N.DATE_CREATED.VALUE, 
                    :RWIPLOTHIS_N.DATE_UPDATED.IS_NULL, :RWIPLOTHIS_N.DATE_UPDATED.VALUE 
                FROM RWIPLOTHIS
                WHERE LOT_ID = :RWIPLOTHIS_N.LOT_ID
                    AND HIST_SEQ = (
                    SELECT MAX(HIST_SEQ) FROM RWIPLOTHIS WHERE
                        LOT_ID = :RWIPLOTHIS_N.LOT_ID
                    AND HIST_DEL_FLAG = DECODE(:RWIPLOTHIS_N.HIST_DEL_FLAG.IS_NULL, 'Y', 'N', :RWIPLOTHIS_N.HIST_DEL_FLAG.VALUE)
                    AND TRAN_CODE = DECODE(:RWIPLOTHIS_N.TRAN_CODE.IS_NULL, 'Y', NULL, :RWIPLOTHIS_N.TRAN_CODE.VALUE)
                    );                   
            break;
            
        case 3:
            /* Queue time check占쏙옙 특占쏙옙 flow,oper占쏙옙 占쏙옙占쏙옙占쏙옙 占시곤옙占쏙옙 占싯삼옙占싼댐옙 */
            EXEC SQL SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(SYS_TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(TRAN_CODE, NULL, 'Y', ' '), NVL(TRAN_CODE, ' '),
                    DECODE(LOT_DESC, NULL, 'Y', ' '), NVL(LOT_DESC, ' '),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '),
                    DECODE(MAT_ID, NULL, 'Y', ' '), NVL(MAT_ID, ' '),
                    DECODE(MAT_VER, NULL, 'Y', ' '), NVL(MAT_VER, '0'),
                    DECODE(FLOW, NULL, 'Y', ' '), NVL(FLOW, ' '),
                    DECODE(FLOW_SEQ_NUM, NULL, 'Y', ' '), NVL(FLOW_SEQ_NUM, '0'),
                    DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
                    DECODE(QTY_1, NULL, 'Y', ' '), NVL(QTY_1, '0'),
                    DECODE(QTY_2, NULL, 'Y', ' '), NVL(QTY_2, '0'),
                    DECODE(QTY_3, NULL, 'Y', ' '), NVL(QTY_3, '0'),
                    DECODE(UNIT_1, NULL, 'Y', ' '), NVL(UNIT_1, ' '),
                    DECODE(UNIT_2, NULL, 'Y', ' '), NVL(UNIT_2, ' '),
                    DECODE(UNIT_3, NULL, 'Y', ' '), NVL(UNIT_3, ' '),
                    DECODE(CRR_ID, NULL, 'Y', ' '), NVL(CRR_ID, ' '),
                    DECODE(LOT_TYPE, NULL, 'Y', ' '), NVL(LOT_TYPE, ' '),
                    DECODE(OWNER_CODE, NULL, 'Y', ' '), NVL(OWNER_CODE, ' '),
                    DECODE(CREATE_CODE, NULL, 'Y', ' '), NVL(CREATE_CODE, ' '),
                    DECODE(LOT_PRIORITY, NULL, 'Y', ' '), NVL(LOT_PRIORITY, ' '),
                    DECODE(LOT_STATUS, NULL, 'Y', ' '), NVL(LOT_STATUS, ' '),
                    DECODE(HOLD_FLAG, NULL, 'Y', ' '), NVL(HOLD_FLAG, 'N'),
                    DECODE(HOLD_CODE, NULL, 'Y', ' '), NVL(HOLD_CODE, ' '),
                    DECODE(HOLD_PASSWORD, NULL, 'Y', ' '), NVL(HOLD_PASSWORD, ' '),
                    DECODE(HOLD_PRV_GRP_ID, NULL, 'Y', ' '), NVL(HOLD_PRV_GRP_ID, ' '),
                    DECODE(OPER_IN_QTY_1, NULL, 'Y', ' '), NVL(OPER_IN_QTY_1, '0'),
                    DECODE(OPER_IN_QTY_2, NULL, 'Y', ' '), NVL(OPER_IN_QTY_2, '0'),
                    DECODE(OPER_IN_QTY_3, NULL, 'Y', ' '), NVL(OPER_IN_QTY_3, '0'),
                    DECODE(CREATE_QTY_1, NULL, 'Y', ' '), NVL(CREATE_QTY_1, '0'),
                    DECODE(CREATE_QTY_2, NULL, 'Y', ' '), NVL(CREATE_QTY_2, '0'),
                    DECODE(CREATE_QTY_3, NULL, 'Y', ' '), NVL(CREATE_QTY_3, '0'),
                    DECODE(START_QTY_1, NULL, 'Y', ' '), NVL(START_QTY_1, '0'),
                    DECODE(START_QTY_2, NULL, 'Y', ' '), NVL(START_QTY_2, '0'),
                    DECODE(START_QTY_3, NULL, 'Y', ' '), NVL(START_QTY_3, '0'),
                    DECODE(INV_FLAG, NULL, 'Y', ' '), NVL(INV_FLAG, ' '),
                    DECODE(TRANSIT_FLAG, NULL, 'Y', ' '), NVL(TRANSIT_FLAG, ' '),
                    DECODE(UNIT_EXIST_FLAG, NULL, 'Y', ' '), NVL(UNIT_EXIST_FLAG, ' '),
                    DECODE(INV_UNIT, NULL, 'Y', ' '), NVL(INV_UNIT, ' '),
