			DECODE(TRIM(A.TRAN_CMF_15), '', NULL, A.TRAN_CMF_15),
			DECODE(TRIM(A.TRAN_CMF_16), '', NULL, A.TRAN_CMF_16),
			DECODE(TRIM(A.TRAN_CMF_17), '', NULL, A.TRAN_CMF_17),
			DECODE(TRIM(A.TRAN_CMF_18), '', NULL, A.TRAN_CMF_18),
			DECODE(TRIM(A.TRAN_CMF_19), '', NULL, A.TRAN_CMF_19),
			DECODE(TRIM(A.TRAN_CMF_20), '', NULL, A.TRAN_CMF_20),
			DECODE(TRIM(A.TRAN_USER_ID), '', NULL, A.TRAN_USER_ID),
			DECODE(TRIM(A.TRAN_COMMENT), '', NULL, A.TRAN_COMMENT),
			DECODE(TRIM(A.PREV_ACTIVE_HIST_SEQ), '', NULL, A.PREV_ACTIVE_HIST_SEQ),
			DECODE(TRIM(A.MULTI_TR_KEY), '', NULL, A.MULTI_TR_KEY),
			DECODE(TRIM(A.MULTI_TR_SEQ), '', NULL, A.MULTI_TR_SEQ),
			DECODE(TRIM(A.EXT_HIST_SEQ), '', NULL, A.EXT_HIST_SEQ),
			DECODE(TRIM(A.HIST_DEL_FLAG), '', 'N', A.HIST_DEL_FLAG),
			DECODE(TRIM(A.HIST_DEL_TIME), '', NULL, TO_DATE(A.HIST_DEL_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(A.HIST_DEL_USER_ID), '', NULL, A.HIST_DEL_USER_ID),
			DECODE(TRIM(A.HIST_DEL_COMMENT), '', NULL, A.HIST_DEL_COMMENT),
			NULL,
			DECODE(TRIM(SUBSTR(C.MAT_GRP_1, 1,1)), '', NULL, SUBSTR(C.MAT_GRP_1, 1,1)),
			DECODE(TRIM(B.OPER_CMF_4), '', NULL, B.OPER_CMF_4),
			DECODE(TRIM(B.OPER_CMF_3), '', NULL, B.OPER_CMF_3),
			SYSDATE,
			NULL
		FROM MWIPLOTHIS A, MWIPOPRDEF B, MWIPMATDEF C
		WHERE A.LOT_ID = :RWIPLOTHIS_N.LOT_ID
		  AND A.HIST_SEQ = :RWIPLOTHIS_N.HIST_SEQ
		  AND A.FACTORY = B.FACTORY(+)
		  AND A.OPER = B.OPER(+)
		  AND A.FACTORY = C.FACTORY(+)
		  AND A.MAT_ID = C.MAT_ID(+)
		  AND A.MAT_VER = C.MAT_VER(+);
    DB_stop_query_timer("RPT_insert_select_rwiplothis", 0);
}

