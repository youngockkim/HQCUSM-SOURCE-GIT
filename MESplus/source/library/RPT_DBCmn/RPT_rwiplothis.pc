                    :RWIPLOTHIS_N.SAVE_RES_ID_2.IS_NULL, :RWIPLOTHIS_N.SAVE_RES_ID_2.VALUE, 
                    :RWIPLOTHIS_N.SUBRES_ID.IS_NULL, :RWIPLOTHIS_N.SUBRES_ID.VALUE, 
                    :RWIPLOTHIS_N.LOT_GROUP_ID_1.IS_NULL, :RWIPLOTHIS_N.LOT_GROUP_ID_1.VALUE, 
                    :RWIPLOTHIS_N.LOT_GROUP_ID_2.IS_NULL, :RWIPLOTHIS_N.LOT_GROUP_ID_2.VALUE, 
