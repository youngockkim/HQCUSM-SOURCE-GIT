            sprintf(sql + strlen(sql), "DECODE(HIST_DEL_FLAG, NULL, 'Y', ' '), NVL(HIST_DEL_FLAG, 'N'), ");
            sprintf(sql + strlen(sql), "DECODE(HIST_DEL_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(HIST_DEL_TIME, 'YYYYMMDDHH24MISS'), ' '), ");
            sprintf(sql + strlen(sql), "DECODE(HIST_DEL_USER_ID, NULL, 'Y', ' '), NVL(HIST_DEL_USER_ID, ' '), ");
            sprintf(sql + strlen(sql), "DECODE(HIST_DEL_COMMENT, NULL, 'Y', ' '), NVL(HIST_DEL_COMMENT, ' '), ");
            sprintf(sql + strlen(sql), "DECODE(SHIFT, NULL, 'Y', ' '), NVL(SHIFT, ' '), ");
            sprintf(sql + strlen(sql), "DECODE(PRODUCT_GRP, NULL, 'Y', ' '), NVL(PRODUCT_GRP, ' '), ");
            sprintf(sql + strlen(sql), "DECODE(YIELD_WORK_CELL, NULL, 'Y', ' '), NVL(YIELD_WORK_CELL, ' '), ");
            sprintf(sql + strlen(sql), "DECODE(YIELD_SECTION, NULL, 'Y', ' '), NVL(YIELD_SECTION, ' '), ");
            sprintf(sql + strlen(sql), "DECODE(DATE_CREATED, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_CREATED, 'YYYYMMDDHH24MISS'), ' '), ");
            sprintf(sql + strlen(sql), "DECODE(DATE_UPDATED, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_UPDATED, 'YYYYMMDDHH24MISS'), ' ') ");
            sprintf(sql + strlen(sql), " FROM RWIPLOTHIS WHERE ");

            make_valid_quote(ts1, RWIPLOTHIS_N.LOT_ID);
            sprintf(sql + strlen(sql), "LOT_ID = '%s' ", ts1);
	            
			if(RWIPLOTHIS_N.HIST_DEL_FLAG.IS_NULL[0] == ' ')
			{
	            if(RWIPLOTHIS->HIST_DEL_FLAG.VALUE == 'N')
	            {
	                sprintf(sql + strlen(sql), "AND HIST_DEL_FLAG = 'N' ");
	            }
	        }
	         	
			if(RWIPLOTHIS_N.TRAN_CODE.IS_NULL[0] == ' ')
			{
	            if(ISSPACE(RWIPLOTHIS->TRAN_CODE.VALUE, sizeof(RWIPLOTHIS->TRAN_CODE.VALUE)) == DB_FALSE)
	            {
	                make_valid_quote(ts1, RWIPLOTHIS_N.TRAN_CODE.VALUE);
	                sprintf(sql + strlen(sql), "AND TRAN_CODE = '%s' ", ts1);
	            }
			}

	        sprintf(sql + strlen(sql), "AND HIST_SEQ <= '%d'", RWIPLOTHIS_N.HIST_SEQ);
			
            sprintf(sql + strlen(sql), "ORDER BY HIST_SEQ DESC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE RPT_RWIPLOTHIS_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN RPT_RWIPLOTHIS_CUR_2;                 
            break;
            
        case 3:
