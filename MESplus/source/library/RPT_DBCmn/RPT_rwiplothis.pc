            sprintf(sql + strlen(sql), "DECODE(MAT_VER, NULL, 'Y', ' '), NVL(MAT_VER, '0'), ");
            sprintf(sql + strlen(sql), "DECODE(FLOW, NULL, 'Y', ' '), NVL(FLOW, ' '), ");
            sprintf(sql + strlen(sql), "DECODE(FLOW_SEQ_NUM, NULL, 'Y', ' '), NVL(FLOW_SEQ_NUM, '0'), ");
