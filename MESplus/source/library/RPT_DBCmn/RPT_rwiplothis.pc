/* SQL SELECT_SCALAR Function */
double RPT_select_rwiplothis_scalar(int sel_type, struct RWIPLOTHIS_TAG *RWIPLOTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTHIS_N_TAG RWIPLOTHIS_N;
    	double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplothis(&RWIPLOTHIS_N, RWIPLOTHIS);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM RWIPLOTHIS
                WHERE LOT_ID = :RWIPLOTHIS_N.LOT_ID
                    AND HIST_SEQ = :RWIPLOTHIS_N.HIST_SEQ;
            break;

        case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM RWIPLOTHIS
                WHERE LOT_ID = :RWIPLOTHIS_N.LOT_ID
                    AND HIST_SEQ = :RWIPLOTHIS_N.HIST_SEQ
                    AND TRAN_CODE = DECODE(:RWIPLOTHIS_N.TRAN_CODE.IS_NULL, 'Y', NULL, :RWIPLOTHIS_N.TRAN_CODE.VALUE)
                    AND FLOW_IN_TIME = DECODE(:RWIPLOTHIS_N.FLOW_IN_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTHIS_N.FLOW_IN_TIME.VALUE, 'YYYYMMDDHH24MISS'))
                    AND OLD_FACTORY = DECODE(:RWIPLOTHIS_N.FACTORY.IS_NULL, 'Y', NULL, :RWIPLOTHIS_N.FACTORY.VALUE)
                    AND OLD_FLOW = DECODE(:RWIPLOTHIS_N.FLOW.IS_NULL, 'Y', NULL, :RWIPLOTHIS_N.FLOW.VALUE)
                    AND OLD_OPER = DECODE(:RWIPLOTHIS_N.OPER.IS_NULL, 'Y', NULL, :RWIPLOTHIS_N.OPER.VALUE);
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("RPT_select_rwiplothis_scalar", sel_type);
    return d_value;
}


/* SQL DELETE Function */
void RPT_delete_rwiplothis(int sel_type, struct RWIPLOTHIS_TAG *RWIPLOTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTHIS_N_TAG RWIPLOTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplothis(&RWIPLOTHIS_N, RWIPLOTHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM RWIPLOTHIS
                WHERE LOT_ID = :RWIPLOTHIS_N.LOT_ID
                    AND HIST_SEQ = :RWIPLOTHIS_N.HIST_SEQ;
            break;

        case 2:
            EXEC SQL DELETE FROM RWIPLOTHIS
                WHERE LOT_ID = :RWIPLOTHIS_N.LOT_ID;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_delete_rwiplothis", sel_type);
}


