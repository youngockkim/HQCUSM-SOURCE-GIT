{
    /* memset by NULL */
    memset(RWIPLOTHIS_N, '\0', sizeof(struct RWIPLOTHIS_N_TAG));
    
    MEMCPY_AN(RWIPLOTHIS_N->LOT_ID, RWIPLOTHIS->LOT_ID, sizeof(RWIPLOTHIS->LOT_ID));
    RWIPLOTHIS_N->HIST_SEQ = RWIPLOTHIS->HIST_SEQ;
