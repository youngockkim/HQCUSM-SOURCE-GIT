                    :RWIPLOTHIS_N.PRODUCT_GRP.IS_NULL, :RWIPLOTHIS_N.PRODUCT_GRP.VALUE, 
                    :RWIPLOTHIS_N.YIELD_WORK_CELL.IS_NULL, :RWIPLOTHIS_N.YIELD_WORK_CELL.VALUE, 
                    :RWIPLOTHIS_N.YIELD_SECTION.IS_NULL, :RWIPLOTHIS_N.YIELD_SECTION.VALUE, 
