/* SQL INSERT-SELECT Function */
/* Added By Shyun (2006. 2. 9) */
void RPT_insert_select_rwiplothis(struct RWIPLOTHIS_TAG *RWIPLOTHIS) 
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTHIS_N_TAG RWIPLOTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplothis(&RWIPLOTHIS_N, RWIPLOTHIS);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RWIPLOTHIS
		SELECT
			A.LOT_ID,
			A.HIST_SEQ,
			DECODE(TRIM(A.TRAN_TIME), '', NULL, TO_DATE(A.TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(A.SYS_TRAN_TIME), '', NULL, TO_DATE(A.SYS_TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(A.TRAN_CODE), '', NULL, A.TRAN_CODE),
			DECODE(TRIM(A.LOT_DESC), '', NULL, A.LOT_DESC),
			DECODE(TRIM(A.FACTORY), '', NULL, A.FACTORY),
			DECODE(TRIM(A.MAT_ID), '', NULL, A.MAT_ID),
			DECODE(TRIM(A.MAT_VER), '', NULL, A.MAT_VER),
