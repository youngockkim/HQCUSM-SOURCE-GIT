                    DECODE(HIST_DEL_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(HIST_DEL_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(HIST_DEL_USER_ID, NULL, 'Y', ' '), NVL(HIST_DEL_USER_ID, ' '),
                    DECODE(HIST_DEL_COMMENT, NULL, 'Y', ' '), NVL(HIST_DEL_COMMENT, ' '),
