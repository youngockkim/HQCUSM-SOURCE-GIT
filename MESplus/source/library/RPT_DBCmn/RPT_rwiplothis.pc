                    :RWIPLOTHIS_N.YIELD_2.IS_NULL, :RWIPLOTHIS_N.YIELD_2.VALUE, 
                    :RWIPLOTHIS_N.YIELD_3.IS_NULL, :RWIPLOTHIS_N.YIELD_3.VALUE, 
                    :RWIPLOTHIS_N.GOOD_QTY.IS_NULL, :RWIPLOTHIS_N.GOOD_QTY.VALUE, 
                    :RWIPLOTHIS_N.RESV_FIELD_1.IS_NULL, :RWIPLOTHIS_N.RESV_FIELD_1.VALUE, 
                    :RWIPLOTHIS_N.RESV_FIELD_2.IS_NULL, :RWIPLOTHIS_N.RESV_FIELD_2.VALUE, 
                    :RWIPLOTHIS_N.RESV_FIELD_3.IS_NULL, :RWIPLOTHIS_N.RESV_FIELD_3.VALUE, 
                    :RWIPLOTHIS_N.RESV_FIELD_4.IS_NULL, :RWIPLOTHIS_N.RESV_FIELD_4.VALUE, 
                    :RWIPLOTHIS_N.RESV_FIELD_5.IS_NULL, :RWIPLOTHIS_N.RESV_FIELD_5.VALUE, 
                    :RWIPLOTHIS_N.RESV_FLAG_1.IS_NULL, :RWIPLOTHIS_N.RESV_FLAG_1.VALUE, 
                    :RWIPLOTHIS_N.RESV_FLAG_2.IS_NULL, :RWIPLOTHIS_N.RESV_FLAG_2.VALUE, 
                    :RWIPLOTHIS_N.RESV_FLAG_3.IS_NULL, :RWIPLOTHIS_N.RESV_FLAG_3.VALUE, 
                    :RWIPLOTHIS_N.RESV_FLAG_4.IS_NULL, :RWIPLOTHIS_N.RESV_FLAG_4.VALUE, 
                    :RWIPLOTHIS_N.RESV_FLAG_5.IS_NULL, :RWIPLOTHIS_N.RESV_FLAG_5.VALUE, 
                    :RWIPLOTHIS_N.FROM_TO_MAT_ID.IS_NULL, :RWIPLOTHIS_N.FROM_TO_MAT_ID.VALUE, 
                    :RWIPLOTHIS_N.FROM_TO_MAT_VER.IS_NULL, :RWIPLOTHIS_N.FROM_TO_MAT_VER.VALUE, 
                    :RWIPLOTHIS_N.FROM_TO_FLOW.IS_NULL, :RWIPLOTHIS_N.FROM_TO_FLOW.VALUE, 
                    :RWIPLOTHIS_N.FROM_TO_FLOW_SEQ_NUM.IS_NULL, :RWIPLOTHIS_N.FROM_TO_FLOW_SEQ_NUM.VALUE, 
                    :RWIPLOTHIS_N.FROM_TO_OPER.IS_NULL, :RWIPLOTHIS_N.FROM_TO_OPER.VALUE, 
                    :RWIPLOTHIS_N.FROM_TO_QTY_1.IS_NULL, :RWIPLOTHIS_N.FROM_TO_QTY_1.VALUE, 
                    :RWIPLOTHIS_N.FROM_TO_QTY_2.IS_NULL, :RWIPLOTHIS_N.FROM_TO_QTY_2.VALUE, 
                    :RWIPLOTHIS_N.FROM_TO_QTY_3.IS_NULL, :RWIPLOTHIS_N.FROM_TO_QTY_3.VALUE, 
                    :RWIPLOTHIS_N.FROM_TO_HIST_SEQ.IS_NULL, :RWIPLOTHIS_N.FROM_TO_HIST_SEQ.VALUE, 
                    :RWIPLOTHIS_N.OLD_FACTORY.IS_NULL, :RWIPLOTHIS_N.OLD_FACTORY.VALUE, 
                    :RWIPLOTHIS_N.OLD_MAT_ID.IS_NULL, :RWIPLOTHIS_N.OLD_MAT_ID.VALUE, 
                    :RWIPLOTHIS_N.OLD_MAT_VER.IS_NULL, :RWIPLOTHIS_N.OLD_MAT_VER.VALUE, 
                    :RWIPLOTHIS_N.OLD_FLOW.IS_NULL, :RWIPLOTHIS_N.OLD_FLOW.VALUE, 
                    :RWIPLOTHIS_N.OLD_FLOW_SEQ_NUM.IS_NULL, :RWIPLOTHIS_N.OLD_FLOW_SEQ_NUM.VALUE, 
                    :RWIPLOTHIS_N.OLD_OPER.IS_NULL, :RWIPLOTHIS_N.OLD_OPER.VALUE, 
                    :RWIPLOTHIS_N.OLD_QTY_1.IS_NULL, :RWIPLOTHIS_N.OLD_QTY_1.VALUE, 
                    :RWIPLOTHIS_N.OLD_QTY_2.IS_NULL, :RWIPLOTHIS_N.OLD_QTY_2.VALUE, 
                    :RWIPLOTHIS_N.OLD_QTY_3.IS_NULL, :RWIPLOTHIS_N.OLD_QTY_3.VALUE, 
                    :RWIPLOTHIS_N.OLD_LOT_TYPE.IS_NULL, :RWIPLOTHIS_N.OLD_LOT_TYPE.VALUE, 
                    :RWIPLOTHIS_N.OLD_OWNER_CODE.IS_NULL, :RWIPLOTHIS_N.OLD_OWNER_CODE.VALUE, 
                    :RWIPLOTHIS_N.OLD_CREATE_CODE.IS_NULL, :RWIPLOTHIS_N.OLD_CREATE_CODE.VALUE, 
                    :RWIPLOTHIS_N.OLD_FAC_IN_TIME.IS_NULL, :RWIPLOTHIS_N.OLD_FAC_IN_TIME.VALUE, 
                    :RWIPLOTHIS_N.OLD_FLOW_IN_TIME.IS_NULL, :RWIPLOTHIS_N.OLD_FLOW_IN_TIME.VALUE, 
                    :RWIPLOTHIS_N.OLD_OPER_IN_TIME.IS_NULL, :RWIPLOTHIS_N.OLD_OPER_IN_TIME.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_1.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_1.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_2.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_2.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_3.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_3.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_4.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_4.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_5.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_5.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_6.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_6.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_7.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_7.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_8.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_8.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_9.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_9.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_10.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_10.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_11.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_11.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_12.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_12.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_13.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_13.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_14.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_14.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_15.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_15.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_16.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_16.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_17.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_17.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_18.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_18.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_19.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_19.VALUE, 
                    :RWIPLOTHIS_N.TRAN_CMF_20.IS_NULL, :RWIPLOTHIS_N.TRAN_CMF_20.VALUE, 
                    :RWIPLOTHIS_N.TRAN_USER_ID.IS_NULL, :RWIPLOTHIS_N.TRAN_USER_ID.VALUE, 
                    :RWIPLOTHIS_N.TRAN_COMMENT.IS_NULL, :RWIPLOTHIS_N.TRAN_COMMENT.VALUE, 
                    :RWIPLOTHIS_N.PREV_ACTIVE_HIST_SEQ.IS_NULL, :RWIPLOTHIS_N.PREV_ACTIVE_HIST_SEQ.VALUE, 
                    :RWIPLOTHIS_N.MULTI_TR_KEY.IS_NULL, :RWIPLOTHIS_N.MULTI_TR_KEY.VALUE, 
                    :RWIPLOTHIS_N.MULTI_TR_SEQ.IS_NULL, :RWIPLOTHIS_N.MULTI_TR_SEQ.VALUE, 
                    :RWIPLOTHIS_N.EXT_HIST_SEQ.IS_NULL, :RWIPLOTHIS_N.EXT_HIST_SEQ.VALUE, 
                    :RWIPLOTHIS_N.HIST_DEL_FLAG.IS_NULL, :RWIPLOTHIS_N.HIST_DEL_FLAG.VALUE, 
                    :RWIPLOTHIS_N.HIST_DEL_TIME.IS_NULL, :RWIPLOTHIS_N.HIST_DEL_TIME.VALUE, 
                    :RWIPLOTHIS_N.HIST_DEL_USER_ID.IS_NULL, :RWIPLOTHIS_N.HIST_DEL_USER_ID.VALUE, 
                    :RWIPLOTHIS_N.HIST_DEL_COMMENT.IS_NULL, :RWIPLOTHIS_N.HIST_DEL_COMMENT.VALUE, 
                    :RWIPLOTHIS_N.SHIFT.IS_NULL, :RWIPLOTHIS_N.SHIFT.VALUE, 
                    :RWIPLOTHIS_N.PRODUCT_GRP.IS_NULL, :RWIPLOTHIS_N.PRODUCT_GRP.VALUE, 
                    :RWIPLOTHIS_N.YIELD_WORK_CELL.IS_NULL, :RWIPLOTHIS_N.YIELD_WORK_CELL.VALUE, 
                    :RWIPLOTHIS_N.YIELD_SECTION.IS_NULL, :RWIPLOTHIS_N.YIELD_SECTION.VALUE, 
                    :RWIPLOTHIS_N.DATE_CREATED.IS_NULL, :RWIPLOTHIS_N.DATE_CREATED.VALUE, 
                    :RWIPLOTHIS_N.DATE_UPDATED.IS_NULL, :RWIPLOTHIS_N.DATE_UPDATED.VALUE 
                FROM RWIPLOTHIS
                WHERE LOT_ID = :RWIPLOTHIS_N.LOT_ID
                    AND HIST_SEQ = (
                    SELECT NVL(MAX(HIST_SEQ), 0) FROM RWIPLOTHIS WHERE
                            LOT_ID = :RWIPLOTHIS_N.LOT_ID
                        AND HIST_DEL_FLAG = 'N'
                        AND TRAN_CODE IN ( 'START', 'END', 'SKIP', 'REWORK')
                        AND OLD_MAT_ID = DECODE(:RWIPLOTHIS_N.OLD_MAT_ID.IS_NULL, 'Y', NULL, :RWIPLOTHIS_N.OLD_MAT_ID.VALUE)
                        AND OLD_FLOW = DECODE(:RWIPLOTHIS_N.OLD_FLOW.IS_NULL, 'Y', NULL, :RWIPLOTHIS_N.OLD_FLOW.VALUE)
                        AND OLD_OPER = DECODE(:RWIPLOTHIS_N.OLD_OPER.IS_NULL, 'Y', NULL, :RWIPLOTHIS_N.OLD_OPER.VALUE)
                    );                   
            break;

        case 5:
            EXEC SQL SELECT NVL(MAX(HIST_SEQ), 0) 
                INTO :RWIPLOTHIS_N.HIST_SEQ
                FROM RWIPLOTHIS
                WHERE LOT_ID = :RWIPLOTHIS_N.LOT_ID;
            break;

        case 6:
            EXEC SQL SELECT NVL(MAX(HIST_SEQ), 0) 
                INTO :RWIPLOTHIS_N.HIST_SEQ
                FROM RWIPLOTHIS
                WHERE LOT_ID = :RWIPLOTHIS_N.LOT_ID
                  AND HIST_DEL_FLAG = 'N';
            break;
            
        case 7:
            EXEC SQL SELECT 
					DECODE(TRAN_CODE, NULL, 'Y', ' '), NVL(TRAN_CODE, ' '),
					DECODE(FROM_TO_LOT_ID, NULL, 'Y', ' '), NVL(FROM_TO_LOT_ID, ' '),
                    DECODE(FROM_TO_HIST_SEQ, NULL, 'Y', ' '), NVL(FROM_TO_HIST_SEQ, '0'),
					DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
					DECODE(OLD_OPER, NULL, 'Y', ' '), NVL(OLD_OPER, ' '),
					DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' ')
                INTO 
					:RWIPLOTHIS_N.TRAN_CODE.IS_NULL, :RWIPLOTHIS_N.TRAN_CODE.VALUE,
					:RWIPLOTHIS_N.FROM_TO_LOT_ID.IS_NULL, :RWIPLOTHIS_N.FROM_TO_LOT_ID.VALUE,
					:RWIPLOTHIS_N.FROM_TO_HIST_SEQ.IS_NULL, :RWIPLOTHIS_N.FROM_TO_HIST_SEQ.VALUE,
					:RWIPLOTHIS_N.OPER.IS_NULL, :RWIPLOTHIS_N.OPER.VALUE,
					:RWIPLOTHIS_N.OLD_OPER.IS_NULL, :RWIPLOTHIS_N.OLD_OPER.VALUE,
					:RWIPLOTHIS_N.TRAN_TIME.IS_NULL, :RWIPLOTHIS_N.TRAN_TIME.VALUE
                FROM RWIPLOTHIS
                WHERE LOT_ID = :RWIPLOTHIS_N.LOT_ID
				  AND OPER = :RWIPLOTHIS_N.OPER.VALUE
				  AND HIST_SEQ = (SELECT NVL(MIN(HIST_SEQ) , 0)
									FROM RWIPLOTHIS
								   WHERE LOT_ID = :RWIPLOTHIS_N.LOT_ID
									 AND OPER = :RWIPLOTHIS_N.OPER.VALUE
									 AND HIST_DEL_FLAG = 'N');
            break;

        case 8:
            EXEC SQL SELECT 
					DECODE(TRAN_CODE, NULL, 'Y', ' '), NVL(TRAN_CODE, ' '),
					DECODE(FROM_TO_LOT_ID, NULL, 'Y', ' '), NVL(FROM_TO_LOT_ID, ' '),
                    DECODE(FROM_TO_HIST_SEQ, NULL, 'Y', ' '), NVL(FROM_TO_HIST_SEQ, '0'),
					DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
					DECODE(OLD_OPER, NULL, 'Y', ' '), NVL(OLD_OPER, ' '),
					DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' ')
                INTO 
					:RWIPLOTHIS_N.TRAN_CODE.IS_NULL, :RWIPLOTHIS_N.TRAN_CODE.VALUE,
					:RWIPLOTHIS_N.FROM_TO_LOT_ID.IS_NULL, :RWIPLOTHIS_N.FROM_TO_LOT_ID.VALUE,
					:RWIPLOTHIS_N.FROM_TO_HIST_SEQ.IS_NULL, :RWIPLOTHIS_N.FROM_TO_HIST_SEQ.VALUE,
					:RWIPLOTHIS_N.OPER.IS_NULL, :RWIPLOTHIS_N.OPER.VALUE,
					:RWIPLOTHIS_N.OLD_OPER.IS_NULL, :RWIPLOTHIS_N.OLD_OPER.VALUE,
					:RWIPLOTHIS_N.TRAN_TIME.IS_NULL, :RWIPLOTHIS_N.TRAN_TIME.VALUE
                FROM RWIPLOTHIS
                WHERE LOT_ID = :RWIPLOTHIS_N.LOT_ID
				  AND OPER = :RWIPLOTHIS_N.OPER.VALUE
				  AND HIST_SEQ = (SELECT NVL(MAX(HIST_SEQ) , 1)
									FROM RWIPLOTHIS
								   WHERE LOT_ID = :RWIPLOTHIS_N.LOT_ID
									 AND HIST_SEQ < :RWIPLOTHIS_N.HIST_SEQ
									 AND OPER = :RWIPLOTHIS_N.OPER.VALUE
									 AND OPER <> OLD_OPER
									 AND HIST_DEL_FLAG = 'N');
            break;

        case 9:
            EXEC SQL SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(SYS_TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(TRAN_CODE, NULL, 'Y', ' '), NVL(TRAN_CODE, ' '),
                    DECODE(LOT_DESC, NULL, 'Y', ' '), NVL(LOT_DESC, ' '),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '),
                    DECODE(MAT_ID, NULL, 'Y', ' '), NVL(MAT_ID, ' '),
                    DECODE(MAT_VER, NULL, 'Y', ' '), NVL(MAT_VER, '0'),
                    DECODE(FLOW, NULL, 'Y', ' '), NVL(FLOW, ' '),
                    DECODE(FLOW_SEQ_NUM, NULL, 'Y', ' '), NVL(FLOW_SEQ_NUM, '0'),
                    DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
                    DECODE(QTY_1, NULL, 'Y', ' '), NVL(QTY_1, '0'),
                    DECODE(QTY_2, NULL, 'Y', ' '), NVL(QTY_2, '0'),
                    DECODE(QTY_3, NULL, 'Y', ' '), NVL(QTY_3, '0'),
                    DECODE(UNIT_1, NULL, 'Y', ' '), NVL(UNIT_1, ' '),
                    DECODE(UNIT_2, NULL, 'Y', ' '), NVL(UNIT_2, ' '),
                    DECODE(UNIT_3, NULL, 'Y', ' '), NVL(UNIT_3, ' '),
                    DECODE(CRR_ID, NULL, 'Y', ' '), NVL(CRR_ID, ' '),
                    DECODE(LOT_TYPE, NULL, 'Y', ' '), NVL(LOT_TYPE, ' '),
                    DECODE(OWNER_CODE, NULL, 'Y', ' '), NVL(OWNER_CODE, ' '),
                    DECODE(CREATE_CODE, NULL, 'Y', ' '), NVL(CREATE_CODE, ' '),
                    DECODE(LOT_PRIORITY, NULL, 'Y', ' '), NVL(LOT_PRIORITY, ' '),
                    DECODE(LOT_STATUS, NULL, 'Y', ' '), NVL(LOT_STATUS, ' '),
                    DECODE(HOLD_FLAG, NULL, 'Y', ' '), NVL(HOLD_FLAG, 'N'),
                    DECODE(HOLD_CODE, NULL, 'Y', ' '), NVL(HOLD_CODE, ' '),
                    DECODE(HOLD_PASSWORD, NULL, 'Y', ' '), NVL(HOLD_PASSWORD, ' '),
                    DECODE(HOLD_PRV_GRP_ID, NULL, 'Y', ' '), NVL(HOLD_PRV_GRP_ID, ' '),
                    DECODE(OPER_IN_QTY_1, NULL, 'Y', ' '), NVL(OPER_IN_QTY_1, '0'),
                    DECODE(OPER_IN_QTY_2, NULL, 'Y', ' '), NVL(OPER_IN_QTY_2, '0'),
                    DECODE(OPER_IN_QTY_3, NULL, 'Y', ' '), NVL(OPER_IN_QTY_3, '0'),
                    DECODE(CREATE_QTY_1, NULL, 'Y', ' '), NVL(CREATE_QTY_1, '0'),
                    DECODE(CREATE_QTY_2, NULL, 'Y', ' '), NVL(CREATE_QTY_2, '0'),
                    DECODE(CREATE_QTY_3, NULL, 'Y', ' '), NVL(CREATE_QTY_3, '0'),
                    DECODE(START_QTY_1, NULL, 'Y', ' '), NVL(START_QTY_1, '0'),
                    DECODE(START_QTY_2, NULL, 'Y', ' '), NVL(START_QTY_2, '0'),
                    DECODE(START_QTY_3, NULL, 'Y', ' '), NVL(START_QTY_3, '0'),
                    DECODE(INV_FLAG, NULL, 'Y', ' '), NVL(INV_FLAG, ' '),
                    DECODE(TRANSIT_FLAG, NULL, 'Y', ' '), NVL(TRANSIT_FLAG, ' '),
                    DECODE(UNIT_EXIST_FLAG, NULL, 'Y', ' '), NVL(UNIT_EXIST_FLAG, ' '),
                    DECODE(INV_UNIT, NULL, 'Y', ' '), NVL(INV_UNIT, ' '),
                    DECODE(RWK_FLAG, NULL, 'Y', ' '), NVL(RWK_FLAG, ' '),
