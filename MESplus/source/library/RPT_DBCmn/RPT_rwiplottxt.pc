                :RWIPLOTTXT_N.TRAN_CMF_5.IS_NULL, :RWIPLOTTXT_N.TRAN_CMF_5.VALUE;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rwiplottxt(&RWIPLOTTXT_N, RWIPLOTTXT);
    }
    DB_stop_query_timer("RPT_fetch_rwiplottxt", sel_type);
}


/* SQL CURSOR CLOSE Function */
void RPT_close_rwiplottxt(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_RWIPLOTTXT_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_rwiplottxt", sel_type);
}


/* Initialize Function */
void RPT_init_rwiplottxt(struct RWIPLOTTXT_TAG *RWIPLOTTXT)
{
    /* memset by Space */
    memset(RWIPLOTTXT, ' ', sizeof(struct RWIPLOTTXT_TAG));
    
    RWIPLOTTXT->HIST_SEQ = 0;
    RWIPLOTTXT->TRAN_TIME.IS_NULL = 'Y';
    RWIPLOTTXT->SYS_TRAN_TIME.IS_NULL = 'Y';
    RWIPLOTTXT->TRAN_CODE.IS_NULL = 'Y';
    RWIPLOTTXT->MAT_ID.IS_NULL = 'Y';
    RWIPLOTTXT->MAT_VER.VALUE = 0;
    RWIPLOTTXT->MAT_VER.IS_NULL = 'Y';
    RWIPLOTTXT->FACTORY.IS_NULL = 'Y';
    RWIPLOTTXT->OPER.IS_NULL = 'Y';
    RWIPLOTTXT->TRAN_COMMENT.IS_NULL = 'Y';
    RWIPLOTTXT->TRAN_USER_ID.IS_NULL = 'Y';
    RWIPLOTTXT->HIST_DEL_FLAG.IS_NULL = 'Y';
    RWIPLOTTXT->HIST_DEL_TIME.IS_NULL = 'Y';
    RWIPLOTTXT->TRAN_CMF_1.IS_NULL = 'Y';
    RWIPLOTTXT->TRAN_CMF_2.IS_NULL = 'Y';
    RWIPLOTTXT->TRAN_CMF_3.IS_NULL = 'Y';
    RWIPLOTTXT->TRAN_CMF_4.IS_NULL = 'Y';
    RWIPLOTTXT->TRAN_CMF_5.IS_NULL = 'Y';
}


