/* SQL Shift Change Function */
void RPT_shift_change_rsumwipeoh(int sel_type, struct RSUMWIPEOH_TAG *RSUMWIPEOH,char *ps_Prev_WorkDate,char pc_Prev_Shift, 
								 char *ps_shift_date_time)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RSUMWIPEOH_N_TAG RSUMWIPEOH_N;
    	char shift_date_time[15];
    	char Prev_WorkDate[9];
    	char Prev_Shift[2];
    EXEC SQL END DECLARE SECTION;
	
    RPT_add_null_rsumwipeoh(&RSUMWIPEOH_N, RSUMWIPEOH);
    DB_error_code = 0;
    memset(shift_date_time, 0x00, sizeof(shift_date_time));
    memcpy(shift_date_time, ps_shift_date_time, sizeof(shift_date_time)-1);

    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM RSUMWIPEOH
                WHERE WORK_DATE = :RSUMWIPEOH_N.WORK_DATE
                    AND SHIFT = :RSUMWIPEOH_N.SHIFT;
            break;
            
        case 2:
            EXEC SQL DELETE FROM RSUMWIPEOH
                WHERE WORK_DATE = :RSUMWIPEOH_N.WORK_DATE
                    AND SHIFT = :RSUMWIPEOH_N.SHIFT
                    AND FACTORY = :RSUMWIPEOH_N.FACTORY;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:
			memset(Prev_WorkDate,0x00,sizeof(Prev_WorkDate));
			memset(Prev_Shift,0x00,sizeof(Prev_Shift));
			memcpy(Prev_WorkDate,ps_Prev_WorkDate,8);
			Prev_Shift[0]=pc_Prev_Shift;
			
            EXEC SQL INSERT INTO RSUMWIPEOH
					SELECT :RSUMWIPEOH_N.WORK_DATE  ,:RSUMWIPEOH_N.SHIFT   ,FACTORY           ,MAT_ID            ,MAT_VER           ,FLOW              ,
							FLOW_SEQ_NUM      ,OPER              ,LOT_TYPE          ,ORDER_ID          ,CM_KEY_1          ,CM_KEY_2          ,
							CM_KEY_3          ,CM_KEY_4          ,CM_KEY_5          ,:RSUMWIPEOH_N.WORK_MONTH        ,:RSUMWIPEOH_N.WORK_WEEK         ,:RSUMWIPEOH_N.WORK_DAYS         ,
							:RSUMWIPEOH_N.WORK_DAY_OF_WEEK  ,EOH_LOT           ,EOH_QTY_1         ,EOH_QTY_2         ,EOH_QTY_3         ,EOH_HOLD_LOT      ,
							EOH_HOLD_QTY_1    ,EOH_HOLD_QTY_2    ,EOH_HOLD_QTY_3    ,EOH_RWK_LOT       ,EOH_RWK_QTY_1     ,EOH_RWK_QTY_2     ,
							EOH_RWK_QTY_3  
					 FROM RSUMWIPEOH   
                WHERE WORK_DATE = :Prev_WorkDate
                    AND SHIFT = :Prev_Shift;
            break;

        case 102:
			memset(Prev_WorkDate,0x00,sizeof(Prev_WorkDate));
			memset(Prev_Shift,0x00,sizeof(Prev_Shift));
			memcpy(Prev_WorkDate,ps_Prev_WorkDate,8);
			Prev_Shift[0]=pc_Prev_Shift;
			
            EXEC SQL INSERT INTO RSUMWIPEOH
					SELECT :RSUMWIPEOH_N.WORK_DATE  ,:RSUMWIPEOH_N.SHIFT   ,FACTORY           ,MAT_ID            ,MAT_VER           ,FLOW              ,
							FLOW_SEQ_NUM      ,OPER              ,LOT_TYPE          ,ORDER_ID          ,CM_KEY_1          ,CM_KEY_2          ,
							CM_KEY_3          ,CM_KEY_4          ,CM_KEY_5          ,:RSUMWIPEOH_N.WORK_MONTH        ,:RSUMWIPEOH_N.WORK_WEEK         ,:RSUMWIPEOH_N.WORK_DAYS         ,
							:RSUMWIPEOH_N.WORK_DAY_OF_WEEK  ,EOH_LOT           ,EOH_QTY_1         ,EOH_QTY_2         ,EOH_QTY_3         ,EOH_HOLD_LOT      ,
							EOH_HOLD_QTY_1    ,EOH_HOLD_QTY_2    ,EOH_HOLD_QTY_3    ,EOH_RWK_LOT       ,EOH_RWK_QTY_1     ,EOH_RWK_QTY_2     ,
							EOH_RWK_QTY_3  
					FROM RSUMWIPEOH 							   
                WHERE WORK_DATE = :Prev_WorkDate
                    AND SHIFT = :Prev_Shift
                    AND FACTORY = :RSUMWIPEOH_N.FACTORY;
            break;
            
        case 103:
            EXEC SQL INSERT INTO RSUMWIPEOH
					SELECT :RSUMWIPEOH_N.WORK_DATE  ,:RSUMWIPEOH_N.SHIFT         ,A.FACTORY          ,A.MAT_ID           ,A.MAT_VER          ,
							A.FLOW             ,A.FLOW_SEQ_NUM     ,A.OPER             ,A.LOT_TYPE         ,A.ORDER_ID         ,
							:RSUMWIPEOH_N.CM_KEY_1         ,
							:RSUMWIPEOH_N.CM_KEY_2         ,
							:RSUMWIPEOH_N.CM_KEY_3         ,
							:RSUMWIPEOH_N.CM_KEY_4         ,
							:RSUMWIPEOH_N.CM_KEY_5         ,
							:RSUMWIPEOH_N.WORK_MONTH       ,
							:RSUMWIPEOH_N.WORK_WEEK        ,
							:RSUMWIPEOH_N.WORK_DAYS        ,
							:RSUMWIPEOH_N.WORK_DAY_OF_WEEK ,
							SUM(1) AS EOH_LOT          ,
							SUM(A.QTY_1) AS EOH_QTY_1        ,
							SUM(A.QTY_2) AS EOH_QTY_2        ,
							SUM(A.QTY_3) AS EOH_QTY_3        ,
							SUM(DECODE(A.HOLD_FLAG,'Y',1,0)) AS EOH_HOLD_LOT     ,
							SUM(DECODE(A.HOLD_FLAG,'Y',A.QTY_1,0)) AS EOH_HOLD_QTY_1   ,
							SUM(DECODE(A.HOLD_FLAG,'Y',A.QTY_2,0)) AS EOH_HOLD_QTY_2   ,
							SUM(DECODE(A.HOLD_FLAG,'Y',A.QTY_3,0)) AS EOH_HOLD_QTY_3   ,
							SUM(DECODE(A.RWK_FLAG,'Y',1,0)) AS EOH_RWK_LOT      ,
							SUM(DECODE(A.RWK_FLAG,'Y',A.QTY_1,0)) AS EOH_RWK_QTY_1    ,
							SUM(DECODE(A.RWK_FLAG,'Y',A.QTY_2,0)) AS EOH_RWK_QTY_2    ,
							SUM(DECODE(A.RWK_FLAG,'Y',A.QTY_3,0)) AS EOH_RWK_QTY_3    
							FROM MWIPLOTHIS A, 
							(SELECT LOT_ID, MAX(HIST_SEQ) AS HIST_SEQ FROM MWIPLOTHIS 
									WHERE TRAN_TIME < :shift_date_time 
									  AND HIST_DEL_FLAG = ' ' GROUP BY LOT_ID) B,
							(SELECT LOT_ID FROM MWIPLOTSTS
							        WHERE CREATE_TIME < :shift_date_time
							          AND (LOT_DEL_FLAG = ' ' OR (LOT_DEL_FLAG = 'Y' AND LOT_DEL_TIME > :shift_date_time))) C
							WHERE A.LOT_ID = B.LOT_ID 
							  AND A.LOT_ID = C.LOT_ID
							  AND A.HIST_SEQ = B.HIST_SEQ
							  AND (A.QTY_1 > 0 OR A.QTY_2 > 0 OR A.QTY_3 > 0)
							GROUP BY A.FACTORY          ,A.MAT_ID           ,A.MAT_VER          ,
							A.FLOW             ,A.FLOW_SEQ_NUM     ,A.OPER             ,A.LOT_TYPE         ,A.ORDER_ID;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
}

