    memset(RSUMWIPEOH, ' ', sizeof(struct RSUMWIPEOH_TAG));
    
    RSUMWIPEOH->MAT_VER = 0;
    RSUMWIPEOH->FLOW_SEQ_NUM = 0;
    RSUMWIPEOH->EOH_LOT = 0;
    RSUMWIPEOH->EOH_QTY_1 = 0;
    RSUMWIPEOH->EOH_QTY_2 = 0;
    RSUMWIPEOH->EOH_QTY_3 = 0;
    RSUMWIPEOH->EOH_HOLD_LOT = 0;
    RSUMWIPEOH->EOH_HOLD_QTY_1 = 0;
    RSUMWIPEOH->EOH_HOLD_QTY_2 = 0;
    RSUMWIPEOH->EOH_HOLD_QTY_3 = 0;
    RSUMWIPEOH->EOH_RWK_LOT = 0;
    RSUMWIPEOH->EOH_RWK_QTY_1 = 0;
    RSUMWIPEOH->EOH_RWK_QTY_2 = 0;
    RSUMWIPEOH->EOH_RWK_QTY_3 = 0;
}


/* Add Null Function */
void RPT_add_null_rsumwipeoh(struct RSUMWIPEOH_N_TAG *RSUMWIPEOH_N, struct RSUMWIPEOH_TAG *RSUMWIPEOH)
{
