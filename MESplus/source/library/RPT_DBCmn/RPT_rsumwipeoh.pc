/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rsumwipeoh(int sel_type, struct RSUMWIPEOH_TAG *RSUMWIPEOH)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RSUMWIPEOH_N_TAG RSUMWIPEOH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rsumwipeoh(&RSUMWIPEOH_N, RSUMWIPEOH);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RSUMWIPEOH_CUR_1 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    SHIFT,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    LOT_TYPE,
                    ORDER_ID,
                    CM_KEY_1,
                    CM_KEY_2,
                    CM_KEY_3,
                    CM_KEY_4,
                    CM_KEY_5,
                    WORK_MONTH,
                    WORK_WEEK,
                    WORK_DAYS,
                    WORK_DAY_OF_WEEK,
                    EOH_LOT,
                    EOH_QTY_1,
                    EOH_QTY_2,
                    EOH_QTY_3,
                    EOH_HOLD_LOT,
                    EOH_HOLD_QTY_1,
                    EOH_HOLD_QTY_2,
                    EOH_HOLD_QTY_3,
                    EOH_RWK_LOT,
                    EOH_RWK_QTY_1,
                    EOH_RWK_QTY_2,
                    EOH_RWK_QTY_3
                FROM RSUMWIPEOH
                ORDER BY WORK_DATE ASC,
                    SHIFT ASC,
                    FACTORY ASC,
                    MAT_ID ASC,
                    MAT_VER ASC,
                    FLOW ASC,
                    FLOW_SEQ_NUM ASC,
                    OPER ASC,
                    LOT_TYPE ASC,
                    ORDER_ID ASC,
                    CM_KEY_1 ASC,
                    CM_KEY_2 ASC,
                    CM_KEY_3 ASC,
                    CM_KEY_4 ASC,
                    CM_KEY_5 ASC;
            EXEC SQL OPEN RPT_RSUMWIPEOH_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:
            EXEC SQL DECLARE RPT_RSUMWIPEOH_CUR_101 CURSOR FOR
                SELECT DISTINCT WORK_DATE, SHIFT, WORK_DAY_OF_WEEK 
                FROM RSUMWIPEOH
                WHERE FACTORY = :RSUMWIPEOH_N.FACTORY
                  AND (WORK_DATE > :RSUMWIPEOH_N.WORK_DATE
                   OR (WORK_DATE = :RSUMWIPEOH_N.WORK_DATE AND SHIFT >= :RSUMWIPEOH_N.SHIFT))
                ORDER BY WORK_DATE ASC,
						 SHIFT ASC,
						 WORK_DAY_OF_WEEK ASC;
            EXEC SQL OPEN RPT_RSUMWIPEOH_CUR_101;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rsumwipeoh", sel_type);
}


