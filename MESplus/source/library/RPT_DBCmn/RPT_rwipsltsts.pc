/* SQL CURSOR CLOSE Function */
void RPT_close_rwipsltsts(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_RWIPSLTSTS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE RPT_RWIPSLTSTS_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE RPT_RWIPSLTSTS_CUR_3;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_rwipsltsts", sel_type);
}


