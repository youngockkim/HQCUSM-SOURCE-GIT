                FROM RWIPSLTSTS
                WHERE SUBLOT_ID = :RWIPSLTSTS_N.SUBLOT_ID;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rwipsltsts(&RWIPSLTSTS_N, RWIPSLTSTS);
    }
    DB_stop_query_timer("RPT_select_rwipsltsts", sel_type);
}


