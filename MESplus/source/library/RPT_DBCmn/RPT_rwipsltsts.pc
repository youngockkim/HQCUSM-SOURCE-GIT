                    RESV_FIELD_1 = DECODE(:RWIPSLTSTS_N.RESV_FIELD_1.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.RESV_FIELD_1.VALUE),
                    RESV_FIELD_2 = DECODE(:RWIPSLTSTS_N.RESV_FIELD_2.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.RESV_FIELD_2.VALUE),
                    RESV_FIELD_3 = DECODE(:RWIPSLTSTS_N.RESV_FIELD_3.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.RESV_FIELD_3.VALUE),
                    RESV_FIELD_4 = DECODE(:RWIPSLTSTS_N.RESV_FIELD_4.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.RESV_FIELD_4.VALUE),
                    RESV_FIELD_5 = DECODE(:RWIPSLTSTS_N.RESV_FIELD_5.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.RESV_FIELD_5.VALUE),
                    RESV_FLAG_1 = DECODE(:RWIPSLTSTS_N.RESV_FLAG_1.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.RESV_FLAG_1.VALUE),
                    RESV_FLAG_2 = DECODE(:RWIPSLTSTS_N.RESV_FLAG_2.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.RESV_FLAG_2.VALUE),
                    RESV_FLAG_3 = DECODE(:RWIPSLTSTS_N.RESV_FLAG_3.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.RESV_FLAG_3.VALUE),
                    RESV_FLAG_4 = DECODE(:RWIPSLTSTS_N.RESV_FLAG_4.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.RESV_FLAG_4.VALUE),
                    RESV_FLAG_5 = DECODE(:RWIPSLTSTS_N.RESV_FLAG_5.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.RESV_FLAG_5.VALUE)
                WHERE SUBLOT_ID = :RWIPSLTSTS_N.SUBLOT_ID;
            break;

        case 2:
            EXEC SQL UPDATE RWIPSLTSTS SET
                    GRADE = DECODE(:RWIPSLTSTS_N.GRADE.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.GRADE.VALUE)
                WHERE SUBLOT_ID = :RWIPSLTSTS_N.SUBLOT_ID;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_update_rwipsltsts", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rwipsltsts(int sel_type, struct RWIPSLTSTS_TAG *RWIPSLTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RWIPSLTSTS_N_TAG RWIPSLTSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwipsltsts(&RWIPSLTSTS_N, RWIPSLTSTS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RWIPSLTSTS_CUR_1 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    DECODE(LOT_ID, NULL, 'Y', ' '), NVL(LOT_ID, ' '),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '),
                    DECODE(MAT_ID, NULL, 'Y', ' '), NVL(MAT_ID, ' '),
                    DECODE(MAT_VER, NULL, 'Y', ' '), NVL(MAT_VER, '0'),
                    DECODE(FLOW, NULL, 'Y', ' '), NVL(FLOW, ' '),
                    DECODE(FLOW_SEQ_NUM, NULL, 'Y', ' '), NVL(FLOW_SEQ_NUM, '0'),
                    DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
                    DECODE(SLOT_NO, NULL, 'Y', ' '), NVL(SLOT_NO, '0'),
                    DECODE(QTY_2, NULL, 'Y', ' '), NVL(QTY_2, '0'),
                    DECODE(QTY_3, NULL, 'Y', ' '), NVL(QTY_3, '0'),
                    DECODE(CRR_ID, NULL, 'Y', ' '), NVL(CRR_ID, ' '),
                    DECODE(OWNER_CODE, NULL, 'Y', ' '), NVL(OWNER_CODE, ' '),
                    DECODE(CREATE_CODE, NULL, 'Y', ' '), NVL(CREATE_CODE, ' '),
                    DECODE(SUBLOT_STATUS, NULL, 'Y', ' '), NVL(SUBLOT_STATUS, ' '),
                    DECODE(HOLD_FLAG, NULL, 'Y', ' '), NVL(HOLD_FLAG, 'N'),
