                  AND FACTORY = DECODE(:RWIPSLTSTS_N.FACTORY.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.FACTORY.VALUE)
                  AND MAT_ID = DECODE(:RWIPSLTSTS_N.MAT_ID.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.MAT_ID.VALUE)
                  AND MAT_VER = DECODE(:RWIPSLTSTS_N.MAT_VER.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.MAT_VER.VALUE)
                  AND FLOW = DECODE(:RWIPSLTSTS_N.FLOW.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.FLOW.VALUE)
                  AND FLOW_SEQ_NUM = DECODE(:RWIPSLTSTS_N.FLOW_SEQ_NUM.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.FLOW_SEQ_NUM.VALUE)
                  AND OPER = DECODE(:RWIPSLTSTS_N.OPER.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.OPER.VALUE)
                ORDER BY SUBLOT_ID ASC;
            EXEC SQL OPEN RPT_RWIPSLTSTS_CUR_3;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rwipsltsts", sel_type);
}


