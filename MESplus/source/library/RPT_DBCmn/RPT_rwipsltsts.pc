/* SQL INSERT-SELECT Function */
void RPT_insert_select_rwipsltsts(struct RWIPSLTSTS_TAG *RWIPSLTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RWIPSLTSTS_N_TAG RWIPSLTSTS_N;
    EXEC SQL END DECLARE SECTION;

