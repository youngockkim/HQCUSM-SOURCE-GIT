			DECODE(TRIM(LOT_HIST_SEQ), '', NULL, LOT_HIST_SEQ),
			DECODE(TRIM(LAST_TRAN_CODE), '', NULL, LAST_TRAN_CODE),
			DECODE(TRIM(LAST_TRAN_TIME), '', NULL, TO_DATE(LAST_TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(LAST_COMMENT), '', NULL, LAST_COMMENT),
			DECODE(TRIM(LAST_ACTIVE_HIST_SEQ), '', NULL, LAST_ACTIVE_HIST_SEQ),
			DECODE(TRIM(LAST_HIST_SEQ), '', NULL, LAST_HIST_SEQ),
            DECODE(TRIM(SUBLOT_TYPE), '', NULL, SUBLOT_TYPE),
			DECODE(TRIM(RESV_FIELD_1), '', NULL, RESV_FIELD_1),
			DECODE(TRIM(RESV_FIELD_2), '', NULL, RESV_FIELD_2),
			DECODE(TRIM(RESV_FIELD_3), '', NULL, RESV_FIELD_3),
			DECODE(TRIM(RESV_FIELD_4), '', NULL, RESV_FIELD_4),
			DECODE(TRIM(RESV_FIELD_5), '', NULL, RESV_FIELD_5),
			DECODE(TRIM(RESV_FLAG_1), '', NULL, RESV_FLAG_1),
			DECODE(TRIM(RESV_FLAG_2), '', NULL, RESV_FLAG_2),
			DECODE(TRIM(RESV_FLAG_3), '', NULL, RESV_FLAG_3),
			DECODE(TRIM(RESV_FLAG_4), '', NULL, RESV_FLAG_4),
			DECODE(TRIM(RESV_FLAG_5), '', NULL, RESV_FLAG_5)
        FROM MWIPSLTSTS
        WHERE LOT_ID = DECODE(:RWIPSLTSTS_N.LOT_ID.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.LOT_ID.VALUE);
    DB_stop_query_timer("RPT_insert_select_rwipsltsts_lot", 0);
}

