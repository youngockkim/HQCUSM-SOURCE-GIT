/* SQL SELECT_SCALAR Function */
double RPT_select_rwipsltsts_scalar(int sel_type, struct RWIPSLTSTS_TAG *RWIPSLTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RWIPSLTSTS_N_TAG RWIPSLTSTS_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwipsltsts(&RWIPSLTSTS_N, RWIPSLTSTS);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM RWIPSLTSTS
                WHERE SUBLOT_ID = :RWIPSLTSTS_N.SUBLOT_ID;
            break;

        case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM RWIPSLTSTS
                WHERE LOT_ID = DECODE(:RWIPSLTSTS_N.LOT_ID.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.LOT_ID.VALUE);
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("RPT_select_rwipsltsts_scalar", sel_type);
    return d_value;
}


/* SQL DELETE Function */
void RPT_delete_rwipsltsts(int sel_type, struct RWIPSLTSTS_TAG *RWIPSLTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RWIPSLTSTS_N_TAG RWIPSLTSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwipsltsts(&RWIPSLTSTS_N, RWIPSLTSTS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM RWIPSLTSTS
                WHERE SUBLOT_ID = :RWIPSLTSTS_N.SUBLOT_ID;
            break;

        case 2:
            EXEC SQL DELETE FROM RWIPSLTSTS
                WHERE LOT_ID = DECODE(:RWIPSLTSTS_N.LOT_ID.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.LOT_ID.VALUE);
            break;

        case 3:
            EXEC SQL DELETE FROM RWIPSLTSTS
                WHERE SUBLOT_ID IN (SELECT SUBLOT_ID FROM MWIPSLTSTS WHERE LOT_ID = DECODE(:RWIPSLTSTS_N.LOT_ID.IS_NULL, 'Y', NULL, :RWIPSLTSTS_N.LOT_ID.VALUE));
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_delete_rwipsltsts", sel_type);
}


