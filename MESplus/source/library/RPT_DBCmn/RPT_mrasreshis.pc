    MEMCPY_AN(MRASRESHIS_N->FACTORY, MRASRESHIS->FACTORY, sizeof(MRASRESHIS->FACTORY));
    MEMCPY_AN(MRASRESHIS_N->RES_ID, MRASRESHIS->RES_ID, sizeof(MRASRESHIS->RES_ID));
