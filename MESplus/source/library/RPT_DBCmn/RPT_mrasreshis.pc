/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_mrasreshis(int sel_type, struct MRASRESHIS_TAG *MRASRESHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct MRASRESHIS_N_TAG MRASRESHIS_N;
	EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_mrasreshis(&MRASRESHIS_N, MRASRESHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_MRASRESHIS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    HIST_SEQ,
                    EVENT_ID,
                    TRAN_TIME,
                    SYS_TRAN_TIME,
                    OLD_EVENT_ID,
                    OLD_HIST_SEQ,
                    OLD_TRAN_TIME,
                    OLD_SYS_TRAN_TIME,
                    OLD_UP_DOWN_FLAG,
                    OLD_PRI_STS,
                    OLD_STS_1,
                    OLD_STS_2,
                    OLD_STS_3,
                    OLD_STS_4,
                    OLD_STS_5,
                    OLD_STS_6,
                    OLD_STS_7,
                    OLD_STS_8,
                    OLD_STS_9,
                    OLD_STS_10,
                    NEW_UP_DOWN_FLAG,
                    NEW_PRI_STS,
                    NEW_STS_1,
                    NEW_STS_2,
                    NEW_STS_3,
                    NEW_STS_4,
                    NEW_STS_5,
                    NEW_STS_6,
                    NEW_STS_7,
                    NEW_STS_8,
                    NEW_STS_9,
                    NEW_STS_10,
                    LOT_ID,
                    SUBLOT_ID,
                    CRR_ID,
                    RES_CTRL_MODE,
                    RES_PROC_MODE,
                    LOT_EXIST_FLAG,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    TRAN_CMF_1,
                    TRAN_CMF_2,
                    TRAN_CMF_3,
                    TRAN_CMF_4,
                    TRAN_CMF_5,
                    TRAN_CMF_6,
                    TRAN_CMF_7,
                    TRAN_CMF_8,
                    TRAN_CMF_9,
                    TRAN_CMF_10,
                    TRAN_CMF_11,
                    TRAN_CMF_12,
                    TRAN_CMF_13,
                    TRAN_CMF_14,
                    TRAN_CMF_15,
                    TRAN_CMF_16,
                    TRAN_CMF_17,
                    TRAN_CMF_18,
                    TRAN_CMF_19,
                    TRAN_CMF_20,
                    TRAN_USER_ID,
                    TRAN_COMMENT,
                    LAST_DOWN_TIME,
                    LAST_DOWN_HIST_SEQ,
                    HIST_START_SEQ,
                    HIST_DEL_FLAG,
                    HIST_DEL_TIME,
                    HIST_DEL_USER_ID,
                    HIST_DEL_COMMENT
                FROM MRASRESHIS
                WHERE FACTORY = :MRASRESHIS_N.FACTORY
                    AND RES_ID = :MRASRESHIS_N.RES_ID
                    AND HIST_DEL_FLAG <> 'Y'
                    AND (TRAN_TIME >= :MRASRESHIS_N.TRAN_TIME AND TRAN_TIME < :MRASRESHIS_N.SYS_TRAN_TIME)
                ORDER BY RES_ID, TRAN_TIME;
            EXEC SQL OPEN RPT_MRASRESHIS_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_mrasreshis", sel_type);
}


