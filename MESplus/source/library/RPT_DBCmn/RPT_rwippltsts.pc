                :RWIPPLTSTS_N.ORIG_UNIT_3.IS_NULL, :RWIPPLTSTS_N.ORIG_UNIT_3.VALUE,
                :RWIPPLTSTS_N.FACTORY.IS_NULL, :RWIPPLTSTS_N.FACTORY.VALUE;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
