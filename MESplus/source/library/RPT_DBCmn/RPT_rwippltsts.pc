                :RWIPPLTSTS_N.LOT_DEL_QTY_3.IS_NULL, :RWIPPLTSTS_N.LOT_DEL_QTY_3.VALUE,
                :RWIPPLTSTS_N.SHIP_CODE.IS_NULL, :RWIPPLTSTS_N.SHIP_CODE.VALUE,
