            break;

        case 2:
            EXEC SQL UPDATE RWIPPLTSTS SET
                    LOT_DEL_FLAG = DECODE(:RWIPPLTSTS_N.LOT_DEL_FLAG.IS_NULL, 'Y', NULL, :RWIPPLTSTS_N.LOT_DEL_FLAG.VALUE),
                    LOT_DEL_TIME = DECODE(:RWIPPLTSTS_N.LOT_DEL_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPPLTSTS_N.LOT_DEL_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    LOT_DEL_QTY_1 = DECODE(:RWIPPLTSTS_N.LOT_DEL_QTY_1.IS_NULL, 'Y', NULL, :RWIPPLTSTS_N.LOT_DEL_QTY_1.VALUE),
                    LOT_DEL_QTY_2 = DECODE(:RWIPPLTSTS_N.LOT_DEL_QTY_2.IS_NULL, 'Y', NULL, :RWIPPLTSTS_N.LOT_DEL_QTY_2.VALUE),
                    LOT_DEL_QTY_3 = DECODE(:RWIPPLTSTS_N.LOT_DEL_QTY_3.IS_NULL, 'Y', NULL, :RWIPPLTSTS_N.LOT_DEL_QTY_3.VALUE),
                    SHIP_CODE = DECODE(:RWIPPLTSTS_N.SHIP_CODE.IS_NULL, 'Y', NULL, :RWIPPLTSTS_N.SHIP_CODE.VALUE)
                WHERE LOT_ID = :RWIPPLTSTS_N.LOT_ID;
            break;

        case 3:
            EXEC SQL UPDATE RWIPPLTSTS SET
                    LOT_DEL_FLAG = DECODE(:RWIPPLTSTS_N.LOT_DEL_FLAG.IS_NULL, 'Y', NULL, :RWIPPLTSTS_N.LOT_DEL_FLAG.VALUE),
                    ORIG_MAT_ID = DECODE(:RWIPPLTSTS_N.ORIG_MAT_ID.IS_NULL, 'Y', NULL, :RWIPPLTSTS_N.ORIG_MAT_ID.VALUE),
                    ORIG_MAT_VER = DECODE(:RWIPPLTSTS_N.ORIG_MAT_VER.IS_NULL, 'Y', NULL, :RWIPPLTSTS_N.ORIG_MAT_VER.VALUE),
                    SCH_DUE_TIME = DECODE(:RWIPPLTSTS_N.SCH_DUE_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPPLTSTS_N.SCH_DUE_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    LOT_DEL_TIME = DECODE(:RWIPPLTSTS_N.LOT_DEL_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPPLTSTS_N.LOT_DEL_TIME.VALUE, 'YYYYMMDDHH24MISS'))
                WHERE LOT_ID = :RWIPPLTSTS_N.LOT_ID;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_update_rwippltsts", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rwippltsts(int sel_type, struct RWIPPLTSTS_TAG *RWIPPLTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPPLTSTS_N_TAG RWIPPLTSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwippltsts(&RWIPPLTSTS_N, RWIPPLTSTS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RWIPPLTSTS_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    DECODE(LOT_DEL_FLAG, NULL, 'Y', ' '), NVL(LOT_DEL_FLAG, ' '),
                    DECODE(PRODUCT_GRP, NULL, 'Y', ' '), NVL(PRODUCT_GRP, ' '),
                    DECODE(ORIG_PRODUCT, NULL, 'Y', ' '), NVL(ORIG_PRODUCT, ' '),
                    DECODE(ORIG_MAT_ID, NULL, 'Y', ' '), NVL(ORIG_MAT_ID, ' '),
                    DECODE(ORIG_MAT_VER, NULL, 'Y', ' '), NVL(ORIG_MAT_VER, '0'),
                    DECODE(ORIG_OWNER_CODE, NULL, 'Y', ' '), NVL(ORIG_OWNER_CODE, ' '),
                    DECODE(ORIG_OPER, NULL, 'Y', ' '), NVL(ORIG_OPER, ' '),
                    DECODE(ORIG_CREATE_CODE, NULL, 'Y', ' '), NVL(ORIG_CREATE_CODE, ' '),
                    DECODE(CREATE_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(CREATE_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(CREATE_QTY_1, NULL, 'Y', ' '), NVL(CREATE_QTY_1, '0'),
                    DECODE(CREATE_QTY_2, NULL, 'Y', ' '), NVL(CREATE_QTY_2, '0'),
                    DECODE(CREATE_QTY_3, NULL, 'Y', ' '), NVL(CREATE_QTY_3, '0'),
                    DECODE(SCH_DUE_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(SCH_DUE_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(LOT_DEL_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(LOT_DEL_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(LOT_DEL_QTY_1, NULL, 'Y', ' '), NVL(LOT_DEL_QTY_1, '0'),
                    DECODE(LOT_DEL_QTY_2, NULL, 'Y', ' '), NVL(LOT_DEL_QTY_2, '0'),
                    DECODE(LOT_DEL_QTY_3, NULL, 'Y', ' '), NVL(LOT_DEL_QTY_3, '0'),
                    DECODE(SHIP_CODE, NULL, 'Y', ' '), NVL(SHIP_CODE, ' '),
                    DECODE(ORIG_UNIT_1, NULL, 'Y', ' '), NVL(ORIG_UNIT_1, ' '),
                    DECODE(ORIG_UNIT_2, NULL, 'Y', ' '), NVL(ORIG_UNIT_2, ' '),
                    DECODE(ORIG_UNIT_3, NULL, 'Y', ' '), NVL(ORIG_UNIT_3, ' '),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' ')
                FROM RWIPPLTSTS
                ORDER BY LOT_ID ASC;
            EXEC SQL OPEN RPT_RWIPPLTSTS_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rwippltsts", sel_type);
}


