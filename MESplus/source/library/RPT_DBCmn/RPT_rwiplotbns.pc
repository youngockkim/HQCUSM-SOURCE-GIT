            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_update_rwiplotbns", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rwiplotbns(int sel_type, struct RWIPLOTBNS_TAG *RWIPLOTBNS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTBNS_N_TAG RWIPLOTBNS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplotbns(&RWIPLOTBNS_N, RWIPLOTBNS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RWIPLOTBNS_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    QTY_FLAG,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_ID,
                    CAUSE_FLOW,
                    CAUSE_OPER,
                    CAUSE_RES_ID,
                    NEW_QTY,
                    OLD_QTY,
                    TOTAL_BONUS_QTY,
                    BONUS_CODE_1,
                    BONUS_CODE_2,
                    BONUS_CODE_3,
                    BONUS_CODE_4,
                    BONUS_CODE_5,
                    BONUS_CODE_6,
                    BONUS_CODE_7,
                    BONUS_CODE_8,
                    BONUS_CODE_9,
                    BONUS_CODE_10,
                    BONUS_QTY_1,
                    BONUS_QTY_2,
                    BONUS_QTY_3,
                    BONUS_QTY_4,
                    BONUS_QTY_5,
                    BONUS_QTY_6,
                    BONUS_QTY_7,
                    BONUS_QTY_8,
                    BONUS_QTY_9,
                    BONUS_QTY_10,
                    BONUS_COMMENT_1,
                    BONUS_COMMENT_2,
                    BONUS_COMMENT_3
                FROM RWIPLOTBNS
                WHERE LOT_ID = :RWIPLOTBNS_N.LOT_ID
                    AND HIST_SEQ = :RWIPLOTBNS_N.HIST_SEQ
                ORDER BY QTY_FLAG ASC;
            EXEC SQL OPEN RPT_RWIPLOTBNS_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rwiplotbns", sel_type);
}


