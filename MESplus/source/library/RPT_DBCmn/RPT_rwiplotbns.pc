/* Initialize Function */
void RPT_init_rwiplotbns(struct RWIPLOTBNS_TAG *RWIPLOTBNS)
{
    /* memset by Space */
    memset(RWIPLOTBNS, ' ', sizeof(struct RWIPLOTBNS_TAG));
    
    RWIPLOTBNS->HIST_SEQ = 0;
    RWIPLOTBNS->MAT_VER = 0;
    RWIPLOTBNS->FLOW_SEQ_NUM = 0;
    RWIPLOTBNS->NEW_QTY = 0;
    RWIPLOTBNS->OLD_QTY = 0;
    RWIPLOTBNS->TOTAL_BONUS_QTY = 0;
    RWIPLOTBNS->BONUS_QTY_1 = 0;
    RWIPLOTBNS->BONUS_QTY_2 = 0;
    RWIPLOTBNS->BONUS_QTY_3 = 0;
    RWIPLOTBNS->BONUS_QTY_4 = 0;
    RWIPLOTBNS->BONUS_QTY_5 = 0;
    RWIPLOTBNS->BONUS_QTY_6 = 0;
    RWIPLOTBNS->BONUS_QTY_7 = 0;
    RWIPLOTBNS->BONUS_QTY_8 = 0;
    RWIPLOTBNS->BONUS_QTY_9 = 0;
    RWIPLOTBNS->BONUS_QTY_10 = 0;
}


/* Add Null Function */
void RPT_add_null_rwiplotbns(struct RWIPLOTBNS_N_TAG *RWIPLOTBNS_N, struct RWIPLOTBNS_TAG *RWIPLOTBNS)
{
    /* memset by NULL */
    memset(RWIPLOTBNS_N, '\0', sizeof(struct RWIPLOTBNS_N_TAG));
    
    MEMCPY_AN(RWIPLOTBNS_N->LOT_ID, RWIPLOTBNS->LOT_ID, sizeof(RWIPLOTBNS->LOT_ID));
    RWIPLOTBNS_N->HIST_SEQ = RWIPLOTBNS->HIST_SEQ;
    RWIPLOTBNS_N->QTY_FLAG[0] = RWIPLOTBNS->QTY_FLAG;
