/* Add Null Function */
void RPT_add_null_rsumprclog(struct RSUMPRCLOG_N_TAG *RSUMPRCLOG_N, struct RSUMPRCLOG_TAG *RSUMPRCLOG)
{
    /* memset by NULL */
    memset(RSUMPRCLOG_N, '\0', sizeof(struct RSUMPRCLOG_N_TAG));
    
    MEMCPY_AN(RSUMPRCLOG_N->FACTORY, RSUMPRCLOG->FACTORY, sizeof(RSUMPRCLOG->FACTORY));
    MEMCPY_AN(RSUMPRCLOG_N->FUNCTION_NAME, RSUMPRCLOG->FUNCTION_NAME, sizeof(RSUMPRCLOG->FUNCTION_NAME));
    MEMCPY_AN(RSUMPRCLOG_N->WORK_DATE, RSUMPRCLOG->WORK_DATE, sizeof(RSUMPRCLOG->WORK_DATE));
    RSUMPRCLOG_N->WORK_SHIFT[0] = RSUMPRCLOG->WORK_SHIFT;
    MEMCPY_AN(RSUMPRCLOG_N->LAST_TRAN_TIME, RSUMPRCLOG->LAST_TRAN_TIME, sizeof(RSUMPRCLOG->LAST_TRAN_TIME));
}


/* Del Null Function */
void RPT_del_null_rsumprclog(struct RSUMPRCLOG_N_TAG *RSUMPRCLOG_N, struct RSUMPRCLOG_TAG *RSUMPRCLOG)
{
    MEMCPY_DN(RSUMPRCLOG->FACTORY, RSUMPRCLOG_N->FACTORY, sizeof(RSUMPRCLOG->FACTORY));
    MEMCPY_DN(RSUMPRCLOG->FUNCTION_NAME, RSUMPRCLOG_N->FUNCTION_NAME, sizeof(RSUMPRCLOG->FUNCTION_NAME));
    MEMCPY_DN(RSUMPRCLOG->WORK_DATE, RSUMPRCLOG_N->WORK_DATE, sizeof(RSUMPRCLOG->WORK_DATE));
    RSUMPRCLOG->WORK_SHIFT = RSUMPRCLOG_N->WORK_SHIFT[0];
    MEMCPY_DN(RSUMPRCLOG->LAST_TRAN_TIME, RSUMPRCLOG_N->LAST_TRAN_TIME, sizeof(RSUMPRCLOG->LAST_TRAN_TIME));
}


