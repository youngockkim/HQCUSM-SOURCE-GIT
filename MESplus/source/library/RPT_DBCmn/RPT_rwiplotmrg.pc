    RWIPLOTMRG_N->FROM_TO_FLOW_SEQ_NUM = RWIPLOTMRG->FROM_TO_FLOW_SEQ_NUM;
    MEMCPY_AN(RWIPLOTMRG_N->FROM_TO_OPER, RWIPLOTMRG->FROM_TO_OPER, sizeof(RWIPLOTMRG->FROM_TO_OPER));
    RWIPLOTMRG_N->FROM_TO_QTY_1 = RWIPLOTMRG->FROM_TO_QTY_1;
    RWIPLOTMRG_N->FROM_TO_QTY_2 = RWIPLOTMRG->FROM_TO_QTY_2;
    RWIPLOTMRG_N->FROM_TO_QTY_3 = RWIPLOTMRG->FROM_TO_QTY_3;
    RWIPLOTMRG_N->FROM_TO_HIST_SEQ = RWIPLOTMRG->FROM_TO_HIST_SEQ;
}


/* Del Null Function */
void RPT_del_null_rwiplotmrg(struct RWIPLOTMRG_N_TAG *RWIPLOTMRG_N, struct RWIPLOTMRG_TAG *RWIPLOTMRG)
{
    MEMCPY_DN(RWIPLOTMRG->LOT_ID, RWIPLOTMRG_N->LOT_ID, sizeof(RWIPLOTMRG->LOT_ID));
    RWIPLOTMRG->HIST_SEQ = RWIPLOTMRG_N->HIST_SEQ;
