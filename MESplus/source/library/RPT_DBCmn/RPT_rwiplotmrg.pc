    RWIPLOTMRG->HIST_DEL_FLAG = RWIPLOTMRG_N->HIST_DEL_FLAG[0];
    MEMCPY_DN(RWIPLOTMRG->FACTORY, RWIPLOTMRG_N->FACTORY, sizeof(RWIPLOTMRG->FACTORY));
    MEMCPY_DN(RWIPLOTMRG->MAT_ID, RWIPLOTMRG_N->MAT_ID, sizeof(RWIPLOTMRG->MAT_ID));
    RWIPLOTMRG->MAT_VER = RWIPLOTMRG_N->MAT_VER;
    MEMCPY_DN(RWIPLOTMRG->FLOW, RWIPLOTMRG_N->FLOW, sizeof(RWIPLOTMRG->FLOW));
    RWIPLOTMRG->FLOW_SEQ_NUM = RWIPLOTMRG_N->FLOW_SEQ_NUM;
    MEMCPY_DN(RWIPLOTMRG->OPER, RWIPLOTMRG_N->OPER, sizeof(RWIPLOTMRG->OPER));
    RWIPLOTMRG->FROM_TO_FLAG = RWIPLOTMRG_N->FROM_TO_FLAG[0];
    MEMCPY_DN(RWIPLOTMRG->FROM_TO_LOT_ID, RWIPLOTMRG_N->FROM_TO_LOT_ID, sizeof(RWIPLOTMRG->FROM_TO_LOT_ID));
    MEMCPY_DN(RWIPLOTMRG->FROM_TO_MAT_ID, RWIPLOTMRG_N->FROM_TO_MAT_ID, sizeof(RWIPLOTMRG->FROM_TO_MAT_ID));
    RWIPLOTMRG->FROM_TO_MAT_VER = RWIPLOTMRG_N->FROM_TO_MAT_VER;
    MEMCPY_DN(RWIPLOTMRG->FROM_TO_FLOW, RWIPLOTMRG_N->FROM_TO_FLOW, sizeof(RWIPLOTMRG->FROM_TO_FLOW));
    RWIPLOTMRG->FROM_TO_FLOW_SEQ_NUM = RWIPLOTMRG_N->FROM_TO_FLOW_SEQ_NUM;
    MEMCPY_DN(RWIPLOTMRG->FROM_TO_OPER, RWIPLOTMRG_N->FROM_TO_OPER, sizeof(RWIPLOTMRG->FROM_TO_OPER));
    RWIPLOTMRG->FROM_TO_QTY_1 = RWIPLOTMRG_N->FROM_TO_QTY_1;
    RWIPLOTMRG->FROM_TO_QTY_2 = RWIPLOTMRG_N->FROM_TO_QTY_2;
    RWIPLOTMRG->FROM_TO_QTY_3 = RWIPLOTMRG_N->FROM_TO_QTY_3;
    RWIPLOTMRG->FROM_TO_HIST_SEQ = RWIPLOTMRG_N->FROM_TO_HIST_SEQ;
}


