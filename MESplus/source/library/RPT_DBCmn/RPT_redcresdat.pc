            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_update_redcresdat", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_redcresdat(int sel_type, struct REDCRESDAT_TAG *REDCRESDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct REDCRESDAT_N_TAG REDCRESDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_redcresdat(&REDCRESDAT_N, REDCRESDAT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_REDCRESDAT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    HIST_SEQ,
                    DECODE(COL_SEQ, NULL, 'Y', ' '), NVL(COL_SEQ, '0'),
                    DECODE(EVENT_ID, NULL, 'Y', ' '), NVL(EVENT_ID, ' '),
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(RECIPE_ID, NULL, 'Y', ' '), NVL(RECIPE_ID, ' '),
                    DECODE(RECIPE_VERSION, NULL, 'Y', ' '), NVL(RECIPE_VERSION, '0'),
                    DECODE(HIST_DEL_FLAG, NULL, 'Y', ' '), NVL(HIST_DEL_FLAG, ' '),
                    DECODE(COL_SET_ID, NULL, 'Y', ' '), NVL(COL_SET_ID, ' '),
                    DECODE(COL_SET_VERSION, NULL, 'Y', ' '), NVL(COL_SET_VERSION, '0'),
                    CHAR_SEQ_NUM,
                    DECODE(CHAR_ID, NULL, 'Y', ' '), NVL(CHAR_ID, ' '),
                    UNIT_SEQ_NUM,
                    DECODE(UNIT_ID, NULL, 'Y', ' '), NVL(UNIT_ID, ' '),
                    VALUE_SEQ_NUM,
                    DECODE(VALUE_TYPE, NULL, 'Y', ' '), NVL(VALUE_TYPE, ' '),
                    DECODE(VALUE_COUNT, NULL, 'Y', ' '), NVL(VALUE_COUNT, '0'),
                    DECODE(VALUE_1, NULL, 'Y', ' '), NVL(VALUE_1, ' '),
                    DECODE(VALUE_2, NULL, 'Y', ' '), NVL(VALUE_2, ' '),
                    DECODE(VALUE_3, NULL, 'Y', ' '), NVL(VALUE_3, ' '),
                    DECODE(VALUE_4, NULL, 'Y', ' '), NVL(VALUE_4, ' '),
                    DECODE(VALUE_5, NULL, 'Y', ' '), NVL(VALUE_5, ' '),
                    DECODE(VALUE_6, NULL, 'Y', ' '), NVL(VALUE_6, ' '),
                    DECODE(VALUE_7, NULL, 'Y', ' '), NVL(VALUE_7, ' '),
                    DECODE(VALUE_8, NULL, 'Y', ' '), NVL(VALUE_8, ' '),
                    DECODE(VALUE_9, NULL, 'Y', ' '), NVL(VALUE_9, ' '),
                    DECODE(VALUE_10, NULL, 'Y', ' '), NVL(VALUE_10, ' '),
                    DECODE(VALUE_11, NULL, 'Y', ' '), NVL(VALUE_11, ' '),
                    DECODE(VALUE_12, NULL, 'Y', ' '), NVL(VALUE_12, ' '),
                    DECODE(VALUE_13, NULL, 'Y', ' '), NVL(VALUE_13, ' '),
                    DECODE(VALUE_14, NULL, 'Y', ' '), NVL(VALUE_14, ' '),
                    DECODE(VALUE_15, NULL, 'Y', ' '), NVL(VALUE_15, ' '),
                    DECODE(VALUE_16, NULL, 'Y', ' '), NVL(VALUE_16, ' '),
                    DECODE(VALUE_17, NULL, 'Y', ' '), NVL(VALUE_17, ' '),
                    DECODE(VALUE_18, NULL, 'Y', ' '), NVL(VALUE_18, ' '),
                    DECODE(VALUE_19, NULL, 'Y', ' '), NVL(VALUE_19, ' '),
                    DECODE(VALUE_20, NULL, 'Y', ' '), NVL(VALUE_20, ' '),
                    DECODE(VALUE_21, NULL, 'Y', ' '), NVL(VALUE_21, ' '),
                    DECODE(VALUE_22, NULL, 'Y', ' '), NVL(VALUE_22, ' '),
                    DECODE(VALUE_23, NULL, 'Y', ' '), NVL(VALUE_23, ' '),
                    DECODE(VALUE_24, NULL, 'Y', ' '), NVL(VALUE_24, ' '),
                    DECODE(VALUE_25, NULL, 'Y', ' '), NVL(VALUE_25, ' '),
                    DECODE(SAMPLE_COUNT, NULL, 'Y', ' '), NVL(SAMPLE_COUNT, '0'),
                    DECODE(NOMINAL, NULL, 'Y', ' '), NVL(NOMINAL, ' '),
                    DECODE(PROCESS_SIGMA, NULL, 'Y', ' '), NVL(PROCESS_SIGMA, ' '),
                    DECODE(SPEC_OUT_MASK, NULL, 'Y', ' '), NVL(SPEC_OUT_MASK, ' '),
                    DECODE(CREATE_USER_ID, NULL, 'Y', ' '), NVL(CREATE_USER_ID, ' '),
                    DECODE(CREATE_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(CREATE_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(UPDATE_USER_ID, NULL, 'Y', ' '), NVL(UPDATE_USER_ID, ' '),
                    DECODE(UPDATE_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(UPDATE_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(DELETE_USER_ID, NULL, 'Y', ' '), NVL(DELETE_USER_ID, ' '),
                    DECODE(DELETE_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(DELETE_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(DATE_CREATED, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_CREATED, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(DATE_UPDATED, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_UPDATED, 'YYYYMMDDHH24MISS'), ' ')
                FROM REDCRESDAT
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SUBRES_ID ASC,
                    HIST_SEQ ASC,
                    CHAR_SEQ_NUM ASC,
                    UNIT_SEQ_NUM ASC,
                    VALUE_SEQ_NUM ASC;
            EXEC SQL OPEN RPT_REDCRESDAT_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_redcresdat", sel_type);
}


