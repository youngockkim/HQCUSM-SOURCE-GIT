void RPT_select_insert_redcresdat(struct REDCRESDAT_TAG *REDCRESDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct REDCRESDAT_N_TAG REDCRESDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_redcresdat(&REDCRESDAT_N, REDCRESDAT);
    DB_error_code = 0;
    EXEC SQL INSERT INTO REDCRESDAT
		SELECT
			FACTORY,
			RES_ID,
			SUBRES_ID,
			HIST_SEQ,
			DECODE(TRIM(COL_SEQ),  '', NULL, COL_SEQ),
			DECODE(TRIM(EVENT_ID),  '', NULL, EVENT_ID),
			DECODE(TRIM(TRAN_TIME),  '', NULL, TO_DATE(TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(RECIPE_ID),  '', NULL, RECIPE_ID),
			DECODE(TRIM(RECIPE_VERSION),  '', NULL, RECIPE_VERSION),
			DECODE(TRIM(HIST_DEL_FLAG),  '', NULL, HIST_DEL_FLAG),
			DECODE(TRIM(COL_SET_ID),  '', NULL, COL_SET_ID),
			DECODE(TRIM(COL_SET_VERSION),  '', NULL, COL_SET_VERSION),
			CHAR_SEQ_NUM,
			DECODE(TRIM(CHAR_ID),  '', NULL, CHAR_ID),
			UNIT_SEQ_NUM,
			DECODE(TRIM(UNIT_ID),  '', NULL, UNIT_ID),
			VALUE_SEQ_NUM,
			DECODE(TRIM(VALUE_TYPE),  '', NULL, VALUE_TYPE),
			DECODE(TRIM(VALUE_COUNT),  '', NULL, VALUE_COUNT),
			DECODE(TRIM(VALUE_1),  '', NULL, VALUE_1),
			DECODE(TRIM(VALUE_2),  '', NULL, VALUE_2),
			DECODE(TRIM(VALUE_3),  '', NULL, VALUE_3),
			DECODE(TRIM(VALUE_4),  '', NULL, VALUE_4),
			DECODE(TRIM(VALUE_5),  '', NULL, VALUE_5),
			DECODE(TRIM(VALUE_6),  '', NULL, VALUE_6),
			DECODE(TRIM(VALUE_7),  '', NULL, VALUE_7),
			DECODE(TRIM(VALUE_8),  '', NULL, VALUE_8),
			DECODE(TRIM(VALUE_9),  '', NULL, VALUE_9),
			DECODE(TRIM(VALUE_10),  '', NULL, VALUE_10),
			DECODE(TRIM(VALUE_11),  '', NULL, VALUE_11),
			DECODE(TRIM(VALUE_12),  '', NULL, VALUE_12),
			DECODE(TRIM(VALUE_13),  '', NULL, VALUE_13),
			DECODE(TRIM(VALUE_14),  '', NULL, VALUE_14),
			DECODE(TRIM(VALUE_15),  '', NULL, VALUE_15),
			DECODE(TRIM(VALUE_16),  '', NULL, VALUE_16),
			DECODE(TRIM(VALUE_17),  '', NULL, VALUE_17),
			DECODE(TRIM(VALUE_18),  '', NULL, VALUE_18),
			DECODE(TRIM(VALUE_19),  '', NULL, VALUE_19),
			DECODE(TRIM(VALUE_20),  '', NULL, VALUE_20),
			DECODE(TRIM(VALUE_21),  '', NULL, VALUE_21),
			DECODE(TRIM(VALUE_22),  '', NULL, VALUE_22),
			DECODE(TRIM(VALUE_23),  '', NULL, VALUE_23),
			DECODE(TRIM(VALUE_24),  '', NULL, VALUE_24),
			DECODE(TRIM(VALUE_25),  '', NULL, VALUE_25),
			DECODE(TRIM(SAMPLE_COUNT),  '', NULL, SAMPLE_COUNT),
			DECODE(TRIM(NOMINAL),  '', NULL, NOMINAL),
			DECODE(TRIM(PROCESS_SIGMA),  '', NULL, PROCESS_SIGMA),
			DECODE(TRIM(SPEC_OUT_MASK),  '', NULL, SPEC_OUT_MASK),
			DECODE(TRIM(CREATE_USER_ID),  '', NULL, CREATE_USER_ID),
			DECODE(TRIM(CREATE_TIME),  '', NULL, TO_DATE(CREATE_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(UPDATE_USER_ID),  '', NULL, UPDATE_USER_ID),
			DECODE(TRIM(UPDATE_TIME),  '', NULL, TO_DATE(UPDATE_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(DELETE_USER_ID),  '', NULL, DELETE_USER_ID),
			DECODE(TRIM(DELETE_TIME),  '', NULL, TO_DATE(DELETE_TIME, 'YYYYMMDDHH24MISS')),
			SYSDATE,
			NULL
		FROM MEDCRESDAT
        WHERE FACTORY = :REDCRESDAT_N.FACTORY
          AND RES_ID = :REDCRESDAT_N.RES_ID
          AND SUBRES_ID = :REDCRESDAT_N.SUBRES_ID
          AND HIST_SEQ = :REDCRESDAT_N.HIST_SEQ;
    DB_stop_query_timer("RPT_select_insert_redcresdat", 0);
