/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rrascrrdef(int sel_type, struct RRASCRRDEF_TAG *RRASCRRDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASCRRDEF_N_TAG RRASCRRDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrascrrdef(&RRASCRRDEF_N, RRASCRRDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RRASCRRDEF_CUR_1 CURSOR FOR
                SELECT 
                    CRR_ID,
                    DECODE(CRR_DESC, NULL, 'Y', ' '), NVL(CRR_DESC, ' '),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '),
                    DECODE(CRR_GROUP, NULL, 'Y', ' '), NVL(CRR_GROUP, ' '),
                    DECODE(CRR_STATUS, NULL, 'Y', ' '), NVL(CRR_STATUS, ' '),
                    DECODE(CRR_STATUS_FLAG, NULL, 'Y', ' '), NVL(CRR_STATUS_FLAG, ' '),
                    DECODE(CRR_TYPE1, NULL, 'Y', ' '), NVL(CRR_TYPE1, ' '),
                    DECODE(CRR_TYPE2, NULL, 'Y', ' '), NVL(CRR_TYPE2, ' '),
                    DECODE(CRR_TYPE3, NULL, 'Y', ' '), NVL(CRR_TYPE3, ' '),
                    DECODE(CRR_MATERIAL, NULL, 'Y', ' '), NVL(CRR_MATERIAL, ' '),
                    DECODE(CRR_SIZE, NULL, 'Y', ' '), NVL(CRR_SIZE, '0'),
                    DECODE(USE_AREA_ID, NULL, 'Y', ' '), NVL(USE_AREA_ID, ' '),
                    DECODE(USE_SUB_AREA_ID, NULL, 'Y', ' '), NVL(USE_SUB_AREA_ID, ' '),
                    DECODE(USE_RES_ID, NULL, 'Y', ' '), NVL(USE_RES_ID, ' '),
                    DECODE(USAGE_LIMIT_COUNT, NULL, 'Y', ' '), NVL(USAGE_LIMIT_COUNT, '0'),
                    DECODE(USAGE_LIMIT_TIME, NULL, 'Y', ' '), NVL(USAGE_LIMIT_TIME, '0'),
                    DECODE(USAGE_COUNT, NULL, 'Y', ' '), NVL(USAGE_COUNT, '0'),
                    DECODE(CLEAN_LIMIT_COUNT, NULL, 'Y', ' '), NVL(CLEAN_LIMIT_COUNT, '0'),
                    DECODE(CLEAN_COUNT, NULL, 'Y', ' '), NVL(CLEAN_COUNT, '0'),
                    DECODE(RES_ID, NULL, 'Y', ' '), NVL(RES_ID, ' '),
                    DECODE(SUBRES_ID, NULL, 'Y', ' '), NVL(SUBRES_ID, ' '),
                    DECODE(PORT_ID, NULL, 'Y', ' '), NVL(PORT_ID, ' '),
                    DECODE(LOCATION_1, NULL, 'Y', ' '), NVL(LOCATION_1, ' '),
                    DECODE(LOCATION_2, NULL, 'Y', ' '), NVL(LOCATION_2, ' '),
                    DECODE(LOCATION_3, NULL, 'Y', ' '), NVL(LOCATION_3, ' '),
                    DECODE(LOCATION_4, NULL, 'Y', ' '), NVL(LOCATION_4, ' '),
                    DECODE(LOCATION_5, NULL, 'Y', ' '), NVL(LOCATION_5, ' '),
                    DECODE(OLD_RES_ID, NULL, 'Y', ' '), NVL(OLD_RES_ID, ' '),
                    DECODE(OLD_SUBRES_ID, NULL, 'Y', ' '), NVL(OLD_SUBRES_ID, ' '),
                    DECODE(OLD_PORT_ID, NULL, 'Y', ' '), NVL(OLD_PORT_ID, ' '),
                    DECODE(OLD_LOCATION_1, NULL, 'Y', ' '), NVL(OLD_LOCATION_1, ' '),
                    DECODE(OLD_LOCATION_2, NULL, 'Y', ' '), NVL(OLD_LOCATION_2, ' '),
                    DECODE(OLD_LOCATION_3, NULL, 'Y', ' '), NVL(OLD_LOCATION_3, ' '),
                    DECODE(OLD_LOCATION_4, NULL, 'Y', ' '), NVL(OLD_LOCATION_4, ' '),
                    DECODE(OLD_LOCATION_5, NULL, 'Y', ' '), NVL(OLD_LOCATION_5, ' '),
                    DECODE(NEED_CLEAN_FLAG, NULL, 'Y', ' '), NVL(NEED_CLEAN_FLAG, ' '),
                    DECODE(FINISH_CLEAN_FLAG, NULL, 'Y', ' '), NVL(FINISH_CLEAN_FLAG, ' '),
                    DECODE(LAST_CLEAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(LAST_CLEAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(LOT_ID, NULL, 'Y', ' '), NVL(LOT_ID, ' '),
                    DECODE(LOT_HIST_SEQ, NULL, 'Y', ' '), NVL(LOT_HIST_SEQ, '0'),
                    DECODE(QTY_1, NULL, 'Y', ' '), NVL(QTY_1, '0'),
                    DECODE(QTY_2, NULL, 'Y', ' '), NVL(QTY_2, '0'),
                    DECODE(QTY_3, NULL, 'Y', ' '), NVL(QTY_3, '0'),
                    DECODE(TBL_SLOT, NULL, 'Y', ' '), NVL(TBL_SLOT, ' '),
                    DECODE(MOVE_FLAG, NULL, 'Y', ' '), NVL(MOVE_FLAG, ' '),
                    DECODE(EMPTY_FLAG, NULL, 'Y', ' '), NVL(EMPTY_FLAG, ' '),
                    DECODE(STOCK_IN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(STOCK_IN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(PLAN_TERMINATE_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(PLAN_TERMINATE_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(CRR_CMF_1, NULL, 'Y', ' '), NVL(CRR_CMF_1, ' '),
                    DECODE(CRR_CMF_2, NULL, 'Y', ' '), NVL(CRR_CMF_2, ' '),
                    DECODE(CRR_CMF_3, NULL, 'Y', ' '), NVL(CRR_CMF_3, ' '),
                    DECODE(CRR_CMF_4, NULL, 'Y', ' '), NVL(CRR_CMF_4, ' '),
                    DECODE(CRR_CMF_5, NULL, 'Y', ' '), NVL(CRR_CMF_5, ' '),
                    DECODE(CRR_CMF_6, NULL, 'Y', ' '), NVL(CRR_CMF_6, ' '),
                    DECODE(CRR_CMF_7, NULL, 'Y', ' '), NVL(CRR_CMF_7, ' '),
                    DECODE(CRR_CMF_8, NULL, 'Y', ' '), NVL(CRR_CMF_8, ' '),
                    DECODE(CRR_CMF_9, NULL, 'Y', ' '), NVL(CRR_CMF_9, ' '),
                    DECODE(CRR_CMF_10, NULL, 'Y', ' '), NVL(CRR_CMF_10, ' '),
                    DECODE(CRR_CMF_11, NULL, 'Y', ' '), NVL(CRR_CMF_11, ' '),
                    DECODE(CRR_CMF_12, NULL, 'Y', ' '), NVL(CRR_CMF_12, ' '),
                    DECODE(CRR_CMF_13, NULL, 'Y', ' '), NVL(CRR_CMF_13, ' '),
                    DECODE(CRR_CMF_14, NULL, 'Y', ' '), NVL(CRR_CMF_14, ' '),
                    DECODE(CRR_CMF_15, NULL, 'Y', ' '), NVL(CRR_CMF_15, ' '),
                    DECODE(CRR_CMF_16, NULL, 'Y', ' '), NVL(CRR_CMF_16, ' '),
                    DECODE(CRR_CMF_17, NULL, 'Y', ' '), NVL(CRR_CMF_17, ' '),
                    DECODE(CRR_CMF_18, NULL, 'Y', ' '), NVL(CRR_CMF_18, ' '),
                    DECODE(CRR_CMF_19, NULL, 'Y', ' '), NVL(CRR_CMF_19, ' '),
                    DECODE(CRR_CMF_20, NULL, 'Y', ' '), NVL(CRR_CMF_20, ' '),
                    DECODE(LAST_HIST_SEQ, NULL, 'Y', ' '), NVL(LAST_HIST_SEQ, '0'),
                    DECODE(LAST_TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(LAST_TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(LAST_TRAN_CODE, NULL, 'Y', ' '), NVL(LAST_TRAN_CODE, ' '),
                    DECODE(CREATE_USER_ID, NULL, 'Y', ' '), NVL(CREATE_USER_ID, ' '),
                    DECODE(CREATE_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(CREATE_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(UPDATE_USER_ID, NULL, 'Y', ' '), NVL(UPDATE_USER_ID, ' '),
                    DECODE(UPDATE_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(UPDATE_TIME, 'YYYYMMDDHH24MISS'), ' '),
					DECODE(USAGE_LIMIT_ALARM, NULL, 'Y', ' '), NVL(USAGE_LIMIT_ALARM, ' '),
                    DECODE(CLEAN_LIMIT_ALARM, NULL, 'Y', ' '), NVL(CLEAN_LIMIT_ALARM, ' '),
                    DECODE(REUSE_LIMIT_COUNT, NULL, 'Y', ' '), NVL(REUSE_LIMIT_COUNT, '0'),
                    DECODE(REUSE_LIMIT_TIME, NULL, 'Y', ' '), NVL(REUSE_LIMIT_TIME, '0'),
                    DECODE(REUSE_COUNT, NULL, 'Y', ' '), NVL(REUSE_COUNT, '0'),
                    DECODE(REUSE_LIMIT_ALARM, NULL, 'Y', ' '), NVL(REUSE_LIMIT_ALARM, ' ')
                FROM RRASCRRDEF
                ORDER BY CRR_ID ASC;
            EXEC SQL OPEN RPT_RRASCRRDEF_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rrascrrdef", sel_type);
}


