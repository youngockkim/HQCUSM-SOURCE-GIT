    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_RRASCRRDEF_CUR_1 INTO
                :RRASCRRDEF_N.CRR_ID,
                :RRASCRRDEF_N.CRR_DESC.IS_NULL, :RRASCRRDEF_N.CRR_DESC.VALUE,
