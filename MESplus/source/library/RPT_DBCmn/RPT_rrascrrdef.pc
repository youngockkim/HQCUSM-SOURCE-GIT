    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    
    RPT_add_null_rrascrrdef(&RRASCRRDEF_N, RRASCRRDEF);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
