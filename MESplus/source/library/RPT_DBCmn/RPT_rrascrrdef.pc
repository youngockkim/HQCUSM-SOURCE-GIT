void RPT_select_insert_rrascrrdef(struct RRASCRRDEF_TAG *RRASCRRDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASCRRDEF_N_TAG RRASCRRDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    
    RPT_add_null_rrascrrdef(&RRASCRRDEF_N, RRASCRRDEF);
    DB_error_code = 0;
    EXEC SQL INSERT INTO RRASCRRDEF
		SELECT
			CRR_ID, 
			DECODE(TRIM(CRR_DESC), '', NULL, CRR_DESC),
			DECODE(TRIM(FACTORY), '', NULL, FACTORY),
			DECODE(TRIM(CRR_GROUP), '', NULL, CRR_GROUP),
			DECODE(TRIM(CRR_STATUS), '', NULL, CRR_STATUS),
			DECODE(TRIM(CRR_STATUS_FLAG), '', NULL, CRR_STATUS_FLAG),
			DECODE(TRIM(CRR_TYPE1), '', NULL, CRR_TYPE1),
			DECODE(TRIM(CRR_TYPE2), '', NULL, CRR_TYPE2),
			DECODE(TRIM(CRR_TYPE3), '', NULL, CRR_TYPE3),
			DECODE(TRIM(CRR_MATERIAL), '', NULL, CRR_MATERIAL),
			DECODE(TRIM(CRR_SIZE), '', NULL, CRR_SIZE),
			DECODE(TRIM(USE_AREA_ID), '', NULL, USE_AREA_ID),
			DECODE(TRIM(USE_SUB_AREA_ID), '', NULL, USE_SUB_AREA_ID),
			DECODE(TRIM(USE_RES_ID), '', NULL, USE_RES_ID),
			DECODE(TRIM(USAGE_LIMIT_COUNT), '', NULL, USAGE_LIMIT_COUNT),
			DECODE(TRIM(USAGE_LIMIT_TIME), '', NULL, USAGE_LIMIT_TIME),
			DECODE(TRIM(USAGE_COUNT), '', NULL, USAGE_COUNT),
			DECODE(TRIM(CLEAN_LIMIT_COUNT), '', NULL, CLEAN_LIMIT_COUNT),
			DECODE(TRIM(CLEAN_COUNT), '', NULL, CLEAN_COUNT),
			DECODE(TRIM(RES_ID), '', NULL, RES_ID),
			DECODE(TRIM(SUBRES_ID), '', NULL, SUBRES_ID),
			DECODE(TRIM(PORT_ID), '', NULL, PORT_ID),
			DECODE(TRIM(LOCATION_1), '', NULL, LOCATION_1),
			DECODE(TRIM(LOCATION_2), '', NULL, LOCATION_2),
			DECODE(TRIM(LOCATION_3), '', NULL, LOCATION_3),
			DECODE(TRIM(LOCATION_4), '', NULL, LOCATION_4),
			DECODE(TRIM(LOCATION_5), '', NULL, LOCATION_5),
			DECODE(TRIM(OLD_RES_ID), '', NULL, OLD_RES_ID),
			DECODE(TRIM(OLD_SUBRES_ID), '', NULL, OLD_SUBRES_ID),
			DECODE(TRIM(OLD_PORT_ID), '', NULL, OLD_PORT_ID),
			DECODE(TRIM(OLD_LOCATION_1), '', NULL, OLD_LOCATION_1),
			DECODE(TRIM(OLD_LOCATION_2), '', NULL, OLD_LOCATION_2),
			DECODE(TRIM(OLD_LOCATION_3), '', NULL, OLD_LOCATION_3),
			DECODE(TRIM(OLD_LOCATION_4), '', NULL, OLD_LOCATION_4),
			DECODE(TRIM(OLD_LOCATION_5), '', NULL, OLD_LOCATION_5),
			DECODE(TRIM(NEED_CLEAN_FLAG), '', NULL, NEED_CLEAN_FLAG),
			DECODE(TRIM(FINISH_CLEAN_FLAG), '', NULL, FINISH_CLEAN_FLAG),
			DECODE(TRIM(LAST_CLEAN_TIME), '', NULL, TO_DATE(LAST_CLEAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(LOT_ID), '', NULL, LOT_ID),
			DECODE(TRIM(LOT_HIST_SEQ), '', NULL, LOT_HIST_SEQ),
			DECODE(TRIM(QTY_1), '', NULL, QTY_1),
			DECODE(TRIM(QTY_2), '', NULL, QTY_2),
			DECODE(TRIM(QTY_3), '', NULL, QTY_3),
			DECODE(TRIM(TBL_SLOT), '', NULL, TBL_SLOT),
			DECODE(TRIM(MOVE_FLAG), '', NULL, MOVE_FLAG),
			DECODE(TRIM(EMPTY_FLAG), '', NULL, EMPTY_FLAG),
			DECODE(TRIM(STOCK_IN_TIME), '', NULL, STOCK_IN_TIME),
			DECODE(TRIM(PLAN_TERMINATE_TIME), '', NULL, TO_DATE(PLAN_TERMINATE_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(CRR_CMF_1), '', NULL, CRR_CMF_1),
			DECODE(TRIM(CRR_CMF_2), '', NULL, CRR_CMF_2),
			DECODE(TRIM(CRR_CMF_3), '', NULL, CRR_CMF_3),
			DECODE(TRIM(CRR_CMF_4), '', NULL, CRR_CMF_4),
			DECODE(TRIM(CRR_CMF_5), '', NULL, CRR_CMF_5),
			DECODE(TRIM(CRR_CMF_6), '', NULL, CRR_CMF_6),
			DECODE(TRIM(CRR_CMF_7), '', NULL, CRR_CMF_7),
			DECODE(TRIM(CRR_CMF_8), '', NULL, CRR_CMF_8),
			DECODE(TRIM(CRR_CMF_9), '', NULL, CRR_CMF_9),
			DECODE(TRIM(CRR_CMF_10), '', NULL, CRR_CMF_10),
			DECODE(TRIM(CRR_CMF_11), '', NULL, CRR_CMF_11),
			DECODE(TRIM(CRR_CMF_12), '', NULL, CRR_CMF_12),
			DECODE(TRIM(CRR_CMF_13), '', NULL, CRR_CMF_13),
			DECODE(TRIM(CRR_CMF_14), '', NULL, CRR_CMF_14),
			DECODE(TRIM(CRR_CMF_15), '', NULL, CRR_CMF_15),
			DECODE(TRIM(CRR_CMF_16), '', NULL, CRR_CMF_16),
			DECODE(TRIM(CRR_CMF_17), '', NULL, CRR_CMF_17),
			DECODE(TRIM(CRR_CMF_18), '', NULL, CRR_CMF_18),
			DECODE(TRIM(CRR_CMF_19), '', NULL, CRR_CMF_19),
			DECODE(TRIM(CRR_CMF_20), '', NULL, CRR_CMF_20),
			DECODE(TRIM(LAST_HIST_SEQ), '', NULL, LAST_HIST_SEQ),
			DECODE(TRIM(LAST_TRAN_TIME), '', NULL, TO_DATE(LAST_TRAN_TIME, 'YYYYMMDDHH24MISS')), 
			DECODE(TRIM(LAST_TRAN_CODE), '', NULL, LAST_TRAN_CODE),
			DECODE(TRIM(CREATE_USER_ID), '', NULL, CREATE_USER_ID),
			DECODE(TRIM(CREATE_TIME), '', NULL, TO_DATE(CREATE_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(UPDATE_USER_ID), '', NULL, UPDATE_USER_ID),
			DECODE(TRIM(UPDATE_TIME), '', NULL, TO_DATE(UPDATE_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(USAGE_LIMIT_ALARM), '', NULL, USAGE_LIMIT_ALARM),
			DECODE(TRIM(CLEAN_LIMIT_ALARM), '', NULL, CLEAN_LIMIT_ALARM),
            DECODE(TRIM(REUSE_LIMIT_COUNT), '', NULL, REUSE_LIMIT_COUNT),
			DECODE(TRIM(REUSE_LIMIT_TIME), '', NULL, REUSE_LIMIT_TIME),
			DECODE(TRIM(REUSE_COUNT), '', NULL, REUSE_COUNT),
            DECODE(TRIM(REUSE_LIMIT_ALARM), '', NULL, REUSE_LIMIT_ALARM)
		FROM MRASCRRDEF
        WHERE CRR_ID = TRIM(:RRASCRRDEF_N.CRR_ID);
    DB_stop_query_timer("RPT_select_insert_rrascrrdef", 0);
}



