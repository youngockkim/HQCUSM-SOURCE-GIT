		struct MGCMTBLDAT_N_TAG MGCMTBLDAT_N;
	EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_mgcmtbldat(&MGCMTBLDAT_N, MGCMTBLDAT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_MGCMTBLDAT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    TABLE_NAME,
                    KEY_1,
                    KEY_2,
                    KEY_3,
                    KEY_4,
                    KEY_5,
                    KEY_6,
                    KEY_7,
                    KEY_8,
                    KEY_9,
                    KEY_10,
                    DATA_1,
                    DATA_2,
                    DATA_3,
                    DATA_4,
                    DATA_5,
                    DATA_6,
                    DATA_7,
                    DATA_8,
                    DATA_9,
                    DATA_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MGCMTBLDAT
                WHERE FACTORY = :MGCMTBLDAT_N.FACTORY
                    AND TABLE_NAME = :MGCMTBLDAT_N.TABLE_NAME
                    AND ( 
                           ( KEY_1 > :MGCMTBLDAT_N.KEY_1) OR
                           ( KEY_1 = :MGCMTBLDAT_N.KEY_1 AND KEY_2 >= :MGCMTBLDAT_N.KEY_2 )
                        )
                ORDER BY KEY_1, KEY_2;
            EXEC SQL OPEN RPT_MGCMTBLDAT_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
