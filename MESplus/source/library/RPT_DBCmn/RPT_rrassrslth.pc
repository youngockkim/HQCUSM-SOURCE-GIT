/* SQL SELECT-INSERT Function */
void RPT_select_insert_rrassrslth(struct RRASSRSLTH_TAG *RRASSRSLTH)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASSRSLTH_N_TAG RRASSRSLTH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrassrslth(&RRASSRSLTH_N, RRASSRSLTH);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RRASSRSLTH
		SELECT
			FACTORY,
			RES_ID,
			SUBRES_ID,
			HIST_SEQ,
			LOT_ID,
			SUBLOT_ID,
			DECODE(TRIM(PARENTS_SUBRES_ID), '', NULL, PARENTS_SUBRES_ID),
			DECODE(TRIM(RES_HIST_SEQ), '', NULL, RES_HIST_SEQ),
			DECODE(TRIM(EVENT_ID), '', NULL, EVENT_ID),
			DECODE(TRIM(TRAN_TIME), '', NULL, TO_DATE(TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(LOT_HIST_SEQ), '', NULL, LOT_HIST_SEQ),
			DECODE(TRIM(SUBLOT_HIST_SEQ), '', NULL, SUBLOT_HIST_SEQ),
			DECODE(TRIM(MAT_ID), '', NULL, MAT_ID),
			DECODE(TRIM(MAT_VER), '', NULL, MAT_VER),
			DECODE(TRIM(FLOW), '', NULL, FLOW),
			DECODE(TRIM(OPER), '', NULL, OPER),
			DECODE(TRIM(LOT_TYPE), '', NULL, LOT_TYPE),
			DECODE(TRIM(RWK_FLAG), '', 'F', 'R'),
			DECODE(TRIM(QTY_1), '', 0, QTY_1),
			DECODE(TRIM(QTY_2), '', 0, QTY_2),
			DECODE(TRIM(QTY_3), '', 0, QTY_3),
			DECODE(TRIM(HIST_DEL_FLAG), '', 'N', HIST_DEL_FLAG)
		FROM MRASSRSLTH
        WHERE FACTORY = :RRASSRSLTH_N.FACTORY
          AND RES_ID = :RRASSRSLTH_N.RES_ID
          AND SUBRES_ID = :RRASSRSLTH_N.SUBRES_ID
          AND HIST_SEQ = :RRASSRSLTH_N.HIST_SEQ;
    DB_stop_query_timer("RPT_select_insert_rrassrslth", 0);
}

