                WHERE FACTORY = :RRASSRSLTH_N.FACTORY
                    AND RES_ID = :RRASSRSLTH_N.RES_ID
                    AND SUBRES_ID = :RRASSRSLTH_N.SUBRES_ID
                    AND HIST_SEQ = :RRASSRSLTH_N.HIST_SEQ;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_update_rrassrslth", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rrassrslth(int sel_type, struct RRASSRSLTH_TAG *RRASSRSLTH)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASSRSLTH_N_TAG RRASSRSLTH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrassrslth(&RRASSRSLTH_N, RRASSRSLTH);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RRASSRSLTH_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    HIST_SEQ,
                    LOT_ID,
                    SUBLOT_ID,
                    DECODE(PARENTS_SUBRES_ID, NULL, 'Y', ' '), NVL(PARENTS_SUBRES_ID, ' '),
                    DECODE(RES_HIST_SEQ, NULL, 'Y', ' '), NVL(RES_HIST_SEQ, '0'),
                    DECODE(EVENT_ID, NULL, 'Y', ' '), NVL(EVENT_ID, ' '),
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(LOT_HIST_SEQ, NULL, 'Y', ' '), NVL(LOT_HIST_SEQ, '0'),
                    DECODE(SUBLOT_HIST_SEQ, NULL, 'Y', ' '), NVL(SUBLOT_HIST_SEQ, '0'),
                    DECODE(MAT_ID, NULL, 'Y', ' '), NVL(MAT_ID, ' '),
                    DECODE(MAT_VER, NULL, 'Y', ' '), NVL(MAT_VER, '0'),
                    DECODE(FLOW, NULL, 'Y', ' '), NVL(FLOW, ' '),
                    DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
                    DECODE(LOT_TYPE, NULL, 'Y', ' '), NVL(LOT_TYPE, ' '),
                    DECODE(RWK_FLAG, NULL, 'Y', ' '), NVL(RWK_FLAG, ' '),
                    DECODE(QTY_1, NULL, 'Y', ' '), NVL(QTY_1, '0'),
                    DECODE(QTY_2, NULL, 'Y', ' '), NVL(QTY_2, '0'),
                    DECODE(QTY_3, NULL, 'Y', ' '), NVL(QTY_3, '0'),
                    DECODE(HIST_DEL_FLAG, NULL, 'Y', ' '), NVL(HIST_DEL_FLAG, 'N')
                FROM RRASSRSLTH
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SUBRES_ID ASC,
                    HIST_SEQ ASC,
                    LOT_ID ASC,
                    SUBLOT_ID ASC;
            EXEC SQL OPEN RPT_RRASSRSLTH_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rrassrslth", sel_type);
}


/* SQL CURSOR FETCH Function */
void RPT_fetch_rrassrslth(int sel_type, struct RRASSRSLTH_TAG *RRASSRSLTH)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASSRSLTH_N_TAG RRASSRSLTH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_RRASSRSLTH_CUR_1 INTO
                :RRASSRSLTH_N.FACTORY,
                :RRASSRSLTH_N.RES_ID,
                :RRASSRSLTH_N.SUBRES_ID,
                :RRASSRSLTH_N.HIST_SEQ,
                :RRASSRSLTH_N.LOT_ID,
                :RRASSRSLTH_N.SUBLOT_ID,
                :RRASSRSLTH_N.PARENTS_SUBRES_ID.IS_NULL, :RRASSRSLTH_N.PARENTS_SUBRES_ID.VALUE,
                :RRASSRSLTH_N.RES_HIST_SEQ.IS_NULL, :RRASSRSLTH_N.RES_HIST_SEQ.VALUE,
                :RRASSRSLTH_N.EVENT_ID.IS_NULL, :RRASSRSLTH_N.EVENT_ID.VALUE,
                :RRASSRSLTH_N.TRAN_TIME.IS_NULL, :RRASSRSLTH_N.TRAN_TIME.VALUE,
                :RRASSRSLTH_N.LOT_HIST_SEQ.IS_NULL, :RRASSRSLTH_N.LOT_HIST_SEQ.VALUE,
                :RRASSRSLTH_N.SUBLOT_HIST_SEQ.IS_NULL, :RRASSRSLTH_N.SUBLOT_HIST_SEQ.VALUE,
                :RRASSRSLTH_N.MAT_ID.IS_NULL, :RRASSRSLTH_N.MAT_ID.VALUE,
                :RRASSRSLTH_N.MAT_VER.IS_NULL, :RRASSRSLTH_N.MAT_VER.VALUE,
                :RRASSRSLTH_N.FLOW.IS_NULL, :RRASSRSLTH_N.FLOW.VALUE,
                :RRASSRSLTH_N.OPER.IS_NULL, :RRASSRSLTH_N.OPER.VALUE,
                :RRASSRSLTH_N.LOT_TYPE.IS_NULL, :RRASSRSLTH_N.LOT_TYPE.VALUE,
                :RRASSRSLTH_N.RWK_FLAG.IS_NULL, :RRASSRSLTH_N.RWK_FLAG.VALUE,
                :RRASSRSLTH_N.QTY_1.IS_NULL, :RRASSRSLTH_N.QTY_1.VALUE,
                :RRASSRSLTH_N.QTY_2.IS_NULL, :RRASSRSLTH_N.QTY_2.VALUE,
                :RRASSRSLTH_N.QTY_3.IS_NULL, :RRASSRSLTH_N.QTY_3.VALUE,
                :RRASSRSLTH_N.HIST_DEL_FLAG.IS_NULL, :RRASSRSLTH_N.HIST_DEL_FLAG.VALUE;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rrassrslth(&RRASSRSLTH_N, RRASSRSLTH);
    }
    DB_stop_query_timer("RPT_fetch_rrassrslth", sel_type);
}


/* SQL CURSOR CLOSE Function */
void RPT_close_rrassrslth(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_RRASSRSLTH_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_rrassrslth", sel_type);
}


/* Initialize Function */
void RPT_init_rrassrslth(struct RRASSRSLTH_TAG *RRASSRSLTH)
{
    /* memset by Space */
    memset(RRASSRSLTH, ' ', sizeof(struct RRASSRSLTH_TAG));
    
    RRASSRSLTH->HIST_SEQ = 0;
    RRASSRSLTH->PARENTS_SUBRES_ID.IS_NULL = 'Y';
    RRASSRSLTH->RES_HIST_SEQ.VALUE = 0;
    RRASSRSLTH->RES_HIST_SEQ.IS_NULL = 'Y';
    RRASSRSLTH->EVENT_ID.IS_NULL = 'Y';
    RRASSRSLTH->TRAN_TIME.IS_NULL = 'Y';
    RRASSRSLTH->LOT_HIST_SEQ.VALUE = 0;
    RRASSRSLTH->LOT_HIST_SEQ.IS_NULL = 'Y';
    RRASSRSLTH->SUBLOT_HIST_SEQ.VALUE = 0;
    RRASSRSLTH->SUBLOT_HIST_SEQ.IS_NULL = 'Y';
    RRASSRSLTH->MAT_ID.IS_NULL = 'Y';
    RRASSRSLTH->MAT_VER.VALUE = 0;
    RRASSRSLTH->MAT_VER.IS_NULL = 'Y';
    RRASSRSLTH->FLOW.IS_NULL = 'Y';
    RRASSRSLTH->OPER.IS_NULL = 'Y';
    RRASSRSLTH->LOT_TYPE.IS_NULL = 'Y';
    RRASSRSLTH->RWK_FLAG.IS_NULL = 'Y';
    RRASSRSLTH->QTY_1.VALUE = 0;
    RRASSRSLTH->QTY_1.IS_NULL = 'Y';
    RRASSRSLTH->QTY_2.VALUE = 0;
    RRASSRSLTH->QTY_2.IS_NULL = 'Y';
    RRASSRSLTH->QTY_3.VALUE = 0;
    RRASSRSLTH->QTY_3.IS_NULL = 'Y';
    RRASSRSLTH->HIST_DEL_FLAG.IS_NULL = 'Y';
}


/* Add Null Function */
void RPT_add_null_rrassrslth(struct RRASSRSLTH_N_TAG *RRASSRSLTH_N, struct RRASSRSLTH_TAG *RRASSRSLTH)
{
    /* memset by NULL */
    memset(RRASSRSLTH_N, '\0', sizeof(struct RRASSRSLTH_N_TAG));
    
    MEMCPY_AN(RRASSRSLTH_N->FACTORY, RRASSRSLTH->FACTORY, sizeof(RRASSRSLTH->FACTORY));
    MEMCPY_AN(RRASSRSLTH_N->RES_ID, RRASSRSLTH->RES_ID, sizeof(RRASSRSLTH->RES_ID));
    MEMCPY_AN(RRASSRSLTH_N->SUBRES_ID, RRASSRSLTH->SUBRES_ID, sizeof(RRASSRSLTH->SUBRES_ID));
    RRASSRSLTH_N->HIST_SEQ = RRASSRSLTH->HIST_SEQ;
    MEMCPY_AN(RRASSRSLTH_N->LOT_ID, RRASSRSLTH->LOT_ID, sizeof(RRASSRSLTH->LOT_ID));
    MEMCPY_AN(RRASSRSLTH_N->SUBLOT_ID, RRASSRSLTH->SUBLOT_ID, sizeof(RRASSRSLTH->SUBLOT_ID));
    RRASSRSLTH_N->PARENTS_SUBRES_ID.IS_NULL[0] = RRASSRSLTH->PARENTS_SUBRES_ID.IS_NULL;
    MEMCPY_AN(RRASSRSLTH_N->PARENTS_SUBRES_ID.VALUE, RRASSRSLTH->PARENTS_SUBRES_ID.VALUE, sizeof(RRASSRSLTH->PARENTS_SUBRES_ID.VALUE));
    RRASSRSLTH_N->RES_HIST_SEQ.IS_NULL[0] = RRASSRSLTH->RES_HIST_SEQ.IS_NULL;
    RRASSRSLTH_N->RES_HIST_SEQ.VALUE = RRASSRSLTH->RES_HIST_SEQ.VALUE;
    RRASSRSLTH_N->EVENT_ID.IS_NULL[0] = RRASSRSLTH->EVENT_ID.IS_NULL;
    MEMCPY_AN(RRASSRSLTH_N->EVENT_ID.VALUE, RRASSRSLTH->EVENT_ID.VALUE, sizeof(RRASSRSLTH->EVENT_ID.VALUE));
    RRASSRSLTH_N->TRAN_TIME.IS_NULL[0] = RRASSRSLTH->TRAN_TIME.IS_NULL;
    MEMCPY_AN(RRASSRSLTH_N->TRAN_TIME.VALUE, RRASSRSLTH->TRAN_TIME.VALUE, sizeof(RRASSRSLTH->TRAN_TIME.VALUE));
    RRASSRSLTH_N->LOT_HIST_SEQ.IS_NULL[0] = RRASSRSLTH->LOT_HIST_SEQ.IS_NULL;
    RRASSRSLTH_N->LOT_HIST_SEQ.VALUE = RRASSRSLTH->LOT_HIST_SEQ.VALUE;
    RRASSRSLTH_N->SUBLOT_HIST_SEQ.IS_NULL[0] = RRASSRSLTH->SUBLOT_HIST_SEQ.IS_NULL;
    RRASSRSLTH_N->SUBLOT_HIST_SEQ.VALUE = RRASSRSLTH->SUBLOT_HIST_SEQ.VALUE;
    RRASSRSLTH_N->MAT_ID.IS_NULL[0] = RRASSRSLTH->MAT_ID.IS_NULL;
    MEMCPY_AN(RRASSRSLTH_N->MAT_ID.VALUE, RRASSRSLTH->MAT_ID.VALUE, sizeof(RRASSRSLTH->MAT_ID.VALUE));
    RRASSRSLTH_N->MAT_VER.IS_NULL[0] = RRASSRSLTH->MAT_VER.IS_NULL;
    RRASSRSLTH_N->MAT_VER.VALUE = RRASSRSLTH->MAT_VER.VALUE;
    RRASSRSLTH_N->FLOW.IS_NULL[0] = RRASSRSLTH->FLOW.IS_NULL;
    MEMCPY_AN(RRASSRSLTH_N->FLOW.VALUE, RRASSRSLTH->FLOW.VALUE, sizeof(RRASSRSLTH->FLOW.VALUE));
    RRASSRSLTH_N->OPER.IS_NULL[0] = RRASSRSLTH->OPER.IS_NULL;
    MEMCPY_AN(RRASSRSLTH_N->OPER.VALUE, RRASSRSLTH->OPER.VALUE, sizeof(RRASSRSLTH->OPER.VALUE));
    RRASSRSLTH_N->LOT_TYPE.IS_NULL[0] = RRASSRSLTH->LOT_TYPE.IS_NULL;
    RRASSRSLTH_N->LOT_TYPE.VALUE[0] = RRASSRSLTH->LOT_TYPE.VALUE;
    RRASSRSLTH_N->RWK_FLAG.IS_NULL[0] = RRASSRSLTH->RWK_FLAG.IS_NULL;
    RRASSRSLTH_N->RWK_FLAG.VALUE[0] = RRASSRSLTH->RWK_FLAG.VALUE;
    RRASSRSLTH_N->QTY_1.IS_NULL[0] = RRASSRSLTH->QTY_1.IS_NULL;
    RRASSRSLTH_N->QTY_1.VALUE = RRASSRSLTH->QTY_1.VALUE;
    RRASSRSLTH_N->QTY_2.IS_NULL[0] = RRASSRSLTH->QTY_2.IS_NULL;
    RRASSRSLTH_N->QTY_2.VALUE = RRASSRSLTH->QTY_2.VALUE;
    RRASSRSLTH_N->QTY_3.IS_NULL[0] = RRASSRSLTH->QTY_3.IS_NULL;
    RRASSRSLTH_N->QTY_3.VALUE = RRASSRSLTH->QTY_3.VALUE;
    RRASSRSLTH_N->HIST_DEL_FLAG.IS_NULL[0] = RRASSRSLTH->HIST_DEL_FLAG.IS_NULL;
    RRASSRSLTH_N->HIST_DEL_FLAG.VALUE[0] = RRASSRSLTH->HIST_DEL_FLAG.VALUE;
}


/* Del Null Function */
void RPT_del_null_rrassrslth(struct RRASSRSLTH_N_TAG *RRASSRSLTH_N, struct RRASSRSLTH_TAG *RRASSRSLTH)
{
    MEMCPY_DN(RRASSRSLTH->FACTORY, RRASSRSLTH_N->FACTORY, sizeof(RRASSRSLTH->FACTORY));
    MEMCPY_DN(RRASSRSLTH->RES_ID, RRASSRSLTH_N->RES_ID, sizeof(RRASSRSLTH->RES_ID));
    MEMCPY_DN(RRASSRSLTH->SUBRES_ID, RRASSRSLTH_N->SUBRES_ID, sizeof(RRASSRSLTH->SUBRES_ID));
    RRASSRSLTH->HIST_SEQ = RRASSRSLTH_N->HIST_SEQ;
    MEMCPY_DN(RRASSRSLTH->LOT_ID, RRASSRSLTH_N->LOT_ID, sizeof(RRASSRSLTH->LOT_ID));
    MEMCPY_DN(RRASSRSLTH->SUBLOT_ID, RRASSRSLTH_N->SUBLOT_ID, sizeof(RRASSRSLTH->SUBLOT_ID));
    RRASSRSLTH->PARENTS_SUBRES_ID.IS_NULL = RRASSRSLTH_N->PARENTS_SUBRES_ID.IS_NULL[0];
    MEMCPY_DN(RRASSRSLTH->PARENTS_SUBRES_ID.VALUE, RRASSRSLTH_N->PARENTS_SUBRES_ID.VALUE, sizeof(RRASSRSLTH->PARENTS_SUBRES_ID.VALUE));
    RRASSRSLTH->RES_HIST_SEQ.IS_NULL = RRASSRSLTH_N->RES_HIST_SEQ.IS_NULL[0];
    RRASSRSLTH->RES_HIST_SEQ.VALUE = RRASSRSLTH_N->RES_HIST_SEQ.VALUE;
    RRASSRSLTH->EVENT_ID.IS_NULL = RRASSRSLTH_N->EVENT_ID.IS_NULL[0];
    MEMCPY_DN(RRASSRSLTH->EVENT_ID.VALUE, RRASSRSLTH_N->EVENT_ID.VALUE, sizeof(RRASSRSLTH->EVENT_ID.VALUE));
    RRASSRSLTH->TRAN_TIME.IS_NULL = RRASSRSLTH_N->TRAN_TIME.IS_NULL[0];
    MEMCPY_DN(RRASSRSLTH->TRAN_TIME.VALUE, RRASSRSLTH_N->TRAN_TIME.VALUE, sizeof(RRASSRSLTH->TRAN_TIME.VALUE));
    RRASSRSLTH->LOT_HIST_SEQ.IS_NULL = RRASSRSLTH_N->LOT_HIST_SEQ.IS_NULL[0];
    RRASSRSLTH->LOT_HIST_SEQ.VALUE = RRASSRSLTH_N->LOT_HIST_SEQ.VALUE;
    RRASSRSLTH->SUBLOT_HIST_SEQ.IS_NULL = RRASSRSLTH_N->SUBLOT_HIST_SEQ.IS_NULL[0];
    RRASSRSLTH->SUBLOT_HIST_SEQ.VALUE = RRASSRSLTH_N->SUBLOT_HIST_SEQ.VALUE;
    RRASSRSLTH->MAT_ID.IS_NULL = RRASSRSLTH_N->MAT_ID.IS_NULL[0];
    MEMCPY_DN(RRASSRSLTH->MAT_ID.VALUE, RRASSRSLTH_N->MAT_ID.VALUE, sizeof(RRASSRSLTH->MAT_ID.VALUE));
    RRASSRSLTH->MAT_VER.IS_NULL = RRASSRSLTH_N->MAT_VER.IS_NULL[0];
    RRASSRSLTH->MAT_VER.VALUE = RRASSRSLTH_N->MAT_VER.VALUE;
    RRASSRSLTH->FLOW.IS_NULL = RRASSRSLTH_N->FLOW.IS_NULL[0];
    MEMCPY_DN(RRASSRSLTH->FLOW.VALUE, RRASSRSLTH_N->FLOW.VALUE, sizeof(RRASSRSLTH->FLOW.VALUE));
    RRASSRSLTH->OPER.IS_NULL = RRASSRSLTH_N->OPER.IS_NULL[0];
    MEMCPY_DN(RRASSRSLTH->OPER.VALUE, RRASSRSLTH_N->OPER.VALUE, sizeof(RRASSRSLTH->OPER.VALUE));
    RRASSRSLTH->LOT_TYPE.IS_NULL = RRASSRSLTH_N->LOT_TYPE.IS_NULL[0];
    RRASSRSLTH->LOT_TYPE.VALUE = RRASSRSLTH_N->LOT_TYPE.VALUE[0];
    RRASSRSLTH->RWK_FLAG.IS_NULL = RRASSRSLTH_N->RWK_FLAG.IS_NULL[0];
    RRASSRSLTH->RWK_FLAG.VALUE = RRASSRSLTH_N->RWK_FLAG.VALUE[0];
    RRASSRSLTH->QTY_1.IS_NULL = RRASSRSLTH_N->QTY_1.IS_NULL[0];
    RRASSRSLTH->QTY_1.VALUE = RRASSRSLTH_N->QTY_1.VALUE;
    RRASSRSLTH->QTY_2.IS_NULL = RRASSRSLTH_N->QTY_2.IS_NULL[0];
    RRASSRSLTH->QTY_2.VALUE = RRASSRSLTH_N->QTY_2.VALUE;
    RRASSRSLTH->QTY_3.IS_NULL = RRASSRSLTH_N->QTY_3.IS_NULL[0];
    RRASSRSLTH->QTY_3.VALUE = RRASSRSLTH_N->QTY_3.VALUE;
    RRASSRSLTH->HIST_DEL_FLAG.IS_NULL = RRASSRSLTH_N->HIST_DEL_FLAG.IS_NULL[0];
    RRASSRSLTH->HIST_DEL_FLAG.VALUE = RRASSRSLTH_N->HIST_DEL_FLAG.VALUE[0];
