    MEMCPY_AN(RRASSRSLOT_N->CREATE_TIME.VALUE, RRASSRSLOT->CREATE_TIME.VALUE, sizeof(RRASSRSLOT->CREATE_TIME.VALUE));
    RRASSRSLOT_N->UPDATE_USER_ID.IS_NULL[0] = RRASSRSLOT->UPDATE_USER_ID.IS_NULL;
    MEMCPY_AN(RRASSRSLOT_N->UPDATE_USER_ID.VALUE, RRASSRSLOT->UPDATE_USER_ID.VALUE, sizeof(RRASSRSLOT->UPDATE_USER_ID.VALUE));
    RRASSRSLOT_N->UPDATE_TIME.IS_NULL[0] = RRASSRSLOT->UPDATE_TIME.IS_NULL;
    MEMCPY_AN(RRASSRSLOT_N->UPDATE_TIME.VALUE, RRASSRSLOT->UPDATE_TIME.VALUE, sizeof(RRASSRSLOT->UPDATE_TIME.VALUE));
}


/* Del Null Function */
void RPT_del_null_rrassrslot(struct RRASSRSLOT_N_TAG *RRASSRSLOT_N, struct RRASSRSLOT_TAG *RRASSRSLOT)
{
    MEMCPY_DN(RRASSRSLOT->FACTORY, RRASSRSLOT_N->FACTORY, sizeof(RRASSRSLOT->FACTORY));
    MEMCPY_DN(RRASSRSLOT->RES_ID, RRASSRSLOT_N->RES_ID, sizeof(RRASSRSLOT->RES_ID));
    MEMCPY_DN(RRASSRSLOT->SUBRES_ID, RRASSRSLOT_N->SUBRES_ID, sizeof(RRASSRSLOT->SUBRES_ID));
    MEMCPY_DN(RRASSRSLOT->LOT_ID, RRASSRSLOT_N->LOT_ID, sizeof(RRASSRSLOT->LOT_ID));
    MEMCPY_DN(RRASSRSLOT->SUBLOT_ID, RRASSRSLOT_N->SUBLOT_ID, sizeof(RRASSRSLOT->SUBLOT_ID));
    RRASSRSLOT->PARENTS_SUBRES_ID.IS_NULL = RRASSRSLOT_N->PARENTS_SUBRES_ID.IS_NULL[0];
    MEMCPY_DN(RRASSRSLOT->PARENTS_SUBRES_ID.VALUE, RRASSRSLOT_N->PARENTS_SUBRES_ID.VALUE, sizeof(RRASSRSLOT->PARENTS_SUBRES_ID.VALUE));
    RRASSRSLOT->EVENT_ID.IS_NULL = RRASSRSLOT_N->EVENT_ID.IS_NULL[0];
    MEMCPY_DN(RRASSRSLOT->EVENT_ID.VALUE, RRASSRSLOT_N->EVENT_ID.VALUE, sizeof(RRASSRSLOT->EVENT_ID.VALUE));
    RRASSRSLOT->TRAN_TIME.IS_NULL = RRASSRSLOT_N->TRAN_TIME.IS_NULL[0];
    MEMCPY_DN(RRASSRSLOT->TRAN_TIME.VALUE, RRASSRSLOT_N->TRAN_TIME.VALUE, sizeof(RRASSRSLOT->TRAN_TIME.VALUE));
    RRASSRSLOT->CREATE_USER_ID.IS_NULL = RRASSRSLOT_N->CREATE_USER_ID.IS_NULL[0];
    MEMCPY_DN(RRASSRSLOT->CREATE_USER_ID.VALUE, RRASSRSLOT_N->CREATE_USER_ID.VALUE, sizeof(RRASSRSLOT->CREATE_USER_ID.VALUE));
    RRASSRSLOT->CREATE_TIME.IS_NULL = RRASSRSLOT_N->CREATE_TIME.IS_NULL[0];
    MEMCPY_DN(RRASSRSLOT->CREATE_TIME.VALUE, RRASSRSLOT_N->CREATE_TIME.VALUE, sizeof(RRASSRSLOT->CREATE_TIME.VALUE));
    RRASSRSLOT->UPDATE_USER_ID.IS_NULL = RRASSRSLOT_N->UPDATE_USER_ID.IS_NULL[0];
    MEMCPY_DN(RRASSRSLOT->UPDATE_USER_ID.VALUE, RRASSRSLOT_N->UPDATE_USER_ID.VALUE, sizeof(RRASSRSLOT->UPDATE_USER_ID.VALUE));
    RRASSRSLOT->UPDATE_TIME.IS_NULL = RRASSRSLOT_N->UPDATE_TIME.IS_NULL[0];
    MEMCPY_DN(RRASSRSLOT->UPDATE_TIME.VALUE, RRASSRSLOT_N->UPDATE_TIME.VALUE, sizeof(RRASSRSLOT->UPDATE_TIME.VALUE));
}


