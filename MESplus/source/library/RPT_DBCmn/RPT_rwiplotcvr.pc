                    QTY_2 = DECODE(:RWIPLOTCVR_N.QTY_2.IS_NULL, 'Y', NULL, :RWIPLOTCVR_N.QTY_2.VALUE),
                    QTY_3 = DECODE(:RWIPLOTCVR_N.QTY_3.IS_NULL, 'Y', NULL, :RWIPLOTCVR_N.QTY_3.VALUE),
                    OLD_QTY_1 = DECODE(:RWIPLOTCVR_N.OLD_QTY_1.IS_NULL, 'Y', NULL, :RWIPLOTCVR_N.OLD_QTY_1.VALUE),
                    OLD_QTY_2 = DECODE(:RWIPLOTCVR_N.OLD_QTY_2.IS_NULL, 'Y', NULL, :RWIPLOTCVR_N.OLD_QTY_2.VALUE),
                    OLD_QTY_3 = DECODE(:RWIPLOTCVR_N.OLD_QTY_3.IS_NULL, 'Y', NULL, :RWIPLOTCVR_N.OLD_QTY_3.VALUE),
                    END_RES_ID = DECODE(:RWIPLOTCVR_N.END_RES_ID.IS_NULL, 'Y', NULL, :RWIPLOTCVR_N.END_RES_ID.VALUE),
                    LOT_DEL_CODE = DECODE(:RWIPLOTCVR_N.LOT_DEL_CODE.IS_NULL, 'Y', NULL, :RWIPLOTCVR_N.LOT_DEL_CODE.VALUE),
                    HIST_DEL_FLAG = DECODE(:RWIPLOTCVR_N.HIST_DEL_FLAG.IS_NULL, 'Y', 'N', :RWIPLOTCVR_N.HIST_DEL_FLAG.VALUE),
                    HIST_DEL_TIME = DECODE(:RWIPLOTCVR_N.HIST_DEL_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTCVR_N.HIST_DEL_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    DATE_CREATED = DECODE(:RWIPLOTCVR_N.DATE_CREATED.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTCVR_N.DATE_CREATED.VALUE, 'YYYYMMDDHH24MISS')),
                    DATE_UPDATED = DECODE(:RWIPLOTCVR_N.DATE_UPDATED.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTCVR_N.DATE_UPDATED.VALUE, 'YYYYMMDDHH24MISS'))
                WHERE LOT_ID = :RWIPLOTCVR_N.LOT_ID
                    AND HIST_SEQ = :RWIPLOTCVR_N.HIST_SEQ;
            break;

        case 2:
            EXEC SQL UPDATE RWIPLOTCVR SET
                    HIST_DEL_FLAG = DECODE(:RWIPLOTCVR_N.HIST_DEL_FLAG.IS_NULL, 'Y', 'N', :RWIPLOTCVR_N.HIST_DEL_FLAG.VALUE),
                    HIST_DEL_TIME = DECODE(:RWIPLOTCVR_N.HIST_DEL_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTCVR_N.HIST_DEL_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    DATE_UPDATED = DECODE(:RWIPLOTCVR_N.DATE_UPDATED.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTCVR_N.DATE_UPDATED.VALUE, 'YYYYMMDDHH24MISS'))
                WHERE LOT_ID = :RWIPLOTCVR_N.LOT_ID
                    AND HIST_SEQ = :RWIPLOTCVR_N.HIST_SEQ;
            break;

        case 3:
            EXEC SQL UPDATE RWIPLOTCVR SET
                    DATE_UPDATED = DECODE(:RWIPLOTCVR_N.DATE_UPDATED.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTCVR_N.DATE_UPDATED.VALUE, 'YYYYMMDDHH24MISS'))
                WHERE LOT_ID = :RWIPLOTCVR_N.LOT_ID
                    AND HIST_SEQ = :RWIPLOTCVR_N.HIST_SEQ;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_update_rwiplotcvr", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rwiplotcvr(int sel_type, struct RWIPLOTCVR_TAG *RWIPLOTCVR)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTCVR_N_TAG RWIPLOTCVR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplotcvr(&RWIPLOTCVR_N, RWIPLOTCVR);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RWIPLOTCVR_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(SYS_TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(TRANS_TYPE, NULL, 'Y', ' '), NVL(TRANS_TYPE, ' '),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '),
                    DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
                    DECODE(MAT_ID, NULL, 'Y', ' '), NVL(MAT_ID, ' '),
                    DECODE(MAT_VER, NULL, 'Y', ' '), NVL(MAT_VER, '0'),
                    DECODE(OWNER_CODE, NULL, 'Y', ' '), NVL(OWNER_CODE, ' '),
                    DECODE(CV_CODE, NULL, 'Y', ' '), NVL(CV_CODE, ' '),
                    DECODE(UNIT_1, NULL, 'Y', ' '), NVL(UNIT_1, ' '),
                    DECODE(UNIT_2, NULL, 'Y', ' '), NVL(UNIT_2, ' '),
                    DECODE(UNIT_3, NULL, 'Y', ' '), NVL(UNIT_3, ' '),
                    DECODE(QTY_1, NULL, 'Y', ' '), NVL(QTY_1, '0'),
                    DECODE(QTY_2, NULL, 'Y', ' '), NVL(QTY_2, '0'),
                    DECODE(QTY_3, NULL, 'Y', ' '), NVL(QTY_3, '0'),
                    DECODE(OLD_QTY_1, NULL, 'Y', ' '), NVL(OLD_QTY_1, '0'),
                    DECODE(OLD_QTY_2, NULL, 'Y', ' '), NVL(OLD_QTY_2, '0'),
                    DECODE(OLD_QTY_3, NULL, 'Y', ' '), NVL(OLD_QTY_3, '0'),
                    DECODE(END_RES_ID, NULL, 'Y', ' '), NVL(END_RES_ID, ' '),
                    DECODE(LOT_DEL_CODE, NULL, 'Y', ' '), NVL(LOT_DEL_CODE, ' '),
                    DECODE(HIST_DEL_FLAG, NULL, 'Y', ' '), NVL(HIST_DEL_FLAG, 'N'),
                    DECODE(HIST_DEL_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(HIST_DEL_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(DATE_CREATED, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_CREATED, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(DATE_UPDATED, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_UPDATED, 'YYYYMMDDHH24MISS'), ' ')
                FROM RWIPLOTCVR
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN RPT_RWIPLOTCVR_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rwiplotcvr", sel_type);
}


/* SQL CURSOR FETCH Function */
void RPT_fetch_rwiplotcvr(int sel_type, struct RWIPLOTCVR_TAG *RWIPLOTCVR)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTCVR_N_TAG RWIPLOTCVR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_RWIPLOTCVR_CUR_1 INTO
                :RWIPLOTCVR_N.LOT_ID,
                :RWIPLOTCVR_N.HIST_SEQ,
                :RWIPLOTCVR_N.TRAN_TIME.IS_NULL, :RWIPLOTCVR_N.TRAN_TIME.VALUE,
                :RWIPLOTCVR_N.SYS_TRAN_TIME.IS_NULL, :RWIPLOTCVR_N.SYS_TRAN_TIME.VALUE,
