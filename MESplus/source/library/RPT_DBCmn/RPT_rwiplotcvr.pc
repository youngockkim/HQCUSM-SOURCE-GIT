                :RWIPLOTCVR_N.UNIT_3.IS_NULL, :RWIPLOTCVR_N.UNIT_3.VALUE,
                :RWIPLOTCVR_N.QTY_1.IS_NULL, :RWIPLOTCVR_N.QTY_1.VALUE,
                :RWIPLOTCVR_N.QTY_2.IS_NULL, :RWIPLOTCVR_N.QTY_2.VALUE,
                :RWIPLOTCVR_N.QTY_3.IS_NULL, :RWIPLOTCVR_N.QTY_3.VALUE,
                :RWIPLOTCVR_N.OLD_QTY_1.IS_NULL, :RWIPLOTCVR_N.OLD_QTY_1.VALUE,
                :RWIPLOTCVR_N.OLD_QTY_2.IS_NULL, :RWIPLOTCVR_N.OLD_QTY_2.VALUE,
                :RWIPLOTCVR_N.OLD_QTY_3.IS_NULL, :RWIPLOTCVR_N.OLD_QTY_3.VALUE,
                :RWIPLOTCVR_N.END_RES_ID.IS_NULL, :RWIPLOTCVR_N.END_RES_ID.VALUE,
                :RWIPLOTCVR_N.LOT_DEL_CODE.IS_NULL, :RWIPLOTCVR_N.LOT_DEL_CODE.VALUE,
                :RWIPLOTCVR_N.HIST_DEL_FLAG.IS_NULL, :RWIPLOTCVR_N.HIST_DEL_FLAG.VALUE,
                :RWIPLOTCVR_N.HIST_DEL_TIME.IS_NULL, :RWIPLOTCVR_N.HIST_DEL_TIME.VALUE,
                :RWIPLOTCVR_N.DATE_CREATED.IS_NULL, :RWIPLOTCVR_N.DATE_CREATED.VALUE,
                :RWIPLOTCVR_N.DATE_UPDATED.IS_NULL, :RWIPLOTCVR_N.DATE_UPDATED.VALUE;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rwiplotcvr(&RWIPLOTCVR_N, RWIPLOTCVR);
    }
    DB_stop_query_timer("RPT_fetch_rwiplotcvr", sel_type);
