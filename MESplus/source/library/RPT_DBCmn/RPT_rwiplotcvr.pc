/* Initialize Function */
void RPT_init_rwiplotcvr(struct RWIPLOTCVR_TAG *RWIPLOTCVR)
{
    /* memset by Space */
    memset(RWIPLOTCVR, ' ', sizeof(struct RWIPLOTCVR_TAG));
    
    RWIPLOTCVR->HIST_SEQ = 0;
    RWIPLOTCVR->TRAN_TIME.IS_NULL = 'Y';
    RWIPLOTCVR->SYS_TRAN_TIME.IS_NULL = 'Y';
    RWIPLOTCVR->TRANS_TYPE.IS_NULL = 'Y';
    RWIPLOTCVR->FACTORY.IS_NULL = 'Y';
    RWIPLOTCVR->OPER.IS_NULL = 'Y';
    RWIPLOTCVR->MAT_ID.IS_NULL = 'Y';
    RWIPLOTCVR->MAT_VER.VALUE = 0;
    RWIPLOTCVR->MAT_VER.IS_NULL = 'Y';
    RWIPLOTCVR->OWNER_CODE.IS_NULL = 'Y';
    RWIPLOTCVR->CV_CODE.IS_NULL = 'Y';
    RWIPLOTCVR->UNIT_1.IS_NULL = 'Y';
    RWIPLOTCVR->UNIT_2.IS_NULL = 'Y';
    RWIPLOTCVR->UNIT_3.IS_NULL = 'Y';
    RWIPLOTCVR->QTY_1.VALUE = 0;
    RWIPLOTCVR->QTY_1.IS_NULL = 'Y';
    RWIPLOTCVR->QTY_2.VALUE = 0;
    RWIPLOTCVR->QTY_2.IS_NULL = 'Y';
    RWIPLOTCVR->QTY_3.VALUE = 0;
    RWIPLOTCVR->QTY_3.IS_NULL = 'Y';
    RWIPLOTCVR->OLD_QTY_1.VALUE = 0;
    RWIPLOTCVR->OLD_QTY_1.IS_NULL = 'Y';
    RWIPLOTCVR->OLD_QTY_2.VALUE = 0;
    RWIPLOTCVR->OLD_QTY_2.IS_NULL = 'Y';
    RWIPLOTCVR->OLD_QTY_3.VALUE = 0;
    RWIPLOTCVR->OLD_QTY_3.IS_NULL = 'Y';
    RWIPLOTCVR->END_RES_ID.IS_NULL = 'Y';
    RWIPLOTCVR->LOT_DEL_CODE.IS_NULL = 'Y';
    RWIPLOTCVR->HIST_DEL_FLAG.IS_NULL = 'Y';
    RWIPLOTCVR->HIST_DEL_TIME.IS_NULL = 'Y';
    RWIPLOTCVR->DATE_CREATED.IS_NULL = 'Y';
    RWIPLOTCVR->DATE_UPDATED.IS_NULL = 'Y';
}


/* Add Null Function */
void RPT_add_null_rwiplotcvr(struct RWIPLOTCVR_N_TAG *RWIPLOTCVR_N, struct RWIPLOTCVR_TAG *RWIPLOTCVR)
{
    /* memset by NULL */
    memset(RWIPLOTCVR_N, '\0', sizeof(struct RWIPLOTCVR_N_TAG));
    
    MEMCPY_AN(RWIPLOTCVR_N->LOT_ID, RWIPLOTCVR->LOT_ID, sizeof(RWIPLOTCVR->LOT_ID));
    RWIPLOTCVR_N->HIST_SEQ = RWIPLOTCVR->HIST_SEQ;
    RWIPLOTCVR_N->TRAN_TIME.IS_NULL[0] = RWIPLOTCVR->TRAN_TIME.IS_NULL;
    MEMCPY_AN(RWIPLOTCVR_N->TRAN_TIME.VALUE, RWIPLOTCVR->TRAN_TIME.VALUE, sizeof(RWIPLOTCVR->TRAN_TIME.VALUE));
    RWIPLOTCVR_N->SYS_TRAN_TIME.IS_NULL[0] = RWIPLOTCVR->SYS_TRAN_TIME.IS_NULL;
