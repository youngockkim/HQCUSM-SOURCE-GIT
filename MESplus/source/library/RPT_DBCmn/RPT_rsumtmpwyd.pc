/* Initialize Function */
void RPT_init_rsumtmpwyd(struct RSUMTMPWYD_TAG *RSUMTMPWYD)
{
    /* memset by Space */
    memset(RSUMTMPWYD, ' ', sizeof(struct RSUMTMPWYD_TAG));
    
    RSUMTMPWYD->SEQ = 0;
    RSUMTMPWYD->HIST_SEQ = 0;
    RSUMTMPWYD->END_SEQ = 0;
    RSUMTMPWYD->IN_QTY = 0;
    RSUMTMPWYD->OUT_QTY = 0;
}


/* Add Null Function */
void RPT_add_null_rsumtmpwyd(struct RSUMTMPWYD_N_TAG *RSUMTMPWYD_N, struct RSUMTMPWYD_TAG *RSUMTMPWYD)
{
    /* memset by NULL */
    memset(RSUMTMPWYD_N, '\0', sizeof(struct RSUMTMPWYD_N_TAG));
    
    MEMCPY_AN(RSUMTMPWYD_N->SUBLOT_ID, RSUMTMPWYD->SUBLOT_ID, sizeof(RSUMTMPWYD->SUBLOT_ID));
    RSUMTMPWYD_N->PERIOD_TYPE[0] = RSUMTMPWYD->PERIOD_TYPE;
    MEMCPY_AN(RSUMTMPWYD_N->PERIOD_NAME, RSUMTMPWYD->PERIOD_NAME, sizeof(RSUMTMPWYD->PERIOD_NAME));
    RSUMTMPWYD_N->SEQ = RSUMTMPWYD->SEQ;
    RSUMTMPWYD_N->END_FLAG[0] = RSUMTMPWYD->END_FLAG;
    RSUMTMPWYD_N->END_SEQ = RSUMTMPWYD->END_SEQ;
    MEMCPY_AN(RSUMTMPWYD_N->LOT_ID, RSUMTMPWYD->LOT_ID, sizeof(RSUMTMPWYD->LOT_ID));
    RSUMTMPWYD_N->HIST_SEQ = RSUMTMPWYD->HIST_SEQ;
    MEMCPY_AN(RSUMTMPWYD_N->TRAN_TIME, RSUMTMPWYD->TRAN_TIME, sizeof(RSUMTMPWYD->TRAN_TIME));
    MEMCPY_AN(RSUMTMPWYD_N->FACTORY, RSUMTMPWYD->FACTORY, sizeof(RSUMTMPWYD->FACTORY));
    MEMCPY_AN(RSUMTMPWYD_N->OPER, RSUMTMPWYD->OPER, sizeof(RSUMTMPWYD->OPER));
    RSUMTMPWYD_N->GRADE[0] = RSUMTMPWYD->GRADE;
    RSUMTMPWYD_N->IN_QTY = RSUMTMPWYD->IN_QTY;
    RSUMTMPWYD_N->OUT_QTY = RSUMTMPWYD->OUT_QTY;
    MEMCPY_AN(RSUMTMPWYD_N->CREATE_TIME, RSUMTMPWYD->CREATE_TIME, sizeof(RSUMTMPWYD->CREATE_TIME));
    MEMCPY_AN(RSUMTMPWYD_N->UPDATE_TIME, RSUMTMPWYD->UPDATE_TIME, sizeof(RSUMTMPWYD->UPDATE_TIME));
}


/* Del Null Function */
void RPT_del_null_rsumtmpwyd(struct RSUMTMPWYD_N_TAG *RSUMTMPWYD_N, struct RSUMTMPWYD_TAG *RSUMTMPWYD)
{
    MEMCPY_DN(RSUMTMPWYD->SUBLOT_ID, RSUMTMPWYD_N->SUBLOT_ID, sizeof(RSUMTMPWYD->SUBLOT_ID));
    RSUMTMPWYD->PERIOD_TYPE = RSUMTMPWYD_N->PERIOD_TYPE[0];
    MEMCPY_DN(RSUMTMPWYD->PERIOD_NAME, RSUMTMPWYD_N->PERIOD_NAME, sizeof(RSUMTMPWYD->PERIOD_NAME));
    RSUMTMPWYD->SEQ = RSUMTMPWYD_N->SEQ;
    RSUMTMPWYD->END_FLAG = RSUMTMPWYD_N->END_FLAG[0];
    RSUMTMPWYD->END_SEQ = RSUMTMPWYD_N->END_SEQ;
    MEMCPY_DN(RSUMTMPWYD->LOT_ID, RSUMTMPWYD_N->LOT_ID, sizeof(RSUMTMPWYD->LOT_ID));
    RSUMTMPWYD->HIST_SEQ = RSUMTMPWYD_N->HIST_SEQ;
    MEMCPY_DN(RSUMTMPWYD->TRAN_TIME, RSUMTMPWYD_N->TRAN_TIME, sizeof(RSUMTMPWYD->TRAN_TIME));
    MEMCPY_DN(RSUMTMPWYD->FACTORY, RSUMTMPWYD_N->FACTORY, sizeof(RSUMTMPWYD->FACTORY));
    MEMCPY_DN(RSUMTMPWYD->OPER, RSUMTMPWYD_N->OPER, sizeof(RSUMTMPWYD->OPER));
    RSUMTMPWYD->GRADE = RSUMTMPWYD_N->GRADE[0];
    RSUMTMPWYD->IN_QTY = RSUMTMPWYD_N->IN_QTY;
    RSUMTMPWYD->OUT_QTY = RSUMTMPWYD_N->OUT_QTY;
    MEMCPY_DN(RSUMTMPWYD->CREATE_TIME, RSUMTMPWYD_N->CREATE_TIME, sizeof(RSUMTMPWYD->CREATE_TIME));
    MEMCPY_DN(RSUMTMPWYD->UPDATE_TIME, RSUMTMPWYD_N->UPDATE_TIME, sizeof(RSUMTMPWYD->UPDATE_TIME));
