/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rsumtmpwyd(int sel_type, struct RSUMTMPWYD_TAG *RSUMTMPWYD)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RSUMTMPWYD_N_TAG RSUMTMPWYD_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rsumtmpwyd(&RSUMTMPWYD_N, RSUMTMPWYD);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RSUMTMPWYD_CUR_1 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    PERIOD_TYPE,
                    PERIOD_NAME,
                    SEQ,
                    END_FLAG,
                    END_SEQ,
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    FACTORY,
                    OPER,
                    GRADE,
                    IN_QTY,
                    OUT_QTY,
                    CREATE_TIME,
                    UPDATE_TIME
                FROM RSUMTMPWYD
                ORDER BY SUBLOT_ID ASC,
                    PERIOD_TYPE ASC,
                    PERIOD_NAME ASC,
                    SEQ ASC;
            EXEC SQL OPEN RPT_RSUMTMPWYD_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE RPT_RSUMTMPWYD_CUR_2 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    PERIOD_TYPE,
                    PERIOD_NAME,
                    SEQ,
                    END_FLAG,
                    END_SEQ,
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    FACTORY,
                    OPER,
                    GRADE,
                    IN_QTY,
                    OUT_QTY,
                    CREATE_TIME,
                    UPDATE_TIME
                FROM RSUMTMPWYD
                WHERE SUBLOT_ID = :RSUMTMPWYD_N.SUBLOT_ID
                ORDER BY PERIOD_TYPE ASC,
						 PERIOD_NAME ASC;
            EXEC SQL OPEN RPT_RSUMTMPWYD_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE RPT_RSUMTMPWYD_CUR_3 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    PERIOD_TYPE,
                    PERIOD_NAME,
                    SEQ,
                    END_FLAG,
                    END_SEQ,
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    FACTORY,
                    OPER,
                    GRADE,
                    IN_QTY,
                    OUT_QTY,
                    CREATE_TIME,
                    UPDATE_TIME
                FROM RSUMTMPWYD
                WHERE LOT_ID = :RSUMTMPWYD_N.LOT_ID
                    AND PERIOD_TYPE = :RSUMTMPWYD_N.PERIOD_TYPE
                    AND PERIOD_NAME = :RSUMTMPWYD_N.PERIOD_NAME
                    AND SEQ = (SELECT MAX(SEQ) FROM RSUMTMPWYD
                                WHERE LOT_ID = :RSUMTMPWYD_N.LOT_ID
                                  AND PERIOD_TYPE = :RSUMTMPWYD_N.PERIOD_TYPE
								  AND PERIOD_NAME = :RSUMTMPWYD_N.PERIOD_NAME
								  AND END_FLAG = :RSUMTMPWYD_N.END_FLAG);
            EXEC SQL OPEN RPT_RSUMTMPWYD_CUR_3;
            break;

        case 4:
            EXEC SQL DECLARE RPT_RSUMTMPWYD_CUR_4 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    PERIOD_TYPE,
                    PERIOD_NAME,
                    SEQ,
                    END_FLAG,
                    END_SEQ,
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    FACTORY,
                    OPER,
                    GRADE,
                    IN_QTY,
                    OUT_QTY,
                    CREATE_TIME,
                    UPDATE_TIME
                FROM RSUMTMPWYD
                WHERE LOT_ID = :RSUMTMPWYD_N.LOT_ID 
                  AND PERIOD_TYPE = :RSUMTMPWYD_N.PERIOD_TYPE
                  AND PERIOD_NAME = :RSUMTMPWYD_N.PERIOD_NAME
                  AND SEQ = (SELECT NVL(MAX(SEQ), 0) FROM RSUMTMPWYD
                              WHERE LOT_ID = :RSUMTMPWYD_N.LOT_ID 
								AND PERIOD_TYPE = :RSUMTMPWYD_N.PERIOD_TYPE
								AND PERIOD_NAME = :RSUMTMPWYD_N.PERIOD_NAME);
            EXEC SQL OPEN RPT_RSUMTMPWYD_CUR_4;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rsumtmpwyd", sel_type);
}


