/* SQL CURSOR CLOSE Function */
void RPT_close_mwipsltsts(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_MWIPSLTSTS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE RPT_MWIPSLTSTS_CUR_2;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_mwipsltsts", sel_type);
}


/* Initialize Function */
void RPT_init_mwipsltsts(struct MWIPSLTSTS_TAG *MWIPSLTSTS)
{
    /* memset by Space */
    memset(MWIPSLTSTS, ' ', sizeof(struct MWIPSLTSTS_TAG));
    
    MWIPSLTSTS->MAT_VER = 0;
    MWIPSLTSTS->FLOW_SEQ_NUM = 0;
    MWIPSLTSTS->SLOT_NO = 0;
    MWIPSLTSTS->QTY_2 = 0;
    MWIPSLTSTS->QTY_3 = 0;
    MWIPSLTSTS->OPER_IN_QTY_2 = 0;
    MWIPSLTSTS->OPER_IN_QTY_3 = 0;
    MWIPSLTSTS->CREATE_QTY_2 = 0;
    MWIPSLTSTS->CREATE_QTY_3 = 0;
    MWIPSLTSTS->START_QTY_2 = 0;
    MWIPSLTSTS->START_QTY_3 = 0;
    MWIPSLTSTS->RWK_COUNT = 0;
    MWIPSLTSTS->RWK_RET_FLOW_SEQ_NUM = 0;
    MWIPSLTSTS->RWK_END_FLOW_SEQ_NUM = 0;
    MWIPSLTSTS->NSTD_RET_FLOW_SEQ_NUM = 0;
    MWIPSLTSTS->STR_RET_FLOW_SEQ_NUM = 0;
    MWIPSLTSTS->LOT_HIST_SEQ = 0;
    MWIPSLTSTS->LAST_ACTIVE_HIST_SEQ = 0;
    MWIPSLTSTS->LAST_HIST_SEQ = 0;
}


/* Add Null Function */
void RPT_add_null_mwipsltsts(struct MWIPSLTSTS_N_TAG *MWIPSLTSTS_N, struct MWIPSLTSTS_TAG *MWIPSLTSTS)
{
    /* memset by NULL */
    memset(MWIPSLTSTS_N, '\0', sizeof(struct MWIPSLTSTS_N_TAG));
    
    MEMCPY_AN(MWIPSLTSTS_N->SUBLOT_ID, MWIPSLTSTS->SUBLOT_ID, sizeof(MWIPSLTSTS->SUBLOT_ID));
    MEMCPY_AN(MWIPSLTSTS_N->LOT_ID, MWIPSLTSTS->LOT_ID, sizeof(MWIPSLTSTS->LOT_ID));
    MEMCPY_AN(MWIPSLTSTS_N->FACTORY, MWIPSLTSTS->FACTORY, sizeof(MWIPSLTSTS->FACTORY));
    MEMCPY_AN(MWIPSLTSTS_N->MAT_ID, MWIPSLTSTS->MAT_ID, sizeof(MWIPSLTSTS->MAT_ID));
    MWIPSLTSTS_N->MAT_VER = MWIPSLTSTS->MAT_VER;
    MEMCPY_AN(MWIPSLTSTS_N->FLOW, MWIPSLTSTS->FLOW, sizeof(MWIPSLTSTS->FLOW));
    MWIPSLTSTS_N->FLOW_SEQ_NUM = MWIPSLTSTS->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPSLTSTS_N->OPER, MWIPSLTSTS->OPER, sizeof(MWIPSLTSTS->OPER));
    MWIPSLTSTS_N->SLOT_NO = MWIPSLTSTS->SLOT_NO;
    MWIPSLTSTS_N->QTY_2 = MWIPSLTSTS->QTY_2;
    MWIPSLTSTS_N->QTY_3 = MWIPSLTSTS->QTY_3;
    MEMCPY_AN(MWIPSLTSTS_N->CRR_ID, MWIPSLTSTS->CRR_ID, sizeof(MWIPSLTSTS->CRR_ID));
    MEMCPY_AN(MWIPSLTSTS_N->OWNER_CODE, MWIPSLTSTS->OWNER_CODE, sizeof(MWIPSLTSTS->OWNER_CODE));
    MEMCPY_AN(MWIPSLTSTS_N->CREATE_CODE, MWIPSLTSTS->CREATE_CODE, sizeof(MWIPSLTSTS->CREATE_CODE));
    MEMCPY_AN(MWIPSLTSTS_N->SUBLOT_STATUS, MWIPSLTSTS->SUBLOT_STATUS, sizeof(MWIPSLTSTS->SUBLOT_STATUS));
    MWIPSLTSTS_N->HOLD_FLAG[0] = MWIPSLTSTS->HOLD_FLAG;
    MEMCPY_AN(MWIPSLTSTS_N->HOLD_CODE, MWIPSLTSTS->HOLD_CODE, sizeof(MWIPSLTSTS->HOLD_CODE));
    MEMCPY_AN(MWIPSLTSTS_N->HOLD_PASSWORD, MWIPSLTSTS->HOLD_PASSWORD, sizeof(MWIPSLTSTS->HOLD_PASSWORD));
    MEMCPY_AN(MWIPSLTSTS_N->HOLD_PRV_GRP_ID, MWIPSLTSTS->HOLD_PRV_GRP_ID, sizeof(MWIPSLTSTS->HOLD_PRV_GRP_ID));
    MWIPSLTSTS_N->OPER_IN_QTY_2 = MWIPSLTSTS->OPER_IN_QTY_2;
    MWIPSLTSTS_N->OPER_IN_QTY_3 = MWIPSLTSTS->OPER_IN_QTY_3;
