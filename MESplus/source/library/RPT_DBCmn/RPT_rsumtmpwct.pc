                    PERIOD_NAME,
                    SEQ,
                    REWORK_FLAG,
                    NO_WAFER_FLAG,
                    LOT_ID,
                    FACTORY,
                    OPER,
                    WAITING_TIME,
                    PROCESS_TIME,
                    STORE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM RSUMTMPWCT
                ORDER BY SUBLOT_ID ASC,
                    HIST_SEQ ASC,
                    PERIOD_TYPE ASC,
                    PERIOD_NAME ASC,
                    SEQ ASC;
            EXEC SQL OPEN RPT_RSUMTMPWCT_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE RPT_RSUMTMPWCT_CUR_2 CURSOR FOR
                SELECT SUBLOT_ID, NVL(SUM(WAITING_TIME), 0), NVL(SUM(PROCESS_TIME), 0), NVL(SUM(STORE_TIME), 0) 
                FROM RSUMTMPWCT
                WHERE PERIOD_TYPE = :RSUMTMPWCT_N.PERIOD_TYPE
                    AND PERIOD_NAME = :RSUMTMPWCT_N.PERIOD_NAME
                    AND SEQ = :RSUMTMPWCT_N.SEQ
                    AND LOT_ID = :RSUMTMPWCT_N.LOT_ID
                    AND NO_WAFER_FLAG = :RSUMTMPWCT_N.NO_WAFER_FLAG
                GROUP BY SUBLOT_ID;
            EXEC SQL OPEN RPT_RSUMTMPWCT_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE RPT_RSUMTMPWCT_CUR_3 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    HIST_SEQ,
                    PERIOD_TYPE,
                    PERIOD_NAME,
                    SEQ,
                    REWORK_FLAG,
                    NO_WAFER_FLAG,
                    LOT_ID,
                    FACTORY,
                    OPER,
                    WAITING_TIME,
                    PROCESS_TIME,
                    STORE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM RSUMTMPWCT
                WHERE SUBLOT_ID = :RSUMTMPWCT_N.SUBLOT_ID
                  AND REWORK_FLAG = :RSUMTMPWCT_N.REWORK_FLAG
                  AND LOT_ID = :RSUMTMPWCT_N.LOT_ID
                ORDER BY SUBLOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN RPT_RSUMTMPWCT_CUR_3;
            break;

        case 4:
            EXEC SQL DECLARE RPT_RSUMTMPWCT_CUR_4 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    HIST_SEQ,
                    PERIOD_TYPE,
                    PERIOD_NAME,
                    SEQ,
                    REWORK_FLAG,
                    NO_WAFER_FLAG,
                    LOT_ID,
                    FACTORY,
                    OPER,
                    WAITING_TIME,
                    PROCESS_TIME,
                    STORE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM RSUMTMPWCT
                WHERE SUBLOT_ID = :RSUMTMPWCT_N.SUBLOT_ID
                  AND LOT_ID = :RSUMTMPWCT_N.LOT_ID
                  AND NO_WAFER_FLAG = :RSUMTMPWCT_N.NO_WAFER_FLAG
                  AND PERIOD_TYPE = :RSUMTMPWCT_N.PERIOD_TYPE
                  AND PERIOD_NAME = :RSUMTMPWCT_N.PERIOD_NAME
                  AND SEQ = (SELECT MAX(SEQ) FROM RSUMTMPWCT
						 	  WHERE SUBLOT_ID = :RSUMTMPWCT_N.SUBLOT_ID
							    AND LOT_ID = :RSUMTMPWCT_N.LOT_ID
							    AND NO_WAFER_FLAG = :RSUMTMPWCT_N.NO_WAFER_FLAG
							    AND PERIOD_TYPE = :RSUMTMPWCT_N.PERIOD_TYPE
							    AND PERIOD_NAME = :RSUMTMPWCT_N.PERIOD_NAME)
                ORDER BY SUBLOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN RPT_RSUMTMPWCT_CUR_4;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rsumtmpwct", sel_type);
}


