/* Initialize Function */
void RPT_init_rsumtmpwct(struct RSUMTMPWCT_TAG *RSUMTMPWCT)
{
    /* memset by Space */
    memset(RSUMTMPWCT, ' ', sizeof(struct RSUMTMPWCT_TAG));
    
    RSUMTMPWCT->HIST_SEQ = 0;
    RSUMTMPWCT->WAITING_TIME = 0;
    RSUMTMPWCT->PROCESS_TIME = 0;
    RSUMTMPWCT->STORE_TIME = 0;
}


/* Add Null Function */
void RPT_add_null_rsumtmpwct(struct RSUMTMPWCT_N_TAG *RSUMTMPWCT_N, struct RSUMTMPWCT_TAG *RSUMTMPWCT)
{
    /* memset by NULL */
    memset(RSUMTMPWCT_N, '\0', sizeof(struct RSUMTMPWCT_N_TAG));
    
    MEMCPY_AN(RSUMTMPWCT_N->SUBLOT_ID, RSUMTMPWCT->SUBLOT_ID, sizeof(RSUMTMPWCT->SUBLOT_ID));
    RSUMTMPWCT_N->HIST_SEQ = RSUMTMPWCT->HIST_SEQ;
    RSUMTMPWCT_N->PERIOD_TYPE[0] = RSUMTMPWCT->PERIOD_TYPE;
    MEMCPY_AN(RSUMTMPWCT_N->PERIOD_NAME, RSUMTMPWCT->PERIOD_NAME, sizeof(RSUMTMPWCT->PERIOD_NAME));
    RSUMTMPWCT_N->SEQ = RSUMTMPWCT->SEQ;
    RSUMTMPWCT_N->REWORK_FLAG[0] = RSUMTMPWCT->REWORK_FLAG;
    RSUMTMPWCT_N->NO_WAFER_FLAG[0] = RSUMTMPWCT->NO_WAFER_FLAG;
    MEMCPY_AN(RSUMTMPWCT_N->LOT_ID, RSUMTMPWCT->LOT_ID, sizeof(RSUMTMPWCT->LOT_ID));
    MEMCPY_AN(RSUMTMPWCT_N->FACTORY, RSUMTMPWCT->FACTORY, sizeof(RSUMTMPWCT->FACTORY));
    MEMCPY_AN(RSUMTMPWCT_N->OPER, RSUMTMPWCT->OPER, sizeof(RSUMTMPWCT->OPER));
    RSUMTMPWCT_N->WAITING_TIME = RSUMTMPWCT->WAITING_TIME;
    RSUMTMPWCT_N->PROCESS_TIME = RSUMTMPWCT->PROCESS_TIME;
    RSUMTMPWCT_N->STORE_TIME = RSUMTMPWCT->STORE_TIME;
    MEMCPY_AN(RSUMTMPWCT_N->CREATE_USER_ID, RSUMTMPWCT->CREATE_USER_ID, sizeof(RSUMTMPWCT->CREATE_USER_ID));
    MEMCPY_AN(RSUMTMPWCT_N->CREATE_TIME, RSUMTMPWCT->CREATE_TIME, sizeof(RSUMTMPWCT->CREATE_TIME));
    MEMCPY_AN(RSUMTMPWCT_N->UPDATE_USER_ID, RSUMTMPWCT->UPDATE_USER_ID, sizeof(RSUMTMPWCT->UPDATE_USER_ID));
    MEMCPY_AN(RSUMTMPWCT_N->UPDATE_TIME, RSUMTMPWCT->UPDATE_TIME, sizeof(RSUMTMPWCT->UPDATE_TIME));
}


/* Del Null Function */
void RPT_del_null_rsumtmpwct(struct RSUMTMPWCT_N_TAG *RSUMTMPWCT_N, struct RSUMTMPWCT_TAG *RSUMTMPWCT)
{
    MEMCPY_DN(RSUMTMPWCT->SUBLOT_ID, RSUMTMPWCT_N->SUBLOT_ID, sizeof(RSUMTMPWCT->SUBLOT_ID));
    RSUMTMPWCT->HIST_SEQ = RSUMTMPWCT_N->HIST_SEQ;
    RSUMTMPWCT->PERIOD_TYPE = RSUMTMPWCT_N->PERIOD_TYPE[0];
    MEMCPY_DN(RSUMTMPWCT->PERIOD_NAME, RSUMTMPWCT_N->PERIOD_NAME, sizeof(RSUMTMPWCT->PERIOD_NAME));
    RSUMTMPWCT->SEQ = RSUMTMPWCT_N->SEQ;
    RSUMTMPWCT->REWORK_FLAG = RSUMTMPWCT_N->REWORK_FLAG[0];
    RSUMTMPWCT->NO_WAFER_FLAG = RSUMTMPWCT_N->NO_WAFER_FLAG[0];
    MEMCPY_DN(RSUMTMPWCT->LOT_ID, RSUMTMPWCT_N->LOT_ID, sizeof(RSUMTMPWCT->LOT_ID));
    MEMCPY_DN(RSUMTMPWCT->FACTORY, RSUMTMPWCT_N->FACTORY, sizeof(RSUMTMPWCT->FACTORY));
    MEMCPY_DN(RSUMTMPWCT->OPER, RSUMTMPWCT_N->OPER, sizeof(RSUMTMPWCT->OPER));
    RSUMTMPWCT->WAITING_TIME = RSUMTMPWCT_N->WAITING_TIME;
    RSUMTMPWCT->PROCESS_TIME = RSUMTMPWCT_N->PROCESS_TIME;
    RSUMTMPWCT->STORE_TIME = RSUMTMPWCT_N->STORE_TIME;
    MEMCPY_DN(RSUMTMPWCT->CREATE_USER_ID, RSUMTMPWCT_N->CREATE_USER_ID, sizeof(RSUMTMPWCT->CREATE_USER_ID));
    MEMCPY_DN(RSUMTMPWCT->CREATE_TIME, RSUMTMPWCT_N->CREATE_TIME, sizeof(RSUMTMPWCT->CREATE_TIME));
    MEMCPY_DN(RSUMTMPWCT->UPDATE_USER_ID, RSUMTMPWCT_N->UPDATE_USER_ID, sizeof(RSUMTMPWCT->UPDATE_USER_ID));
    MEMCPY_DN(RSUMTMPWCT->UPDATE_TIME, RSUMTMPWCT_N->UPDATE_TIME, sizeof(RSUMTMPWCT->UPDATE_TIME));
}


