/* SQL INSERT Function */
void RPT_insert_rsumtmpwct_lot(char *lot_id, int seq, struct RSUMTMPWCT_TAG *RSUMTMPWCT)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RSUMTMPWCT_N_TAG RSUMTMPWCT_N;
    	char lot_id_n[26];
        int seq_n;
    EXEC SQL END DECLARE SECTION;

	memset(lot_id_n, '\0', sizeof(lot_id_n));
    MEMCPY_AN(lot_id_n, lot_id, sizeof(lot_id_n) -1 );
    seq_n = seq;
    
    RPT_add_null_rsumtmpwct(&RSUMTMPWCT_N, RSUMTMPWCT);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RSUMTMPWCT
        SELECT 
			LOT_ID,
			HIST_SEQ,
			PERIOD_TYPE,
			PERIOD_NAME,
			:seq_n,
			REWORK_FLAG,
			NO_WAFER_FLAG,
			:lot_id_n,
			FACTORY,
			OPER,
			WAITING_TIME,
			PROCESS_TIME,
			STORE_TIME,
			CREATE_USER_ID,
			CREATE_TIME,
			UPDATE_USER_ID,
			UPDATE_TIME
          FROM RSUMTMPWCT
         WHERE LOT_ID = :RSUMTMPWCT_N.LOT_ID
           AND PERIOD_TYPE = :RSUMTMPWCT_N.PERIOD_TYPE
           AND PERIOD_NAME = :RSUMTMPWCT_N.PERIOD_NAME
           AND NO_WAFER_FLAG = 'Y'
           AND SEQ = (SELECT NVL(MAX(SEQ), 0)
					   FROM RSUMTMPWCT
					  WHERE LOT_ID = :RSUMTMPWCT_N.LOT_ID
						AND PERIOD_TYPE = :RSUMTMPWCT_N.PERIOD_TYPE
						AND PERIOD_NAME = :RSUMTMPWCT_N.PERIOD_NAME);
}

