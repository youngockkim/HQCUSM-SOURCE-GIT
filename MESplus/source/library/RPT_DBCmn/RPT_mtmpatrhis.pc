            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_mtmpatrhis(&MTMPATRHIS_N, MTMPATRHIS);
    }
    DB_stop_query_timer("RPT_fetch_mtmpatrhis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void RPT_close_mtmpatrhis(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_MTMPATRHIS_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_mtmpatrhis", sel_type);
}


/* Initialize Function */
void RPT_init_mtmpatrhis(struct MTMPATRHIS_TAG *MTMPATRHIS)
{
    /* memset by Space */
    memset(MTMPATRHIS, ' ', sizeof(struct MTMPATRHIS_TAG));
    
    MTMPATRHIS->TABLE_UPDATE_SEQ = 0;
    MTMPATRHIS->HIST_SEQ = 0;
    MTMPATRHIS->KEY_HIST_SEQ = 0;
    MTMPATRHIS->PREV_ACTIVE_HIST_SEQ = 0;
    MTMPATRHIS->HIST_START_SEQ = 0;
}


/* Add Null Function */
void RPT_add_null_mtmpatrhis(struct MTMPATRHIS_N_TAG *MTMPATRHIS_N, struct MTMPATRHIS_TAG *MTMPATRHIS)
{
    /* memset by NULL */
    memset(MTMPATRHIS_N, '\0', sizeof(struct MTMPATRHIS_N_TAG));
    
    MTMPATRHIS_N->TABLE_UPDATE_SEQ = MTMPATRHIS->TABLE_UPDATE_SEQ;
    MEMCPY_AN(MTMPATRHIS_N->CM_KEY_1, MTMPATRHIS->CM_KEY_1, sizeof(MTMPATRHIS->CM_KEY_1));
    MEMCPY_AN(MTMPATRHIS_N->CM_KEY_2, MTMPATRHIS->CM_KEY_2, sizeof(MTMPATRHIS->CM_KEY_2));
    MEMCPY_AN(MTMPATRHIS_N->CM_KEY_3, MTMPATRHIS->CM_KEY_3, sizeof(MTMPATRHIS->CM_KEY_3));
    MEMCPY_AN(MTMPATRHIS_N->CM_KEY_4, MTMPATRHIS->CM_KEY_4, sizeof(MTMPATRHIS->CM_KEY_4));
    MEMCPY_AN(MTMPATRHIS_N->CM_KEY_5, MTMPATRHIS->CM_KEY_5, sizeof(MTMPATRHIS->CM_KEY_5));
    MEMCPY_AN(MTMPATRHIS_N->FACTORY, MTMPATRHIS->FACTORY, sizeof(MTMPATRHIS->FACTORY));
    MEMCPY_AN(MTMPATRHIS_N->ATTR_TYPE, MTMPATRHIS->ATTR_TYPE, sizeof(MTMPATRHIS->ATTR_TYPE));
    MEMCPY_AN(MTMPATRHIS_N->ATTR_NAME, MTMPATRHIS->ATTR_NAME, sizeof(MTMPATRHIS->ATTR_NAME));
    MEMCPY_AN(MTMPATRHIS_N->ATTR_KEY, MTMPATRHIS->ATTR_KEY, sizeof(MTMPATRHIS->ATTR_KEY));
    MTMPATRHIS_N->HIST_SEQ = MTMPATRHIS->HIST_SEQ;
    MEMCPY_AN(MTMPATRHIS_N->ATTR_OLD_VALUE, MTMPATRHIS->ATTR_OLD_VALUE, sizeof(MTMPATRHIS->ATTR_OLD_VALUE));
    MEMCPY_AN(MTMPATRHIS_N->ATTR_NEW_VALUE, MTMPATRHIS->ATTR_NEW_VALUE, sizeof(MTMPATRHIS->ATTR_NEW_VALUE));
    MTMPATRHIS_N->NULL_FLAG[0] = MTMPATRHIS->NULL_FLAG;
    MEMCPY_AN(MTMPATRHIS_N->TRAN_TIME, MTMPATRHIS->TRAN_TIME, sizeof(MTMPATRHIS->TRAN_TIME));
    MEMCPY_AN(MTMPATRHIS_N->SYS_TRAN_TIME, MTMPATRHIS->SYS_TRAN_TIME, sizeof(MTMPATRHIS->SYS_TRAN_TIME));
    MTMPATRHIS_N->KEY_HIST_SEQ = MTMPATRHIS->KEY_HIST_SEQ;
    MTMPATRHIS_N->PREV_ACTIVE_HIST_SEQ = MTMPATRHIS->PREV_ACTIVE_HIST_SEQ;
    MTMPATRHIS_N->HIST_START_SEQ = MTMPATRHIS->HIST_START_SEQ;
    MTMPATRHIS_N->HIST_DEL_FLAG[0] = MTMPATRHIS->HIST_DEL_FLAG;
    MEMCPY_AN(MTMPATRHIS_N->HIST_DEL_TIME, MTMPATRHIS->HIST_DEL_TIME, sizeof(MTMPATRHIS->HIST_DEL_TIME));
    MEMCPY_AN(MTMPATRHIS_N->HIST_DEL_USER_ID, MTMPATRHIS->HIST_DEL_USER_ID, sizeof(MTMPATRHIS->HIST_DEL_USER_ID));
    MEMCPY_AN(MTMPATRHIS_N->HIST_DEL_COMMENT, MTMPATRHIS->HIST_DEL_COMMENT, sizeof(MTMPATRHIS->HIST_DEL_COMMENT));
    MTMPATRHIS_N->PROCESS_FLAG[0] = MTMPATRHIS->PROCESS_FLAG;
	MEMCPY_AN(MTMPATRHIS_N->TRAN_USER_ID, MTMPATRHIS->TRAN_USER_ID, sizeof(MTMPATRHIS->TRAN_USER_ID));
}


/* Del Null Function */
void RPT_del_null_mtmpatrhis(struct MTMPATRHIS_N_TAG *MTMPATRHIS_N, struct MTMPATRHIS_TAG *MTMPATRHIS)
{
    MTMPATRHIS->TABLE_UPDATE_SEQ = MTMPATRHIS_N->TABLE_UPDATE_SEQ;
    MEMCPY_DN(MTMPATRHIS->CM_KEY_1, MTMPATRHIS_N->CM_KEY_1, sizeof(MTMPATRHIS->CM_KEY_1));
    MEMCPY_DN(MTMPATRHIS->CM_KEY_2, MTMPATRHIS_N->CM_KEY_2, sizeof(MTMPATRHIS->CM_KEY_2));
    MEMCPY_DN(MTMPATRHIS->CM_KEY_3, MTMPATRHIS_N->CM_KEY_3, sizeof(MTMPATRHIS->CM_KEY_3));
    MEMCPY_DN(MTMPATRHIS->CM_KEY_4, MTMPATRHIS_N->CM_KEY_4, sizeof(MTMPATRHIS->CM_KEY_4));
    MEMCPY_DN(MTMPATRHIS->CM_KEY_5, MTMPATRHIS_N->CM_KEY_5, sizeof(MTMPATRHIS->CM_KEY_5));
    MEMCPY_DN(MTMPATRHIS->FACTORY, MTMPATRHIS_N->FACTORY, sizeof(MTMPATRHIS->FACTORY));
    MEMCPY_DN(MTMPATRHIS->ATTR_TYPE, MTMPATRHIS_N->ATTR_TYPE, sizeof(MTMPATRHIS->ATTR_TYPE));
    MEMCPY_DN(MTMPATRHIS->ATTR_NAME, MTMPATRHIS_N->ATTR_NAME, sizeof(MTMPATRHIS->ATTR_NAME));
    MEMCPY_DN(MTMPATRHIS->ATTR_KEY, MTMPATRHIS_N->ATTR_KEY, sizeof(MTMPATRHIS->ATTR_KEY));
    MTMPATRHIS->HIST_SEQ = MTMPATRHIS_N->HIST_SEQ;
    MEMCPY_DN(MTMPATRHIS->ATTR_OLD_VALUE, MTMPATRHIS_N->ATTR_OLD_VALUE, sizeof(MTMPATRHIS->ATTR_OLD_VALUE));
    MEMCPY_DN(MTMPATRHIS->ATTR_NEW_VALUE, MTMPATRHIS_N->ATTR_NEW_VALUE, sizeof(MTMPATRHIS->ATTR_NEW_VALUE));
    MTMPATRHIS->NULL_FLAG = MTMPATRHIS_N->NULL_FLAG[0];
    MEMCPY_DN(MTMPATRHIS->TRAN_TIME, MTMPATRHIS_N->TRAN_TIME, sizeof(MTMPATRHIS->TRAN_TIME));
    MEMCPY_DN(MTMPATRHIS->SYS_TRAN_TIME, MTMPATRHIS_N->SYS_TRAN_TIME, sizeof(MTMPATRHIS->SYS_TRAN_TIME));
    MTMPATRHIS->KEY_HIST_SEQ = MTMPATRHIS_N->KEY_HIST_SEQ;
    MTMPATRHIS->PREV_ACTIVE_HIST_SEQ = MTMPATRHIS_N->PREV_ACTIVE_HIST_SEQ;
    MTMPATRHIS->HIST_START_SEQ = MTMPATRHIS_N->HIST_START_SEQ;
    MTMPATRHIS->HIST_DEL_FLAG = MTMPATRHIS_N->HIST_DEL_FLAG[0];
    MEMCPY_DN(MTMPATRHIS->HIST_DEL_TIME, MTMPATRHIS_N->HIST_DEL_TIME, sizeof(MTMPATRHIS->HIST_DEL_TIME));
    MEMCPY_DN(MTMPATRHIS->HIST_DEL_USER_ID, MTMPATRHIS_N->HIST_DEL_USER_ID, sizeof(MTMPATRHIS->HIST_DEL_USER_ID));
    MEMCPY_DN(MTMPATRHIS->HIST_DEL_COMMENT, MTMPATRHIS_N->HIST_DEL_COMMENT, sizeof(MTMPATRHIS->HIST_DEL_COMMENT));
    MTMPATRHIS->PROCESS_FLAG = MTMPATRHIS_N->PROCESS_FLAG[0];
	MEMCPY_DN(MTMPATRHIS->TRAN_USER_ID, MTMPATRHIS_N->TRAN_USER_ID, sizeof(MTMPATRHIS->TRAN_USER_ID));
}


