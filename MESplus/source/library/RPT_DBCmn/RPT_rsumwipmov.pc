                    :RSUMWIPMOV_N.S2_QUEUE_TIME,
                    :RSUMWIPMOV_N.S3_QUEUE_TIME,
                    :RSUMWIPMOV_N.S4_QUEUE_TIME,
                    :RSUMWIPMOV_N.S1_HOLD_TIME,
                    :RSUMWIPMOV_N.S2_HOLD_TIME,
                    :RSUMWIPMOV_N.S3_HOLD_TIME,
                    :RSUMWIPMOV_N.S4_HOLD_TIME,
