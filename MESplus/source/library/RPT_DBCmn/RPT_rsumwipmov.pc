                    :RSUMWIPMOV_N.S2_PROC_TIME,
                    :RSUMWIPMOV_N.S3_PROC_TIME,
                    :RSUMWIPMOV_N.S4_PROC_TIME,
                    :RSUMWIPMOV_N.S1_PULL_TIME,
                    :RSUMWIPMOV_N.S2_PULL_TIME,
                    :RSUMWIPMOV_N.S3_PULL_TIME,
                    :RSUMWIPMOV_N.S4_PULL_TIME
                FROM RSUMWIPMOV
                WHERE WORK_DATE = :RSUMWIPMOV_N.WORK_DATE
                    AND FACTORY = :RSUMWIPMOV_N.FACTORY
                    AND MAT_ID = :RSUMWIPMOV_N.MAT_ID
                    AND MAT_VER = :RSUMWIPMOV_N.MAT_VER
                    AND FLOW = :RSUMWIPMOV_N.FLOW
                    AND FLOW_SEQ_NUM = :RSUMWIPMOV_N.FLOW_SEQ_NUM
                    AND OPER = :RSUMWIPMOV_N.OPER
                    AND LOT_TYPE = :RSUMWIPMOV_N.LOT_TYPE
                    AND ORDER_ID = :RSUMWIPMOV_N.ORDER_ID
                    AND CM_KEY_1 = :RSUMWIPMOV_N.CM_KEY_1
                    AND CM_KEY_2 = :RSUMWIPMOV_N.CM_KEY_2
                    AND CM_KEY_3 = :RSUMWIPMOV_N.CM_KEY_3
                    AND CM_KEY_4 = :RSUMWIPMOV_N.CM_KEY_4
                    AND CM_KEY_5 = :RSUMWIPMOV_N.CM_KEY_5;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:
            EXEC SQL SELECT TRIM(TO_CHAR(PLAN_YEAR))||LPAD(PLAN_MONTH,2,'0'),
							TRIM(TO_CHAR(PLAN_YEAR))||LPAD(PLAN_WEEK,2,'0'),
							LPAD(JULIAN_DAY,3,'0') 
                INTO :RSUMWIPMOV_N.WORK_MONTH,
					 :RSUMWIPMOV_N.WORK_WEEK,
					 :RSUMWIPMOV_N.WORK_DAYS
                FROM MWIPCALDEF
                WHERE CALENDAR_ID = :RSUMWIPMOV_N.FACTORY
                  AND SYS_YEAR = TO_NUMBER(SUBSTR(:RSUMWIPMOV_N.WORK_DATE,1,4))
                  AND SYS_MONTH = TO_NUMBER(SUBSTR(:RSUMWIPMOV_N.WORK_DATE,5,2))
                  AND SYS_DAY = TO_NUMBER(SUBSTR(:RSUMWIPMOV_N.WORK_DATE,7,2));
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rsumwipmov(&RSUMWIPMOV_N, RSUMWIPMOV);
    }
    DB_stop_query_timer("RPT_select_rsumwipmov", sel_type);
}


