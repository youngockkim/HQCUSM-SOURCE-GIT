/* SQL UPDATE Function */
void RPT_update_rsumwipmov(int sel_type, struct RSUMWIPMOV_TAG *RSUMWIPMOV)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RSUMWIPMOV_N_TAG RSUMWIPMOV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rsumwipmov(&RSUMWIPMOV_N, RSUMWIPMOV);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE RSUMWIPMOV SET
                    WORK_MONTH = :RSUMWIPMOV_N.WORK_MONTH,
                    WORK_WEEK = :RSUMWIPMOV_N.WORK_WEEK,
                    WORK_DAYS = :RSUMWIPMOV_N.WORK_DAYS,
                    WORK_DAY_OF_WEEK = :RSUMWIPMOV_N.WORK_DAY_OF_WEEK,
                    S1_OPER_IN_LOT = :RSUMWIPMOV_N.S1_OPER_IN_LOT,
                    S2_OPER_IN_LOT = :RSUMWIPMOV_N.S2_OPER_IN_LOT,
                    S3_OPER_IN_LOT = :RSUMWIPMOV_N.S3_OPER_IN_LOT,
                    S4_OPER_IN_LOT = :RSUMWIPMOV_N.S4_OPER_IN_LOT,
                    S1_OPER_IN_QTY_1 = :RSUMWIPMOV_N.S1_OPER_IN_QTY_1,
                    S2_OPER_IN_QTY_1 = :RSUMWIPMOV_N.S2_OPER_IN_QTY_1,
                    S3_OPER_IN_QTY_1 = :RSUMWIPMOV_N.S3_OPER_IN_QTY_1,
                    S4_OPER_IN_QTY_1 = :RSUMWIPMOV_N.S4_OPER_IN_QTY_1,
                    S1_OPER_IN_QTY_2 = :RSUMWIPMOV_N.S1_OPER_IN_QTY_2,
                    S2_OPER_IN_QTY_2 = :RSUMWIPMOV_N.S2_OPER_IN_QTY_2,
                    S3_OPER_IN_QTY_2 = :RSUMWIPMOV_N.S3_OPER_IN_QTY_2,
                    S4_OPER_IN_QTY_2 = :RSUMWIPMOV_N.S4_OPER_IN_QTY_2,
                    S1_OPER_IN_QTY_3 = :RSUMWIPMOV_N.S1_OPER_IN_QTY_3,
                    S2_OPER_IN_QTY_3 = :RSUMWIPMOV_N.S2_OPER_IN_QTY_3,
                    S3_OPER_IN_QTY_3 = :RSUMWIPMOV_N.S3_OPER_IN_QTY_3,
                    S4_OPER_IN_QTY_3 = :RSUMWIPMOV_N.S4_OPER_IN_QTY_3,
                    S1_OPER_IN_RWK_LOT = :RSUMWIPMOV_N.S1_OPER_IN_RWK_LOT,
