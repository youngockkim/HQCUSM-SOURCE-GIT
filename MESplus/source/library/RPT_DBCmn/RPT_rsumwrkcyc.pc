    RSUMWRKCYC->CYCLETIME_WORKCELL.IS_NULL = 'Y';
    RSUMWRKCYC->OPER.IS_NULL = 'Y';
    RSUMWRKCYC->RWK_FLAG.IS_NULL = 'Y';
    RSUMWRKCYC->OWNER_CODE.IS_NULL = 'Y';
    RSUMWRKCYC->MAT_ID.IS_NULL = 'Y';
    RSUMWRKCYC->MAT_VER.VALUE = 0;
    RSUMWRKCYC->MAT_VER.IS_NULL = 'Y';
    RSUMWRKCYC->REPORTABLE_YN.IS_NULL = 'Y';
    RSUMWRKCYC->WC_START_TIME.IS_NULL = 'Y';
    RSUMWRKCYC->WC_CYCLETIME.VALUE = 0;
    RSUMWRKCYC->WC_CYCLETIME.IS_NULL = 'Y';
    RSUMWRKCYC->WC_PROC_TIME.VALUE = 0;
    RSUMWRKCYC->WC_PROC_TIME.IS_NULL = 'Y';
    RSUMWRKCYC->WC_WAIT_TIME.VALUE = 0;
    RSUMWRKCYC->WC_WAIT_TIME.IS_NULL = 'Y';
    RSUMWRKCYC->WC_STORE_TIME.VALUE = 0;
    RSUMWRKCYC->WC_STORE_TIME.IS_NULL = 'Y';
    RSUMWRKCYC->CYCLETIME_WORKCELL_NEW.IS_NULL = 'Y';
    RSUMWRKCYC->FACTORY.IS_NULL = 'Y';
    RSUMWRKCYC->DATE_CREATE.IS_NULL = 'Y';
    RSUMWRKCYC->DATE_UPDATE.IS_NULL = 'Y';
}


