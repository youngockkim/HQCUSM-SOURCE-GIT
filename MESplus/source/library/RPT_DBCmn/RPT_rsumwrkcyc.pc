                :RSUMWRKCYC_N.REPORTABLE_YN.IS_NULL, :RSUMWRKCYC_N.REPORTABLE_YN.VALUE,
                :RSUMWRKCYC_N.WC_START_TIME.IS_NULL, :RSUMWRKCYC_N.WC_START_TIME.VALUE,
                :RSUMWRKCYC_N.WC_CYCLETIME.IS_NULL, :RSUMWRKCYC_N.WC_CYCLETIME.VALUE,
                :RSUMWRKCYC_N.WC_PROC_TIME.IS_NULL, :RSUMWRKCYC_N.WC_PROC_TIME.VALUE,
                :RSUMWRKCYC_N.WC_WAIT_TIME.IS_NULL, :RSUMWRKCYC_N.WC_WAIT_TIME.VALUE,
                :RSUMWRKCYC_N.WC_STORE_TIME.IS_NULL, :RSUMWRKCYC_N.WC_STORE_TIME.VALUE,
                :RSUMWRKCYC_N.CYCLETIME_WORKCELL_NEW.IS_NULL, :RSUMWRKCYC_N.CYCLETIME_WORKCELL_NEW.VALUE,
                :RSUMWRKCYC_N.FACTORY.IS_NULL, :RSUMWRKCYC_N.FACTORY.VALUE,
                :RSUMWRKCYC_N.DATE_CREATE.IS_NULL, :RSUMWRKCYC_N.DATE_CREATE.VALUE,
                :RSUMWRKCYC_N.DATE_UPDATE.IS_NULL, :RSUMWRKCYC_N.DATE_UPDATE.VALUE;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rsumwrkcyc(&RSUMWRKCYC_N, RSUMWRKCYC);
    }
    DB_stop_query_timer("RPT_fetch_rsumwrkcyc", sel_type);
}


