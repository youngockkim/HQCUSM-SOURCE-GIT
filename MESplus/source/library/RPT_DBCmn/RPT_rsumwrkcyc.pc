    	struct RSUMWRKCYC_N_TAG RSUMWRKCYC_N;
    	struct RSUMWRKCYC_TAG   RSUMWRKCYC_S;
    	char   sql[10000];
    	char   ts[1000];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rsumwrkcyc(&RSUMWRKCYC_N, RSUMWRKCYC);
    DB_error_code = 0;
    memset(sql, 0x00, sizeof(sql));
    memset(ts, 0x00, sizeof(ts));

    switch(sel_type)
    {
        case 1:
            RPT_init_rsumwrkcyc(&RSUMWRKCYC_S);
            memcpy(RSUMWRKCYC_S.LOT_ID, RSUMWRKCYC->LOT_ID, sizeof(RSUMWRKCYC_S.LOT_ID));
            RSUMWRKCYC_S.HIST_SEQ = RSUMWRKCYC->HIST_SEQ;
            RPT_select_rsumwrkcyc(1, &RSUMWRKCYC_S);
            if(DB_error_code != DB_SUCCESS) break;

            make_valid_quote(ts, RSUMWRKCYC_N.LOT_ID);
            sprintf(sql, "UPDATE RSUMWRKCYC SET LOT_ID='%s'", ts);

            if(RSUMWRKCYC->TRAN_TIME.IS_NULL == RSUMWRKCYC_S.TRAN_TIME.IS_NULL) {
                if(RSUMWRKCYC->TRAN_TIME.IS_NULL != 'Y') {
                    if(memcmp(RSUMWRKCYC->TRAN_TIME.VALUE, RSUMWRKCYC_S.TRAN_TIME.VALUE, sizeof(RSUMWRKCYC->TRAN_TIME.VALUE)) != 0) {
                        make_valid_quote(ts, RSUMWRKCYC_N.TRAN_TIME.VALUE);
                        sprintf(sql + strlen(sql), ", TRAN_TIME = TO_DATE('%s', 'YYYYMMDDHH24MISS')", ts);
                    }
                }
            } else {
                if(RSUMWRKCYC->TRAN_TIME.IS_NULL == 'Y') {
                    sprintf(sql + strlen(sql), ", TRAN_TIME = NULL");
                } else {
                    make_valid_quote(ts, RSUMWRKCYC_N.TRAN_TIME.VALUE);
                    sprintf(sql + strlen(sql), ", TRAN_TIME = TO_DATE('%s', 'YYYYMMDDHH24MISS')", ts);
                }
