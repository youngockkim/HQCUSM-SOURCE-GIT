/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rsumwrkcyc(int sel_type, struct RSUMWRKCYC_TAG *RSUMWRKCYC)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RSUMWRKCYC_N_TAG RSUMWRKCYC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rsumwrkcyc(&RSUMWRKCYC_N, RSUMWRKCYC);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RSUMWRKCYC_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(PARENT_LOT_ID, NULL, 'Y', ' '), NVL(PARENT_LOT_ID, ' '),
                    DECODE(CYCLETIME_WORKCELL, NULL, 'Y', ' '), NVL(CYCLETIME_WORKCELL, ' '),
                    DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
                    DECODE(RWK_FLAG, NULL, 'Y', ' '), NVL(RWK_FLAG, ' '),
                    DECODE(OWNER_CODE, NULL, 'Y', ' '), NVL(OWNER_CODE, ' '),
                    DECODE(MAT_ID, NULL, 'Y', ' '), NVL(MAT_ID, ' '),
                    DECODE(MAT_VER, NULL, 'Y', ' '), NVL(MAT_VER, '0'),
                    DECODE(REPORTABLE_YN, NULL, 'Y', ' '), NVL(REPORTABLE_YN, ' '),
                    DECODE(WC_START_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(WC_START_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(WC_CYCLETIME, NULL, 'Y', ' '), NVL(WC_CYCLETIME, '0'),
                    DECODE(WC_PROC_TIME, NULL, 'Y', ' '), NVL(WC_PROC_TIME, '0'),
                    DECODE(WC_WAIT_TIME, NULL, 'Y', ' '), NVL(WC_WAIT_TIME, '0'),
                    DECODE(WC_STORE_TIME, NULL, 'Y', ' '), NVL(WC_STORE_TIME, '0'),
                    DECODE(CYCLETIME_WORKCELL_NEW, NULL, 'Y', ' '), NVL(CYCLETIME_WORKCELL_NEW, ' '),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '),
                    DECODE(DATE_CREATE, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_CREATE, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(DATE_UPDATE, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_UPDATE, 'YYYYMMDDHH24MISS'), ' ')
                FROM RSUMWRKCYC
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN RPT_RSUMWRKCYC_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rsumwrkcyc", sel_type);
}


/* SQL CURSOR FETCH Function */
void RPT_fetch_rsumwrkcyc(int sel_type, struct RSUMWRKCYC_TAG *RSUMWRKCYC)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RSUMWRKCYC_N_TAG RSUMWRKCYC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_RSUMWRKCYC_CUR_1 INTO 
                :RSUMWRKCYC_N.LOT_ID,
                :RSUMWRKCYC_N.HIST_SEQ,
                :RSUMWRKCYC_N.TRAN_TIME.IS_NULL, :RSUMWRKCYC_N.TRAN_TIME.VALUE,
                :RSUMWRKCYC_N.PARENT_LOT_ID.IS_NULL, :RSUMWRKCYC_N.PARENT_LOT_ID.VALUE,
