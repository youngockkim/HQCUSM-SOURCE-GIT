                    :RRASRESHIS_N.TRAN_COMMENT.IS_NULL, :RRASRESHIS_N.TRAN_COMMENT.VALUE, 
                    :RRASRESHIS_N.LAST_DOWN_TIME.IS_NULL, :RRASRESHIS_N.LAST_DOWN_TIME.VALUE, 
                    :RRASRESHIS_N.LAST_DOWN_HIST_SEQ.IS_NULL, :RRASRESHIS_N.LAST_DOWN_HIST_SEQ.VALUE, 
