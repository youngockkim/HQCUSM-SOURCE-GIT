                    EDC_DETAILS, 
                    REPAIR_PRIOR
         ) 
        VALUES (
                    :RRASRESHIS_N.FACTORY,
                    :RRASRESHIS_N.RES_ID,
                    :RRASRESHIS_N.HIST_SEQ,
                    DECODE(:RRASRESHIS_N.EVENT_ID.IS_NULL, 'Y', NULL, :RRASRESHIS_N.EVENT_ID.VALUE),
