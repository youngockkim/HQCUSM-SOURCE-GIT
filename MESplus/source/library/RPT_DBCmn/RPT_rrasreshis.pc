                    :RRASRESHIS_N.HIST_DEL_TIME.IS_NULL, :RRASRESHIS_N.HIST_DEL_TIME.VALUE, 
                    :RRASRESHIS_N.HIST_DEL_USER_ID.IS_NULL, :RRASRESHIS_N.HIST_DEL_USER_ID.VALUE, 
                    :RRASRESHIS_N.HIST_DEL_COMMENT.IS_NULL, :RRASRESHIS_N.HIST_DEL_COMMENT.VALUE, 
                    :RRASRESHIS_N.END_DATE.IS_NULL, :RRASRESHIS_N.END_DATE.VALUE, 
                    :RRASRESHIS_N.EDC_DETAILS.IS_NULL, :RRASRESHIS_N.EDC_DETAILS.VALUE, 
                    :RRASRESHIS_N.REPAIR_PRIOR.IS_NULL, :RRASRESHIS_N.REPAIR_PRIOR.VALUE 
                FROM RRASRESHIS
                WHERE FACTORY = :RRASRESHIS_N.FACTORY
                    AND RES_ID = :RRASRESHIS_N.RES_ID
                    AND HIST_SEQ = (SELECT MAX(HIST_SEQ) FROM RRASRESHIS 
									 WHERE FACTORY = :RRASRESHIS_N.FACTORY
									   AND RES_ID = :RRASRESHIS_N.RES_ID
									   AND HIST_SEQ < :RRASRESHIS_N.HIST_SEQ
									   AND HIST_DEL_FLAG = 'N');
            break;
            
        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rrasreshis(&RRASRESHIS_N, RRASRESHIS);
    }
    DB_stop_query_timer("RPT_select_rrasreshis", sel_type);
}


/* SQL SELECT_FOR_UPDATE Function */
void RPT_select_rrasreshis_for_update(int sel_type, struct RRASRESHIS_TAG *RRASRESHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASRESHIS_N_TAG RRASRESHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrasreshis(&RRASRESHIS_N, RRASRESHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
