/* SQL SELECT - INSERT Function */
void RPT_select_insert_rrasreshis(struct RRASRESHIS_TAG *RRASRESHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASRESHIS_N_TAG RRASRESHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrasreshis(&RRASRESHIS_N, RRASRESHIS);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RRASRESHIS
		SELECT
			DECODE(TRIM(A.FACTORY), '', NULL, A.FACTORY),  
			DECODE(TRIM(A.RES_ID), '', NULL, A.RES_ID),  
			DECODE(TRIM(A.HIST_SEQ), '', NULL, A.HIST_SEQ),  
			DECODE(TRIM(A.EVENT_ID), '', NULL, A.EVENT_ID),  
			DECODE(TRIM(A.TRAN_TIME), '', NULL, TO_DATE(A.TRAN_TIME, 'YYYYMMDDHH24MISS')),  
			DECODE(TRIM(A.SYS_TRAN_TIME), '', NULL, TO_DATE(A.SYS_TRAN_TIME, 'YYYYMMDDHH24MISS')),  
			DECODE(TRIM(A.OLD_EVENT_ID), '', NULL, A.OLD_EVENT_ID),  
			DECODE(TRIM(A.OLD_HIST_SEQ), '', NULL, A.OLD_HIST_SEQ),  
			DECODE(TRIM(A.OLD_TRAN_TIME), '', NULL, TO_DATE(A.OLD_TRAN_TIME, 'YYYYMMDDHH24MISS')),  
			DECODE(TRIM(A.OLD_SYS_TRAN_TIME), '', NULL, TO_DATE(A.OLD_SYS_TRAN_TIME, 'YYYYMMDDHH24MISS')),  
			DECODE(TRIM(A.OLD_UP_DOWN_FLAG), '', NULL, A.OLD_UP_DOWN_FLAG),  
			DECODE(TRIM(A.OLD_PRI_STS), '', NULL, A.OLD_PRI_STS),  
			DECODE(TRIM(A.OLD_STS_1), '', NULL, A.OLD_STS_1),     
			DECODE(TRIM(A.OLD_STS_2), '', NULL, A.OLD_STS_2),  
			DECODE(TRIM(A.OLD_STS_3), '', NULL, A.OLD_STS_3),  
			DECODE(TRIM(A.OLD_STS_4), '', NULL, A.OLD_STS_4),  
			DECODE(TRIM(A.OLD_STS_5), '', NULL, A.OLD_STS_5),  
			DECODE(TRIM(A.OLD_STS_6), '', NULL, A.OLD_STS_6),  
			DECODE(TRIM(A.OLD_STS_7), '', NULL, A.OLD_STS_7),  
			DECODE(TRIM(A.OLD_STS_8), '', NULL, A.OLD_STS_8),  
			DECODE(TRIM(A.OLD_STS_9), '', NULL, A.OLD_STS_9),  
			DECODE(TRIM(A.OLD_STS_10), '', NULL, A.OLD_STS_10),  
			DECODE(TRIM(A.NEW_UP_DOWN_FLAG), '', NULL, A.NEW_UP_DOWN_FLAG),  
			DECODE(TRIM(A.NEW_PRI_STS), '', NULL, A.NEW_PRI_STS),  
			DECODE(TRIM(A.NEW_STS_1), '', NULL, A.NEW_STS_1),  
			DECODE(TRIM(A.NEW_STS_2), '', NULL, A.NEW_STS_2),  
			DECODE(TRIM(A.NEW_STS_3), '', NULL, A.NEW_STS_3),  
			DECODE(TRIM(A.NEW_STS_4), '', NULL, A.NEW_STS_4),  
			DECODE(TRIM(A.NEW_STS_5), '', NULL, A.NEW_STS_5),  
			DECODE(TRIM(A.NEW_STS_6), '', NULL, A.NEW_STS_6),  
			DECODE(TRIM(A.NEW_STS_7), '', NULL, A.NEW_STS_7),  
			DECODE(TRIM(A.NEW_STS_8), '', NULL, A.NEW_STS_8),  
			DECODE(TRIM(A.NEW_STS_9), '', NULL, A.NEW_STS_9),  
			DECODE(TRIM(A.NEW_STS_10), '', NULL, A.NEW_STS_10),  
			DECODE(TRIM(A.LOT_ID), '', NULL, A.LOT_ID),  
			DECODE(TRIM(A.SUBLOT_ID), '', NULL, A.SUBLOT_ID),  
			DECODE(TRIM(A.CRR_ID), '', NULL, A.CRR_ID),  
			DECODE(TRIM(A.RES_CTRL_MODE), '', NULL, A.RES_CTRL_MODE),  
			DECODE(TRIM(A.RES_PROC_MODE), '', NULL, A.RES_PROC_MODE),  
			DECODE(TRIM(A.LOT_EXIST_FLAG), '', 'N', A.LOT_EXIST_FLAG),  
			DECODE(TRIM(A.COL_SET_ID), '', NULL, A.COL_SET_ID),  
			DECODE(TRIM(A.COL_SET_VERSION), '', NULL, A.COL_SET_VERSION),  
			DECODE(TRIM(A.TRAN_CMF_1), '', NULL, A.TRAN_CMF_1),  
			DECODE(TRIM(A.TRAN_CMF_2), '', NULL, A.TRAN_CMF_2),  
			DECODE(TRIM(A.TRAN_CMF_3), '', NULL, A.TRAN_CMF_3),  
			DECODE(TRIM(A.TRAN_CMF_4), '', NULL, A.TRAN_CMF_4),  
			DECODE(TRIM(A.TRAN_CMF_5), '', NULL, A.TRAN_CMF_5),  
			DECODE(TRIM(A.TRAN_CMF_6), '', NULL, A.TRAN_CMF_6),  
			DECODE(TRIM(A.TRAN_CMF_7), '', NULL, A.TRAN_CMF_7),  
			DECODE(TRIM(A.TRAN_CMF_8), '', NULL, A.TRAN_CMF_8),  
			DECODE(TRIM(A.TRAN_CMF_9), '', NULL, A.TRAN_CMF_9),  
			DECODE(TRIM(A.TRAN_CMF_10), '', NULL, A.TRAN_CMF_10),  
			DECODE(TRIM(A.TRAN_CMF_11), '', NULL, A.TRAN_CMF_11),  
			DECODE(TRIM(A.TRAN_CMF_12), '', NULL, A.TRAN_CMF_12),  
			DECODE(TRIM(A.TRAN_CMF_13), '', NULL, A.TRAN_CMF_13),  
			DECODE(TRIM(A.TRAN_CMF_14), '', NULL, A.TRAN_CMF_14),  
			DECODE(TRIM(A.TRAN_CMF_15), '', NULL, A.TRAN_CMF_15),  
			DECODE(TRIM(A.TRAN_CMF_16), '', NULL, A.TRAN_CMF_16),  
			DECODE(TRIM(A.TRAN_CMF_17), '', NULL, A.TRAN_CMF_17),  
			DECODE(TRIM(A.TRAN_CMF_18), '', NULL, A.TRAN_CMF_18),  
			DECODE(TRIM(A.TRAN_CMF_19), '', NULL, A.TRAN_CMF_19),  
			DECODE(TRIM(A.TRAN_CMF_20), '', NULL, A.TRAN_CMF_20),  
			DECODE(TRIM(A.TRAN_USER_ID), '', NULL, A.TRAN_USER_ID),  
			DECODE(TRIM(A.TRAN_COMMENT), '', NULL, A.TRAN_COMMENT),  
			DECODE(TRIM(A.LAST_DOWN_TIME), '', NULL, TO_DATE(A.LAST_DOWN_TIME, 'YYYYMMDDHH24MISS')),  
			DECODE(TRIM(A.LAST_DOWN_HIST_SEQ), '', NULL, A.LAST_DOWN_HIST_SEQ),  
			DECODE(TRIM(A.HIST_START_SEQ), '', NULL, A.HIST_START_SEQ),  
			DECODE(TRIM(A.HIST_DEL_FLAG), '', 'N', A.HIST_DEL_FLAG),  
			DECODE(TRIM(A.HIST_DEL_TIME), '', NULL, TO_DATE(A.HIST_DEL_TIME, 'YYYYMMDDHH24MISS')),  
			DECODE(TRIM(A.HIST_DEL_USER_ID), '', NULL, A.HIST_DEL_USER_ID),  
			DECODE(TRIM(A.HIST_DEL_COMMENT), '', NULL, A.HIST_DEL_COMMENT),  
			NULL,  
			NULL,  
			NULL
		FROM MRASRESHIS A
        WHERE A.FACTORY = :RRASRESHIS_N.FACTORY
          AND A.RES_ID = :RRASRESHIS_N.RES_ID
          AND A.HIST_SEQ = :RRASRESHIS_N.HIST_SEQ;
    DB_stop_query_timer("RPT_select_insert_rrasreshis", 0);
}

/* SQL INSERT Function */
