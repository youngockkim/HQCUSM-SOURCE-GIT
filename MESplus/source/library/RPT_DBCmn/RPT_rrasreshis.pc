                    DECODE(TRAN_CMF_15, NULL, 'Y', ' '), NVL(TRAN_CMF_15, ' '),
                    DECODE(TRAN_CMF_16, NULL, 'Y', ' '), NVL(TRAN_CMF_16, ' '),
                    DECODE(TRAN_CMF_17, NULL, 'Y', ' '), NVL(TRAN_CMF_17, ' '),
                    DECODE(TRAN_CMF_18, NULL, 'Y', ' '), NVL(TRAN_CMF_18, ' '),
                    DECODE(TRAN_CMF_19, NULL, 'Y', ' '), NVL(TRAN_CMF_19, ' '),
                    DECODE(TRAN_CMF_20, NULL, 'Y', ' '), NVL(TRAN_CMF_20, ' '),
                    DECODE(TRAN_USER_ID, NULL, 'Y', ' '), NVL(TRAN_USER_ID, ' '),
                    DECODE(TRAN_COMMENT, NULL, 'Y', ' '), NVL(TRAN_COMMENT, ' '),
                    DECODE(LAST_DOWN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(LAST_DOWN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(LAST_DOWN_HIST_SEQ, NULL, 'Y', ' '), NVL(LAST_DOWN_HIST_SEQ, '0'),
                    DECODE(HIST_START_SEQ, NULL, 'Y', ' '), NVL(HIST_START_SEQ, '0'),
                    DECODE(HIST_DEL_FLAG, NULL, 'Y', ' '), NVL(HIST_DEL_FLAG, 'N'),
                    DECODE(HIST_DEL_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(HIST_DEL_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(HIST_DEL_USER_ID, NULL, 'Y', ' '), NVL(HIST_DEL_USER_ID, ' '),
                    DECODE(HIST_DEL_COMMENT, NULL, 'Y', ' '), NVL(HIST_DEL_COMMENT, ' '),
                    DECODE(END_DATE, NULL, 'Y', ' '), NVL(TO_CHAR(END_DATE, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(EDC_DETAILS, NULL, 'Y', ' '), NVL(EDC_DETAILS, ' '),
                    DECODE(REPAIR_PRIOR, NULL, 'Y', ' '), NVL(REPAIR_PRIOR, ' ')
                FROM RRASRESHIS
                WHERE FACTORY = :RRASRESHIS_N.FACTORY
                    AND RES_ID = :RRASRESHIS_N.RES_ID
                    AND HIST_SEQ = :RRASRESHIS_N.HIST_SEQ
                ORDER BY HIST_SEQ ASC;
            EXEC SQL OPEN RPT_RRASRESHIS_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rrasreshis", sel_type);
}


