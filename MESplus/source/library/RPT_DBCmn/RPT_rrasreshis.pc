{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASRESHIS_N_TAG RRASRESHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrasreshis(&RRASRESHIS_N, RRASRESHIS);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RRASRESHIS( 
                    FACTORY, 
                    RES_ID, 
                    HIST_SEQ, 
                    EVENT_ID, 
                    TRAN_TIME, 
                    SYS_TRAN_TIME, 
                    OLD_EVENT_ID, 
                    OLD_HIST_SEQ, 
                    OLD_TRAN_TIME, 
                    OLD_SYS_TRAN_TIME, 
                    OLD_UP_DOWN_FLAG, 
                    OLD_PRI_STS, 
                    OLD_STS_1, 
                    OLD_STS_2, 
                    OLD_STS_3, 
                    OLD_STS_4, 
                    OLD_STS_5, 
                    OLD_STS_6, 
                    OLD_STS_7, 
                    OLD_STS_8, 
                    OLD_STS_9, 
                    OLD_STS_10, 
                    NEW_UP_DOWN_FLAG, 
                    NEW_PRI_STS, 
