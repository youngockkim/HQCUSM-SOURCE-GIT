/* SQL SELECT_COUNT Function */
int RPT_select_rrasreshis_count(int sel_type, struct RRASRESHIS_TAG *RRASRESHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASRESHIS_N_TAG RRASRESHIS_N;
		int    count;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrasreshis(&RRASRESHIS_N, RRASRESHIS);
    DB_error_code = 0;
    count = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :count
                FROM RRASRESHIS
                WHERE FACTORY = :RRASRESHIS_N.FACTORY
                    AND RES_ID = :RRASRESHIS_N.RES_ID
                    AND HIST_SEQ = :RRASRESHIS_N.HIST_SEQ;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    return count;
    DB_stop_query_timer("RPT_select_rrasreshis_count", sel_type);
}


