                    HIST_DEL_FLAG = DECODE(:RRASRESHIS_N.HIST_DEL_FLAG.IS_NULL, 'Y', 'N', :RRASRESHIS_N.HIST_DEL_FLAG.VALUE),
                    HIST_DEL_TIME = DECODE(:RRASRESHIS_N.HIST_DEL_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RRASRESHIS_N.HIST_DEL_TIME.VALUE, 'YYYYMMDDHH24MISS')),
