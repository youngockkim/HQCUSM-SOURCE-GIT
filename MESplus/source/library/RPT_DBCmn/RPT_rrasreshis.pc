                WHERE FACTORY = :RRASRESHIS_N.FACTORY
                    AND RES_ID = :RRASRESHIS_N.RES_ID
                    AND HIST_SEQ = :RRASRESHIS_N.HIST_SEQ;
            break;

        case 3:
            EXEC SQL UPDATE RRASRESHIS SET
                    END_DATE = DECODE(:RRASRESHIS_N.END_DATE.IS_NULL, 'Y', NULL, TO_DATE(:RRASRESHIS_N.END_DATE.VALUE, 'YYYYMMDDHH24MISS'))
                WHERE FACTORY = :RRASRESHIS_N.FACTORY
                    AND RES_ID = :RRASRESHIS_N.RES_ID
                    AND HIST_SEQ = :RRASRESHIS_N.HIST_SEQ;
            break;

        case 4:
            EXEC SQL UPDATE RRASRESHIS SET
                    EDC_DETAILS = DECODE(:RRASRESHIS_N.EDC_DETAILS.IS_NULL, 'Y', NULL, :RRASRESHIS_N.EDC_DETAILS.VALUE),
                    REPAIR_PRIOR = DECODE(:RRASRESHIS_N.REPAIR_PRIOR.IS_NULL, 'Y', NULL, :RRASRESHIS_N.REPAIR_PRIOR.VALUE)
                WHERE FACTORY = :RRASRESHIS_N.FACTORY
                    AND RES_ID = :RRASRESHIS_N.RES_ID
                    AND HIST_SEQ = :RRASRESHIS_N.HIST_SEQ;
            break;

        case 5:
            EXEC SQL UPDATE RRASRESHIS SET
                    END_DATE = DECODE(:RRASRESHIS_N.END_DATE.IS_NULL, 'Y', NULL, TO_DATE(:RRASRESHIS_N.END_DATE.VALUE, 'YYYYMMDDHH24MISS')),
                    EDC_DETAILS = DECODE(:RRASRESHIS_N.EDC_DETAILS.IS_NULL, 'Y', NULL, :RRASRESHIS_N.EDC_DETAILS.VALUE),
                    REPAIR_PRIOR = DECODE(:RRASRESHIS_N.REPAIR_PRIOR.IS_NULL, 'Y', NULL, :RRASRESHIS_N.REPAIR_PRIOR.VALUE)
                WHERE FACTORY = :RRASRESHIS_N.FACTORY
                    AND RES_ID = :RRASRESHIS_N.RES_ID
                    AND HIST_SEQ = :RRASRESHIS_N.HIST_SEQ;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_update_rrasreshis", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rrasreshis(int sel_type, struct RRASRESHIS_TAG *RRASRESHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASRESHIS_N_TAG RRASRESHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrasreshis(&RRASRESHIS_N, RRASRESHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RRASRESHIS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    HIST_SEQ,
                    DECODE(EVENT_ID, NULL, 'Y', ' '), NVL(EVENT_ID, ' '),
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(SYS_TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(OLD_EVENT_ID, NULL, 'Y', ' '), NVL(OLD_EVENT_ID, ' '),
                    DECODE(OLD_HIST_SEQ, NULL, 'Y', ' '), NVL(OLD_HIST_SEQ, '0'),
                    DECODE(OLD_TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(OLD_TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(OLD_SYS_TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(OLD_SYS_TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(OLD_UP_DOWN_FLAG, NULL, 'Y', ' '), NVL(OLD_UP_DOWN_FLAG, ' '),
                    DECODE(OLD_PRI_STS, NULL, 'Y', ' '), NVL(OLD_PRI_STS, ' '),
                    DECODE(OLD_STS_1, NULL, 'Y', ' '), NVL(OLD_STS_1, ' '),
                    DECODE(OLD_STS_2, NULL, 'Y', ' '), NVL(OLD_STS_2, ' '),
                    DECODE(OLD_STS_3, NULL, 'Y', ' '), NVL(OLD_STS_3, ' '),
                    DECODE(OLD_STS_4, NULL, 'Y', ' '), NVL(OLD_STS_4, ' '),
                    DECODE(OLD_STS_5, NULL, 'Y', ' '), NVL(OLD_STS_5, ' '),
                    DECODE(OLD_STS_6, NULL, 'Y', ' '), NVL(OLD_STS_6, ' '),
                    DECODE(OLD_STS_7, NULL, 'Y', ' '), NVL(OLD_STS_7, ' '),
                    DECODE(OLD_STS_8, NULL, 'Y', ' '), NVL(OLD_STS_8, ' '),
                    DECODE(OLD_STS_9, NULL, 'Y', ' '), NVL(OLD_STS_9, ' '),
                    DECODE(OLD_STS_10, NULL, 'Y', ' '), NVL(OLD_STS_10, ' '),
                    DECODE(NEW_UP_DOWN_FLAG, NULL, 'Y', ' '), NVL(NEW_UP_DOWN_FLAG, ' '),
                    DECODE(NEW_PRI_STS, NULL, 'Y', ' '), NVL(NEW_PRI_STS, ' '),
                    DECODE(NEW_STS_1, NULL, 'Y', ' '), NVL(NEW_STS_1, ' '),
                    DECODE(NEW_STS_2, NULL, 'Y', ' '), NVL(NEW_STS_2, ' '),
                    DECODE(NEW_STS_3, NULL, 'Y', ' '), NVL(NEW_STS_3, ' '),
                    DECODE(NEW_STS_4, NULL, 'Y', ' '), NVL(NEW_STS_4, ' '),
                    DECODE(NEW_STS_5, NULL, 'Y', ' '), NVL(NEW_STS_5, ' '),
                    DECODE(NEW_STS_6, NULL, 'Y', ' '), NVL(NEW_STS_6, ' '),
                    DECODE(NEW_STS_7, NULL, 'Y', ' '), NVL(NEW_STS_7, ' '),
                    DECODE(NEW_STS_8, NULL, 'Y', ' '), NVL(NEW_STS_8, ' '),
                    DECODE(NEW_STS_9, NULL, 'Y', ' '), NVL(NEW_STS_9, ' '),
                    DECODE(NEW_STS_10, NULL, 'Y', ' '), NVL(NEW_STS_10, ' '),
                    DECODE(LOT_ID, NULL, 'Y', ' '), NVL(LOT_ID, ' '),
                    DECODE(SUBLOT_ID, NULL, 'Y', ' '), NVL(SUBLOT_ID, ' '),
                    DECODE(CRR_ID, NULL, 'Y', ' '), NVL(CRR_ID, ' '),
                    DECODE(RES_CTRL_MODE, NULL, 'Y', ' '), NVL(RES_CTRL_MODE, ' '),
                    DECODE(RES_PROC_MODE, NULL, 'Y', ' '), NVL(RES_PROC_MODE, ' '),
                    DECODE(LOT_EXIST_FLAG, NULL, 'Y', ' '), NVL(LOT_EXIST_FLAG, ' '),
                    DECODE(COL_SET_ID, NULL, 'Y', ' '), NVL(COL_SET_ID, ' '),
                    DECODE(COL_SET_VERSION, NULL, 'Y', ' '), NVL(COL_SET_VERSION, '0'),
                    DECODE(TRAN_CMF_1, NULL, 'Y', ' '), NVL(TRAN_CMF_1, ' '),
                    DECODE(TRAN_CMF_2, NULL, 'Y', ' '), NVL(TRAN_CMF_2, ' '),
                    DECODE(TRAN_CMF_3, NULL, 'Y', ' '), NVL(TRAN_CMF_3, ' '),
                    DECODE(TRAN_CMF_4, NULL, 'Y', ' '), NVL(TRAN_CMF_4, ' '),
                    DECODE(TRAN_CMF_5, NULL, 'Y', ' '), NVL(TRAN_CMF_5, ' '),
                    DECODE(TRAN_CMF_6, NULL, 'Y', ' '), NVL(TRAN_CMF_6, ' '),
