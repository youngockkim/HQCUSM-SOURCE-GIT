                    DECODE(:RRASRESHIS_N.OLD_HIST_SEQ.IS_NULL, 'Y', NULL, :RRASRESHIS_N.OLD_HIST_SEQ.VALUE),
                    DECODE(:RRASRESHIS_N.OLD_TRAN_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RRASRESHIS_N.OLD_TRAN_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    DECODE(:RRASRESHIS_N.OLD_SYS_TRAN_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RRASRESHIS_N.OLD_SYS_TRAN_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    DECODE(:RRASRESHIS_N.OLD_UP_DOWN_FLAG.IS_NULL, 'Y', NULL, :RRASRESHIS_N.OLD_UP_DOWN_FLAG.VALUE),
                    DECODE(:RRASRESHIS_N.OLD_PRI_STS.IS_NULL, 'Y', NULL, :RRASRESHIS_N.OLD_PRI_STS.VALUE),
                    DECODE(:RRASRESHIS_N.OLD_STS_1.IS_NULL, 'Y', NULL, :RRASRESHIS_N.OLD_STS_1.VALUE),
