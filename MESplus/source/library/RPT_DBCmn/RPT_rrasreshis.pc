    MEMCPY_AN(RRASRESHIS_N->RES_ID, RRASRESHIS->RES_ID, sizeof(RRASRESHIS->RES_ID));
    RRASRESHIS_N->HIST_SEQ = RRASRESHIS->HIST_SEQ;
