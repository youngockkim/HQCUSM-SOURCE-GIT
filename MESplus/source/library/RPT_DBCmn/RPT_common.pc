/******************************************************************************
*
*    Function Name  : DB_usr_error() 
*
*    Program ID     : DB common
*
*    Description    : when an error occured or no data found while quering  
*                     the DB, copy the sql error message to sql_error_msg 
*                     which is defined as global variable 
*
*    Parameters     : None 
*                     
*    System Inputs  : None
*
*    System Outputs : None
* 
*    Globals
*        Used       : sql_error_code 
*        Modified   : sql_error_msg
*  
*    External Funs  : None 
*                     
*    Return Value   : None                    
*
*    Special Login Notes :
*                     None
*
*******************************************************************************/
void DB_usr_error()
{
    char err_msg[512];       
    size_t buf_len, msg_len;

    EXEC SQL WHENEVER SQLERROR CONTINUE;

    DB_error_code = sqlca.sqlcode;
    memset(DB_error_msg,' ', sizeof(DB_error_msg));

    /**
    memcpy(MPDB_error_msg, sqlca.sqlerrm.sqlerrmc, 70);
    **/
    
    buf_len = sizeof(err_msg);
    sqlglm(err_msg, &buf_len, &msg_len);
    
    if(msg_len > 200) {
        msg_len = 200;
    }
        
    memcpy(DB_error_msg, err_msg, msg_len);
    return;     
}

EXEC SQL WHENEVER SQLERROR DO DB_usr_error();
EXEC SQL WHENEVER NOT FOUND DO DB_usr_error();


/******************************************************************************
*
*    Function Name  : DB_connect() 
*
*    Program ID     : DB common
*
*    Description    : execute CONNECT command used in SQL according
*                     to condition 
*
*    Parameters     : int node
*                     char Nodename
*                     char User
*                     char Pass  
*                     
*    System Inputs  : None
*
*    System Outputs : None
* 
*    Globals
*        Used       : None 
*        Modified   : sql_error_code
*  
*    External Funs  : None 
*                     
*    Return Value   : None                    
*
*    Special Login Notes :
*                     None
*
*******************************************************************************/
void DB_connect(int Mode, char *Conn, char *NodeName, char *User, char *Pass)
{

    EXEC SQL BEGIN DECLARE SECTION;
        VARCHAR    ConnName[32];
        VARCHAR    UserName[32];
        VARCHAR    PassWord[32];
        VARCHAR	   TnsName[32];
    EXEC SQL END   DECLARE SECTION;

    DB_error_code = 0;
    strcpy((char *)ConnName.arr, Conn);
    strcpy((char *)UserName.arr, User);
    strcpy((char *)PassWord.arr, Pass);
    strcpy((char *)TnsName.arr, NodeName);
    
    ConnName.len = strlen((char *)ConnName.arr);
    UserName.len = strlen((char *)UserName.arr);
    PassWord.len = strlen((char *)PassWord.arr);
    TnsName.len  = strlen((char *)TnsName.arr);
    
    switch(Mode)
    {
    case 1:
        EXEC SQL CONNECT :UserName IDENTIFIED BY :PassWord;
        EXEC SQL ALTER SESSION SET NLS_DATE_FORMAT='YYYYMMDDHH24MISS';
        break;
    case 2:
        EXEC SQL CONNECT :UserName IDENTIFIED BY :PassWord USING :TnsName;
        EXEC SQL ALTER SESSION SET NLS_DATE_FORMAT='YYYYMMDDHH24MISS';
        break;
    case 3:
        EXEC SQL CONNECT :UserName IDENTIFIED BY :PassWord AT :ConnName USING :TnsName;
        EXEC SQL AT :ConnName ALTER SESSION SET NLS_DATE_FORMAT='YYYYMMDDHH24MISS';
        break;
    default:
        break;
    }
    
}


/******************************************************************************
*
*    Function Name  : DB_disconnect() 
*
*    Program ID     : DB common
*
*    Description    : disconnect the connection to DB by releasing the 
*                     ROLLBACK work 
*
*    Parameters     : None  
*                     
*    System Inputs  : None
*
*    System Outputs : None
* 
*    Globals
*        Used       : None 
*        Modified   : None 
*  
*    External Funs  : None 
*                     
*    Return Value   : None                    
*
*    Special Login Notes :
*                     None
*
*******************************************************************************/
void DB_disconnect(int Mode, char *DBConn)
{
    EXEC SQL BEGIN DECLARE SECTION;
        char *s_DBConn;
    EXEC SQL END DECLARE SECTION;
      
    switch(Mode)
    {
    case 1:
        EXEC SQL ROLLBACK WORK RELEASE;
        break;
    case 2:
        EXEC SQL ROLLBACK WORK RELEASE;
        break;
    case 3:
        s_DBConn = DBConn;
        EXEC SQL AT :s_DBConn ROLLBACK WORK RELEASE;
        break;
    }
}


/******************************************************************************
*
*    Function Name  : MES_get_systime()
*
*    Program ID     : DB common
*
*    Description    : Get DB System Time ('YYYYMMDDHH24MISS')
*
*    Parameters     : char *s_time
*                     
*    System Inputs  : None
*
*    System Outputs : None
* 
*    Globals
*        Used       : None 
*        Modified   : None 
*  
*    External Funs  : None 
*                     
*    Return Value   : None
*
*    Special Login Notes :
*                     None
*
*******************************************************************************/
void MES_get_systime(char *s_time)
{
    EXEC SQL BEGIN DECLARE SECTION;
		char s_t_time[15];    
	EXEC SQL END DECLARE SECTION;

    memset(s_time, ' ', 14);
    memset(s_t_time, ' ', sizeof(s_t_time));
    DB_error_code = 0;

    EXEC SQL AT :MESConn SELECT TO_CHAR(SYSDATE, 'YYYYMMDDHH24MISS') INTO :s_t_time FROM DUAL;
    
    memcpy(s_time, s_t_time, 14);
}


