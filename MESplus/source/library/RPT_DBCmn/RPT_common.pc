/*******************************************************************************
    DB_init_condition()
        - Initialize Condition Struct Function
    Return Value
        - void
    Arguments
        - struct DB_Q_COND_TAG *DB_Q_COND
*******************************************************************************/
void DB_init_condition(struct DB_Q_COND_TAG *DB_Q_COND)
{
    /* memset by Space */
    memset(DB_Q_COND, ' ', sizeof(struct DB_Q_COND_TAG));
    DB_Q_COND->FROM_SEQ = 0;
    DB_Q_COND->TO_SEQ = 0;
    DB_Q_COND->PRIO_LEVEL = 0;
}


/*******************************************************************************
    DB_add_null_condition()
        - Add Null Condition Struct Function
    Return Value
        - void
    Arguments
        - struct DB_Q_COND_N_TAG *DB_Q_COND_N
*******************************************************************************/
void DB_add_null_condition(struct DB_Q_COND_TAG *DB_Q_COND, struct DB_Q_COND_N_TAG *DB_Q_COND_N)
{
    /* memset by Space */
    memset(DB_Q_COND_N, '\0', sizeof(struct DB_Q_COND_N_TAG));
    MEMCPY_AN(DB_Q_COND_N->FROM_DATE, DB_Q_COND->FROM_DATE, sizeof(DB_Q_COND->FROM_DATE));
    MEMCPY_AN(DB_Q_COND_N->TO_DATE, DB_Q_COND->TO_DATE, sizeof(DB_Q_COND->TO_DATE));
    MEMCPY_AN(DB_Q_COND_N->FROM_TIME, DB_Q_COND->FROM_TIME, sizeof(DB_Q_COND->FROM_TIME));
    MEMCPY_AN(DB_Q_COND_N->TO_TIME, DB_Q_COND->TO_TIME, sizeof(DB_Q_COND->TO_TIME));
    MEMCPY_AN(DB_Q_COND_N->MAT_TYPE, DB_Q_COND->MAT_TYPE, sizeof(DB_Q_COND->MAT_TYPE));
    MEMCPY_AN(DB_Q_COND_N->MAT_GRP, DB_Q_COND->MAT_GRP, sizeof(DB_Q_COND->MAT_GRP));
    MEMCPY_AN(DB_Q_COND_N->RES_ID, DB_Q_COND->RES_ID, sizeof(DB_Q_COND->RES_ID));
    MEMCPY_AN(DB_Q_COND_N->OPER, DB_Q_COND->OPER, sizeof(DB_Q_COND->OPER));
    MEMCPY_AN(DB_Q_COND_N->SPC_SUMMARY_KEY, DB_Q_COND->SPC_SUMMARY_KEY, sizeof(DB_Q_COND->SPC_SUMMARY_KEY));
    DB_Q_COND_N->FROM_SEQ = DB_Q_COND->FROM_SEQ;
    DB_Q_COND_N->TO_SEQ = DB_Q_COND->TO_SEQ;
    DB_Q_COND_N->PRIO_LEVEL = DB_Q_COND->PRIO_LEVEL;
    MEMCPY_AN(DB_Q_COND_N->PRIO_KEY, DB_Q_COND->PRIO_KEY, sizeof(DB_Q_COND->PRIO_KEY));
    MEMCPY_AN(DB_Q_COND_N->KEY_VALUE_1, DB_Q_COND->KEY_VALUE_1, sizeof(DB_Q_COND->KEY_VALUE_1));
    MEMCPY_AN(DB_Q_COND_N->KEY_VALUE_2, DB_Q_COND->KEY_VALUE_2, sizeof(DB_Q_COND->KEY_VALUE_2));
}


/******************************************************************************
*
*    Function Name  : MEMCPY_AN() 
*
*    Program ID     : DB common
*
*    Description    : Insert null at end of string 
*
*    Parameters     : char d
*                     char s
*                     long size  
*                     
*    System Inputs  : None
*
*    System Outputs : None
* 
*    Globals
*        Used       : None 
*        Modified   : None 
*  
*    External Funs  : None 
*                     
*    Return Value   : None                    
*
*    Special Login Notes :
*                     None
*
*******************************************************************************/
void MEMCPY_AN(char *d,char *s,int size)
{
    int  i;
    int  i_end_of_space; 
   
    i_end_of_space = 0;

    for(i = size-1 ; i >= 0 ; i--)
    {
        if(*(s+i) == ' ' && i_end_of_space == 0)
        {
            *(d+i) = '\0';
        }
        else
        {
            *(d+i) = *(s+i);
            i_end_of_space = 1;
        }
    }

    if(*(d) == '\0') {
        *(d) = ' ';
    }
}


/******************************************************************************
*
*    Function Name  : MEMCPY_DN() 
*
*    Program ID     : DB common
*
*    Description    : copy the memory without NULL by transfering from NULL
*                     to SPACE
*
*    Parameters     : char d
*                     char s
*                     long size  
*                     
*    System Inputs  : None
*
*    System Outputs : None
* 
*    Globals
*        Used       : None 
*        Modified   : None 
*  
*    External Funs  : None 
*                     
*    Return Value   : None                    
*
*    Special Login Notes :
*                     None
*
*******************************************************************************/
void MEMCPY_DN(char *d,char *s,int size)
{
    int i;

    for(i=0 ; i<size ; i++)
    {
        if(*(s+i) == '\0')
        {  
            *(d+i)=' ';
        }
        else
        {
            *(d+i) = *(s+i);
        }
    }
}


/******************************************************************************
*
*    Function Name  : ISSPACE()
*
*    Program ID     : DB common
*
*    Description    : Check the String whether blank or not
*
*    Parameters     : char *s_p
*                     char size_i
*                     
*    System Inputs  : None
*
*    System Outputs : None
* 
*    Globals
*        Used       : None 
*        Modified   : None 
*  
*    External Funs  : None 
*                     
*    Return Value   : 1 (blank)/ 0 (not blank)
*
*    Special Login Notes :
*                     None
*
*******************************************************************************/
int ISSPACE( char *s_p, int size_i )    
{                                           
    int i;                                  
                                            
    for ( i = 0; i < size_i; i++ )          
    {                                       
        if ( *(s_p+i) == ' ' )              
            ;                               
        else                                
            return( DB_FALSE );                    
    }                                       
                                            
    return( DB_TRUE );                            
}                                           

/******************************************************************************
*
*    Function Name  : DB_make_valid()
*
*    Program ID     : DB common
*
*    Description    : 
*
*    Parameters     : char *d
*                     char *s
*                     
*    System Inputs  : None
*
*    System Outputs : None
* 
*    Globals
*        Used       : None 
*        Modified   : None 
*  
*    External Funs  : None 
*                     
*    Return Value   : None
*
*    Special Login Notes :
*                     None
*
*******************************************************************************/
void make_valid_quote(char *d, char *s)
{
    int i;
    int j;
    int size;
    
    j=0;
    size = strlen(s);
    for (i = 0; i < size ; i++)
    {
        if( *(s+i) == 0x27 )
        {
            *(d+j) = 0x27;
            j++;
            *(d+j) = 0x27;
            j++;
        }
        else
        {
            *(d+j) = *(s+i);
            j++;
        }
    }
    
    *(d+j) = 0x0;
}

int DB_is_connected()
{
    if(DB_error_code == DB_LISTENER_FAILED ||
       DB_error_code == DB_DISCONNECT  ||
       DB_error_code == DB_EOF_CHANNEL ||
       DB_error_code == DB_FAIL_PACKET_WRITE ||
       DB_error_code == DB_NOT_LOGGED_ON ||
	   DB_error_code == DB_LOST_CONTACT ||
       DB_error_code == DB_NO_LISTENER)
    {
        return DB_FALSE;
    }

    return DB_TRUE;
}

