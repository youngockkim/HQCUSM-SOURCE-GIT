			DECODE(TRIM(RES_CTRL_MODE), '', NULL, RES_CTRL_MODE),
			DECODE(TRIM(RES_PROC_MODE), '', NULL, RES_PROC_MODE),
			DECODE(TRIM(LAST_RECIPE_ID), '', NULL, LAST_RECIPE_ID),
			DECODE(TRIM(PROC_COUNT), '', NULL, PROC_COUNT),
			DECODE(TRIM(LAST_START_TIME), '', NULL, TO_DATE(LAST_START_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(LAST_END_TIME), '', NULL, TO_DATE(LAST_END_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(LAST_DOWN_TIME), '', NULL, TO_DATE(LAST_DOWN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(LAST_DOWN_HIST_SEQ), '', NULL, LAST_DOWN_HIST_SEQ),
			DECODE(TRIM(LAST_EVENT_ID), '', NULL, LAST_EVENT_ID),
			DECODE(TRIM(LAST_EVENT_TIME), '', NULL, TO_DATE(LAST_EVENT_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(LAST_ACTIVE_HIST_SEQ), '', NULL, LAST_ACTIVE_HIST_SEQ),
			DECODE(TRIM(LAST_HIST_SEQ), '', NULL, LAST_HIST_SEQ),
			NULL,
			DECODE(TRIM(RES_SHORT_DESC), '', NULL, RES_SHORT_DESC)
		FROM MRASRESDEF
        WHERE FACTORY = :RRASRESDEF_N.FACTORY
          AND RES_ID = :RRASRESDEF_N.RES_ID;
    DB_stop_query_timer("RPT_select_insert_rrasresdef", 0);
}

