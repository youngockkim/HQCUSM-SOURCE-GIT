/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rrasresdef(int sel_type, struct RRASRESDEF_TAG *RRASRESDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASRESDEF_N_TAG RRASRESDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrasresdef(&RRASRESDEF_N, RRASRESDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RRASRESDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    DECODE(RES_DESC, NULL, 'Y', ' '), NVL(RES_DESC, ' '),
                    DECODE(RES_TYPE, NULL, 'Y', ' '), NVL(RES_TYPE, ' '),
