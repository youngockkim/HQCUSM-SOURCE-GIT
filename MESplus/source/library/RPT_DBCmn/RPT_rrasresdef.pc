					DECODE(RES_SHORT_DESC, NULL, 'Y', ' '), NVL(RES_SHORT_DESC, ' ')
                FROM RRASRESDEF
                WHERE DELETE_FLAG<>'Y'
                ORDER BY RES_ID ASC;
            EXEC SQL OPEN RPT_RRASRESDEF_CUR_2;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rrasresdef", sel_type);
}


