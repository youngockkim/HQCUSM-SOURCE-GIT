			DECODE(TRIM(RES_CMF_11), '', NULL, RES_CMF_11),
			DECODE(TRIM(RES_CMF_12), '', NULL, RES_CMF_12),
			DECODE(TRIM(RES_CMF_13), '', NULL, RES_CMF_13),
			DECODE(TRIM(RES_CMF_14), '', NULL, RES_CMF_14),
