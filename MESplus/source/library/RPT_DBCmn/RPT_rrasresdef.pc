            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rrasresdef(&RRASRESDEF_N, RRASRESDEF);
    }
    DB_stop_query_timer("RPT_fetch_rrasresdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void RPT_close_rrasresdef(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_RRASRESDEF_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE RPT_RRASRESDEF_CUR_2;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_rrasresdef", sel_type);
}


