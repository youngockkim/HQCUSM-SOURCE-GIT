/* SQL UPDATE Function */
void RPT_update_rrasresdef(int sel_type, struct RRASRESDEF_TAG *RRASRESDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASRESDEF_N_TAG RRASRESDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrasresdef(&RRASRESDEF_N, RRASRESDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE RRASRESDEF SET
                    RES_DESC = DECODE(:RRASRESDEF_N.RES_DESC.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_DESC.VALUE),
                    RES_TYPE = DECODE(:RRASRESDEF_N.RES_TYPE.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_TYPE.VALUE),
                    RES_GRP_1 = DECODE(:RRASRESDEF_N.RES_GRP_1.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_GRP_1.VALUE),
                    RES_GRP_2 = DECODE(:RRASRESDEF_N.RES_GRP_2.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_GRP_2.VALUE),
                    RES_GRP_3 = DECODE(:RRASRESDEF_N.RES_GRP_3.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_GRP_3.VALUE),
                    RES_GRP_4 = DECODE(:RRASRESDEF_N.RES_GRP_4.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_GRP_4.VALUE),
                    RES_GRP_5 = DECODE(:RRASRESDEF_N.RES_GRP_5.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_GRP_5.VALUE),
                    RES_GRP_6 = DECODE(:RRASRESDEF_N.RES_GRP_6.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_GRP_6.VALUE),
                    RES_GRP_7 = DECODE(:RRASRESDEF_N.RES_GRP_7.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_GRP_7.VALUE),
                    RES_GRP_8 = DECODE(:RRASRESDEF_N.RES_GRP_8.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_GRP_8.VALUE),
                    RES_GRP_9 = DECODE(:RRASRESDEF_N.RES_GRP_9.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_GRP_9.VALUE),
                    RES_GRP_10 = DECODE(:RRASRESDEF_N.RES_GRP_10.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_GRP_10.VALUE),
                    USE_FAC_PRT_FLAG = DECODE(:RRASRESDEF_N.USE_FAC_PRT_FLAG.IS_NULL, 'Y', NULL, :RRASRESDEF_N.USE_FAC_PRT_FLAG.VALUE),
                    RES_STS_PRT_1 = DECODE(:RRASRESDEF_N.RES_STS_PRT_1.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_STS_PRT_1.VALUE),
                    RES_STS_PRT_2 = DECODE(:RRASRESDEF_N.RES_STS_PRT_2.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_STS_PRT_2.VALUE),
                    RES_STS_PRT_3 = DECODE(:RRASRESDEF_N.RES_STS_PRT_3.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_STS_PRT_3.VALUE),
                    RES_STS_PRT_4 = DECODE(:RRASRESDEF_N.RES_STS_PRT_4.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_STS_PRT_4.VALUE),
                    RES_STS_PRT_5 = DECODE(:RRASRESDEF_N.RES_STS_PRT_5.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_STS_PRT_5.VALUE),
                    RES_STS_PRT_6 = DECODE(:RRASRESDEF_N.RES_STS_PRT_6.IS_NULL, 'Y', NULL, :RRASRESDEF_N.RES_STS_PRT_6.VALUE),
