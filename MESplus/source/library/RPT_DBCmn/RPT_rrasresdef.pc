/* SQL SELECT_SCALAR Function */
double RPT_select_rrasresdef_scalar(int sel_type, struct RRASRESDEF_TAG *RRASRESDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASRESDEF_N_TAG RRASRESDEF_N;
		double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    
    RPT_add_null_rrasresdef(&RRASRESDEF_N, RRASRESDEF);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM RRASRESDEF
                WHERE FACTORY = :RRASRESDEF_N.FACTORY
                    AND RES_ID = :RRASRESDEF_N.RES_ID;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("RPT_select_rrasresdef_scalar", sel_type);
    return d_value;
}


/* SQL DELETE Function */
