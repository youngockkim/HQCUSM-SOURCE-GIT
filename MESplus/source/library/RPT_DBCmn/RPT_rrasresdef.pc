                    DECODE(LAST_START_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(LAST_START_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(LAST_END_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(LAST_END_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(LAST_DOWN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(LAST_DOWN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(LAST_DOWN_HIST_SEQ, NULL, 'Y', ' '), NVL(LAST_DOWN_HIST_SEQ, '0'),
