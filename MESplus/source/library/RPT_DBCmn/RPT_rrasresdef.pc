/* SQL SELECT - INSERT Function */
void RPT_select_insert_rrasresdef(struct RRASRESDEF_TAG *RRASRESDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASRESDEF_N_TAG RRASRESDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrasresdef(&RRASRESDEF_N, RRASRESDEF);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RRASRESDEF
		SELECT
			FACTORY,
			RES_ID,
			DECODE(TRIM(RES_DESC), '', NULL, RES_DESC),
			DECODE(TRIM(RES_TYPE), '', NULL, RES_TYPE),
			DECODE(TRIM(RES_GRP_1), '', NULL, RES_GRP_1),
			DECODE(TRIM(RES_GRP_2), '', NULL, RES_GRP_2),
