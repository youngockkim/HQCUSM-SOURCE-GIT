			DECODE(TRIM(RES_STS_PRT_1), '', NULL, RES_STS_PRT_1),
			DECODE(TRIM(RES_STS_PRT_2), '', NULL, RES_STS_PRT_2),
			DECODE(TRIM(RES_STS_PRT_3), '', NULL, RES_STS_PRT_3),
			DECODE(TRIM(RES_STS_PRT_4), '', NULL, RES_STS_PRT_4),
			DECODE(TRIM(RES_STS_PRT_5), '', NULL, RES_STS_PRT_5),
			DECODE(TRIM(RES_STS_PRT_6), '', NULL, RES_STS_PRT_6),
			DECODE(TRIM(RES_STS_PRT_7), '', NULL, RES_STS_PRT_7),
			DECODE(TRIM(RES_STS_PRT_8), '', NULL, RES_STS_PRT_8),
			DECODE(TRIM(RES_STS_PRT_9), '', NULL, RES_STS_PRT_9),
			DECODE(TRIM(RES_STS_PRT_10), '', NULL, RES_STS_PRT_10),
			DECODE(TRIM(RES_CMF_1), '', NULL, RES_CMF_1),
			DECODE(TRIM(RES_CMF_2), '', NULL, RES_CMF_2),
			DECODE(TRIM(RES_CMF_3), '', NULL, RES_CMF_3),
			DECODE(TRIM(RES_CMF_4), '', NULL, RES_CMF_4),
			DECODE(TRIM(RES_CMF_5), '', NULL, RES_CMF_5),
