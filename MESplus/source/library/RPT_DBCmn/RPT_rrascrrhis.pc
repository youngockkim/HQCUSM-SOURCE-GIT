/* SQL INSERT Function */
void RPT_insert_rrascrrhis(struct RRASCRRHIS_TAG *RRASCRRHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASCRRHIS_N_TAG RRASCRRHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrascrrhis(&RRASCRRHIS_N, RRASCRRHIS);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RRASCRRHIS( 
                    CRR_ID, 
                    HIST_SEQ, 
                    TRAN_TIME, 
                    SYS_TRAN_TIME, 
                    TRAN_CODE, 
                    FACTORY, 
                    CRR_STATUS, 
                    CRR_STATUS_FLAG, 
                    USAGE_COUNT, 
                    CLEAN_COUNT, 
                    RES_ID, 
                    SUBRES_ID, 
                    PORT_ID, 
                    LOCATION_1, 
                    LOCATION_2, 
                    LOCATION_3, 
                    LOCATION_4, 
                    LOCATION_5, 
                    NEED_CLEAN_FLAG, 
                    FINISH_CLEAN_FLAG, 
                    LAST_CLEAN_TIME, 
                    LOT_ID, 
                    LOT_HIST_SEQ, 
                    QTY_1, 
                    QTY_2, 
                    QTY_3, 
                    TBL_SLOT, 
                    MOVE_FLAG, 
                    EMPTY_FLAG, 
                    STOCK_IN_TIME, 
                    TRAN_CMF_1, 
                    TRAN_CMF_2, 
                    TRAN_CMF_3, 
                    TRAN_CMF_4, 
                    TRAN_CMF_5, 
                    TRAN_CMF_6, 
                    TRAN_CMF_7, 
                    TRAN_CMF_8, 
                    TRAN_CMF_9, 
                    TRAN_CMF_10, 
                    TRAN_CMF_11, 
                    TRAN_CMF_12, 
                    TRAN_CMF_13, 
                    TRAN_CMF_14, 
                    TRAN_CMF_15, 
                    TRAN_CMF_16, 
                    TRAN_CMF_17, 
                    TRAN_CMF_18, 
                    TRAN_CMF_19, 
                    TRAN_CMF_20, 
                    TRAN_USER_ID, 
                    TRAN_COMMENT, 
                    CRR_CMF_1, 
                    CRR_CMF_2, 
                    CRR_CMF_3, 
                    CRR_CMF_4, 
                    CRR_CMF_5, 
                    CRR_CMF_6, 
