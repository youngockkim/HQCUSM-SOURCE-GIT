                    CRR_CMF_11, 
                    CRR_CMF_12, 
                    CRR_CMF_13, 
                    CRR_CMF_14, 
                    CRR_CMF_15, 
                    CRR_CMF_16, 
                    CRR_CMF_17, 
                    CRR_CMF_18, 
                    CRR_CMF_19, 
                    CRR_CMF_20, 
                    REUSE_COUNT
         ) 
        VALUES (
                    :RRASCRRHIS_N.CRR_ID,
                    :RRASCRRHIS_N.HIST_SEQ,
                    DECODE(:RRASCRRHIS_N.TRAN_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RRASCRRHIS_N.TRAN_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    DECODE(:RRASCRRHIS_N.SYS_TRAN_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RRASCRRHIS_N.SYS_TRAN_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    DECODE(:RRASCRRHIS_N.TRAN_CODE.IS_NULL, 'Y', NULL, :RRASCRRHIS_N.TRAN_CODE.VALUE),
                    DECODE(:RRASCRRHIS_N.FACTORY.IS_NULL, 'Y', NULL, :RRASCRRHIS_N.FACTORY.VALUE),
                    DECODE(:RRASCRRHIS_N.CRR_STATUS.IS_NULL, 'Y', NULL, :RRASCRRHIS_N.CRR_STATUS.VALUE),
                    DECODE(:RRASCRRHIS_N.CRR_STATUS_FLAG.IS_NULL, 'Y', NULL, :RRASCRRHIS_N.CRR_STATUS_FLAG.VALUE),
                    DECODE(:RRASCRRHIS_N.USAGE_COUNT.IS_NULL, 'Y', NULL, :RRASCRRHIS_N.USAGE_COUNT.VALUE),
                    DECODE(:RRASCRRHIS_N.CLEAN_COUNT.IS_NULL, 'Y', NULL, :RRASCRRHIS_N.CLEAN_COUNT.VALUE),
                    DECODE(:RRASCRRHIS_N.RES_ID.IS_NULL, 'Y', NULL, :RRASCRRHIS_N.RES_ID.VALUE),
                    DECODE(:RRASCRRHIS_N.SUBRES_ID.IS_NULL, 'Y', NULL, :RRASCRRHIS_N.SUBRES_ID.VALUE),
                    DECODE(:RRASCRRHIS_N.PORT_ID.IS_NULL, 'Y', NULL, :RRASCRRHIS_N.PORT_ID.VALUE),
                    DECODE(:RRASCRRHIS_N.LOCATION_1.IS_NULL, 'Y', NULL, :RRASCRRHIS_N.LOCATION_1.VALUE),
                    DECODE(:RRASCRRHIS_N.LOCATION_2.IS_NULL, 'Y', NULL, :RRASCRRHIS_N.LOCATION_2.VALUE),
