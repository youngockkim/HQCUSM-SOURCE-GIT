			DECODE(TRIM(CRR_CMF_20), '', NULL, CRR_CMF_20),
            DECODE(TRIM(REUSE_COUNT), '', NULL, REUSE_COUNT)
		FROM MRASCRRHIS
        WHERE CRR_ID = :RRASCRRHIS_N.CRR_ID
          AND HIST_SEQ = :RRASCRRHIS_N.HIST_SEQ;
    DB_stop_query_timer("RPT_select_insert_rrascrrhis", 0);
