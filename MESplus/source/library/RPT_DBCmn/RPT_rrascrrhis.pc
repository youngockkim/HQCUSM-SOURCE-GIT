/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rrascrrhis(int sel_type, struct RRASCRRHIS_TAG *RRASCRRHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASCRRHIS_N_TAG RRASCRRHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrascrrhis(&RRASCRRHIS_N, RRASCRRHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RRASCRRHIS_CUR_1 CURSOR FOR
                SELECT 
                    CRR_ID,
                    HIST_SEQ,
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(SYS_TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(TRAN_CODE, NULL, 'Y', ' '), NVL(TRAN_CODE, ' '),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '),
                    DECODE(CRR_STATUS, NULL, 'Y', ' '), NVL(CRR_STATUS, ' '),
                    DECODE(CRR_STATUS_FLAG, NULL, 'Y', ' '), NVL(CRR_STATUS_FLAG, ' '),
                    DECODE(USAGE_COUNT, NULL, 'Y', ' '), NVL(USAGE_COUNT, '0'),
                    DECODE(CLEAN_COUNT, NULL, 'Y', ' '), NVL(CLEAN_COUNT, '0'),
                    DECODE(RES_ID, NULL, 'Y', ' '), NVL(RES_ID, ' '),
                    DECODE(SUBRES_ID, NULL, 'Y', ' '), NVL(SUBRES_ID, ' '),
                    DECODE(PORT_ID, NULL, 'Y', ' '), NVL(PORT_ID, ' '),
                    DECODE(LOCATION_1, NULL, 'Y', ' '), NVL(LOCATION_1, ' '),
                    DECODE(LOCATION_2, NULL, 'Y', ' '), NVL(LOCATION_2, ' '),
                    DECODE(LOCATION_3, NULL, 'Y', ' '), NVL(LOCATION_3, ' '),
                    DECODE(LOCATION_4, NULL, 'Y', ' '), NVL(LOCATION_4, ' '),
                    DECODE(LOCATION_5, NULL, 'Y', ' '), NVL(LOCATION_5, ' '),
                    DECODE(NEED_CLEAN_FLAG, NULL, 'Y', ' '), NVL(NEED_CLEAN_FLAG, ' '),
                    DECODE(FINISH_CLEAN_FLAG, NULL, 'Y', ' '), NVL(FINISH_CLEAN_FLAG, ' '),
                    DECODE(LAST_CLEAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(LAST_CLEAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(LOT_ID, NULL, 'Y', ' '), NVL(LOT_ID, ' '),
                    DECODE(LOT_HIST_SEQ, NULL, 'Y', ' '), NVL(LOT_HIST_SEQ, '0'),
                    DECODE(QTY_1, NULL, 'Y', ' '), NVL(QTY_1, '0'),
                    DECODE(QTY_2, NULL, 'Y', ' '), NVL(QTY_2, '0'),
                    DECODE(QTY_3, NULL, 'Y', ' '), NVL(QTY_3, '0'),
