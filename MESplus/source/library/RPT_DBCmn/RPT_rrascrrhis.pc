/* SQL SELECT - INSERT Function */
void RPT_select_insert_rrascrrhis(struct RRASCRRHIS_TAG *RRASCRRHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASCRRHIS_N_TAG RRASCRRHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrascrrhis(&RRASCRRHIS_N, RRASCRRHIS);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RRASCRRHIS
		SELECT
			CRR_ID, 
			HIST_SEQ, 
			DECODE(TRIM(TRAN_TIME), '', NULL, TO_DATE(TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(SYS_TRAN_TIME), '', NULL, TO_DATE(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(TRAN_CODE), '', NULL, TRAN_CODE),
			DECODE(TRIM(FACTORY), '', NULL, FACTORY),
			DECODE(TRIM(CRR_STATUS), '', NULL, CRR_STATUS),
			DECODE(TRIM(CRR_STATUS_FLAG), '', NULL, CRR_STATUS_FLAG),
