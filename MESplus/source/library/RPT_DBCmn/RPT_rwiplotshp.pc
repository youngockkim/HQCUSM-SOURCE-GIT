}


/* Del Null Function */
void RPT_del_null_rwiplotshp(struct RWIPLOTSHP_N_TAG *RWIPLOTSHP_N, struct RWIPLOTSHP_TAG *RWIPLOTSHP)
{
    MEMCPY_DN(RWIPLOTSHP->LOT_ID, RWIPLOTSHP_N->LOT_ID, sizeof(RWIPLOTSHP->LOT_ID));
    RWIPLOTSHP->HIST_SEQ = RWIPLOTSHP_N->HIST_SEQ;
    MEMCPY_DN(RWIPLOTSHP->TRAN_TIME, RWIPLOTSHP_N->TRAN_TIME, sizeof(RWIPLOTSHP->TRAN_TIME));
    RWIPLOTSHP->HIST_DEL_FLAG = RWIPLOTSHP_N->HIST_DEL_FLAG[0];
    MEMCPY_DN(RWIPLOTSHP->FACTORY, RWIPLOTSHP_N->FACTORY, sizeof(RWIPLOTSHP->FACTORY));
    MEMCPY_DN(RWIPLOTSHP->MAT_ID, RWIPLOTSHP_N->MAT_ID, sizeof(RWIPLOTSHP->MAT_ID));
    RWIPLOTSHP->MAT_VER = RWIPLOTSHP_N->MAT_VER;
    MEMCPY_DN(RWIPLOTSHP->FLOW, RWIPLOTSHP_N->FLOW, sizeof(RWIPLOTSHP->FLOW));
    RWIPLOTSHP->FLOW_SEQ_NUM = RWIPLOTSHP_N->FLOW_SEQ_NUM;
