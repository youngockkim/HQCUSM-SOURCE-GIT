        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_rwiplotshp", sel_type);
}


/* Initialize Function */
void RPT_init_rwiplotshp(struct RWIPLOTSHP_TAG *RWIPLOTSHP)
{
    /* memset by Space */
    memset(RWIPLOTSHP, ' ', sizeof(struct RWIPLOTSHP_TAG));
    
    RWIPLOTSHP->HIST_SEQ = 0;
    RWIPLOTSHP->MAT_VER = 0;
    RWIPLOTSHP->FLOW_SEQ_NUM = 0;
    RWIPLOTSHP->QTY_1 = 0;
    RWIPLOTSHP->QTY_2 = 0;
    RWIPLOTSHP->QTY_3 = 0;
}


/* Add Null Function */
void RPT_add_null_rwiplotshp(struct RWIPLOTSHP_N_TAG *RWIPLOTSHP_N, struct RWIPLOTSHP_TAG *RWIPLOTSHP)
{
    /* memset by NULL */
    memset(RWIPLOTSHP_N, '\0', sizeof(struct RWIPLOTSHP_N_TAG));
    
    MEMCPY_AN(RWIPLOTSHP_N->LOT_ID, RWIPLOTSHP->LOT_ID, sizeof(RWIPLOTSHP->LOT_ID));
    RWIPLOTSHP_N->HIST_SEQ = RWIPLOTSHP->HIST_SEQ;
    MEMCPY_AN(RWIPLOTSHP_N->TRAN_TIME, RWIPLOTSHP->TRAN_TIME, sizeof(RWIPLOTSHP->TRAN_TIME));
    RWIPLOTSHP_N->HIST_DEL_FLAG[0] = RWIPLOTSHP->HIST_DEL_FLAG;
    MEMCPY_AN(RWIPLOTSHP_N->FACTORY, RWIPLOTSHP->FACTORY, sizeof(RWIPLOTSHP->FACTORY));
    MEMCPY_AN(RWIPLOTSHP_N->MAT_ID, RWIPLOTSHP->MAT_ID, sizeof(RWIPLOTSHP->MAT_ID));
    RWIPLOTSHP_N->MAT_VER = RWIPLOTSHP->MAT_VER;
    MEMCPY_AN(RWIPLOTSHP_N->FLOW, RWIPLOTSHP->FLOW, sizeof(RWIPLOTSHP->FLOW));
    RWIPLOTSHP_N->FLOW_SEQ_NUM = RWIPLOTSHP->FLOW_SEQ_NUM;
    MEMCPY_AN(RWIPLOTSHP_N->OPER, RWIPLOTSHP->OPER, sizeof(RWIPLOTSHP->OPER));
    RWIPLOTSHP_N->QTY_1 = RWIPLOTSHP->QTY_1;
    RWIPLOTSHP_N->QTY_2 = RWIPLOTSHP->QTY_2;
    RWIPLOTSHP_N->QTY_3 = RWIPLOTSHP->QTY_3;
    MEMCPY_AN(RWIPLOTSHP_N->CMF_1, RWIPLOTSHP->CMF_1, sizeof(RWIPLOTSHP->CMF_1));
    MEMCPY_AN(RWIPLOTSHP_N->CMF_2, RWIPLOTSHP->CMF_2, sizeof(RWIPLOTSHP->CMF_2));
    MEMCPY_AN(RWIPLOTSHP_N->CMF_3, RWIPLOTSHP->CMF_3, sizeof(RWIPLOTSHP->CMF_3));
    MEMCPY_AN(RWIPLOTSHP_N->CMF_4, RWIPLOTSHP->CMF_4, sizeof(RWIPLOTSHP->CMF_4));
    MEMCPY_AN(RWIPLOTSHP_N->CMF_5, RWIPLOTSHP->CMF_5, sizeof(RWIPLOTSHP->CMF_5));
    MEMCPY_AN(RWIPLOTSHP_N->CMF_6, RWIPLOTSHP->CMF_6, sizeof(RWIPLOTSHP->CMF_6));
    MEMCPY_AN(RWIPLOTSHP_N->CMF_7, RWIPLOTSHP->CMF_7, sizeof(RWIPLOTSHP->CMF_7));
