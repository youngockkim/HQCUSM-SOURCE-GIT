    MEMCPY_AN(RWIPLOTSHP_N->CMF_9, RWIPLOTSHP->CMF_9, sizeof(RWIPLOTSHP->CMF_9));
    MEMCPY_AN(RWIPLOTSHP_N->CMF_10, RWIPLOTSHP->CMF_10, sizeof(RWIPLOTSHP->CMF_10));
    MEMCPY_AN(RWIPLOTSHP_N->CMF_11, RWIPLOTSHP->CMF_11, sizeof(RWIPLOTSHP->CMF_11));
    MEMCPY_AN(RWIPLOTSHP_N->CMF_12, RWIPLOTSHP->CMF_12, sizeof(RWIPLOTSHP->CMF_12));
    MEMCPY_AN(RWIPLOTSHP_N->CMF_13, RWIPLOTSHP->CMF_13, sizeof(RWIPLOTSHP->CMF_13));
    MEMCPY_AN(RWIPLOTSHP_N->CMF_14, RWIPLOTSHP->CMF_14, sizeof(RWIPLOTSHP->CMF_14));
    MEMCPY_AN(RWIPLOTSHP_N->CMF_15, RWIPLOTSHP->CMF_15, sizeof(RWIPLOTSHP->CMF_15));
    MEMCPY_AN(RWIPLOTSHP_N->CMF_16, RWIPLOTSHP->CMF_16, sizeof(RWIPLOTSHP->CMF_16));
    MEMCPY_AN(RWIPLOTSHP_N->CMF_17, RWIPLOTSHP->CMF_17, sizeof(RWIPLOTSHP->CMF_17));
