/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rsumwiplth(int sel_type, struct RSUMWIPLTH_TAG *RSUMWIPLTH)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RSUMWIPLTH_N_TAG RSUMWIPLTH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rsumwiplth(&RSUMWIPLTH_N, RSUMWIPLTH);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RSUMWIPLTH_CUR_1 CURSOR FOR
                SELECT 
                    OPER_IN_TIME,
                    LOT_ID,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    CRR_ID,
                    LOT_TYPE,
                    LOT_PRIORITY,
                    ORDER_ID,
                    OPER_IN_QTY_1,
                    OPER_IN_QTY_2,
                    OPER_IN_QTY_3,
                    START_TIME,
                    START_RES_ID,
                    START_QTY_1,
                    START_QTY_2,
                    START_QTY_3,
                    END_TIME,
                    END_RES_ID,
                    END_QTY_1,
                    END_QTY_2,
                    END_QTY_3,
                    MOVE_TIME,
                    MOVE_QTY_1,
                    MOVE_QTY_2,
                    MOVE_QTY_3,
                    LOSS_QTY_1,
                    LOSS_QTY_2,
                    LOSS_QTY_3,
                    BONUS_QTY_1,
                    BONUS_QTY_2,
                    BONUS_QTY_3,
                    CV_QTY_1,
                    CV_QTY_2,
                    CV_QTY_3,
                    CHG_QTY_1,
                    CHG_QTY_2,
                    CHG_QTY_3,
                    TO_RWK_TIME,
                    TO_RWK_QTY_1,
                    TO_RWK_QTY_2,
                    TO_RWK_QTY_3,
                    RWK_FLAG,
                    LOT_YIELD_1,
                    LOT_YIELD_2,
                    LOT_YIELD_3,
                    QUEUE_TIME,
                    PULL_TIME,
                    HOLD_TIME,
                    PROC_TIME,
                    CUM_QUEUE_TIME,
                    CUM_PULL_TIME,
                    CUM_HOLD_TIME,
                    CUM_PROC_TIME,
                    CM_FIELD_1,
                    CM_FIELD_2,
                    CM_FIELD_3,
                    CM_FIELD_4,
                    CM_FIELD_5
                FROM RSUMWIPLTH
                ORDER BY OPER_IN_TIME ASC,
                    LOT_ID ASC;
            EXEC SQL OPEN RPT_RSUMWIPLTH_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rsumwiplth", sel_type);
}


