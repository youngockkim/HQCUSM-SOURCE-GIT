/* Add Null Function */
void RPT_add_null_rsumwiplth(struct RSUMWIPLTH_N_TAG *RSUMWIPLTH_N, struct RSUMWIPLTH_TAG *RSUMWIPLTH)
{
    /* memset by NULL */
    memset(RSUMWIPLTH_N, '\0', sizeof(struct RSUMWIPLTH_N_TAG));
    
    MEMCPY_AN(RSUMWIPLTH_N->OPER_IN_TIME, RSUMWIPLTH->OPER_IN_TIME, sizeof(RSUMWIPLTH->OPER_IN_TIME));
    MEMCPY_AN(RSUMWIPLTH_N->LOT_ID, RSUMWIPLTH->LOT_ID, sizeof(RSUMWIPLTH->LOT_ID));
    MEMCPY_AN(RSUMWIPLTH_N->FACTORY, RSUMWIPLTH->FACTORY, sizeof(RSUMWIPLTH->FACTORY));
