    RSUMWIPLTH_N->FLOW_SEQ_NUM = RSUMWIPLTH->FLOW_SEQ_NUM;
    MEMCPY_AN(RSUMWIPLTH_N->OPER, RSUMWIPLTH->OPER, sizeof(RSUMWIPLTH->OPER));
    MEMCPY_AN(RSUMWIPLTH_N->CRR_ID, RSUMWIPLTH->CRR_ID, sizeof(RSUMWIPLTH->CRR_ID));
    RSUMWIPLTH_N->LOT_TYPE[0] = RSUMWIPLTH->LOT_TYPE;
    RSUMWIPLTH_N->LOT_PRIORITY[0] = RSUMWIPLTH->LOT_PRIORITY;
    MEMCPY_AN(RSUMWIPLTH_N->ORDER_ID, RSUMWIPLTH->ORDER_ID, sizeof(RSUMWIPLTH->ORDER_ID));
