        case 2:
            EXEC SQL UPDATE RWIPLOTSTS SET
                    PRODUCT_GRP = DECODE(:RWIPLOTSTS_N.PRODUCT_GRP.IS_NULL, 'Y', NULL, :RWIPLOTSTS_N.PRODUCT_GRP.VALUE),
                    UNIT_1 = DECODE(:RWIPLOTSTS_N.UNIT_1.IS_NULL, 'Y', NULL, :RWIPLOTSTS_N.UNIT_1.VALUE),
                    UNIT_2 = DECODE(:RWIPLOTSTS_N.UNIT_2.IS_NULL, 'Y', NULL, :RWIPLOTSTS_N.UNIT_2.VALUE),
                    UNIT_3 = DECODE(:RWIPLOTSTS_N.UNIT_3.IS_NULL, 'Y', NULL, :RWIPLOTSTS_N.UNIT_3.VALUE),
                    ORIG_OPER = DECODE(:RWIPLOTSTS_N.ORIG_OPER.IS_NULL, 'Y', NULL, :RWIPLOTSTS_N.ORIG_OPER.VALUE)
                WHERE LOT_ID = :RWIPLOTSTS_N.LOT_ID;
            break;

        case 3:
            EXEC SQL UPDATE RWIPLOTSTS SET
                    DATE_CREATE = SYSDATE
                WHERE LOT_ID = :RWIPLOTSTS_N.LOT_ID;
            break;

        case 4:
            EXEC SQL UPDATE RWIPLOTSTS SET
                    DATE_CREATE = TO_DATE(:RWIPLOTSTS_N.DATE_CREATE.VALUE, 'YYYYMMDDHH24MISS'),
                    DATE_UPDATE = SYSDATE
                WHERE LOT_ID = :RWIPLOTSTS_N.LOT_ID;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_update_rwiplotsts", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rwiplotsts(int sel_type, struct RWIPLOTSTS_TAG *RWIPLOTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTSTS_N_TAG RWIPLOTSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplotsts(&RWIPLOTSTS_N, RWIPLOTSTS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RWIPLOTSTS_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    DECODE(LOT_DESC, NULL, 'Y', ' '), NVL(LOT_DESC, ' '),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '),
                    DECODE(MAT_ID, NULL, 'Y', ' '), NVL(MAT_ID, ' '),
                    DECODE(MAT_VER, NULL, 'Y', ' '), NVL(MAT_VER, '0'),
                    DECODE(FLOW, NULL, 'Y', ' '), NVL(FLOW, ' '),
                    DECODE(FLOW_SEQ_NUM, NULL, 'Y', ' '), NVL(FLOW_SEQ_NUM, '0'),
                    DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
                    DECODE(QTY_1, NULL, 'Y', ' '), NVL(QTY_1, '0'),
                    DECODE(QTY_2, NULL, 'Y', ' '), NVL(QTY_2, '0'),
                    DECODE(QTY_3, NULL, 'Y', ' '), NVL(QTY_3, '0'),
                    DECODE(CRR_ID, NULL, 'Y', ' '), NVL(CRR_ID, ' '),
                    LOT_TYPE,
                    DECODE(OWNER_CODE, NULL, 'Y', ' '), NVL(OWNER_CODE, ' '),
                    DECODE(CREATE_CODE, NULL, 'Y', ' '), NVL(CREATE_CODE, ' '),
                    LOT_PRIORITY,
                    DECODE(LOT_STATUS, NULL, 'Y', ' '), NVL(LOT_STATUS, ' '),
                    DECODE(HOLD_FLAG, NULL, 'Y', ' '), NVL(HOLD_FLAG, 'N'),
                    DECODE(HOLD_CODE, NULL, 'Y', ' '), NVL(HOLD_CODE, ' '),
                    DECODE(HOLD_PASSWORD, NULL, 'Y', ' '), NVL(HOLD_PASSWORD, ' '),
                    DECODE(HOLD_PRV_GRP_ID, NULL, 'Y', ' '), NVL(HOLD_PRV_GRP_ID, ' '),
                    DECODE(OPER_IN_QTY_1, NULL, 'Y', ' '), NVL(OPER_IN_QTY_1, '0'),
                    DECODE(OPER_IN_QTY_2, NULL, 'Y', ' '), NVL(OPER_IN_QTY_2, '0'),
                    DECODE(OPER_IN_QTY_3, NULL, 'Y', ' '), NVL(OPER_IN_QTY_3, '0'),
                    DECODE(CREATE_QTY_1, NULL, 'Y', ' '), NVL(CREATE_QTY_1, '0'),
                    DECODE(CREATE_QTY_2, NULL, 'Y', ' '), NVL(CREATE_QTY_2, '0'),
