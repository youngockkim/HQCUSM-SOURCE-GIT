                    DATE_CREATE = DECODE(:RWIPLOTSTS_N.DATE_CREATE.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTSTS_N.DATE_CREATE.VALUE, 'YYYYMMDDHH24MISS')),
