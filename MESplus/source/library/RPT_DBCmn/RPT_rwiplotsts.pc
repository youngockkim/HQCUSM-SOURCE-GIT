/* SQL INSERT-SELECT Function */
/* Added By Daniel Kim (2007. 12. 03) */
void RPT_insert_select_rwiplotsts(struct RWIPLOTSTS_TAG *RWIPLOTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTSTS_N_TAG RWIPLOTSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplotsts(&RWIPLOTSTS_N, RWIPLOTSTS);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RWIPLOTSTS
		SELECT   
			LOT_ID, 
			DECODE(TRIM(LOT_DESC), '', NULL, LOT_DESC), 
			DECODE(TRIM(FACTORY), '', NULL, FACTORY), 
			DECODE(TRIM(MAT_ID), '', NULL, MAT_ID), 
			DECODE(TRIM(MAT_VER), '', NULL, MAT_VER), 
			DECODE(TRIM(FLOW), '', NULL, FLOW), 
			DECODE(TRIM(FLOW_SEQ_NUM), '', NULL, FLOW_SEQ_NUM), 
			DECODE(TRIM(OPER), '', NULL, OPER), 
			DECODE(TRIM(QTY_1), '', NULL, QTY_1), 
			DECODE(TRIM(QTY_2), '', NULL, QTY_2), 
