                :RWIPLOTSTS_N.PRODUCT_GRP.IS_NULL, :RWIPLOTSTS_N.PRODUCT_GRP.VALUE,
                :RWIPLOTSTS_N.UNIT_1.IS_NULL, :RWIPLOTSTS_N.UNIT_1.VALUE,
                :RWIPLOTSTS_N.UNIT_2.IS_NULL, :RWIPLOTSTS_N.UNIT_2.VALUE,
                :RWIPLOTSTS_N.UNIT_3.IS_NULL, :RWIPLOTSTS_N.UNIT_3.VALUE,
                :RWIPLOTSTS_N.ORIG_OPER.IS_NULL, :RWIPLOTSTS_N.ORIG_OPER.VALUE,
                :RWIPLOTSTS_N.DATE_CREATE.IS_NULL, :RWIPLOTSTS_N.DATE_CREATE.VALUE,
                :RWIPLOTSTS_N.DATE_UPDATE.IS_NULL, :RWIPLOTSTS_N.DATE_UPDATE.VALUE;
            break;

        case 2:
            EXEC SQL FETCH RPT_RWIPLOTSTS_CUR_2 
            INTO :RWIPLOTSTS_N.FACTORY.IS_NULL, :RWIPLOTSTS_N.FACTORY.VALUE, 
                 :RWIPLOTSTS_N.MAT_ID.IS_NULL, :RWIPLOTSTS_N.MAT_ID.VALUE, 
                 :RWIPLOTSTS_N.FLOW.IS_NULL, :RWIPLOTSTS_N.FLOW.VALUE, 
                 :RWIPLOTSTS_N.OPER.IS_NULL, :RWIPLOTSTS_N.OPER.VALUE, 
                 :RWIPLOTSTS_N.LOT_TYPE, 
                 :RWIPLOTSTS_N.HOLD_FLAG.IS_NULL, :RWIPLOTSTS_N.HOLD_FLAG.VALUE, 
                 :RWIPLOTSTS_N.RWK_FLAG.IS_NULL, :RWIPLOTSTS_N.RWK_FLAG.VALUE,
                 :RWIPLOTSTS_N.RWK_COUNT.IS_NULL, :RWIPLOTSTS_N.RWK_COUNT.VALUE, 
                 :RWIPLOTSTS_N.QTY_1.IS_NULL, :RWIPLOTSTS_N.QTY_1.VALUE,
                 :RWIPLOTSTS_N.QTY_2.IS_NULL, :RWIPLOTSTS_N.QTY_2.VALUE,
                 :RWIPLOTSTS_N.QTY_3.IS_NULL, :RWIPLOTSTS_N.QTY_3.VALUE,
                 :RWIPLOTSTS_N.OPER_IN_QTY_1.IS_NULL, :RWIPLOTSTS_N.OPER_IN_QTY_1.VALUE,
                 :RWIPLOTSTS_N.OPER_IN_QTY_2.IS_NULL, :RWIPLOTSTS_N.OPER_IN_QTY_2.VALUE,
                 :RWIPLOTSTS_N.OPER_IN_QTY_3.IS_NULL, :RWIPLOTSTS_N.OPER_IN_QTY_3.VALUE,
                 :RWIPLOTSTS_N.CREATE_QTY_1.IS_NULL, :RWIPLOTSTS_N.CREATE_QTY_1.VALUE,
                 :RWIPLOTSTS_N.CREATE_QTY_2.IS_NULL, :RWIPLOTSTS_N.CREATE_QTY_2.VALUE,
                 :RWIPLOTSTS_N.CREATE_QTY_3.IS_NULL, :RWIPLOTSTS_N.CREATE_QTY_3.VALUE;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rwiplotsts(&RWIPLOTSTS_N, RWIPLOTSTS);
    }
    DB_stop_query_timer("RPT_fetch_rwiplotsts", sel_type);
}


/* SQL CURSOR CLOSE Function */
void RPT_close_rwiplotsts(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_RWIPLOTSTS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE RPT_RWIPLOTSTS_CUR_2;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_rwiplotsts", sel_type);
}


