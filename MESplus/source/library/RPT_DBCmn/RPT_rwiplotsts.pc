                    DECODE(LOT_CMF_15, NULL, 'Y', ' '), NVL(LOT_CMF_15, ' '),
                    DECODE(LOT_CMF_16, NULL, 'Y', ' '), NVL(LOT_CMF_16, ' '),
                    DECODE(LOT_CMF_17, NULL, 'Y', ' '), NVL(LOT_CMF_17, ' '),
                    DECODE(LOT_CMF_18, NULL, 'Y', ' '), NVL(LOT_CMF_18, ' '),
                    DECODE(LOT_CMF_19, NULL, 'Y', ' '), NVL(LOT_CMF_19, ' '),
                    DECODE(LOT_CMF_20, NULL, 'Y', ' '), NVL(LOT_CMF_20, ' '),
                    DECODE(LOT_DEL_FLAG, NULL, 'Y', ' '), NVL(LOT_DEL_FLAG, ' '),
                    DECODE(LOT_DEL_CODE, NULL, 'Y', ' '), NVL(LOT_DEL_CODE, ' '),
                    DECODE(LOT_DEL_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(LOT_DEL_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(BOM_SET_ID, NULL, 'Y', ' '), NVL(BOM_SET_ID, ' '),
                    DECODE(BOM_SET_VERSION, NULL, 'Y', ' '), NVL(BOM_SET_VERSION, '0'),
                    DECODE(BOM_ACTIVE_HIST_SEQ, NULL, 'Y', ' '), NVL(BOM_ACTIVE_HIST_SEQ, '0'),
                    DECODE(BOM_HIST_SEQ, NULL, 'Y', ' '), NVL(BOM_HIST_SEQ, '0'),
                    DECODE(LAST_TRAN_CODE, NULL, 'Y', ' '), NVL(LAST_TRAN_CODE, ' '),
                    DECODE(LAST_TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(LAST_TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(LAST_COMMENT, NULL, 'Y', ' '), NVL(LAST_COMMENT, ' '),
                    DECODE(LAST_ACTIVE_HIST_SEQ, NULL, 'Y', ' '), NVL(LAST_ACTIVE_HIST_SEQ, '0'),
                    DECODE(LAST_HIST_SEQ, NULL, 'Y', ' '), NVL(LAST_HIST_SEQ, '0'),
                    DECODE(CRITICAL_RES_ID, NULL, 'Y', ' '), NVL(CRITICAL_RES_ID, ' '),
                    DECODE(CRITICAL_RES_GROUP_ID, NULL, 'Y', ' '), NVL(CRITICAL_RES_GROUP_ID, ' '),
                    DECODE(SAVE_RES_ID_1, NULL, 'Y', ' '), NVL(SAVE_RES_ID_1, ' '),
                    DECODE(SAVE_RES_ID_2, NULL, 'Y', ' '), NVL(SAVE_RES_ID_2, ' '),
                    DECODE(SUBRES_ID, NULL, 'Y', ' '), NVL(SUBRES_ID, ' '),
                    DECODE(LOT_GROUP_ID_1, NULL, 'Y', ' '), NVL(LOT_GROUP_ID_1, ' '),
                    DECODE(LOT_GROUP_ID_2, NULL, 'Y', ' '), NVL(LOT_GROUP_ID_2, ' '),
                    DECODE(LOT_GROUP_ID_3, NULL, 'Y', ' '), NVL(LOT_GROUP_ID_3, ' '),
                    DECODE(YIELD_1, NULL, 'Y', ' '), NVL(YIELD_1, '0'),
                    DECODE(YIELD_2, NULL, 'Y', ' '), NVL(YIELD_2, '0'),
                    DECODE(YIELD_3, NULL, 'Y', ' '), NVL(YIELD_3, '0'),
                    DECODE(GOOD_QTY, NULL, 'Y', ' '), NVL(GOOD_QTY, '0'),
                    DECODE(RESV_FIELD_1, NULL, 'Y', ' '), NVL(RESV_FIELD_1, ' '),
                    DECODE(RESV_FIELD_2, NULL, 'Y', ' '), NVL(RESV_FIELD_2, ' '),
                    DECODE(RESV_FIELD_3, NULL, 'Y', ' '), NVL(RESV_FIELD_3, ' '),
                    DECODE(RESV_FIELD_4, NULL, 'Y', ' '), NVL(RESV_FIELD_4, ' '),
                    DECODE(RESV_FIELD_5, NULL, 'Y', ' '), NVL(RESV_FIELD_5, ' '),
                    DECODE(RESV_FLAG_1, NULL, 'Y', ' '), NVL(RESV_FLAG_1, ' '),
                    DECODE(RESV_FLAG_2, NULL, 'Y', ' '), NVL(RESV_FLAG_2, ' '),
                    DECODE(RESV_FLAG_3, NULL, 'Y', ' '), NVL(RESV_FLAG_3, ' '),
                    DECODE(RESV_FLAG_4, NULL, 'Y', ' '), NVL(RESV_FLAG_4, ' '),
                    DECODE(RESV_FLAG_5, NULL, 'Y', ' '), NVL(RESV_FLAG_5, ' '),
                    DECODE(PRODUCT_GRP, NULL, 'Y', ' '), NVL(PRODUCT_GRP, ' '),
                    DECODE(UNIT_1, NULL, 'Y', ' '), NVL(UNIT_1, ' '),
                    DECODE(UNIT_2, NULL, 'Y', ' '), NVL(UNIT_2, ' '),
                    DECODE(UNIT_3, NULL, 'Y', ' '), NVL(UNIT_3, ' '),
                    DECODE(ORIG_OPER, NULL, 'Y', ' '), NVL(ORIG_OPER, ' '),
                    DECODE(DATE_CREATE, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_CREATE, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(DATE_UPDATE, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_UPDATE, 'YYYYMMDDHH24MISS'), ' ')
                FROM RWIPLOTSTS
                ORDER BY LOT_ID ASC;
            EXEC SQL OPEN RPT_RWIPLOTSTS_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE RPT_RWIPLOTSTS_CUR_2 CURSOR FOR
                SELECT DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '), 
                       DECODE(MAT_ID, NULL, 'Y', ' '), NVL(MAT_ID, ' '), 
                       DECODE(FLOW, NULL, 'Y', ' '), NVL(FLOW, ' '), 
                       DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '), 
                       LOT_TYPE, 
                       DECODE(HOLD_FLAG, NULL, 'Y', ' '), NVL(HOLD_FLAG, 'N'), 
                       DECODE(RWK_FLAG, NULL, 'Y', ' '), NVL(RWK_FLAG, ' '),
                       ' ', COUNT(*) AS LOTS, 
                       ' ', SUM(QTY_1) AS QTY_1, 
                       ' ', SUM(QTY_2) AS QTY_2, 
                       ' ', SUM(QTY_3) AS QTY_3,
                       ' ', SUM(OPER_IN_QTY_1) AS OPER_IN_QTY_1, 
                       ' ', SUM(OPER_IN_QTY_2) AS OPER_IN_QTY_2, 
                       ' ', SUM(OPER_IN_QTY_3) AS OPER_IN_QTY_3,
                       ' ', SUM(CREATE_QTY_1) AS CREATE_QTY_1, 
                       ' ', SUM(CREATE_QTY_2) AS CREATE_QTY_2, 
                       ' ', SUM(CREATE_QTY_3) AS CREATE_QTY_3
                FROM RWIPLOTSTS
                WHERE TRANSIT_FLAG <> 'Y' 
                  AND LOT_DEL_FLAG <> 'Y' 
                GROUP BY FACTORY, MAT_ID, FLOW, OPER, LOT_TYPE, HOLD_FLAG, RWK_FLAG;
            EXEC SQL OPEN RPT_RWIPLOTSTS_CUR_2;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rwiplotsts", sel_type);
}


