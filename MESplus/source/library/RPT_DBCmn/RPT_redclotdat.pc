                :REDCLOTDAT_N.PROC_FLOW.IS_NULL, :REDCLOTDAT_N.PROC_FLOW.VALUE,
                :REDCLOTDAT_N.PROC_OPER.IS_NULL, :REDCLOTDAT_N.PROC_OPER.VALUE,
                :REDCLOTDAT_N.PROC_RES_ID.IS_NULL, :REDCLOTDAT_N.PROC_RES_ID.VALUE,
                :REDCLOTDAT_N.RECIPE_ID.IS_NULL, :REDCLOTDAT_N.RECIPE_ID.VALUE,
                :REDCLOTDAT_N.RECIPE_VERSION.IS_NULL, :REDCLOTDAT_N.RECIPE_VERSION.VALUE,
                :REDCLOTDAT_N.COL_SET_ID,
                :REDCLOTDAT_N.COL_SET_VERSION.IS_NULL, :REDCLOTDAT_N.COL_SET_VERSION.VALUE,
                :REDCLOTDAT_N.CHAR_SEQ_NUM,
                :REDCLOTDAT_N.CHAR_ID.IS_NULL, :REDCLOTDAT_N.CHAR_ID.VALUE,
                :REDCLOTDAT_N.UNIT_SEQ_NUM,
                :REDCLOTDAT_N.UNIT_ID.IS_NULL, :REDCLOTDAT_N.UNIT_ID.VALUE,
                :REDCLOTDAT_N.VALUE_SEQ_NUM,
                :REDCLOTDAT_N.VALUE_TYPE.IS_NULL, :REDCLOTDAT_N.VALUE_TYPE.VALUE,
                :REDCLOTDAT_N.VALUE_COUNT.IS_NULL, :REDCLOTDAT_N.VALUE_COUNT.VALUE,
                :REDCLOTDAT_N.VALUE_1.IS_NULL, :REDCLOTDAT_N.VALUE_1.VALUE,
