{
    /* memset by NULL */
    memset(REDCLOTDAT_N, '\0', sizeof(struct REDCLOTDAT_N_TAG));
    
    MEMCPY_AN(REDCLOTDAT_N->LOT_ID, REDCLOTDAT->LOT_ID, sizeof(REDCLOTDAT->LOT_ID));
    REDCLOTDAT_N->HIST_SEQ = REDCLOTDAT->HIST_SEQ;
