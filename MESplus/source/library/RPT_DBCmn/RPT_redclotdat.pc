                    DECODE(SPEC_OUT_MASK, NULL, 'Y', ' '), NVL(SPEC_OUT_MASK, ' '),
                    DECODE(CREATE_USER_ID, NULL, 'Y', ' '), NVL(CREATE_USER_ID, ' '),
                    DECODE(CREATE_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(CREATE_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(UPDATE_USER_ID, NULL, 'Y', ' '), NVL(UPDATE_USER_ID, ' '),
                    DECODE(UPDATE_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(UPDATE_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(DELETE_USER_ID, NULL, 'Y', ' '), NVL(DELETE_USER_ID, ' '),
                    DECODE(DELETE_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(DELETE_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(DEL_HIST_DATE, NULL, 'Y', ' '), NVL(TO_CHAR(DEL_HIST_DATE, 'YYYYMMDDHH24MISS'), ' ')
                FROM REDCLOTDAT
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC,
                    COL_SEQ ASC,
                    COL_SET_ID ASC,
                    CHAR_SEQ_NUM ASC,
                    UNIT_SEQ_NUM ASC,
                    VALUE_SEQ_NUM ASC;
            EXEC SQL OPEN RPT_REDCLOTDAT_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_redclotdat", sel_type);
}


/* SQL CURSOR FETCH Function */
void RPT_fetch_redclotdat(int sel_type, struct REDCLOTDAT_TAG *REDCLOTDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct REDCLOTDAT_N_TAG REDCLOTDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_REDCLOTDAT_CUR_1 INTO
                :REDCLOTDAT_N.LOT_ID,
                :REDCLOTDAT_N.HIST_SEQ,
                :REDCLOTDAT_N.COL_SEQ,
                :REDCLOTDAT_N.TRAN_TIME.IS_NULL, :REDCLOTDAT_N.TRAN_TIME.VALUE,
                :REDCLOTDAT_N.HIST_DEL_FLAG.IS_NULL, :REDCLOTDAT_N.HIST_DEL_FLAG.VALUE,
