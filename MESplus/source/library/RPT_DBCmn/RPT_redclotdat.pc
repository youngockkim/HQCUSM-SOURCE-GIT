/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_redclotdat(int sel_type, struct REDCLOTDAT_TAG *REDCLOTDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct REDCLOTDAT_N_TAG REDCLOTDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_redclotdat(&REDCLOTDAT_N, REDCLOTDAT);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_REDCLOTDAT_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
