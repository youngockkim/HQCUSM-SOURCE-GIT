/* SQL UPDATE Function */
void RPT_update_rwiplotdel(int sel_type, struct RWIPLOTDEL_TAG *RWIPLOTDEL)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTDEL_N_TAG RWIPLOTDEL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplotdel(&RWIPLOTDEL_N, RWIPLOTDEL);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE RWIPLOTDEL SET
                    TRAN_TIME = DECODE(:RWIPLOTDEL_N.TRAN_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTDEL_N.TRAN_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    TRAN_CODE = DECODE(:RWIPLOTDEL_N.TRAN_CODE.IS_NULL, 'Y', NULL, :RWIPLOTDEL_N.TRAN_CODE.VALUE),
                    LOT_DESC = DECODE(:RWIPLOTDEL_N.LOT_DESC.IS_NULL, 'Y', NULL, :RWIPLOTDEL_N.LOT_DESC.VALUE),
                    FACTORY = DECODE(:RWIPLOTDEL_N.FACTORY.IS_NULL, 'Y', NULL, :RWIPLOTDEL_N.FACTORY.VALUE),
                    MAT_ID = DECODE(:RWIPLOTDEL_N.MAT_ID.IS_NULL, 'Y', NULL, :RWIPLOTDEL_N.MAT_ID.VALUE),
