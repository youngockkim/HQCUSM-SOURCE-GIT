            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rwiplotdel(&RWIPLOTDEL_N, RWIPLOTDEL);
    }
    DB_stop_query_timer("RPT_select_rwiplotdel", sel_type);
