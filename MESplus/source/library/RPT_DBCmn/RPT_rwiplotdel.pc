/* SQL SELECT_SCALAR Function */
double RPT_select_rwiplotdel_scalar(int sel_type, struct RWIPLOTDEL_TAG *RWIPLOTDEL)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTDEL_N_TAG RWIPLOTDEL_N;
    	double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplotdel(&RWIPLOTDEL_N, RWIPLOTDEL);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM RWIPLOTDEL
                WHERE LOT_ID = :RWIPLOTDEL_N.LOT_ID
                    AND HIST_SEQ = :RWIPLOTDEL_N.HIST_SEQ
                    AND SYS_TRAN_TIME = TO_DATE(:RWIPLOTDEL_N.SYS_TRAN_TIME, 'YYYYMMDDHH24MISS');
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("RPT_select_rwiplotdel_scalar", sel_type);
    return d_value;
}


