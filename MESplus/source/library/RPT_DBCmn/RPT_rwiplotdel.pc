/* Add Null Function */
void RPT_add_null_rwiplotdel(struct RWIPLOTDEL_N_TAG *RWIPLOTDEL_N, struct RWIPLOTDEL_TAG *RWIPLOTDEL)
{
    /* memset by NULL */
    memset(RWIPLOTDEL_N, '\0', sizeof(struct RWIPLOTDEL_N_TAG));
    
    MEMCPY_AN(RWIPLOTDEL_N->LOT_ID, RWIPLOTDEL->LOT_ID, sizeof(RWIPLOTDEL->LOT_ID));
    RWIPLOTDEL_N->HIST_SEQ = RWIPLOTDEL->HIST_SEQ;
    RWIPLOTDEL_N->TRAN_TIME.IS_NULL[0] = RWIPLOTDEL->TRAN_TIME.IS_NULL;
    MEMCPY_AN(RWIPLOTDEL_N->TRAN_TIME.VALUE, RWIPLOTDEL->TRAN_TIME.VALUE, sizeof(RWIPLOTDEL->TRAN_TIME.VALUE));
    MEMCPY_AN(RWIPLOTDEL_N->SYS_TRAN_TIME, RWIPLOTDEL->SYS_TRAN_TIME, sizeof(RWIPLOTDEL->SYS_TRAN_TIME));
    RWIPLOTDEL_N->TRAN_CODE.IS_NULL[0] = RWIPLOTDEL->TRAN_CODE.IS_NULL;
    MEMCPY_AN(RWIPLOTDEL_N->TRAN_CODE.VALUE, RWIPLOTDEL->TRAN_CODE.VALUE, sizeof(RWIPLOTDEL->TRAN_CODE.VALUE));
    RWIPLOTDEL_N->LOT_DESC.IS_NULL[0] = RWIPLOTDEL->LOT_DESC.IS_NULL;
    MEMCPY_AN(RWIPLOTDEL_N->LOT_DESC.VALUE, RWIPLOTDEL->LOT_DESC.VALUE, sizeof(RWIPLOTDEL->LOT_DESC.VALUE));
    RWIPLOTDEL_N->FACTORY.IS_NULL[0] = RWIPLOTDEL->FACTORY.IS_NULL;
    MEMCPY_AN(RWIPLOTDEL_N->FACTORY.VALUE, RWIPLOTDEL->FACTORY.VALUE, sizeof(RWIPLOTDEL->FACTORY.VALUE));
    RWIPLOTDEL_N->MAT_ID.IS_NULL[0] = RWIPLOTDEL->MAT_ID.IS_NULL;
    MEMCPY_AN(RWIPLOTDEL_N->MAT_ID.VALUE, RWIPLOTDEL->MAT_ID.VALUE, sizeof(RWIPLOTDEL->MAT_ID.VALUE));
    RWIPLOTDEL_N->MAT_VER.IS_NULL[0] = RWIPLOTDEL->MAT_VER.IS_NULL;
    RWIPLOTDEL_N->MAT_VER.VALUE = RWIPLOTDEL->MAT_VER.VALUE;
    RWIPLOTDEL_N->FLOW.IS_NULL[0] = RWIPLOTDEL->FLOW.IS_NULL;
    MEMCPY_AN(RWIPLOTDEL_N->FLOW.VALUE, RWIPLOTDEL->FLOW.VALUE, sizeof(RWIPLOTDEL->FLOW.VALUE));
    RWIPLOTDEL_N->FLOW_SEQ_NUM.IS_NULL[0] = RWIPLOTDEL->FLOW_SEQ_NUM.IS_NULL;
    RWIPLOTDEL_N->FLOW_SEQ_NUM.VALUE = RWIPLOTDEL->FLOW_SEQ_NUM.VALUE;
