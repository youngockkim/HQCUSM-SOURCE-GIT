/* SQL SELECT_FOR_UPDATE Function */
void RPT_select_rwiplotdel_for_update(int sel_type, struct RWIPLOTDEL_TAG *RWIPLOTDEL)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTDEL_N_TAG RWIPLOTDEL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplotdel(&RWIPLOTDEL_N, RWIPLOTDEL);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    NVL(TO_CHAR(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(TRAN_CODE, NULL, 'Y', ' '), NVL(TRAN_CODE, ' '),
                    DECODE(LOT_DESC, NULL, 'Y', ' '), NVL(LOT_DESC, ' '),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '),
                    DECODE(MAT_ID, NULL, 'Y', ' '), NVL(MAT_ID, ' '),
                    DECODE(MAT_VER, NULL, 'Y', ' '), NVL(MAT_VER, '0'),
                    DECODE(FLOW, NULL, 'Y', ' '), NVL(FLOW, ' '),
                    DECODE(FLOW_SEQ_NUM, NULL, 'Y', ' '), NVL(FLOW_SEQ_NUM, '0'),
                    DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
                    DECODE(QTY_1, NULL, 'Y', ' '), NVL(QTY_1, '0'),
                    DECODE(QTY_2, NULL, 'Y', ' '), NVL(QTY_2, '0'),
                    DECODE(QTY_3, NULL, 'Y', ' '), NVL(QTY_3, '0'),
                    DECODE(CRR_ID, NULL, 'Y', ' '), NVL(CRR_ID, ' '),
                    LOT_TYPE,
                    DECODE(OWNER_CODE, NULL, 'Y', ' '), NVL(OWNER_CODE, ' '),
                    DECODE(CREATE_CODE, NULL, 'Y', ' '), NVL(CREATE_CODE, ' '),
                    LOT_PRIORITY,
                    DECODE(LOT_STATUS, NULL, 'Y', ' '), NVL(LOT_STATUS, ' '),
                    DECODE(HOLD_FLAG, NULL, 'Y', ' '), NVL(HOLD_FLAG, ' '),
                    DECODE(HOLD_CODE, NULL, 'Y', ' '), NVL(HOLD_CODE, ' '),
                    DECODE(HOLD_PASSWORD, NULL, 'Y', ' '), NVL(HOLD_PASSWORD, ' '),
                    DECODE(HOLD_PRV_GRP_ID, NULL, 'Y', ' '), NVL(HOLD_PRV_GRP_ID, ' '),
                    DECODE(OPER_IN_QTY_1, NULL, 'Y', ' '), NVL(OPER_IN_QTY_1, '0'),
                    DECODE(OPER_IN_QTY_2, NULL, 'Y', ' '), NVL(OPER_IN_QTY_2, '0'),
                    DECODE(OPER_IN_QTY_3, NULL, 'Y', ' '), NVL(OPER_IN_QTY_3, '0'),
