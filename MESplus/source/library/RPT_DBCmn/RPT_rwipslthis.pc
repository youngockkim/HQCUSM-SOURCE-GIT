                    :RWIPSLTHIS_N.RESV_FLAG_1.IS_NULL, :RWIPSLTHIS_N.RESV_FLAG_1.VALUE, 
                    :RWIPSLTHIS_N.RESV_FLAG_2.IS_NULL, :RWIPSLTHIS_N.RESV_FLAG_2.VALUE, 
                    :RWIPSLTHIS_N.RESV_FLAG_3.IS_NULL, :RWIPSLTHIS_N.RESV_FLAG_3.VALUE, 
                    :RWIPSLTHIS_N.RESV_FLAG_4.IS_NULL, :RWIPSLTHIS_N.RESV_FLAG_4.VALUE, 
                    :RWIPSLTHIS_N.RESV_FLAG_5.IS_NULL, :RWIPSLTHIS_N.RESV_FLAG_5.VALUE 
                FROM RWIPSLTHIS
                WHERE SUBLOT_ID = :RWIPSLTHIS_N.SUBLOT_ID
				  AND HIST_SEQ = (SELECT NVL(MAX(HIST_SEQ) , 0)
									FROM RWIPSLTHIS
								   WHERE SUBLOT_ID = :RWIPSLTHIS_N.SUBLOT_ID
									 AND HIST_DEL_FLAG = 'N'
									 AND HIST_SEQ < :RWIPSLTHIS_N.HIST_SEQ);
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rwipslthis(&RWIPSLTHIS_N, RWIPSLTHIS);
    }
    DB_stop_query_timer("RPT_select_rwipslthis", sel_type);
}


/* SQL SELECT_FOR_UPDATE Function */
void RPT_select_rwipslthis_for_update(int sel_type, struct RWIPSLTHIS_TAG *RWIPSLTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPSLTHIS_N_TAG RWIPSLTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwipslthis(&RWIPSLTHIS_N, RWIPSLTHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT 
                    SUBLOT_ID,
                    HIST_SEQ,
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
