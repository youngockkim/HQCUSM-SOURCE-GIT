        case 2:
            EXEC SQL UPDATE RWIPSLTHIS SET
                    HIST_DEL_FLAG = DECODE(:RWIPSLTHIS_N.HIST_DEL_FLAG.IS_NULL, 'Y', 'N', :RWIPSLTHIS_N.HIST_DEL_FLAG.VALUE),
                    HIST_DEL_TIME = DECODE(:RWIPSLTHIS_N.HIST_DEL_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPSLTHIS_N.HIST_DEL_TIME.VALUE, 'YYYYMMDDHH24MISS')),
