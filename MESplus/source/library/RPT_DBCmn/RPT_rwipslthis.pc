                    DECODE(RWK_RET_CLEAR_FLAG, NULL, 'Y', ' '), NVL(RWK_RET_CLEAR_FLAG, ' '),
                    DECODE(RWK_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(RWK_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(NSTD_FLAG, NULL, 'Y', ' '), NVL(NSTD_FLAG, ' '),
                    DECODE(NSTD_RET_FLOW, NULL, 'Y', ' '), NVL(NSTD_RET_FLOW, ' '),
                    DECODE(NSTD_RET_FLOW_SEQ_NUM, NULL, 'Y', ' '), NVL(NSTD_RET_FLOW_SEQ_NUM, '0'),
