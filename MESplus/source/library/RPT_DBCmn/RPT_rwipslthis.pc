                    HIST_DEL_COMMENT = DECODE(:RWIPSLTHIS_N.HIST_DEL_COMMENT.IS_NULL, 'Y', NULL, :RWIPSLTHIS_N.HIST_DEL_COMMENT.VALUE)
                WHERE SUBLOT_ID = :RWIPSLTHIS_N.SUBLOT_ID
                    AND HIST_SEQ = :RWIPSLTHIS_N.HIST_SEQ;
            break;

        case 3:
            EXEC SQL UPDATE RWIPSLTHIS SET
                    OLD_GRADE = DECODE(:RWIPSLTHIS_N.OLD_GRADE.IS_NULL, 'Y', NULL, :RWIPSLTHIS_N.OLD_GRADE.VALUE),
                    OLD_LOT_ID = DECODE(:RWIPSLTHIS_N.OLD_LOT_ID.IS_NULL, 'Y', NULL, :RWIPSLTHIS_N.OLD_LOT_ID.VALUE),
                    OLD_SLOT_NO = DECODE(:RWIPSLTHIS_N.OLD_SLOT_NO.IS_NULL, 'Y', NULL, :RWIPSLTHIS_N.OLD_SLOT_NO.VALUE)
                WHERE SUBLOT_ID = :RWIPSLTHIS_N.SUBLOT_ID
                    AND HIST_SEQ = :RWIPSLTHIS_N.HIST_SEQ;
            break;
            
        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_update_rwipslthis", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rwipslthis(int sel_type, struct RWIPSLTHIS_TAG *RWIPSLTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPSLTHIS_N_TAG RWIPSLTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwipslthis(&RWIPSLTHIS_N, RWIPSLTHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RWIPSLTHIS_CUR_1 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    HIST_SEQ,
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(SYS_TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(TRAN_CODE, NULL, 'Y', ' '), NVL(TRAN_CODE, ' '),
                    DECODE(LOT_ID, NULL, 'Y', ' '), NVL(LOT_ID, ' '),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '),
                    DECODE(MAT_ID, NULL, 'Y', ' '), NVL(MAT_ID, ' '),
                    DECODE(MAT_VER, NULL, 'Y', ' '), NVL(MAT_VER, '0'),
                    DECODE(FLOW, NULL, 'Y', ' '), NVL(FLOW, ' '),
                    DECODE(FLOW_SEQ_NUM, NULL, 'Y', ' '), NVL(FLOW_SEQ_NUM, '0'),
                    DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
                    DECODE(SLOT_NO, NULL, 'Y', ' '), NVL(SLOT_NO, '0'),
                    DECODE(QTY_2, NULL, 'Y', ' '), NVL(QTY_2, '0'),
                    DECODE(QTY_3, NULL, 'Y', ' '), NVL(QTY_3, '0'),
                    DECODE(CRR_ID, NULL, 'Y', ' '), NVL(CRR_ID, ' '),
