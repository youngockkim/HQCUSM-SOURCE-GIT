/* SQL UPDATE Function */
void RPT_update_rwipslthis(int sel_type, struct RWIPSLTHIS_TAG *RWIPSLTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPSLTHIS_N_TAG RWIPSLTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwipslthis(&RWIPSLTHIS_N, RWIPSLTHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE RWIPSLTHIS SET
                    TRAN_TIME = DECODE(:RWIPSLTHIS_N.TRAN_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPSLTHIS_N.TRAN_TIME.VALUE, 'YYYYMMDDHH24MISS')),
