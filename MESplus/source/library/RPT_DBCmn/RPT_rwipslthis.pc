/* SQL INSERT-SELECT Function */
void RPT_insert_select_rwipslthis(struct RWIPSLTHIS_TAG *RWIPSLTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPSLTHIS_N_TAG RWIPSLTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwipslthis(&RWIPSLTHIS_N, RWIPSLTHIS);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RWIPSLTHIS
        SELECT
			SUBLOT_ID,
			HIST_SEQ,
			DECODE(TRIM(TRAN_TIME), '', NULL, TO_DATE(TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(SYS_TRAN_TIME), '', NULL, TO_DATE(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(TRAN_CODE), '', NULL, TRAN_CODE),
			DECODE(TRIM(LOT_ID), '', NULL, LOT_ID),
			DECODE(TRIM(FACTORY), '', NULL, FACTORY),
			DECODE(TRIM(MAT_ID), '', NULL, MAT_ID),
			DECODE(TRIM(MAT_VER), '', NULL, MAT_VER),
			DECODE(TRIM(FLOW), '', NULL, FLOW),
			DECODE(TRIM(FLOW_SEQ_NUM), '', NULL, FLOW_SEQ_NUM),
			DECODE(TRIM(OPER), '', NULL, OPER),
			DECODE(TRIM(SLOT_NO), '', NULL, SLOT_NO),
			DECODE(TRIM(QTY_2), '', NULL, QTY_2),
			DECODE(TRIM(QTY_3), '', NULL, QTY_3),
			DECODE(TRIM(CRR_ID), '', NULL, CRR_ID),
			DECODE(TRIM(OWNER_CODE), '', NULL, OWNER_CODE),
			DECODE(TRIM(CREATE_CODE), '', NULL, CREATE_CODE),
			DECODE(TRIM(SUBLOT_STATUS), '', NULL, SUBLOT_STATUS),
			DECODE(TRIM(HOLD_FLAG), '', NULL, HOLD_FLAG),
			DECODE(TRIM(HOLD_CODE), '', NULL, HOLD_CODE),
			DECODE(TRIM(HOLD_PASSWORD), '', NULL, HOLD_PASSWORD),
			DECODE(TRIM(HOLD_PRV_GRP_ID), '', NULL, HOLD_PRV_GRP_ID),
			DECODE(TRIM(OPER_IN_QTY_2), '', NULL, OPER_IN_QTY_2),
			DECODE(TRIM(OPER_IN_QTY_3), '', NULL, OPER_IN_QTY_3),
			DECODE(TRIM(CREATE_QTY_2), '', NULL, CREATE_QTY_2),
			DECODE(TRIM(CREATE_QTY_3), '', NULL, CREATE_QTY_3),
			DECODE(TRIM(START_QTY_2), '', NULL, START_QTY_2),
			DECODE(TRIM(START_QTY_3), '', NULL, START_QTY_3),
			DECODE(TRIM(INV_FLAG), '', NULL, INV_FLAG),
			DECODE(TRIM(TRANSIT_FLAG), '', NULL, TRANSIT_FLAG),
			DECODE(TRIM(UNIT_EXIST_FLAG), '', NULL, UNIT_EXIST_FLAG),
			DECODE(TRIM(INV_UNIT), '', NULL, INV_UNIT),
			DECODE(TRIM(RWK_FLAG), '', NULL, RWK_FLAG),
			DECODE(TRIM(RWK_CODE), '', NULL, RWK_CODE),
			DECODE(TRIM(RWK_COUNT), '', NULL, RWK_COUNT),
			DECODE(TRIM(RWK_RET_FLOW), '', NULL, RWK_RET_FLOW),
			DECODE(TRIM(RWK_RET_FLOW_SEQ_NUM), '', NULL, RWK_RET_FLOW_SEQ_NUM),
			DECODE(TRIM(RWK_RET_OPER), '', NULL, RWK_RET_OPER),
			DECODE(TRIM(RWK_END_FLOW), '', NULL, RWK_END_FLOW),
			DECODE(TRIM(RWK_END_FLOW_SEQ_NUM), '', NULL, RWK_END_FLOW_SEQ_NUM),
			DECODE(TRIM(RWK_END_OPER), '', NULL, RWK_END_OPER),
			DECODE(TRIM(RWK_RET_CLEAR_FLAG), '', NULL, RWK_RET_CLEAR_FLAG),
			DECODE(TRIM(RWK_TIME), '', NULL, TO_DATE(RWK_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(NSTD_FLAG), '', NULL, NSTD_FLAG),
			DECODE(TRIM(NSTD_RET_FLOW), '', NULL, NSTD_RET_FLOW),
			DECODE(TRIM(NSTD_RET_FLOW_SEQ_NUM), '', NULL, NSTD_RET_FLOW_SEQ_NUM),
			DECODE(TRIM(NSTD_RET_OPER), '', NULL, NSTD_RET_OPER),
			DECODE(TRIM(NSTD_TIME), '', NULL, TO_DATE(NSTD_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(REP_FLAG), '', NULL, REP_FLAG),
			DECODE(TRIM(REP_RET_OPER), '', NULL, REP_RET_OPER),
			DECODE(TRIM(STR_RET_FLOW), '', NULL, STR_RET_FLOW),
