/* SQL SELECT_SCALAR Function */
double RPT_select_rwipslthis_scalar(int sel_type, struct RWIPSLTHIS_TAG *RWIPSLTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPSLTHIS_N_TAG RWIPSLTHIS_N;
    	double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwipslthis(&RWIPSLTHIS_N, RWIPSLTHIS);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM RWIPSLTHIS
                WHERE SUBLOT_ID = :RWIPSLTHIS_N.SUBLOT_ID
                    AND HIST_SEQ = :RWIPSLTHIS_N.HIST_SEQ;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("RPT_select_rwipslthis_scalar", sel_type);
    return d_value;
}


/* SQL DELETE Function */
void RPT_delete_rwipslthis(int sel_type, struct RWIPSLTHIS_TAG *RWIPSLTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPSLTHIS_N_TAG RWIPSLTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwipslthis(&RWIPSLTHIS_N, RWIPSLTHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM RWIPSLTHIS
                WHERE SUBLOT_ID = :RWIPSLTHIS_N.SUBLOT_ID
                    AND HIST_SEQ = :RWIPSLTHIS_N.HIST_SEQ;
            break;

        case 2:
            EXEC SQL DELETE FROM RWIPSLTHIS
                WHERE SUBLOT_ID = :RWIPSLTHIS_N.SUBLOT_ID;
            break;

        case 3:
            EXEC SQL DELETE FROM RWIPSLTHIS
                WHERE LOT_ID = DECODE(:RWIPSLTHIS_N.LOT_ID.IS_NULL, 'Y', NULL, :RWIPSLTHIS_N.LOT_ID.VALUE);
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_delete_rwipslthis", sel_type);
}


