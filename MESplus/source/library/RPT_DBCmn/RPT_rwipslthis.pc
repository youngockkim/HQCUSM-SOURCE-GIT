                    :RWIPSLTHIS_N.HIST_DEL_TIME.IS_NULL, :RWIPSLTHIS_N.HIST_DEL_TIME.VALUE, 
                    :RWIPSLTHIS_N.HIST_DEL_USER_ID.IS_NULL, :RWIPSLTHIS_N.HIST_DEL_USER_ID.VALUE, 
                    :RWIPSLTHIS_N.HIST_DEL_COMMENT.IS_NULL, :RWIPSLTHIS_N.HIST_DEL_COMMENT.VALUE, 
                    :RWIPSLTHIS_N.OLD_GRADE.IS_NULL, :RWIPSLTHIS_N.OLD_GRADE.VALUE, 
                    :RWIPSLTHIS_N.OLD_LOT_ID.IS_NULL, :RWIPSLTHIS_N.OLD_LOT_ID.VALUE, 
                    :RWIPSLTHIS_N.OLD_SLOT_NO.IS_NULL, :RWIPSLTHIS_N.OLD_SLOT_NO.VALUE,
                    :RWIPSLTHIS_N.SUBLOT_TYPE.IS_NULL, :RWIPSLTHIS_N.SUBLOT_TYPE.VALUE, 
                    :RWIPSLTHIS_N.RESV_FIELD_1.IS_NULL, :RWIPSLTHIS_N.RESV_FIELD_1.VALUE, 
                    :RWIPSLTHIS_N.RESV_FIELD_2.IS_NULL, :RWIPSLTHIS_N.RESV_FIELD_2.VALUE, 
                    :RWIPSLTHIS_N.RESV_FIELD_3.IS_NULL, :RWIPSLTHIS_N.RESV_FIELD_3.VALUE, 
                    :RWIPSLTHIS_N.RESV_FIELD_4.IS_NULL, :RWIPSLTHIS_N.RESV_FIELD_4.VALUE, 
                    :RWIPSLTHIS_N.RESV_FIELD_5.IS_NULL, :RWIPSLTHIS_N.RESV_FIELD_5.VALUE, 
                    :RWIPSLTHIS_N.RESV_FLAG_1.IS_NULL, :RWIPSLTHIS_N.RESV_FLAG_1.VALUE, 
                    :RWIPSLTHIS_N.RESV_FLAG_2.IS_NULL, :RWIPSLTHIS_N.RESV_FLAG_2.VALUE, 
                    :RWIPSLTHIS_N.RESV_FLAG_3.IS_NULL, :RWIPSLTHIS_N.RESV_FLAG_3.VALUE, 
                    :RWIPSLTHIS_N.RESV_FLAG_4.IS_NULL, :RWIPSLTHIS_N.RESV_FLAG_4.VALUE, 
                    :RWIPSLTHIS_N.RESV_FLAG_5.IS_NULL, :RWIPSLTHIS_N.RESV_FLAG_5.VALUE 
                FROM RWIPSLTHIS
                WHERE SUBLOT_ID = :RWIPSLTHIS_N.SUBLOT_ID
                    AND HIST_SEQ = :RWIPSLTHIS_N.HIST_SEQ;
            break;

        case 2:
            EXEC SQL SELECT NVL(MAX(HIST_SEQ) , 0)
                INTO :RWIPSLTHIS_N.HIST_SEQ
                FROM RWIPSLTHIS
                WHERE SUBLOT_ID = :RWIPSLTHIS_N.SUBLOT_ID;
            break;

        case 3:
            EXEC SQL SELECT 
					DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' ')
                INTO 
					:RWIPSLTHIS_N.TRAN_TIME.IS_NULL, :RWIPSLTHIS_N.TRAN_TIME.VALUE
                FROM RWIPSLTHIS
                WHERE SUBLOT_ID = :RWIPSLTHIS_N.SUBLOT_ID
				  AND HIST_SEQ = (SELECT NVL(MAX(HIST_SEQ) , 0)
									FROM RWIPSLTHIS
								   WHERE SUBLOT_ID = :RWIPSLTHIS_N.SUBLOT_ID
									 AND OPER = :RWIPSLTHIS_N.OPER.VALUE
									 AND OPER <> OLD_OPER
									 AND HIST_DEL_FLAG = 'N'
									 AND TRAN_TIME < TO_DATE(:RWIPSLTHIS_N.TRAN_TIME.VALUE, 'YYYYMMDDHH24MISS'));
            break;

        case 4:
            EXEC SQL SELECT 
					DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' ')
                INTO 
					:RWIPSLTHIS_N.TRAN_TIME.IS_NULL, :RWIPSLTHIS_N.TRAN_TIME.VALUE
                FROM RWIPSLTHIS
                WHERE SUBLOT_ID = :RWIPSLTHIS_N.SUBLOT_ID
				  AND HIST_SEQ = (SELECT NVL(MIN(HIST_SEQ) , 0)
									FROM RWIPSLTHIS
								   WHERE SUBLOT_ID = :RWIPSLTHIS_N.SUBLOT_ID
									 AND OPER = :RWIPSLTHIS_N.OPER.VALUE
									 AND HIST_DEL_FLAG = 'N');
            break;


        case 5:
            EXEC SQL SELECT 
                    SUBLOT_ID,
                    HIST_SEQ,
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(SYS_TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(TRAN_CODE, NULL, 'Y', ' '), NVL(TRAN_CODE, ' '),
                    DECODE(LOT_ID, NULL, 'Y', ' '), NVL(LOT_ID, ' '),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '),
                    DECODE(MAT_ID, NULL, 'Y', ' '), NVL(MAT_ID, ' '),
                    DECODE(MAT_VER, NULL, 'Y', ' '), NVL(MAT_VER, '0'),
                    DECODE(FLOW, NULL, 'Y', ' '), NVL(FLOW, ' '),
                    DECODE(FLOW_SEQ_NUM, NULL, 'Y', ' '), NVL(FLOW_SEQ_NUM, '0'),
                    DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
                    DECODE(SLOT_NO, NULL, 'Y', ' '), NVL(SLOT_NO, '0'),
