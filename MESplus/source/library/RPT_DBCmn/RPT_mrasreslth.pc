/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_mrasreslth(int sel_type, struct MRASRESLTH_TAG *MRASRESLTH)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct MRASRESLTH_N_TAG MRASRESLTH_N;
	EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_mrasreslth(&MRASRESLTH_N, MRASRESLTH);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1: /* FLOW : TO_TRAN_TIME, QTY_3 : LOTS */
            EXEC SQL DECLARE RPT_MRASRESLTH_CUR_1 CURSOR FOR
                SELECT FACTORY, MAT_ID, FLOW, OPER, LOT_TYPE, RES_ID, EVENT_ID, RWK_FLAG, 
                    SUM(QTY_1) AS QTY_1, SUM(QTY_2) AS QTY_2, COUNT(*) AS QTY_3, RES_SEQ, SUBRES_ID, PORT_ID, CRR_ID
                FROM MRASRESLTH
                WHERE FACTORY = :MRASRESLTH_N.FACTORY
                    AND EVENT_ID IN ('START_LOT', 'END_LOT')
                    AND (TRAN_TIME >= :MRASRESLTH_N.TRAN_TIME 
                    AND TRAN_TIME < :MRASRESLTH_N.FLOW)     /* FLOW : TO_TRAN_TIME */
                    AND RES_HIST_DEL_FLAG <> 'Y'
                GROUP BY FACTORY, MAT_ID, FLOW, OPER, LOT_TYPE, RES_ID, EVENT_ID, RWK_FLAG;
            EXEC SQL OPEN RPT_MRASRESLTH_CUR_1;
            break;
            
        case 2:  /* FLOW : TO_TRAN_TIME, QTY_3 : LOTS */
            EXEC SQL DECLARE RPT_MRASRESLTH_CUR_2 CURSOR FOR
                SELECT FACTORY, MAT_ID, FLOW, OPER, LOT_TYPE, RES_ID, EVENT_ID, RWK_FLAG, 
                    SUM(QTY_1) AS QTY_1, SUM(QTY_2) AS QTY_2, COUNT(*) AS QTY_3, RES_SEQ, SUBRES_ID, PORT_ID, CRR_ID
                FROM MRASRESLTH
                WHERE EVENT_ID IN ('START_LOT', 'END_LOT')
                    AND (TRAN_TIME >= :MRASRESLTH_N.TRAN_TIME 
                    AND TRAN_TIME < :MRASRESLTH_N.FLOW)     /* FLOW : TO_TRAN_TIME */
                    AND RES_HIST_DEL_FLAG <> 'Y'
                GROUP BY FACTORY, MAT_ID, FLOW, OPER, LOT_TYPE, RES_ID, EVENT_ID, RWK_FLAG;
            EXEC SQL OPEN RPT_MRASRESLTH_CUR_2;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_mrasreslth", sel_type);
}


