    RWIPLOTDUE->RWK_FLAG = RWIPLOTDUE_N->RWK_FLAG[0];
    MEMCPY_DN(RWIPLOTDUE->ORG_DUE_TIME, RWIPLOTDUE_N->ORG_DUE_TIME, sizeof(RWIPLOTDUE->ORG_DUE_TIME));
    MEMCPY_DN(RWIPLOTDUE->SCH_DUE_TIME, RWIPLOTDUE_N->SCH_DUE_TIME, sizeof(RWIPLOTDUE->SCH_DUE_TIME));
    RWIPLOTDUE->REMAIN_QUEUE_TIME = RWIPLOTDUE_N->REMAIN_QUEUE_TIME;
    RWIPLOTDUE->REMAIN_PROC_TIME = RWIPLOTDUE_N->REMAIN_PROC_TIME;
    MEMCPY_DN(RWIPLOTDUE->FORECAST_DUE_TIME, RWIPLOTDUE_N->FORECAST_DUE_TIME, sizeof(RWIPLOTDUE->FORECAST_DUE_TIME));
    MEMCPY_DN(RWIPLOTDUE->CREATE_TIME, RWIPLOTDUE_N->CREATE_TIME, sizeof(RWIPLOTDUE->CREATE_TIME));
}


