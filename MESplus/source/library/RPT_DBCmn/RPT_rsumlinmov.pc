/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rsumlinmov(int sel_type, struct RSUMLINMOV_TAG *RSUMLINMOV)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RSUMLINMOV_N_TAG RSUMLINMOV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rsumlinmov(&RSUMLINMOV_N, RSUMLINMOV);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RSUMLINMOV_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(PARENT_LOT_ID, NULL, 'Y', ' '), NVL(PARENT_LOT_ID, ' '),
                    DECODE(YIELD_LINE, NULL, 'Y', ' '), NVL(YIELD_LINE, ' '),
                    DECODE(YIELD_SECTION, NULL, 'Y', ' '), NVL(YIELD_SECTION, ' '),
                    DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
                    DECODE(RWK_FLAG, NULL, 'Y', ' '), NVL(RWK_FLAG, ' '),
                    DECODE(OWNER_CODE, NULL, 'Y', ' '), NVL(OWNER_CODE, ' '),
                    DECODE(MAT_ID, NULL, 'Y', ' '), NVL(MAT_ID, ' '),
                    DECODE(MAT_VER, NULL, 'Y', ' '), NVL(MAT_VER, '0'),
                    DECODE(REPORTABLE_YN, NULL, 'Y', ' '), NVL(REPORTABLE_YN, ' '),
                    DECODE(LINE_END_QTY_1, NULL, 'Y', ' '), NVL(LINE_END_QTY_1, '0'),
                    DECODE(LINE_END_QTY_2, NULL, 'Y', ' '), NVL(LINE_END_QTY_2, '0'),
                    DECODE(LINE_END_QTY_3, NULL, 'Y', ' '), NVL(LINE_END_QTY_3, '0'),
                    DECODE(UNIT_1, NULL, 'Y', ' '), NVL(UNIT_1, ' '),
                    DECODE(UNIT_2, NULL, 'Y', ' '), NVL(UNIT_2, ' '),
                    DECODE(UNIT_3, NULL, 'Y', ' '), NVL(UNIT_3, ' '),
                    DECODE(CALC_LINE_MVIN_QTY, NULL, 'Y', ' '), NVL(CALC_LINE_MVIN_QTY, '0'),
                    DECODE(LINE_END_QTY, NULL, 'Y', ' '), NVL(LINE_END_QTY, '0'),
                    DECODE(UNIT, NULL, 'Y', ' '), NVL(UNIT, ' '),
                    DECODE(CALC_LINE_YIELD, NULL, 'Y', ' '), NVL(CALC_LINE_YIELD, '0'),
                    DECODE(YIELD_SECTION_NEW, NULL, 'Y', ' '), NVL(YIELD_SECTION_NEW, ' '),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '),
                    DECODE(NONPROD_MVOU_QTY, NULL, 'Y', ' '), NVL(NONPROD_MVOU_QTY, '0'),
                    DECODE(NONPROD_MVIN_QTY, NULL, 'Y', ' '), NVL(NONPROD_MVIN_QTY, '0'),
                    DECODE(LINE_DIRECTION, NULL, 'Y', ' '), NVL(LINE_DIRECTION, ' '),
                    DECODE(DATE_CREATE, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_CREATE, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(DATE_UPDATE, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_UPDATE, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(COMPONENT_FLAG, NULL, 'Y', ' '), NVL(COMPONENT_FLAG, ' ')
                FROM RSUMLINMOV
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN RPT_RSUMLINMOV_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rsumlinmov", sel_type);
}


