/* Add Null Function */
void RPT_add_null_rsumwipldr(struct RSUMWIPLDR_N_TAG *RSUMWIPLDR_N, struct RSUMWIPLDR_TAG *RSUMWIPLDR)
{
    /* memset by NULL */
    memset(RSUMWIPLDR_N, '\0', sizeof(struct RSUMWIPLDR_N_TAG));
    
    MEMCPY_AN(RSUMWIPLDR_N->FACTORY, RSUMWIPLDR->FACTORY, sizeof(RSUMWIPLDR->FACTORY));
    MEMCPY_AN(RSUMWIPLDR_N->WORK_DATE, RSUMWIPLDR->WORK_DATE, sizeof(RSUMWIPLDR->WORK_DATE));
    RSUMWIPLDR_N->WORK_SHIFT[0] = RSUMWIPLDR->WORK_SHIFT;
    MEMCPY_AN(RSUMWIPLDR_N->LAST_TRAN_TIME, RSUMWIPLDR->LAST_TRAN_TIME, sizeof(RSUMWIPLDR->LAST_TRAN_TIME));
}


/* Del Null Function */
void RPT_del_null_rsumwipldr(struct RSUMWIPLDR_N_TAG *RSUMWIPLDR_N, struct RSUMWIPLDR_TAG *RSUMWIPLDR)
{
    MEMCPY_DN(RSUMWIPLDR->FACTORY, RSUMWIPLDR_N->FACTORY, sizeof(RSUMWIPLDR->FACTORY));
    MEMCPY_DN(RSUMWIPLDR->WORK_DATE, RSUMWIPLDR_N->WORK_DATE, sizeof(RSUMWIPLDR->WORK_DATE));
    RSUMWIPLDR->WORK_SHIFT = RSUMWIPLDR_N->WORK_SHIFT[0];
    MEMCPY_DN(RSUMWIPLDR->LAST_TRAN_TIME, RSUMWIPLDR_N->LAST_TRAN_TIME, sizeof(RSUMWIPLDR->LAST_TRAN_TIME));
}


