/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_mwipcaldef(int sel_type, struct MWIPCALDEF_TAG *MWIPCALDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct MWIPCALDEF_N_TAG MWIPCALDEF_N;
	EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_mwipcaldef(&MWIPCALDEF_N, MWIPCALDEF);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_MWIPCALDEF_CUR_1 CURSOR FOR
                SELECT 
                    CALENDAR_ID,
                    SYS_YEAR,
                    SYS_MONTH,
                    SYS_DAY,
                    CALENDAR_TYPE,
                    SYS_DATE,
                    JULIAN_DAY,
                    HOLIDAY_FLAG,
                    HOLIDAY_DESC,
                    PLAN_YEAR,
                    PLAN_QUARTER,
                    PLAN_MONTH,
                    PLAN_WEEK,
                    START_TIME,
                    PREV_DAY_FG,
                    WORK_HOURS,
                    SHIFT_1,
                    SHIFT_2,
                    SHIFT_3,
                    SHIFT_4,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
					CAL_GRP_1,
					CAL_GRP_2,
					CAL_GRP_3,
					CAL_GRP_4,
					CAL_GRP_5,
					CAL_GRP_6,
					CAL_GRP_7,
					CAL_GRP_8,
					CAL_GRP_9,
					CAL_GRP_10,
					CAL_CMF_1,
					CAL_CMF_2,
					CAL_CMF_3,
					CAL_CMF_4,
					CAL_CMF_5,
					CAL_CMF_6,
					CAL_CMF_7,
					CAL_CMF_8,
					CAL_CMF_9,
					CAL_CMF_10,
					CAL_CMF_11,
					CAL_CMF_12,
					CAL_CMF_13,
					CAL_CMF_14,
					CAL_CMF_15,
					CAL_CMF_16,
					CAL_CMF_17,
					CAL_CMF_18,
					CAL_CMF_19,
					CAL_CMF_20
                FROM MWIPCALDEF
                WHERE CALENDAR_ID = :MWIPCALDEF_N.CALENDAR_ID
                    AND SYS_YEAR = :MWIPCALDEF_N.SYS_YEAR
                    AND SYS_MONTH = :MWIPCALDEF_N.SYS_MONTH
                ORDER BY SYS_DAY ASC;
            EXEC SQL OPEN RPT_MWIPCALDEF_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_mwipcaldef", sel_type);
}


