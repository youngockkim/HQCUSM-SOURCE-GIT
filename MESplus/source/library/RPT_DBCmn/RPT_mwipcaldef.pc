    MEMCPY_AN(MWIPCALDEF_N->CALENDAR_ID, MWIPCALDEF->CALENDAR_ID, sizeof(MWIPCALDEF->CALENDAR_ID));
    MWIPCALDEF_N->SYS_YEAR = MWIPCALDEF->SYS_YEAR;
