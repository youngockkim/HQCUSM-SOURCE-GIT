/* Initialize Function */
void RPT_init_mwipcaldef(struct MWIPCALDEF_TAG *MWIPCALDEF)
{
    /* memset by Space */
    memset(MWIPCALDEF, ' ', sizeof(struct MWIPCALDEF_TAG));
    
    MWIPCALDEF->SYS_YEAR = 0;
    MWIPCALDEF->SYS_MONTH = 0;
    MWIPCALDEF->SYS_DAY = 0;
    MWIPCALDEF->JULIAN_DAY = 0;
    MWIPCALDEF->PLAN_YEAR = 0;
    MWIPCALDEF->PLAN_QUARTER = 0;
    MWIPCALDEF->PLAN_MONTH = 0;
    MWIPCALDEF->PLAN_WEEK = 0;
    MWIPCALDEF->START_TIME = 0;
    MWIPCALDEF->WORK_HOURS = 0;
}


