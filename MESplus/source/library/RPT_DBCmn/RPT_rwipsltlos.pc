/* Initialize Function */
void RPT_init_rwipsltlos(struct RWIPSLTLOS_TAG *RWIPSLTLOS)
{
    /* memset by Space */
    memset(RWIPSLTLOS, ' ', sizeof(struct RWIPSLTLOS_TAG));
    
    RWIPSLTLOS->HIST_SEQ = 0;
    RWIPSLTLOS->LOT_HIST_SEQ = 0;
    RWIPSLTLOS->GRADE.IS_NULL = 'Y';
    RWIPSLTLOS->TRAN_TIME.IS_NULL = 'Y';
    RWIPSLTLOS->HIST_DEL_FLAG.IS_NULL = 'Y';
    RWIPSLTLOS->FACTORY.IS_NULL = 'Y';
    RWIPSLTLOS->MAT_ID.IS_NULL = 'Y';
    RWIPSLTLOS->MAT_VER.VALUE = 0;
    RWIPSLTLOS->MAT_VER.IS_NULL = 'Y';
    RWIPSLTLOS->FLOW.IS_NULL = 'Y';
    RWIPSLTLOS->FLOW_SEQ_NUM.VALUE = 0;
    RWIPSLTLOS->FLOW_SEQ_NUM.IS_NULL = 'Y';
    RWIPSLTLOS->OPER.IS_NULL = 'Y';
    RWIPSLTLOS->RES_ID.IS_NULL = 'Y';
    RWIPSLTLOS->CAUSE_FLOW.IS_NULL = 'Y';
    RWIPSLTLOS->CAUSE_OPER.IS_NULL = 'Y';
    RWIPSLTLOS->CAUSE_RES_ID.IS_NULL = 'Y';
	RWIPSLTLOS->LOSS_QTY.VALUE = 0;
    RWIPSLTLOS->LOSS_QTY.IS_NULL = 'Y';
}


