			DECODE(TRIM(LOSS_QTY), '', NULL, LOSS_QTY)
		FROM MWIPSLTLOS
        WHERE SUBLOT_ID = :RWIPSLTLOS_N.SUBLOT_ID
          AND HIST_SEQ = :RWIPSLTLOS_N.HIST_SEQ;
    DB_stop_query_timer("RPT_insert_select_rwipsltlos", 0);
