                    DECODE(REPORTABLE_YN, NULL, 'Y', ' '), NVL(REPORTABLE_YN, ' '),
                    DECODE(LINE_START_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(LINE_START_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(LINE_CYCLETIME, NULL, 'Y', ' '), NVL(LINE_CYCLETIME, '0'),
                    DECODE(LINE_PROC_TIME, NULL, 'Y', ' '), NVL(LINE_PROC_TIME, '0'),
                    DECODE(LINE_WAIT_TIME, NULL, 'Y', ' '), NVL(LINE_WAIT_TIME, '0'),
                    DECODE(LINE_STORE_TIME, NULL, 'Y', ' '), NVL(LINE_STORE_TIME, '0'),
                    DECODE(CYCLETIME_SECTION_NEW, NULL, 'Y', ' '), NVL(CYCLETIME_SECTION_NEW, ' '),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '),
                    DECODE(DATE_CREATE, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_CREATE, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(DATE_UPDATE, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_UPDATE, 'YYYYMMDDHH24MISS'), ' ')
                FROM RSUMLINCYC
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN RPT_RSUMLINCYC_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rsumlincyc", sel_type);
}


/* SQL CURSOR FETCH Function */
void RPT_fetch_rsumlincyc(int sel_type, struct RSUMLINCYC_TAG *RSUMLINCYC)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RSUMLINCYC_N_TAG RSUMLINCYC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_RSUMLINCYC_CUR_1 INTO
                :RSUMLINCYC_N.LOT_ID,
                :RSUMLINCYC_N.HIST_SEQ,
                :RSUMLINCYC_N.TRAN_TIME.IS_NULL, :RSUMLINCYC_N.TRAN_TIME.VALUE,
                :RSUMLINCYC_N.PARENT_LOT_ID.IS_NULL, :RSUMLINCYC_N.PARENT_LOT_ID.VALUE,
                :RSUMLINCYC_N.CYCLETIME_LINE.IS_NULL, :RSUMLINCYC_N.CYCLETIME_LINE.VALUE,
                :RSUMLINCYC_N.CYCLETIME_SECTION.IS_NULL, :RSUMLINCYC_N.CYCLETIME_SECTION.VALUE,
                :RSUMLINCYC_N.OPER.IS_NULL, :RSUMLINCYC_N.OPER.VALUE,
                :RSUMLINCYC_N.RWK_FLAG.IS_NULL, :RSUMLINCYC_N.RWK_FLAG.VALUE,
                :RSUMLINCYC_N.OWNER_CODE.IS_NULL, :RSUMLINCYC_N.OWNER_CODE.VALUE,
                :RSUMLINCYC_N.MAT_ID.IS_NULL, :RSUMLINCYC_N.MAT_ID.VALUE,
                :RSUMLINCYC_N.MAT_VER.IS_NULL, :RSUMLINCYC_N.MAT_VER.VALUE,
                :RSUMLINCYC_N.REPORTABLE_YN.IS_NULL, :RSUMLINCYC_N.REPORTABLE_YN.VALUE,
                :RSUMLINCYC_N.LINE_START_TIME.IS_NULL, :RSUMLINCYC_N.LINE_START_TIME.VALUE,
                :RSUMLINCYC_N.LINE_CYCLETIME.IS_NULL, :RSUMLINCYC_N.LINE_CYCLETIME.VALUE,
                :RSUMLINCYC_N.LINE_PROC_TIME.IS_NULL, :RSUMLINCYC_N.LINE_PROC_TIME.VALUE,
                :RSUMLINCYC_N.LINE_WAIT_TIME.IS_NULL, :RSUMLINCYC_N.LINE_WAIT_TIME.VALUE,
                :RSUMLINCYC_N.LINE_STORE_TIME.IS_NULL, :RSUMLINCYC_N.LINE_STORE_TIME.VALUE,
                :RSUMLINCYC_N.CYCLETIME_SECTION_NEW.IS_NULL, :RSUMLINCYC_N.CYCLETIME_SECTION_NEW.VALUE,
                :RSUMLINCYC_N.FACTORY.IS_NULL, :RSUMLINCYC_N.FACTORY.VALUE,
                :RSUMLINCYC_N.DATE_CREATE.IS_NULL, :RSUMLINCYC_N.DATE_CREATE.VALUE,
                :RSUMLINCYC_N.DATE_UPDATE.IS_NULL, :RSUMLINCYC_N.DATE_UPDATE.VALUE;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rsumlincyc(&RSUMLINCYC_N, RSUMLINCYC);
    }
    DB_stop_query_timer("RPT_fetch_rsumlincyc", sel_type);
}


/* SQL CURSOR CLOSE Function */
void RPT_close_rsumlincyc(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_RSUMLINCYC_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_rsumlincyc", sel_type);
}


/* Initialize Function */
void RPT_init_rsumlincyc(struct RSUMLINCYC_TAG *RSUMLINCYC)
{
    /* memset by Space */
    memset(RSUMLINCYC, ' ', sizeof(struct RSUMLINCYC_TAG));
    
    RSUMLINCYC->HIST_SEQ = 0;
    RSUMLINCYC->TRAN_TIME.IS_NULL = 'Y';
    RSUMLINCYC->PARENT_LOT_ID.IS_NULL = 'Y';
    RSUMLINCYC->CYCLETIME_LINE.IS_NULL = 'Y';
    RSUMLINCYC->CYCLETIME_SECTION.IS_NULL = 'Y';
    RSUMLINCYC->OPER.IS_NULL = 'Y';
    RSUMLINCYC->RWK_FLAG.IS_NULL = 'Y';
    RSUMLINCYC->OWNER_CODE.IS_NULL = 'Y';
    RSUMLINCYC->MAT_ID.IS_NULL = 'Y';
    RSUMLINCYC->MAT_VER.VALUE = 0;
    RSUMLINCYC->MAT_VER.IS_NULL = 'Y';
    RSUMLINCYC->REPORTABLE_YN.IS_NULL = 'Y';
    RSUMLINCYC->LINE_START_TIME.IS_NULL = 'Y';
    RSUMLINCYC->LINE_CYCLETIME.VALUE = 0;
    RSUMLINCYC->LINE_CYCLETIME.IS_NULL = 'Y';
    RSUMLINCYC->LINE_PROC_TIME.VALUE = 0;
    RSUMLINCYC->LINE_PROC_TIME.IS_NULL = 'Y';
    RSUMLINCYC->LINE_WAIT_TIME.VALUE = 0;
    RSUMLINCYC->LINE_WAIT_TIME.IS_NULL = 'Y';
    RSUMLINCYC->LINE_STORE_TIME.VALUE = 0;
    RSUMLINCYC->LINE_STORE_TIME.IS_NULL = 'Y';
    RSUMLINCYC->CYCLETIME_SECTION_NEW.IS_NULL = 'Y';
    RSUMLINCYC->FACTORY.IS_NULL = 'Y';
    RSUMLINCYC->DATE_CREATE.IS_NULL = 'Y';
    RSUMLINCYC->DATE_UPDATE.IS_NULL = 'Y';
}


/* Add Null Function */
void RPT_add_null_rsumlincyc(struct RSUMLINCYC_N_TAG *RSUMLINCYC_N, struct RSUMLINCYC_TAG *RSUMLINCYC)
{
    /* memset by NULL */
    memset(RSUMLINCYC_N, '\0', sizeof(struct RSUMLINCYC_N_TAG));
    
    MEMCPY_AN(RSUMLINCYC_N->LOT_ID, RSUMLINCYC->LOT_ID, sizeof(RSUMLINCYC->LOT_ID));
    RSUMLINCYC_N->HIST_SEQ = RSUMLINCYC->HIST_SEQ;
