{
    /* memset by NULL */
    memset(RWIPLOTSPM_N, '\0', sizeof(struct RWIPLOTSPM_N_TAG));
    
    MEMCPY_AN(RWIPLOTSPM_N->LOT_ID, RWIPLOTSPM->LOT_ID, sizeof(RWIPLOTSPM->LOT_ID));
    RWIPLOTSPM_N->HIST_SEQ = RWIPLOTSPM->HIST_SEQ;
