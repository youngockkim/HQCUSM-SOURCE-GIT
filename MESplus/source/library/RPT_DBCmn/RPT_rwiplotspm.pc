                :RWIPLOTSPM_N.FROM_TO_QTY_2.IS_NULL, :RWIPLOTSPM_N.FROM_TO_QTY_2.VALUE,
                :RWIPLOTSPM_N.FROM_TO_QTY_3.IS_NULL, :RWIPLOTSPM_N.FROM_TO_QTY_3.VALUE,
                :RWIPLOTSPM_N.TRAN_CODE.IS_NULL, :RWIPLOTSPM_N.TRAN_CODE.VALUE,
                :RWIPLOTSPM_N.HIST_DEL_TIME.IS_NULL, :RWIPLOTSPM_N.HIST_DEL_TIME.VALUE,
                :RWIPLOTSPM_N.FROM_TO_OLD_QTY_1.IS_NULL, :RWIPLOTSPM_N.FROM_TO_OLD_QTY_1.VALUE,
                :RWIPLOTSPM_N.FROM_TO_OLD_QTY_2.IS_NULL, :RWIPLOTSPM_N.FROM_TO_OLD_QTY_2.VALUE,
                :RWIPLOTSPM_N.FROM_TO_OLD_QTY_3.IS_NULL, :RWIPLOTSPM_N.FROM_TO_OLD_QTY_3.VALUE,
                :RWIPLOTSPM_N.UNIT_1.IS_NULL, :RWIPLOTSPM_N.UNIT_1.VALUE,
                :RWIPLOTSPM_N.UNIT_2.IS_NULL, :RWIPLOTSPM_N.UNIT_2.VALUE,
                :RWIPLOTSPM_N.UNIT_3.IS_NULL, :RWIPLOTSPM_N.UNIT_3.VALUE;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rwiplotspm(&RWIPLOTSPM_N, RWIPLOTSPM);
    }
    DB_stop_query_timer("RPT_fetch_rwiplotspm", sel_type);
}


