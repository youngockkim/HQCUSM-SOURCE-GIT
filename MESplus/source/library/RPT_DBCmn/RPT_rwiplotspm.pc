                    HIST_DEL_FLAG = DECODE(:RWIPLOTSPM_N.HIST_DEL_FLAG.IS_NULL, 'Y', 'N', :RWIPLOTSPM_N.HIST_DEL_FLAG.VALUE),
                    FACTORY = DECODE(:RWIPLOTSPM_N.FACTORY.IS_NULL, 'Y', 'N', :RWIPLOTSPM_N.FACTORY.VALUE),
                    MAT_ID = DECODE(:RWIPLOTSPM_N.MAT_ID.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.MAT_ID.VALUE),
                    MAT_VER = DECODE(:RWIPLOTSPM_N.MAT_VER.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.MAT_VER.VALUE),
                    FLOW = DECODE(:RWIPLOTSPM_N.FLOW.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.FLOW.VALUE),
                    FLOW_SEQ_NUM = DECODE(:RWIPLOTSPM_N.FLOW_SEQ_NUM.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.FLOW_SEQ_NUM.VALUE),
                    OPER = DECODE(:RWIPLOTSPM_N.OPER.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.OPER.VALUE),
                    FROM_TO_FLAG = DECODE(:RWIPLOTSPM_N.FROM_TO_FLAG.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.FROM_TO_FLAG.VALUE),
                    FROM_TO_LOT_ID = DECODE(:RWIPLOTSPM_N.FROM_TO_LOT_ID.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.FROM_TO_LOT_ID.VALUE),
                    FROM_TO_MAT_ID = DECODE(:RWIPLOTSPM_N.FROM_TO_MAT_ID.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.FROM_TO_MAT_ID.VALUE),
                    FROM_TO_MAT_VER = DECODE(:RWIPLOTSPM_N.FROM_TO_MAT_VER.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.FROM_TO_MAT_VER.VALUE),
                    FROM_TO_FLOW = DECODE(:RWIPLOTSPM_N.FROM_TO_FLOW.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.FROM_TO_FLOW.VALUE),
                    FROM_TO_FLOW_SEQ_NUM = DECODE(:RWIPLOTSPM_N.FROM_TO_FLOW_SEQ_NUM.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.FROM_TO_FLOW_SEQ_NUM.VALUE),
                    FROM_TO_OPER = DECODE(:RWIPLOTSPM_N.FROM_TO_OPER.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.FROM_TO_OPER.VALUE),
                    FROM_TO_QTY_1 = DECODE(:RWIPLOTSPM_N.FROM_TO_QTY_1.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.FROM_TO_QTY_1.VALUE),
                    FROM_TO_QTY_2 = DECODE(:RWIPLOTSPM_N.FROM_TO_QTY_2.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.FROM_TO_QTY_2.VALUE),
                    FROM_TO_QTY_3 = DECODE(:RWIPLOTSPM_N.FROM_TO_QTY_3.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.FROM_TO_QTY_3.VALUE),
                    TRAN_CODE = DECODE(:RWIPLOTSPM_N.TRAN_CODE.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.TRAN_CODE.VALUE),
                    HIST_DEL_TIME = DECODE(:RWIPLOTSPM_N.HIST_DEL_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTSPM_N.HIST_DEL_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    FROM_TO_OLD_QTY_1 = DECODE(:RWIPLOTSPM_N.FROM_TO_OLD_QTY_1.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.FROM_TO_OLD_QTY_1.VALUE),
                    FROM_TO_OLD_QTY_2 = DECODE(:RWIPLOTSPM_N.FROM_TO_OLD_QTY_2.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.FROM_TO_OLD_QTY_2.VALUE),
                    FROM_TO_OLD_QTY_3 = DECODE(:RWIPLOTSPM_N.FROM_TO_OLD_QTY_3.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.FROM_TO_OLD_QTY_3.VALUE),
                    UNIT_1 = DECODE(:RWIPLOTSPM_N.UNIT_1.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.UNIT_1.VALUE),
                    UNIT_2 = DECODE(:RWIPLOTSPM_N.UNIT_2.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.UNIT_2.VALUE),
                    UNIT_3 = DECODE(:RWIPLOTSPM_N.UNIT_3.IS_NULL, 'Y', NULL, :RWIPLOTSPM_N.UNIT_3.VALUE)
                WHERE LOT_ID = :RWIPLOTSPM_N.LOT_ID
                    AND HIST_SEQ = :RWIPLOTSPM_N.HIST_SEQ;
            break;

        case 2:
            EXEC SQL UPDATE RWIPLOTSPM SET
                    HIST_DEL_FLAG = DECODE(:RWIPLOTSPM_N.HIST_DEL_FLAG.IS_NULL, 'Y', 'N', :RWIPLOTSPM_N.HIST_DEL_FLAG.VALUE),
                    HIST_DEL_TIME = DECODE(:RWIPLOTSPM_N.HIST_DEL_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RWIPLOTSPM_N.HIST_DEL_TIME.VALUE, 'YYYYMMDDHH24MISS'))
                WHERE LOT_ID = :RWIPLOTSPM_N.LOT_ID
                    AND HIST_SEQ = :RWIPLOTSPM_N.HIST_SEQ;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_update_rwiplotspm", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rwiplotspm(int sel_type, struct RWIPLOTSPM_TAG *RWIPLOTSPM)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTSPM_N_TAG RWIPLOTSPM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplotspm(&RWIPLOTSPM_N, RWIPLOTSPM);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RWIPLOTSPM_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(HIST_DEL_FLAG, NULL, 'Y', ' '), NVL(HIST_DEL_FLAG, 'N'),
                    DECODE(FACTORY, NULL, 'Y', ' '), NVL(FACTORY, ' '),
                    DECODE(MAT_ID, NULL, 'Y', ' '), NVL(MAT_ID, ' '),
                    DECODE(MAT_VER, NULL, 'Y', ' '), NVL(MAT_VER, '0'),
                    DECODE(FLOW, NULL, 'Y', ' '), NVL(FLOW, ' '),
                    DECODE(FLOW_SEQ_NUM, NULL, 'Y', ' '), NVL(FLOW_SEQ_NUM, '0'),
                    DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
                    DECODE(FROM_TO_FLAG, NULL, 'Y', ' '), NVL(FROM_TO_FLAG, ' '),
                    DECODE(FROM_TO_LOT_ID, NULL, 'Y', ' '), NVL(FROM_TO_LOT_ID, ' '),
                    DECODE(FROM_TO_MAT_ID, NULL, 'Y', ' '), NVL(FROM_TO_MAT_ID, ' '),
                    DECODE(FROM_TO_MAT_VER, NULL, 'Y', ' '), NVL(FROM_TO_MAT_VER, '0'),
                    DECODE(FROM_TO_FLOW, NULL, 'Y', ' '), NVL(FROM_TO_FLOW, ' '),
                    DECODE(FROM_TO_FLOW_SEQ_NUM, NULL, 'Y', ' '), NVL(FROM_TO_FLOW_SEQ_NUM, '0'),
                    DECODE(FROM_TO_OPER, NULL, 'Y', ' '), NVL(FROM_TO_OPER, ' '),
                    DECODE(FROM_TO_QTY_1, NULL, 'Y', ' '), NVL(FROM_TO_QTY_1, '0'),
                    DECODE(FROM_TO_QTY_2, NULL, 'Y', ' '), NVL(FROM_TO_QTY_2, '0'),
                    DECODE(FROM_TO_QTY_3, NULL, 'Y', ' '), NVL(FROM_TO_QTY_3, '0'),
                    DECODE(TRAN_CODE, NULL, 'Y', ' '), NVL(TRAN_CODE, ' '),
                    DECODE(HIST_DEL_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(HIST_DEL_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(FROM_TO_OLD_QTY_1, NULL, 'Y', ' '), NVL(FROM_TO_OLD_QTY_1, '0'),
                    DECODE(FROM_TO_OLD_QTY_2, NULL, 'Y', ' '), NVL(FROM_TO_OLD_QTY_2, '0'),
                    DECODE(FROM_TO_OLD_QTY_3, NULL, 'Y', ' '), NVL(FROM_TO_OLD_QTY_3, '0'),
                    DECODE(UNIT_1, NULL, 'Y', ' '), NVL(UNIT_1, ' '),
                    DECODE(UNIT_2, NULL, 'Y', ' '), NVL(UNIT_2, ' '),
                    DECODE(UNIT_3, NULL, 'Y', ' '), NVL(UNIT_3, ' ')
                FROM RWIPLOTSPM
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN RPT_RWIPLOTSPM_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rwiplotspm", sel_type);
}


/* SQL CURSOR FETCH Function */
void RPT_fetch_rwiplotspm(int sel_type, struct RWIPLOTSPM_TAG *RWIPLOTSPM)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTSPM_N_TAG RWIPLOTSPM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

