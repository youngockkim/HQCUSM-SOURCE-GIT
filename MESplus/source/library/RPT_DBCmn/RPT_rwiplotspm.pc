                :RWIPLOTSPM_N.LOT_ID,
                :RWIPLOTSPM_N.HIST_SEQ,
                :RWIPLOTSPM_N.TRAN_TIME.IS_NULL, :RWIPLOTSPM_N.TRAN_TIME.VALUE,
