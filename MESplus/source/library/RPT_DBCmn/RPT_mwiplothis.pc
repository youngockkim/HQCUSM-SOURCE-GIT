    MWIPLOTHIS->RWK_END_FLOW_SEQ_NUM = 0;
    MWIPLOTHIS->NSTD_RET_FLOW_SEQ_NUM = 0;
    MWIPLOTHIS->STR_RET_FLOW_SEQ_NUM = 0;
    MWIPLOTHIS->BATCH_SEQ = 0;
    MWIPLOTHIS->BOM_SET_VERSION = 0;
