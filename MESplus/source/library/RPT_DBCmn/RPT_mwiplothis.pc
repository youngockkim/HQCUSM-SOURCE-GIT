/* SQL SELECT_SCALAR Function */
double RPT_select_mwiplothis_scalar(int sel_type, struct MWIPLOTHIS_TAG *MWIPLOTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct MWIPLOTHIS_N_TAG MWIPLOTHIS_N;
		double d_value;
	EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_mwiplothis(&MWIPLOTHIS_N, MWIPLOTHIS);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTHIS
                WHERE LOT_ID = :MWIPLOTHIS_N.LOT_ID
                    AND HIST_SEQ = :MWIPLOTHIS_N.HIST_SEQ;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("RPT_select_mwiplothis_scalar", sel_type);
    return d_value;
}


