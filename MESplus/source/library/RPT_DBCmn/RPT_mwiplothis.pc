/* SQL INSERT Function */
void RPT_insert_mwiplothis(struct MWIPLOTHIS_TAG *MWIPLOTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct MWIPLOTHIS_N_TAG MWIPLOTHIS_N;
	EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_mwiplothis(&MWIPLOTHIS_N, MWIPLOTHIS);
    DB_error_code = 0;

    EXEC SQL INSERT INTO MWIPLOTHIS (
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    SYS_TRAN_TIME,
                    TRAN_CODE,
                    LOT_DESC,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    CRR_ID,
                    LOT_TYPE,
