                                                    :MWIPLOTHIS_N.TRAN_CMF_14,
                                                    :MWIPLOTHIS_N.TRAN_CMF_15,
                                                    :MWIPLOTHIS_N.TRAN_CMF_16,
                                                    :MWIPLOTHIS_N.TRAN_CMF_17,
                                                    :MWIPLOTHIS_N.TRAN_CMF_18,
                                                    :MWIPLOTHIS_N.TRAN_CMF_19,
                                                    :MWIPLOTHIS_N.TRAN_CMF_20,
                                                    :MWIPLOTHIS_N.TRAN_USER_ID,
                                                    :MWIPLOTHIS_N.TRAN_COMMENT,
                                                    :MWIPLOTHIS_N.PREV_ACTIVE_HIST_SEQ,
                                                    :MWIPLOTHIS_N.MULTI_TR_KEY,
                                                    :MWIPLOTHIS_N.MULTI_TR_SEQ,
                                                    :MWIPLOTHIS_N.EXT_HIST_SEQ,
                                                    :MWIPLOTHIS_N.HIST_DEL_FLAG,
                                                    :MWIPLOTHIS_N.HIST_DEL_TIME,
                                                    :MWIPLOTHIS_N.HIST_DEL_USER_ID,
                                                    :MWIPLOTHIS_N.HIST_DEL_COMMENT;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_mwiplothis(&MWIPLOTHIS_N, MWIPLOTHIS);
    }
    DB_stop_query_timer("RPT_fetch_mwiplothis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void RPT_close_mwiplothis(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_MWIPLOTHIS_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_mwiplothis", sel_type);
}


/* Initialize Function */
void RPT_init_mwiplothis(struct MWIPLOTHIS_TAG *MWIPLOTHIS)
{
    /* memset by Space */
    memset(MWIPLOTHIS, ' ', sizeof(struct MWIPLOTHIS_TAG));
    
    MWIPLOTHIS->HIST_SEQ = 0;
    MWIPLOTHIS->MAT_VER = 0;
    MWIPLOTHIS->FLOW_SEQ_NUM = 0;
    MWIPLOTHIS->QTY_1 = 0;
    MWIPLOTHIS->QTY_2 = 0;
