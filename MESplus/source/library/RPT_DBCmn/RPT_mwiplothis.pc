    MWIPLOTHIS->BOM_HIST_SEQ = 0;
    MWIPLOTHIS->YIELD_1 = 0;
    MWIPLOTHIS->YIELD_2 = 0;
    MWIPLOTHIS->YIELD_3 = 0;
    MWIPLOTHIS->GOOD_QTY = 0;
