    MWIPLOTHIS->FROM_TO_FLOW_SEQ_NUM = 0;
    MWIPLOTHIS->FROM_TO_QTY_1 = 0;
    MWIPLOTHIS->FROM_TO_QTY_2 = 0;
    MWIPLOTHIS->FROM_TO_QTY_3 = 0;
    MWIPLOTHIS->FROM_TO_HIST_SEQ = 0;
    MWIPLOTHIS->OLD_MAT_VER = 0;
    MWIPLOTHIS->OLD_FLOW_SEQ_NUM = 0;
    MWIPLOTHIS->OLD_QTY_1 = 0;
