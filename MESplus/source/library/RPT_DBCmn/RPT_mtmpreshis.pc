/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_mtmpreshis(int sel_type, struct MTMPRESHIS_TAG *MTMPRESHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct MTMPRESHIS_N_TAG MTMPRESHIS_N;
	EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_mtmpreshis(&MTMPRESHIS_N, MTMPRESHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_MTMPRESHIS_CUR_1 CURSOR FOR
                SELECT 
                    TABLE_UPDATE_SEQ,
                    CM_KEY_1,
                    CM_KEY_2,
                    CM_KEY_3,
                    CM_KEY_4,
                    CM_KEY_5,
                    FACTORY,
                    MAIN_SUB_FLAG,
                    RES_ID,
