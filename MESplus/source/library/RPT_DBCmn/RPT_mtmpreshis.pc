/* SQL SELECT_SCALAR Function */
double RPT_select_mtmpreshis_scalar(int sel_type, struct MTMPRESHIS_TAG *MTMPRESHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct MTMPRESHIS_N_TAG MTMPRESHIS_N;
		double d_value;
	EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_mtmpreshis(&MTMPRESHIS_N, MTMPRESHIS);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MTMPRESHIS
                WHERE TABLE_UPDATE_SEQ = :MTMPRESHIS_N.TABLE_UPDATE_SEQ;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("RPT_select_mtmpreshis_scalar", sel_type);
    return d_value;
}


