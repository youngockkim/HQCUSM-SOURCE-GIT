								   WHERE FACTORY = :MTMPRESHIS_N.FACTORY
									 AND RES_ID = :MTMPRESHIS_N.RES_ID
									 AND SUBRES_ID = :MTMPRESHIS_N.SUBRES_ID);
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_mtmpreshis(&MTMPRESHIS_N, MTMPRESHIS);
    }
    DB_stop_query_timer("RPT_select_mtmpreshis", sel_type);
}


