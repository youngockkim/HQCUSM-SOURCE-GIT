/* SQL SELECT - INSERT Function */
void RPT_select_insert_ratrnamhis(struct RATRNAMHIS_TAG *RATRNAMHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RATRNAMHIS_N_TAG RATRNAMHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_ratrnamhis(&RATRNAMHIS_N, RATRNAMHIS);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RATRNAMHIS
		SELECT
			FACTORY, ATTR_TYPE, ATTR_NAME, ATTR_KEY, HIST_SEQ, 
			DECODE(TRIM(ATTR_OLD_VALUE), '', NULL, ATTR_OLD_VALUE),
			DECODE(TRIM(ATTR_NEW_VALUE), '', NULL, ATTR_NEW_VALUE),
			DECODE(TRIM(NULL_FLAG), '', NULL, NULL_FLAG),
			DECODE(TRIM(TRAN_TIME), '', NULL, TO_DATE(TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(SYS_TRAN_TIME), '', NULL, TO_DATE(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(KEY_HIST_SEQ), '', NULL, KEY_HIST_SEQ),
			DECODE(TRIM(PREV_ACTIVE_HIST_SEQ), '', NULL, PREV_ACTIVE_HIST_SEQ),
			DECODE(TRIM(HIST_START_SEQ), '', NULL, HIST_START_SEQ),
			DECODE(TRIM(HIST_DEL_FLAG), '', 'N', HIST_DEL_FLAG),
			DECODE(TRIM(HIST_DEL_TIME), '', NULL, TO_DATE(HIST_DEL_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(HIST_DEL_USER_ID), '', NULL, HIST_DEL_USER_ID),
			DECODE(TRIM(HIST_DEL_COMMENT), '', NULL, HIST_DEL_COMMENT),
			DECODE(TRIM(TRAN_USER_ID), '', NULL, TRAN_USER_ID)
		FROM MATRNAMHIS
        WHERE FACTORY = :RATRNAMHIS_N.FACTORY
          AND ATTR_TYPE = :RATRNAMHIS_N.ATTR_TYPE
          AND ATTR_NAME = :RATRNAMHIS_N.ATTR_NAME
          AND ATTR_KEY = :RATRNAMHIS_N.ATTR_KEY
          AND HIST_SEQ = :RATRNAMHIS_N.HIST_SEQ;
    DB_stop_query_timer("RPT_select_insert_ratrnamhis", 0);
}

