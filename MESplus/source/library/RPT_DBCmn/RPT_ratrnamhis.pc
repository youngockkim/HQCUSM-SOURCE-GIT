                    DECODE(SYS_TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(KEY_HIST_SEQ, NULL, 'Y', ' '), NVL(KEY_HIST_SEQ, '0'),
                    DECODE(PREV_ACTIVE_HIST_SEQ, NULL, 'Y', ' '), NVL(PREV_ACTIVE_HIST_SEQ, '0'),
                    DECODE(HIST_START_SEQ, NULL, 'Y', ' '), NVL(HIST_START_SEQ, '0'),
                    DECODE(HIST_DEL_FLAG, NULL, 'Y', ' '), NVL(HIST_DEL_FLAG, 'N'),
                    DECODE(HIST_DEL_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(HIST_DEL_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(HIST_DEL_USER_ID, NULL, 'Y', ' '), NVL(HIST_DEL_USER_ID, ' '),
                    DECODE(HIST_DEL_COMMENT, NULL, 'Y', ' '), NVL(HIST_DEL_COMMENT, ' '),
					DECODE(TRAN_USER_ID, NULL, 'Y', ' '), NVL(TRAN_USER_ID, ' ')
                FROM RATRNAMHIS
                ORDER BY FACTORY ASC,
                    ATTR_TYPE ASC,
                    ATTR_NAME ASC,
                    ATTR_KEY ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN RPT_RATRNAMHIS_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_ratrnamhis", sel_type);
}


/* SQL CURSOR FETCH Function */
void RPT_fetch_ratrnamhis(int sel_type, struct RATRNAMHIS_TAG *RATRNAMHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RATRNAMHIS_N_TAG RATRNAMHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_RATRNAMHIS_CUR_1 INTO
                :RATRNAMHIS_N.FACTORY,
                :RATRNAMHIS_N.ATTR_TYPE,
                :RATRNAMHIS_N.ATTR_NAME,
                :RATRNAMHIS_N.ATTR_KEY,
                :RATRNAMHIS_N.HIST_SEQ,
                :RATRNAMHIS_N.ATTR_OLD_VALUE.IS_NULL, :RATRNAMHIS_N.ATTR_OLD_VALUE.VALUE,
                :RATRNAMHIS_N.ATTR_NEW_VALUE.IS_NULL, :RATRNAMHIS_N.ATTR_NEW_VALUE.VALUE,
                :RATRNAMHIS_N.NULL_FLAG.IS_NULL, :RATRNAMHIS_N.NULL_FLAG.VALUE,
                :RATRNAMHIS_N.TRAN_TIME.IS_NULL, :RATRNAMHIS_N.TRAN_TIME.VALUE,
                :RATRNAMHIS_N.SYS_TRAN_TIME.IS_NULL, :RATRNAMHIS_N.SYS_TRAN_TIME.VALUE,
                :RATRNAMHIS_N.KEY_HIST_SEQ.IS_NULL, :RATRNAMHIS_N.KEY_HIST_SEQ.VALUE,
                :RATRNAMHIS_N.PREV_ACTIVE_HIST_SEQ.IS_NULL, :RATRNAMHIS_N.PREV_ACTIVE_HIST_SEQ.VALUE,
                :RATRNAMHIS_N.HIST_START_SEQ.IS_NULL, :RATRNAMHIS_N.HIST_START_SEQ.VALUE,
                :RATRNAMHIS_N.HIST_DEL_FLAG.IS_NULL, :RATRNAMHIS_N.HIST_DEL_FLAG.VALUE,
                :RATRNAMHIS_N.HIST_DEL_TIME.IS_NULL, :RATRNAMHIS_N.HIST_DEL_TIME.VALUE,
                :RATRNAMHIS_N.HIST_DEL_USER_ID.IS_NULL, :RATRNAMHIS_N.HIST_DEL_USER_ID.VALUE,
                :RATRNAMHIS_N.HIST_DEL_COMMENT.IS_NULL, :RATRNAMHIS_N.HIST_DEL_COMMENT.VALUE,
				:RATRNAMHIS_N.TRAN_USER_ID.IS_NULL, :RATRNAMHIS_N.TRAN_USER_ID.VALUE;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_ratrnamhis(&RATRNAMHIS_N, RATRNAMHIS);
    }
    DB_stop_query_timer("RPT_fetch_ratrnamhis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void RPT_close_ratrnamhis(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_RATRNAMHIS_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_ratrnamhis", sel_type);
}


/* Initialize Function */
void RPT_init_ratrnamhis(struct RATRNAMHIS_TAG *RATRNAMHIS)
{
    /* memset by Space */
    memset(RATRNAMHIS, ' ', sizeof(struct RATRNAMHIS_TAG));
    
    RATRNAMHIS->HIST_SEQ = 0;
    RATRNAMHIS->ATTR_OLD_VALUE.IS_NULL = 'Y';
    RATRNAMHIS->ATTR_NEW_VALUE.IS_NULL = 'Y';
    RATRNAMHIS->NULL_FLAG.IS_NULL = 'Y';
    RATRNAMHIS->TRAN_TIME.IS_NULL = 'Y';
    RATRNAMHIS->SYS_TRAN_TIME.IS_NULL = 'Y';
    RATRNAMHIS->KEY_HIST_SEQ.VALUE = 0;
    RATRNAMHIS->KEY_HIST_SEQ.IS_NULL = 'Y';
    RATRNAMHIS->PREV_ACTIVE_HIST_SEQ.VALUE = 0;
    RATRNAMHIS->PREV_ACTIVE_HIST_SEQ.IS_NULL = 'Y';
    RATRNAMHIS->HIST_START_SEQ.VALUE = 0;
    RATRNAMHIS->HIST_START_SEQ.IS_NULL = 'Y';
    RATRNAMHIS->HIST_DEL_FLAG.IS_NULL = 'Y';
    RATRNAMHIS->HIST_DEL_TIME.IS_NULL = 'Y';
    RATRNAMHIS->HIST_DEL_USER_ID.IS_NULL = 'Y';
    RATRNAMHIS->HIST_DEL_COMMENT.IS_NULL = 'Y';
	RATRNAMHIS->TRAN_USER_ID.IS_NULL = 'Y';
}


/* Add Null Function */
void RPT_add_null_ratrnamhis(struct RATRNAMHIS_N_TAG *RATRNAMHIS_N, struct RATRNAMHIS_TAG *RATRNAMHIS)
{
    /* memset by NULL */
    memset(RATRNAMHIS_N, '\0', sizeof(struct RATRNAMHIS_N_TAG));
    
    MEMCPY_AN(RATRNAMHIS_N->FACTORY, RATRNAMHIS->FACTORY, sizeof(RATRNAMHIS->FACTORY));
    MEMCPY_AN(RATRNAMHIS_N->ATTR_TYPE, RATRNAMHIS->ATTR_TYPE, sizeof(RATRNAMHIS->ATTR_TYPE));
    MEMCPY_AN(RATRNAMHIS_N->ATTR_NAME, RATRNAMHIS->ATTR_NAME, sizeof(RATRNAMHIS->ATTR_NAME));
    MEMCPY_AN(RATRNAMHIS_N->ATTR_KEY, RATRNAMHIS->ATTR_KEY, sizeof(RATRNAMHIS->ATTR_KEY));
    RATRNAMHIS_N->HIST_SEQ = RATRNAMHIS->HIST_SEQ;
    RATRNAMHIS_N->ATTR_OLD_VALUE.IS_NULL[0] = RATRNAMHIS->ATTR_OLD_VALUE.IS_NULL;
    MEMCPY_AN(RATRNAMHIS_N->ATTR_OLD_VALUE.VALUE, RATRNAMHIS->ATTR_OLD_VALUE.VALUE, sizeof(RATRNAMHIS->ATTR_OLD_VALUE.VALUE));
    RATRNAMHIS_N->ATTR_NEW_VALUE.IS_NULL[0] = RATRNAMHIS->ATTR_NEW_VALUE.IS_NULL;
    MEMCPY_AN(RATRNAMHIS_N->ATTR_NEW_VALUE.VALUE, RATRNAMHIS->ATTR_NEW_VALUE.VALUE, sizeof(RATRNAMHIS->ATTR_NEW_VALUE.VALUE));
    RATRNAMHIS_N->NULL_FLAG.IS_NULL[0] = RATRNAMHIS->NULL_FLAG.IS_NULL;
    RATRNAMHIS_N->NULL_FLAG.VALUE[0] = RATRNAMHIS->NULL_FLAG.VALUE;
    RATRNAMHIS_N->TRAN_TIME.IS_NULL[0] = RATRNAMHIS->TRAN_TIME.IS_NULL;
    MEMCPY_AN(RATRNAMHIS_N->TRAN_TIME.VALUE, RATRNAMHIS->TRAN_TIME.VALUE, sizeof(RATRNAMHIS->TRAN_TIME.VALUE));
    RATRNAMHIS_N->SYS_TRAN_TIME.IS_NULL[0] = RATRNAMHIS->SYS_TRAN_TIME.IS_NULL;
    MEMCPY_AN(RATRNAMHIS_N->SYS_TRAN_TIME.VALUE, RATRNAMHIS->SYS_TRAN_TIME.VALUE, sizeof(RATRNAMHIS->SYS_TRAN_TIME.VALUE));
    RATRNAMHIS_N->KEY_HIST_SEQ.IS_NULL[0] = RATRNAMHIS->KEY_HIST_SEQ.IS_NULL;
    RATRNAMHIS_N->KEY_HIST_SEQ.VALUE = RATRNAMHIS->KEY_HIST_SEQ.VALUE;
    RATRNAMHIS_N->PREV_ACTIVE_HIST_SEQ.IS_NULL[0] = RATRNAMHIS->PREV_ACTIVE_HIST_SEQ.IS_NULL;
    RATRNAMHIS_N->PREV_ACTIVE_HIST_SEQ.VALUE = RATRNAMHIS->PREV_ACTIVE_HIST_SEQ.VALUE;
    RATRNAMHIS_N->HIST_START_SEQ.IS_NULL[0] = RATRNAMHIS->HIST_START_SEQ.IS_NULL;
    RATRNAMHIS_N->HIST_START_SEQ.VALUE = RATRNAMHIS->HIST_START_SEQ.VALUE;
    RATRNAMHIS_N->HIST_DEL_FLAG.IS_NULL[0] = RATRNAMHIS->HIST_DEL_FLAG.IS_NULL;
    RATRNAMHIS_N->HIST_DEL_FLAG.VALUE[0] = RATRNAMHIS->HIST_DEL_FLAG.VALUE;
    RATRNAMHIS_N->HIST_DEL_TIME.IS_NULL[0] = RATRNAMHIS->HIST_DEL_TIME.IS_NULL;
    MEMCPY_AN(RATRNAMHIS_N->HIST_DEL_TIME.VALUE, RATRNAMHIS->HIST_DEL_TIME.VALUE, sizeof(RATRNAMHIS->HIST_DEL_TIME.VALUE));
    RATRNAMHIS_N->HIST_DEL_USER_ID.IS_NULL[0] = RATRNAMHIS->HIST_DEL_USER_ID.IS_NULL;
    MEMCPY_AN(RATRNAMHIS_N->HIST_DEL_USER_ID.VALUE, RATRNAMHIS->HIST_DEL_USER_ID.VALUE, sizeof(RATRNAMHIS->HIST_DEL_USER_ID.VALUE));
    RATRNAMHIS_N->HIST_DEL_COMMENT.IS_NULL[0] = RATRNAMHIS->HIST_DEL_COMMENT.IS_NULL;
    MEMCPY_AN(RATRNAMHIS_N->HIST_DEL_COMMENT.VALUE, RATRNAMHIS->HIST_DEL_COMMENT.VALUE, sizeof(RATRNAMHIS->HIST_DEL_COMMENT.VALUE));
	MEMCPY_AN(RATRNAMHIS_N->TRAN_USER_ID.VALUE, RATRNAMHIS->TRAN_USER_ID.VALUE, sizeof(RATRNAMHIS->TRAN_USER_ID.VALUE));
}


/* Del Null Function */
void RPT_del_null_ratrnamhis(struct RATRNAMHIS_N_TAG *RATRNAMHIS_N, struct RATRNAMHIS_TAG *RATRNAMHIS)
{
    MEMCPY_DN(RATRNAMHIS->FACTORY, RATRNAMHIS_N->FACTORY, sizeof(RATRNAMHIS->FACTORY));
    MEMCPY_DN(RATRNAMHIS->ATTR_TYPE, RATRNAMHIS_N->ATTR_TYPE, sizeof(RATRNAMHIS->ATTR_TYPE));
    MEMCPY_DN(RATRNAMHIS->ATTR_NAME, RATRNAMHIS_N->ATTR_NAME, sizeof(RATRNAMHIS->ATTR_NAME));
    MEMCPY_DN(RATRNAMHIS->ATTR_KEY, RATRNAMHIS_N->ATTR_KEY, sizeof(RATRNAMHIS->ATTR_KEY));
    RATRNAMHIS->HIST_SEQ = RATRNAMHIS_N->HIST_SEQ;
