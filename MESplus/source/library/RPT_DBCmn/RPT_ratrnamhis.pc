    RATRNAMHIS->ATTR_NEW_VALUE.IS_NULL = RATRNAMHIS_N->ATTR_NEW_VALUE.IS_NULL[0];
    MEMCPY_DN(RATRNAMHIS->ATTR_NEW_VALUE.VALUE, RATRNAMHIS_N->ATTR_NEW_VALUE.VALUE, sizeof(RATRNAMHIS->ATTR_NEW_VALUE.VALUE));
    RATRNAMHIS->NULL_FLAG.IS_NULL = RATRNAMHIS_N->NULL_FLAG.IS_NULL[0];
    RATRNAMHIS->NULL_FLAG.VALUE = RATRNAMHIS_N->NULL_FLAG.VALUE[0];
    RATRNAMHIS->TRAN_TIME.IS_NULL = RATRNAMHIS_N->TRAN_TIME.IS_NULL[0];
    MEMCPY_DN(RATRNAMHIS->TRAN_TIME.VALUE, RATRNAMHIS_N->TRAN_TIME.VALUE, sizeof(RATRNAMHIS->TRAN_TIME.VALUE));
    RATRNAMHIS->SYS_TRAN_TIME.IS_NULL = RATRNAMHIS_N->SYS_TRAN_TIME.IS_NULL[0];
    MEMCPY_DN(RATRNAMHIS->SYS_TRAN_TIME.VALUE, RATRNAMHIS_N->SYS_TRAN_TIME.VALUE, sizeof(RATRNAMHIS->SYS_TRAN_TIME.VALUE));
    RATRNAMHIS->KEY_HIST_SEQ.IS_NULL = RATRNAMHIS_N->KEY_HIST_SEQ.IS_NULL[0];
    RATRNAMHIS->KEY_HIST_SEQ.VALUE = RATRNAMHIS_N->KEY_HIST_SEQ.VALUE;
    RATRNAMHIS->PREV_ACTIVE_HIST_SEQ.IS_NULL = RATRNAMHIS_N->PREV_ACTIVE_HIST_SEQ.IS_NULL[0];
    RATRNAMHIS->PREV_ACTIVE_HIST_SEQ.VALUE = RATRNAMHIS_N->PREV_ACTIVE_HIST_SEQ.VALUE;
    RATRNAMHIS->HIST_START_SEQ.IS_NULL = RATRNAMHIS_N->HIST_START_SEQ.IS_NULL[0];
    RATRNAMHIS->HIST_START_SEQ.VALUE = RATRNAMHIS_N->HIST_START_SEQ.VALUE;
    RATRNAMHIS->HIST_DEL_FLAG.IS_NULL = RATRNAMHIS_N->HIST_DEL_FLAG.IS_NULL[0];
    RATRNAMHIS->HIST_DEL_FLAG.VALUE = RATRNAMHIS_N->HIST_DEL_FLAG.VALUE[0];
    RATRNAMHIS->HIST_DEL_TIME.IS_NULL = RATRNAMHIS_N->HIST_DEL_TIME.IS_NULL[0];
    MEMCPY_DN(RATRNAMHIS->HIST_DEL_TIME.VALUE, RATRNAMHIS_N->HIST_DEL_TIME.VALUE, sizeof(RATRNAMHIS->HIST_DEL_TIME.VALUE));
    RATRNAMHIS->HIST_DEL_USER_ID.IS_NULL = RATRNAMHIS_N->HIST_DEL_USER_ID.IS_NULL[0];
    MEMCPY_DN(RATRNAMHIS->HIST_DEL_USER_ID.VALUE, RATRNAMHIS_N->HIST_DEL_USER_ID.VALUE, sizeof(RATRNAMHIS->HIST_DEL_USER_ID.VALUE));
    RATRNAMHIS->HIST_DEL_COMMENT.IS_NULL = RATRNAMHIS_N->HIST_DEL_COMMENT.IS_NULL[0];
    MEMCPY_DN(RATRNAMHIS->HIST_DEL_COMMENT.VALUE, RATRNAMHIS_N->HIST_DEL_COMMENT.VALUE, sizeof(RATRNAMHIS->HIST_DEL_COMMENT.VALUE));
	MEMCPY_DN(RATRNAMHIS->TRAN_USER_ID.VALUE, RATRNAMHIS_N->TRAN_USER_ID.VALUE, sizeof(RATRNAMHIS->TRAN_USER_ID.VALUE));
}


