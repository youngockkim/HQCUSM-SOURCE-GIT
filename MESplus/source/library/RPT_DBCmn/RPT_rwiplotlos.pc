/* Initialize Function */
void RPT_init_rwiplotlos(struct RWIPLOTLOS_TAG *RWIPLOTLOS)
{
    /* memset by Space */
    memset(RWIPLOTLOS, ' ', sizeof(struct RWIPLOTLOS_TAG));
    
    RWIPLOTLOS->HIST_SEQ = 0;
    RWIPLOTLOS->MAT_VER = 0;
    RWIPLOTLOS->FLOW_SEQ_NUM = 0;
    RWIPLOTLOS->NEW_QTY = 0;
    RWIPLOTLOS->OLD_QTY = 0;
    RWIPLOTLOS->TOTAL_LOSS_QTY = 0;
    RWIPLOTLOS->LOSS_QTY_1 = 0;
    RWIPLOTLOS->LOSS_QTY_2 = 0;
    RWIPLOTLOS->LOSS_QTY_3 = 0;
    RWIPLOTLOS->LOSS_QTY_4 = 0;
    RWIPLOTLOS->LOSS_QTY_5 = 0;
    RWIPLOTLOS->LOSS_QTY_6 = 0;
    RWIPLOTLOS->LOSS_QTY_7 = 0;
    RWIPLOTLOS->LOSS_QTY_8 = 0;
    RWIPLOTLOS->LOSS_QTY_9 = 0;
    RWIPLOTLOS->LOSS_QTY_10 = 0;
}


/* Add Null Function */
void RPT_add_null_rwiplotlos(struct RWIPLOTLOS_N_TAG *RWIPLOTLOS_N, struct RWIPLOTLOS_TAG *RWIPLOTLOS)
{
    /* memset by NULL */
    memset(RWIPLOTLOS_N, '\0', sizeof(struct RWIPLOTLOS_N_TAG));
    
    MEMCPY_AN(RWIPLOTLOS_N->LOT_ID, RWIPLOTLOS->LOT_ID, sizeof(RWIPLOTLOS->LOT_ID));
    RWIPLOTLOS_N->HIST_SEQ = RWIPLOTLOS->HIST_SEQ;
    RWIPLOTLOS_N->QTY_FLAG[0] = RWIPLOTLOS->QTY_FLAG;
