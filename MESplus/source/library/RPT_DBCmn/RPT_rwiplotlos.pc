                    QTY_FLAG,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_ID,
                    CAUSE_FLOW,
                    CAUSE_OPER,
                    CAUSE_RES_ID,
                    NEW_QTY,
                    OLD_QTY,
                    TOTAL_LOSS_QTY,
                    LOSS_CODE_1,
                    LOSS_CODE_2,
                    LOSS_CODE_3,
                    LOSS_CODE_4,
                    LOSS_CODE_5,
                    LOSS_CODE_6,
                    LOSS_CODE_7,
                    LOSS_CODE_8,
                    LOSS_CODE_9,
                    LOSS_CODE_10,
                    LOSS_QTY_1,
                    LOSS_QTY_2,
                    LOSS_QTY_3,
                    LOSS_QTY_4,
                    LOSS_QTY_5,
                    LOSS_QTY_6,
                    LOSS_QTY_7,
                    LOSS_QTY_8,
                    LOSS_QTY_9,
                    LOSS_QTY_10,
                    LOSS_COMMENT_1,
                    LOSS_COMMENT_2,
                    LOSS_COMMENT_3
                FROM RWIPLOTLOS
                WHERE LOT_ID = :RWIPLOTLOS_N.LOT_ID
                    AND HIST_SEQ = :RWIPLOTLOS_N.HIST_SEQ
                ORDER BY QTY_FLAG ASC;
            EXEC SQL OPEN RPT_RWIPLOTLOS_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rwiplotlos", sel_type);
}


/* SQL CURSOR FETCH Function */
void RPT_fetch_rwiplotlos(int sel_type, struct RWIPLOTLOS_TAG *RWIPLOTLOS)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTLOS_N_TAG RWIPLOTLOS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_RWIPLOTLOS_CUR_1 INTO 
                                                    :RWIPLOTLOS_N.LOT_ID,
                                                    :RWIPLOTLOS_N.HIST_SEQ,
                                                    :RWIPLOTLOS_N.QTY_FLAG,
                                                    :RWIPLOTLOS_N.TRAN_TIME,
                                                    :RWIPLOTLOS_N.HIST_DEL_FLAG,
                                                    :RWIPLOTLOS_N.FACTORY,
                                                    :RWIPLOTLOS_N.MAT_ID,
                                                    :RWIPLOTLOS_N.MAT_VER,
                                                    :RWIPLOTLOS_N.FLOW,
                                                    :RWIPLOTLOS_N.FLOW_SEQ_NUM,
                                                    :RWIPLOTLOS_N.OPER,
                                                    :RWIPLOTLOS_N.RES_ID,
                                                    :RWIPLOTLOS_N.CAUSE_FLOW,
                                                    :RWIPLOTLOS_N.CAUSE_OPER,
                                                    :RWIPLOTLOS_N.CAUSE_RES_ID,
                                                    :RWIPLOTLOS_N.NEW_QTY,
                                                    :RWIPLOTLOS_N.OLD_QTY,
                                                    :RWIPLOTLOS_N.TOTAL_LOSS_QTY,
                                                    :RWIPLOTLOS_N.LOSS_CODE_1,
                                                    :RWIPLOTLOS_N.LOSS_CODE_2,
                                                    :RWIPLOTLOS_N.LOSS_CODE_3,
                                                    :RWIPLOTLOS_N.LOSS_CODE_4,
                                                    :RWIPLOTLOS_N.LOSS_CODE_5,
                                                    :RWIPLOTLOS_N.LOSS_CODE_6,
                                                    :RWIPLOTLOS_N.LOSS_CODE_7,
                                                    :RWIPLOTLOS_N.LOSS_CODE_8,
                                                    :RWIPLOTLOS_N.LOSS_CODE_9,
                                                    :RWIPLOTLOS_N.LOSS_CODE_10,
                                                    :RWIPLOTLOS_N.LOSS_QTY_1,
                                                    :RWIPLOTLOS_N.LOSS_QTY_2,
                                                    :RWIPLOTLOS_N.LOSS_QTY_3,
                                                    :RWIPLOTLOS_N.LOSS_QTY_4,
                                                    :RWIPLOTLOS_N.LOSS_QTY_5,
                                                    :RWIPLOTLOS_N.LOSS_QTY_6,
                                                    :RWIPLOTLOS_N.LOSS_QTY_7,
                                                    :RWIPLOTLOS_N.LOSS_QTY_8,
                                                    :RWIPLOTLOS_N.LOSS_QTY_9,
                                                    :RWIPLOTLOS_N.LOSS_QTY_10,
                                                    :RWIPLOTLOS_N.LOSS_COMMENT_1,
                                                    :RWIPLOTLOS_N.LOSS_COMMENT_2,
                                                    :RWIPLOTLOS_N.LOSS_COMMENT_3;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rwiplotlos(&RWIPLOTLOS_N, RWIPLOTLOS);
    }
    DB_stop_query_timer("RPT_fetch_rwiplotlos", sel_type);
}


