void RPT_del_null_rwiplotlos(struct RWIPLOTLOS_N_TAG *RWIPLOTLOS_N, struct RWIPLOTLOS_TAG *RWIPLOTLOS)
{
    MEMCPY_DN(RWIPLOTLOS->LOT_ID, RWIPLOTLOS_N->LOT_ID, sizeof(RWIPLOTLOS->LOT_ID));
