/* SQL UPDATE Function */
void RPT_update_rraspothis(int sel_type, struct RRASPOTHIS_TAG *RRASPOTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RRASPOTHIS_N_TAG RRASPOTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rraspothis(&RRASPOTHIS_N, RRASPOTHIS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE RRASPOTHIS SET
                    TRAN_CODE = DECODE(:RRASPOTHIS_N.TRAN_CODE.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CODE.VALUE),
					TRAN_TIME = DECODE(:RRASPOTHIS_N.TRAN_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RRASPOTHIS_N.TRAN_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    SYS_TRAN_TIME = DECODE(:RRASPOTHIS_N.SYS_TRAN_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RRASPOTHIS_N.SYS_TRAN_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    TRS_STATE = DECODE(:RRASPOTHIS_N.TRS_STATE.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRS_STATE.VALUE),
                    ASC_STATE = DECODE(:RRASPOTHIS_N.ASC_STATE.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.ASC_STATE.VALUE),
                    ASC_OBJ_ID = DECODE(:RRASPOTHIS_N.ASC_OBJ_ID.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.ASC_OBJ_ID.VALUE),
                    ACC_STATE = DECODE(:RRASPOTHIS_N.ACC_STATE.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.ACC_STATE.VALUE),
                    RSV_STATE = DECODE(:RRASPOTHIS_N.RSV_STATE.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.RSV_STATE.VALUE),
                    RSV_OBJ_ID = DECODE(:RRASPOTHIS_N.RSV_OBJ_ID.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.RSV_OBJ_ID.VALUE),
                    LOT_ID = DECODE(:RRASPOTHIS_N.LOT_ID.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.LOT_ID.VALUE),
                    CRR_ID = DECODE(:RRASPOTHIS_N.CRR_ID.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.CRR_ID.VALUE),
                    BCR_STATUS_FLAG = DECODE(:RRASPOTHIS_N.BCR_STATUS_FLAG.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.BCR_STATUS_FLAG.VALUE),
                    TRAN_CMF_1 = DECODE(:RRASPOTHIS_N.TRAN_CMF_1.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_1.VALUE),
                    TRAN_CMF_2 = DECODE(:RRASPOTHIS_N.TRAN_CMF_2.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_2.VALUE),
                    TRAN_CMF_3 = DECODE(:RRASPOTHIS_N.TRAN_CMF_3.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_3.VALUE),
                    TRAN_CMF_4 = DECODE(:RRASPOTHIS_N.TRAN_CMF_4.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_4.VALUE),
                    TRAN_CMF_5 = DECODE(:RRASPOTHIS_N.TRAN_CMF_5.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_5.VALUE),
                    TRAN_CMF_6 = DECODE(:RRASPOTHIS_N.TRAN_CMF_6.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_6.VALUE),
                    TRAN_CMF_7 = DECODE(:RRASPOTHIS_N.TRAN_CMF_7.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_7.VALUE),
                    TRAN_CMF_8 = DECODE(:RRASPOTHIS_N.TRAN_CMF_8.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_8.VALUE),
                    TRAN_CMF_9 = DECODE(:RRASPOTHIS_N.TRAN_CMF_9.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_9.VALUE),
                    TRAN_CMF_10 = DECODE(:RRASPOTHIS_N.TRAN_CMF_10.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_10.VALUE),
                    TRAN_CMF_11 = DECODE(:RRASPOTHIS_N.TRAN_CMF_11.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_11.VALUE),
                    TRAN_CMF_12 = DECODE(:RRASPOTHIS_N.TRAN_CMF_12.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_12.VALUE),
                    TRAN_CMF_13 = DECODE(:RRASPOTHIS_N.TRAN_CMF_13.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_13.VALUE),
                    TRAN_CMF_14 = DECODE(:RRASPOTHIS_N.TRAN_CMF_14.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_14.VALUE),
                    TRAN_CMF_15 = DECODE(:RRASPOTHIS_N.TRAN_CMF_15.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_15.VALUE),
                    TRAN_CMF_16 = DECODE(:RRASPOTHIS_N.TRAN_CMF_16.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_16.VALUE),
                    TRAN_CMF_17 = DECODE(:RRASPOTHIS_N.TRAN_CMF_17.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_17.VALUE),
                    TRAN_CMF_18 = DECODE(:RRASPOTHIS_N.TRAN_CMF_18.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_18.VALUE),
                    TRAN_CMF_19 = DECODE(:RRASPOTHIS_N.TRAN_CMF_19.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_19.VALUE),
                    TRAN_CMF_20 = DECODE(:RRASPOTHIS_N.TRAN_CMF_20.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_CMF_20.VALUE),
                    TRAN_USER_ID = DECODE(:RRASPOTHIS_N.TRAN_USER_ID.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_USER_ID.VALUE),
                    TRAN_COMMENT = DECODE(:RRASPOTHIS_N.TRAN_COMMENT.IS_NULL, 'Y', NULL, :RRASPOTHIS_N.TRAN_COMMENT.VALUE)
                WHERE FACTORY = :RRASPOTHIS_N.FACTORY
                    AND RES_ID = :RRASPOTHIS_N.RES_ID
                    AND SUBRES_ID = :RRASPOTHIS_N.SUBRES_ID
                    AND PORT_ID = :RRASPOTHIS_N.PORT_ID
                    AND HIST_SEQ = :RRASPOTHIS_N.HIST_SEQ;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("RPT_update_rraspothis", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rraspothis(int sel_type, struct RRASPOTHIS_TAG *RRASPOTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RRASPOTHIS_N_TAG RRASPOTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rraspothis(&RRASPOTHIS_N, RRASPOTHIS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RRASPOTHIS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    PORT_ID,
                    HIST_SEQ,
                    DECODE(TRAN_CODE, NULL, 'Y', ' '), NVL(TRAN_CODE, ' '),
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(SYS_TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(TRS_STATE, NULL, 'Y', ' '), NVL(TRS_STATE, ' '),
                    DECODE(ASC_STATE, NULL, 'Y', ' '), NVL(ASC_STATE, ' '),
                    DECODE(ASC_OBJ_ID, NULL, 'Y', ' '), NVL(ASC_OBJ_ID, ' '),
                    DECODE(ACC_STATE, NULL, 'Y', ' '), NVL(ACC_STATE, ' '),
                    DECODE(RSV_STATE, NULL, 'Y', ' '), NVL(RSV_STATE, ' '),
                    DECODE(RSV_OBJ_ID, NULL, 'Y', ' '), NVL(RSV_OBJ_ID, ' '),
                    DECODE(LOT_ID, NULL, 'Y', ' '), NVL(LOT_ID, ' '),
                    DECODE(CRR_ID, NULL, 'Y', ' '), NVL(CRR_ID, ' '),
                    DECODE(BCR_STATUS_FLAG, NULL, 'Y', ' '), NVL(BCR_STATUS_FLAG, ' '),
                    DECODE(TRAN_CMF_1, NULL, 'Y', ' '), NVL(TRAN_CMF_1, ' '),
                    DECODE(TRAN_CMF_2, NULL, 'Y', ' '), NVL(TRAN_CMF_2, ' '),
                    DECODE(TRAN_CMF_3, NULL, 'Y', ' '), NVL(TRAN_CMF_3, ' '),
                    DECODE(TRAN_CMF_4, NULL, 'Y', ' '), NVL(TRAN_CMF_4, ' '),
                    DECODE(TRAN_CMF_5, NULL, 'Y', ' '), NVL(TRAN_CMF_5, ' '),
                    DECODE(TRAN_CMF_6, NULL, 'Y', ' '), NVL(TRAN_CMF_6, ' '),
                    DECODE(TRAN_CMF_7, NULL, 'Y', ' '), NVL(TRAN_CMF_7, ' '),
                    DECODE(TRAN_CMF_8, NULL, 'Y', ' '), NVL(TRAN_CMF_8, ' '),
                    DECODE(TRAN_CMF_9, NULL, 'Y', ' '), NVL(TRAN_CMF_9, ' '),
                    DECODE(TRAN_CMF_10, NULL, 'Y', ' '), NVL(TRAN_CMF_10, ' '),
                    DECODE(TRAN_CMF_11, NULL, 'Y', ' '), NVL(TRAN_CMF_11, ' '),
                    DECODE(TRAN_CMF_12, NULL, 'Y', ' '), NVL(TRAN_CMF_12, ' '),
                    DECODE(TRAN_CMF_13, NULL, 'Y', ' '), NVL(TRAN_CMF_13, ' '),
                    DECODE(TRAN_CMF_14, NULL, 'Y', ' '), NVL(TRAN_CMF_14, ' '),
                    DECODE(TRAN_CMF_15, NULL, 'Y', ' '), NVL(TRAN_CMF_15, ' '),
                    DECODE(TRAN_CMF_16, NULL, 'Y', ' '), NVL(TRAN_CMF_16, ' '),
                    DECODE(TRAN_CMF_17, NULL, 'Y', ' '), NVL(TRAN_CMF_17, ' '),
                    DECODE(TRAN_CMF_18, NULL, 'Y', ' '), NVL(TRAN_CMF_18, ' '),
                    DECODE(TRAN_CMF_19, NULL, 'Y', ' '), NVL(TRAN_CMF_19, ' '),
                    DECODE(TRAN_CMF_20, NULL, 'Y', ' '), NVL(TRAN_CMF_20, ' '),
                    DECODE(TRAN_USER_ID, NULL, 'Y', ' '), NVL(TRAN_USER_ID, ' '),
                    DECODE(TRAN_COMMENT, NULL, 'Y', ' '), NVL(TRAN_COMMENT, ' ')
                FROM RRASPOTHIS
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SUBRES_ID ASC,
                    PORT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN RPT_RRASPOTHIS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("RPT_open_rraspothis", sel_type);
}


