    EXEC SQL INSERT INTO RRASPOTHIS( 
                    FACTORY, 
                    RES_ID, 
                    SUBRES_ID, 
                    PORT_ID, 
                    HIST_SEQ, 
                    TRAN_CODE, 
                    TRAN_TIME, 
                    SYS_TRAN_TIME, 
