/* Initialize Function */
void RPT_init_rraspothis(struct RRASPOTHIS_TAG *RRASPOTHIS)
{
    /* memset by Space */
    memset(RRASPOTHIS, ' ', sizeof(struct RRASPOTHIS_TAG));
    
    RRASPOTHIS->HIST_SEQ = 0;
}


/* Add Null Function */
void RPT_add_null_rraspothis(struct RRASPOTHIS_N_TAG *RRASPOTHIS_N, struct RRASPOTHIS_TAG *RRASPOTHIS)
{
    /* memset by NULL */
    memset(RRASPOTHIS_N, '\0', sizeof(struct RRASPOTHIS_N_TAG));
    
    MEMCPY_AN(RRASPOTHIS_N->FACTORY, RRASPOTHIS->FACTORY, sizeof(RRASPOTHIS->FACTORY));
    MEMCPY_AN(RRASPOTHIS_N->RES_ID, RRASPOTHIS->RES_ID, sizeof(RRASPOTHIS->RES_ID));
    MEMCPY_AN(RRASPOTHIS_N->SUBRES_ID, RRASPOTHIS->SUBRES_ID, sizeof(RRASPOTHIS->SUBRES_ID));
    MEMCPY_AN(RRASPOTHIS_N->PORT_ID, RRASPOTHIS->PORT_ID, sizeof(RRASPOTHIS->PORT_ID));
    RRASPOTHIS_N->HIST_SEQ = RRASPOTHIS->HIST_SEQ;
