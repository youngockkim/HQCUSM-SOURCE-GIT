void RPT_select_insert_rraspothis(struct RRASPOTHIS_TAG *RRASPOTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASPOTHIS_N_TAG RRASPOTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    
    RPT_add_null_rraspothis(&RRASPOTHIS_N, RRASPOTHIS);
    DB_error_code = 0;
    EXEC SQL INSERT INTO RRASPOTHIS
		SELECT
			FACTORY,
            RES_ID,
            SUBRES_ID,
            PORT_ID,
            HIST_SEQ,
            DECODE(TRIM(TRAN_CODE), '', NULL, TRAN_CODE),
            DECODE(TRIM(TRAN_TIME), '', NULL, TO_DATE(TRAN_TIME, 'YYYYMMDDHH24MISS')),
            DECODE(TRIM(SYS_TRAN_TIME), '', NULL, TO_DATE(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS')),
            DECODE(TRIM(TRS_STATE), '', NULL, TRS_STATE),
            DECODE(TRIM(ASC_STATE), '', NULL, ASC_STATE),
            DECODE(TRIM(ASC_OBJ_ID), '', NULL, ASC_OBJ_ID),
            DECODE(TRIM(ACC_STATE), '', NULL, ACC_STATE),
            DECODE(TRIM(RSV_STATE), '', NULL, RSV_STATE),
            DECODE(TRIM(RSV_OBJ_ID), '', NULL, RSV_OBJ_ID),
            DECODE(TRIM(LOT_ID), '', NULL, LOT_ID),
            DECODE(TRIM(CRR_ID), '', NULL, CRR_ID),
            DECODE(TRIM(BCR_STATUS_FLAG), '', NULL, BCR_STATUS_FLAG),
            DECODE(TRIM(TRAN_CMF_1), '', NULL, TRAN_CMF_1),
            DECODE(TRIM(TRAN_CMF_2), '', NULL, TRAN_CMF_2),
            DECODE(TRIM(TRAN_CMF_3), '', NULL, TRAN_CMF_3),
            DECODE(TRIM(TRAN_CMF_4), '', NULL, TRAN_CMF_4),
            DECODE(TRIM(TRAN_CMF_5), '', NULL, TRAN_CMF_5),
            DECODE(TRIM(TRAN_CMF_6), '', NULL, TRAN_CMF_6),
            DECODE(TRIM(TRAN_CMF_7), '', NULL, TRAN_CMF_7),
            DECODE(TRIM(TRAN_CMF_8), '', NULL, TRAN_CMF_8),
            DECODE(TRIM(TRAN_CMF_9), '', NULL, TRAN_CMF_9),
            DECODE(TRIM(TRAN_CMF_10), '', NULL, TRAN_CMF_10),
            DECODE(TRIM(TRAN_CMF_11), '', NULL, TRAN_CMF_11),
            DECODE(TRIM(TRAN_CMF_12), '', NULL, TRAN_CMF_12),
            DECODE(TRIM(TRAN_CMF_13), '', NULL, TRAN_CMF_13),
            DECODE(TRIM(TRAN_CMF_14), '', NULL, TRAN_CMF_14),
            DECODE(TRIM(TRAN_CMF_15), '', NULL, TRAN_CMF_15),
            DECODE(TRIM(TRAN_CMF_16), '', NULL, TRAN_CMF_16),
            DECODE(TRIM(TRAN_CMF_17), '', NULL, TRAN_CMF_17),
            DECODE(TRIM(TRAN_CMF_18), '', NULL, TRAN_CMF_18),
            DECODE(TRIM(TRAN_CMF_19), '', NULL, TRAN_CMF_19),
            DECODE(TRIM(TRAN_CMF_20), '', NULL, TRAN_CMF_20),
            DECODE(TRIM(TRAN_USER_ID), '', NULL, TRAN_USER_ID),
            DECODE(TRIM(TRAN_COMMENT), '', NULL, TRAN_COMMENT)
		FROM MRASPOTHIS
        WHERE FACTORY = :RRASPOTHIS_N.FACTORY
          AND RES_ID = :RRASPOTHIS_N.RES_ID
          AND SUBRES_ID = :RRASPOTHIS_N.SUBRES_ID
          AND PORT_ID = :RRASPOTHIS_N.PORT_ID
          AND HIST_SEQ = :RRASPOTHIS_N.HIST_SEQ;

    DB_stop_query_timer("RPT_select_insert_rraspothis", 0);
}

/* SQL INSERT Function */
