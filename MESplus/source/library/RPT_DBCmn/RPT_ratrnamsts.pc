    RATRNAMSTS_N->ATTR_VALUE.IS_NULL[0] = RATRNAMSTS->ATTR_VALUE.IS_NULL;
    MEMCPY_AN(RATRNAMSTS_N->ATTR_VALUE.VALUE, RATRNAMSTS->ATTR_VALUE.VALUE, sizeof(RATRNAMSTS->ATTR_VALUE.VALUE));
    RATRNAMSTS_N->NULL_FLAG.IS_NULL[0] = RATRNAMSTS->NULL_FLAG.IS_NULL;
    RATRNAMSTS_N->NULL_FLAG.VALUE[0] = RATRNAMSTS->NULL_FLAG.VALUE;
    RATRNAMSTS_N->LAST_TRAN_TIME.IS_NULL[0] = RATRNAMSTS->LAST_TRAN_TIME.IS_NULL;
    MEMCPY_AN(RATRNAMSTS_N->LAST_TRAN_TIME.VALUE, RATRNAMSTS->LAST_TRAN_TIME.VALUE, sizeof(RATRNAMSTS->LAST_TRAN_TIME.VALUE));
