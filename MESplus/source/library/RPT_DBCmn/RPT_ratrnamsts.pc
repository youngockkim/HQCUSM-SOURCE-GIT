void RPT_select_insert_ratrnamsts(struct RATRNAMSTS_TAG *RATRNAMSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RATRNAMSTS_N_TAG RATRNAMSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_ratrnamsts(&RATRNAMSTS_N, RATRNAMSTS);
    DB_error_code = 0;
    EXEC SQL INSERT INTO RATRNAMSTS
		SELECT A.FACTORY, A.ATTR_TYPE, A.ATTR_NAME, A.ATTR_KEY, 
			   DECODE(TRIM(A.KEY_HIST_SEQ), '', NULL, A.KEY_HIST_SEQ),
			   DECODE(TRIM(B.ATTR_FMT), '', NULL, B.ATTR_FMT),
			   DECODE(TRIM(B.ATTR_SIZE), '', NULL, B.ATTR_SIZE),
			   DECODE(TRIM(A.ATTR_VALUE), '', NULL, A.ATTR_VALUE),
			   DECODE(TRIM(A.NULL_FLAG), '', NULL, A.NULL_FLAG),
			   DECODE(TRIM(A.LAST_TRAN_TIME), '', NULL, TO_DATE(A.LAST_TRAN_TIME, 'YYYYMMDDHH24MISS')),
			   DECODE(TRIM(A.LAST_ACTIVE_HIST_SEQ), '', NULL, A.LAST_ACTIVE_HIST_SEQ),
			   DECODE(TRIM(A.LAST_HIST_SEQ), '', NULL, A.LAST_HIST_SEQ)
		  FROM MATRNAMSTS A, MATRNAMDEF B
		 WHERE A.FACTORY = B.FACTORY
		   AND A.ATTR_TYPE = B.ATTR_TYPE
		   AND A.ATTR_NAME = B.ATTR_NAME
		   AND A.FACTORY = :RATRNAMSTS_N.FACTORY
		   AND A.ATTR_TYPE = :RATRNAMSTS_N.ATTR_TYPE
		   AND A.ATTR_NAME = :RATRNAMSTS_N.ATTR_NAME
		   AND A.ATTR_KEY = :RATRNAMSTS_N.ATTR_KEY;
    DB_stop_query_timer("RPT_select_insert_ratrnamsts", 0);
}

