    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RWIPLOTRWK_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    TRAN_TIME,
                    HIST_DEL_FLAG,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    RES_ID,
                    CAUSE_FLOW,
                    CAUSE_OPER,
                    CAUSE_RES_ID,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    RWK_CODE,
                    RWK_COUNT,
                    RWK_DEPTH,
                    RWK_FLOW,
                    RWK_FLOW_SEQ_NUM,
                    RWK_OPER,
                    RWK_STOP_OPER,
                    RWK_RET_FLOW,
                    RWK_RET_FLOW_SEQ_NUM,
                    RWK_RET_OPER,
                    RWK_END_FLOW,
                    RWK_END_FLOW_SEQ_NUM,
                    RWK_END_OPER,
                    RWK_RET_CLEAR_FLAG,
                    LOCAL_REWORK_FLAG,
                    RWK_USER_ID,
                    RWK_COMMENT,
                    USER_ID_1,
                    USER_TIME_1,
                    USER_COMMENT_1,
                    USER_ID_2,
                    USER_TIME_2,
                    USER_COMMENT_2,
                    USER_ID_3,
                    USER_TIME_3,
                    USER_COMMENT_3
                FROM RWIPLOTRWK
                WHERE LOT_ID = :RWIPLOTRWK_N.LOT_ID
                ORDER BY HIST_SEQ ASC;
            EXEC SQL OPEN RPT_RWIPLOTRWK_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rwiplotrwk", sel_type);
}


