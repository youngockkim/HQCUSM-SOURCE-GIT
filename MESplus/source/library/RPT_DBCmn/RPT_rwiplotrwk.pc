/* Initialize Function */
void RPT_init_rwiplotrwk(struct RWIPLOTRWK_TAG *RWIPLOTRWK)
{
    /* memset by Space */
    memset(RWIPLOTRWK, ' ', sizeof(struct RWIPLOTRWK_TAG));
    
    RWIPLOTRWK->HIST_SEQ = 0;
    RWIPLOTRWK->MAT_VER = 0;
    RWIPLOTRWK->FLOW_SEQ_NUM = 0;
    RWIPLOTRWK->QTY_1 = 0;
    RWIPLOTRWK->QTY_2 = 0;
    RWIPLOTRWK->QTY_3 = 0;
    RWIPLOTRWK->RWK_COUNT = 0;
    RWIPLOTRWK->RWK_DEPTH = 0;
    RWIPLOTRWK->RWK_FLOW_SEQ_NUM = 0;
    RWIPLOTRWK->RWK_RET_FLOW_SEQ_NUM = 0;
    RWIPLOTRWK->RWK_END_FLOW_SEQ_NUM = 0;
}


/* Add Null Function */
void RPT_add_null_rwiplotrwk(struct RWIPLOTRWK_N_TAG *RWIPLOTRWK_N, struct RWIPLOTRWK_TAG *RWIPLOTRWK)
{
    /* memset by NULL */
    memset(RWIPLOTRWK_N, '\0', sizeof(struct RWIPLOTRWK_N_TAG));
    
    MEMCPY_AN(RWIPLOTRWK_N->LOT_ID, RWIPLOTRWK->LOT_ID, sizeof(RWIPLOTRWK->LOT_ID));
    RWIPLOTRWK_N->HIST_SEQ = RWIPLOTRWK->HIST_SEQ;
