void RPT_select_insert_rraspotdef(struct RRASPOTDEF_TAG *RRASPOTDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASPOTDEF_N_TAG RRASPOTDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    
    RPT_add_null_rraspotdef(&RRASPOTDEF_N, RRASPOTDEF);
    DB_error_code = 0;
    EXEC SQL INSERT INTO RRASPOTDEF
		SELECT
			FACTORY,
            RES_ID,
            SUBRES_ID,
            PORT_ID,
            DECODE(TRIM(PORT_SEQ), '', NULL, PORT_SEQ),
            DECODE(TRIM(PORT_DESC), '', NULL, PORT_DESC),
			DECODE(TRIM(TRS_STATE), '', NULL, TRS_STATE),
			DECODE(TRIM(ASC_STATE), '', NULL, ASC_STATE),
			DECODE(TRIM(ASC_OBJ_ID), '', NULL, ASC_OBJ_ID),
            DECODE(TRIM(ACC_STATE), '', NULL, ACC_STATE),
            DECODE(TRIM(RSV_STATE), '', NULL, RSV_STATE),
            DECODE(TRIM(RSV_OBJ_ID), '', NULL, RSV_OBJ_ID),
            DECODE(TRIM(LOT_ID), '', NULL, LOT_ID),
            DECODE(TRIM(CRR_ID), '', NULL, CRR_ID),
            DECODE(TRIM(BCR_STATUS_FLAG), '', NULL, BCR_STATUS_FLAG),
            DECODE(TRIM(PORT_TYPE), '', NULL, PORT_TYPE),
            DECODE(TRIM(PORT_BATCH_FLAG), '', NULL, PORT_BATCH_FLAG),
			DECODE(TRIM(ADD_PORT_TYPE), '', NULL, ADD_PORT_TYPE),
            DECODE(TRIM(PORT_LEVEL), '', NULL, PORT_LEVEL),
			DECODE(TRIM(PORT_CMF_1), '', NULL, PORT_CMF_1),
			DECODE(TRIM(PORT_CMF_2), '', NULL, PORT_CMF_2),
			DECODE(TRIM(PORT_CMF_3), '', NULL, PORT_CMF_3),
			DECODE(TRIM(PORT_CMF_4), '', NULL, PORT_CMF_4),
			DECODE(TRIM(PORT_CMF_5), '', NULL, PORT_CMF_5),
			DECODE(TRIM(PORT_CMF_6), '', NULL, PORT_CMF_6),
			DECODE(TRIM(PORT_CMF_7), '', NULL, PORT_CMF_7),
			DECODE(TRIM(PORT_CMF_8), '', NULL, PORT_CMF_8),
			DECODE(TRIM(PORT_CMF_9), '', NULL, PORT_CMF_9),
			DECODE(TRIM(PORT_CMF_10), '', NULL, PORT_CMF_10),
			DECODE(TRIM(PORT_CMF_11), '', NULL, PORT_CMF_11),
			DECODE(TRIM(PORT_CMF_12), '', NULL, PORT_CMF_12),
			DECODE(TRIM(PORT_CMF_13), '', NULL, PORT_CMF_13),
			DECODE(TRIM(PORT_CMF_14), '', NULL, PORT_CMF_14),
			DECODE(TRIM(PORT_CMF_15), '', NULL, PORT_CMF_15),
			DECODE(TRIM(PORT_CMF_16), '', NULL, PORT_CMF_16),
			DECODE(TRIM(PORT_CMF_17), '', NULL, PORT_CMF_17),
			DECODE(TRIM(PORT_CMF_18), '', NULL, PORT_CMF_18),
			DECODE(TRIM(PORT_CMF_19), '', NULL, PORT_CMF_19),
			DECODE(TRIM(PORT_CMF_20), '', NULL, PORT_CMF_20),
			DECODE(TRIM(LAST_HIST_SEQ), '', NULL, LAST_HIST_SEQ),
			DECODE(TRIM(CREATE_USER_ID), '', NULL, CREATE_USER_ID),
			DECODE(TRIM(CREATE_TIME), '', NULL, TO_DATE(CREATE_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(UPDATE_USER_ID), '', NULL, UPDATE_USER_ID),
			DECODE(TRIM(UPDATE_TIME), '', NULL, TO_DATE(UPDATE_TIME, 'YYYYMMDDHH24MISS'))
		FROM MRASPOTDEF
        WHERE FACTORY = :RRASPOTDEF_N.FACTORY
          AND RES_ID = :RRASPOTDEF_N.RES_ID
          AND SUBRES_ID = :RRASPOTDEF_N.SUBRES_ID
          AND PORT_ID = :RRASPOTDEF_N.PORT_ID;

    DB_stop_query_timer("RPT_select_insert_rraspotdef", 0);
}

/* SQL INSERT Function */
void RPT_insert_rraspotdef(struct RRASPOTDEF_TAG *RRASPOTDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RRASPOTDEF_N_TAG RRASPOTDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rraspotdef(&RRASPOTDEF_N, RRASPOTDEF);
    DB_error_code = 0;


    EXEC SQL INSERT INTO RRASPOTDEF( 
                    FACTORY, 
                    RES_ID, 
                    SUBRES_ID, 
                    PORT_ID, 
                    PORT_SEQ, 
                    PORT_DESC, 
                    TRS_STATE, 
                    ASC_STATE, 
                    ASC_OBJ_ID, 
                    ACC_STATE, 
                    RSV_STATE, 
                    RSV_OBJ_ID, 
                    LOT_ID, 
                    CRR_ID, 
                    BCR_STATUS_FLAG, 
                    PORT_TYPE, 
                    PORT_BATCH_FLAG, 
                    ADD_PORT_TYPE, 
                    PORT_LEVEL, 
                    PORT_CMF_1, 
                    PORT_CMF_2, 
                    PORT_CMF_3, 
                    PORT_CMF_4, 
                    PORT_CMF_5, 
                    PORT_CMF_6, 
                    PORT_CMF_7, 
                    PORT_CMF_8, 
                    PORT_CMF_9, 
                    PORT_CMF_10, 
                    PORT_CMF_11, 
                    PORT_CMF_12, 
                    PORT_CMF_13, 
                    PORT_CMF_14, 
                    PORT_CMF_15, 
                    PORT_CMF_16, 
                    PORT_CMF_17, 
                    PORT_CMF_18, 
                    PORT_CMF_19, 
                    PORT_CMF_20, 
                    LAST_HIST_SEQ, 
                    CREATE_USER_ID, 
                    CREATE_TIME, 
                    UPDATE_USER_ID, 
                    UPDATE_TIME
         ) 
        VALUES (
                    :RRASPOTDEF_N.FACTORY,
                    :RRASPOTDEF_N.RES_ID,
                    :RRASPOTDEF_N.SUBRES_ID,
                    :RRASPOTDEF_N.PORT_ID,
                    DECODE(:RRASPOTDEF_N.PORT_SEQ.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_SEQ.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_DESC.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_DESC.VALUE),
                    DECODE(:RRASPOTDEF_N.TRS_STATE.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.TRS_STATE.VALUE),
                    DECODE(:RRASPOTDEF_N.ASC_STATE.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.ASC_STATE.VALUE),
                    DECODE(:RRASPOTDEF_N.ASC_OBJ_ID.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.ASC_OBJ_ID.VALUE),
                    DECODE(:RRASPOTDEF_N.ACC_STATE.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.ACC_STATE.VALUE),
                    DECODE(:RRASPOTDEF_N.RSV_STATE.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.RSV_STATE.VALUE),
                    DECODE(:RRASPOTDEF_N.RSV_OBJ_ID.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.RSV_OBJ_ID.VALUE),
                    DECODE(:RRASPOTDEF_N.LOT_ID.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.LOT_ID.VALUE),
                    DECODE(:RRASPOTDEF_N.CRR_ID.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.CRR_ID.VALUE),
                    DECODE(:RRASPOTDEF_N.BCR_STATUS_FLAG.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.BCR_STATUS_FLAG.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_TYPE.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_TYPE.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_BATCH_FLAG.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_BATCH_FLAG.VALUE),
                    DECODE(:RRASPOTDEF_N.ADD_PORT_TYPE.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.ADD_PORT_TYPE.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_LEVEL.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_LEVEL.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_CMF_1.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_1.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_CMF_2.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_2.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_CMF_3.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_3.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_CMF_4.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_4.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_CMF_5.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_5.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_CMF_6.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_6.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_CMF_7.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_7.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_CMF_8.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_8.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_CMF_9.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_9.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_CMF_10.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_10.VALUE),
