                :RRASPOTDEF_N.FACTORY,
                :RRASPOTDEF_N.RES_ID,
                :RRASPOTDEF_N.SUBRES_ID,
                :RRASPOTDEF_N.PORT_ID,
                :RRASPOTDEF_N.PORT_SEQ.IS_NULL, :RRASPOTDEF_N.PORT_SEQ.VALUE,
                :RRASPOTDEF_N.PORT_DESC.IS_NULL, :RRASPOTDEF_N.PORT_DESC.VALUE,
                :RRASPOTDEF_N.TRS_STATE.IS_NULL, :RRASPOTDEF_N.TRS_STATE.VALUE,
                :RRASPOTDEF_N.ASC_STATE.IS_NULL, :RRASPOTDEF_N.ASC_STATE.VALUE,
