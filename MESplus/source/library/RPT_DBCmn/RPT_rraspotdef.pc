                :RRASPOTDEF_N.ADD_PORT_TYPE.IS_NULL, :RRASPOTDEF_N.ADD_PORT_TYPE.VALUE,
                :RRASPOTDEF_N.PORT_LEVEL.IS_NULL, :RRASPOTDEF_N.PORT_LEVEL.VALUE,
                :RRASPOTDEF_N.PORT_CMF_1.IS_NULL, :RRASPOTDEF_N.PORT_CMF_1.VALUE,
                :RRASPOTDEF_N.PORT_CMF_2.IS_NULL, :RRASPOTDEF_N.PORT_CMF_2.VALUE,
                :RRASPOTDEF_N.PORT_CMF_3.IS_NULL, :RRASPOTDEF_N.PORT_CMF_3.VALUE,
                :RRASPOTDEF_N.PORT_CMF_4.IS_NULL, :RRASPOTDEF_N.PORT_CMF_4.VALUE,
                :RRASPOTDEF_N.PORT_CMF_5.IS_NULL, :RRASPOTDEF_N.PORT_CMF_5.VALUE,
                :RRASPOTDEF_N.PORT_CMF_6.IS_NULL, :RRASPOTDEF_N.PORT_CMF_6.VALUE,
                :RRASPOTDEF_N.PORT_CMF_7.IS_NULL, :RRASPOTDEF_N.PORT_CMF_7.VALUE,
                :RRASPOTDEF_N.PORT_CMF_8.IS_NULL, :RRASPOTDEF_N.PORT_CMF_8.VALUE,
                :RRASPOTDEF_N.PORT_CMF_9.IS_NULL, :RRASPOTDEF_N.PORT_CMF_9.VALUE,
                :RRASPOTDEF_N.PORT_CMF_10.IS_NULL, :RRASPOTDEF_N.PORT_CMF_10.VALUE,
                :RRASPOTDEF_N.PORT_CMF_11.IS_NULL, :RRASPOTDEF_N.PORT_CMF_11.VALUE,
                :RRASPOTDEF_N.PORT_CMF_12.IS_NULL, :RRASPOTDEF_N.PORT_CMF_12.VALUE,
                :RRASPOTDEF_N.PORT_CMF_13.IS_NULL, :RRASPOTDEF_N.PORT_CMF_13.VALUE,
                :RRASPOTDEF_N.PORT_CMF_14.IS_NULL, :RRASPOTDEF_N.PORT_CMF_14.VALUE,
                :RRASPOTDEF_N.PORT_CMF_15.IS_NULL, :RRASPOTDEF_N.PORT_CMF_15.VALUE,
                :RRASPOTDEF_N.PORT_CMF_16.IS_NULL, :RRASPOTDEF_N.PORT_CMF_16.VALUE,
                :RRASPOTDEF_N.PORT_CMF_17.IS_NULL, :RRASPOTDEF_N.PORT_CMF_17.VALUE,
                :RRASPOTDEF_N.PORT_CMF_18.IS_NULL, :RRASPOTDEF_N.PORT_CMF_18.VALUE,
                :RRASPOTDEF_N.PORT_CMF_19.IS_NULL, :RRASPOTDEF_N.PORT_CMF_19.VALUE,
                :RRASPOTDEF_N.PORT_CMF_20.IS_NULL, :RRASPOTDEF_N.PORT_CMF_20.VALUE,
                :RRASPOTDEF_N.LAST_HIST_SEQ.IS_NULL, :RRASPOTDEF_N.LAST_HIST_SEQ.VALUE,
                :RRASPOTDEF_N.CREATE_USER_ID.IS_NULL, :RRASPOTDEF_N.CREATE_USER_ID.VALUE,
                :RRASPOTDEF_N.CREATE_TIME.IS_NULL, :RRASPOTDEF_N.CREATE_TIME.VALUE,
                :RRASPOTDEF_N.UPDATE_USER_ID.IS_NULL, :RRASPOTDEF_N.UPDATE_USER_ID.VALUE,
                :RRASPOTDEF_N.UPDATE_TIME.IS_NULL, :RRASPOTDEF_N.UPDATE_TIME.VALUE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rraspotdef(&RRASPOTDEF_N, RRASPOTDEF);
    }

    DB_stop_query_timer("RPT_fetch_rraspotdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void RPT_close_rraspotdef(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_RRASPOTDEF_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("RPT_close_rraspotdef", sel_type);
}


/* Initialize Function */
void RPT_init_rraspotdef(struct RRASPOTDEF_TAG *RRASPOTDEF)
{
    /* memset by Space */
    memset(RRASPOTDEF, ' ', sizeof(struct RRASPOTDEF_TAG));
    
    RRASPOTDEF->PORT_SEQ.VALUE = 0;
    RRASPOTDEF->PORT_SEQ.IS_NULL = 'Y';
    RRASPOTDEF->LAST_HIST_SEQ.VALUE = 0;
    RRASPOTDEF->LAST_HIST_SEQ.IS_NULL = 'Y';
}


