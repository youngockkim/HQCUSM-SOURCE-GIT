                    DECODE(:RRASPOTDEF_N.LAST_HIST_SEQ.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.LAST_HIST_SEQ.VALUE),
                    DECODE(:RRASPOTDEF_N.CREATE_USER_ID.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.CREATE_USER_ID.VALUE),
					DECODE(:RRASPOTDEF_N.CREATE_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RRASPOTDEF_N.CREATE_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    DECODE(:RRASPOTDEF_N.UPDATE_USER_ID.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.UPDATE_USER_ID.VALUE),
					DECODE(:RRASPOTDEF_N.UPDATE_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RRASPOTDEF_N.UPDATE_TIME.VALUE, 'YYYYMMDDHH24MISS'))
