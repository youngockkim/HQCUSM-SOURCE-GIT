/* SQL UPDATE Function */
void RPT_update_rraspotdef(int sel_type, struct RRASPOTDEF_TAG *RRASPOTDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RRASPOTDEF_N_TAG RRASPOTDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rraspotdef(&RRASPOTDEF_N, RRASPOTDEF);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE RRASPOTDEF SET
                    PORT_SEQ = DECODE(:RRASPOTDEF_N.PORT_SEQ.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_SEQ.VALUE),
                    PORT_DESC = DECODE(:RRASPOTDEF_N.PORT_DESC.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_DESC.VALUE),
                    TRS_STATE = DECODE(:RRASPOTDEF_N.TRS_STATE.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.TRS_STATE.VALUE),
                    ASC_STATE = DECODE(:RRASPOTDEF_N.ASC_STATE.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.ASC_STATE.VALUE),
                    ASC_OBJ_ID = DECODE(:RRASPOTDEF_N.ASC_OBJ_ID.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.ASC_OBJ_ID.VALUE),
                    ACC_STATE = DECODE(:RRASPOTDEF_N.ACC_STATE.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.ACC_STATE.VALUE),
                    RSV_STATE = DECODE(:RRASPOTDEF_N.RSV_STATE.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.RSV_STATE.VALUE),
                    RSV_OBJ_ID = DECODE(:RRASPOTDEF_N.RSV_OBJ_ID.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.RSV_OBJ_ID.VALUE),
                    LOT_ID = DECODE(:RRASPOTDEF_N.LOT_ID.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.LOT_ID.VALUE),
                    CRR_ID = DECODE(:RRASPOTDEF_N.CRR_ID.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.CRR_ID.VALUE),
                    BCR_STATUS_FLAG = DECODE(:RRASPOTDEF_N.BCR_STATUS_FLAG.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.BCR_STATUS_FLAG.VALUE),
                    PORT_TYPE = DECODE(:RRASPOTDEF_N.PORT_TYPE.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_TYPE.VALUE),
                    PORT_BATCH_FLAG = DECODE(:RRASPOTDEF_N.PORT_BATCH_FLAG.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_BATCH_FLAG.VALUE),
                    ADD_PORT_TYPE = DECODE(:RRASPOTDEF_N.ADD_PORT_TYPE.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.ADD_PORT_TYPE.VALUE),
                    PORT_LEVEL = DECODE(:RRASPOTDEF_N.PORT_LEVEL.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_LEVEL.VALUE),
                    PORT_CMF_1 = DECODE(:RRASPOTDEF_N.PORT_CMF_1.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_1.VALUE),
                    PORT_CMF_2 = DECODE(:RRASPOTDEF_N.PORT_CMF_2.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_2.VALUE),
                    PORT_CMF_3 = DECODE(:RRASPOTDEF_N.PORT_CMF_3.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_3.VALUE),
                    PORT_CMF_4 = DECODE(:RRASPOTDEF_N.PORT_CMF_4.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_4.VALUE),
                    PORT_CMF_5 = DECODE(:RRASPOTDEF_N.PORT_CMF_5.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_5.VALUE),
                    PORT_CMF_6 = DECODE(:RRASPOTDEF_N.PORT_CMF_6.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_6.VALUE),
                    PORT_CMF_7 = DECODE(:RRASPOTDEF_N.PORT_CMF_7.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_7.VALUE),
                    PORT_CMF_8 = DECODE(:RRASPOTDEF_N.PORT_CMF_8.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_8.VALUE),
                    PORT_CMF_9 = DECODE(:RRASPOTDEF_N.PORT_CMF_9.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_9.VALUE),
                    PORT_CMF_10 = DECODE(:RRASPOTDEF_N.PORT_CMF_10.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_10.VALUE),
                    PORT_CMF_11 = DECODE(:RRASPOTDEF_N.PORT_CMF_11.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_11.VALUE),
                    PORT_CMF_12 = DECODE(:RRASPOTDEF_N.PORT_CMF_12.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_12.VALUE),
                    PORT_CMF_13 = DECODE(:RRASPOTDEF_N.PORT_CMF_13.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_13.VALUE),
                    PORT_CMF_14 = DECODE(:RRASPOTDEF_N.PORT_CMF_14.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_14.VALUE),
                    PORT_CMF_15 = DECODE(:RRASPOTDEF_N.PORT_CMF_15.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_15.VALUE),
                    PORT_CMF_16 = DECODE(:RRASPOTDEF_N.PORT_CMF_16.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_16.VALUE),
                    PORT_CMF_17 = DECODE(:RRASPOTDEF_N.PORT_CMF_17.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_17.VALUE),
                    PORT_CMF_18 = DECODE(:RRASPOTDEF_N.PORT_CMF_18.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_18.VALUE),
                    PORT_CMF_19 = DECODE(:RRASPOTDEF_N.PORT_CMF_19.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_19.VALUE),
                    PORT_CMF_20 = DECODE(:RRASPOTDEF_N.PORT_CMF_20.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_20.VALUE),
                    LAST_HIST_SEQ = DECODE(:RRASPOTDEF_N.LAST_HIST_SEQ.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.LAST_HIST_SEQ.VALUE),
                    CREATE_USER_ID = DECODE(:RRASPOTDEF_N.CREATE_USER_ID.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.CREATE_USER_ID.VALUE),
					CREATE_TIME = DECODE(:RRASPOTDEF_N.CREATE_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RRASPOTDEF_N.CREATE_TIME.VALUE, 'YYYYMMDDHH24MISS')),
                    UPDATE_USER_ID = DECODE(:RRASPOTDEF_N.UPDATE_USER_ID.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.UPDATE_USER_ID.VALUE),
					UPDATE_TIME = DECODE(:RRASPOTDEF_N.UPDATE_TIME.IS_NULL, 'Y', NULL, TO_DATE(:RRASPOTDEF_N.UPDATE_TIME.VALUE, 'YYYYMMDDHH24MISS'))
                WHERE FACTORY = :RRASPOTDEF_N.FACTORY
                    AND RES_ID = :RRASPOTDEF_N.RES_ID
                    AND SUBRES_ID = :RRASPOTDEF_N.SUBRES_ID
                    AND PORT_ID = :RRASPOTDEF_N.PORT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("RPT_update_rraspotdef", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rraspotdef(int sel_type, struct RRASPOTDEF_TAG *RRASPOTDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RRASPOTDEF_N_TAG RRASPOTDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rraspotdef(&RRASPOTDEF_N, RRASPOTDEF);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RRASPOTDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    PORT_ID,
                    DECODE(PORT_SEQ, NULL, 'Y', ' '), NVL(PORT_SEQ, '0'),
                    DECODE(PORT_DESC, NULL, 'Y', ' '), NVL(PORT_DESC, ' '),
                    DECODE(TRS_STATE, NULL, 'Y', ' '), NVL(TRS_STATE, ' '),
                    DECODE(ASC_STATE, NULL, 'Y', ' '), NVL(ASC_STATE, ' '),
                    DECODE(ASC_OBJ_ID, NULL, 'Y', ' '), NVL(ASC_OBJ_ID, ' '),
                    DECODE(ACC_STATE, NULL, 'Y', ' '), NVL(ACC_STATE, ' '),
                    DECODE(RSV_STATE, NULL, 'Y', ' '), NVL(RSV_STATE, ' '),
                    DECODE(RSV_OBJ_ID, NULL, 'Y', ' '), NVL(RSV_OBJ_ID, ' '),
                    DECODE(LOT_ID, NULL, 'Y', ' '), NVL(LOT_ID, ' '),
                    DECODE(CRR_ID, NULL, 'Y', ' '), NVL(CRR_ID, ' '),
                    DECODE(BCR_STATUS_FLAG, NULL, 'Y', ' '), NVL(BCR_STATUS_FLAG, ' '),
                    DECODE(PORT_TYPE, NULL, 'Y', ' '), NVL(PORT_TYPE, ' '),
                    DECODE(PORT_BATCH_FLAG, NULL, 'Y', ' '), NVL(PORT_BATCH_FLAG, ' '),
                    DECODE(ADD_PORT_TYPE, NULL, 'Y', ' '), NVL(ADD_PORT_TYPE, ' '),
                    DECODE(PORT_LEVEL, NULL, 'Y', ' '), NVL(PORT_LEVEL, ' '),
                    DECODE(PORT_CMF_1, NULL, 'Y', ' '), NVL(PORT_CMF_1, ' '),
                    DECODE(PORT_CMF_2, NULL, 'Y', ' '), NVL(PORT_CMF_2, ' '),
                    DECODE(PORT_CMF_3, NULL, 'Y', ' '), NVL(PORT_CMF_3, ' '),
                    DECODE(PORT_CMF_4, NULL, 'Y', ' '), NVL(PORT_CMF_4, ' '),
                    DECODE(PORT_CMF_5, NULL, 'Y', ' '), NVL(PORT_CMF_5, ' '),
                    DECODE(PORT_CMF_6, NULL, 'Y', ' '), NVL(PORT_CMF_6, ' '),
                    DECODE(PORT_CMF_7, NULL, 'Y', ' '), NVL(PORT_CMF_7, ' '),
                    DECODE(PORT_CMF_8, NULL, 'Y', ' '), NVL(PORT_CMF_8, ' '),
                    DECODE(PORT_CMF_9, NULL, 'Y', ' '), NVL(PORT_CMF_9, ' '),
                    DECODE(PORT_CMF_10, NULL, 'Y', ' '), NVL(PORT_CMF_10, ' '),
                    DECODE(PORT_CMF_11, NULL, 'Y', ' '), NVL(PORT_CMF_11, ' '),
                    DECODE(PORT_CMF_12, NULL, 'Y', ' '), NVL(PORT_CMF_12, ' '),
                    DECODE(PORT_CMF_13, NULL, 'Y', ' '), NVL(PORT_CMF_13, ' '),
                    DECODE(PORT_CMF_14, NULL, 'Y', ' '), NVL(PORT_CMF_14, ' '),
                    DECODE(PORT_CMF_15, NULL, 'Y', ' '), NVL(PORT_CMF_15, ' '),
                    DECODE(PORT_CMF_16, NULL, 'Y', ' '), NVL(PORT_CMF_16, ' '),
                    DECODE(PORT_CMF_17, NULL, 'Y', ' '), NVL(PORT_CMF_17, ' '),
                    DECODE(PORT_CMF_18, NULL, 'Y', ' '), NVL(PORT_CMF_18, ' '),
                    DECODE(PORT_CMF_19, NULL, 'Y', ' '), NVL(PORT_CMF_19, ' '),
                    DECODE(PORT_CMF_20, NULL, 'Y', ' '), NVL(PORT_CMF_20, ' '),
                    DECODE(LAST_HIST_SEQ, NULL, 'Y', ' '), NVL(LAST_HIST_SEQ, '0'),
                    DECODE(CREATE_USER_ID, NULL, 'Y', ' '), NVL(CREATE_USER_ID, ' '),
					DECODE(CREATE_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(CREATE_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(UPDATE_USER_ID, NULL, 'Y', ' '), NVL(UPDATE_USER_ID, ' '),
					DECODE(UPDATE_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(UPDATE_TIME, 'YYYYMMDDHH24MISS'), ' ')
                FROM RRASPOTDEF
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SUBRES_ID ASC,
                    PORT_ID ASC;
            EXEC SQL OPEN RPT_RRASPOTDEF_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("RPT_open_rraspotdef", sel_type);
}


/* SQL CURSOR FETCH Function */
void RPT_fetch_rraspotdef(int sel_type, struct RRASPOTDEF_TAG *RRASPOTDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RRASPOTDEF_N_TAG RRASPOTDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


