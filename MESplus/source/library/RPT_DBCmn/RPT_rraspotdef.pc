                    DECODE(:RRASPOTDEF_N.PORT_CMF_15.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_15.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_CMF_16.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_16.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_CMF_17.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_17.VALUE),
                    DECODE(:RRASPOTDEF_N.PORT_CMF_18.IS_NULL, 'Y', NULL, :RRASPOTDEF_N.PORT_CMF_18.VALUE),
