                    LOT_ID,
                    CRR_ID,
                    BCR_STATUS_FLAG,
                    TRAN_CMF_1,
                    TRAN_CMF_2,
                    TRAN_CMF_3,
                    TRAN_CMF_4,
                    TRAN_CMF_5,
                    TRAN_CMF_6,
                    TRAN_CMF_7,
                    TRAN_CMF_8,
                    TRAN_CMF_9,
                    TRAN_CMF_10,
                    TRAN_CMF_11,
                    TRAN_CMF_12,
                    TRAN_CMF_13,
                    TRAN_CMF_14,
                    TRAN_CMF_15,
                    TRAN_CMF_16,
                    TRAN_CMF_17,
                    TRAN_CMF_18,
                    TRAN_CMF_19,
                    TRAN_CMF_20,
                    TRAN_USER_ID,
                    TRAN_COMMENT,
                    PROCESS_FLAG
                FROM MTMPPOTHIS_BAK
                ORDER BY TABLE_UPDATE_SEQ ASC;
            EXEC SQL OPEN RPT_MTMPPOTHIS_BAK_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("RPT_open_mtmppothis_bak", sel_type);
}


/* SQL CURSOR FETCH Function */
void RPT_fetch_mtmppothis_bak(int sel_type, struct MTMPPOTHIS_BAK_TAG *MTMPPOTHIS_BAK)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MTMPPOTHIS_BAK_N_TAG MTMPPOTHIS_BAK_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_MTMPPOTHIS_BAK_CUR_1 INTO
                :MTMPPOTHIS_BAK_N.TABLE_UPDATE_SEQ,
                :MTMPPOTHIS_BAK_N.CM_KEY_1,
                :MTMPPOTHIS_BAK_N.CM_KEY_2,
                :MTMPPOTHIS_BAK_N.CM_KEY_3,
                :MTMPPOTHIS_BAK_N.CM_KEY_4,
                :MTMPPOTHIS_BAK_N.CM_KEY_5,
                :MTMPPOTHIS_BAK_N.FACTORY,
                :MTMPPOTHIS_BAK_N.RES_ID,
                :MTMPPOTHIS_BAK_N.SUBRES_ID,
                :MTMPPOTHIS_BAK_N.PORT_ID,
                :MTMPPOTHIS_BAK_N.HIST_SEQ,
                :MTMPPOTHIS_BAK_N.TRAN_CODE,
                :MTMPPOTHIS_BAK_N.TRAN_TIME,
                :MTMPPOTHIS_BAK_N.SYS_TRAN_TIME,
                :MTMPPOTHIS_BAK_N.TRS_STATE,
                :MTMPPOTHIS_BAK_N.ASC_STATE,
                :MTMPPOTHIS_BAK_N.ASC_OBJ_ID,
                :MTMPPOTHIS_BAK_N.ACC_STATE,
                :MTMPPOTHIS_BAK_N.RSV_STATE,
                :MTMPPOTHIS_BAK_N.RSV_OBJ_ID,
                :MTMPPOTHIS_BAK_N.LOT_ID,
                :MTMPPOTHIS_BAK_N.CRR_ID,
                :MTMPPOTHIS_BAK_N.BCR_STATUS_FLAG,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_1,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_2,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_3,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_4,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_5,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_6,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_7,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_8,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_9,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_10,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_11,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_12,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_13,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_14,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_15,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_16,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_17,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_18,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_19,
                :MTMPPOTHIS_BAK_N.TRAN_CMF_20,
                :MTMPPOTHIS_BAK_N.TRAN_USER_ID,
                :MTMPPOTHIS_BAK_N.TRAN_COMMENT,
                :MTMPPOTHIS_BAK_N.PROCESS_FLAG;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_mtmppothis_bak(&MTMPPOTHIS_BAK_N, MTMPPOTHIS_BAK);
    }

    DB_stop_query_timer("RPT_fetch_mtmppothis_bak", sel_type);
}


/* SQL CURSOR CLOSE Function */
void RPT_close_mtmppothis_bak(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_MTMPPOTHIS_BAK_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("RPT_close_mtmppothis_bak", sel_type);
}


/* Initialize Function */
void RPT_init_mtmppothis_bak(struct MTMPPOTHIS_BAK_TAG *MTMPPOTHIS_BAK)
{
    /* memset by Space */
    memset(MTMPPOTHIS_BAK, ' ', sizeof(struct MTMPPOTHIS_BAK_TAG));
    
    MTMPPOTHIS_BAK->TABLE_UPDATE_SEQ = 0;
    MTMPPOTHIS_BAK->HIST_SEQ = 0;
}


