    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RWIPCRRLOT_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    CRR_ID,
                    NVL(FACTORY, ' '),
                    NVL(QTY_1, '0.0'),
                    NVL(QTY_2, '0.0'),
                    NVL(QTY_3, '0.0'),
                    NVL(USER_GRP_ID, ' '),
                    NVL(USER_ID, ' '),
                    NVL(CREATE_USER_ID, ' '),
                    NVL(CREATE_TIME, ' '),
                    NVL(CRR_SEQ, '0')
                FROM RWIPCRRLOT
                ORDER BY LOT_ID ASC,
                    CRR_ID ASC;
            EXEC SQL OPEN RPT_RWIPCRRLOT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
