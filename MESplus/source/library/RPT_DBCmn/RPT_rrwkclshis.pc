    RRWKCLSHIS->C_LINE_REWORK = RRWKCLSHIS_N->C_LINE_REWORK[0];
    MEMCPY_DN(RRWKCLSHIS->CYCLETIME_LINE, RRWKCLSHIS_N->CYCLETIME_LINE, sizeof(RRWKCLSHIS->CYCLETIME_LINE));
