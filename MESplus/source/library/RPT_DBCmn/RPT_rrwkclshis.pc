    RRWKCLSHIS->Y_WORKCELL_REWORK = RRWKCLSHIS_N->Y_WORKCELL_REWORK[0];
    MEMCPY_DN(RRWKCLSHIS->YIELD_WORKCELL, RRWKCLSHIS_N->YIELD_WORKCELL, sizeof(RRWKCLSHIS->YIELD_WORKCELL));
    MEMCPY_DN(RRWKCLSHIS->F_YIELD_WORKCELL, RRWKCLSHIS_N->F_YIELD_WORKCELL, sizeof(RRWKCLSHIS->F_YIELD_WORKCELL));
    RRWKCLSHIS->Y_SECTION_REWORK = RRWKCLSHIS_N->Y_SECTION_REWORK[0];
