    MEMCPY_DN(RRWKCLSHIS->F_YIELD_SECTION, RRWKCLSHIS_N->F_YIELD_SECTION, sizeof(RRWKCLSHIS->F_YIELD_SECTION));
    RRWKCLSHIS->Y_LINE_REWORK = RRWKCLSHIS_N->Y_LINE_REWORK[0];
    MEMCPY_DN(RRWKCLSHIS->YIELD_LINE, RRWKCLSHIS_N->YIELD_LINE, sizeof(RRWKCLSHIS->YIELD_LINE));
    MEMCPY_DN(RRWKCLSHIS->F_YIELD_LINE, RRWKCLSHIS_N->F_YIELD_LINE, sizeof(RRWKCLSHIS->F_YIELD_LINE));
    RRWKCLSHIS->REWORK_DIRECTION = RRWKCLSHIS_N->REWORK_DIRECTION[0];
}

