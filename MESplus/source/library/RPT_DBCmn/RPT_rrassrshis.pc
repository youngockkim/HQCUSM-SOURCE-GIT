			DECODE(TRIM(TRAN_COMMENT), '', NULL, TRAN_COMMENT),
			DECODE(TRIM(LAST_DOWN_TIME), '', NULL, TO_DATE(LAST_DOWN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(LAST_DOWN_HIST_SEQ), '', NULL, LAST_DOWN_HIST_SEQ),
			DECODE(TRIM(HIST_START_SEQ), '', NULL, HIST_START_SEQ),
			DECODE(TRIM(HIST_DEL_FLAG), '', 'N', HIST_DEL_FLAG),
