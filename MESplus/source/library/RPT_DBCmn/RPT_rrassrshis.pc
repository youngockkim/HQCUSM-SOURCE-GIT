void RPT_select_insert_rrassrshis(struct RRASSRSHIS_TAG *RRASSRSHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASSRSHIS_N_TAG RRASSRSHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrassrshis(&RRASSRSHIS_N, RRASSRSHIS);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RRASSRSHIS
		SELECT
			FACTORY,
			RES_ID,
			SUBRES_ID,
			HIST_SEQ,
			DECODE(TRIM(EVENT_ID), '', NULL, EVENT_ID),
			DECODE(TRIM(TRAN_TIME), '', NULL, TO_DATE(TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(SYS_TRAN_TIME), '', NULL, TO_DATE(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(PARENTS_SUBRES_ID), '', NULL, PARENTS_SUBRES_ID),
			DECODE(TRIM(MAIN_HIST_SEQ), '', NULL, MAIN_HIST_SEQ),
			DECODE(TRIM(OLD_EVENT_ID), '', NULL, OLD_EVENT_ID),
			DECODE(TRIM(OLD_HIST_SEQ), '', NULL, OLD_HIST_SEQ),
			DECODE(TRIM(OLD_TRAN_TIME), '', NULL, TO_DATE(OLD_TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(OLD_SYS_TRAN_TIME), '', NULL, TO_DATE(OLD_SYS_TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(OLD_UP_DOWN_FLAG), '', 'U', OLD_UP_DOWN_FLAG),
			DECODE(TRIM(OLD_PRI_STS), '', NULL, OLD_PRI_STS),
			DECODE(TRIM(OLD_STS_1), '', NULL, OLD_STS_1),
			DECODE(TRIM(OLD_STS_2), '', NULL, OLD_STS_2),
			DECODE(TRIM(OLD_STS_3), '', NULL, OLD_STS_3),
			DECODE(TRIM(OLD_STS_4), '', NULL, OLD_STS_4),
			DECODE(TRIM(OLD_STS_5), '', NULL, OLD_STS_5),
