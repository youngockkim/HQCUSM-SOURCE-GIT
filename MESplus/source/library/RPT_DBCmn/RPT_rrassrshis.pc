                    DECODE(EDC_DETAILS, NULL, 'Y', ' '), NVL(EDC_DETAILS, ' '),
                    DECODE(REPAIR_PRIOR, NULL, 'Y', ' '), NVL(REPAIR_PRIOR, ' ')
                FROM RRASSRSHIS
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SUBRES_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN RPT_RRASSRSHIS_CUR_1;
