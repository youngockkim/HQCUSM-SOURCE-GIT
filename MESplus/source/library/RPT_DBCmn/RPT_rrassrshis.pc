/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rrassrshis(int sel_type, struct RRASSRSHIS_TAG *RRASSRSHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASSRSHIS_N_TAG RRASSRSHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrassrshis(&RRASSRSHIS_N, RRASSRSHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RRASSRSHIS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    HIST_SEQ,
                    DECODE(EVENT_ID, NULL, 'Y', ' '), NVL(EVENT_ID, ' '),
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(SYS_TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(SYS_TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(PARENTS_SUBRES_ID, NULL, 'Y', ' '), NVL(PARENTS_SUBRES_ID, ' '),
                    DECODE(MAIN_HIST_SEQ, NULL, 'Y', ' '), NVL(MAIN_HIST_SEQ, '0'),
