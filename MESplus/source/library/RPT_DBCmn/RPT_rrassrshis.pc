                    DECODE(NEW_STS_5, NULL, 'Y', ' '), NVL(NEW_STS_5, ' '),
                    DECODE(NEW_STS_6, NULL, 'Y', ' '), NVL(NEW_STS_6, ' '),
                    DECODE(NEW_STS_7, NULL, 'Y', ' '), NVL(NEW_STS_7, ' '),
                    DECODE(NEW_STS_8, NULL, 'Y', ' '), NVL(NEW_STS_8, ' '),
                    DECODE(NEW_STS_9, NULL, 'Y', ' '), NVL(NEW_STS_9, ' '),
