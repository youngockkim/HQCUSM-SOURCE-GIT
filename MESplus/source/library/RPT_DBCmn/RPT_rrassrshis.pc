                    :RRASSRSHIS_N.TRAN_COMMENT.IS_NULL, :RRASSRSHIS_N.TRAN_COMMENT.VALUE, 
                    :RRASSRSHIS_N.LAST_DOWN_TIME.IS_NULL, :RRASSRSHIS_N.LAST_DOWN_TIME.VALUE, 
                    :RRASSRSHIS_N.LAST_DOWN_HIST_SEQ.IS_NULL, :RRASSRSHIS_N.LAST_DOWN_HIST_SEQ.VALUE, 
                    :RRASSRSHIS_N.HIST_START_SEQ.IS_NULL, :RRASSRSHIS_N.HIST_START_SEQ.VALUE, 
                    :RRASSRSHIS_N.HIST_DEL_FLAG.IS_NULL, :RRASSRSHIS_N.HIST_DEL_FLAG.VALUE, 
                    :RRASSRSHIS_N.HIST_DEL_TIME.IS_NULL, :RRASSRSHIS_N.HIST_DEL_TIME.VALUE, 
                    :RRASSRSHIS_N.HIST_DEL_USER_ID.IS_NULL, :RRASSRSHIS_N.HIST_DEL_USER_ID.VALUE, 
                    :RRASSRSHIS_N.HIST_DEL_COMMENT.IS_NULL, :RRASSRSHIS_N.HIST_DEL_COMMENT.VALUE, 
                    :RRASSRSHIS_N.END_DATE.IS_NULL, :RRASSRSHIS_N.END_DATE.VALUE, 
                    :RRASSRSHIS_N.EDC_DETAILS.IS_NULL, :RRASSRSHIS_N.EDC_DETAILS.VALUE, 
                    :RRASSRSHIS_N.REPAIR_PRIOR.IS_NULL, :RRASSRSHIS_N.REPAIR_PRIOR.VALUE 
                FROM RRASSRSHIS
                WHERE FACTORY = :RRASSRSHIS_N.FACTORY
                    AND RES_ID = :RRASSRSHIS_N.RES_ID
                    AND SUBRES_ID = :RRASSRSHIS_N.SUBRES_ID
                    AND HIST_SEQ = (SELECT MAX(HIST_SEQ) FROM RRASSRSHIS 
									 WHERE FACTORY = :RRASSRSHIS_N.FACTORY
									   AND RES_ID = :RRASSRSHIS_N.RES_ID
									   AND SUBRES_ID = :RRASSRSHIS_N.SUBRES_ID
									   AND HIST_SEQ < :RRASSRSHIS_N.HIST_SEQ
									   AND HIST_DEL_FLAG = 'N');
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rrassrshis(&RRASSRSHIS_N, RRASSRSHIS);
    }
    DB_stop_query_timer("RPT_select_rrassrshis", sel_type);
}


/* SQL SELECT_FOR_UPDATE Function */
void RPT_select_rrassrshis_for_update(int sel_type, struct RRASSRSHIS_TAG *RRASSRSHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASSRSHIS_N_TAG RRASSRSHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrassrshis(&RRASSRSHIS_N, RRASSRSHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    HIST_SEQ,
                    DECODE(EVENT_ID, NULL, 'Y', ' '), NVL(EVENT_ID, ' '),
