			DECODE(TRIM(OLD_STS_7), '', NULL, OLD_STS_7),
			DECODE(TRIM(OLD_STS_8), '', NULL, OLD_STS_8),
			DECODE(TRIM(OLD_STS_9), '', NULL, OLD_STS_9),
			DECODE(TRIM(OLD_STS_10), '', NULL, OLD_STS_10),
			DECODE(TRIM(NEW_UP_DOWN_FLAG), '', 'U', NEW_UP_DOWN_FLAG),
			DECODE(TRIM(NEW_PRI_STS), '', NULL, NEW_PRI_STS),
			DECODE(TRIM(NEW_STS_1), '', NULL, NEW_STS_1),
			DECODE(TRIM(NEW_STS_2), '', NULL, NEW_STS_2),
			DECODE(TRIM(NEW_STS_3), '', NULL, NEW_STS_3),
			DECODE(TRIM(NEW_STS_4), '', NULL, NEW_STS_4),
			DECODE(TRIM(NEW_STS_5), '', NULL, NEW_STS_5),
			DECODE(TRIM(NEW_STS_6), '', NULL, NEW_STS_6),
			DECODE(TRIM(NEW_STS_7), '', NULL, NEW_STS_7),
			DECODE(TRIM(NEW_STS_8), '', NULL, NEW_STS_8),
			DECODE(TRIM(NEW_STS_9), '', NULL, NEW_STS_9),
			DECODE(TRIM(NEW_STS_10), '', NULL, NEW_STS_10),
			DECODE(TRIM(LOT_EXIST_FLAG), '', NULL, LOT_EXIST_FLAG),
			DECODE(TRIM(TRAN_CMF_1), '', NULL, TRAN_CMF_1),
			DECODE(TRIM(TRAN_CMF_2), '', NULL, TRAN_CMF_2),
			DECODE(TRIM(TRAN_CMF_3), '', NULL, TRAN_CMF_3),
			DECODE(TRIM(TRAN_CMF_4), '', NULL, TRAN_CMF_4),
			DECODE(TRIM(TRAN_CMF_5), '', NULL, TRAN_CMF_5),
			DECODE(TRIM(TRAN_CMF_6), '', NULL, TRAN_CMF_6),
			DECODE(TRIM(TRAN_CMF_7), '', NULL, TRAN_CMF_7),
