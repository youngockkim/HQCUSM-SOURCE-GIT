/* SQL CURSOR FETCH Function */
void RPT_fetch_rrassrshis(int sel_type, struct RRASSRSHIS_TAG *RRASSRSHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASSRSHIS_N_TAG RRASSRSHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_RRASSRSHIS_CUR_1 INTO
                :RRASSRSHIS_N.FACTORY,
                :RRASSRSHIS_N.RES_ID,
