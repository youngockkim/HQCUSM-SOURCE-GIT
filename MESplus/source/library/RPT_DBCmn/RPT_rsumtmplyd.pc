/* Initialize Function */
void RPT_init_rsumtmplyd(struct RSUMTMPLYD_TAG *RSUMTMPLYD)
{
    /* memset by Space */
    memset(RSUMTMPLYD, ' ', sizeof(struct RSUMTMPLYD_TAG));
    
    RSUMTMPLYD->SEQ = 0;
    RSUMTMPLYD->HIST_SEQ = 0;
    RSUMTMPLYD->END_SEQ = 0;
    RSUMTMPLYD->IN_QTY = 0;
    RSUMTMPLYD->OUT_QTY = 0;
}


/* Add Null Function */
void RPT_add_null_rsumtmplyd(struct RSUMTMPLYD_N_TAG *RSUMTMPLYD_N, struct RSUMTMPLYD_TAG *RSUMTMPLYD)
{
    /* memset by NULL */
    memset(RSUMTMPLYD_N, '\0', sizeof(struct RSUMTMPLYD_N_TAG));
    
    MEMCPY_AN(RSUMTMPLYD_N->SUBLOT_ID, RSUMTMPLYD->SUBLOT_ID, sizeof(RSUMTMPLYD->SUBLOT_ID));
    MEMCPY_AN(RSUMTMPLYD_N->LOT_ID, RSUMTMPLYD->LOT_ID, sizeof(RSUMTMPLYD->LOT_ID));
    RSUMTMPLYD_N->PERIOD_TYPE[0] = RSUMTMPLYD->PERIOD_TYPE;
    MEMCPY_AN(RSUMTMPLYD_N->PERIOD_NAME, RSUMTMPLYD->PERIOD_NAME, sizeof(RSUMTMPLYD->PERIOD_NAME));
    RSUMTMPLYD_N->SEQ = RSUMTMPLYD->SEQ;
    RSUMTMPLYD_N->END_FLAG[0] = RSUMTMPLYD->END_FLAG;
    RSUMTMPLYD_N->END_SEQ = RSUMTMPLYD->END_SEQ;
    MEMCPY_AN(RSUMTMPLYD_N->FACTORY, RSUMTMPLYD->FACTORY, sizeof(RSUMTMPLYD->FACTORY));
    MEMCPY_AN(RSUMTMPLYD_N->TRAN_CODE, RSUMTMPLYD->TRAN_CODE, sizeof(RSUMTMPLYD->TRAN_CODE));
    RSUMTMPLYD_N->HIST_SEQ = RSUMTMPLYD->HIST_SEQ;
    MEMCPY_AN(RSUMTMPLYD_N->TRAN_TIME, RSUMTMPLYD->TRAN_TIME, sizeof(RSUMTMPLYD->TRAN_TIME));
    MEMCPY_AN(RSUMTMPLYD_N->OPER_NEW, RSUMTMPLYD->OPER_NEW, sizeof(RSUMTMPLYD->OPER_NEW));
    MEMCPY_AN(RSUMTMPLYD_N->OPER_OLD, RSUMTMPLYD->OPER_OLD, sizeof(RSUMTMPLYD->OPER_OLD));
    RSUMTMPLYD_N->GRADE_NEW[0] = RSUMTMPLYD->GRADE_NEW;
    RSUMTMPLYD_N->GRADE_OLD[0] = RSUMTMPLYD->GRADE_OLD;
    RSUMTMPLYD_N->IN_QTY = RSUMTMPLYD->IN_QTY;
    RSUMTMPLYD_N->OUT_QTY = RSUMTMPLYD->OUT_QTY;
    RSUMTMPLYD_N->ORIG_GRADE[0] = RSUMTMPLYD->ORIG_GRADE;
    MEMCPY_AN(RSUMTMPLYD_N->CREATE_TIME, RSUMTMPLYD->CREATE_TIME, sizeof(RSUMTMPLYD->CREATE_TIME));
    MEMCPY_AN(RSUMTMPLYD_N->UPDATE_TIME, RSUMTMPLYD->UPDATE_TIME, sizeof(RSUMTMPLYD->UPDATE_TIME));
}


/* Del Null Function */
void RPT_del_null_rsumtmplyd(struct RSUMTMPLYD_N_TAG *RSUMTMPLYD_N, struct RSUMTMPLYD_TAG *RSUMTMPLYD)
{
    MEMCPY_DN(RSUMTMPLYD->SUBLOT_ID, RSUMTMPLYD_N->SUBLOT_ID, sizeof(RSUMTMPLYD->SUBLOT_ID));
    MEMCPY_DN(RSUMTMPLYD->LOT_ID, RSUMTMPLYD_N->LOT_ID, sizeof(RSUMTMPLYD->LOT_ID));
    RSUMTMPLYD->PERIOD_TYPE = RSUMTMPLYD_N->PERIOD_TYPE[0];
    MEMCPY_DN(RSUMTMPLYD->PERIOD_NAME, RSUMTMPLYD_N->PERIOD_NAME, sizeof(RSUMTMPLYD->PERIOD_NAME));
    RSUMTMPLYD->SEQ = RSUMTMPLYD_N->SEQ;
    RSUMTMPLYD->END_FLAG = RSUMTMPLYD_N->END_FLAG[0];
    RSUMTMPLYD->END_SEQ = RSUMTMPLYD_N->END_SEQ;
    MEMCPY_DN(RSUMTMPLYD->FACTORY, RSUMTMPLYD_N->FACTORY, sizeof(RSUMTMPLYD->FACTORY));
    MEMCPY_DN(RSUMTMPLYD->TRAN_CODE, RSUMTMPLYD_N->TRAN_CODE, sizeof(RSUMTMPLYD->TRAN_CODE));
    RSUMTMPLYD->HIST_SEQ = RSUMTMPLYD_N->HIST_SEQ;
    MEMCPY_DN(RSUMTMPLYD->TRAN_TIME, RSUMTMPLYD_N->TRAN_TIME, sizeof(RSUMTMPLYD->TRAN_TIME));
    MEMCPY_DN(RSUMTMPLYD->OPER_NEW, RSUMTMPLYD_N->OPER_NEW, sizeof(RSUMTMPLYD->OPER_NEW));
    MEMCPY_DN(RSUMTMPLYD->OPER_OLD, RSUMTMPLYD_N->OPER_OLD, sizeof(RSUMTMPLYD->OPER_OLD));
    RSUMTMPLYD->GRADE_NEW = RSUMTMPLYD_N->GRADE_NEW[0];
    RSUMTMPLYD->GRADE_OLD = RSUMTMPLYD_N->GRADE_OLD[0];
    RSUMTMPLYD->IN_QTY = RSUMTMPLYD_N->IN_QTY;
    RSUMTMPLYD->OUT_QTY = RSUMTMPLYD_N->OUT_QTY;
    RSUMTMPLYD->ORIG_GRADE = RSUMTMPLYD_N->ORIG_GRADE[0];
    MEMCPY_DN(RSUMTMPLYD->CREATE_TIME, RSUMTMPLYD_N->CREATE_TIME, sizeof(RSUMTMPLYD->CREATE_TIME));
    MEMCPY_DN(RSUMTMPLYD->UPDATE_TIME, RSUMTMPLYD_N->UPDATE_TIME, sizeof(RSUMTMPLYD->UPDATE_TIME));
}


