/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rsumtmplyd(int sel_type, struct RSUMTMPLYD_TAG *RSUMTMPLYD)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RSUMTMPLYD_N_TAG RSUMTMPLYD_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rsumtmplyd(&RSUMTMPLYD_N, RSUMTMPLYD);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RSUMTMPLYD_CUR_1 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    LOT_ID,
                    PERIOD_TYPE,
                    PERIOD_NAME,
                    SEQ,
                    END_FLAG,
                    END_SEQ,
                    FACTORY,
                    TRAN_CODE,
                    HIST_SEQ,
                    TRAN_TIME,
                    OPER_NEW,
                    OPER_OLD,
                    GRADE_NEW,
                    GRADE_OLD,
                    IN_QTY,
                    OUT_QTY,
                    ORIG_GRADE,
                    CREATE_TIME,
                    UPDATE_TIME
                FROM RSUMTMPLYD
                ORDER BY SUBLOT_ID ASC,
                    LOT_ID ASC,
                    PERIOD_TYPE ASC,
                    PERIOD_NAME ASC,
                    SEQ ASC;
            EXEC SQL OPEN RPT_RSUMTMPLYD_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE RPT_RSUMTMPLYD_CUR_2 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    LOT_ID,
                    PERIOD_TYPE,
                    PERIOD_NAME,
                    SEQ,
                    END_FLAG,
                    END_SEQ,
                    FACTORY,
                    TRAN_CODE,
                    HIST_SEQ,
                    TRAN_TIME,
                    OPER_NEW,
                    OPER_OLD,
                    GRADE_NEW,
                    GRADE_OLD,
                    IN_QTY,
                    OUT_QTY,
                    ORIG_GRADE,
                    CREATE_TIME,
                    UPDATE_TIME
                FROM RSUMTMPLYD
                WHERE LOT_ID = :RSUMTMPLYD_N.LOT_ID
                  AND HIST_SEQ = :RSUMTMPLYD_N.HIST_SEQ
                  AND PERIOD_TYPE = :RSUMTMPLYD_N.PERIOD_TYPE
                  AND PERIOD_NAME = :RSUMTMPLYD_N.PERIOD_NAME
                  AND SEQ = (SELECT NVL(MAX(SEQ), 0) FROM RSUMTMPLYD
                              WHERE LOT_ID = :RSUMTMPLYD_N.LOT_ID
								AND PERIOD_TYPE = :RSUMTMPLYD_N.PERIOD_TYPE
								AND PERIOD_NAME = :RSUMTMPLYD_N.PERIOD_NAME)
                ORDER BY SUBLOT_ID ASC;
            EXEC SQL OPEN RPT_RSUMTMPLYD_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE RPT_RSUMTMPLYD_CUR_3 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    LOT_ID,
                    PERIOD_TYPE,
                    PERIOD_NAME,
                    SEQ,
                    END_FLAG,
                    END_SEQ,
                    FACTORY,
                    TRAN_CODE,
                    HIST_SEQ,
                    TRAN_TIME,
                    OPER_NEW,
                    OPER_OLD,
                    GRADE_NEW,
                    GRADE_OLD,
                    IN_QTY,
                    OUT_QTY,
                    ORIG_GRADE,
                    CREATE_TIME,
                    UPDATE_TIME
                FROM RSUMTMPLYD
                WHERE LOT_ID = :RSUMTMPLYD_N.LOT_ID
                  AND PERIOD_TYPE = :RSUMTMPLYD_N.PERIOD_TYPE
                  AND PERIOD_NAME = :RSUMTMPLYD_N.PERIOD_NAME
                  AND SEQ = (SELECT NVL(MAX(SEQ), 0) FROM RSUMTMPLYD
                              WHERE LOT_ID = :RSUMTMPLYD_N.LOT_ID
								AND PERIOD_TYPE = :RSUMTMPLYD_N.PERIOD_TYPE
								AND PERIOD_NAME = :RSUMTMPLYD_N.PERIOD_NAME
								AND END_FLAG = :RSUMTMPLYD_N.END_FLAG)
                ORDER BY SUBLOT_ID ASC;
            EXEC SQL OPEN RPT_RSUMTMPLYD_CUR_3;
            break;

        case 4:
            EXEC SQL DECLARE RPT_RSUMTMPLYD_CUR_4 CURSOR FOR
                SELECT 
                    SUBLOT_ID,
                    LOT_ID,
                    PERIOD_TYPE,
                    PERIOD_NAME,
                    SEQ,
                    END_FLAG,
                    END_SEQ,
                    FACTORY,
                    TRAN_CODE,
                    HIST_SEQ,
                    TRAN_TIME,
                    OPER_NEW,
                    OPER_OLD,
                    GRADE_NEW,
                    GRADE_OLD,
                    IN_QTY,
                    OUT_QTY,
                    ORIG_GRADE,
                    CREATE_TIME,
                    UPDATE_TIME
                FROM RSUMTMPLYD
                WHERE LOT_ID = :RSUMTMPLYD_N.LOT_ID
                  AND END_SEQ = :RSUMTMPLYD_N.END_SEQ
                  AND PERIOD_TYPE = :RSUMTMPLYD_N.PERIOD_TYPE
                  AND PERIOD_NAME = :RSUMTMPLYD_N.PERIOD_NAME
                  AND SEQ = (SELECT NVL(MAX(SEQ), 0) FROM RSUMTMPLYD
                              WHERE LOT_ID = :RSUMTMPLYD_N.LOT_ID
								AND PERIOD_TYPE = :RSUMTMPLYD_N.PERIOD_TYPE
								AND PERIOD_NAME = :RSUMTMPLYD_N.PERIOD_NAME)
                ORDER BY SUBLOT_ID ASC;
            EXEC SQL OPEN RPT_RSUMTMPLYD_CUR_4;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rsumtmplyd", sel_type);
}


