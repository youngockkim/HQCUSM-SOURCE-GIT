{
    /* memset by Space */
    memset(RSUMSECCYC, ' ', sizeof(struct RSUMSECCYC_TAG));
    
    RSUMSECCYC->HIST_SEQ = 0;
    RSUMSECCYC->TRAN_TIME.IS_NULL = 'Y';
    RSUMSECCYC->PARENT_LOT_ID.IS_NULL = 'Y';
    RSUMSECCYC->CYCLETIME_SECTION.IS_NULL = 'Y';
    RSUMSECCYC->OPER.IS_NULL = 'Y';
    RSUMSECCYC->RWK_FLAG.IS_NULL = 'Y';
