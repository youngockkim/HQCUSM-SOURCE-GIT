                    DECODE(DATE_CREATE, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_CREATE, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(DATE_UPDATE, NULL, 'Y', ' '), NVL(TO_CHAR(DATE_UPDATE, 'YYYYMMDDHH24MISS'), ' ')
                FROM RSUMSECCYC
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN RPT_RSUMSECCYC_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rsumseccyc", sel_type);
}


/* SQL CURSOR FETCH Function */
void RPT_fetch_rsumseccyc(int sel_type, struct RSUMSECCYC_TAG *RSUMSECCYC)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RSUMSECCYC_N_TAG RSUMSECCYC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_RSUMSECCYC_CUR_1 INTO
                :RSUMSECCYC_N.LOT_ID,
                :RSUMSECCYC_N.HIST_SEQ,
                :RSUMSECCYC_N.TRAN_TIME.IS_NULL, :RSUMSECCYC_N.TRAN_TIME.VALUE,
                :RSUMSECCYC_N.PARENT_LOT_ID.IS_NULL, :RSUMSECCYC_N.PARENT_LOT_ID.VALUE,
                :RSUMSECCYC_N.CYCLETIME_SECTION.IS_NULL, :RSUMSECCYC_N.CYCLETIME_SECTION.VALUE,
                :RSUMSECCYC_N.OPER.IS_NULL, :RSUMSECCYC_N.OPER.VALUE,
                :RSUMSECCYC_N.RWK_FLAG.IS_NULL, :RSUMSECCYC_N.RWK_FLAG.VALUE,
                :RSUMSECCYC_N.OWNER_CODE.IS_NULL, :RSUMSECCYC_N.OWNER_CODE.VALUE,
                :RSUMSECCYC_N.MAT_ID.IS_NULL, :RSUMSECCYC_N.MAT_ID.VALUE,
                :RSUMSECCYC_N.MAT_VER.IS_NULL, :RSUMSECCYC_N.MAT_VER.VALUE,
                :RSUMSECCYC_N.REPORTABLE_YN.IS_NULL, :RSUMSECCYC_N.REPORTABLE_YN.VALUE,
                :RSUMSECCYC_N.SECTION_START_TIME.IS_NULL, :RSUMSECCYC_N.SECTION_START_TIME.VALUE,
                :RSUMSECCYC_N.SECTION_CYCLETIME.IS_NULL, :RSUMSECCYC_N.SECTION_CYCLETIME.VALUE,
                :RSUMSECCYC_N.SECTION_PROC_TIME.IS_NULL, :RSUMSECCYC_N.SECTION_PROC_TIME.VALUE,
                :RSUMSECCYC_N.SECTION_WAIT_TIME.IS_NULL, :RSUMSECCYC_N.SECTION_WAIT_TIME.VALUE,
                :RSUMSECCYC_N.SECTION_STORE_TIME.IS_NULL, :RSUMSECCYC_N.SECTION_STORE_TIME.VALUE,
                :RSUMSECCYC_N.CYCLETIME_SECTION_NEW.IS_NULL, :RSUMSECCYC_N.CYCLETIME_SECTION_NEW.VALUE,
                :RSUMSECCYC_N.FACTORY.IS_NULL, :RSUMSECCYC_N.FACTORY.VALUE,
                :RSUMSECCYC_N.DATE_CREATE.IS_NULL, :RSUMSECCYC_N.DATE_CREATE.VALUE,
                :RSUMSECCYC_N.DATE_UPDATE.IS_NULL, :RSUMSECCYC_N.DATE_UPDATE.VALUE;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rsumseccyc(&RSUMSECCYC_N, RSUMSECCYC);
    }
    DB_stop_query_timer("RPT_fetch_rsumseccyc", sel_type);
}


