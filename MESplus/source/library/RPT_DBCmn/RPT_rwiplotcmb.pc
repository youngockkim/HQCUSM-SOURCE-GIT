    RWIPLOTCMB_N->MAT_VER = RWIPLOTCMB->MAT_VER;
    MEMCPY_AN(RWIPLOTCMB_N->FLOW, RWIPLOTCMB->FLOW, sizeof(RWIPLOTCMB->FLOW));
    RWIPLOTCMB_N->FLOW_SEQ_NUM = RWIPLOTCMB->FLOW_SEQ_NUM;
    MEMCPY_AN(RWIPLOTCMB_N->OPER, RWIPLOTCMB->OPER, sizeof(RWIPLOTCMB->OPER));
    RWIPLOTCMB_N->FROM_TO_FLAG[0] = RWIPLOTCMB->FROM_TO_FLAG;
    MEMCPY_AN(RWIPLOTCMB_N->FROM_TO_LOT_ID, RWIPLOTCMB->FROM_TO_LOT_ID, sizeof(RWIPLOTCMB->FROM_TO_LOT_ID));
    MEMCPY_AN(RWIPLOTCMB_N->FROM_TO_MAT_ID, RWIPLOTCMB->FROM_TO_MAT_ID, sizeof(RWIPLOTCMB->FROM_TO_MAT_ID));
    RWIPLOTCMB_N->FROM_TO_MAT_VER = RWIPLOTCMB->FROM_TO_MAT_VER;
    MEMCPY_AN(RWIPLOTCMB_N->FROM_TO_FLOW, RWIPLOTCMB->FROM_TO_FLOW, sizeof(RWIPLOTCMB->FROM_TO_FLOW));
    RWIPLOTCMB_N->FROM_TO_FLOW_SEQ_NUM = RWIPLOTCMB->FROM_TO_FLOW_SEQ_NUM;
    MEMCPY_AN(RWIPLOTCMB_N->FROM_TO_OPER, RWIPLOTCMB->FROM_TO_OPER, sizeof(RWIPLOTCMB->FROM_TO_OPER));
    RWIPLOTCMB_N->FROM_TO_QTY_1 = RWIPLOTCMB->FROM_TO_QTY_1;
    RWIPLOTCMB_N->FROM_TO_QTY_2 = RWIPLOTCMB->FROM_TO_QTY_2;
    RWIPLOTCMB_N->FROM_TO_QTY_3 = RWIPLOTCMB->FROM_TO_QTY_3;
    RWIPLOTCMB_N->FROM_TO_HIST_SEQ = RWIPLOTCMB->FROM_TO_HIST_SEQ;
}


/* Del Null Function */
void RPT_del_null_rwiplotcmb(struct RWIPLOTCMB_N_TAG *RWIPLOTCMB_N, struct RWIPLOTCMB_TAG *RWIPLOTCMB)
{
    MEMCPY_DN(RWIPLOTCMB->LOT_ID, RWIPLOTCMB_N->LOT_ID, sizeof(RWIPLOTCMB->LOT_ID));
    RWIPLOTCMB->HIST_SEQ = RWIPLOTCMB_N->HIST_SEQ;
    MEMCPY_DN(RWIPLOTCMB->TRAN_TIME, RWIPLOTCMB_N->TRAN_TIME, sizeof(RWIPLOTCMB->TRAN_TIME));
    RWIPLOTCMB->HIST_DEL_FLAG = RWIPLOTCMB_N->HIST_DEL_FLAG[0];
    MEMCPY_DN(RWIPLOTCMB->FACTORY, RWIPLOTCMB_N->FACTORY, sizeof(RWIPLOTCMB->FACTORY));
    MEMCPY_DN(RWIPLOTCMB->MAT_ID, RWIPLOTCMB_N->MAT_ID, sizeof(RWIPLOTCMB->MAT_ID));
    RWIPLOTCMB->MAT_VER = RWIPLOTCMB_N->MAT_VER;
    MEMCPY_DN(RWIPLOTCMB->FLOW, RWIPLOTCMB_N->FLOW, sizeof(RWIPLOTCMB->FLOW));
    RWIPLOTCMB->FLOW_SEQ_NUM = RWIPLOTCMB_N->FLOW_SEQ_NUM;
    MEMCPY_DN(RWIPLOTCMB->OPER, RWIPLOTCMB_N->OPER, sizeof(RWIPLOTCMB->OPER));
    RWIPLOTCMB->FROM_TO_FLAG = RWIPLOTCMB_N->FROM_TO_FLAG[0];
    MEMCPY_DN(RWIPLOTCMB->FROM_TO_LOT_ID, RWIPLOTCMB_N->FROM_TO_LOT_ID, sizeof(RWIPLOTCMB->FROM_TO_LOT_ID));
    MEMCPY_DN(RWIPLOTCMB->FROM_TO_MAT_ID, RWIPLOTCMB_N->FROM_TO_MAT_ID, sizeof(RWIPLOTCMB->FROM_TO_MAT_ID));
    RWIPLOTCMB->FROM_TO_MAT_VER = RWIPLOTCMB_N->FROM_TO_MAT_VER;
    MEMCPY_DN(RWIPLOTCMB->FROM_TO_FLOW, RWIPLOTCMB_N->FROM_TO_FLOW, sizeof(RWIPLOTCMB->FROM_TO_FLOW));
    RWIPLOTCMB->FROM_TO_FLOW_SEQ_NUM = RWIPLOTCMB_N->FROM_TO_FLOW_SEQ_NUM;
    MEMCPY_DN(RWIPLOTCMB->FROM_TO_OPER, RWIPLOTCMB_N->FROM_TO_OPER, sizeof(RWIPLOTCMB->FROM_TO_OPER));
    RWIPLOTCMB->FROM_TO_QTY_1 = RWIPLOTCMB_N->FROM_TO_QTY_1;
    RWIPLOTCMB->FROM_TO_QTY_2 = RWIPLOTCMB_N->FROM_TO_QTY_2;
    RWIPLOTCMB->FROM_TO_QTY_3 = RWIPLOTCMB_N->FROM_TO_QTY_3;
    RWIPLOTCMB->FROM_TO_HIST_SEQ = RWIPLOTCMB_N->FROM_TO_HIST_SEQ;
}


