/* Add Null Function */
void RPT_add_null_rwiplotcmb(struct RWIPLOTCMB_N_TAG *RWIPLOTCMB_N, struct RWIPLOTCMB_TAG *RWIPLOTCMB)
{
    /* memset by NULL */
    memset(RWIPLOTCMB_N, '\0', sizeof(struct RWIPLOTCMB_N_TAG));
    
    MEMCPY_AN(RWIPLOTCMB_N->LOT_ID, RWIPLOTCMB->LOT_ID, sizeof(RWIPLOTCMB->LOT_ID));
    RWIPLOTCMB_N->HIST_SEQ = RWIPLOTCMB->HIST_SEQ;
    MEMCPY_AN(RWIPLOTCMB_N->TRAN_TIME, RWIPLOTCMB->TRAN_TIME, sizeof(RWIPLOTCMB->TRAN_TIME));
    RWIPLOTCMB_N->HIST_DEL_FLAG[0] = RWIPLOTCMB->HIST_DEL_FLAG;
    MEMCPY_AN(RWIPLOTCMB_N->FACTORY, RWIPLOTCMB->FACTORY, sizeof(RWIPLOTCMB->FACTORY));
