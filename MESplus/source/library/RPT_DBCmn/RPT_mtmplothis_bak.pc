    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MTMPLOTHIS_BAK
                WHERE TABLE_UPDATE_SEQ = :MTMPLOTHIS_BAK_N.TABLE_UPDATE_SEQ;
