/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_mtmplothis_bak(int sel_type, struct MTMPLOTHIS_BAK_TAG *MTMPLOTHIS_BAK)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct MTMPLOTHIS_BAK_N_TAG MTMPLOTHIS_BAK_N;
	EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_mtmplothis_bak(&MTMPLOTHIS_BAK_N, MTMPLOTHIS_BAK);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_MTMPLOTHIS_BAK_CUR_1 CURSOR FOR
                SELECT 
                    TABLE_UPDATE_SEQ,
                    CM_KEY_1,
