/* SQL UPDATE Function */
void RPT_update_mtmplothis_bak(int sel_type, struct MTMPLOTHIS_BAK_TAG *MTMPLOTHIS_BAK)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct MTMPLOTHIS_BAK_N_TAG MTMPLOTHIS_BAK_N;
	EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_mtmplothis_bak(&MTMPLOTHIS_BAK_N, MTMPLOTHIS_BAK);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MTMPLOTHIS_BAK SET
                    CM_KEY_1 = :MTMPLOTHIS_BAK_N.CM_KEY_1,
