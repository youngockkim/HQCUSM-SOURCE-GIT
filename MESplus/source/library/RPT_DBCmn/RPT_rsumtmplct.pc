                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    LOT_ID,
                    HIST_SEQ,
                    PERIOD_TYPE,
                    PERIOD_NAME,
                    SEQ,
                    REWORK_FLAG,
                    FACTORY,
                    OPER,
                    WAITING_TIME,
                    PROCESS_TIME,
                    STORE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM  RSUMTMPLLC
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC,
                    PERIOD_TYPE ASC,
                    PERIOD_NAME ASC,
                    SEQ ASC;
            EXEC SQL OPEN RPT_ RSUMTMPLLC_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE RPT_ RSUMTMPLLC_CUR_2 CURSOR FOR
                SELECT LOT_ID, NVL(SUM(WAITING_TIME), 0), NVL(SUM(PROCESS_TIME), 0), NVL(SUM(STORE_TIME), 0) 
                FROM  RSUMTMPLLC
                WHERE PERIOD_TYPE = : RSUMTMPLLC_N.PERIOD_TYPE
                    AND PERIOD_NAME = : RSUMTMPLLC_N.PERIOD_NAME
                    AND SEQ = : RSUMTMPLLC_N.SEQ
                    AND LOT_ID = : RSUMTMPLLC_N.LOT_ID
                GROUP BY LOT_ID;
            EXEC SQL OPEN RPT_ RSUMTMPLLC_CUR_2;
            break;

        case 3:
            EXEC SQL DECLARE RPT_ RSUMTMPLLC_CUR_3 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    PERIOD_TYPE,
                    PERIOD_NAME,
                    SEQ,
                    REWORK_FLAG,
                    FACTORY,
                    OPER,
                    WAITING_TIME,
                    PROCESS_TIME,
                    STORE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    LOT_ID,
                    HIST_SEQ,
                    PERIOD_TYPE,
                    PERIOD_NAME,
                    SEQ,
                    REWORK_FLAG,
                    FACTORY,
                    OPER,
                    WAITING_TIME,
                    PROCESS_TIME,
                    STORE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM  RSUMTMPLLC
                WHERE REWORK_FLAG = : RSUMTMPLLC_N.REWORK_FLAG
                  AND LOT_ID = : RSUMTMPLLC_N.LOT_ID
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN RPT_ RSUMTMPLLC_CUR_3;
            break;

        case 4:
            EXEC SQL DECLARE RPT_ RSUMTMPLLC_CUR_4 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    PERIOD_TYPE,
                    PERIOD_NAME,
                    SEQ,
                    REWORK_FLAG,
                    FACTORY,
                    OPER,
                    WAITING_TIME,
                    PROCESS_TIME,
                    STORE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    LOT_ID,
                    HIST_SEQ,
                    PERIOD_TYPE,
                    PERIOD_NAME,
                    SEQ,
                    REWORK_FLAG,
                    FACTORY,
                    OPER,
                    WAITING_TIME,
                    PROCESS_TIME,
                    STORE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM  RSUMTMPLLC
                WHERE LOT_ID = : RSUMTMPLLC_N.LOT_ID
                  AND PERIOD_TYPE = : RSUMTMPLLC_N.PERIOD_TYPE
                  AND PERIOD_NAME = : RSUMTMPLLC_N.PERIOD_NAME
                  AND SEQ = (SELECT MAX(SEQ) FROM  RSUMTMPLLC
						 	  WHERE LOT_ID = : RSUMTMPLLC_N.LOT_ID
							    AND PERIOD_TYPE = : RSUMTMPLLC_N.PERIOD_TYPE
							    AND PERIOD_NAME = : RSUMTMPLLC_N.PERIOD_NAME)
                ORDER BY LOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN RPT_ RSUMTMPLLC_CUR_4;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rsumtmpllc", sel_type);
}


/* SQL CURSOR FETCH Function */
void RPT_fetch_rsumtmpllc(int sel_type, struct  RSUMTMPLLC_TAG * RSUMTMPLLC)
{
    struct  RSUMTMPLLC_N_TAG  RSUMTMPLLC_N;

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_ RSUMTMPLLC_CUR_1 INTO : RSUMTMPLLC_N;
            break;

        case 2:
            EXEC SQL FETCH RPT_ RSUMTMPLLC_CUR_2 INTO : RSUMTMPLLC_N.WAITING_TIME,
                                                     : RSUMTMPLLC_N.PROCESS_TIME,
                                                     : RSUMTMPLLC_N.STORE_TIME;
            break;

        case 3:
            EXEC SQL FETCH RPT_ RSUMTMPLLC_CUR_3 INTO : RSUMTMPLLC_N;
            break;

        case 4:
            EXEC SQL FETCH RPT_ RSUMTMPLLC_CUR_4 INTO : RSUMTMPLLC_N;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rsumtmpllc(& RSUMTMPLLC_N,  RSUMTMPLLC);
    }
    DB_stop_query_timer("RPT_fetch_rsumtmpllc", sel_type);
}


/* SQL CURSOR CLOSE Function */
void RPT_close_rsumtmpllc(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_ RSUMTMPLLC_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_rsumtmpllc", sel_type);
}


/* Initialize Function */
void RPT_init_rsumtmpllc(struct  RSUMTMPLLC_TAG * RSUMTMPLLC)
{
    /* memset by Space */
    memset( RSUMTMPLLC, ' ', sizeof(struct  RSUMTMPLLC_TAG));
    
     RSUMTMPLLC->HIST_SEQ = 0;
     RSUMTMPLLC->SEQ = 0;
     RSUMTMPLLC->WAITING_TIME = 0;
     RSUMTMPLLC->PROCESS_TIME = 0;
     RSUMTMPLLC->STORE_TIME = 0;
}


/* Add Null Function */
void RPT_add_null_rsumtmpllc(struct  RSUMTMPLLC_N_TAG * RSUMTMPLLC_N, struct  RSUMTMPLLC_TAG * RSUMTMPLLC)
{
    /* memset by NULL */
    memset( RSUMTMPLLC_N, '\0', sizeof(struct  RSUMTMPLLC_N_TAG));
    
    MEMCPY_AN( RSUMTMPLLC_N->LOT_ID,  RSUMTMPLLC->LOT_ID, sizeof( RSUMTMPLLC->LOT_ID));
     RSUMTMPLLC_N->HIST_SEQ =  RSUMTMPLLC->HIST_SEQ;
     RSUMTMPLLC_N->PERIOD_TYPE[0] =  RSUMTMPLLC->PERIOD_TYPE;
    MEMCPY_AN( RSUMTMPLLC_N->PERIOD_NAME,  RSUMTMPLLC->PERIOD_NAME, sizeof( RSUMTMPLLC->PERIOD_NAME));
     RSUMTMPLLC_N->SEQ =  RSUMTMPLLC->SEQ;
     RSUMTMPLLC_N->REWORK_FLAG[0] =  RSUMTMPLLC->REWORK_FLAG;
    MEMCPY_AN( RSUMTMPLLC_N->FACTORY,  RSUMTMPLLC->FACTORY, sizeof( RSUMTMPLLC->FACTORY));
    MEMCPY_AN( RSUMTMPLLC_N->OPER,  RSUMTMPLLC->OPER, sizeof( RSUMTMPLLC->OPER));
     RSUMTMPLLC_N->WAITING_TIME =  RSUMTMPLLC->WAITING_TIME;
     RSUMTMPLLC_N->PROCESS_TIME =  RSUMTMPLLC->PROCESS_TIME;
     RSUMTMPLLC_N->STORE_TIME =  RSUMTMPLLC->STORE_TIME;
    MEMCPY_AN( RSUMTMPLLC_N->CREATE_USER_ID,  RSUMTMPLLC->CREATE_USER_ID, sizeof( RSUMTMPLLC->CREATE_USER_ID));
    MEMCPY_AN( RSUMTMPLLC_N->CREATE_TIME,  RSUMTMPLLC->CREATE_TIME, sizeof( RSUMTMPLLC->CREATE_TIME));
    MEMCPY_AN( RSUMTMPLLC_N->UPDATE_USER_ID,  RSUMTMPLLC->UPDATE_USER_ID, sizeof( RSUMTMPLLC->UPDATE_USER_ID));
    MEMCPY_AN( RSUMTMPLLC_N->UPDATE_TIME,  RSUMTMPLLC->UPDATE_TIME, sizeof( RSUMTMPLLC->UPDATE_TIME));
}


/* Del Null Function */
void RPT_del_null_rsumtmpllc(struct  RSUMTMPLLC_N_TAG * RSUMTMPLLC_N, struct  RSUMTMPLLC_TAG * RSUMTMPLLC)
{
    MEMCPY_DN( RSUMTMPLLC->LOT_ID,  RSUMTMPLLC_N->LOT_ID, sizeof( RSUMTMPLLC->LOT_ID));
     RSUMTMPLLC->HIST_SEQ =  RSUMTMPLLC_N->HIST_SEQ;
     RSUMTMPLLC->PERIOD_TYPE =  RSUMTMPLLC_N->PERIOD_TYPE[0];
    MEMCPY_DN( RSUMTMPLLC->PERIOD_NAME,  RSUMTMPLLC_N->PERIOD_NAME, sizeof( RSUMTMPLLC->PERIOD_NAME));
     RSUMTMPLLC->SEQ =  RSUMTMPLLC_N->SEQ;
     RSUMTMPLLC->REWORK_FLAG =  RSUMTMPLLC_N->REWORK_FLAG[0];
    MEMCPY_DN( RSUMTMPLLC->FACTORY,  RSUMTMPLLC_N->FACTORY, sizeof( RSUMTMPLLC->FACTORY));
    MEMCPY_DN( RSUMTMPLLC->OPER,  RSUMTMPLLC_N->OPER, sizeof( RSUMTMPLLC->OPER));
     RSUMTMPLLC->WAITING_TIME =  RSUMTMPLLC_N->WAITING_TIME;
     RSUMTMPLLC->PROCESS_TIME =  RSUMTMPLLC_N->PROCESS_TIME;
     RSUMTMPLLC->STORE_TIME =  RSUMTMPLLC_N->STORE_TIME;
    MEMCPY_DN( RSUMTMPLLC->CREATE_USER_ID,  RSUMTMPLLC_N->CREATE_USER_ID, sizeof( RSUMTMPLLC->CREATE_USER_ID));
    MEMCPY_DN( RSUMTMPLLC->CREATE_TIME,  RSUMTMPLLC_N->CREATE_TIME, sizeof( RSUMTMPLLC->CREATE_TIME));
    MEMCPY_DN( RSUMTMPLLC->UPDATE_USER_ID,  RSUMTMPLLC_N->UPDATE_USER_ID, sizeof( RSUMTMPLLC->UPDATE_USER_ID));
    MEMCPY_DN( RSUMTMPLLC->UPDATE_TIME,  RSUMTMPLLC_N->UPDATE_TIME, sizeof( RSUMTMPLLC->UPDATE_TIME));
}


