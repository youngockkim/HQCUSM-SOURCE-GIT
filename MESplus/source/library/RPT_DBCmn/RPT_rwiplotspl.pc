    RWIPLOTSPL_N->MAT_VER = RWIPLOTSPL->MAT_VER;
    MEMCPY_AN(RWIPLOTSPL_N->FLOW, RWIPLOTSPL->FLOW, sizeof(RWIPLOTSPL->FLOW));
    RWIPLOTSPL_N->FLOW_SEQ_NUM = RWIPLOTSPL->FLOW_SEQ_NUM;
    MEMCPY_AN(RWIPLOTSPL_N->OPER, RWIPLOTSPL->OPER, sizeof(RWIPLOTSPL->OPER));
    RWIPLOTSPL_N->FROM_TO_FLAG[0] = RWIPLOTSPL->FROM_TO_FLAG;
    MEMCPY_AN(RWIPLOTSPL_N->FROM_TO_LOT_ID, RWIPLOTSPL->FROM_TO_LOT_ID, sizeof(RWIPLOTSPL->FROM_TO_LOT_ID));
    MEMCPY_AN(RWIPLOTSPL_N->FROM_TO_MAT_ID, RWIPLOTSPL->FROM_TO_MAT_ID, sizeof(RWIPLOTSPL->FROM_TO_MAT_ID));
    RWIPLOTSPL_N->FROM_TO_MAT_VER = RWIPLOTSPL->FROM_TO_MAT_VER;
    MEMCPY_AN(RWIPLOTSPL_N->FROM_TO_FLOW, RWIPLOTSPL->FROM_TO_FLOW, sizeof(RWIPLOTSPL->FROM_TO_FLOW));
    RWIPLOTSPL_N->FROM_TO_FLOW_SEQ_NUM = RWIPLOTSPL->FROM_TO_FLOW_SEQ_NUM;
    MEMCPY_AN(RWIPLOTSPL_N->FROM_TO_OPER, RWIPLOTSPL->FROM_TO_OPER, sizeof(RWIPLOTSPL->FROM_TO_OPER));
    RWIPLOTSPL_N->FROM_TO_QTY_1 = RWIPLOTSPL->FROM_TO_QTY_1;
    RWIPLOTSPL_N->FROM_TO_QTY_2 = RWIPLOTSPL->FROM_TO_QTY_2;
    RWIPLOTSPL_N->FROM_TO_QTY_3 = RWIPLOTSPL->FROM_TO_QTY_3;
    RWIPLOTSPL_N->FROM_TO_HIST_SEQ = RWIPLOTSPL->FROM_TO_HIST_SEQ;
}


/* Del Null Function */
void RPT_del_null_rwiplotspl(struct RWIPLOTSPL_N_TAG *RWIPLOTSPL_N, struct RWIPLOTSPL_TAG *RWIPLOTSPL)
{
    MEMCPY_DN(RWIPLOTSPL->LOT_ID, RWIPLOTSPL_N->LOT_ID, sizeof(RWIPLOTSPL->LOT_ID));
    RWIPLOTSPL->HIST_SEQ = RWIPLOTSPL_N->HIST_SEQ;
    MEMCPY_DN(RWIPLOTSPL->TRAN_TIME, RWIPLOTSPL_N->TRAN_TIME, sizeof(RWIPLOTSPL->TRAN_TIME));
    RWIPLOTSPL->HIST_DEL_FLAG = RWIPLOTSPL_N->HIST_DEL_FLAG[0];
    MEMCPY_DN(RWIPLOTSPL->FACTORY, RWIPLOTSPL_N->FACTORY, sizeof(RWIPLOTSPL->FACTORY));
    MEMCPY_DN(RWIPLOTSPL->MAT_ID, RWIPLOTSPL_N->MAT_ID, sizeof(RWIPLOTSPL->MAT_ID));
    RWIPLOTSPL->MAT_VER = RWIPLOTSPL_N->MAT_VER;
    MEMCPY_DN(RWIPLOTSPL->FLOW, RWIPLOTSPL_N->FLOW, sizeof(RWIPLOTSPL->FLOW));
    RWIPLOTSPL->FLOW_SEQ_NUM = RWIPLOTSPL_N->FLOW_SEQ_NUM;
    MEMCPY_DN(RWIPLOTSPL->OPER, RWIPLOTSPL_N->OPER, sizeof(RWIPLOTSPL->OPER));
    RWIPLOTSPL->FROM_TO_FLAG = RWIPLOTSPL_N->FROM_TO_FLAG[0];
    MEMCPY_DN(RWIPLOTSPL->FROM_TO_LOT_ID, RWIPLOTSPL_N->FROM_TO_LOT_ID, sizeof(RWIPLOTSPL->FROM_TO_LOT_ID));
    MEMCPY_DN(RWIPLOTSPL->FROM_TO_MAT_ID, RWIPLOTSPL_N->FROM_TO_MAT_ID, sizeof(RWIPLOTSPL->FROM_TO_MAT_ID));
    RWIPLOTSPL->FROM_TO_MAT_VER = RWIPLOTSPL_N->FROM_TO_MAT_VER;
    MEMCPY_DN(RWIPLOTSPL->FROM_TO_FLOW, RWIPLOTSPL_N->FROM_TO_FLOW, sizeof(RWIPLOTSPL->FROM_TO_FLOW));
    RWIPLOTSPL->FROM_TO_FLOW_SEQ_NUM = RWIPLOTSPL_N->FROM_TO_FLOW_SEQ_NUM;
    MEMCPY_DN(RWIPLOTSPL->FROM_TO_OPER, RWIPLOTSPL_N->FROM_TO_OPER, sizeof(RWIPLOTSPL->FROM_TO_OPER));
    RWIPLOTSPL->FROM_TO_QTY_1 = RWIPLOTSPL_N->FROM_TO_QTY_1;
    RWIPLOTSPL->FROM_TO_QTY_2 = RWIPLOTSPL_N->FROM_TO_QTY_2;
    RWIPLOTSPL->FROM_TO_QTY_3 = RWIPLOTSPL_N->FROM_TO_QTY_3;
    RWIPLOTSPL->FROM_TO_HIST_SEQ = RWIPLOTSPL_N->FROM_TO_HIST_SEQ;
}


