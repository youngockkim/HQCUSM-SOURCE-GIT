    MEMCPY_AN(RWIPLOTSPL_N->LOT_ID, RWIPLOTSPL->LOT_ID, sizeof(RWIPLOTSPL->LOT_ID));
    RWIPLOTSPL_N->HIST_SEQ = RWIPLOTSPL->HIST_SEQ;
