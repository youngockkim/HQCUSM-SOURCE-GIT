/* SQL INSERT-SELECT Function */
/* Added By Cloud Lee (2008. 3. 5) */
void RPT_insert_select_rwiplothld(struct RWIPLOTHLD_TAG *RWIPLOTHLD) 
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTHLD_N_TAG RWIPLOTHLD_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplothld(&RWIPLOTHLD_N, RWIPLOTHLD);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RWIPLOTHLD
        SELECT 
			LOT_ID,
			HIST_SEQ,
			HOLD_TRAN_TIME,
			RELEASE_TRAN_TIME,
			DECODE(TRIM(HIST_DEL_FLAG), '', 'N', HIST_DEL_FLAG),
			RELEASE_HIST_SEQ,
			FACTORY,
			MAT_ID,
			MAT_VER,
			FLOW,
			FLOW_SEQ_NUM,
			OPER,
			RES_ID,
			CAUSE_FLOW,
			CAUSE_OPER,
			CAUSE_RES_ID,
			QTY_1,
			QTY_2,
			QTY_3,
			CMF_1,
			CMF_2,
			CMF_3,
			CMF_4,
			CMF_5,
			CMF_6,
			CMF_7,
			CMF_8,
			CMF_9,
			CMF_10,
			CMF_11,
			CMF_12,
			CMF_13,
			CMF_14,
			CMF_15,
			CMF_16,
			CMF_17,
			CMF_18,
			CMF_19,
			CMF_20,
			HOLD_CODE,
			HOLD_USER_ID,
			HOLD_PRV_GRP_ID,
			HOLD_COMMENT,
			RELEASE_CODE,
			RELEASE_USER_ID,
			RELEASE_COMMENT,
			USER_ID_1,
			USER_TIME_1,
			USER_COMMENT_1,
			USER_ID_2,
			USER_TIME_2,
			USER_COMMENT_2,
			USER_ID_3,
			USER_TIME_3,
			USER_COMMENT_3     
        FROM MWIPLOTHLD
        WHERE LOT_ID = :RWIPLOTHLD_N.LOT_ID
        AND HIST_SEQ = :RWIPLOTHLD_N.HIST_SEQ;
    DB_stop_query_timer("RPT_insert_select_rwiplothld", 0);
}

