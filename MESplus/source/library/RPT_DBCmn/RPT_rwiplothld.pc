            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_update_rwiplothld", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rwiplothld(int sel_type, struct RWIPLOTHLD_TAG *RWIPLOTHLD)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTHLD_N_TAG RWIPLOTHLD_N;
    	char   sql[5120];
    	char   ts1[100];
    	char   ts2[100];
    	char   ts3[100];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rwiplothld(&RWIPLOTHLD_N, RWIPLOTHLD);
    DB_error_code = 0;
    
    memset( ts1, 0x00, sizeof(ts1));
    memset( ts2, 0x00, sizeof(ts2));
    memset( ts3, 0x00, sizeof(ts3));

    switch(sel_type)
    {
        case 1:
            memset( sql, 0x00, sizeof(sql));
            sprintf(sql,               "SELECT ");
            sprintf(sql + strlen(sql),   "LOT_ID, ");
            sprintf(sql + strlen(sql),   "HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "HOLD_TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "RELEASE_TRAN_TIME, ");
            sprintf(sql + strlen(sql),   "HIST_DEL_FLAG, ");
            sprintf(sql + strlen(sql),   "RELEASE_HIST_SEQ, ");
            sprintf(sql + strlen(sql),   "FACTORY, ");
