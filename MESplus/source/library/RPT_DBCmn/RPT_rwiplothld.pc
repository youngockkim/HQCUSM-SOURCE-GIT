                WHERE LOT_ID = :RWIPLOTHLD_N.LOT_ID
                    AND HIST_SEQ = :RWIPLOTHLD_N.HIST_SEQ;
            break;

        case 2:
            EXEC SQL UPDATE RWIPLOTHLD SET
                    HIST_DEL_FLAG = :RWIPLOTHLD_N.HIST_DEL_FLAG
                WHERE LOT_ID = :RWIPLOTHLD_N.LOT_ID
                    AND HIST_SEQ = :RWIPLOTHLD_N.HIST_SEQ;
            break;

        case 3:  /* Release Transaction */
            EXEC SQL UPDATE RWIPLOTHLD SET
                    RELEASE_TRAN_TIME = :RWIPLOTHLD_N.RELEASE_TRAN_TIME,
                    RELEASE_HIST_SEQ = :RWIPLOTHLD_N.RELEASE_HIST_SEQ,
                    RELEASE_CODE = :RWIPLOTHLD_N.RELEASE_CODE,
