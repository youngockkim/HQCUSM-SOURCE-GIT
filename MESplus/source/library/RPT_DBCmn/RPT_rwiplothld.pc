{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTHLD_N_TAG RWIPLOTHLD_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_RWIPLOTHLD_CUR_1 INTO 
                                                    :RWIPLOTHLD_N.LOT_ID,
                                                    :RWIPLOTHLD_N.HIST_SEQ,
                                                    :RWIPLOTHLD_N.HOLD_TRAN_TIME,
