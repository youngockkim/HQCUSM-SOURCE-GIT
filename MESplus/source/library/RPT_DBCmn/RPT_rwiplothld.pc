/* SQL CURSOR CLOSE Function */
void RPT_close_rwiplothld(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_RWIPLOTHLD_CUR_1;
            break;
        case 2:
            EXEC SQL CLOSE RPT_RWIPLOTHLD_CUR_2;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_rwiplothld", sel_type);
}


/* Initialize Function */
void RPT_init_rwiplothld(struct RWIPLOTHLD_TAG *RWIPLOTHLD)
{
    /* memset by Space */
    memset(RWIPLOTHLD, ' ', sizeof(struct RWIPLOTHLD_TAG));
    
    RWIPLOTHLD->HIST_SEQ = 0;
    RWIPLOTHLD->RELEASE_HIST_SEQ = 0;
    RWIPLOTHLD->MAT_VER = 0;
    RWIPLOTHLD->FLOW_SEQ_NUM = 0;
    RWIPLOTHLD->QTY_1 = 0;
    RWIPLOTHLD->QTY_2 = 0;
    RWIPLOTHLD->QTY_3 = 0;
}


/* Add Null Function */
void RPT_add_null_rwiplothld(struct RWIPLOTHLD_N_TAG *RWIPLOTHLD_N, struct RWIPLOTHLD_TAG *RWIPLOTHLD)
{
    /* memset by NULL */
    memset(RWIPLOTHLD_N, '\0', sizeof(struct RWIPLOTHLD_N_TAG));
    
    MEMCPY_AN(RWIPLOTHLD_N->LOT_ID, RWIPLOTHLD->LOT_ID, sizeof(RWIPLOTHLD->LOT_ID));
    RWIPLOTHLD_N->HIST_SEQ = RWIPLOTHLD->HIST_SEQ;
    MEMCPY_AN(RWIPLOTHLD_N->HOLD_TRAN_TIME, RWIPLOTHLD->HOLD_TRAN_TIME, sizeof(RWIPLOTHLD->HOLD_TRAN_TIME));
    MEMCPY_AN(RWIPLOTHLD_N->RELEASE_TRAN_TIME, RWIPLOTHLD->RELEASE_TRAN_TIME, sizeof(RWIPLOTHLD->RELEASE_TRAN_TIME));
    RWIPLOTHLD_N->HIST_DEL_FLAG[0] = RWIPLOTHLD->HIST_DEL_FLAG;
    RWIPLOTHLD_N->RELEASE_HIST_SEQ = RWIPLOTHLD->RELEASE_HIST_SEQ;
    MEMCPY_AN(RWIPLOTHLD_N->FACTORY, RWIPLOTHLD->FACTORY, sizeof(RWIPLOTHLD->FACTORY));
    MEMCPY_AN(RWIPLOTHLD_N->MAT_ID, RWIPLOTHLD->MAT_ID, sizeof(RWIPLOTHLD->MAT_ID));
    RWIPLOTHLD_N->MAT_VER = RWIPLOTHLD->MAT_VER;
    MEMCPY_AN(RWIPLOTHLD_N->FLOW, RWIPLOTHLD->FLOW, sizeof(RWIPLOTHLD->FLOW));
    RWIPLOTHLD_N->FLOW_SEQ_NUM = RWIPLOTHLD->FLOW_SEQ_NUM;
    MEMCPY_AN(RWIPLOTHLD_N->OPER, RWIPLOTHLD->OPER, sizeof(RWIPLOTHLD->OPER));
    MEMCPY_AN(RWIPLOTHLD_N->RES_ID, RWIPLOTHLD->RES_ID, sizeof(RWIPLOTHLD->RES_ID));
    MEMCPY_AN(RWIPLOTHLD_N->CAUSE_FLOW, RWIPLOTHLD->CAUSE_FLOW, sizeof(RWIPLOTHLD->CAUSE_FLOW));
    MEMCPY_AN(RWIPLOTHLD_N->CAUSE_OPER, RWIPLOTHLD->CAUSE_OPER, sizeof(RWIPLOTHLD->CAUSE_OPER));
    MEMCPY_AN(RWIPLOTHLD_N->CAUSE_RES_ID, RWIPLOTHLD->CAUSE_RES_ID, sizeof(RWIPLOTHLD->CAUSE_RES_ID));
    RWIPLOTHLD_N->QTY_1 = RWIPLOTHLD->QTY_1;
    RWIPLOTHLD_N->QTY_2 = RWIPLOTHLD->QTY_2;
    RWIPLOTHLD_N->QTY_3 = RWIPLOTHLD->QTY_3;
    MEMCPY_AN(RWIPLOTHLD_N->CMF_1, RWIPLOTHLD->CMF_1, sizeof(RWIPLOTHLD->CMF_1));
    MEMCPY_AN(RWIPLOTHLD_N->CMF_2, RWIPLOTHLD->CMF_2, sizeof(RWIPLOTHLD->CMF_2));
    MEMCPY_AN(RWIPLOTHLD_N->CMF_3, RWIPLOTHLD->CMF_3, sizeof(RWIPLOTHLD->CMF_3));
    MEMCPY_AN(RWIPLOTHLD_N->CMF_4, RWIPLOTHLD->CMF_4, sizeof(RWIPLOTHLD->CMF_4));
    MEMCPY_AN(RWIPLOTHLD_N->CMF_5, RWIPLOTHLD->CMF_5, sizeof(RWIPLOTHLD->CMF_5));
    MEMCPY_AN(RWIPLOTHLD_N->CMF_6, RWIPLOTHLD->CMF_6, sizeof(RWIPLOTHLD->CMF_6));
    MEMCPY_AN(RWIPLOTHLD_N->CMF_7, RWIPLOTHLD->CMF_7, sizeof(RWIPLOTHLD->CMF_7));
