/* SQL UPDATE Function */
void RPT_update_rwiplothld(int sel_type, struct RWIPLOTHLD_TAG *RWIPLOTHLD)
{
    EXEC SQL BEGIN DECLARE SECTION;
    	struct RWIPLOTHLD_N_TAG RWIPLOTHLD_N;
    EXEC SQL END DECLARE SECTION;

