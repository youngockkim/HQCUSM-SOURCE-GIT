                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    DELETE_USER_ID,
                    DELETE_TIME
                FROM MEDCRESDAT
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SUBRES_ID ASC,
                    HIST_SEQ ASC,
                    CHAR_SEQ_NUM ASC,
                    UNIT_SEQ_NUM ASC,
                    VALUE_SEQ_NUM ASC;
            EXEC SQL OPEN RPT_MEDCRESDAT_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE RPT_MEDCRESDAT_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    HIST_SEQ,
                    COL_SEQ,
                    EVENT_ID,
                    TRAN_TIME,
                    RECIPE_ID,
                    RECIPE_VERSION,
                    HIST_DEL_FLAG,
                    COL_SET_ID,
                    COL_SET_VERSION,
                    CHAR_SEQ_NUM,
                    CHAR_ID,
                    UNIT_SEQ_NUM,
                    UNIT_ID,
                    VALUE_SEQ_NUM,
                    VALUE_TYPE,
                    VALUE_COUNT,
                    VALUE_1,
                    VALUE_2,
                    VALUE_3,
                    VALUE_4,
                    VALUE_5,
                    VALUE_6,
                    VALUE_7,
                    VALUE_8,
                    VALUE_9,
                    VALUE_10,
                    VALUE_11,
                    VALUE_12,
                    VALUE_13,
                    VALUE_14,
                    VALUE_15,
                    VALUE_16,
                    VALUE_17,
                    VALUE_18,
                    VALUE_19,
                    VALUE_20,
                    VALUE_21,
                    VALUE_22,
                    VALUE_23,
                    VALUE_24,
                    VALUE_25,
                    SAMPLE_COUNT,
                    NOMINAL,
                    PROCESS_SIGMA,
                    SPEC_OUT_MASK,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    DELETE_USER_ID,
                    DELETE_TIME
                FROM MEDCRESDAT
                WHERE FACTORY = :MEDCRESDAT_N.FACTORY
                  AND RES_ID = :MEDCRESDAT_N.RES_ID
                  AND SUBRES_ID = :MEDCRESDAT_N.SUBRES_ID
                  AND HIST_SEQ = :MEDCRESDAT_N.HIST_SEQ
                  AND COL_SET_ID = :MEDCRESDAT_N.COL_SET_ID
                  AND COL_SEQ = :MEDCRESDAT_N.COL_SEQ
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SUBRES_ID ASC,
                    HIST_SEQ ASC,
                    CHAR_SEQ_NUM ASC,
                    UNIT_SEQ_NUM ASC,
                    VALUE_SEQ_NUM ASC;
            EXEC SQL OPEN RPT_MEDCRESDAT_CUR_2;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_medcresdat", sel_type);
}


