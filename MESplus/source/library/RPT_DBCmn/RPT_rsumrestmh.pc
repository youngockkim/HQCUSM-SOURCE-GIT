/* Initialize Function */
void RPT_init_rsumrestmh(struct RSUMRESTMH_TAG *RSUMRESTMH)
{
    /* memset by Space */
    memset(RSUMRESTMH, ' ', sizeof(struct RSUMRESTMH_TAG));
    
