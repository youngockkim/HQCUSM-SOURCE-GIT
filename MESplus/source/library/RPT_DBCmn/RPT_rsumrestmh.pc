}


/* Add Null Function */
void RPT_add_null_rsumrestmh(struct RSUMRESTMH_N_TAG *RSUMRESTMH_N, struct RSUMRESTMH_TAG *RSUMRESTMH)
{
    /* memset by NULL */
    memset(RSUMRESTMH_N, '\0', sizeof(struct RSUMRESTMH_N_TAG));
    
    MEMCPY_AN(RSUMRESTMH_N->WORK_DATE, RSUMRESTMH->WORK_DATE, sizeof(RSUMRESTMH->WORK_DATE));
    MEMCPY_AN(RSUMRESTMH_N->FACTORY, RSUMRESTMH->FACTORY, sizeof(RSUMRESTMH->FACTORY));
    MEMCPY_AN(RSUMRESTMH_N->RES_ID, RSUMRESTMH->RES_ID, sizeof(RSUMRESTMH->RES_ID));
    RSUMRESTMH_N->RES_UP_DOWN_FLAG[0] = RSUMRESTMH->RES_UP_DOWN_FLAG;
    MEMCPY_AN(RSUMRESTMH_N->RES_PRI_STS, RSUMRESTMH->RES_PRI_STS, sizeof(RSUMRESTMH->RES_PRI_STS));
    RSUMRESTMH_N->TIME_SUM = RSUMRESTMH->TIME_SUM;
}


/* Del Null Function */
void RPT_del_null_rsumrestmh(struct RSUMRESTMH_N_TAG *RSUMRESTMH_N, struct RSUMRESTMH_TAG *RSUMRESTMH)
{
    MEMCPY_DN(RSUMRESTMH->WORK_DATE, RSUMRESTMH_N->WORK_DATE, sizeof(RSUMRESTMH->WORK_DATE));
    MEMCPY_DN(RSUMRESTMH->FACTORY, RSUMRESTMH_N->FACTORY, sizeof(RSUMRESTMH->FACTORY));
    MEMCPY_DN(RSUMRESTMH->RES_ID, RSUMRESTMH_N->RES_ID, sizeof(RSUMRESTMH->RES_ID));
    RSUMRESTMH->RES_UP_DOWN_FLAG = RSUMRESTMH_N->RES_UP_DOWN_FLAG[0];
    MEMCPY_DN(RSUMRESTMH->RES_PRI_STS, RSUMRESTMH_N->RES_PRI_STS, sizeof(RSUMRESTMH->RES_PRI_STS));
    RSUMRESTMH->TIME_SUM = RSUMRESTMH_N->TIME_SUM;
}


