/* SQL CURSOR CLOSE Function */
void RPT_close_mwiplotsts(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_MWIPLOTSTS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE RPT_MWIPLOTSTS_CUR_2;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_mwiplotsts", sel_type);
}


/* Initialize Function */
void RPT_init_mwiplotsts(struct MWIPLOTSTS_TAG *MWIPLOTSTS)
{
    /* memset by Space */
    memset(MWIPLOTSTS, ' ', sizeof(struct MWIPLOTSTS_TAG));
    
    MWIPLOTSTS->MAT_VER = 0;
    MWIPLOTSTS->FLOW_SEQ_NUM = 0;
    MWIPLOTSTS->QTY_1 = 0;
    MWIPLOTSTS->QTY_2 = 0;
    MWIPLOTSTS->QTY_3 = 0;
    MWIPLOTSTS->OPER_IN_QTY_1 = 0;
    MWIPLOTSTS->OPER_IN_QTY_2 = 0;
    MWIPLOTSTS->OPER_IN_QTY_3 = 0;
    MWIPLOTSTS->CREATE_QTY_1 = 0;
    MWIPLOTSTS->CREATE_QTY_2 = 0;
    MWIPLOTSTS->CREATE_QTY_3 = 0;
    MWIPLOTSTS->START_QTY_1 = 0;
    MWIPLOTSTS->START_QTY_2 = 0;
    MWIPLOTSTS->START_QTY_3 = 0;
    MWIPLOTSTS->RWK_COUNT = 0;
    MWIPLOTSTS->RWK_RET_FLOW_SEQ_NUM = 0;
    MWIPLOTSTS->RWK_END_FLOW_SEQ_NUM = 0;
    MWIPLOTSTS->NSTD_RET_FLOW_SEQ_NUM = 0;
    MWIPLOTSTS->BATCH_SEQ = 0;
    MWIPLOTSTS->BOM_SET_VERSION = 0;
    MWIPLOTSTS->BOM_ACTIVE_HIST_SEQ = 0;
    MWIPLOTSTS->BOM_HIST_SEQ = 0;
    MWIPLOTSTS->LAST_ACTIVE_HIST_SEQ = 0;
    MWIPLOTSTS->LAST_HIST_SEQ = 0;
}


