/* SQL SELECT_SCALAR Function */
double RPT_select_mwiplotsts_scalar(int sel_type, struct MWIPLOTSTS_TAG *MWIPLOTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct MWIPLOTSTS_N_TAG MWIPLOTSTS_N;
		double d_value;
	EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_mwiplotsts(&MWIPLOTSTS_N, MWIPLOTSTS);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTSTS
                WHERE FACTORY = :MWIPLOTSTS_N.FACTORY 
                    AND LOT_DEL_FLAG<>'Y' 
                    AND TRANSIT_FLAG<>'Y';
            break;
            
        case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTSTS
                WHERE LOT_DEL_FLAG<>'Y' 
                    AND TRANSIT_FLAG<>'Y';
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("RPT_select_mwiplotsts_scalar", sel_type);
    return d_value;
}


