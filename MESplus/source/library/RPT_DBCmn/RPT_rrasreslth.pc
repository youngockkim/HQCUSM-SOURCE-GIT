/* SQL SELECT - INSERT Function */
void RPT_select_insert_rrasreslth(struct RRASRESLTH_TAG *RRASRESLTH)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASRESLTH_N_TAG RRASRESLTH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrasreslth(&RRASRESLTH_N, RRASRESLTH);
    DB_error_code = 0;

    EXEC SQL INSERT INTO RRASRESLTH
		SELECT
			FACTORY,
			RES_ID,
			RES_HIST_SEQ,
			LOT_ID,
			DECODE(TRIM(RES_HIST_DEL_FLAG), '', 'N', RES_HIST_DEL_FLAG),
			DECODE(TRIM(EVENT_ID), '', NULL, EVENT_ID),
			DECODE(TRIM(TRAN_TIME), '', NULL, TO_DATE(TRAN_TIME, 'YYYYMMDDHH24MISS')),
			DECODE(TRIM(LOT_HIST_SEQ), '', 0, LOT_HIST_SEQ),
			DECODE(TRIM(LOT_HIST_DEL_FLAG), '', 'N', LOT_HIST_DEL_FLAG),
			DECODE(TRIM(MAT_ID), '', NULL, MAT_ID),
			DECODE(TRIM(MAT_VER), '', NULL, MAT_VER),
			DECODE(TRIM(FLOW), '', NULL, FLOW),
			DECODE(TRIM(OPER), '', NULL, OPER),
			DECODE(TRIM(LOT_TYPE), '', NULL, LOT_TYPE),
			DECODE(TRIM(RWK_FLAG), '', NULL, RWK_FLAG),
			DECODE(TRIM(QTY_1), '', 0, QTY_1),
			DECODE(TRIM(QTY_2), '', 0, QTY_2),
            DECODE(TRIM(QTY_3), '', 0, QTY_3),
            DECODE(TRIM(RES_SEQ), '', 0, RES_SEQ),
			DECODE(TRIM(SUBRES_ID), '', NULL, SUBRES_ID),
			DECODE(TRIM(PORT_ID), '', NULL, PORT_ID),
			DECODE(TRIM(CRR_ID), '', NULL, CRR_ID)
		FROM MRASRESLTH
        WHERE FACTORY = :RRASRESLTH_N.FACTORY
          AND RES_ID = :RRASRESLTH_N.RES_ID
          AND RES_HIST_SEQ = :RRASRESLTH_N.RES_HIST_SEQ;
    DB_stop_query_timer("RPT_select_insert_rrasreslth", 0);
}

