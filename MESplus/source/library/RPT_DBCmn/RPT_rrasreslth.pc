            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        RPT_del_null_rrasreslth(&RRASRESLTH_N, RRASRESLTH);
    }
    DB_stop_query_timer("RPT_fetch_rrasreslth", sel_type);
