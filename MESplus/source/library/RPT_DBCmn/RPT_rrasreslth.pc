                :RRASRESLTH_N.LOT_TYPE.IS_NULL, :RRASRESLTH_N.LOT_TYPE.VALUE,
                :RRASRESLTH_N.RWK_FLAG.IS_NULL, :RRASRESLTH_N.RWK_FLAG.VALUE,
                :RRASRESLTH_N.QTY_1.IS_NULL, :RRASRESLTH_N.QTY_1.VALUE,
                :RRASRESLTH_N.QTY_2.IS_NULL, :RRASRESLTH_N.QTY_2.VALUE,
                :RRASRESLTH_N.QTY_3.IS_NULL, :RRASRESLTH_N.QTY_3.VALUE,
                :RRASRESLTH_N.RES_SEQ.IS_NULL, :RRASRESLTH_N.RES_SEQ.VALUE,
				:RRASRESLTH_N.SUBRES_ID.IS_NULL, :RRASRESLTH_N.SUBRES_ID.VALUE,
				:RRASRESLTH_N.PORT_ID.IS_NULL, :RRASRESLTH_N.PORT_ID.VALUE,
