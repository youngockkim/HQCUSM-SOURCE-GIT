            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_update_rrasreslth", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void RPT_open_rrasreslth(int sel_type, struct RRASRESLTH_TAG *RRASRESLTH)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASRESLTH_N_TAG RRASRESLTH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    RPT_add_null_rrasreslth(&RRASRESLTH_N, RRASRESLTH);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE RPT_RRASRESLTH_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    RES_HIST_SEQ,
                    LOT_ID,
                    DECODE(RES_HIST_DEL_FLAG, NULL, 'Y', ' '), NVL(RES_HIST_DEL_FLAG, 'N'),
                    DECODE(EVENT_ID, NULL, 'Y', ' '), NVL(EVENT_ID, ' '),
                    DECODE(TRAN_TIME, NULL, 'Y', ' '), NVL(TO_CHAR(TRAN_TIME, 'YYYYMMDDHH24MISS'), ' '),
                    DECODE(LOT_HIST_SEQ, NULL, 'Y', ' '), NVL(LOT_HIST_SEQ, '0'),
                    DECODE(LOT_HIST_DEL_FLAG, NULL, 'Y', ' '), NVL(LOT_HIST_DEL_FLAG, 'N'),
                    DECODE(MAT_ID, NULL, 'Y', ' '), NVL(MAT_ID, ' '),
                    DECODE(MAT_VER, NULL, 'Y', ' '), NVL(MAT_VER, '0'),
                    DECODE(FLOW, NULL, 'Y', ' '), NVL(FLOW, ' '),
                    DECODE(OPER, NULL, 'Y', ' '), NVL(OPER, ' '),
                    DECODE(LOT_TYPE, NULL, 'Y', ' '), NVL(LOT_TYPE, ' '),
                    DECODE(RWK_FLAG, NULL, 'Y', ' '), NVL(RWK_FLAG, ' '),
                    DECODE(QTY_1, NULL, 'Y', ' '), NVL(QTY_1, '0'),
                    DECODE(QTY_2, NULL, 'Y', ' '), NVL(QTY_2, '0'),
                    DECODE(QTY_3, NULL, 'Y', ' '), NVL(QTY_3, '0'),
                    DECODE(RES_SEQ, NULL, 'Y', ' '), NVL(RES_SEQ, '0'),
					DECODE(SUBRES_ID, NULL, 'Y', ' '), NVL(SUBRES_ID, ' '),
					DECODE(PORT_ID, NULL, 'Y', ' '), NVL(PORT_ID, ' '),
					DECODE(CRR_ID, NULL, 'Y', ' '), NVL(CRR_ID, ' ')
                FROM RRASRESLTH
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    RES_HIST_SEQ ASC,
                    LOT_ID ASC;
            EXEC SQL OPEN RPT_RRASRESLTH_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("RPT_open_rrasreslth", sel_type);
}


/* SQL CURSOR FETCH Function */
void RPT_fetch_rrasreslth(int sel_type, struct RRASRESLTH_TAG *RRASRESLTH)
{
    EXEC SQL BEGIN DECLARE SECTION;
		struct RRASRESLTH_N_TAG RRASRESLTH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH RPT_RRASRESLTH_CUR_1 INTO
                :RRASRESLTH_N.FACTORY,
