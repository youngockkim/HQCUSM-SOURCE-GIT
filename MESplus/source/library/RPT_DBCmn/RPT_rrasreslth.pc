    RRASRESLTH->MAT_VER.IS_NULL = RRASRESLTH_N->MAT_VER.IS_NULL[0];
    RRASRESLTH->MAT_VER.VALUE = RRASRESLTH_N->MAT_VER.VALUE;
    RRASRESLTH->FLOW.IS_NULL = RRASRESLTH_N->FLOW.IS_NULL[0];
    MEMCPY_DN(RRASRESLTH->FLOW.VALUE, RRASRESLTH_N->FLOW.VALUE, sizeof(RRASRESLTH->FLOW.VALUE));
    RRASRESLTH->OPER.IS_NULL = RRASRESLTH_N->OPER.IS_NULL[0];
    MEMCPY_DN(RRASRESLTH->OPER.VALUE, RRASRESLTH_N->OPER.VALUE, sizeof(RRASRESLTH->OPER.VALUE));
    RRASRESLTH->LOT_TYPE.IS_NULL = RRASRESLTH_N->LOT_TYPE.IS_NULL[0];
    RRASRESLTH->LOT_TYPE.VALUE = RRASRESLTH_N->LOT_TYPE.VALUE[0];
    RRASRESLTH->RWK_FLAG.IS_NULL = RRASRESLTH_N->RWK_FLAG.IS_NULL[0];
    RRASRESLTH->RWK_FLAG.VALUE = RRASRESLTH_N->RWK_FLAG.VALUE[0];
    RRASRESLTH->QTY_1.IS_NULL = RRASRESLTH_N->QTY_1.IS_NULL[0];
    RRASRESLTH->QTY_1.VALUE = RRASRESLTH_N->QTY_1.VALUE;
    RRASRESLTH->QTY_2.IS_NULL = RRASRESLTH_N->QTY_2.IS_NULL[0];
    RRASRESLTH->QTY_2.VALUE = RRASRESLTH_N->QTY_2.VALUE;
    RRASRESLTH->QTY_3.IS_NULL = RRASRESLTH_N->QTY_3.IS_NULL[0];
    RRASRESLTH->QTY_3.VALUE = RRASRESLTH_N->QTY_3.VALUE;
    RRASRESLTH->RES_SEQ.IS_NULL = RRASRESLTH_N->RES_SEQ.IS_NULL[0];
    RRASRESLTH->RES_SEQ.VALUE = RRASRESLTH_N->RES_SEQ.VALUE;
	RRASRESLTH->SUBRES_ID.IS_NULL = RRASRESLTH_N->SUBRES_ID.IS_NULL[0];
    MEMCPY_DN(RRASRESLTH->SUBRES_ID.VALUE, RRASRESLTH_N->SUBRES_ID.VALUE, sizeof(RRASRESLTH->SUBRES_ID.VALUE));
	RRASRESLTH->PORT_ID.IS_NULL = RRASRESLTH_N->PORT_ID.IS_NULL[0];
    MEMCPY_DN(RRASRESLTH->PORT_ID.VALUE, RRASRESLTH_N->PORT_ID.VALUE, sizeof(RRASRESLTH->PORT_ID.VALUE));
	RRASRESLTH->CRR_ID.IS_NULL = RRASRESLTH_N->CRR_ID.IS_NULL[0];
