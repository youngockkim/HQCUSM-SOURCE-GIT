/* Initialize Function */
void RPT_init_rrasreslth(struct RRASRESLTH_TAG *RRASRESLTH)
{
    /* memset by Space */
    memset(RRASRESLTH, ' ', sizeof(struct RRASRESLTH_TAG));
    
    RRASRESLTH->RES_HIST_SEQ = 0;
    RRASRESLTH->RES_HIST_DEL_FLAG.IS_NULL = 'Y';
    RRASRESLTH->EVENT_ID.IS_NULL = 'Y';
    RRASRESLTH->TRAN_TIME.IS_NULL = 'Y';
    RRASRESLTH->LOT_HIST_SEQ.VALUE = 0;
    RRASRESLTH->LOT_HIST_SEQ.IS_NULL = 'Y';
    RRASRESLTH->LOT_HIST_DEL_FLAG.IS_NULL = 'Y';
    RRASRESLTH->MAT_ID.IS_NULL = 'Y';
    RRASRESLTH->MAT_VER.VALUE = 0;
    RRASRESLTH->MAT_VER.IS_NULL = 'Y';
    RRASRESLTH->FLOW.IS_NULL = 'Y';
    RRASRESLTH->OPER.IS_NULL = 'Y';
    RRASRESLTH->LOT_TYPE.IS_NULL = 'Y';
    RRASRESLTH->RWK_FLAG.IS_NULL = 'Y';
    RRASRESLTH->QTY_1.VALUE = 0;
    RRASRESLTH->QTY_1.IS_NULL = 'Y';
    RRASRESLTH->QTY_2.VALUE = 0;
    RRASRESLTH->QTY_2.IS_NULL = 'Y';
    RRASRESLTH->QTY_3.VALUE = 0;
    RRASRESLTH->QTY_3.IS_NULL = 'Y';
    RRASRESLTH->RES_SEQ.VALUE = 0;
    RRASRESLTH->RES_SEQ.IS_NULL = 'Y';
	RRASRESLTH->SUBRES_ID.IS_NULL = 'Y';
	RRASRESLTH->PORT_ID.IS_NULL = 'Y';
	RRASRESLTH->CRR_ID.IS_NULL = 'Y';
}


/* Add Null Function */
void RPT_add_null_rrasreslth(struct RRASRESLTH_N_TAG *RRASRESLTH_N, struct RRASRESLTH_TAG *RRASRESLTH)
{
    /* memset by NULL */
    memset(RRASRESLTH_N, '\0', sizeof(struct RRASRESLTH_N_TAG));
    
    MEMCPY_AN(RRASRESLTH_N->FACTORY, RRASRESLTH->FACTORY, sizeof(RRASRESLTH->FACTORY));
    MEMCPY_AN(RRASRESLTH_N->RES_ID, RRASRESLTH->RES_ID, sizeof(RRASRESLTH->RES_ID));
    RRASRESLTH_N->RES_HIST_SEQ = RRASRESLTH->RES_HIST_SEQ;
    MEMCPY_AN(RRASRESLTH_N->LOT_ID, RRASRESLTH->LOT_ID, sizeof(RRASRESLTH->LOT_ID));
    RRASRESLTH_N->RES_HIST_DEL_FLAG.IS_NULL[0] = RRASRESLTH->RES_HIST_DEL_FLAG.IS_NULL;
    RRASRESLTH_N->RES_HIST_DEL_FLAG.VALUE[0] = RRASRESLTH->RES_HIST_DEL_FLAG.VALUE;
    RRASRESLTH_N->EVENT_ID.IS_NULL[0] = RRASRESLTH->EVENT_ID.IS_NULL;
    MEMCPY_AN(RRASRESLTH_N->EVENT_ID.VALUE, RRASRESLTH->EVENT_ID.VALUE, sizeof(RRASRESLTH->EVENT_ID.VALUE));
    RRASRESLTH_N->TRAN_TIME.IS_NULL[0] = RRASRESLTH->TRAN_TIME.IS_NULL;
    MEMCPY_AN(RRASRESLTH_N->TRAN_TIME.VALUE, RRASRESLTH->TRAN_TIME.VALUE, sizeof(RRASRESLTH->TRAN_TIME.VALUE));
    RRASRESLTH_N->LOT_HIST_SEQ.IS_NULL[0] = RRASRESLTH->LOT_HIST_SEQ.IS_NULL;
    RRASRESLTH_N->LOT_HIST_SEQ.VALUE = RRASRESLTH->LOT_HIST_SEQ.VALUE;
    RRASRESLTH_N->LOT_HIST_DEL_FLAG.IS_NULL[0] = RRASRESLTH->LOT_HIST_DEL_FLAG.IS_NULL;
    RRASRESLTH_N->LOT_HIST_DEL_FLAG.VALUE[0] = RRASRESLTH->LOT_HIST_DEL_FLAG.VALUE;
    RRASRESLTH_N->MAT_ID.IS_NULL[0] = RRASRESLTH->MAT_ID.IS_NULL;
    MEMCPY_AN(RRASRESLTH_N->MAT_ID.VALUE, RRASRESLTH->MAT_ID.VALUE, sizeof(RRASRESLTH->MAT_ID.VALUE));
    RRASRESLTH_N->MAT_VER.IS_NULL[0] = RRASRESLTH->MAT_VER.IS_NULL;
    RRASRESLTH_N->MAT_VER.VALUE = RRASRESLTH->MAT_VER.VALUE;
    RRASRESLTH_N->FLOW.IS_NULL[0] = RRASRESLTH->FLOW.IS_NULL;
    MEMCPY_AN(RRASRESLTH_N->FLOW.VALUE, RRASRESLTH->FLOW.VALUE, sizeof(RRASRESLTH->FLOW.VALUE));
    RRASRESLTH_N->OPER.IS_NULL[0] = RRASRESLTH->OPER.IS_NULL;
    MEMCPY_AN(RRASRESLTH_N->OPER.VALUE, RRASRESLTH->OPER.VALUE, sizeof(RRASRESLTH->OPER.VALUE));
    RRASRESLTH_N->LOT_TYPE.IS_NULL[0] = RRASRESLTH->LOT_TYPE.IS_NULL;
    RRASRESLTH_N->LOT_TYPE.VALUE[0] = RRASRESLTH->LOT_TYPE.VALUE;
    RRASRESLTH_N->RWK_FLAG.IS_NULL[0] = RRASRESLTH->RWK_FLAG.IS_NULL;
    RRASRESLTH_N->RWK_FLAG.VALUE[0] = RRASRESLTH->RWK_FLAG.VALUE;
    RRASRESLTH_N->QTY_1.IS_NULL[0] = RRASRESLTH->QTY_1.IS_NULL;
    RRASRESLTH_N->QTY_1.VALUE = RRASRESLTH->QTY_1.VALUE;
    RRASRESLTH_N->QTY_2.IS_NULL[0] = RRASRESLTH->QTY_2.IS_NULL;
    RRASRESLTH_N->QTY_2.VALUE = RRASRESLTH->QTY_2.VALUE;
    RRASRESLTH_N->QTY_3.IS_NULL[0] = RRASRESLTH->QTY_3.IS_NULL;
    RRASRESLTH_N->QTY_3.VALUE = RRASRESLTH->QTY_3.VALUE;
    RRASRESLTH_N->RES_SEQ.IS_NULL[0] = RRASRESLTH->RES_SEQ.IS_NULL;
    RRASRESLTH_N->RES_SEQ.VALUE = RRASRESLTH->RES_SEQ.VALUE;
	RRASRESLTH_N->SUBRES_ID.IS_NULL[0] = RRASRESLTH->SUBRES_ID.IS_NULL;
    MEMCPY_AN(RRASRESLTH_N->SUBRES_ID.VALUE, RRASRESLTH->SUBRES_ID.VALUE, sizeof(RRASRESLTH->SUBRES_ID.VALUE));
	RRASRESLTH_N->PORT_ID.IS_NULL[0] = RRASRESLTH->PORT_ID.IS_NULL;
    MEMCPY_AN(RRASRESLTH_N->PORT_ID.VALUE, RRASRESLTH->PORT_ID.VALUE, sizeof(RRASRESLTH->PORT_ID.VALUE));
	RRASRESLTH_N->CRR_ID.IS_NULL[0] = RRASRESLTH->CRR_ID.IS_NULL;
    MEMCPY_AN(RRASRESLTH_N->CRR_ID.VALUE, RRASRESLTH->CRR_ID.VALUE, sizeof(RRASRESLTH->CRR_ID.VALUE));
}


/* Del Null Function */
void RPT_del_null_rrasreslth(struct RRASRESLTH_N_TAG *RRASRESLTH_N, struct RRASRESLTH_TAG *RRASRESLTH)
{
    MEMCPY_DN(RRASRESLTH->FACTORY, RRASRESLTH_N->FACTORY, sizeof(RRASRESLTH->FACTORY));
    MEMCPY_DN(RRASRESLTH->RES_ID, RRASRESLTH_N->RES_ID, sizeof(RRASRESLTH->RES_ID));
    RRASRESLTH->RES_HIST_SEQ = RRASRESLTH_N->RES_HIST_SEQ;
    MEMCPY_DN(RRASRESLTH->LOT_ID, RRASRESLTH_N->LOT_ID, sizeof(RRASRESLTH->LOT_ID));
    RRASRESLTH->RES_HIST_DEL_FLAG.IS_NULL = RRASRESLTH_N->RES_HIST_DEL_FLAG.IS_NULL[0];
    RRASRESLTH->RES_HIST_DEL_FLAG.VALUE = RRASRESLTH_N->RES_HIST_DEL_FLAG.VALUE[0];
