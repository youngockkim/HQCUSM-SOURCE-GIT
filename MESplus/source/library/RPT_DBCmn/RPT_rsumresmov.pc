/* SQL CURSOR CLOSE Function */
void RPT_close_rsumresmov(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE RPT_RSUMRESMOV_CUR_1;
            break;

        /* TODO : Insert your code(case 101 ~ ) */
        case 101:

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("RPT_close_rsumresmov", sel_type);
}


/* Initialize Function */
void RPT_init_rsumresmov(struct RSUMRESMOV_TAG *RSUMRESMOV)
{
    /* memset by Space */
    memset(RSUMRESMOV, ' ', sizeof(struct RSUMRESMOV_TAG));
    
    RSUMRESMOV->MAT_VER = 0;
    RSUMRESMOV->FLOW_SEQ_NUM = 0;
    RSUMRESMOV->START_LOT = 0;
    RSUMRESMOV->START_QTY_1 = 0;
