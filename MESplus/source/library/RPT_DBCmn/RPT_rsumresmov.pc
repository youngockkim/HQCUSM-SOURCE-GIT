    RSUMRESMOV->END_RWK_LOT = 0;
    RSUMRESMOV->END_RWK_QTY_1 = 0;
    RSUMRESMOV->END_RWK_QTY_2 = 0;
    RSUMRESMOV->END_RWK_QTY_3 = 0;
