            EXEC SQL FETCH BDB_MWIPBINUNT_CUR_1 INTO
                :MWIPBINUNT_N.CREATE_USER_ID,
                :MWIPBINUNT_N.CREATE_TIME,
                :MWIPBINUNT_N.UPDATE_USER_ID,
                :MWIPBINUNT_N.UPDATE_TIME,
                :MWIPBINUNT_N.FACTORY,
                :MWIPBINUNT_N.BIN_ID,
                :MWIPBINUNT_N.BIN_VERSION,
                :MWIPBINUNT_N.BIN_UNIT,
                :MWIPBINUNT_N.BIN_UNIT_DESC,
                :MWIPBINUNT_N.TOT_SPLIT_FLAG,
                :MWIPBINUNT_N.YIELD_CALC_TYPE,
                :MWIPBINUNT_N.YIELD_BASE,
                :MWIPBINUNT_N.YIELD_BASE_OPER,
                :MWIPBINUNT_N.UPPER_LIMIT,
                :MWIPBINUNT_N.LOWER_LIMIT,
                :MWIPBINUNT_N.ALARM_ID,
                :MWIPBINUNT_N.USE_SPEC_LIMIT_FLAG,
                :MWIPBINUNT_N.USE_SPEC_CHAR_ID,
                :MWIPBINUNT_N.BIN_UNIT_CMF_1,
                :MWIPBINUNT_N.BIN_UNIT_CMF_2,
                :MWIPBINUNT_N.BIN_UNIT_CMF_3,
                :MWIPBINUNT_N.BIN_UNIT_CMF_4,
                :MWIPBINUNT_N.BIN_UNIT_CMF_5,
                :MWIPBINUNT_N.BIN_UNIT_CMF_6,
                :MWIPBINUNT_N.BIN_UNIT_CMF_7,
                :MWIPBINUNT_N.BIN_UNIT_CMF_8,
                :MWIPBINUNT_N.BIN_UNIT_CMF_9,
                :MWIPBINUNT_N.BIN_UNIT_CMF_10,
                :MWIPBINUNT_N.BIN_UNIT_CMF_11,
                :MWIPBINUNT_N.BIN_UNIT_CMF_12,
                :MWIPBINUNT_N.BIN_UNIT_CMF_13,
                :MWIPBINUNT_N.BIN_UNIT_CMF_14,
                :MWIPBINUNT_N.BIN_UNIT_CMF_15,
                :MWIPBINUNT_N.BIN_UNIT_CMF_16,
                :MWIPBINUNT_N.BIN_UNIT_CMF_17,
                :MWIPBINUNT_N.BIN_UNIT_CMF_18,
                :MWIPBINUNT_N.BIN_UNIT_CMF_19,
                :MWIPBINUNT_N.BIN_UNIT_CMF_20;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        BDB_del_null_mwipbinunt(&MWIPBINUNT_N, MWIPBINUNT);
    }

    DB_stop_query_timer("BDB_fetch_mwipbinunt", sel_type);
}


/* SQL CURSOR CLOSE Function */
void BDB_close_mwipbinunt(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE BDB_MWIPBINUNT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("BDB_close_mwipbinunt", sel_type);
}


/* Initialize Function */
void BDB_init_mwipbinunt(struct MWIPBINUNT_TAG *MWIPBINUNT)
{
    /* memset by Space */
    memset(MWIPBINUNT, ' ', sizeof(struct MWIPBINUNT_TAG));
    
    MWIPBINUNT->BIN_VERSION = 0;
}


