                    FLOW_SEQ_NUM,
                    OPER,
                    FROM_FACTORY,
                    FROM_FLOW,
                    FROM_FLOW_SEQ_NUM,
                    FROM_OPER,
                    FROM_POINT_FLAG,
                    CHECK_POINT_FLAG,
                    UPPER_WARN_QUE_TIME,
                    LOWER_WARN_QUE_TIME,
                    WARN_ALARM_ID,
                    UPPER_ERR_QUE_TIME,
                    LOWER_ERR_QUE_TIME,
                    ERROR_ALARM_ID,
                    PRIORITY,
                    SUBLOT_FLAG,
                    VIO_RULE_FLAG,
                    VIO_LIMIT_NUM,
                    SEARCH_MRG_HIS_FLAG,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CMF_11,
                    CMF_12,
                    CMF_13,
                    CMF_14,
                    CMF_15,
                    CMF_16,
                    CMF_17,
                    CMF_18,
                    CMF_19,
                    CMF_20,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MWIPQTMDEF
                ORDER BY FACTORY ASC,
                    MAT_ID ASC,
                    MAT_VER ASC,
                    FLOW ASC,
                    FLOW_SEQ_NUM ASC,
                    OPER ASC,
                    FROM_FACTORY ASC,
                    FROM_FLOW ASC,
                    FROM_FLOW_SEQ_NUM ASC,
                    FROM_OPER ASC,
                    FROM_POINT_FLAG ASC,
                    CHECK_POINT_FLAG ASC;
            EXEC SQL OPEN BDB_MWIPQTMDEF_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("BDB_open_mwipqtmdef", sel_type);
}

/* SQL CURSOR FETCH Function */
void BDB_fetch_mwipqtmdef(int sel_type, struct MWIPQTMDEF_TAG *MWIPQTMDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPQTMDEF_N_TAG MWIPQTMDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH BDB_MWIPQTMDEF_CUR_1 INTO
                :MWIPQTMDEF_N.FACTORY,
                :MWIPQTMDEF_N.MAT_ID,
                :MWIPQTMDEF_N.MAT_VER,
                :MWIPQTMDEF_N.FLOW,
                :MWIPQTMDEF_N.FLOW_SEQ_NUM,
                :MWIPQTMDEF_N.OPER,
                :MWIPQTMDEF_N.FROM_FACTORY,
                :MWIPQTMDEF_N.FROM_FLOW,
                :MWIPQTMDEF_N.FROM_FLOW_SEQ_NUM,
                :MWIPQTMDEF_N.FROM_OPER,
                :MWIPQTMDEF_N.FROM_POINT_FLAG,
                :MWIPQTMDEF_N.CHECK_POINT_FLAG,
                :MWIPQTMDEF_N.UPPER_WARN_QUE_TIME,
                :MWIPQTMDEF_N.LOWER_WARN_QUE_TIME,
                :MWIPQTMDEF_N.WARN_ALARM_ID,
                :MWIPQTMDEF_N.UPPER_ERR_QUE_TIME,
                :MWIPQTMDEF_N.LOWER_ERR_QUE_TIME,
                :MWIPQTMDEF_N.ERROR_ALARM_ID,
                :MWIPQTMDEF_N.PRIORITY,
                :MWIPQTMDEF_N.SUBLOT_FLAG,
                :MWIPQTMDEF_N.VIO_RULE_FLAG,
                :MWIPQTMDEF_N.VIO_LIMIT_NUM,
                :MWIPQTMDEF_N.SEARCH_MRG_HIS_FLAG,
                :MWIPQTMDEF_N.CMF_1,
                :MWIPQTMDEF_N.CMF_2,
                :MWIPQTMDEF_N.CMF_3,
                :MWIPQTMDEF_N.CMF_4,
                :MWIPQTMDEF_N.CMF_5,
                :MWIPQTMDEF_N.CMF_6,
                :MWIPQTMDEF_N.CMF_7,
                :MWIPQTMDEF_N.CMF_8,
                :MWIPQTMDEF_N.CMF_9,
                :MWIPQTMDEF_N.CMF_10,
                :MWIPQTMDEF_N.CMF_11,
                :MWIPQTMDEF_N.CMF_12,
                :MWIPQTMDEF_N.CMF_13,
                :MWIPQTMDEF_N.CMF_14,
                :MWIPQTMDEF_N.CMF_15,
                :MWIPQTMDEF_N.CMF_16,
                :MWIPQTMDEF_N.CMF_17,
                :MWIPQTMDEF_N.CMF_18,
                :MWIPQTMDEF_N.CMF_19,
                :MWIPQTMDEF_N.CMF_20,
                :MWIPQTMDEF_N.CREATE_USER_ID,
                :MWIPQTMDEF_N.CREATE_TIME,
                :MWIPQTMDEF_N.UPDATE_USER_ID,
                :MWIPQTMDEF_N.UPDATE_TIME;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        BDB_del_null_mwipqtmdef(&MWIPQTMDEF_N, MWIPQTMDEF);
    }

    DB_stop_query_timer("BDB_fetch_mwipqtmdef", sel_type);
}

/* SQL CURSOR CLOSE Function */
void BDB_close_mwipqtmdef(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE BDB_MWIPQTMDEF_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("BDB_close_mwipqtmdef", sel_type);
}

/* Initialize Function */
void BDB_init_mwipqtmdef(struct MWIPQTMDEF_TAG *MWIPQTMDEF)
{
    /* memset by Space */
    memset(MWIPQTMDEF, ' ', sizeof(struct MWIPQTMDEF_TAG));
    
    MWIPQTMDEF->MAT_VER = 0;
    MWIPQTMDEF->FLOW_SEQ_NUM = 0;
    MWIPQTMDEF->FROM_FLOW_SEQ_NUM = 0;
    MWIPQTMDEF->UPPER_WARN_QUE_TIME = 0;
    MWIPQTMDEF->LOWER_WARN_QUE_TIME = 0;
    MWIPQTMDEF->UPPER_ERR_QUE_TIME = 0;
    MWIPQTMDEF->LOWER_ERR_QUE_TIME = 0;
    MWIPQTMDEF->PRIORITY = 0;
    MWIPQTMDEF->VIO_LIMIT_NUM = 0;
}


/* Add Null Function */
