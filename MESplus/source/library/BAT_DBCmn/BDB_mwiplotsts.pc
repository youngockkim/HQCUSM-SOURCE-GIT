            sprintf(sql + strlen(sql),   "RESV_FIELD_4, ");
            sprintf(sql + strlen(sql),   "RESV_FIELD_5, ");
            sprintf(sql + strlen(sql),   "RESV_FLAG_1, ");
            sprintf(sql + strlen(sql),   "RESV_FLAG_2, ");
            sprintf(sql + strlen(sql),   "RESV_FLAG_3, ");
            sprintf(sql + strlen(sql),   "RESV_FLAG_4, ");
            sprintf(sql + strlen(sql),   "RESV_FLAG_5 ");
            sprintf(sql + strlen(sql), "FROM MWIPLOTSTS WHERE LOT_DEL_FLAG = ' ' ");

            if(ISSPACE(MWIPLOTSTS->FACTORY, sizeof(MWIPLOTSTS->FACTORY)) == DB_FALSE)
            {
                make_valid_quote(ts1, MWIPLOTSTS_N.FACTORY);
                sprintf(sql + strlen(sql), "AND FACTORY = '%s' ", ts1);
            }
            if(ISSPACE(MWIPLOTSTS->MAT_ID, sizeof(MWIPLOTSTS->MAT_ID)) == DB_FALSE)
            {
                make_valid_quote(ts1, MWIPLOTSTS_N.MAT_ID);
                sprintf(sql + strlen(sql), "AND MAT_ID = '%s' ", ts1);
            }
            if(MWIPLOTSTS->MAT_VER > 0)
            {
                sprintf(sql + strlen(sql), "AND MAT_VER = %d ", MWIPLOTSTS->MAT_VER);
            }
            if(ISSPACE(MWIPLOTSTS->FLOW, sizeof(MWIPLOTSTS->FLOW)) == DB_FALSE)
            {
                make_valid_quote(ts1, MWIPLOTSTS_N.FLOW);
                sprintf(sql + strlen(sql), "AND FLOW = '%s' ", ts1);
            }
            if(ISSPACE(MWIPLOTSTS->OPER, sizeof(MWIPLOTSTS->OPER)) == DB_FALSE)
            {
                make_valid_quote(ts1, MWIPLOTSTS_N.OPER);
                sprintf(sql + strlen(sql), "AND OPER = '%s' ", ts1);
            }
            sprintf(sql + strlen(sql), "ORDER BY LOT_ID ASC");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE BDB_MWIPLOTSTS_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN BDB_MWIPLOTSTS_CUR_2;                 
            break;
            
            
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("BDB_open_mwiplotsts", sel_type);
}


