                    :MWIPLOTSTS_N.BOM_ACTIVE_HIST_SEQ,
                    :MWIPLOTSTS_N.BOM_HIST_SEQ,
                    :MWIPLOTSTS_N.LAST_TRAN_CODE,
                    :MWIPLOTSTS_N.LAST_TRAN_TIME,
                    :MWIPLOTSTS_N.LAST_COMMENT,
                    :MWIPLOTSTS_N.LAST_ACTIVE_HIST_SEQ,
                    :MWIPLOTSTS_N.LAST_HIST_SEQ,
                    :MWIPLOTSTS_N.CRITICAL_RES_ID,
                    :MWIPLOTSTS_N.CRITICAL_RES_GROUP_ID,
                    :MWIPLOTSTS_N.SAVE_RES_ID_1,
                    :MWIPLOTSTS_N.SAVE_RES_ID_2,
                    :MWIPLOTSTS_N.SUBRES_ID,
                    :MWIPLOTSTS_N.LOT_GROUP_ID_1,
                    :MWIPLOTSTS_N.LOT_GROUP_ID_2,
                    :MWIPLOTSTS_N.LOT_GROUP_ID_3,
                    :MWIPLOTSTS_N.YIELD_1,
                    :MWIPLOTSTS_N.YIELD_2,
                    :MWIPLOTSTS_N.YIELD_3,
                    :MWIPLOTSTS_N.GOOD_QTY,
                    :MWIPLOTSTS_N.RESV_FIELD_1,
                    :MWIPLOTSTS_N.RESV_FIELD_2,
                    :MWIPLOTSTS_N.RESV_FIELD_3,
                    :MWIPLOTSTS_N.RESV_FIELD_4,
                    :MWIPLOTSTS_N.RESV_FIELD_5,
                    :MWIPLOTSTS_N.RESV_FLAG_1,
                    :MWIPLOTSTS_N.RESV_FLAG_2,
                    :MWIPLOTSTS_N.RESV_FLAG_3,
                    :MWIPLOTSTS_N.RESV_FLAG_4,
                    :MWIPLOTSTS_N.RESV_FLAG_5
                FROM MWIPLOTSTS
                WHERE LOT_ID = :MWIPLOTSTS_N.LOT_ID
                FOR UPDATE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        BDB_del_null_mwiplotsts(&MWIPLOTSTS_N, MWIPLOTSTS);
    }
    DB_stop_query_timer("BDB_select_mwiplotsts_for_update", sel_type);
}


/* SQL SELECT_SCALAR Function */
double BDB_select_mwiplotsts_scalar(int sel_type, struct MWIPLOTSTS_TAG *MWIPLOTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTSTS_N_TAG MWIPLOTSTS_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    

    BDB_add_null_mwiplotsts(&MWIPLOTSTS_N, MWIPLOTSTS);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM MWIPLOTSTS
                WHERE FACTORY = :MWIPLOTSTS_N.FACTORY
                AND MAT_ID = :MWIPLOTSTS_N.MAT_ID
                AND MAT_VER = :MWIPLOTSTS_N.MAT_VER
                AND LOT_DEL_FLAG = :MWIPLOTSTS_N.LOT_DEL_FLAG;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("BDB_select_mwiplotsts_scalar", sel_type);
    return d_value;
}


/* SQL DELETE Function */
void BDB_delete_mwiplotsts(int sel_type, struct MWIPLOTSTS_TAG *MWIPLOTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTSTS_N_TAG MWIPLOTSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    BDB_add_null_mwiplotsts(&MWIPLOTSTS_N, MWIPLOTSTS);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM MWIPLOTSTS
                WHERE LOT_ID = :MWIPLOTSTS_N.LOT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    DB_stop_query_timer("BDB_delete_mwiplotsts", sel_type);
}


