/* SQL UPDATE Function */
void BDB_update_mwiplotsts(int sel_type, struct MWIPLOTSTS_TAG *MWIPLOTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTSTS_N_TAG MWIPLOTSTS_N;
        struct MWIPLOTSTS_TAG   MWIPLOTSTS_S;
        char   sql[10000];
        char   ts[1000];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();



    BDB_add_null_mwiplotsts(&MWIPLOTSTS_N, MWIPLOTSTS);
    DB_error_code = 0;
    memset(sql, 0x00, sizeof(sql));
    memset(ts, 0x00, sizeof(ts));

    switch(sel_type)
    {
        case 1:
        
            BDB_init_mwiplotsts(&MWIPLOTSTS_S);
            memcpy(MWIPLOTSTS_S.LOT_ID, MWIPLOTSTS->LOT_ID, sizeof(MWIPLOTSTS_S.LOT_ID));
            BDB_select_mwiplotsts(1, &MWIPLOTSTS_S);
            if(DB_error_code != DB_SUCCESS) break;

            make_valid_quote(ts, MWIPLOTSTS_N.LOT_ID);
            sprintf(sql, "UPDATE MWIPLOTSTS SET LOT_ID='%s'", ts);

            if(memcmp(MWIPLOTSTS->LOT_DESC, MWIPLOTSTS_S.LOT_DESC, sizeof(MWIPLOTSTS->LOT_DESC)) != 0) {
                make_valid_quote(ts, MWIPLOTSTS_N.LOT_DESC);
                sprintf(sql + strlen(sql), ", LOT_DESC='%s'", ts);
            }
            if(memcmp(MWIPLOTSTS->FACTORY, MWIPLOTSTS_S.FACTORY, sizeof(MWIPLOTSTS->FACTORY)) != 0) {
                make_valid_quote(ts, MWIPLOTSTS_N.FACTORY);
                sprintf(sql + strlen(sql), ", FACTORY='%s'", ts);
            }
            if(memcmp(MWIPLOTSTS->MAT_ID, MWIPLOTSTS_S.MAT_ID, sizeof(MWIPLOTSTS->MAT_ID)) != 0) {
                make_valid_quote(ts, MWIPLOTSTS_N.MAT_ID);
                sprintf(sql + strlen(sql), ", MAT_ID='%s'", ts);
            }
            if(MWIPLOTSTS->MAT_VER != MWIPLOTSTS_S.MAT_VER) {
                sprintf(sql + strlen(sql), ", MAT_VER=%d", MWIPLOTSTS_N.MAT_VER);
            }
            if(memcmp(MWIPLOTSTS->FLOW, MWIPLOTSTS_S.FLOW, sizeof(MWIPLOTSTS->FLOW)) != 0) {
                make_valid_quote(ts, MWIPLOTSTS_N.FLOW);
                sprintf(sql + strlen(sql), ", FLOW='%s'", ts);
            }
            if(MWIPLOTSTS->FLOW_SEQ_NUM != MWIPLOTSTS_S.FLOW_SEQ_NUM) {
                sprintf(sql + strlen(sql), ", FLOW_SEQ_NUM=%d", MWIPLOTSTS_N.FLOW_SEQ_NUM);
            }
            if(memcmp(MWIPLOTSTS->OPER, MWIPLOTSTS_S.OPER, sizeof(MWIPLOTSTS->OPER)) != 0) {
                make_valid_quote(ts, MWIPLOTSTS_N.OPER);
                sprintf(sql + strlen(sql), ", OPER='%s'", ts);
            }
            if(MWIPLOTSTS->QTY_1 != MWIPLOTSTS_S.QTY_1) {
                sprintf(sql + strlen(sql), ", QTY_1=%f", MWIPLOTSTS_N.QTY_1);
            }
            if(MWIPLOTSTS->QTY_2 != MWIPLOTSTS_S.QTY_2) {
                sprintf(sql + strlen(sql), ", QTY_2=%f", MWIPLOTSTS_N.QTY_2);
            }
            if(MWIPLOTSTS->QTY_3 != MWIPLOTSTS_S.QTY_3) {
                sprintf(sql + strlen(sql), ", QTY_3=%f", MWIPLOTSTS_N.QTY_3);
            }
            if(memcmp(MWIPLOTSTS->CRR_ID, MWIPLOTSTS_S.CRR_ID, sizeof(MWIPLOTSTS->CRR_ID)) != 0) {
                make_valid_quote(ts, MWIPLOTSTS_N.CRR_ID);
                sprintf(sql + strlen(sql), ", CRR_ID='%s'", ts);
            }
            if(MWIPLOTSTS->LOT_TYPE != MWIPLOTSTS_S.LOT_TYPE) {
                sprintf(sql + strlen(sql), ", LOT_TYPE='%c'", MWIPLOTSTS_N.LOT_TYPE[0]);
            }
            if(memcmp(MWIPLOTSTS->OWNER_CODE, MWIPLOTSTS_S.OWNER_CODE, sizeof(MWIPLOTSTS->OWNER_CODE)) != 0) {
                make_valid_quote(ts, MWIPLOTSTS_N.OWNER_CODE);
                sprintf(sql + strlen(sql), ", OWNER_CODE='%s'", ts);
            }
            if(memcmp(MWIPLOTSTS->CREATE_CODE, MWIPLOTSTS_S.CREATE_CODE, sizeof(MWIPLOTSTS->CREATE_CODE)) != 0) {
                make_valid_quote(ts, MWIPLOTSTS_N.CREATE_CODE);
                sprintf(sql + strlen(sql), ", CREATE_CODE='%s'", ts);
            }
            if(MWIPLOTSTS->LOT_PRIORITY != MWIPLOTSTS_S.LOT_PRIORITY) {
                sprintf(sql + strlen(sql), ", LOT_PRIORITY='%c'", MWIPLOTSTS_N.LOT_PRIORITY[0]);
            }
            if(memcmp(MWIPLOTSTS->LOT_STATUS, MWIPLOTSTS_S.LOT_STATUS, sizeof(MWIPLOTSTS->LOT_STATUS)) != 0) {
                make_valid_quote(ts, MWIPLOTSTS_N.LOT_STATUS);
                sprintf(sql + strlen(sql), ", LOT_STATUS='%s'", ts);
            }
            if(MWIPLOTSTS->HOLD_FLAG != MWIPLOTSTS_S.HOLD_FLAG) {
                sprintf(sql + strlen(sql), ", HOLD_FLAG='%c'", MWIPLOTSTS_N.HOLD_FLAG[0]);
            }
            if(memcmp(MWIPLOTSTS->HOLD_CODE, MWIPLOTSTS_S.HOLD_CODE, sizeof(MWIPLOTSTS->HOLD_CODE)) != 0) {
                make_valid_quote(ts, MWIPLOTSTS_N.HOLD_CODE);
                sprintf(sql + strlen(sql), ", HOLD_CODE='%s'", ts);
            }
            if(memcmp(MWIPLOTSTS->HOLD_PASSWORD, MWIPLOTSTS_S.HOLD_PASSWORD, sizeof(MWIPLOTSTS->HOLD_PASSWORD)) != 0) {
                make_valid_quote(ts, MWIPLOTSTS_N.HOLD_PASSWORD);
                sprintf(sql + strlen(sql), ", HOLD_PASSWORD='%s'", ts);
            }
            if(memcmp(MWIPLOTSTS->HOLD_PRV_GRP_ID, MWIPLOTSTS_S.HOLD_PRV_GRP_ID, sizeof(MWIPLOTSTS->HOLD_PRV_GRP_ID)) != 0) {
                make_valid_quote(ts, MWIPLOTSTS_N.HOLD_PRV_GRP_ID);
                sprintf(sql + strlen(sql), ", HOLD_PRV_GRP_ID='%s'", ts);
            }
            if(MWIPLOTSTS->OPER_IN_QTY_1 != MWIPLOTSTS_S.OPER_IN_QTY_1) {
                sprintf(sql + strlen(sql), ", OPER_IN_QTY_1=%f", MWIPLOTSTS_N.OPER_IN_QTY_1);
            }
            if(MWIPLOTSTS->OPER_IN_QTY_2 != MWIPLOTSTS_S.OPER_IN_QTY_2) {
                sprintf(sql + strlen(sql), ", OPER_IN_QTY_2=%f", MWIPLOTSTS_N.OPER_IN_QTY_2);
            }
            if(MWIPLOTSTS->OPER_IN_QTY_3 != MWIPLOTSTS_S.OPER_IN_QTY_3) {
                sprintf(sql + strlen(sql), ", OPER_IN_QTY_3=%f", MWIPLOTSTS_N.OPER_IN_QTY_3);
            }
            if(MWIPLOTSTS->CREATE_QTY_1 != MWIPLOTSTS_S.CREATE_QTY_1) {
                sprintf(sql + strlen(sql), ", CREATE_QTY_1=%f", MWIPLOTSTS_N.CREATE_QTY_1);
