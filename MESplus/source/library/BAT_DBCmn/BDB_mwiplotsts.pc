/* SQL CURSOR CLOSE Function */
void BDB_close_mwiplotsts(int sel_type)
{

    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
            
        case 1:
            EXEC SQL CLOSE BDB_MWIPLOTSTS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE BDB_MWIPLOTSTS_CUR_2;
            break;
            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }
    DB_stop_query_timer("BDB_close_mwiplotsts", sel_type);
}

/* Initialize Function */
void BDB_init_mwiplotsts(struct MWIPLOTSTS_TAG *MWIPLOTSTS)
{
    /* memset by Space */
    memset(MWIPLOTSTS, ' ', sizeof(struct MWIPLOTSTS_TAG));
    
    MWIPLOTSTS->MAT_VER = 0;
    MWIPLOTSTS->FLOW_SEQ_NUM = 0;
    MWIPLOTSTS->QTY_1 = 0;
    MWIPLOTSTS->QTY_2 = 0;
    MWIPLOTSTS->QTY_3 = 0;
    MWIPLOTSTS->OPER_IN_QTY_1 = 0;
    MWIPLOTSTS->OPER_IN_QTY_2 = 0;
    MWIPLOTSTS->OPER_IN_QTY_3 = 0;
    MWIPLOTSTS->CREATE_QTY_1 = 0;
    MWIPLOTSTS->CREATE_QTY_2 = 0;
    MWIPLOTSTS->CREATE_QTY_3 = 0;
    MWIPLOTSTS->START_QTY_1 = 0;
    MWIPLOTSTS->START_QTY_2 = 0;
    MWIPLOTSTS->START_QTY_3 = 0;
    MWIPLOTSTS->RWK_COUNT = 0;
    MWIPLOTSTS->RWK_RET_FLOW_SEQ_NUM = 0;
    MWIPLOTSTS->RWK_END_FLOW_SEQ_NUM = 0;
    MWIPLOTSTS->NSTD_RET_FLOW_SEQ_NUM = 0;
    MWIPLOTSTS->BATCH_SEQ = 0;
    MWIPLOTSTS->BOM_SET_VERSION = 0;
    MWIPLOTSTS->BOM_ACTIVE_HIST_SEQ = 0;
    MWIPLOTSTS->BOM_HIST_SEQ = 0;
    MWIPLOTSTS->LAST_ACTIVE_HIST_SEQ = 0;
    MWIPLOTSTS->LAST_HIST_SEQ = 0;
    MWIPLOTSTS->STR_RET_FLOW_SEQ_NUM = 0;
    MWIPLOTSTS->YIELD_1 = 0;
    MWIPLOTSTS->YIELD_2 = 0;
    MWIPLOTSTS->YIELD_3 = 0;
    MWIPLOTSTS->GOOD_QTY = 0;
}


/* Add Null Function */
void BDB_add_null_mwiplotsts(struct MWIPLOTSTS_N_TAG *MWIPLOTSTS_N, struct MWIPLOTSTS_TAG *MWIPLOTSTS)
{
    /* memset by NULL */
    memset(MWIPLOTSTS_N, '\0', sizeof(struct MWIPLOTSTS_N_TAG));
    
    MEMCPY_AN(MWIPLOTSTS_N->LOT_ID, MWIPLOTSTS->LOT_ID, sizeof(MWIPLOTSTS->LOT_ID));
    MEMCPY_AN(MWIPLOTSTS_N->LOT_DESC, MWIPLOTSTS->LOT_DESC, sizeof(MWIPLOTSTS->LOT_DESC));
    MEMCPY_AN(MWIPLOTSTS_N->FACTORY, MWIPLOTSTS->FACTORY, sizeof(MWIPLOTSTS->FACTORY));
    MEMCPY_AN(MWIPLOTSTS_N->MAT_ID, MWIPLOTSTS->MAT_ID, sizeof(MWIPLOTSTS->MAT_ID));
    MWIPLOTSTS_N->MAT_VER = MWIPLOTSTS->MAT_VER;
    MEMCPY_AN(MWIPLOTSTS_N->FLOW, MWIPLOTSTS->FLOW, sizeof(MWIPLOTSTS->FLOW));
