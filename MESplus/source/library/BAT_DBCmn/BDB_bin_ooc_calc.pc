/* Add Null Function */
void BDB_add_null_bin_ooc_calc(struct BIN_OOC_N_TAG *BIN_OOC_N, struct BIN_OOC_TAG *BIN_OOC)
{
    /* memset by NULL */
    memset(BIN_OOC_N, '\0', sizeof(struct BIN_OOC_N_TAG));
    
    MEMCPY_AN(BIN_OOC_N->FACTORY, BIN_OOC->FACTORY, sizeof(BIN_OOC->FACTORY));
    MEMCPY_AN(BIN_OOC_N->CUSTOMER, BIN_OOC->CUSTOMER, sizeof(BIN_OOC->CUSTOMER));
    MEMCPY_AN(BIN_OOC_N->PACKAGE, BIN_OOC->PACKAGE, sizeof(BIN_OOC->PACKAGE));
    MEMCPY_AN(BIN_OOC_N->BIN_ID, BIN_OOC->BIN_ID, sizeof(BIN_OOC->BIN_ID));
    MEMCPY_AN(BIN_OOC_N->BIN_UNIT, BIN_OOC->BIN_UNIT, sizeof(BIN_OOC->BIN_UNIT));
    BIN_OOC_N->BIN_SEQ = BIN_OOC->BIN_SEQ;
    BIN_OOC_N->DVAL_1 = BIN_OOC->DVAL_1;
    BIN_OOC_N->DVAL_2 = BIN_OOC->DVAL_2;
    BIN_OOC_N->DVAL_3 = BIN_OOC->DVAL_3;
    BIN_OOC_N->DVAL_4 = BIN_OOC->DVAL_4;
    BIN_OOC_N->DVAL_5 = BIN_OOC->DVAL_5;
    BIN_OOC_N->IVAL_1 = BIN_OOC->IVAL_1;
    BIN_OOC_N->IVAL_2 = BIN_OOC->IVAL_2;
    BIN_OOC_N->IVAL_3 = BIN_OOC->IVAL_3;
    BIN_OOC_N->IVAL_4 = BIN_OOC->IVAL_4;
