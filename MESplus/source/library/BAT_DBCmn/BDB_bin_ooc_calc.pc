    BIN_OOC->IVAL_1 = BIN_OOC_N->IVAL_1;
    BIN_OOC->IVAL_2 = BIN_OOC_N->IVAL_2;
    BIN_OOC->IVAL_3 = BIN_OOC_N->IVAL_3;
    BIN_OOC->IVAL_4 = BIN_OOC_N->IVAL_4;
    BIN_OOC->IVAL_5 = BIN_OOC_N->IVAL_5;
}
