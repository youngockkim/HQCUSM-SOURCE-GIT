/* SQL CURSOR FETCH Function */
void BDB_fetch_bin_ooc_calc(int sel_type, struct BIN_OOC_TAG *BIN_OOC)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct BIN_OOC_N_TAG BIN_OOC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH BDB_BIN_OOC_CUR_1 INTO
                :BIN_OOC_N.BIN_ID,
                :BIN_OOC_N.BIN_UNIT,
                :BIN_OOC_N.DVAL_1, //AVERAGE
                :BIN_OOC_N.DVAL_2, //STDDEVIATION
                :BIN_OOC_N.DVAL_3, //LCL
                :BIN_OOC_N.DVAL_4; //UCL
            break;

        case 2:
            EXEC SQL FETCH BDB_BIN_OOC_CUR_2 INTO
                :BIN_OOC_N.BIN_ID,
                :BIN_OOC_N.BIN_SEQ,
                :BIN_OOC_N.DVAL_1, //AVERAGE
                :BIN_OOC_N.DVAL_2, //STDDEVIATION
                :BIN_OOC_N.DVAL_3; //UCL
            break;

        case 3:
            EXEC SQL FETCH BDB_BIN_OOC_CUR_3 INTO
                :BIN_OOC_N.BIN_ID,
                :BIN_OOC_N.BIN_UNIT,
                :BIN_OOC_N.DVAL_1, //P10
                :BIN_OOC_N.DVAL_2, //P50
                :BIN_OOC_N.DVAL_3, //STDDEVIATION
                :BIN_OOC_N.DVAL_4; //LCL
            break;

        case 4:
            EXEC SQL FETCH BDB_BIN_OOC_CUR_4 INTO
                :BIN_OOC_N.BIN_ID,
                :BIN_OOC_N.BIN_SEQ,
                :BIN_OOC_N.DVAL_1, //P50
                :BIN_OOC_N.DVAL_2, //P90
                :BIN_OOC_N.DVAL_3, //STDDEVIATION
                :BIN_OOC_N.DVAL_4; //UCL
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        BDB_del_null_bin_ooc_calc(&BIN_OOC_N, BIN_OOC);
    }

    DB_stop_query_timer("BDB_fetch_bin_ooc_calc", sel_type);
}


