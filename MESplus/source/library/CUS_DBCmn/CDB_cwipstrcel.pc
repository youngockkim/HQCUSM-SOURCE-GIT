    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPSTRCEL_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    STRING_ID,
                    CELL_ID,
                    CELL_LOATION,
                    MODULE_ID,
                    MAT_ID,
                    FLOW,
                    OPER,
                    ORDER_ID,
                    CRR_ID,
                    LINE_ID,
                    RES_ID,
                    STATUS_FLAG,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_TIME,
                    LAST_TRAN_TIME
                FROM CWIPSTRCEL
                ORDER BY FACTORY ASC,
                    STRING_ID ASC,
                    CELL_ID ASC;
            EXEC SQL OPEN CDB_CWIPSTRCEL_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
