/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cmmsinsdef(int sel_type, struct CMMSINSDEF_TAG *CMMSINSDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMMSINSDEF_N_TAG CMMSINSDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cmmsinsdef(&CMMSINSDEF_N, CMMSINSDEF);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CMMSINSDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    INSTI_CODE,
                    INSTI_NAME,
                    CALI_DIV,
                    ADDRESS,
                    CERTIFICATE_NAME,
                    CERTIFICATE_NO,
                    CERTIFICATE_PART,
                    CERTIFICATE_AGENCY,
                    ISSUE_DATE,
                    FIRST_ISSUE_DATE,
                    EXPIRE_START_DATE,
                    EXPIRE_END_DATE,
                    FILE_NAME,
                    FILE_PATH,
                    USE_FLAG,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSINSDEF
                ORDER BY FACTORY ASC,
                    INSTI_CODE ASC;
            EXEC SQL OPEN CDB_CMMSINSDEF_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CMMSINSDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    INSTI_CODE,
                    INSTI_NAME,
                    CALI_DIV,
                    ADDRESS,
                    CERTIFICATE_NAME,
                    CERTIFICATE_NO,
                    CERTIFICATE_PART,
                    CERTIFICATE_AGENCY,
                    ISSUE_DATE,
                    FIRST_ISSUE_DATE,
                    EXPIRE_START_DATE,
                    EXPIRE_END_DATE,
                    FILE_NAME,
                    FILE_PATH,
                    USE_FLAG,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSINSDEF
			   WHERE FACTORY = :CMMSINSDEF_N.FACTORY
			     AND CALI_DIV LIKE '%' || TRIM(:CMMSINSDEF_N.CALI_DIV) || '%'
                ORDER BY FACTORY ASC,
                    INSTI_CODE ASC;
            EXEC SQL OPEN CDB_CMMSINSDEF_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_CMMSINSDEF_CUR_3 CURSOR FOR
                SELECT 
                    INSTI_CODE,
                    INSTI_NAME
                FROM CMMSINSDEF
			   WHERE FACTORY = :CMMSINSDEF_N.FACTORY
			     AND USE_FLAG = :CMMSINSDEF_N.USE_FLAG
                ORDER BY FACTORY ASC,
                    INSTI_CODE ASC;
            EXEC SQL OPEN CDB_CMMSINSDEF_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cmmsinsdef", sel_type);
}


