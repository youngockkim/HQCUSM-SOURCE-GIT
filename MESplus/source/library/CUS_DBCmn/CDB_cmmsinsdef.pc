/* Add Null Function */
void CDB_add_null_cmmsinsdef(struct CMMSINSDEF_N_TAG *CMMSINSDEF_N, struct CMMSINSDEF_TAG *CMMSINSDEF)
{
    /* memset by NULL */
    memset(CMMSINSDEF_N, '\0', sizeof(struct CMMSINSDEF_N_TAG));
    
    MEMCPY_AN(CMMSINSDEF_N->FACTORY, CMMSINSDEF->FACTORY, sizeof(CMMSINSDEF->FACTORY));
    MEMCPY_AN(CMMSINSDEF_N->INSTI_CODE, CMMSINSDEF->INSTI_CODE, sizeof(CMMSINSDEF->INSTI_CODE));
    MEMCPY_AN(CMMSINSDEF_N->INSTI_NAME, CMMSINSDEF->INSTI_NAME, sizeof(CMMSINSDEF->INSTI_NAME));
    CMMSINSDEF_N->CALI_DIV[0] = CMMSINSDEF->CALI_DIV;
