/* Add Null Function */
void CDB_add_null_cmmssamdef(struct CMMSSAMDEF_N_TAG *CMMSSAMDEF_N, struct CMMSSAMDEF_TAG *CMMSSAMDEF)
{
    /* memset by NULL */
    memset(CMMSSAMDEF_N, '\0', sizeof(struct CMMSSAMDEF_N_TAG));
    
	MEMCPY_AN(CMMSSAMDEF_N->FACTORY, CMMSSAMDEF->FACTORY, sizeof(CMMSSAMDEF->FACTORY));
    MEMCPY_AN(CMMSSAMDEF_N->SAMPLE_CODE, CMMSSAMDEF->SAMPLE_CODE, sizeof(CMMSSAMDEF->SAMPLE_CODE));
    MEMCPY_AN(CMMSSAMDEF_N->SAMPLE_NAME, CMMSSAMDEF->SAMPLE_NAME, sizeof(CMMSSAMDEF->SAMPLE_NAME));
    MEMCPY_AN(CMMSSAMDEF_N->SAMPLE_CLASS_CODE, CMMSSAMDEF->SAMPLE_CLASS_CODE, sizeof(CMMSSAMDEF->SAMPLE_CLASS_CODE));
    MEMCPY_AN(CMMSSAMDEF_N->SAMPLE_GROUP_CODE, CMMSSAMDEF->SAMPLE_GROUP_CODE, sizeof(CMMSSAMDEF->SAMPLE_GROUP_CODE));
    CMMSSAMDEF_N->SAMPLE_ID_CODE = CMMSSAMDEF->SAMPLE_ID_CODE;
    CMMSSAMDEF_N->UNIT_NO = CMMSSAMDEF->UNIT_NO;
    CMMSSAMDEF_N->SMP_POINT_NO = CMMSSAMDEF->SMP_POINT_NO;
