/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cmmssamdef(int sel_type, struct CMMSSAMDEF_TAG *CMMSSAMDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMMSSAMDEF_N_TAG CMMSSAMDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cmmssamdef(&CMMSSAMDEF_N, CMMSSAMDEF);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CMMSSAMDEF_CUR_1 CURSOR FOR
                SELECT 
					FACTORY,
                    SAMPLE_CODE,
                    SAMPLE_NAME,
                    SAMPLE_CLASS_CODE,
                    SAMPLE_GROUP_CODE,
                    SAMPLE_ID_CODE,
                    UNIT_NO,
                    SMP_POINT_NO,
                    PROD_CLASS_NO,
                    PROD_NO,
                    AUTO_FLAG,
                    PRIORITY,
                    DEAULT_SPEC_KIND,
                    CERTI_FLAG,
                    REPORT_NO,
                    RESERVE_FLAG,
                    RESERVE_DAY,
                    RESERVE_CONDITION,
                    CHECK_SMP_FLAG,
                    STD_REF_NO,
                    SAMPLE_DESC,
                    COST_PART_NO,
                    USE_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSSAMDEF
                ORDER BY SAMPLE_CODE ASC;
            EXEC SQL OPEN CDB_CMMSSAMDEF_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CMMSSAMDEF_CUR_2 CURSOR FOR
                SELECT 
					FACTORY,
                    SAMPLE_CODE,
                    SAMPLE_NAME,
                    SAMPLE_CLASS_CODE,
                    SAMPLE_GROUP_CODE,
                    SAMPLE_ID_CODE,
                    UNIT_NO,
                    SMP_POINT_NO,
                    PROD_CLASS_NO,
                    PROD_NO,
                    AUTO_FLAG,
                    PRIORITY,
                    DEAULT_SPEC_KIND,
                    CERTI_FLAG,
                    REPORT_NO,
                    RESERVE_FLAG,
                    RESERVE_DAY,
                    RESERVE_CONDITION,
                    CHECK_SMP_FLAG,
                    STD_REF_NO,
                    SAMPLE_DESC,
                    COST_PART_NO,
                    USE_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSSAMDEF
			   WHERE FACTORY = :CMMSSAMDEF_N.FACTORY
					AND SAMPLE_GROUP_CODE LIKE '%' || TRIM(:CMMSSAMDEF_N.SAMPLE_GROUP_CODE) || '%'
                ORDER BY SAMPLE_CODE ASC;
            EXEC SQL OPEN CDB_CMMSSAMDEF_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_CMMSSAMDEF_CUR_3 CURSOR FOR
                SELECT 
					FACTORY,
                    SAMPLE_CODE,
                    SAMPLE_NAME
                FROM CMMSSAMDEF
			   WHERE FACTORY = :CMMSSAMDEF_N.FACTORY
					AND SAMPLE_GROUP_CODE LIKE '%' || TRIM(:CMMSSAMDEF_N.SAMPLE_GROUP_CODE) || '%'
					AND USE_FLAG = :CMMSSAMDEF_N.USE_FLAG 
                ORDER BY SAMPLE_CODE ASC;
            EXEC SQL OPEN CDB_CMMSSAMDEF_CUR_3;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cmmssamdef", sel_type);
}


