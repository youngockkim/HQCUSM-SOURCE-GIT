    MEMCPY_AN(IWIPRWKDAT_N->INF_TIME, IWIPRWKDAT->INF_TIME, sizeof(IWIPRWKDAT->INF_TIME));
    MEMCPY_AN(IWIPRWKDAT_N->INF_PROC_TIME, IWIPRWKDAT->INF_PROC_TIME, sizeof(IWIPRWKDAT->INF_PROC_TIME));
    MEMCPY_AN(IWIPRWKDAT_N->CMF_1, IWIPRWKDAT->CMF_1, sizeof(IWIPRWKDAT->CMF_1));
