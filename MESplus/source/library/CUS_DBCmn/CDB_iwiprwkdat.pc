    MEMCPY_AN(IWIPRWKDAT_N->CMF_4, IWIPRWKDAT->CMF_4, sizeof(IWIPRWKDAT->CMF_4));
    MEMCPY_AN(IWIPRWKDAT_N->CMF_5, IWIPRWKDAT->CMF_5, sizeof(IWIPRWKDAT->CMF_5));
    IWIPRWKDAT_N->DATA_FLAG[0] = IWIPRWKDAT->DATA_FLAG;
    MEMCPY_AN(IWIPRWKDAT_N->UPDATE_COUNT, IWIPRWKDAT->UPDATE_COUNT, sizeof(IWIPRWKDAT->UPDATE_COUNT));
    MEMCPY_AN(IWIPRWKDAT_N->INSERT_COUNT, IWIPRWKDAT->INSERT_COUNT, sizeof(IWIPRWKDAT->INSERT_COUNT));
    MEMCPY_AN(IWIPRWKDAT_N->DELETE_COUNT, IWIPRWKDAT->DELETE_COUNT, sizeof(IWIPRWKDAT->DELETE_COUNT));
    MEMCPY_AN(IWIPRWKDAT_N->SQL_DML_COUNT, IWIPRWKDAT->SQL_DML_COUNT, sizeof(IWIPRWKDAT->SQL_DML_COUNT));
    MEMCPY_AN(IWIPRWKDAT_N->ZPICODE, IWIPRWKDAT->ZPICODE, sizeof(IWIPRWKDAT->ZPICODE));
    MEMCPY_AN(IWIPRWKDAT_N->ZPIMSGID, IWIPRWKDAT->ZPIMSGID, sizeof(IWIPRWKDAT->ZPIMSGID));
    IWIPRWKDAT_N->RETURN_TYPE[0] = IWIPRWKDAT->RETURN_TYPE;
    MEMCPY_AN(IWIPRWKDAT_N->RETURN_MSG, IWIPRWKDAT->RETURN_MSG, sizeof(IWIPRWKDAT->RETURN_MSG));
    MEMCPY_AN(IWIPRWKDAT_N->ZIFERNAM, IWIPRWKDAT->ZIFERNAM, sizeof(IWIPRWKDAT->ZIFERNAM));
    MEMCPY_AN(IWIPRWKDAT_N->ZIFDATE, IWIPRWKDAT->ZIFDATE, sizeof(IWIPRWKDAT->ZIFDATE));
