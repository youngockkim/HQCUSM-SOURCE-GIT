                :IWIPRWKDAT_N.INSERT_COUNT,
                :IWIPRWKDAT_N.DELETE_COUNT,
                :IWIPRWKDAT_N.SQL_DML_COUNT,
                :IWIPRWKDAT_N.ZPICODE,
                :IWIPRWKDAT_N.ZPIMSGID,
                :IWIPRWKDAT_N.RETURN_TYPE,
                :IWIPRWKDAT_N.RETURN_MSG,
                :IWIPRWKDAT_N.ZIFERNAM,
                :IWIPRWKDAT_N.ZIFDATE,
                :IWIPRWKDAT_N.ZIFTIME,
                :IWIPRWKDAT_N.ZPISTAT,
                :IWIPRWKDAT_N.ZPIMSG;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_iwiprwkdat(&IWIPRWKDAT_N, IWIPRWKDAT);
    }

    DB_stop_query_timer("CDB_fetch_iwiprwkdat", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_iwiprwkdat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IWIPRWKDAT_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE CDB_IWIPRWKDAT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_iwiprwkdat", sel_type);
}


/* Initialize Function */
void CDB_init_iwiprwkdat(struct IWIPRWKDAT_TAG *IWIPRWKDAT)
{
    /* memset by Space */
    memset(IWIPRWKDAT, ' ', sizeof(struct IWIPRWKDAT_TAG));
    
}


/* Add Null Function */
void CDB_add_null_iwiprwkdat(struct IWIPRWKDAT_N_TAG *IWIPRWKDAT_N, struct IWIPRWKDAT_TAG *IWIPRWKDAT)
{
    /* memset by NULL */
    memset(IWIPRWKDAT_N, '\0', sizeof(struct IWIPRWKDAT_N_TAG));
    
