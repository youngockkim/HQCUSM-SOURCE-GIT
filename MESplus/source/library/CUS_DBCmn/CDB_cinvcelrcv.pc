        struct CINVCELRCV_N_TAG CINVCELRCV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cinvcelrcv(&CINVCELRCV_N, CINVCELRCV);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CINVCELRCV_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    INV_LOT_ID,
                    SMALLBOXID,
                    ACTION_TYPE,
                    SITE_ID,
                    STORAGE_LOCATION,
                    FR_SITE_ID,
                    MATERIALDEFINITIONID,
                    BATCHNO,
                    ORI_QTY,
                    UNIT_ID,
                    MIDDLEBOXID,
                    LARGEBOXID,
                    CELLTYPE,
                    CELLPRODUCTDATE,
                    CELLGRADE,
                    CELLBOXBARCODE,
                    INSPECT_STATUS,
                    BLOCK_STATUS,
                    BLOCK_DATE,
                    POWERGRADE,
                    QUALITYGRADE,
                    ERP_MW,
                    SORTER_MW,
                    AVG_NCELL,
                    AVG_ISC,
                    AVG_UOC,
                    AVG_FF,
                    AVG_RS,
                    AVG_RSH,
                    AVG_TEMPERATURE,
                    WORKDAY,
                    WORKTIME,
                    PRODUCTCLASSID,
                    PRODUCTDEFINITIONTYPE,
                    GR_BATCHNO,
                    GR_DATE,
                    GI_BATCH_NO,
                    STATUS_FLAG,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM CINVCELRCV
                ORDER BY FACTORY ASC,
                    INV_LOT_ID ASC;
            EXEC SQL OPEN CDB_CINVCELRCV_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cinvcelrcv", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_cinvcelrcv(int sel_type, struct CINVCELRCV_TAG *CINVCELRCV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CINVCELRCV_N_TAG CINVCELRCV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CINVCELRCV_CUR_1 INTO
                :CINVCELRCV_N.FACTORY,
                :CINVCELRCV_N.INV_LOT_ID,
                :CINVCELRCV_N.SMALLBOXID,
                :CINVCELRCV_N.ACTION_TYPE,
                :CINVCELRCV_N.SITE_ID,
                :CINVCELRCV_N.STORAGE_LOCATION,
                :CINVCELRCV_N.FR_SITE_ID,
                :CINVCELRCV_N.MATERIALDEFINITIONID,
                :CINVCELRCV_N.BATCHNO,
                :CINVCELRCV_N.ORI_QTY,
                :CINVCELRCV_N.UNIT_ID,
                :CINVCELRCV_N.MIDDLEBOXID,
                :CINVCELRCV_N.LARGEBOXID,
                :CINVCELRCV_N.CELLTYPE,
                :CINVCELRCV_N.CELLPRODUCTDATE,
                :CINVCELRCV_N.CELLGRADE,
                :CINVCELRCV_N.CELLBOXBARCODE,
                :CINVCELRCV_N.INSPECT_STATUS,
                :CINVCELRCV_N.BLOCK_STATUS,
                :CINVCELRCV_N.BLOCK_DATE,
                :CINVCELRCV_N.POWERGRADE,
                :CINVCELRCV_N.QUALITYGRADE,
                :CINVCELRCV_N.ERP_MW,
                :CINVCELRCV_N.SORTER_MW,
                :CINVCELRCV_N.AVG_NCELL,
                :CINVCELRCV_N.AVG_ISC,
                :CINVCELRCV_N.AVG_UOC,
                :CINVCELRCV_N.AVG_FF,
                :CINVCELRCV_N.AVG_RS,
                :CINVCELRCV_N.AVG_RSH,
                :CINVCELRCV_N.AVG_TEMPERATURE,
                :CINVCELRCV_N.WORKDAY,
                :CINVCELRCV_N.WORKTIME,
                :CINVCELRCV_N.PRODUCTCLASSID,
                :CINVCELRCV_N.PRODUCTDEFINITIONTYPE,
                :CINVCELRCV_N.GR_BATCHNO,
                :CINVCELRCV_N.GR_DATE,
                :CINVCELRCV_N.GI_BATCH_NO,
                :CINVCELRCV_N.STATUS_FLAG,
                :CINVCELRCV_N.CMF_1,
                :CINVCELRCV_N.CMF_2,
                :CINVCELRCV_N.CMF_3,
                :CINVCELRCV_N.CMF_4,
                :CINVCELRCV_N.CMF_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cinvcelrcv(&CINVCELRCV_N, CINVCELRCV);
    }

    DB_stop_query_timer("CDB_fetch_cinvcelrcv", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cinvcelrcv(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CINVCELRCV_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cinvcelrcv", sel_type);
}


/* Initialize Function */
void CDB_init_cinvcelrcv(struct CINVCELRCV_TAG *CINVCELRCV)
{
    /* memset by Space */
    memset(CINVCELRCV, ' ', sizeof(struct CINVCELRCV_TAG));
    
    CINVCELRCV->ERP_MW = 0;
    CINVCELRCV->SORTER_MW = 0;
    CINVCELRCV->AVG_NCELL = 0;
    CINVCELRCV->AVG_ISC = 0;
    CINVCELRCV->AVG_UOC = 0;
    CINVCELRCV->AVG_FF = 0;
    CINVCELRCV->AVG_RS = 0;
    CINVCELRCV->AVG_RSH = 0;
    CINVCELRCV->AVG_TEMPERATURE = 0;
}


/* Add Null Function */
void CDB_add_null_cinvcelrcv(struct CINVCELRCV_N_TAG *CINVCELRCV_N, struct CINVCELRCV_TAG *CINVCELRCV)
{
