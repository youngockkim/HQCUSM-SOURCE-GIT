    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM IERPFCLMOV
                WHERE DOC_ID = :IERPFCLMOV_N.DOC_ID
                    AND ACTION_TYPE = :IERPFCLMOV_N.ACTION_TYPE
                    AND SITE_ID = :IERPFCLMOV_N.SITE_ID
                    AND PROD_ORDER_NO = :IERPFCLMOV_N.PROD_ORDER_NO
                    AND MATE_NO = :IERPFCLMOV_N.MATE_NO
                    AND BATCH_NO = :IERPFCLMOV_N.BATCH_NO
                    AND FR_LOC_ID = :IERPFCLMOV_N.FR_LOC_ID
                    AND TO_LOC_ID = :IERPFCLMOV_N.TO_LOC_ID;
            break;

		case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
				FROM (
                SELECT *	            
                FROM (	
                SELECT *
                FROM IERPFCLMOV
                    WHERE ACTION_TYPE = 'I'
                        AND SITE_ID = :IERPFCLMOV_N.SITE_ID
                        AND PROD_ORDER_NO = :IERPFCLMOV_N.PROD_ORDER_NO
                        AND MATE_NO = :IERPFCLMOV_N.MATE_NO
                        AND BATCH_NO = :IERPFCLMOV_N.BATCH_NO
                        AND FR_LOC_ID = :IERPFCLMOV_N.FR_LOC_ID
                        AND TO_LOC_ID = :IERPFCLMOV_N.TO_LOC_ID
					    AND CMF_1 = :IERPFCLMOV_N.CMF_1
                        AND DATA_FLAG = 'I'
                        AND ZPISTAT = 'S'
                    UNION
                    SELECT *
                    FROM IBAKFCLMOV
                    WHERE ACTION_TYPE = 'I'
                        AND SITE_ID = :IERPFCLMOV_N.SITE_ID
                        AND PROD_ORDER_NO = :IERPFCLMOV_N.PROD_ORDER_NO
                        AND MATE_NO = :IERPFCLMOV_N.MATE_NO
                        AND BATCH_NO = :IERPFCLMOV_N.BATCH_NO
                        AND FR_LOC_ID = :IERPFCLMOV_N.FR_LOC_ID
                        AND TO_LOC_ID = :IERPFCLMOV_N.TO_LOC_ID
					    AND CMF_1 = :IERPFCLMOV_N.CMF_1
                        AND DATA_FLAG = 'I'
                        AND ZPISTAT = 'S'
                     ) ORDER BY DOC_ID DESC )
                     WHERE ROWNUM = 1;
            break;

		case 3:
            EXEC SQL SELECT count(*) 
                INTO :d_value
				FROM (
					SELECT *	            
					FROM (	
						SELECT *
						FROM IERPFCLMOV
						WHERE 1 = 1
							AND SITE_ID = :IERPFCLMOV_N.SITE_ID
							AND PROD_ORDER_NO = :IERPFCLMOV_N.PROD_ORDER_NO
							AND MATE_NO = :IERPFCLMOV_N.MATE_NO
							AND BATCH_NO = :IERPFCLMOV_N.BATCH_NO
							AND FR_LOC_ID = :IERPFCLMOV_N.FR_LOC_ID
							AND TO_LOC_ID = :IERPFCLMOV_N.TO_LOC_ID
							AND CMF_1 = :IERPFCLMOV_N.CMF_1
						ORDER BY DOC_ID DESC 
					)
					where ROWNUM = 1
				)
                WHERE 1 = 1
					AND DATA_FLAG = 'I'
					AND ZPISTAT = 'S';
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
