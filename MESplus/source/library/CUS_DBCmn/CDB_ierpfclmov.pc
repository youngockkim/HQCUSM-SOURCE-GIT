                    CMF_5 = :IERPFCLMOV_N.CMF_5,
                    DATA_FLAG = :IERPFCLMOV_N.DATA_FLAG,
                    ZIFERNAM = :IERPFCLMOV_N.ZIFERNAM,
                    ZIFDATE = :IERPFCLMOV_N.ZIFDATE,
                    ZIFTIME = :IERPFCLMOV_N.ZIFTIME,
                    ZPICODE = :IERPFCLMOV_N.ZPICODE,
                    ZPIMSGID = :IERPFCLMOV_N.ZPIMSGID,
                    ZPISTAT = :IERPFCLMOV_N.ZPISTAT,
                    ZPIMSG = :IERPFCLMOV_N.ZPIMSG,
                    RETURN_TYPE = :IERPFCLMOV_N.RETURN_TYPE,
                    RETURN_MSG = :IERPFCLMOV_N.RETURN_MSG,
                    ERP_DATE = :IERPFCLMOV_N.ERP_DATE,
                    ERP_TIME = :IERPFCLMOV_N.ERP_TIME,
                    ERP_FLAG = :IERPFCLMOV_N.ERP_FLAG,
                    ERP_MSG = :IERPFCLMOV_N.ERP_MSG,
                    IF_FLAG = :IERPFCLMOV_N.IF_FLAG
                WHERE DOC_ID = :IERPFCLMOV_N.DOC_ID
                    AND ACTION_TYPE = :IERPFCLMOV_N.ACTION_TYPE
                    AND SITE_ID = :IERPFCLMOV_N.SITE_ID
                    AND PROD_ORDER_NO = :IERPFCLMOV_N.PROD_ORDER_NO
                    AND MATE_NO = :IERPFCLMOV_N.MATE_NO
                    AND BATCH_NO = :IERPFCLMOV_N.BATCH_NO
                    AND FR_LOC_ID = :IERPFCLMOV_N.FR_LOC_ID
                    AND TO_LOC_ID = :IERPFCLMOV_N.TO_LOC_ID;
            break;

		case 2:
            EXEC SQL UPDATE IERPFCLMOV SET
                    INF_PROC_TIME = :IERPFCLMOV_N.INF_PROC_TIME,                    
                    RETURN_TYPE = 'E',
                    RETURN_MSG = :IERPFCLMOV_N.RETURN_MSG
                WHERE DOC_ID = :IERPFCLMOV_N.DOC_ID
                    AND ACTION_TYPE = :IERPFCLMOV_N.ACTION_TYPE
                    AND SITE_ID = :IERPFCLMOV_N.SITE_ID
                    AND PROD_ORDER_NO = :IERPFCLMOV_N.PROD_ORDER_NO
                    AND MATE_NO = :IERPFCLMOV_N.MATE_NO
                    AND BATCH_NO = :IERPFCLMOV_N.BATCH_NO
                    AND FR_LOC_ID = :IERPFCLMOV_N.FR_LOC_ID
                    AND TO_LOC_ID = :IERPFCLMOV_N.TO_LOC_ID;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_ierpfclmov", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_ierpfclmov(int sel_type, struct IERPFCLMOV_TAG *IERPFCLMOV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IERPFCLMOV_N_TAG IERPFCLMOV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ierpfclmov(&IERPFCLMOV_N, IERPFCLMOV);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IERPFCLMOV_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    ACTION_TYPE,
                    SITE_ID,
                    PROD_ORDER_NO,
                    MATE_NO,
                    BATCH_NO,
                    FR_LOC_ID,
                    TO_LOC_ID,
                    QTY,
                    UNIT_ID,
                    POST_DATE,
                    INF_USER_ID,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPICODE,
                    ZPIMSGID,
                    ZPISTAT,
                    ZPIMSG,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ERP_DATE,
                    ERP_TIME,
                    ERP_FLAG,
                    ERP_MSG,
                    IF_FLAG
                FROM IERPFCLMOV
                ORDER BY DOC_ID ASC,
                    ACTION_TYPE ASC,
                    SITE_ID ASC,
                    PROD_ORDER_NO ASC,
                    MATE_NO ASC,
                    BATCH_NO ASC,
                    FR_LOC_ID ASC,
                    TO_LOC_ID ASC;
            EXEC SQL OPEN CDB_IERPFCLMOV_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_IERPFCLMOV_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    ACTION_TYPE,
                    SITE_ID,
                    PROD_ORDER_NO,
                    MATE_NO,
                    BATCH_NO,
                    FR_LOC_ID,
                    TO_LOC_ID,
                    QTY,
                    UNIT_ID,
                    POST_DATE,
                    INF_USER_ID,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPICODE,
                    ZPIMSGID,
                    ZPISTAT,
                    ZPIMSG,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ERP_DATE,
                    ERP_TIME,
                    ERP_FLAG,
                    ERP_MSG,
                    IF_FLAG
                FROM IERPFCLMOV
				WHERE RETURN_TYPE <> 'E'
                ORDER BY DOC_ID ASC,
                    ACTION_TYPE ASC,
                    SITE_ID ASC,
                    PROD_ORDER_NO ASC,
                    MATE_NO ASC,
                    BATCH_NO ASC,
                    FR_LOC_ID ASC,
                    TO_LOC_ID ASC;
            EXEC SQL OPEN CDB_IERPFCLMOV_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_ierpfclmov", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_ierpfclmov(int sel_type, struct IERPFCLMOV_TAG *IERPFCLMOV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IERPFCLMOV_N_TAG IERPFCLMOV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_IERPFCLMOV_CUR_1 INTO
                :IERPFCLMOV_N.DOC_ID,
                :IERPFCLMOV_N.ACTION_TYPE,
                :IERPFCLMOV_N.SITE_ID,
                :IERPFCLMOV_N.PROD_ORDER_NO,
