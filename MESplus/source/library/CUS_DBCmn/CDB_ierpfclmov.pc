                :IERPFCLMOV_N.CMF_2,
                :IERPFCLMOV_N.CMF_3,
                :IERPFCLMOV_N.CMF_4,
                :IERPFCLMOV_N.CMF_5,
                :IERPFCLMOV_N.DATA_FLAG,
                :IERPFCLMOV_N.ZIFERNAM,
                :IERPFCLMOV_N.ZIFDATE,
                :IERPFCLMOV_N.ZIFTIME,
                :IERPFCLMOV_N.ZPICODE,
                :IERPFCLMOV_N.ZPIMSGID,
                :IERPFCLMOV_N.ZPISTAT,
                :IERPFCLMOV_N.ZPIMSG,
                :IERPFCLMOV_N.RETURN_TYPE,
                :IERPFCLMOV_N.RETURN_MSG,
                :IERPFCLMOV_N.ERP_DATE,
                :IERPFCLMOV_N.ERP_TIME,
                :IERPFCLMOV_N.ERP_FLAG,
                :IERPFCLMOV_N.ERP_MSG,
                :IERPFCLMOV_N.IF_FLAG;
            break;

		case 2:
            EXEC SQL FETCH CDB_IERPFCLMOV_CUR_2 INTO
                :IERPFCLMOV_N.DOC_ID,
                :IERPFCLMOV_N.ACTION_TYPE,
                :IERPFCLMOV_N.SITE_ID,
                :IERPFCLMOV_N.PROD_ORDER_NO,
                :IERPFCLMOV_N.MATE_NO,
                :IERPFCLMOV_N.BATCH_NO,
                :IERPFCLMOV_N.FR_LOC_ID,
                :IERPFCLMOV_N.TO_LOC_ID,
                :IERPFCLMOV_N.QTY,
                :IERPFCLMOV_N.UNIT_ID,
                :IERPFCLMOV_N.POST_DATE,
                :IERPFCLMOV_N.INF_USER_ID,
                :IERPFCLMOV_N.INF_TIME,
                :IERPFCLMOV_N.INF_PROC_TIME,
                :IERPFCLMOV_N.CMF_1,
                :IERPFCLMOV_N.CMF_2,
                :IERPFCLMOV_N.CMF_3,
                :IERPFCLMOV_N.CMF_4,
                :IERPFCLMOV_N.CMF_5,
                :IERPFCLMOV_N.DATA_FLAG,
                :IERPFCLMOV_N.ZIFERNAM,
                :IERPFCLMOV_N.ZIFDATE,
                :IERPFCLMOV_N.ZIFTIME,
                :IERPFCLMOV_N.ZPICODE,
                :IERPFCLMOV_N.ZPIMSGID,
                :IERPFCLMOV_N.ZPISTAT,
                :IERPFCLMOV_N.ZPIMSG,
                :IERPFCLMOV_N.RETURN_TYPE,
                :IERPFCLMOV_N.RETURN_MSG,
                :IERPFCLMOV_N.ERP_DATE,
                :IERPFCLMOV_N.ERP_TIME,
                :IERPFCLMOV_N.ERP_FLAG,
                :IERPFCLMOV_N.ERP_MSG,
                :IERPFCLMOV_N.IF_FLAG;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_ierpfclmov(&IERPFCLMOV_N, IERPFCLMOV);
    }

    DB_stop_query_timer("CDB_fetch_ierpfclmov", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_ierpfclmov(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IERPFCLMOV_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IERPFCLMOV_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ierpfclmov", sel_type);
}


/* Initialize Function */
void CDB_init_ierpfclmov(struct IERPFCLMOV_TAG *IERPFCLMOV)
{
    /* memset by Space */
    memset(IERPFCLMOV, ' ', sizeof(struct IERPFCLMOV_TAG));
    
    IERPFCLMOV->QTY = 0;
}


/* Add Null Function */
void CDB_add_null_ierpfclmov(struct IERPFCLMOV_N_TAG *IERPFCLMOV_N, struct IERPFCLMOV_TAG *IERPFCLMOV)
{
    /* memset by NULL */
    memset(IERPFCLMOV_N, '\0', sizeof(struct IERPFCLMOV_N_TAG));
    
    MEMCPY_AN(IERPFCLMOV_N->DOC_ID, IERPFCLMOV->DOC_ID, sizeof(IERPFCLMOV->DOC_ID));
    MEMCPY_AN(IERPFCLMOV_N->ACTION_TYPE, IERPFCLMOV->ACTION_TYPE, sizeof(IERPFCLMOV->ACTION_TYPE));
    MEMCPY_AN(IERPFCLMOV_N->SITE_ID, IERPFCLMOV->SITE_ID, sizeof(IERPFCLMOV->SITE_ID));
    MEMCPY_AN(IERPFCLMOV_N->PROD_ORDER_NO, IERPFCLMOV->PROD_ORDER_NO, sizeof(IERPFCLMOV->PROD_ORDER_NO));
    MEMCPY_AN(IERPFCLMOV_N->MATE_NO, IERPFCLMOV->MATE_NO, sizeof(IERPFCLMOV->MATE_NO));
    MEMCPY_AN(IERPFCLMOV_N->BATCH_NO, IERPFCLMOV->BATCH_NO, sizeof(IERPFCLMOV->BATCH_NO));
    MEMCPY_AN(IERPFCLMOV_N->FR_LOC_ID, IERPFCLMOV->FR_LOC_ID, sizeof(IERPFCLMOV->FR_LOC_ID));
    MEMCPY_AN(IERPFCLMOV_N->TO_LOC_ID, IERPFCLMOV->TO_LOC_ID, sizeof(IERPFCLMOV->TO_LOC_ID));
    IERPFCLMOV_N->QTY = IERPFCLMOV->QTY;
    MEMCPY_AN(IERPFCLMOV_N->UNIT_ID, IERPFCLMOV->UNIT_ID, sizeof(IERPFCLMOV->UNIT_ID));
    MEMCPY_AN(IERPFCLMOV_N->POST_DATE, IERPFCLMOV->POST_DATE, sizeof(IERPFCLMOV->POST_DATE));
    MEMCPY_AN(IERPFCLMOV_N->INF_USER_ID, IERPFCLMOV->INF_USER_ID, sizeof(IERPFCLMOV->INF_USER_ID));
    MEMCPY_AN(IERPFCLMOV_N->INF_TIME, IERPFCLMOV->INF_TIME, sizeof(IERPFCLMOV->INF_TIME));
    MEMCPY_AN(IERPFCLMOV_N->INF_PROC_TIME, IERPFCLMOV->INF_PROC_TIME, sizeof(IERPFCLMOV->INF_PROC_TIME));
    MEMCPY_AN(IERPFCLMOV_N->CMF_1, IERPFCLMOV->CMF_1, sizeof(IERPFCLMOV->CMF_1));
    MEMCPY_AN(IERPFCLMOV_N->CMF_2, IERPFCLMOV->CMF_2, sizeof(IERPFCLMOV->CMF_2));
    MEMCPY_AN(IERPFCLMOV_N->CMF_3, IERPFCLMOV->CMF_3, sizeof(IERPFCLMOV->CMF_3));
    MEMCPY_AN(IERPFCLMOV_N->CMF_4, IERPFCLMOV->CMF_4, sizeof(IERPFCLMOV->CMF_4));
    MEMCPY_AN(IERPFCLMOV_N->CMF_5, IERPFCLMOV->CMF_5, sizeof(IERPFCLMOV->CMF_5));
    IERPFCLMOV_N->DATA_FLAG[0] = IERPFCLMOV->DATA_FLAG;
    MEMCPY_AN(IERPFCLMOV_N->ZIFERNAM, IERPFCLMOV->ZIFERNAM, sizeof(IERPFCLMOV->ZIFERNAM));
    MEMCPY_AN(IERPFCLMOV_N->ZIFDATE, IERPFCLMOV->ZIFDATE, sizeof(IERPFCLMOV->ZIFDATE));
    MEMCPY_AN(IERPFCLMOV_N->ZIFTIME, IERPFCLMOV->ZIFTIME, sizeof(IERPFCLMOV->ZIFTIME));
    MEMCPY_AN(IERPFCLMOV_N->ZPICODE, IERPFCLMOV->ZPICODE, sizeof(IERPFCLMOV->ZPICODE));
    MEMCPY_AN(IERPFCLMOV_N->ZPIMSGID, IERPFCLMOV->ZPIMSGID, sizeof(IERPFCLMOV->ZPIMSGID));
    IERPFCLMOV_N->ZPISTAT[0] = IERPFCLMOV->ZPISTAT;
    MEMCPY_AN(IERPFCLMOV_N->ZPIMSG, IERPFCLMOV->ZPIMSG, sizeof(IERPFCLMOV->ZPIMSG));
    IERPFCLMOV_N->RETURN_TYPE[0] = IERPFCLMOV->RETURN_TYPE;
    MEMCPY_AN(IERPFCLMOV_N->RETURN_MSG, IERPFCLMOV->RETURN_MSG, sizeof(IERPFCLMOV->RETURN_MSG));
    MEMCPY_AN(IERPFCLMOV_N->ERP_DATE, IERPFCLMOV->ERP_DATE, sizeof(IERPFCLMOV->ERP_DATE));
    MEMCPY_AN(IERPFCLMOV_N->ERP_TIME, IERPFCLMOV->ERP_TIME, sizeof(IERPFCLMOV->ERP_TIME));
    IERPFCLMOV_N->ERP_FLAG[0] = IERPFCLMOV->ERP_FLAG;
    MEMCPY_AN(IERPFCLMOV_N->ERP_MSG, IERPFCLMOV->ERP_MSG, sizeof(IERPFCLMOV->ERP_MSG));
    IERPFCLMOV_N->IF_FLAG[0] = IERPFCLMOV->IF_FLAG;
}


/* Del Null Function */
void CDB_del_null_ierpfclmov(struct IERPFCLMOV_N_TAG *IERPFCLMOV_N, struct IERPFCLMOV_TAG *IERPFCLMOV)
{
    MEMCPY_DN(IERPFCLMOV->DOC_ID, IERPFCLMOV_N->DOC_ID, sizeof(IERPFCLMOV->DOC_ID));
    MEMCPY_DN(IERPFCLMOV->ACTION_TYPE, IERPFCLMOV_N->ACTION_TYPE, sizeof(IERPFCLMOV->ACTION_TYPE));
    MEMCPY_DN(IERPFCLMOV->SITE_ID, IERPFCLMOV_N->SITE_ID, sizeof(IERPFCLMOV->SITE_ID));
    MEMCPY_DN(IERPFCLMOV->PROD_ORDER_NO, IERPFCLMOV_N->PROD_ORDER_NO, sizeof(IERPFCLMOV->PROD_ORDER_NO));
    MEMCPY_DN(IERPFCLMOV->MATE_NO, IERPFCLMOV_N->MATE_NO, sizeof(IERPFCLMOV->MATE_NO));
    MEMCPY_DN(IERPFCLMOV->BATCH_NO, IERPFCLMOV_N->BATCH_NO, sizeof(IERPFCLMOV->BATCH_NO));
    MEMCPY_DN(IERPFCLMOV->FR_LOC_ID, IERPFCLMOV_N->FR_LOC_ID, sizeof(IERPFCLMOV->FR_LOC_ID));
    MEMCPY_DN(IERPFCLMOV->TO_LOC_ID, IERPFCLMOV_N->TO_LOC_ID, sizeof(IERPFCLMOV->TO_LOC_ID));
    IERPFCLMOV->QTY = IERPFCLMOV_N->QTY;
    MEMCPY_DN(IERPFCLMOV->UNIT_ID, IERPFCLMOV_N->UNIT_ID, sizeof(IERPFCLMOV->UNIT_ID));
    MEMCPY_DN(IERPFCLMOV->POST_DATE, IERPFCLMOV_N->POST_DATE, sizeof(IERPFCLMOV->POST_DATE));
    MEMCPY_DN(IERPFCLMOV->INF_USER_ID, IERPFCLMOV_N->INF_USER_ID, sizeof(IERPFCLMOV->INF_USER_ID));
    MEMCPY_DN(IERPFCLMOV->INF_TIME, IERPFCLMOV_N->INF_TIME, sizeof(IERPFCLMOV->INF_TIME));
    MEMCPY_DN(IERPFCLMOV->INF_PROC_TIME, IERPFCLMOV_N->INF_PROC_TIME, sizeof(IERPFCLMOV->INF_PROC_TIME));
    MEMCPY_DN(IERPFCLMOV->CMF_1, IERPFCLMOV_N->CMF_1, sizeof(IERPFCLMOV->CMF_1));
    MEMCPY_DN(IERPFCLMOV->CMF_2, IERPFCLMOV_N->CMF_2, sizeof(IERPFCLMOV->CMF_2));
    MEMCPY_DN(IERPFCLMOV->CMF_3, IERPFCLMOV_N->CMF_3, sizeof(IERPFCLMOV->CMF_3));
    MEMCPY_DN(IERPFCLMOV->CMF_4, IERPFCLMOV_N->CMF_4, sizeof(IERPFCLMOV->CMF_4));
    MEMCPY_DN(IERPFCLMOV->CMF_5, IERPFCLMOV_N->CMF_5, sizeof(IERPFCLMOV->CMF_5));
    IERPFCLMOV->DATA_FLAG = IERPFCLMOV_N->DATA_FLAG[0];
    MEMCPY_DN(IERPFCLMOV->ZIFERNAM, IERPFCLMOV_N->ZIFERNAM, sizeof(IERPFCLMOV->ZIFERNAM));
    MEMCPY_DN(IERPFCLMOV->ZIFDATE, IERPFCLMOV_N->ZIFDATE, sizeof(IERPFCLMOV->ZIFDATE));
    MEMCPY_DN(IERPFCLMOV->ZIFTIME, IERPFCLMOV_N->ZIFTIME, sizeof(IERPFCLMOV->ZIFTIME));
    MEMCPY_DN(IERPFCLMOV->ZPICODE, IERPFCLMOV_N->ZPICODE, sizeof(IERPFCLMOV->ZPICODE));
    MEMCPY_DN(IERPFCLMOV->ZPIMSGID, IERPFCLMOV_N->ZPIMSGID, sizeof(IERPFCLMOV->ZPIMSGID));
    IERPFCLMOV->ZPISTAT = IERPFCLMOV_N->ZPISTAT[0];
    MEMCPY_DN(IERPFCLMOV->ZPIMSG, IERPFCLMOV_N->ZPIMSG, sizeof(IERPFCLMOV->ZPIMSG));
    IERPFCLMOV->RETURN_TYPE = IERPFCLMOV_N->RETURN_TYPE[0];
    MEMCPY_DN(IERPFCLMOV->RETURN_MSG, IERPFCLMOV_N->RETURN_MSG, sizeof(IERPFCLMOV->RETURN_MSG));
    MEMCPY_DN(IERPFCLMOV->ERP_DATE, IERPFCLMOV_N->ERP_DATE, sizeof(IERPFCLMOV->ERP_DATE));
    MEMCPY_DN(IERPFCLMOV->ERP_TIME, IERPFCLMOV_N->ERP_TIME, sizeof(IERPFCLMOV->ERP_TIME));
    IERPFCLMOV->ERP_FLAG = IERPFCLMOV_N->ERP_FLAG[0];
    MEMCPY_DN(IERPFCLMOV->ERP_MSG, IERPFCLMOV_N->ERP_MSG, sizeof(IERPFCLMOV->ERP_MSG));
    IERPFCLMOV->IF_FLAG = IERPFCLMOV_N->IF_FLAG[0];
}


