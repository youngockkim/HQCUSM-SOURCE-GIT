/* Initialize Function */
void CDB_init_cwipctwhis(struct CWIPCTWHIS_TAG *CWIPCTWHIS)
{
    /* memset by Space */
    memset(CWIPCTWHIS, ' ', sizeof(struct CWIPCTWHIS_TAG));
    
    CWIPCTWHIS->TAB_NO = 0;
    CWIPCTWHIS->POS = 0;
    CWIPCTWHIS->HIST_SEQ = 0;
    CWIPCTWHIS->INS_CNT = 0;
