            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwipctwhis", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_cwipctwhis(int sel_type, struct CWIPCTWHIS_TAG *CWIPCTWHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPCTWHIS_N_TAG CWIPCTWHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
