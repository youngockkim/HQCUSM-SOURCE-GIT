                :CWIPCTWHIS_N.POS_RE_2,
                :CWIPCTWHIS_N.POS_RE_3,
                :CWIPCTWHIS_N.POS_RE_4,
                :CWIPCTWHIS_N.POS_RE_5,
                :CWIPCTWHIS_N.POS_RE_6,
                :CWIPCTWHIS_N.POS_RE_7,
                :CWIPCTWHIS_N.POS_RE_8,
                :CWIPCTWHIS_N.POS_RE_9,
                :CWIPCTWHIS_N.POS_RE_10,
                :CWIPCTWHIS_N.POS_RE_11,
                :CWIPCTWHIS_N.POS_RE_12,
                :CWIPCTWHIS_N.INS_CNT,
                :CWIPCTWHIS_N.INS_TIME,
