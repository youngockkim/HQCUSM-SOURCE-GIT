        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cwipctwhis(&CWIPCTWHIS_N, CWIPCTWHIS);
    }

    DB_stop_query_timer("CDB_fetch_cwipctwhis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cwipctwhis(int sel_type)
{
