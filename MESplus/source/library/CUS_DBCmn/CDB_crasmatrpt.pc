/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_crasmatrpt(int sel_type, struct CRASMATRPT_TAG *CRASMATRPT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASMATRPT_N_TAG CRASMATRPT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_crasmatrpt(&CRASMATRPT_N, CRASMATRPT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASMATRPT_CUR_1 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    LINE_ID,
                    RPT_TYPE,
                    RPT_ITEM,
                    WORK_TIME,
                    WORK_SHIFT,
                    NVL(QTY_1, '0'),
                    NVL(QTY_2, '0'),
                    NVL(QTY_3, '0'),
                    NVL(QTY_4, '0'),
                    NVL(QTY_5, '0'),
                    NVL(CREATE_USER_ID, ' '),
                    NVL(TRAN_TIME, ' '),
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' ')
                FROM CRASMATRPT
                ORDER BY WORK_DATE ASC,
                    LINE_ID ASC,
                    RPT_TYPE ASC,
                    RPT_ITEM ASC,
                    WORK_TIME ASC,
                    WORK_SHIFT ASC;
            EXEC SQL OPEN CDB_CRASMATRPT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_crasmatrpt", sel_type);
}


