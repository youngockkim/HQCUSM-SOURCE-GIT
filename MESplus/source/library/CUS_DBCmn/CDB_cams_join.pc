    MEMCPY_DN(CAMS_JOIN->ACTION_MGR_ID, CAMS_JOIN_N->ACTION_MGR_ID, sizeof(CAMS_JOIN->ACTION_MGR_ID));
    MEMCPY_DN(CAMS_JOIN->ACTION_MGR_NAME, CAMS_JOIN_N->ACTION_MGR_NAME, sizeof(CAMS_JOIN->ACTION_MGR_NAME));
