/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cams_join(int sel_type, struct CAMS_JOIN_TAG *CAMS_JOIN)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CAMS_JOIN_N_TAG CAMS_JOIN_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cams_join(&CAMS_JOIN_N, CAMS_JOIN);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CAMS_JOIN_CUR_1 CURSOR FOR
                SELECT RST.FACTORY
                     , RST.AUDIT_ID
                     , PLN.AUDIT_DESC
                     , (CASE WHEN LENGTH(RST.PLAN_DATE) = 8 THEN TO_CHAR(TO_DATE(RST.PLAN_DATE,'YYYYMMDD'),'FMMM/DD/YYYY') ELSE ' ' END) AS PLAN_DATE
                     , PLN.CUSTOMER_CODE
                     , NVL(CUS.DATA_1, PLN.CUSTOMER_CODE) AS CUSTOMER_NAME
                     , PLN.AUDITOR
                     , PLN.MANAGER_ID
                     , NVL(PMGR.DATA_1, PLN.MANAGER_ID) AS MANAGER_NAME
                     , PLN.AGENDA
                     , (CASE WHEN LENGTH(RST.AUDIT_DATE) = 8 THEN TO_CHAR(TO_DATE(RST.AUDIT_DATE,'YYYYMMDD'),'FMMM/DD/YYYY') ELSE ' ' END) AS AUDIT_DATE
                     , CASE  RST.RESULT WHEN 'O' THEN 'Open' WHEN 'C' THEN 'Close' ELSE ' ' END AS RESULT
                     , RST.STATUS 
                     , NVL(GCM.DATA_1, ' ') AS STATUS_DESC
                     , RST.CMF_1 AS DOCUMENT
                     , ITM.ITEM_DIVISION
                     , NVL(DIV.DATA_1, ' ') AS ITEM_DIV_DESC
                     , ITM.ITEM_NAME
                     , ITM.CHECK_DETAIL
                     , CASE ITM.CHECK_RESULT WHEN 'C' THEN 'Critical' WHEN 'M' THEN 'Major' WHEN 'N' THEN 'Minor' ELSE ' ' END AS CHECK_RESULT
                     , ITM.FILE_NAME
                     , ITM.FILE_PATH
                     , ITM.ACTION_MGR_ID 
                     , NVL(MGR.DATA_1, ITM.ACTION_MGR_ID) AS ACTION_MGR_NAME
                     , (CASE WHEN LENGTH(ITM.ACTION_LIMIT_DATE) = 8 THEN TO_CHAR(TO_DATE(ITM.ACTION_LIMIT_DATE,'YYYYMMDD'),'FMMM/DD/YYYY') ELSE ' ' END) AS ACTION_LIMIT_DATE
                     , (CASE WHEN LENGTH(ITM.ACTION_DATE) = 8 THEN TO_CHAR(TO_DATE(ITM.ACTION_DATE, 'YYYYMMDD'),'FMMM/DD/YYYY') ELSE ' ' END) AS ACTION_DATE
                     , ITM.ACTION_USER_ID
                     , NVL(USR.DATA_1, ITM.ACTION_USER_ID) AS ACTION_USER_NAME
                     , ITM.ACTION_FILE_NAME
                     , ITM.ACTION_FILE_PATH
                     , CASE ITM.ACTION_RESULT WHEN 'O' THEN 'Open' WHEN 'C' THEN 'Close' ELSE ' ' END AS ACTION_RESULT
                     , ITM.REMARKS 
                  FROM CAMSADTRST RST
                     , CAMSADTPLN PLN
                     , CAMSADTITM ITM
                     , MGCMTBLDAT GCM
                     , MGCMTBLDAT CUS
                     , MGCMTBLDAT DIV
                     , MGCMTBLDAT MGR
                     , MGCMTBLDAT USR
                     , MGCMTBLDAT PMGR
                 WHERE RST.FACTORY = PLN.FACTORY
                   AND RST.AUDIT_ID = PLN.AUDIT_ID
                   AND RST.FACTORY = ITM.FACTORY
                   AND RST.AUDIT_ID = ITM.AUDIT_ID
                   AND RST.FACTORY = CUS.FACTORY(+)
                   AND CUS.TABLE_NAME(+) = 'AMS_CUSTOMER'
                   AND PLN.CUSTOMER_CODE = CUS.KEY_1(+)
                   AND RST.FACTORY = GCM.FACTORY(+)
                   AND GCM.TABLE_NAME(+) = 'AMS_AUDIT_STATUS'
                   AND RST.STATUS = GCM.KEY_1(+)
                   AND RST.FACTORY = DIV.FACTORY(+)
                   AND DIV.TABLE_NAME(+) = 'AMS_ITEM_DIV'
                   AND ITM.ITEM_DIVISION = DIV.KEY_1(+)
                   AND RST.FACTORY = MGR.FACTORY(+)
                   AND MGR.TABLE_NAME(+) = 'AMS_MANAGER'
                   AND ITM.ACTION_MGR_ID = MGR.KEY_1(+)
                   AND RST.FACTORY = USR.FACTORY(+)
                   AND USR.TABLE_NAME(+) = 'AMS_USER'
                   AND ITM.ACTION_USER_ID = USR.KEY_1(+)
                   AND RST.FACTORY = PMGR.FACTORY(+)
                   AND PMGR.TABLE_NAME(+) = 'AMS_MANAGER'
                   AND PLN.MANAGER_ID = PMGR.KEY_1(+) 
                   AND RST.FACTORY = :CAMS_JOIN_N.FACTORY
                   AND RST.PLAN_DATE BETWEEN :CAMS_JOIN_N.PLAN_DATE AND :CAMS_JOIN_N.AUDIT_DATE
                   AND RST.STATUS LIKE '%' || TRIM(:CAMS_JOIN_N.STATUS) ||'%'
                   AND PLN.CUSTOMER_CODE LIKE '%' || TRIM(:CAMS_JOIN_N.CUSTOMER_CODE) ||'%'                   
                   AND PLN.MANAGER_ID LIKE '%' || TRIM(:CAMS_JOIN_N.MANAGER_ID) ||'%'                   
                  ORDER BY FACTORY ASC
                         , PLAN_DATE ASC
                         , AUDIT_ID ASC;
            EXEC SQL OPEN CDB_CAMS_JOIN_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cams_join", sel_type);
}


