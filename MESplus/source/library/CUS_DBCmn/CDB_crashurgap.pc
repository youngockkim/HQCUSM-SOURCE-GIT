    CRASHURGAP->FEL_QTY = CRASHURGAP_N->FEL_QTY;
    CRASHURGAP->DIFF_QTY = CRASHURGAP_N->DIFF_QTY;
    CRASHURGAP->TIME_LOSS = CRASHURGAP_N->TIME_LOSS;
    CRASHURGAP->DOWN_TIME = CRASHURGAP_N->DOWN_TIME;
    CRASHURGAP->EFF_TIME = CRASHURGAP_N->EFF_TIME;
    MEMCPY_DN(CRASHURGAP->TYPE_4M, CRASHURGAP_N->TYPE_4M, sizeof(CRASHURGAP->TYPE_4M));
    MEMCPY_DN(CRASHURGAP->PROCESS_TYPE, CRASHURGAP_N->PROCESS_TYPE, sizeof(CRASHURGAP->PROCESS_TYPE));
    MEMCPY_DN(CRASHURGAP->EQ, CRASHURGAP_N->EQ, sizeof(CRASHURGAP->EQ));
    CRASHURGAP->EQ_MAX = CRASHURGAP_N->EQ_MAX;
    MEMCPY_DN(CRASHURGAP->HOUR_DESC, CRASHURGAP_N->HOUR_DESC, sizeof(CRASHURGAP->HOUR_DESC));
    MEMCPY_DN(CRASHURGAP->CREATE_USER_ID, CRASHURGAP_N->CREATE_USER_ID, sizeof(CRASHURGAP->CREATE_USER_ID));
    MEMCPY_DN(CRASHURGAP->TRAN_TIME, CRASHURGAP_N->TRAN_TIME, sizeof(CRASHURGAP->TRAN_TIME));
    MEMCPY_DN(CRASHURGAP->CMF_1, CRASHURGAP_N->CMF_1, sizeof(CRASHURGAP->CMF_1));
    MEMCPY_DN(CRASHURGAP->CMF_2, CRASHURGAP_N->CMF_2, sizeof(CRASHURGAP->CMF_2));
