                :CRASHURGAP_N.CREATE_USER_ID,
                :CRASHURGAP_N.TRAN_TIME,
                :CRASHURGAP_N.CMF_1,
                :CRASHURGAP_N.CMF_2,
                :CRASHURGAP_N.CMF_3,
                :CRASHURGAP_N.CMF_4,
                :CRASHURGAP_N.CMF_5;
            break;

		case 2:
            EXEC SQL FETCH CDB_CRASHURGAP_CUR_2 INTO
                :CRASHURGAP_N.WORK_DATE,
                :CRASHURGAP_N.LINE_ID,
                :CRASHURGAP_N.HOUR_TYPE,
                :CRASHURGAP_N.WORK_SHIFT,
                :CRASHURGAP_N.WORK_TIME,
                :CRASHURGAP_N.HIST_SEQ,
                :CRASHURGAP_N.TARGET_QTY,
                :CRASHURGAP_N.FEL_QTY,
                :CRASHURGAP_N.DIFF_QTY,
                :CRASHURGAP_N.TIME_LOSS,
                :CRASHURGAP_N.DOWN_TIME,
                :CRASHURGAP_N.EFF_TIME,
                :CRASHURGAP_N.TYPE_4M,
                :CRASHURGAP_N.PROCESS_TYPE,
                :CRASHURGAP_N.EQ,
                :CRASHURGAP_N.EQ_MAX,
                :CRASHURGAP_N.HOUR_DESC,
                :CRASHURGAP_N.CREATE_USER_ID,
                :CRASHURGAP_N.TRAN_TIME,
                :CRASHURGAP_N.CMF_1,
                :CRASHURGAP_N.CMF_2,
                :CRASHURGAP_N.CMF_3,
                :CRASHURGAP_N.CMF_4,
                :CRASHURGAP_N.CMF_5;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_crashurgap(&CRASHURGAP_N, CRASHURGAP);
    }

    DB_stop_query_timer("CDB_fetch_crashurgap", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_crashurgap(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CRASHURGAP_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE CDB_CRASHURGAP_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_crashurgap", sel_type);
}


/* Initialize Function */
void CDB_init_crashurgap(struct CRASHURGAP_TAG *CRASHURGAP)
{
    /* memset by Space */
    memset(CRASHURGAP, ' ', sizeof(struct CRASHURGAP_TAG));
    
    CRASHURGAP->HIST_SEQ = 0;
    CRASHURGAP->TARGET_QTY = 0;
    CRASHURGAP->FEL_QTY = 0;
    CRASHURGAP->DIFF_QTY = 0;
    CRASHURGAP->TIME_LOSS = 0;
    CRASHURGAP->DOWN_TIME = 0;
    CRASHURGAP->EFF_TIME = 0;
    CRASHURGAP->EQ_MAX = 0;
}


/* Add Null Function */
void CDB_add_null_crashurgap(struct CRASHURGAP_N_TAG *CRASHURGAP_N, struct CRASHURGAP_TAG *CRASHURGAP)
{
    /* memset by NULL */
    memset(CRASHURGAP_N, '\0', sizeof(struct CRASHURGAP_N_TAG));
    
    MEMCPY_AN(CRASHURGAP_N->WORK_DATE, CRASHURGAP->WORK_DATE, sizeof(CRASHURGAP->WORK_DATE));
    MEMCPY_AN(CRASHURGAP_N->LINE_ID, CRASHURGAP->LINE_ID, sizeof(CRASHURGAP->LINE_ID));
    MEMCPY_AN(CRASHURGAP_N->HOUR_TYPE, CRASHURGAP->HOUR_TYPE, sizeof(CRASHURGAP->HOUR_TYPE));
    MEMCPY_AN(CRASHURGAP_N->WORK_SHIFT, CRASHURGAP->WORK_SHIFT, sizeof(CRASHURGAP->WORK_SHIFT));
    MEMCPY_AN(CRASHURGAP_N->WORK_TIME, CRASHURGAP->WORK_TIME, sizeof(CRASHURGAP->WORK_TIME));
    CRASHURGAP_N->HIST_SEQ = CRASHURGAP->HIST_SEQ;
    CRASHURGAP_N->TARGET_QTY = CRASHURGAP->TARGET_QTY;
    CRASHURGAP_N->FEL_QTY = CRASHURGAP->FEL_QTY;
    CRASHURGAP_N->DIFF_QTY = CRASHURGAP->DIFF_QTY;
    CRASHURGAP_N->TIME_LOSS = CRASHURGAP->TIME_LOSS;
    CRASHURGAP_N->DOWN_TIME = CRASHURGAP->DOWN_TIME;
    CRASHURGAP_N->EFF_TIME = CRASHURGAP->EFF_TIME;
    MEMCPY_AN(CRASHURGAP_N->TYPE_4M, CRASHURGAP->TYPE_4M, sizeof(CRASHURGAP->TYPE_4M));
    MEMCPY_AN(CRASHURGAP_N->PROCESS_TYPE, CRASHURGAP->PROCESS_TYPE, sizeof(CRASHURGAP->PROCESS_TYPE));
    MEMCPY_AN(CRASHURGAP_N->EQ, CRASHURGAP->EQ, sizeof(CRASHURGAP->EQ));
    CRASHURGAP_N->EQ_MAX = CRASHURGAP->EQ_MAX;
    MEMCPY_AN(CRASHURGAP_N->HOUR_DESC, CRASHURGAP->HOUR_DESC, sizeof(CRASHURGAP->HOUR_DESC));
    MEMCPY_AN(CRASHURGAP_N->CREATE_USER_ID, CRASHURGAP->CREATE_USER_ID, sizeof(CRASHURGAP->CREATE_USER_ID));
    MEMCPY_AN(CRASHURGAP_N->TRAN_TIME, CRASHURGAP->TRAN_TIME, sizeof(CRASHURGAP->TRAN_TIME));
    MEMCPY_AN(CRASHURGAP_N->CMF_1, CRASHURGAP->CMF_1, sizeof(CRASHURGAP->CMF_1));
    MEMCPY_AN(CRASHURGAP_N->CMF_2, CRASHURGAP->CMF_2, sizeof(CRASHURGAP->CMF_2));
    MEMCPY_AN(CRASHURGAP_N->CMF_3, CRASHURGAP->CMF_3, sizeof(CRASHURGAP->CMF_3));
    MEMCPY_AN(CRASHURGAP_N->CMF_4, CRASHURGAP->CMF_4, sizeof(CRASHURGAP->CMF_4));
    MEMCPY_AN(CRASHURGAP_N->CMF_5, CRASHURGAP->CMF_5, sizeof(CRASHURGAP->CMF_5));
}


/* Del Null Function */
void CDB_del_null_crashurgap(struct CRASHURGAP_N_TAG *CRASHURGAP_N, struct CRASHURGAP_TAG *CRASHURGAP)
{
    MEMCPY_DN(CRASHURGAP->WORK_DATE, CRASHURGAP_N->WORK_DATE, sizeof(CRASHURGAP->WORK_DATE));
    MEMCPY_DN(CRASHURGAP->LINE_ID, CRASHURGAP_N->LINE_ID, sizeof(CRASHURGAP->LINE_ID));
