/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_crashurgap(int sel_type, struct CRASHURGAP_TAG *CRASHURGAP)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASHURGAP_N_TAG CRASHURGAP_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_crashurgap(&CRASHURGAP_N, CRASHURGAP);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASHURGAP_CUR_1 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    LINE_ID,
                    HOUR_TYPE,
                    WORK_SHIFT,
                    WORK_TIME,
                    HIST_SEQ,
                    NVL(TARGET_QTY, '0'),
                    NVL(FEL_QTY, '0'),
                    NVL(DIFF_QTY, '0'),
                    NVL(TIME_LOSS, '0'),
                    NVL(DOWN_TIME, '0'),
                    NVL(EFF_TIME, '0'),
                    NVL(TYPE_4M, ' '),
                    NVL(PROCESS_TYPE, ' '),
                    NVL(EQ, ' '),
                    NVL(EQ_MAX, '0'),
                    NVL(HOUR_DESC, ' '),
                    NVL(CREATE_USER_ID, ' '),
                    NVL(TRAN_TIME, ' '),
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' ')
                FROM CRASHURGAP
                ORDER BY WORK_DATE ASC,
                    LINE_ID ASC,
                    HOUR_TYPE ASC,
                    WORK_SHIFT ASC,
                    WORK_TIME ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN CDB_CRASHURGAP_CUR_1;
            break;

			case 2:
				EXEC SQL DECLARE CDB_CRASHURGAP_CUR_2 CURSOR FOR
					SELECT 
						DECODE(WORK_TIME,'01',WORK_DATE+1,'02',WORK_DATE+1,'03',WORK_DATE+1,'04',WORK_DATE+1,'05',WORK_DATE+1,WORK_DATE) WORK_DATE,
						LINE_ID,
						HOUR_TYPE,
						WORK_SHIFT,
						WORK_TIME,
						HIST_SEQ,
						NVL(TARGET_QTY, '0'),
						NVL(FEL_QTY, '0'),
						NVL(DIFF_QTY, '0'),
						NVL(TIME_LOSS, '0'),
						NVL(DOWN_TIME, '0'),
						NVL(EFF_TIME, '0'),
						NVL(TYPE_4M, ' '),
						NVL(PROCESS_TYPE, ' '),
						NVL(EQ, ' '),
						NVL(EQ_MAX, '0'),
						NVL(HOUR_DESC, ' '),
						NVL(CREATE_USER_ID, ' '),
						NVL(TRAN_TIME, ' '),
						NVL(CMF_1, ' '),
						NVL(CMF_2, ' '),
						NVL(CMF_3, ' '),
						NVL(CMF_4, ' '),
						NVL(CMF_5, ' ')
					FROM CRASHURGAP
					WHERE WORK_DATE = :CRASHURGAP_N.WORK_DATE
                    AND LINE_ID = :CRASHURGAP_N.LINE_ID
                    AND HOUR_TYPE = :CRASHURGAP_N.HOUR_TYPE
                    AND WORK_SHIFT = :CRASHURGAP_N.WORK_SHIFT 
					ORDER BY WORK_DATE ASC,
						LINE_ID ASC,
						HOUR_TYPE ASC,
						WORK_SHIFT ASC,
						WORK_TIME ASC,
						HIST_SEQ ASC;
				EXEC SQL OPEN CDB_CRASHURGAP_CUR_2;
				break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_crashurgap", sel_type);
}


