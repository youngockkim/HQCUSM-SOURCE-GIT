    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPLOTRPS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOT_ID,
                    STRING_ID,
                    TO_STRING_ID,
                    STRING_LOC,
                    MAT_ID,
                    FLOW,
                    OPER,
                    ORDER_ID,
                    LINE_ID,
                    RES_ID,
