                    NULL_SPACE_FLAG,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10
                FROM CWIPLOTRPS
                ORDER BY FACTORY ASC,
                    LOT_ID ASC,
                    STRING_ID ASC;
