    CDB_add_null_cedclotrlt(&CEDCLOTRLT_N, CEDCLOTRLT);
    DB_error_code = 0;


    EXEC SQL INSERT INTO CEDCLOTRLT( 
                    FACTORY, 
                    INS_TYPE, 
                    LOT_ID, 
