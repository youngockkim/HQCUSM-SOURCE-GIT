                    :CEDCLOTRLT_N.INS_CNT,
                    :CEDCLOTRLT_N.CMF_1
                FROM CEDCLOTRLT
                WHERE FACTORY = :CEDCLOTRLT_N.FACTORY
                    AND INS_TYPE = :CEDCLOTRLT_N.INS_TYPE
                    AND LOT_ID = :CEDCLOTRLT_N.LOT_ID;
            break;
		case 3:
			EXEC SQL SELECT TRIM(TO_CHAR(TRUNC(AVG(NVL(M.STEP_1_MEASURE, B.STEP_1_MEASURE)), 5), '0.00000')) STEP_1_MEASURE
				,TRIM(TO_CHAR(TRUNC(AVG(NVL(M.STEP_2_MEASURE, B.STEP_2_MEASURE)), 5), '0.00000')) STEP_2_MEASURE
				,TRIM(TO_CHAR(TRUNC(AVG(NVL(M.STEP_3_MEASURE, B.STEP_3_MEASURE)), 5), '0.00000')) STEP_3_MEASURE
				,TRIM(TO_CHAR(TRUNC(AVG(NVL(M.STEP_4_MEASURE, B.STEP_4_MEASURE)), 5), '0.00000')) STEP_4_MEASURE
			INTO
				:CEDCLOTRLT_N.CMF_1,
                :CEDCLOTRLT_N.CMF_2,
                :CEDCLOTRLT_N.CMF_3,
                :CEDCLOTRLT_N.CMF_4
			FROM 
			(
				SELECT E.LOT_ID
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_1_MEASURE_OHM', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_1_MEASURE
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_1_RESULT', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_1_RESULT
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_2_MEASURE_OHM', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_2_MEASURE
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_2_RESULT', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_2_RESULT
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_3_MEASURE_OHM', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_3_MEASURE
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_3_RESULT', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_3_RESULT
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_4_MEASURE_OHM', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_4_MEASURE
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_4_RESULT', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_4_RESULT
				FROM CEDCLOTRLT T, CEDCINSDAT E
				WHERE T.FACTORY = 'USGAM1'
				AND T.INS_TYPE = 'GR'
				AND T.RESULT_VALUE = 'OK'
				AND T.CMF_1 > TO_CHAR(SYSDATE-20,'YYYYMMDDHH24MISS')
				AND T.FACTORY = E.FACTORY
				AND T.LOT_ID = E.LOT_ID
				AND T.MAT_ID = :CEDCLOTRLT_N.MAT_ID
				AND E.OPER = 'M3100'
				AND ROWNUM <= 400
				GROUP BY E.LOT_ID, E.LOT_HIST_SEQ
			) M,
			(
				SELECT E.LOT_ID
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_1_MEASURE_OHM', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_1_MEASURE
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_1_RESULT', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_1_RESULT
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_2_MEASURE_OHM', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_2_MEASURE
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_2_RESULT', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_2_RESULT
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_3_MEASURE_OHM', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_3_MEASURE
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_3_RESULT', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_3_RESULT
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_4_MEASURE_OHM', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_4_MEASURE
				,SUM(DECODE(E.PARAM_NAME, 'I_GRD_01_STEP_4_RESULT', TO_NUMBER(TRIM(E.PARAM_VALUE||'')), '0')) STEP_4_RESULT
				FROM CEDCLOTRLT T, CEDCINSDAT E
				WHERE T.FACTORY = 'USGAM1'
				AND T.INS_TYPE = 'GR'
				AND T.CMF_1 > TO_CHAR(SYSDATE-20,'YYYYMMDDHH24MISS')
				AND T.RESULT_VALUE = 'OK'
				AND T.FACTORY = E.FACTORY
				AND T.LOT_ID = E.LOT_ID
				AND T.MAT_ID IN (SELECT MAT_ID FROM MWIPMATDEF WHERE MAT_CMF_3 = (SELECT MAT_CMF_3 FROM MWIPMATDEF WHERE MAT_ID = :CEDCLOTRLT_N.MAT_ID AND ROWNUM <= 10))
				AND E.OPER = 'M3100'
				AND ROWNUM <= 400
				GROUP BY E.LOT_ID, E.LOT_HIST_SEQ
			) B
			WHERE M.STEP_1_RESULT = '0'
				AND M.STEP_2_RESULT = '0'
				AND M.STEP_3_RESULT = '0'
				AND M.STEP_4_RESULT = '0'
				AND B.STEP_1_RESULT = '0'
				AND B.STEP_2_RESULT = '0'
				AND B.STEP_3_RESULT = '0'
				AND B.STEP_4_RESULT = '0';
			break;

		case 4:
            EXEC SQL SELECT 
                    FACTORY,
                    INS_TYPE,
                    LOT_ID,
                    INS_OPER,
                    MAT_ID,
                    FLOW,
                    OPER,
                    LOT_TYPE,
                    LINE_ID,
                    RES_ID,
                    QTY,
