/* SQL UPDATE Function */
void CDB_update_cedclotrlt(int sel_type, struct CEDCLOTRLT_TAG *CEDCLOTRLT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CEDCLOTRLT_N_TAG CEDCLOTRLT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedclotrlt(&CEDCLOTRLT_N, CEDCLOTRLT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE /*+ INDEX (CEDCLOTRLT,CEDCLOTRLT_PK )  */ CEDCLOTRLT SET
                    INS_OPER = :CEDCLOTRLT_N.INS_OPER,
                    MAT_ID = :CEDCLOTRLT_N.MAT_ID,
                    FLOW = :CEDCLOTRLT_N.FLOW,
                    OPER = :CEDCLOTRLT_N.OPER,
                    LOT_TYPE = :CEDCLOTRLT_N.LOT_TYPE,
                    LINE_ID = :CEDCLOTRLT_N.LINE_ID,
                    RES_ID = :CEDCLOTRLT_N.RES_ID,
                    QTY = :CEDCLOTRLT_N.QTY,
                    INS_CNT = :CEDCLOTRLT_N.INS_CNT,
                    INS_VALUE = :CEDCLOTRLT_N.INS_VALUE,
                    INS_USER_ID = :CEDCLOTRLT_N.INS_USER_ID,
                    INS_TIME = :CEDCLOTRLT_N.INS_TIME,
                    RESULT_USER_ID = :CEDCLOTRLT_N.RESULT_USER_ID,
                    RESULT_TIME = :CEDCLOTRLT_N.RESULT_TIME,
                    RESULT_VALUE = :CEDCLOTRLT_N.RESULT_VALUE,
                    INC_COMMENT = :CEDCLOTRLT_N.INC_COMMENT,
                    RLT_COMMENT = :CEDCLOTRLT_N.RLT_COMMENT,
                    TYPE_FLAG = :CEDCLOTRLT_N.TYPE_FLAG,
                    ORDER_ID = :CEDCLOTRLT_N.ORDER_ID,
                    GRADE = :CEDCLOTRLT_N.GRADE,
                    POWER = :CEDCLOTRLT_N.POWER,
                    LOC_ID = :CEDCLOTRLT_N.LOC_ID,
                    EFF = :CEDCLOTRLT_N.EFF,
                    RSH = :CEDCLOTRLT_N.RSH,
                    RS = :CEDCLOTRLT_N.RS,
                    FF = :CEDCLOTRLT_N.FF,
                    ISC = :CEDCLOTRLT_N.ISC,
                    VOC = :CEDCLOTRLT_N.VOC,
                    IMPP = :CEDCLOTRLT_N.IMPP,
                    VMPP = :CEDCLOTRLT_N.VMPP,
                    PMPP = :CEDCLOTRLT_N.PMPP,
                    TEMP = :CEDCLOTRLT_N.TEMP,
                    TREF = :CEDCLOTRLT_N.TREF,
                    SURFTEMP = :CEDCLOTRLT_N.SURFTEMP,
                    SUN = :CEDCLOTRLT_N.SUN,
                    OSC = :CEDCLOTRLT_N.OSC,
                    ESC = :CEDCLOTRLT_N.ESC,
                    EL = :CEDCLOTRLT_N.EL,
                    FLASHER_CODE = :CEDCLOTRLT_N.FLASHER_CODE,
                    CURING_TIME = :CEDCLOTRLT_N.CURING_TIME,
                    ARTICLE_NO = :CEDCLOTRLT_N.ARTICLE_NO,
                    ARTICLE_EXT_NO = :CEDCLOTRLT_N.ARTICLE_EXT_NO,
                    COLOR_CLASS = :CEDCLOTRLT_N.COLOR_CLASS,
                    PALLET_ID = :CEDCLOTRLT_N.PALLET_ID,
                    PAK_BAR_INFO = :CEDCLOTRLT_N.PAK_BAR_INFO,
                    PAK_GROUP = :CEDCLOTRLT_N.PAK_GROUP,
                    PAK_MOD_TYPE = :CEDCLOTRLT_N.PAK_MOD_TYPE,
                    LAST_HIST_SEQ = :CEDCLOTRLT_N.LAST_HIST_SEQ,
                --    CMF_1 = :CEDCLOTRLT_N.CMF_1,
                    CMF_2 = :CEDCLOTRLT_N.CMF_2,
                    CMF_3 = :CEDCLOTRLT_N.CMF_3,
                    CMF_4 = :CEDCLOTRLT_N.CMF_4,
                    CMF_5 = :CEDCLOTRLT_N.CMF_5,
                    WORK_SHIFT = :CEDCLOTRLT_N.WORK_SHIFT,
                    WORK_MONTH = :CEDCLOTRLT_N.WORK_MONTH,
                    WORK_WEEK = :CEDCLOTRLT_N.WORK_WEEK,
                    WORK_DAYS = :CEDCLOTRLT_N.WORK_DAYS,
                    WORK_DAY_OF_WEEK = :CEDCLOTRLT_N.WORK_DAY_OF_WEEK
                WHERE FACTORY = :CEDCLOTRLT_N.FACTORY
                    AND INS_TYPE = :CEDCLOTRLT_N.INS_TYPE
                    AND LOT_ID = :CEDCLOTRLT_N.LOT_ID;
            break;
		case 2:
            EXEC SQL UPDATE /*+ INDEX (CEDCLOTRLT,CEDCLOTRLT_PK )  */ CEDCLOTRLT SET
                    CMF_2 = :CEDCLOTRLT_N.CMF_2
                WHERE FACTORY = :CEDCLOTRLT_N.FACTORY
                    AND INS_TYPE = :CEDCLOTRLT_N.INS_TYPE
                    AND LOT_ID = :CEDCLOTRLT_N.LOT_ID;
            break;

		case 901:
            EXEC SQL INSERT INTO CEDCLOTRLT 
				SELECT
				  FACTORY, 
                    INS_TYPE, 
                    :CEDCLOTRLT_N.CMF_1, 
                    INS_OPER, 
                    MAT_ID, 
                    FLOW, 
                    OPER, 
                    LOT_TYPE, 
                    LINE_ID, 
                    RES_ID, 
                    QTY, 
                    INS_CNT, 
                    INS_VALUE, 
                    INS_USER_ID, 
                    DECODE(INS_TYPE, 'FC', :CEDCLOTRLT_N.INS_TIME, INS_TIME), 
                    RESULT_USER_ID, 
                    DECODE(INS_TYPE, 'FC', :CEDCLOTRLT_N.RESULT_TIME, RESULT_TIME),  
                    RESULT_VALUE, 
                    INC_COMMENT, 
                    RLT_COMMENT, 
                    TYPE_FLAG, 
                    ORDER_ID, 
                    GRADE, 
                    POWER, 
                    LOC_ID, 
                    EFF, 
                    RSH, 
                    RS, 
                    FF, 
                    ISC, 
                    VOC, 
                    IMPP, 
                    VMPP, 
                    PMPP, 
                    TEMP, 
                    TREF, 
                    SURFTEMP, 
                    SUN, 
                    OSC, 
                    ESC, 
                    EL, 
                    FLASHER_CODE, 
                    CURING_TIME, 
                    ARTICLE_NO, 
                    ARTICLE_EXT_NO, 
                    COLOR_CLASS, 
                    PALLET_ID, 
                    PAK_BAR_INFO, 
                    PAK_GROUP, 
                    PAK_MOD_TYPE, 
                    LAST_HIST_SEQ, 
                    DECODE(INS_TYPE, 'FC', :CEDCLOTRLT_N.INS_TIME, CMF_1), 
                    CMF_2, 
                    CMF_3, 
                    CMF_4, 
                    CMF_5, 
                    WORK_SHIFT, 
                    WORK_MONTH, 
                    WORK_WEEK, 
                    WORK_DAYS, 
                    WORK_DAY_OF_WEEK
				FROM CEDCLOTRLT
                WHERE FACTORY = :CEDCLOTRLT_N.FACTORY
                    AND LOT_ID = :CEDCLOTRLT_N.LOT_ID;
            break;



        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_cedclotrlt", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cedclotrlt(int sel_type, struct CEDCLOTRLT_TAG *CEDCLOTRLT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CEDCLOTRLT_N_TAG CEDCLOTRLT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedclotrlt(&CEDCLOTRLT_N, CEDCLOTRLT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CEDCLOTRLT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    INS_TYPE,
                    LOT_ID,
                    INS_OPER,
                    MAT_ID,
                    FLOW,
                    OPER,
                    LOT_TYPE,
                    LINE_ID,
                    RES_ID,
                    QTY,
                    INS_CNT,
                    INS_VALUE,
                    INS_USER_ID,
                    INS_TIME,
                    RESULT_USER_ID,
                    RESULT_TIME,
                    RESULT_VALUE,
                    INC_COMMENT,
                    RLT_COMMENT,
                    TYPE_FLAG,
                    ORDER_ID,
                    GRADE,
                    POWER,
                    LOC_ID,
                    EFF,
                    RSH,
                    RS,
                    FF,
                    ISC,
                    VOC,
                    IMPP,
                    VMPP,
                    PMPP,
                    TEMP,
                    TREF,
                    SURFTEMP,
                    SUN,
                    OSC,
                    ESC,
                    EL,
                    FLASHER_CODE,
                    CURING_TIME,
                    ARTICLE_NO,
                    ARTICLE_EXT_NO,
                    COLOR_CLASS,
                    PALLET_ID,
                    PAK_BAR_INFO,
                    PAK_GROUP,
                    PAK_MOD_TYPE,
                    LAST_HIST_SEQ,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    WORK_SHIFT,
                    WORK_MONTH,
                    WORK_WEEK,
                    WORK_DAYS,
                    WORK_DAY_OF_WEEK
                FROM CEDCLOTRLT
                ORDER BY FACTORY ASC,
                    INS_TYPE ASC,
                    LOT_ID ASC;
            EXEC SQL OPEN CDB_CEDCLOTRLT_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CEDCLOTRLT_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    INS_TYPE,
                    LOT_ID,
                    INS_OPER,
                    MAT_ID,
                    FLOW,
                    OPER,
                    LOT_TYPE,
                    LINE_ID,
                    RES_ID,
                    QTY,
                    INS_CNT,
                    INS_VALUE,
                    INS_USER_ID,
                    INS_TIME,
                    RESULT_USER_ID,
                    RESULT_TIME,
                    RESULT_VALUE,
                    INC_COMMENT,
                    RLT_COMMENT,
                    TYPE_FLAG,
                    ORDER_ID,
                    GRADE,
                    POWER,
                    LOC_ID,
                    EFF,
                    RSH,
                    RS,
                    FF,
                    ISC,
                    VOC,
                    IMPP,
                    VMPP,
                    PMPP,
                    TEMP,
                    TREF,
                    SURFTEMP,
                    SUN,
                    OSC,
                    ESC,
                    EL,
                    FLASHER_CODE,
                    CURING_TIME,
                    ARTICLE_NO,
                    ARTICLE_EXT_NO,
                    COLOR_CLASS,
                    PALLET_ID,
                    PAK_BAR_INFO,
                    PAK_GROUP,
                    PAK_MOD_TYPE,
                    LAST_HIST_SEQ,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    WORK_SHIFT,
                    WORK_MONTH,
                    WORK_WEEK,
                    WORK_DAYS,
                    WORK_DAY_OF_WEEK
                FROM CEDCLOTRLT
				WHERE LOT_ID = :CEDCLOTRLT_N.LOT_ID
                ORDER BY FACTORY ASC,
                    INS_TYPE ASC,
                    LOT_ID ASC;
            EXEC SQL OPEN CDB_CEDCLOTRLT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cedclotrlt", sel_type);
}


