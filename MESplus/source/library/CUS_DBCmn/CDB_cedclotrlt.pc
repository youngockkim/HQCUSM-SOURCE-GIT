                :CEDCLOTRLT_N.WORK_SHIFT,
                :CEDCLOTRLT_N.WORK_MONTH,
                :CEDCLOTRLT_N.WORK_WEEK,
                :CEDCLOTRLT_N.WORK_DAYS,
                :CEDCLOTRLT_N.WORK_DAY_OF_WEEK;
            break;

		case 2:
            EXEC SQL FETCH CDB_CEDCLOTRLT_CUR_2 INTO
                :CEDCLOTRLT_N.FACTORY,
                :CEDCLOTRLT_N.INS_TYPE,
                :CEDCLOTRLT_N.LOT_ID,
                :CEDCLOTRLT_N.INS_OPER,
                :CEDCLOTRLT_N.MAT_ID,
                :CEDCLOTRLT_N.FLOW,
                :CEDCLOTRLT_N.OPER,
                :CEDCLOTRLT_N.LOT_TYPE,
                :CEDCLOTRLT_N.LINE_ID,
                :CEDCLOTRLT_N.RES_ID,
                :CEDCLOTRLT_N.QTY,
                :CEDCLOTRLT_N.INS_CNT,
                :CEDCLOTRLT_N.INS_VALUE,
                :CEDCLOTRLT_N.INS_USER_ID,
                :CEDCLOTRLT_N.INS_TIME,
                :CEDCLOTRLT_N.RESULT_USER_ID,
                :CEDCLOTRLT_N.RESULT_TIME,
                :CEDCLOTRLT_N.RESULT_VALUE,
                :CEDCLOTRLT_N.INC_COMMENT,
                :CEDCLOTRLT_N.RLT_COMMENT,
                :CEDCLOTRLT_N.TYPE_FLAG,
                :CEDCLOTRLT_N.ORDER_ID,
                :CEDCLOTRLT_N.GRADE,
                :CEDCLOTRLT_N.POWER,
                :CEDCLOTRLT_N.LOC_ID,
                :CEDCLOTRLT_N.EFF,
                :CEDCLOTRLT_N.RSH,
                :CEDCLOTRLT_N.RS,
                :CEDCLOTRLT_N.FF,
                :CEDCLOTRLT_N.ISC,
                :CEDCLOTRLT_N.VOC,
                :CEDCLOTRLT_N.IMPP,
                :CEDCLOTRLT_N.VMPP,
                :CEDCLOTRLT_N.PMPP,
                :CEDCLOTRLT_N.TEMP,
                :CEDCLOTRLT_N.TREF,
                :CEDCLOTRLT_N.SURFTEMP,
                :CEDCLOTRLT_N.SUN,
                :CEDCLOTRLT_N.OSC,
                :CEDCLOTRLT_N.ESC,
                :CEDCLOTRLT_N.EL,
                :CEDCLOTRLT_N.FLASHER_CODE,
                :CEDCLOTRLT_N.CURING_TIME,
                :CEDCLOTRLT_N.ARTICLE_NO,
                :CEDCLOTRLT_N.ARTICLE_EXT_NO,
                :CEDCLOTRLT_N.COLOR_CLASS,
                :CEDCLOTRLT_N.PALLET_ID,
                :CEDCLOTRLT_N.PAK_BAR_INFO,
                :CEDCLOTRLT_N.PAK_GROUP,
                :CEDCLOTRLT_N.PAK_MOD_TYPE,
                :CEDCLOTRLT_N.LAST_HIST_SEQ,
                :CEDCLOTRLT_N.CMF_1,
                :CEDCLOTRLT_N.CMF_2,
                :CEDCLOTRLT_N.CMF_3,
                :CEDCLOTRLT_N.CMF_4,
                :CEDCLOTRLT_N.CMF_5,
                :CEDCLOTRLT_N.WORK_SHIFT,
                :CEDCLOTRLT_N.WORK_MONTH,
                :CEDCLOTRLT_N.WORK_WEEK,
                :CEDCLOTRLT_N.WORK_DAYS,
                :CEDCLOTRLT_N.WORK_DAY_OF_WEEK;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cedclotrlt(&CEDCLOTRLT_N, CEDCLOTRLT);
    }

    DB_stop_query_timer("CDB_fetch_cedclotrlt", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cedclotrlt(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CEDCLOTRLT_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CEDCLOTRLT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cedclotrlt", sel_type);
}


/* Initialize Function */
void CDB_init_cedclotrlt(struct CEDCLOTRLT_TAG *CEDCLOTRLT)
{
    /* memset by Space */
    memset(CEDCLOTRLT, ' ', sizeof(struct CEDCLOTRLT_TAG));
    
    CEDCLOTRLT->QTY = 0;
    CEDCLOTRLT->INS_CNT = 0;
    CEDCLOTRLT->LAST_HIST_SEQ = 0;
}


