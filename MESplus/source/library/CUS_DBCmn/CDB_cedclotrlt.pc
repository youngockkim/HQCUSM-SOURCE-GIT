        struct CEDCLOTRLT_N_TAG CEDCLOTRLT_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedclotrlt(&CEDCLOTRLT_N, CEDCLOTRLT);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CEDCLOTRLT
                WHERE FACTORY = :CEDCLOTRLT_N.FACTORY
                    AND INS_TYPE = :CEDCLOTRLT_N.INS_TYPE
                    AND LOT_ID = :CEDCLOTRLT_N.LOT_ID;
            break;

		case 2:
			EXEC SQL SELECT count(*) 
				INTO :d_value
				FROM CEDCLOTRLT A, CWIPLOTTRC B
				WHERE A.LOT_ID = B.LOT_ID
				AND  A.INS_TYPE =  :CEDCLOTRLT_N.INS_TYPE
				AND A.FACTORY = :CEDCLOTRLT_N.FACTORY
				AND A.CMF_1 >= :CEDCLOTRLT_N.CMF_1
				AND A.CMF_1 <  :CEDCLOTRLT_N.INS_TIME
				AND A.ORDER_ID = :CEDCLOTRLT_N.ORDER_ID
				AND A.GRADE = :CEDCLOTRLT_N.GRADE
				AND A.POWER =  :CEDCLOTRLT_N.POWER
				AND B.CMF1 = :CEDCLOTRLT_N.CMF_2
				AND B.TAB_RES_ID =  :CEDCLOTRLT_N.CMF_3;
			break;

		case 3:
			EXEC SQL SELECT SUM(DECODE(A.RESULT_VALUE,'A',1,1)) OUT_QTY
				INTO :d_value
				FROM CEDCLOTRLT A, CWIPLOTTRC B
				WHERE A.LOT_ID = B.LOT_ID
				AND  A.INS_TYPE =  :CEDCLOTRLT_N.INS_TYPE
				AND A.FACTORY = :CEDCLOTRLT_N.FACTORY
				AND A.CMF_1 >= :CEDCLOTRLT_N.CMF_1
				AND A.CMF_1 <  :CEDCLOTRLT_N.INS_TIME
				AND A.ORDER_ID = :CEDCLOTRLT_N.ORDER_ID
				AND A.GRADE = :CEDCLOTRLT_N.GRADE
				AND A.POWER =  :CEDCLOTRLT_N.POWER
				AND B.CMF1 = :CEDCLOTRLT_N.CMF_2
				AND B.TAB_RES_ID =  :CEDCLOTRLT_N.CMF_3
				AND A.RES_ID = :CEDCLOTRLT_N.RES_ID
				AND SUBSTR(A.CMF_1 ,9,2) = :CEDCLOTRLT_N.CMF_4;
			break;
		
		case 4:
			EXEC SQL SELECT SUM(DECODE(A.RESULT_VALUE,'A',1,1)) OUT_QTY
				INTO :d_value
				FROM CEDCLOTRLT A, CWIPLOTTRC B
				WHERE A.LOT_ID = B.LOT_ID
				AND  A.INS_TYPE =  :CEDCLOTRLT_N.INS_TYPE
				AND A.FACTORY = :CEDCLOTRLT_N.FACTORY
				AND A.CMF_1 >= :CEDCLOTRLT_N.CMF_1
				AND A.CMF_1 <  :CEDCLOTRLT_N.INS_TIME
				AND A.ORDER_ID = :CEDCLOTRLT_N.ORDER_ID
				AND A.GRADE = :CEDCLOTRLT_N.GRADE
				AND A.POWER =  :CEDCLOTRLT_N.POWER
				AND B.CMF1 = :CEDCLOTRLT_N.CMF_2
				AND A.RES_ID = :CEDCLOTRLT_N.RES_ID
				AND B.TAB_RES_ID =  :CEDCLOTRLT_N.CMF_3;
			break;
		
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_cedclotrlt_scalar", sel_type);

    return d_value;
}


/* SQL DELETE Function */
void CDB_delete_cedclotrlt(int sel_type, struct CEDCLOTRLT_TAG *CEDCLOTRLT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CEDCLOTRLT_N_TAG CEDCLOTRLT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedclotrlt(&CEDCLOTRLT_N, CEDCLOTRLT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM CEDCLOTRLT
                WHERE FACTORY = :CEDCLOTRLT_N.FACTORY
                    AND INS_TYPE = :CEDCLOTRLT_N.INS_TYPE
                    AND LOT_ID = :CEDCLOTRLT_N.LOT_ID;
