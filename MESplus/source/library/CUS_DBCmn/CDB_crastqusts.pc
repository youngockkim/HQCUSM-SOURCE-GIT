/* Del Null Function */
void CDB_del_null_crastqusts(struct CRASTQUSTS_N_TAG *CRASTQUSTS_N, struct CRASTQUSTS_TAG *CRASTQUSTS)
{
    MEMCPY_DN(CRASTQUSTS->JOB_ID, CRASTQUSTS_N->JOB_ID, sizeof(CRASTQUSTS->JOB_ID));
    MEMCPY_DN(CRASTQUSTS->FACTORY, CRASTQUSTS_N->FACTORY, sizeof(CRASTQUSTS->FACTORY));
    MEMCPY_DN(CRASTQUSTS->REQ_SYSTEM, CRASTQUSTS_N->REQ_SYSTEM, sizeof(CRASTQUSTS->REQ_SYSTEM));
    MEMCPY_DN(CRASTQUSTS->REQ_USER_ID, CRASTQUSTS_N->REQ_USER_ID, sizeof(CRASTQUSTS->REQ_USER_ID));
    MEMCPY_DN(CRASTQUSTS->REQ_TIME, CRASTQUSTS_N->REQ_TIME, sizeof(CRASTQUSTS->REQ_TIME));
    MEMCPY_DN(CRASTQUSTS->REQ_LINE_CODE, CRASTQUSTS_N->REQ_LINE_CODE, sizeof(CRASTQUSTS->REQ_LINE_CODE));
    MEMCPY_DN(CRASTQUSTS->REQ_PORT_TYPE, CRASTQUSTS_N->REQ_PORT_TYPE, sizeof(CRASTQUSTS->REQ_PORT_TYPE));
    MEMCPY_DN(CRASTQUSTS->REQ_MAT_TYPE, CRASTQUSTS_N->REQ_MAT_TYPE, sizeof(CRASTQUSTS->REQ_MAT_TYPE));
    MEMCPY_DN(CRASTQUSTS->REQ_RES_ID, CRASTQUSTS_N->REQ_RES_ID, sizeof(CRASTQUSTS->REQ_RES_ID));
