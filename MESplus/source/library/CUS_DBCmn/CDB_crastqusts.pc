                    :CRASTQUSTS_N.ORDER_ID,
                    :CRASTQUSTS_N.MAT_ID,
                    :CRASTQUSTS_N.JOB_CANCEL_FLAG,
                    :CRASTQUSTS_N.JOB_CANCEL_USER_ID,
                    :CRASTQUSTS_N.JOB_CANCEL_TIME,
                    :CRASTQUSTS_N.JOB_PAUSE_FLAG,
                    :CRASTQUSTS_N.JOB_PAUSE_USER_ID,
                    :CRASTQUSTS_N.JOB_PAUSE_TIME,
                    :CRASTQUSTS_N.JOB_RESUME_FLAG,
                    :CRASTQUSTS_N.JOB_RESUME_USER_ID,
                    :CRASTQUSTS_N.JOB_RESUME_TIME,
                    :CRASTQUSTS_N.QUEUE_CMF_1,
                    :CRASTQUSTS_N.QUEUE_CMF_2,
                    :CRASTQUSTS_N.QUEUE_CMF_3,
                    :CRASTQUSTS_N.QUEUE_CMF_4,
                    :CRASTQUSTS_N.QUEUE_CMF_5,
                    :CRASTQUSTS_N.QUEUE_CMF_6,
                    :CRASTQUSTS_N.QUEUE_CMF_7,
                    :CRASTQUSTS_N.QUEUE_CMF_8,
                    :CRASTQUSTS_N.QUEUE_CMF_9,
                    :CRASTQUSTS_N.QUEUE_CMF_10,
                    :CRASTQUSTS_N.QUEUE_CMF_11,
                    :CRASTQUSTS_N.QUEUE_CMF_12,
                    :CRASTQUSTS_N.QUEUE_CMF_13,
                    :CRASTQUSTS_N.QUEUE_CMF_14,
                    :CRASTQUSTS_N.QUEUE_CMF_15,
                    :CRASTQUSTS_N.QUEUE_CMF_16,
                    :CRASTQUSTS_N.QUEUE_CMF_17,
                    :CRASTQUSTS_N.QUEUE_CMF_18,
                    :CRASTQUSTS_N.QUEUE_CMF_19,
                    :CRASTQUSTS_N.QUEUE_CMF_20,
                    :CRASTQUSTS_N.ERROR_SYSTEM,
                    :CRASTQUSTS_N.ERROR_CODE,
                    :CRASTQUSTS_N.ERROR_MSG,
                    :CRASTQUSTS_N.DELETE_FLAG,
                    :CRASTQUSTS_N.DELETE_USER_ID,
                    :CRASTQUSTS_N.DELETE_TIME,
                    :CRASTQUSTS_N.CREATE_USER_ID,
                    :CRASTQUSTS_N.CREATE_TIME,
                    :CRASTQUSTS_N.UPDATE_USER_ID,
                    :CRASTQUSTS_N.UPDATE_TIME
         );

    DB_stop_query_timer("CDB_insert_crastqusts", 0);
}


/* SQL UPDATE Function */
void CDB_update_crastqusts(int sel_type, struct CRASTQUSTS_TAG *CRASTQUSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASTQUSTS_N_TAG CRASTQUSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_crastqusts(&CRASTQUSTS_N, CRASTQUSTS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE CRASTQUSTS SET
                    FACTORY = :CRASTQUSTS_N.FACTORY,
                    REQ_SYSTEM = :CRASTQUSTS_N.REQ_SYSTEM,
                    REQ_USER_ID = :CRASTQUSTS_N.REQ_USER_ID,
