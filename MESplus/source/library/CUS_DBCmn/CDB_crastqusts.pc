                :CRASTQUSTS_N.QUEUE_CMF_6,
                :CRASTQUSTS_N.QUEUE_CMF_7,
                :CRASTQUSTS_N.QUEUE_CMF_8,
                :CRASTQUSTS_N.QUEUE_CMF_9,
                :CRASTQUSTS_N.QUEUE_CMF_10,
                :CRASTQUSTS_N.QUEUE_CMF_11,
                :CRASTQUSTS_N.QUEUE_CMF_12,
                :CRASTQUSTS_N.QUEUE_CMF_13,
                :CRASTQUSTS_N.QUEUE_CMF_14,
                :CRASTQUSTS_N.QUEUE_CMF_15,
                :CRASTQUSTS_N.QUEUE_CMF_16,
                :CRASTQUSTS_N.QUEUE_CMF_17,
                :CRASTQUSTS_N.QUEUE_CMF_18,
                :CRASTQUSTS_N.QUEUE_CMF_19,
                :CRASTQUSTS_N.QUEUE_CMF_20,
                :CRASTQUSTS_N.ERROR_SYSTEM,
                :CRASTQUSTS_N.ERROR_CODE,
                :CRASTQUSTS_N.ERROR_MSG,
                :CRASTQUSTS_N.DELETE_FLAG,
                :CRASTQUSTS_N.DELETE_USER_ID,
                :CRASTQUSTS_N.DELETE_TIME,
                :CRASTQUSTS_N.CREATE_USER_ID,
                :CRASTQUSTS_N.CREATE_TIME,
                :CRASTQUSTS_N.UPDATE_USER_ID,
                :CRASTQUSTS_N.UPDATE_TIME;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_crastqusts(&CRASTQUSTS_N, CRASTQUSTS);
    }

    DB_stop_query_timer("CDB_fetch_crastqusts", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_crastqusts(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CRASTQUSTS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE CDB_CRASTQUSTS_CUR_2;
            break;
            
        case 3:
            EXEC SQL CLOSE CDB_CRASTQUSTS_CUR_3;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_crastqusts", sel_type);
}


/* Initialize Function */
void CDB_init_crastqusts(struct CRASTQUSTS_TAG *CRASTQUSTS)
{
    /* memset by Space */
    memset(CRASTQUSTS, ' ', sizeof(struct CRASTQUSTS_TAG));
    
    CRASTQUSTS->TRANS_PRIORITY = 0;
    CRASTQUSTS->JOB_INTERVAL_SEC = 0;
    CRASTQUSTS->MOVE_INTERVAL_SEC = 0;
}


