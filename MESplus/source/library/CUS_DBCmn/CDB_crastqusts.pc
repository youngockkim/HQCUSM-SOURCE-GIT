                    :CRASTQUSTS_N.QUEUE_CMF_12,
                    :CRASTQUSTS_N.QUEUE_CMF_13,
                    :CRASTQUSTS_N.QUEUE_CMF_14,
                    :CRASTQUSTS_N.QUEUE_CMF_15,
                    :CRASTQUSTS_N.QUEUE_CMF_16,
                    :CRASTQUSTS_N.QUEUE_CMF_17,
                    :CRASTQUSTS_N.QUEUE_CMF_18,
                    :CRASTQUSTS_N.QUEUE_CMF_19,
                    :CRASTQUSTS_N.QUEUE_CMF_20,
                    :CRASTQUSTS_N.ERROR_SYSTEM,
                    :CRASTQUSTS_N.ERROR_CODE,
                    :CRASTQUSTS_N.ERROR_MSG,
                    :CRASTQUSTS_N.DELETE_FLAG,
                    :CRASTQUSTS_N.DELETE_USER_ID,
                    :CRASTQUSTS_N.DELETE_TIME,
                    :CRASTQUSTS_N.CREATE_USER_ID,
                    :CRASTQUSTS_N.CREATE_TIME,
                    :CRASTQUSTS_N.UPDATE_USER_ID,
                    :CRASTQUSTS_N.UPDATE_TIME
                FROM 
                (
                    SELECT * 
                    FROM CRASTQUSTS
                    WHERE 1                 = 1
                    AND FACTORY             = :CRASTQUSTS_N.FACTORY
                    AND REQ_PORT_ID         = :CRASTQUSTS_N.REQ_PORT_ID
                    AND DELETE_FLAG         <> 'Y'
                    AND JOB_CANCEL_FLAG     <> 'Y'
                    AND JOB_END_FLAG        <> 'Y'
                    AND JOB_STATUS          <> 'END'
                    AND REQ_TYPE            = 'MAT'
                    ORDER BY REQ_TIME DESC
                ) 
                WHERE ROWNUM  = 1;

            break;

            

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_crastqusts(&CRASTQUSTS_N, CRASTQUSTS);
    }

    DB_stop_query_timer("CDB_select_crastqusts", sel_type);
}


