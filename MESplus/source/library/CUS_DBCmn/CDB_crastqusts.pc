/* SQL SELECT_SCALAR Function */
double CDB_select_crastqusts_scalar(int sel_type, struct CRASTQUSTS_TAG *CRASTQUSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASTQUSTS_N_TAG CRASTQUSTS_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_crastqusts(&CRASTQUSTS_N, CRASTQUSTS);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CRASTQUSTS
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;

        
        case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CRASTQUSTS
                WHERE 1             = 1
                AND FACTORY         = :CRASTQUSTS_N.FACTORY
                AND DELETE_FLAG     <> 'Y'
                AND JOB_CANCEL_FLAG <> 'Y'
				AND JOB_REPLY_STATUS <> '0'
                AND RESV_FLAG       = 'Y'
                AND REQ_TYPE        = 'MAT'
                AND REQ_PORT_TYPE   = :CRASTQUSTS_N.REQ_PORT_TYPE
                AND REQ_MAT_TYPE    = :CRASTQUSTS_N.REQ_MAT_TYPE
                AND REQ_LINE_CODE IN(SELECT KEY_2 
                                        FROM MGCMTBLDAT
                                        WHERE FACTORY  = :CRASTQUSTS_N.FACTORY
                                        AND TABLE_NAME = '@KIT_PORT_MAP'
                                        AND KEY_1      = :CRASTQUSTS_N.REQ_PORT_ID);
            break;


        case 3:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CRASTQUSTS
                WHERE 1                 = 1
                AND FACTORY             = :CRASTQUSTS_N.FACTORY
                AND RESV_FLAG           = 'Y'
                AND DELETE_FLAG         <> 'Y'
                AND JOB_CANCEL_FLAG     <> 'Y'
                AND REQ_RES_ID          = :CRASTQUSTS_N.REQ_RES_ID
                AND REQ_PORT_ID         = :CRASTQUSTS_N.REQ_PORT_ID
                AND REQ_PORT_TYPE       = :CRASTQUSTS_N.REQ_PORT_TYPE
                AND REQ_MAT_TYPE        = :CRASTQUSTS_N.REQ_MAT_TYPE
                AND REQ_TYPE            = 'MAT';
            break;


        case 4:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CRASTQUSTS
                WHERE 1                 = 1
                AND FACTORY             = :CRASTQUSTS_N.FACTORY
                AND DELETE_FLAG         <> 'Y'
                AND JOB_CANCEL_FLAG     <> 'Y'
                AND JOB_STATUS          NOT IN ('CANCEL', 'TERM', 'END')
                AND CRR_ID              = :CRASTQUSTS_N.CRR_ID
                AND (REQ_PORT_ID = :CRASTQUSTS_N.REQ_PORT_ID    OR
                     FROM_PORT_ID = :CRASTQUSTS_N.FROM_PORT_ID  OR
                     TO_PORT_ID = :CRASTQUSTS_N.TO_PORT_ID);
            break;

        case 5:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CRASTQUSTS
                WHERE 1                 = 1
                AND FACTORY             = :CRASTQUSTS_N.FACTORY
                AND REQ_PORT_ID         = :CRASTQUSTS_N.REQ_PORT_ID
                AND REQ_TYPE            = 'CRR'
                AND JOB_SEND_STATUS     = '0'
                AND JOB_REPLY_STATUS    = '0'
                AND DELETE_FLAG         <> 'Y'
                AND JOB_CANCEL_FLAG     <> 'Y'
                AND JOB_TERM_FLAG       <> 'Y'
                AND JOB_END_FLAG        <> 'Y'
                AND JOB_STATUS          NOT IN ('CANCEL', 'TERM', 'END');
            break;

        case 6:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CRASTQUSTS
                WHERE 1                 = 1
                AND FACTORY             = :CRASTQUSTS_N.FACTORY
                AND REQ_PORT_ID         = :CRASTQUSTS_N.REQ_PORT_ID
                AND DELETE_FLAG         <> 'Y'
                AND JOB_CANCEL_FLAG     <> 'Y'
                AND JOB_TERM_FLAG       <> 'Y'
                AND JOB_END_FLAG        <> 'Y'
                AND REQ_TYPE            = :CRASTQUSTS_N.REQ_TYPE
                AND JOB_STATUS          NOT IN ('CANCEL', 'TERM', 'END');
            break;

        case 7:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CRASTQUSTS
                WHERE 1                 = 1
                AND FACTORY             = :CRASTQUSTS_N.FACTORY
                AND TO_PORT_ID         = :CRASTQUSTS_N.TO_PORT_ID
                AND DELETE_FLAG         <> 'Y'
                AND JOB_CANCEL_FLAG     <> 'Y'
                AND JOB_TERM_FLAG       <> 'Y'
                AND JOB_END_FLAG        <> 'Y'
                AND REQ_TYPE            = :CRASTQUSTS_N.REQ_TYPE
                AND JOB_STATUS          NOT IN ('CANCEL', 'TERM', 'END');
            break;

        case 8:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CRASTQUSTS
                WHERE 1                 = 1
                AND FACTORY             = :CRASTQUSTS_N.FACTORY
                AND TO_PORT_ID         = :CRASTQUSTS_N.TO_PORT_ID
                AND DELETE_FLAG         <> 'Y'
                AND JOB_CANCEL_FLAG     <> 'Y'
                AND JOB_TERM_FLAG       <> 'Y'
                AND JOB_END_FLAG        <> 'Y'
                AND REQ_TYPE            = :CRASTQUSTS_N.REQ_TYPE
                AND JOB_STATUS          NOT IN ('CANCEL', 'TERM', 'END');
            break;

        case 9:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CRASTQUSTS
                WHERE 1                 = 1
                AND FACTORY             = :CRASTQUSTS_N.FACTORY
                AND REQ_PORT_ID         = :CRASTQUSTS_N.REQ_PORT_ID
                AND RESV_FLAG           <> 'Y'
                AND DELETE_FLAG         <> 'Y'
                AND JOB_CANCEL_FLAG     <> 'Y'
                AND JOB_TERM_FLAG       <> 'Y'
                AND JOB_END_FLAG        <> 'Y'
                AND JOB_STATUS          NOT IN ('CANCEL', 'TERM', 'END');
            break;
            
        case 10:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CRASTQUSTS
                WHERE 1                 = 1
                AND FACTORY             = :CRASTQUSTS_N.FACTORY
                AND FROM_PORT_ID         = :CRASTQUSTS_N.FROM_PORT_ID
                AND DELETE_FLAG         <> 'Y'
                AND JOB_CANCEL_FLAG     <> 'Y'
                AND JOB_TERM_FLAG       <> 'Y'
                AND JOB_END_FLAG        <> 'Y'
                AND JOB_STATUS          NOT IN ('CANCEL', 'TERM', 'END');
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_crastqusts_scalar", sel_type);

    return d_value;
}


/* SQL DELETE Function */
void CDB_delete_crastqusts(int sel_type, struct CRASTQUSTS_TAG *CRASTQUSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASTQUSTS_N_TAG CRASTQUSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_crastqusts(&CRASTQUSTS_N, CRASTQUSTS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM CRASTQUSTS
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_delete_crastqusts", sel_type);
}


/* SQL INSERT Function */
