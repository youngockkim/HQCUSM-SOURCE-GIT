            sprintf(sql + strlen(sql), "RESV_FLAG,  ");
            sprintf(sql + strlen(sql), "FROM_RES_ID,  ");
            sprintf(sql + strlen(sql), "FROM_PORT_ID,  ");
            sprintf(sql + strlen(sql), "FROM_ZONE_ID,  ");
            sprintf(sql + strlen(sql), "TO_RES_ID,  ");
            sprintf(sql + strlen(sql), "TO_PORT_ID,  ");
            sprintf(sql + strlen(sql), "TO_ZONE_ID,  ");
            sprintf(sql + strlen(sql), "CUR_RES_ID,  ");
            sprintf(sql + strlen(sql), "CUR_PORT_ID,  ");
            sprintf(sql + strlen(sql), "CUR_ZONE_ID,  ");
            sprintf(sql + strlen(sql), "TRANS_PRIORITY,  ");
