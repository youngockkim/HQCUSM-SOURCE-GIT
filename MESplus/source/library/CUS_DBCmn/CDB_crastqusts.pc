/* SQL CURSOR FETCH Function */
void CDB_fetch_crastqusts(int sel_type, struct CRASTQUSTS_TAG *CRASTQUSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASTQUSTS_N_TAG CRASTQUSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CRASTQUSTS_CUR_1 INTO
                :CRASTQUSTS_N.JOB_ID,
                :CRASTQUSTS_N.FACTORY,
