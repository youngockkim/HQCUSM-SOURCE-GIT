                    JOB_END_FLAG = :CRASTQUSTS_N.JOB_END_FLAG,
                    JOB_END_TIME = :CRASTQUSTS_N.JOB_END_TIME,
                    JOB_END_STATUS = :CRASTQUSTS_N.JOB_END_STATUS,
                    JOB_ABNORMAL_FLAG = :CRASTQUSTS_N.JOB_ABNORMAL_FLAG,
                    JOB_TERM_FLAG = :CRASTQUSTS_N.JOB_TERM_FLAG,
                    JOB_TERM_TIME = :CRASTQUSTS_N.JOB_TERM_TIME,
                    JOB_TERM_STATUS = :CRASTQUSTS_N.JOB_TERM_STATUS,
                    JOB_ALTER_FLAG = :CRASTQUSTS_N.JOB_ALTER_FLAG,
                    JOB_ALTER_TIME = :CRASTQUSTS_N.JOB_ALTER_TIME,
                    JOB_ALTER_STATUS = :CRASTQUSTS_N.JOB_ALTER_STATUS,
                    JOB_INTERVAL_SEC = :CRASTQUSTS_N.JOB_INTERVAL_SEC,
                    MOVE_INTERVAL_SEC = :CRASTQUSTS_N.MOVE_INTERVAL_SEC,
                    CRR_TYPE = :CRASTQUSTS_N.CRR_TYPE,
                    CRR_ID = :CRASTQUSTS_N.CRR_ID,
                    JOB_STATUS = :CRASTQUSTS_N.JOB_STATUS,
                    EMPTY_CRR_FLAG = :CRASTQUSTS_N.EMPTY_CRR_FLAG,
                    LOT_ID = :CRASTQUSTS_N.LOT_ID,
                    ORDER_ID = :CRASTQUSTS_N.ORDER_ID,
                    MAT_ID = :CRASTQUSTS_N.MAT_ID,
                    JOB_CANCEL_FLAG = :CRASTQUSTS_N.JOB_CANCEL_FLAG,
                    JOB_CANCEL_USER_ID = :CRASTQUSTS_N.JOB_CANCEL_USER_ID,
                    JOB_CANCEL_TIME = :CRASTQUSTS_N.JOB_CANCEL_TIME,
                    JOB_PAUSE_FLAG = :CRASTQUSTS_N.JOB_PAUSE_FLAG,
                    JOB_PAUSE_USER_ID = :CRASTQUSTS_N.JOB_PAUSE_USER_ID,
                    JOB_PAUSE_TIME = :CRASTQUSTS_N.JOB_PAUSE_TIME,
                    JOB_RESUME_FLAG = :CRASTQUSTS_N.JOB_RESUME_FLAG,
                    JOB_RESUME_USER_ID = :CRASTQUSTS_N.JOB_RESUME_USER_ID,
                    JOB_RESUME_TIME = :CRASTQUSTS_N.JOB_RESUME_TIME,
                    QUEUE_CMF_1 = :CRASTQUSTS_N.QUEUE_CMF_1,
                    QUEUE_CMF_2 = :CRASTQUSTS_N.QUEUE_CMF_2,
                    QUEUE_CMF_3 = :CRASTQUSTS_N.QUEUE_CMF_3,
                    QUEUE_CMF_4 = :CRASTQUSTS_N.QUEUE_CMF_4,
                    QUEUE_CMF_5 = :CRASTQUSTS_N.QUEUE_CMF_5,
                    QUEUE_CMF_6 = :CRASTQUSTS_N.QUEUE_CMF_6,
                    QUEUE_CMF_7 = :CRASTQUSTS_N.QUEUE_CMF_7,
                    QUEUE_CMF_8 = :CRASTQUSTS_N.QUEUE_CMF_8,
                    QUEUE_CMF_9 = :CRASTQUSTS_N.QUEUE_CMF_9,
                    QUEUE_CMF_10 = :CRASTQUSTS_N.QUEUE_CMF_10,
                    QUEUE_CMF_11 = :CRASTQUSTS_N.QUEUE_CMF_11,
                    QUEUE_CMF_12 = :CRASTQUSTS_N.QUEUE_CMF_12,
                    QUEUE_CMF_13 = :CRASTQUSTS_N.QUEUE_CMF_13,
                    QUEUE_CMF_14 = :CRASTQUSTS_N.QUEUE_CMF_14,
                    QUEUE_CMF_15 = :CRASTQUSTS_N.QUEUE_CMF_15,
                    QUEUE_CMF_16 = :CRASTQUSTS_N.QUEUE_CMF_16,
                    QUEUE_CMF_17 = :CRASTQUSTS_N.QUEUE_CMF_17,
                    QUEUE_CMF_18 = :CRASTQUSTS_N.QUEUE_CMF_18,
                    QUEUE_CMF_19 = :CRASTQUSTS_N.QUEUE_CMF_19,
                    QUEUE_CMF_20 = :CRASTQUSTS_N.QUEUE_CMF_20,
                    ERROR_SYSTEM = :CRASTQUSTS_N.ERROR_SYSTEM,
                    ERROR_CODE = :CRASTQUSTS_N.ERROR_CODE,
                    ERROR_MSG = :CRASTQUSTS_N.ERROR_MSG,
                    DELETE_FLAG = :CRASTQUSTS_N.DELETE_FLAG,
                    DELETE_USER_ID = :CRASTQUSTS_N.DELETE_USER_ID,
                    DELETE_TIME = :CRASTQUSTS_N.DELETE_TIME,
                    CREATE_USER_ID = :CRASTQUSTS_N.CREATE_USER_ID,
                    CREATE_TIME = :CRASTQUSTS_N.CREATE_TIME,
                    UPDATE_USER_ID = :CRASTQUSTS_N.UPDATE_USER_ID,
                    UPDATE_TIME = :CRASTQUSTS_N.UPDATE_TIME
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;

        case 2:
            EXEC SQL UPDATE CRASTQUSTS SET
                    JOB_STATUS        = :CRASTQUSTS_N.JOB_STATUS,
                    JOB_SEND_TIME     = :CRASTQUSTS_N.JOB_SEND_TIME,
                    JOB_SEND_STATUS   = :CRASTQUSTS_N.JOB_SEND_STATUS, 
                    RESV_FLAG         = ' ',
                    JOB_ABNORMAL_FLAG = ' ',
                    JOB_END_FLAG = ' ',
                    ORDER_ID = :CRASTQUSTS_N.ORDER_ID,
                    UPDATE_USER_ID = :CRASTQUSTS_N.UPDATE_USER_ID,
                    UPDATE_TIME = :CRASTQUSTS_N.UPDATE_TIME
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;

        case 3:
            EXEC SQL UPDATE CRASTQUSTS SET
                    JOB_STATUS = :CRASTQUSTS_N.JOB_STATUS,
                    JOB_REPLY_TIME = :CRASTQUSTS_N.JOB_REPLY_TIME,
                    JOB_REPLY_STATUS = :CRASTQUSTS_N.JOB_REPLY_STATUS,
                    RESV_FLAG = :CRASTQUSTS_N.RESV_FLAG,
                    JOB_ABNORMAL_FLAG = :CRASTQUSTS_N.JOB_ABNORMAL_FLAG,
                    ERROR_CODE = :CRASTQUSTS_N.ERROR_CODE,
                    ERROR_MSG = :CRASTQUSTS_N.ERROR_MSG,
                    JOB_TERM_FLAG = :CRASTQUSTS_N.JOB_TERM_FLAG,
                    JOB_TERM_TIME = :CRASTQUSTS_N.JOB_TERM_TIME,
                    UPDATE_USER_ID = :CRASTQUSTS_N.UPDATE_USER_ID,
                    UPDATE_TIME = :CRASTQUSTS_N.UPDATE_TIME
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;

        case 4:
            EXEC SQL UPDATE CRASTQUSTS SET
                    JOB_STATUS = :CRASTQUSTS_N.JOB_STATUS,
                    JOB_CREATE_TIME = :CRASTQUSTS_N.JOB_CREATE_TIME,
                    JOB_CREATE_STATUS = :CRASTQUSTS_N.JOB_CREATE_STATUS
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;

        case 5:
            EXEC SQL UPDATE /*+ INDEX (CRASTQUSTS JOB_ID) */ CRASTQUSTS   SET 
                    JOB_STATUS = :CRASTQUSTS_N.JOB_STATUS,
                    JOB_MOVE_START_TIME = :CRASTQUSTS_N.JOB_MOVE_START_TIME,
                    JOB_MOVE_STATUS = :CRASTQUSTS_N.JOB_MOVE_STATUS,
                    ERROR_CODE = :CRASTQUSTS_N.ERROR_CODE,
                    ERROR_MSG = :CRASTQUSTS_N.ERROR_MSG,
                    UPDATE_USER_ID = :CRASTQUSTS_N.UPDATE_USER_ID,
                    UPDATE_TIME = :CRASTQUSTS_N.UPDATE_TIME
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;

        case 6:
            EXEC SQL UPDATE CRASTQUSTS SET
                    JOB_STATUS = :CRASTQUSTS_N.JOB_STATUS,
                    JOB_END_FLAG = :CRASTQUSTS_N.JOB_END_FLAG,
                    JOB_END_TIME = :CRASTQUSTS_N.JOB_END_TIME,
                    JOB_END_STATUS = :CRASTQUSTS_N.JOB_END_STATUS,
                    JOB_INTERVAL_SEC = :CRASTQUSTS_N.JOB_INTERVAL_SEC,
                    MOVE_INTERVAL_SEC = :CRASTQUSTS_N.MOVE_INTERVAL_SEC
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;

        case 7:
            EXEC SQL UPDATE CRASTQUSTS SET
                    JOB_STATUS = :CRASTQUSTS_N.JOB_STATUS,
                    JOB_END_FLAG = :CRASTQUSTS_N.JOB_END_FLAG,
                    JOB_ABNORMAL_FLAG = :CRASTQUSTS_N.JOB_ABNORMAL_FLAG,
                    JOB_TERM_TIME = :CRASTQUSTS_N.JOB_TERM_TIME,
                    JOB_TERM_STATUS = :CRASTQUSTS_N.JOB_TERM_STATUS,
                    ERROR_CODE = :CRASTQUSTS_N.ERROR_CODE,
                    ERROR_MSG = :CRASTQUSTS_N.ERROR_MSG,
                    UPDATE_USER_ID = :CRASTQUSTS_N.UPDATE_USER_ID,
                    UPDATE_TIME = :CRASTQUSTS_N.UPDATE_TIME
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;

        case 8:
            EXEC SQL UPDATE CRASTQUSTS SET
                    JOB_STATUS = :CRASTQUSTS_N.JOB_STATUS,
                    JOB_ALTER_FLAG = :CRASTQUSTS_N.JOB_ALTER_FLAG,
                    JOB_ALTER_TIME = :CRASTQUSTS_N.JOB_ALTER_TIME,
                    JOB_ALTER_STATUS = :CRASTQUSTS_N.JOB_ALTER_STATUS
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;

        case 9:
            EXEC SQL UPDATE CRASTQUSTS SET
                    JOB_STATUS = :CRASTQUSTS_N.JOB_STATUS,
                    JOB_CANCEL_FLAG = :CRASTQUSTS_N.JOB_CANCEL_FLAG,
                    JOB_CANCEL_TIME = :CRASTQUSTS_N.JOB_CANCEL_TIME,
                    JOB_CANCEL_USER_ID = :CRASTQUSTS_N.JOB_CANCEL_USER_ID,
                    ERROR_CODE = :CRASTQUSTS_N.ERROR_CODE,
                    ERROR_MSG = :CRASTQUSTS_N.ERROR_MSG,
                    UPDATE_USER_ID = :CRASTQUSTS_N.UPDATE_USER_ID,
                    UPDATE_TIME = :CRASTQUSTS_N.UPDATE_TIME
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;

        case 10:
            EXEC SQL UPDATE CRASTQUSTS SET
                    JOB_STATUS = :CRASTQUSTS_N.JOB_STATUS,
                    JOB_PAUSE_FLAG = :CRASTQUSTS_N.JOB_PAUSE_FLAG,
                    JOB_PAUSE_TIME = :CRASTQUSTS_N.JOB_PAUSE_TIME,
                    JOB_PAUSE_USER_ID = :CRASTQUSTS_N.JOB_PAUSE_USER_ID
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;

        case 11:
            EXEC SQL UPDATE CRASTQUSTS SET
                    JOB_STATUS = :CRASTQUSTS_N.JOB_STATUS,
                    JOB_PAUSE_FLAG = ' ',
                    JOB_RESUME_FLAG = :CRASTQUSTS_N.JOB_RESUME_FLAG,
                    JOB_RESUME_TIME = :CRASTQUSTS_N.JOB_RESUME_TIME,
                    JOB_RESUME_USER_ID = :CRASTQUSTS_N.JOB_RESUME_USER_ID,
                    ERROR_CODE = :CRASTQUSTS_N.ERROR_CODE,
                    ERROR_MSG = :CRASTQUSTS_N.ERROR_MSG,
                    UPDATE_TIME = :CRASTQUSTS_N.UPDATE_TIME,
                    UPDATE_USER_ID = :CRASTQUSTS_N.UPDATE_USER_ID
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;

        case 12:
            EXEC SQL UPDATE CRASTQUSTS SET
                    RESV_FLAG = 'Y',
                    ORDER_ID = :CRASTQUSTS_N.ORDER_ID,
                    UPDATE_USER_ID = :CRASTQUSTS_N.UPDATE_USER_ID,
                    UPDATE_TIME = :CRASTQUSTS_N.UPDATE_TIME
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;

        case 13:
            EXEC SQL UPDATE CRASTQUSTS SET
                    CRR_ID = :CRASTQUSTS_N.CRR_ID,
                    LOT_ID = :CRASTQUSTS_N.LOT_ID,
                    MAT_ID = :CRASTQUSTS_N.MAT_ID,
                    FROM_RES_ID = :CRASTQUSTS_N.FROM_RES_ID,
                    FROM_PORT_ID = :CRASTQUSTS_N.FROM_PORT_ID,
                    TO_PORT_ID = :CRASTQUSTS_N.TO_PORT_ID,
                    CUR_RES_ID = :CRASTQUSTS_N.CUR_RES_ID,
                    CUR_PORT_ID = :CRASTQUSTS_N.CUR_PORT_ID,
                    CUR_ZONE_ID = :CRASTQUSTS_N.CUR_ZONE_ID,
                    QUEUE_CMF_5 = :CRASTQUSTS_N.QUEUE_CMF_5,
                    UPDATE_USER_ID = :CRASTQUSTS_N.UPDATE_USER_ID,
                    UPDATE_TIME = :CRASTQUSTS_N.UPDATE_TIME
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;

        case 14:
            EXEC SQL UPDATE CRASTQUSTS SET
                    QUEUE_CMF_4 = :CRASTQUSTS_N.QUEUE_CMF_4
                WHERE JOB_ID = :CRASTQUSTS_N.JOB_ID;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_crastqusts", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_crastqusts(int sel_type, struct CRASTQUSTS_TAG *CRASTQUSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASTQUSTS_N_TAG CRASTQUSTS_N;
        char   sql[10000];
        char   ts[1000];
        int    isize;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_crastqusts(&CRASTQUSTS_N, CRASTQUSTS);
    DB_error_code = 0;
    isize = 0;
    memset( sql, 0x00, sizeof(sql));
    memset( ts, 0x00, sizeof(ts));


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASTQUSTS_CUR_1 CURSOR FOR
                SELECT 
                    JOB_ID,
                    FACTORY,
                    REQ_SYSTEM,
                    REQ_USER_ID,
                    REQ_TIME,
                    REQ_LINE_CODE,
                    REQ_PORT_TYPE,
                    REQ_MAT_TYPE,
                    REQ_RES_ID,
                    REPR_RES_FLAG,
                    REQ_PORT_ID,
                    REQ_ZONE_ID,
                    REQ_TYPE,
                    RESV_FLAG,
                    FROM_RES_ID,
                    FROM_PORT_ID,
                    FROM_ZONE_ID,
                    TO_RES_ID,
                    TO_PORT_ID,
                    TO_ZONE_ID,
                    CUR_RES_ID,
                    CUR_PORT_ID,
                    CUR_ZONE_ID,
                    TRANS_PRIORITY,
                    JOB_SEND_TIME,
                    JOB_SEND_STATUS,
                    JOB_REPLY_TIME,
                    JOB_REPLY_STATUS,
                    JOB_CREATE_TIME,
                    JOB_CREATE_STATUS,
                    JOB_MOVE_START_TIME,
                    JOB_MOVE_STATUS,
                    JOB_CRR_LOC_TIME,
                    JOB_CRR_LOC_STATUS,
                    JOB_END_FLAG,
                    JOB_END_TIME,
                    JOB_END_STATUS,
                    JOB_ABNORMAL_FLAG,
                    JOB_TERM_FLAG,
                    JOB_TERM_TIME,
                    JOB_TERM_STATUS,
                    JOB_ALTER_FLAG,
                    JOB_ALTER_TIME,
                    JOB_ALTER_STATUS,
                    JOB_INTERVAL_SEC,
                    MOVE_INTERVAL_SEC,
                    CRR_TYPE,
                    CRR_ID,
                    JOB_STATUS,
                    EMPTY_CRR_FLAG,
                    LOT_ID,
                    ORDER_ID,
                    MAT_ID,
                    JOB_CANCEL_FLAG,
                    JOB_CANCEL_USER_ID,
                    JOB_CANCEL_TIME,
                    JOB_PAUSE_FLAG,
                    JOB_PAUSE_USER_ID,
                    JOB_PAUSE_TIME,
                    JOB_RESUME_FLAG,
                    JOB_RESUME_USER_ID,
                    JOB_RESUME_TIME,
                    QUEUE_CMF_1,
                    QUEUE_CMF_2,
                    QUEUE_CMF_3,
                    QUEUE_CMF_4,
                    QUEUE_CMF_5,
                    QUEUE_CMF_6,
                    QUEUE_CMF_7,
                    QUEUE_CMF_8,
                    QUEUE_CMF_9,
                    QUEUE_CMF_10,
                    QUEUE_CMF_11,
                    QUEUE_CMF_12,
                    QUEUE_CMF_13,
                    QUEUE_CMF_14,
                    QUEUE_CMF_15,
                    QUEUE_CMF_16,
                    QUEUE_CMF_17,
                    QUEUE_CMF_18,
                    QUEUE_CMF_19,
                    QUEUE_CMF_20,
                    ERROR_SYSTEM,
                    ERROR_CODE,
                    ERROR_MSG,
                    DELETE_FLAG,
                    DELETE_USER_ID,
                    DELETE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CRASTQUSTS
                ORDER BY JOB_ID ASC;
            EXEC SQL OPEN CDB_CRASTQUSTS_CUR_1;
            break;

        case 2:
      
			sprintf(sql , "SELECT            "); 
            sprintf(sql + strlen(sql), "JOB_ID,  ");
            sprintf(sql + strlen(sql), "FACTORY,  ");
            sprintf(sql + strlen(sql), "REQ_SYSTEM,  ");
            sprintf(sql + strlen(sql), "REQ_USER_ID,  ");
            sprintf(sql + strlen(sql), "REQ_TIME,  ");
            sprintf(sql + strlen(sql), "REQ_LINE_CODE,  ");
            sprintf(sql + strlen(sql), "REQ_PORT_TYPE,  ");
            sprintf(sql + strlen(sql), "REQ_MAT_TYPE,  ");
            sprintf(sql + strlen(sql), "REQ_RES_ID,  ");
            sprintf(sql + strlen(sql), "REPR_RES_FLAG,  ");
