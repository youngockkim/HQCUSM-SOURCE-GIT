            sprintf(sql + strlen(sql), "JOB_REPLY_STATUS,  ");
            sprintf(sql + strlen(sql), "JOB_CREATE_TIME,  ");
            sprintf(sql + strlen(sql), "JOB_CREATE_STATUS,  ");
            sprintf(sql + strlen(sql), "JOB_MOVE_START_TIME,  ");
            sprintf(sql + strlen(sql), "JOB_MOVE_STATUS,  ");
            sprintf(sql + strlen(sql), "JOB_CRR_LOC_TIME,  ");
            sprintf(sql + strlen(sql), "JOB_CRR_LOC_STATUS,  ");
