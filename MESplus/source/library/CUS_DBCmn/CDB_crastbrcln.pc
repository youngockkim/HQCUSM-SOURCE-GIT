/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_crastbrcln(int sel_type, struct CRASTBRCLN_TAG *CRASTBRCLN)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASTBRCLN_N_TAG CRASTBRCLN_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_crastbrcln(&CRASTBRCLN_N, CRASTBRCLN);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASTBRCLN_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LINE_ID,
                    WORK_SHIFT,
                    RES_ID,
                    CLNG_DATE,
                    CLNG_TIME,
                    CLNG_TYPE,
                    RQST_DPMT,
                    CLNG_PLAN,
                    CLNG_CMMT,
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' '),
                    NVL(CMF_6, ' '),
                    NVL(CMF_7, ' '),
                    NVL(CMF_8, ' '),
                    NVL(CMF_9, ' '),
                    NVL(CMF_10, ' '),
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CRASTBRCLN
				WHERE FACTORY = :CRASTBRCLN_N.FACTORY
				AND   LINE_ID = :CRASTBRCLN_N.LINE_ID
				AND   CLNG_DATE = :CRASTBRCLN_N.CLNG_DATE
                ORDER BY FACTORY ASC,
                    LINE_ID ASC,
                    WORK_SHIFT ASC,
                    RES_ID ASC,
                    CLNG_DATE ASC,
                    CLNG_TIME ASC;
            EXEC SQL OPEN CDB_CRASTBRCLN_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_crastbrcln", sel_type);
}


