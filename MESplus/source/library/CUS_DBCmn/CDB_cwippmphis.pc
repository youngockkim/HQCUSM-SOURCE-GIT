                    NVL(DEFECT_POSITION, ' '),
                    NVL(OPERATOR, ' '),
                    NVL(MACHINE_ISSUE_TYPE, ' '),
                    NVL(MACHINE_TECHNICIAN, ' '),
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' '),
                    NVL(CREATE_USER_ID, ' '),
                    NVL(CREATE_TIME, ' '),
                    NVL(UPDATE_USER_ID, ' '),
                    NVL(UPDATE_TIME, ' ')
                FROM CWIPPMPHIS
				WHERE FACTORY = :CWIPPMPHIS_N.FACTORY
				AND INS_TIME BETWEEN TO_CHAR(TO_DATE(:CWIPPMPHIS_N.WORK_DATE,'YYYYMMDD')  ,'YYYYMMDD') || '060000' 
				                 AND TO_CHAR(TO_DATE(:CWIPPMPHIS_N.WORK_DATE,'YYYYMMDD')+1,'YYYYMMDD') || '055959'
				AND LINE_ID LIKE :CWIPPMPHIS_N.LINE_ID
				AND DEFECT_POSITION LIKE :CWIPPMPHIS_N.DEFECT_POSITION
				AND RES_ID LIKE :CWIPPMPHIS_N.RES_ID
				AND WORK_SHIFT LIKE :CWIPPMPHIS_N.WORK_SHIFT
				AND MACHINE_ISSUE_TYPE LIKE :CWIPPMPHIS_N.MACHINE_ISSUE_TYPE
				AND CMF_1 LIKE :CWIPPMPHIS_N.CMF_1		//IS-20-09-118 IS-20-09-118 	
				AND UPDATE_TIME = ' '
				ORDER BY INS_TIME DESC;
            EXEC SQL OPEN CDB_CWIPPMPHIS_CUR_3;
            break;

		case 4:
            EXEC SQL DECLARE CDB_CWIPPMPHIS_CUR_4 CURSOR FOR
                  SELECT 
                    FACTORY, 
                    LOT_ID, 
                    INS_CNT, 
                    NVL(LINE_ID, ' '),
                    NVL(RES_ID, ' '),
                    NVL(INS_TIME, ' '),
                    NVL(WORK_DATE, ' '),
                    NVL(WORK_TIME, ' '),
                    NVL(WORK_SHIFT, ' '),
                    NVL(PMPP, ' '),
                    NVL(DIODE, ' '),
                    NVL(DEFECT_POSITION, ' '),
                    NVL(OPERATOR, ' '),
                    NVL(MACHINE_ISSUE_TYPE, ' '),
                    NVL(MACHINE_TECHNICIAN, ' '),
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' '),
                    NVL(CREATE_USER_ID, ' '),
                    NVL(CREATE_TIME, ' '),
                    NVL(UPDATE_USER_ID, ' '),
                    NVL(UPDATE_TIME, ' ')
                FROM CWIPPMPHIS
				WHERE FACTORY = :CWIPPMPHIS_N.FACTORY
				AND INS_TIME BETWEEN TO_CHAR(TO_DATE(:CWIPPMPHIS_N.WORK_DATE,'YYYYMMDD')  ,'YYYYMMDD') || '060000' 
								 AND TO_CHAR(TO_DATE(:CWIPPMPHIS_N.WORK_DATE,'YYYYMMDD')+1,'YYYYMMDD') || '055959'
				AND LINE_ID LIKE :CWIPPMPHIS_N.LINE_ID
				AND DEFECT_POSITION LIKE :CWIPPMPHIS_N.DEFECT_POSITION
				AND RES_ID LIKE :CWIPPMPHIS_N.RES_ID
				AND WORK_SHIFT LIKE :CWIPPMPHIS_N.WORK_SHIFT
				AND MACHINE_ISSUE_TYPE LIKE :CWIPPMPHIS_N.MACHINE_ISSUE_TYPE
				AND CMF_1 LIKE :CWIPPMPHIS_N.CMF_1		//IS-20-09-118 IS-20-09-118 	
				AND UPDATE_TIME != ' '
				ORDER BY INS_TIME DESC;
            EXEC SQL OPEN CDB_CWIPPMPHIS_CUR_4; 
            break;

		case 5:
            EXEC SQL DECLARE CDB_CWIPPMPHIS_CUR_5 CURSOR FOR
                  SELECT 
                    FACTORY, 
                    LOT_ID, 
                    INS_CNT, 
                    NVL(LINE_ID, ' '),
                    NVL(RES_ID, ' '),
                    NVL(INS_TIME, ' '),
                    NVL(WORK_DATE, ' '),
                    NVL(WORK_TIME, ' '),
                    NVL(WORK_SHIFT, ' '),
                    NVL(PMPP, ' '),
                    NVL(DIODE, ' '),
                    NVL(DEFECT_POSITION, ' '),
                    NVL(OPERATOR, ' '),
                    NVL(MACHINE_ISSUE_TYPE, ' '),
                    NVL(MACHINE_TECHNICIAN, ' '),
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' '),
                    NVL(CREATE_USER_ID, ' '),
                    NVL(CREATE_TIME, ' '),
                    NVL(UPDATE_USER_ID, ' '),
                    NVL(UPDATE_TIME, ' ')
			   FROM CWIPPMPHIS WHERE LOT_ID IN 
				  (SELECT LOT_ID 
				  FROM CWIPPMPHIS 
				  WHERE FACTORY LIKE :CWIPPMPHIS_N.FACTORY
				  AND LOT_ID LIKE :CWIPPMPHIS_N.LOT_ID
				  AND INS_TIME BETWEEN TO_CHAR(TO_DATE(:CWIPPMPHIS_N.WORK_DATE,'YYYYMMDD')  ,'YYYYMMDD') || '060000' 
						  AND TO_CHAR(TO_DATE(:CWIPPMPHIS_N.WORK_DATE,'YYYYMMDD')+1,'YYYYMMDD') || '055959'
				  AND LINE_ID LIKE :CWIPPMPHIS_N.LINE_ID
				  AND DEFECT_POSITION LIKE :CWIPPMPHIS_N.DEFECT_POSITION
				  AND RES_ID LIKE :CWIPPMPHIS_N.RES_ID
				  AND WORK_SHIFT LIKE :CWIPPMPHIS_N.WORK_SHIFT
				  AND MACHINE_ISSUE_TYPE LIKE :CWIPPMPHIS_N.MACHINE_ISSUE_TYPE
				  AND CMF_1 LIKE :CWIPPMPHIS_N.CMF_1)
				AND DEFECT_POSITION = ' '
				ORDER BY INS_TIME DESC;
            EXEC SQL OPEN CDB_CWIPPMPHIS_CUR_5; 
            break;

		case 6:
            EXEC SQL DECLARE CDB_CWIPPMPHIS_CUR_6 CURSOR FOR
                  SELECT 
                    FACTORY, 
                    LOT_ID, 
                    INS_CNT, 
