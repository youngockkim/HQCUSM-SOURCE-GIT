/* SQL CURSOR CLOSE Function */
void CDB_close_cwippmphis(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CWIPPMPHIS_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CWIPPMPHIS_CUR_2;
            break;

		case 3:
            EXEC SQL CLOSE CDB_CWIPPMPHIS_CUR_3;
            break;

		case 4:
            EXEC SQL CLOSE CDB_CWIPPMPHIS_CUR_4;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwippmphis", sel_type);
}


/* Initialize Function */
void CDB_init_cwippmphis(struct CWIPPMPHIS_TAG *CWIPPMPHIS)
{
    /* memset by Space */
    memset(CWIPPMPHIS, ' ', sizeof(struct CWIPPMPHIS_TAG));
    
    CWIPPMPHIS->INS_CNT = 0;
}


/* Add Null Function */
void CDB_add_null_cwippmphis(struct CWIPPMPHIS_N_TAG *CWIPPMPHIS_N, struct CWIPPMPHIS_TAG *CWIPPMPHIS)
{
    /* memset by NULL */
    memset(CWIPPMPHIS_N, '\0', sizeof(struct CWIPPMPHIS_N_TAG));
    
    MEMCPY_AN(CWIPPMPHIS_N->FACTORY, CWIPPMPHIS->FACTORY, sizeof(CWIPPMPHIS->FACTORY));
    MEMCPY_AN(CWIPPMPHIS_N->LOT_ID, CWIPPMPHIS->LOT_ID, sizeof(CWIPPMPHIS->LOT_ID));
    CWIPPMPHIS_N->INS_CNT = CWIPPMPHIS->INS_CNT;
    MEMCPY_AN(CWIPPMPHIS_N->LINE_ID, CWIPPMPHIS->LINE_ID, sizeof(CWIPPMPHIS->LINE_ID));
    MEMCPY_AN(CWIPPMPHIS_N->RES_ID, CWIPPMPHIS->RES_ID, sizeof(CWIPPMPHIS->RES_ID));
    MEMCPY_AN(CWIPPMPHIS_N->INS_TIME, CWIPPMPHIS->INS_TIME, sizeof(CWIPPMPHIS->INS_TIME));
    MEMCPY_AN(CWIPPMPHIS_N->WORK_DATE, CWIPPMPHIS->WORK_DATE, sizeof(CWIPPMPHIS->WORK_DATE));
    MEMCPY_AN(CWIPPMPHIS_N->WORK_TIME, CWIPPMPHIS->WORK_TIME, sizeof(CWIPPMPHIS->WORK_TIME));
    MEMCPY_AN(CWIPPMPHIS_N->WORK_SHIFT, CWIPPMPHIS->WORK_SHIFT, sizeof(CWIPPMPHIS->WORK_SHIFT));
    MEMCPY_AN(CWIPPMPHIS_N->PMPP, CWIPPMPHIS->PMPP, sizeof(CWIPPMPHIS->PMPP));
    MEMCPY_AN(CWIPPMPHIS_N->DIODE, CWIPPMPHIS->DIODE, sizeof(CWIPPMPHIS->DIODE));
