/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwippmphis(int sel_type, struct CWIPPMPHIS_TAG *CWIPPMPHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPPMPHIS_N_TAG CWIPPMPHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwippmphis(&CWIPPMPHIS_N, CWIPPMPHIS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPPMPHIS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOT_ID,
                    INS_CNT,
                    NVL(LINE_ID, ' '),
                    NVL(RES_ID, ' '),
                    NVL(INS_TIME, ' '),
                    NVL(WORK_DATE, ' '),
                    NVL(WORK_TIME, ' '),
                    NVL(WORK_SHIFT, ' '),
                    NVL(PMPP, ' '),
                    NVL(DIODE, ' '),
                    NVL(DEFECT_POSITION, ' '),
                    NVL(OPERATOR, ' '),
                    NVL(MACHINE_ISSUE_TYPE, ' '),
                    NVL(MACHINE_TECHNICIAN, ' '),
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' '),
                    NVL(CREATE_USER_ID, ' '),
                    NVL(CREATE_TIME, ' '),
                    NVL(UPDATE_USER_ID, ' '),
                    NVL(UPDATE_TIME, ' ')
                FROM CWIPPMPHIS
				WHERE FACTORY = :CWIPPMPHIS_N.FACTORY
				AND WORK_DATE = :CWIPPMPHIS_N.WORK_DATE
				AND LINE_ID LIKE :CWIPPMPHIS_N.LINE_ID
				AND DEFECT_POSITION LIKE :CWIPPMPHIS_N.DEFECT_POSITION
				AND RES_ID LIKE :CWIPPMPHIS_N.RES_ID
				AND WORK_SHIFT LIKE :CWIPPMPHIS_N.WORK_SHIFT
				AND MACHINE_ISSUE_TYPE LIKE :CWIPPMPHIS_N.MACHINE_ISSUE_TYPE
				AND UPDATE_TIME = ' '
				ORDER BY INS_TIME DESC;
            EXEC SQL OPEN CDB_CWIPPMPHIS_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CWIPPMPHIS_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY, 
                    LOT_ID, 
                    INS_CNT, 
                    NVL(LINE_ID, ' '),
                    NVL(RES_ID, ' '),
                    NVL(INS_TIME, ' '),
                    NVL(WORK_DATE, ' '),
                    NVL(WORK_TIME, ' '),
                    NVL(WORK_SHIFT, ' '),
