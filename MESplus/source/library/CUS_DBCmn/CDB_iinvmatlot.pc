    MEMCPY_AN(IINVMATLOT_N->CMF_4, IINVMATLOT->CMF_4, sizeof(IINVMATLOT->CMF_4));
    MEMCPY_AN(IINVMATLOT_N->CMF_5, IINVMATLOT->CMF_5, sizeof(IINVMATLOT->CMF_5));
    IINVMATLOT_N->DATA_FLAG[0] = IINVMATLOT->DATA_FLAG;
