            EXEC SQL FETCH CDB_IINVMATLOT_CUR_1 INTO
                :IINVMATLOT_N.DOC_ID,
                :IINVMATLOT_N.VENDOR_BARCD,
                :IINVMATLOT_N.ACTION_TYPE,
                :IINVMATLOT_N.VENDOR_CREDITOR,
                :IINVMATLOT_N.VENDOR_NAME,
                :IINVMATLOT_N.SITE_ID,
                :IINVMATLOT_N.STORAGE_LOCATION,
                :IINVMATLOT_N.BATCH_NO,
                :IINVMATLOT_N.MATE_NO,
                :IINVMATLOT_N.MATE_DESC,
                :IINVMATLOT_N.ORI_QTY,
                :IINVMATLOT_N.UNIT_ID,
                :IINVMATLOT_N.VENDOR_LOTID,
                :IINVMATLOT_N.INF_TIME,
                :IINVMATLOT_N.INF_PROC_TIME,
                :IINVMATLOT_N.CMF_1,
                :IINVMATLOT_N.CMF_2,
                :IINVMATLOT_N.CMF_3,
                :IINVMATLOT_N.CMF_4,
                :IINVMATLOT_N.CMF_5,
                :IINVMATLOT_N.DATA_FLAG,
                :IINVMATLOT_N.UPDATE_COUNT,
                :IINVMATLOT_N.INSERT_COUNT,
                :IINVMATLOT_N.DELETE_COUNT,
                :IINVMATLOT_N.SQL_DML_COUNT,
                :IINVMATLOT_N.ZPICODE,
                :IINVMATLOT_N.ZPIMSGID,
                :IINVMATLOT_N.RETURN_TYPE,
                :IINVMATLOT_N.RETURN_MSG,
                :IINVMATLOT_N.ZIFERNAM,
                :IINVMATLOT_N.ZIFDATE,
                :IINVMATLOT_N.ZIFTIME,
                :IINVMATLOT_N.ZPISTAT,
                :IINVMATLOT_N.ZPIMSG;
            break;

		case 2:
            EXEC SQL FETCH CDB_IINVMATLOT_CUR_2 INTO
                :IINVMATLOT_N.DOC_ID,
                :IINVMATLOT_N.VENDOR_BARCD,
                :IINVMATLOT_N.ACTION_TYPE,
                :IINVMATLOT_N.VENDOR_CREDITOR,
                :IINVMATLOT_N.VENDOR_NAME,
                :IINVMATLOT_N.SITE_ID,
                :IINVMATLOT_N.STORAGE_LOCATION,
                :IINVMATLOT_N.BATCH_NO,
                :IINVMATLOT_N.MATE_NO,
                :IINVMATLOT_N.MATE_DESC,
                :IINVMATLOT_N.ORI_QTY,
                :IINVMATLOT_N.UNIT_ID,
                :IINVMATLOT_N.VENDOR_LOTID,
                :IINVMATLOT_N.INF_TIME,
                :IINVMATLOT_N.INF_PROC_TIME,
                :IINVMATLOT_N.CMF_1,
                :IINVMATLOT_N.CMF_2,
                :IINVMATLOT_N.CMF_3,
                :IINVMATLOT_N.CMF_4,
                :IINVMATLOT_N.CMF_5,
                :IINVMATLOT_N.DATA_FLAG,
                :IINVMATLOT_N.UPDATE_COUNT,
                :IINVMATLOT_N.INSERT_COUNT,
                :IINVMATLOT_N.DELETE_COUNT,
                :IINVMATLOT_N.SQL_DML_COUNT,
                :IINVMATLOT_N.ZPICODE,
                :IINVMATLOT_N.ZPIMSGID,
                :IINVMATLOT_N.RETURN_TYPE,
                :IINVMATLOT_N.RETURN_MSG,
                :IINVMATLOT_N.ZIFERNAM,
                :IINVMATLOT_N.ZIFDATE,
                :IINVMATLOT_N.ZIFTIME,
                :IINVMATLOT_N.ZPISTAT,
                :IINVMATLOT_N.ZPIMSG;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_iinvmatlot(&IINVMATLOT_N, IINVMATLOT);
    }

    DB_stop_query_timer("CDB_fetch_iinvmatlot", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_iinvmatlot(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IINVMATLOT_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IINVMATLOT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_iinvmatlot", sel_type);
}


/* Initialize Function */
void CDB_init_iinvmatlot(struct IINVMATLOT_TAG *IINVMATLOT)
{
    /* memset by Space */
    memset(IINVMATLOT, ' ', sizeof(struct IINVMATLOT_TAG));
    
}


/* Add Null Function */
void CDB_add_null_iinvmatlot(struct IINVMATLOT_N_TAG *IINVMATLOT_N, struct IINVMATLOT_TAG *IINVMATLOT)
{
    /* memset by NULL */
    memset(IINVMATLOT_N, '\0', sizeof(struct IINVMATLOT_N_TAG));
    
    MEMCPY_AN(IINVMATLOT_N->DOC_ID, IINVMATLOT->DOC_ID, sizeof(IINVMATLOT->DOC_ID));
    MEMCPY_AN(IINVMATLOT_N->VENDOR_BARCD, IINVMATLOT->VENDOR_BARCD, sizeof(IINVMATLOT->VENDOR_BARCD));
