/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_iinvmatlot(int sel_type, struct IINVMATLOT_TAG *IINVMATLOT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IINVMATLOT_N_TAG IINVMATLOT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_iinvmatlot(&IINVMATLOT_N, IINVMATLOT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IINVMATLOT_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    VENDOR_BARCD,
                    ACTION_TYPE,
                    VENDOR_CREDITOR,
                    VENDOR_NAME,
                    SITE_ID,
                    STORAGE_LOCATION,
                    BATCH_NO,
                    MATE_NO,
                    MATE_DESC,
                    ORI_QTY,
                    UNIT_ID,
                    VENDOR_LOTID,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IINVMATLOT
                ORDER BY DOC_ID ASC,
                    VENDOR_BARCD ASC,
                    ACTION_TYPE ASC;
            EXEC SQL OPEN CDB_IINVMATLOT_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_IINVMATLOT_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    VENDOR_BARCD,
                    ACTION_TYPE,
                    VENDOR_CREDITOR,
                    VENDOR_NAME,
                    SITE_ID,
                    STORAGE_LOCATION,
                    BATCH_NO,
                    MATE_NO,
                    MATE_DESC,
                    ORI_QTY,
                    UNIT_ID,
                    VENDOR_LOTID,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IINVMATLOT
				WHERE RETURN_TYPE <> 'E'
                ORDER BY DOC_ID ASC,
                    VENDOR_BARCD ASC,
                    ACTION_TYPE ASC;
            EXEC SQL OPEN CDB_IINVMATLOT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_iinvmatlot", sel_type);
}


