    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_IQCMSAMDAT_CUR_1 INTO
                :IQCMSAMDAT_N.DOC_ID,
                :IQCMSAMDAT_N.SITE_ID,
                :IQCMSAMDAT_N.Z_GROUP,
                :IQCMSAMDAT_N.MODULE_ID,
                :IQCMSAMDAT_N.ACTION_TYPE,
                :IQCMSAMDAT_N.PROD_ORDER_NO,
                :IQCMSAMDAT_N.MATE_NO,
                :IQCMSAMDAT_N.QC_INSPECTION,
                :IQCMSAMDAT_N.STORAGE_LOCATION,
                :IQCMSAMDAT_N.LOCATION,
                :IQCMSAMDAT_N.SHIFT,
                :IQCMSAMDAT_N.QUALITY_GRADE,
                :IQCMSAMDAT_N.POWER_GRADE,
                :IQCMSAMDAT_N.FQC_DEFECTCODE,
                :IQCMSAMDAT_N.CMF_1,
                :IQCMSAMDAT_N.CMF_2,
                :IQCMSAMDAT_N.CMF_3,
                :IQCMSAMDAT_N.CMF_4,
                :IQCMSAMDAT_N.CMF_5,
                :IQCMSAMDAT_N.DATA_FLAG,
                :IQCMSAMDAT_N.DOC_ID_R,
                :IQCMSAMDAT_N.SITE_ID_R,
                :IQCMSAMDAT_N.PROD_ORDER_NO_R,
                :IQCMSAMDAT_N.MODULE_ID_R,
                :IQCMSAMDAT_N.OPER_NO,
                :IQCMSAMDAT_N.WORK_CENTER,
                :IQCMSAMDAT_N.ACTION_TYPE_R,
                :IQCMSAMDAT_N.ERP_FLAG,
                :IQCMSAMDAT_N.ERP_MSG,
                :IQCMSAMDAT_N.ZPICODE,
                :IQCMSAMDAT_N.ZPIMSGID,
                :IQCMSAMDAT_N.ZIFERNAM,
                :IQCMSAMDAT_N.ZIFDATE,
                :IQCMSAMDAT_N.ZIFTIME,
                :IQCMSAMDAT_N.ZPISTAT,
                :IQCMSAMDAT_N.ZPIMSG,
                :IQCMSAMDAT_N.ZPIMSGID_R,
                :IQCMSAMDAT_N.ZIFERNAM_R;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_iqcmsamdat(&IQCMSAMDAT_N, IQCMSAMDAT);
    }

    DB_stop_query_timer("CDB_fetch_iqcmsamdat", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_iqcmsamdat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IQCMSAMDAT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_iqcmsamdat", sel_type);
}


