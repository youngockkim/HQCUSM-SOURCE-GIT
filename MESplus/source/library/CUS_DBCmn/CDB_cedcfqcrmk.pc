        case 1:
            EXEC SQL DECLARE CDB_CEDCFQCRMK_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    INS_CNT,
                    KEY_SEQ,
                    FACTORY,
                    LINE_ID,
                    OPER,
                    RES_ID,
                    LOT_HIST_SEQ,
                    REMARK_CATE_SEQ,
