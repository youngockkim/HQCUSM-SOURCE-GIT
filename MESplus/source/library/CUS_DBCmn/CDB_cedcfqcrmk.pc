                    CREATE_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM CEDCFQCRMK
                ORDER BY LOT_ID ASC,
                    INS_CNT ASC,
                    KEY_SEQ ASC;
            EXEC SQL OPEN CDB_CEDCFQCRMK_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
