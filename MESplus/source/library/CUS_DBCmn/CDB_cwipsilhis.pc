    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwipsilhis(&CWIPSILHIS_N, CWIPSILHIS);
    DB_error_code = 0;

    switch(sel_type)
    {
       
        case 1:
            EXEC SQL DECLARE CDB_CWIPSILHIS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
					NAME,
					LINE,
					SILICONE_TYPE,
					TABLE_NAME,
					SILICONE_SIDE,
					LEFT_WEIGHT,
					LEFT_WEIGHT_RESULT,
					CENTER_WEIGHT,
					CENTER_WEIGHT_RESULT,
					RIGHT_WEIGHT,
					RIGHT_WEIGHT_RESULT,
					POTTING_WEIGHT_A,
					POTTING_WEIGHT_B,
					POTTING_WEIGHT_RATIO,
					RATIO_WEIGHT_RESULT,
					CREATE_USER_ID,
					CREATE_TIME,
					COMMENT_CONT,
					FRAME_SHORT_WEIGHT,
					FRAME_SHORT_RESULT,
					FRAME_LONG_WEIGHT,
					FRAME_LONG_RESULT,
					FRAME_MODULE_TYPE
				FROM CWIPSILHIS
               	WHERE FACTORY = :CWIPSILHIS_N.FACTORY
				AND CREATE_TIME >= CONCAT(:CWIPSILHIS_N.CREATE_TIME, '000000') 
                AND CREATE_TIME <= CONCAT(:CWIPSILHIS_N.CREATE_TIME, '235959') 
				AND TABLE_NAME LIKE :CWIPSILHIS_N.TABLE_NAME 
				AND LINE LIKE :CWIPSILHIS_N.LINE 
				AND SILICONE_TYPE LIKE :CWIPSILHIS_N.SILICONE_TYPE 
				AND NAME LIKE :CWIPSILHIS_N.NAME
                ORDER BY CREATE_TIME DESC;
