/* SQL UPDATE Function */
void CDB_update_cedclotfqc(int sel_type, struct CEDCLOTFQC_TAG *CEDCLOTFQC)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CEDCLOTFQC_N_TAG CEDCLOTFQC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedclotfqc(&CEDCLOTFQC_N, CEDCLOTFQC);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE CEDCLOTFQC SET
                    CELL_INFO = :CEDCLOTFQC_N.CELL_INFO,
                    POS_X = :CEDCLOTFQC_N.POS_X,
                    POS_Y = :CEDCLOTFQC_N.POS_Y,
                    DEFECT_CODE = :CEDCLOTFQC_N.DEFECT_CODE,
                    REMARK = :CEDCLOTFQC_N.REMARK,
                    FACTORY = :CEDCLOTFQC_N.FACTORY,
                    LINE_ID = :CEDCLOTFQC_N.LINE_ID,
                    OPER = :CEDCLOTFQC_N.OPER,
                    LOT_HIST_SEQ = :CEDCLOTFQC_N.LOT_HIST_SEQ,
                    INS_TIME = :CEDCLOTFQC_N.INS_TIME,
                    INS_TYPE = :CEDCLOTFQC_N.INS_TYPE,
                    INS_CNT = :CEDCLOTFQC_N.INS_CNT,
                    INS_USER_ID = :CEDCLOTFQC_N.INS_USER_ID,
                    GRADE = :CEDCLOTFQC_N.GRADE,
                    POWER_GRADE = :CEDCLOTFQC_N.POWER_GRADE,
                    ARTICLE_NO = :CEDCLOTFQC_N.ARTICLE_NO,
                    FQC_JUDGE = :CEDCLOTFQC_N.FQC_JUDGE,
                    WORK_SHIFT = :CEDCLOTFQC_N.WORK_SHIFT,
                    TRACKING_REQUEST = :CEDCLOTFQC_N.TRACKING_REQUEST,
                    FQC_RESULT = :CEDCLOTFQC_N.FQC_RESULT,
                    AOI_RESULT = :CEDCLOTFQC_N.AOI_RESULT,
                    HVT_RESULT = :CEDCLOTFQC_N.HVT_RESULT,
                    BEL_RESULT = :CEDCLOTFQC_N.BEL_RESULT,
                    GRT_RESULT = :CEDCLOTFQC_N.GRT_RESULT,
                    SIM_RESULT = :CEDCLOTFQC_N.SIM_RESULT,
                    FLASH_PMAX = :CEDCLOTFQC_N.FLASH_PMAX,
                    FLASH_ISC = :CEDCLOTFQC_N.FLASH_ISC,
                    FLASH_VOC = :CEDCLOTFQC_N.FLASH_VOC,
                    FLASH_IMPP = :CEDCLOTFQC_N.FLASH_IMPP,
                    CURING_TIME = :CEDCLOTFQC_N.CURING_TIME,
                    PORT = :CEDCLOTFQC_N.PORT,
            --        CMF_1 = :CEDCLOTFQC_N.CMF_1,
                    CMF_2 = :CEDCLOTFQC_N.CMF_2,
                    CMF_3 = :CEDCLOTFQC_N.CMF_3,
                    CMF_4 = :CEDCLOTFQC_N.CMF_4,
                    CMF_5 = :CEDCLOTFQC_N.CMF_5,
                    CMF_6 = :CEDCLOTFQC_N.CMF_6,
                    CMF_7 = :CEDCLOTFQC_N.CMF_7,
                    CMF_8 = :CEDCLOTFQC_N.CMF_8,
                    CMF_9 = :CEDCLOTFQC_N.CMF_9,
                    CMF_10 = :CEDCLOTFQC_N.CMF_10
                WHERE LOT_ID = :CEDCLOTFQC_N.LOT_ID
                    AND RES_ID = :CEDCLOTFQC_N.RES_ID
                    AND INS_SEQ = :CEDCLOTFQC_N.INS_SEQ
                    AND DEFECT_SEQ = :CEDCLOTFQC_N.DEFECT_SEQ;
            break;

		case 901:
            EXEC SQL INSERT INTO CEDCLOTFQC 
				SELECT
				  :CEDCLOTFQC_N.CMF_1,
                    RES_ID,
                    INS_SEQ,
                    DEFECT_SEQ,
                    CELL_INFO,
                    POS_X,
                    POS_Y,
                    DEFECT_CODE,
                    REMARK,
                    FACTORY,
                    LINE_ID,
                    OPER,
                    LOT_HIST_SEQ,
                    :CEDCLOTFQC_N.INS_TIME,
                    INS_TYPE,
                    INS_CNT,
                    INS_USER_ID,
                    GRADE,
                    POWER_GRADE,
                    ARTICLE_NO,
                    FQC_JUDGE,
                    WORK_SHIFT,
                    TRACKING_REQUEST,
                    FQC_RESULT,
                    AOI_RESULT,
                    HVT_RESULT,
                    BEL_RESULT,
                    GRT_RESULT,
                    SIM_RESULT,
                    FLASH_PMAX,
                    FLASH_ISC,
                    FLASH_VOC,
                    FLASH_IMPP,
                    CURING_TIME,
                    PORT,
                    :CEDCLOTFQC_N.INS_TIME,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10
				FROM CEDCLOTFQC
                WHERE LOT_ID = :CEDCLOTFQC_N.LOT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_cedclotfqc", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cedclotfqc(int sel_type, struct CEDCLOTFQC_TAG *CEDCLOTFQC)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CEDCLOTFQC_N_TAG CEDCLOTFQC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedclotfqc(&CEDCLOTFQC_N, CEDCLOTFQC);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CEDCLOTFQC_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    RES_ID,
                    INS_SEQ,
                    DEFECT_SEQ,
                    CELL_INFO,
                    POS_X,
                    POS_Y,
                    DEFECT_CODE,
                    REMARK,
                    FACTORY,
                    LINE_ID,
                    OPER,
                    LOT_HIST_SEQ,
                    INS_TIME,
                    INS_TYPE,
                    INS_CNT,
                    INS_USER_ID,
                    GRADE,
                    POWER_GRADE,
                    ARTICLE_NO,
                    FQC_JUDGE,
                    WORK_SHIFT,
                    TRACKING_REQUEST,
                    FQC_RESULT,
                    AOI_RESULT,
                    HVT_RESULT,
                    BEL_RESULT,
                    GRT_RESULT,
                    SIM_RESULT,
                    FLASH_PMAX,
                    FLASH_ISC,
                    FLASH_VOC,
                    FLASH_IMPP,
                    CURING_TIME,
                    PORT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10
                FROM CEDCLOTFQC
                ORDER BY LOT_ID ASC,
                    RES_ID ASC,
                    INS_SEQ ASC,
                    DEFECT_SEQ ASC;
            EXEC SQL OPEN CDB_CEDCLOTFQC_CUR_1;
            break;

		case 100:
            EXEC SQL DECLARE CDB_CEDCLOTFQC_CUR_100 CURSOR FOR
                SELECT 
                    LOT_ID,
                    RES_ID,
                    INS_SEQ,
                    DEFECT_SEQ,
                    CELL_INFO,
                    POS_X,
                    POS_Y,
                    DEFECT_CODE,
                    REMARK,
                    FACTORY,
                    LINE_ID,
                    OPER,
                    LOT_HIST_SEQ,
                    INS_TIME,
                    INS_TYPE,
                    INS_CNT,
                    INS_USER_ID,
                    GRADE,
                    POWER_GRADE,
                    ARTICLE_NO,
                    FQC_JUDGE,
                    WORK_SHIFT,
                    TRACKING_REQUEST,
                    FQC_RESULT,
                    AOI_RESULT,
                    HVT_RESULT,
                    BEL_RESULT,
                    GRT_RESULT,
                    SIM_RESULT,
                    FLASH_PMAX,
                    FLASH_ISC,
                    FLASH_VOC,
                    FLASH_IMPP,
                    CURING_TIME,
                    PORT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10
                FROM CEDCLOTFQC
				WHERE LOT_ID = :CEDCLOTFQC_N.LOT_ID
                    AND RES_ID = :CEDCLOTFQC_N.RES_ID
                    AND INS_CNT = :CEDCLOTFQC_N.INS_CNT
                ORDER BY LOT_ID ASC,
                    RES_ID ASC,
                    INS_SEQ ASC,
                    DEFECT_SEQ ASC;
            EXEC SQL OPEN CDB_CEDCLOTFQC_CUR_100;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cedclotfqc", sel_type);
}


