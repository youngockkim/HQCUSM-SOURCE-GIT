/* SQL SELECT_SCALAR Function */
double CDB_select_cedclotfqc_scalar(int sel_type, struct CEDCLOTFQC_TAG *CEDCLOTFQC)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CEDCLOTFQC_N_TAG CEDCLOTFQC_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedclotfqc(&CEDCLOTFQC_N, CEDCLOTFQC);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CEDCLOTFQC
                WHERE LOT_ID = :CEDCLOTFQC_N.LOT_ID
                    AND RES_ID = :CEDCLOTFQC_N.RES_ID
                    AND INS_SEQ = :CEDCLOTFQC_N.INS_SEQ
                    AND DEFECT_SEQ = :CEDCLOTFQC_N.DEFECT_SEQ;
            break;

        case 2:
            EXEC SQL SELECT NVL(MAX(INS_SEQ),0)
                INTO :d_value
                FROM CEDCLOTFQC
                WHERE LOT_ID = :CEDCLOTFQC_N.LOT_ID
                    AND RES_ID = :CEDCLOTFQC_N.RES_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_cedclotfqc_scalar", sel_type);

    return d_value;
}


