/* SQL CURSOR CLOSE Function */
void CDB_close_cedclotfqc(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CEDCLOTFQC_CUR_1;
            break;

		case 100:
            EXEC SQL CLOSE CDB_CEDCLOTFQC_CUR_100;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cedclotfqc", sel_type);
}


/* Initialize Function */
void CDB_init_cedclotfqc(struct CEDCLOTFQC_TAG *CEDCLOTFQC)
{
    /* memset by Space */
    memset(CEDCLOTFQC, ' ', sizeof(struct CEDCLOTFQC_TAG));
    
    CEDCLOTFQC->INS_SEQ = 0;
    CEDCLOTFQC->DEFECT_SEQ = 0;
    CEDCLOTFQC->LOT_HIST_SEQ = 0;
    CEDCLOTFQC->INS_CNT = 0;
}


/* Add Null Function */
void CDB_add_null_cedclotfqc(struct CEDCLOTFQC_N_TAG *CEDCLOTFQC_N, struct CEDCLOTFQC_TAG *CEDCLOTFQC)
{
    /* memset by NULL */
    memset(CEDCLOTFQC_N, '\0', sizeof(struct CEDCLOTFQC_N_TAG));
    
    MEMCPY_AN(CEDCLOTFQC_N->LOT_ID, CEDCLOTFQC->LOT_ID, sizeof(CEDCLOTFQC->LOT_ID));
    MEMCPY_AN(CEDCLOTFQC_N->RES_ID, CEDCLOTFQC->RES_ID, sizeof(CEDCLOTFQC->RES_ID));
    CEDCLOTFQC_N->INS_SEQ = CEDCLOTFQC->INS_SEQ;
    CEDCLOTFQC_N->DEFECT_SEQ = CEDCLOTFQC->DEFECT_SEQ;
    MEMCPY_AN(CEDCLOTFQC_N->CELL_INFO, CEDCLOTFQC->CELL_INFO, sizeof(CEDCLOTFQC->CELL_INFO));
    MEMCPY_AN(CEDCLOTFQC_N->POS_X, CEDCLOTFQC->POS_X, sizeof(CEDCLOTFQC->POS_X));
    MEMCPY_AN(CEDCLOTFQC_N->POS_Y, CEDCLOTFQC->POS_Y, sizeof(CEDCLOTFQC->POS_Y));
    MEMCPY_AN(CEDCLOTFQC_N->DEFECT_CODE, CEDCLOTFQC->DEFECT_CODE, sizeof(CEDCLOTFQC->DEFECT_CODE));
    MEMCPY_AN(CEDCLOTFQC_N->REMARK, CEDCLOTFQC->REMARK, sizeof(CEDCLOTFQC->REMARK));
    MEMCPY_AN(CEDCLOTFQC_N->FACTORY, CEDCLOTFQC->FACTORY, sizeof(CEDCLOTFQC->FACTORY));
    MEMCPY_AN(CEDCLOTFQC_N->LINE_ID, CEDCLOTFQC->LINE_ID, sizeof(CEDCLOTFQC->LINE_ID));
    MEMCPY_AN(CEDCLOTFQC_N->OPER, CEDCLOTFQC->OPER, sizeof(CEDCLOTFQC->OPER));
    CEDCLOTFQC_N->LOT_HIST_SEQ = CEDCLOTFQC->LOT_HIST_SEQ;
    MEMCPY_AN(CEDCLOTFQC_N->INS_TIME, CEDCLOTFQC->INS_TIME, sizeof(CEDCLOTFQC->INS_TIME));
    MEMCPY_AN(CEDCLOTFQC_N->INS_TYPE, CEDCLOTFQC->INS_TYPE, sizeof(CEDCLOTFQC->INS_TYPE));
    CEDCLOTFQC_N->INS_CNT = CEDCLOTFQC->INS_CNT;
    MEMCPY_AN(CEDCLOTFQC_N->INS_USER_ID, CEDCLOTFQC->INS_USER_ID, sizeof(CEDCLOTFQC->INS_USER_ID));
    MEMCPY_AN(CEDCLOTFQC_N->GRADE, CEDCLOTFQC->GRADE, sizeof(CEDCLOTFQC->GRADE));
    MEMCPY_AN(CEDCLOTFQC_N->POWER_GRADE, CEDCLOTFQC->POWER_GRADE, sizeof(CEDCLOTFQC->POWER_GRADE));
    MEMCPY_AN(CEDCLOTFQC_N->ARTICLE_NO, CEDCLOTFQC->ARTICLE_NO, sizeof(CEDCLOTFQC->ARTICLE_NO));
    MEMCPY_AN(CEDCLOTFQC_N->FQC_JUDGE, CEDCLOTFQC->FQC_JUDGE, sizeof(CEDCLOTFQC->FQC_JUDGE));
    MEMCPY_AN(CEDCLOTFQC_N->WORK_SHIFT, CEDCLOTFQC->WORK_SHIFT, sizeof(CEDCLOTFQC->WORK_SHIFT));
    MEMCPY_AN(CEDCLOTFQC_N->TRACKING_REQUEST, CEDCLOTFQC->TRACKING_REQUEST, sizeof(CEDCLOTFQC->TRACKING_REQUEST));
    MEMCPY_AN(CEDCLOTFQC_N->FQC_RESULT, CEDCLOTFQC->FQC_RESULT, sizeof(CEDCLOTFQC->FQC_RESULT));
    MEMCPY_AN(CEDCLOTFQC_N->AOI_RESULT, CEDCLOTFQC->AOI_RESULT, sizeof(CEDCLOTFQC->AOI_RESULT));
    MEMCPY_AN(CEDCLOTFQC_N->HVT_RESULT, CEDCLOTFQC->HVT_RESULT, sizeof(CEDCLOTFQC->HVT_RESULT));
    MEMCPY_AN(CEDCLOTFQC_N->BEL_RESULT, CEDCLOTFQC->BEL_RESULT, sizeof(CEDCLOTFQC->BEL_RESULT));
    MEMCPY_AN(CEDCLOTFQC_N->GRT_RESULT, CEDCLOTFQC->GRT_RESULT, sizeof(CEDCLOTFQC->GRT_RESULT));
    MEMCPY_AN(CEDCLOTFQC_N->SIM_RESULT, CEDCLOTFQC->SIM_RESULT, sizeof(CEDCLOTFQC->SIM_RESULT));
    MEMCPY_AN(CEDCLOTFQC_N->FLASH_PMAX, CEDCLOTFQC->FLASH_PMAX, sizeof(CEDCLOTFQC->FLASH_PMAX));
    MEMCPY_AN(CEDCLOTFQC_N->FLASH_ISC, CEDCLOTFQC->FLASH_ISC, sizeof(CEDCLOTFQC->FLASH_ISC));
    MEMCPY_AN(CEDCLOTFQC_N->FLASH_VOC, CEDCLOTFQC->FLASH_VOC, sizeof(CEDCLOTFQC->FLASH_VOC));
    MEMCPY_AN(CEDCLOTFQC_N->FLASH_IMPP, CEDCLOTFQC->FLASH_IMPP, sizeof(CEDCLOTFQC->FLASH_IMPP));
    MEMCPY_AN(CEDCLOTFQC_N->CURING_TIME, CEDCLOTFQC->CURING_TIME, sizeof(CEDCLOTFQC->CURING_TIME));
