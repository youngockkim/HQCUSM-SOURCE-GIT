/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_crasresmah(int sel_type, struct CRASRESMAH_TAG *CRASRESMAH)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASRESMAH_N_TAG CRASRESMAH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_crasresmah(&CRASRESMAH_N, CRASRESMAH);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASRESMAH_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SEQ,
                    POSITION_ID,
                    INV_BARCODE_ID,
                    INV_MAT_ID,
                    INV_LOT_ID,
                    INV_LOT_DESC,
                    MAT_ID,
                    FLOW,
                    OPER,
                    MATERIALS_KINDS,
                    ATTACH_QTY,
                    USED_QTY,
                    REMAIN_QTY,
                    UNIT,
                    DEFAULT_USE_QTY,
                    ATTACH_TIME,
                    ATTACH_USER_ID,
                    INPUT_QTY,
                    TOTAL_USED_QTY,
                    ETC_QTY,
                    MAX_USE_QTY,
                    USE_BATCH_ID,
                    USE_TYPE,
                    MAX_USE_TIME,
                    ORDER_ID,
                    LAST_ACTION,
                    DETACH_TIME,
                    DETACH_USER_ID,
                    LAST_HIST_SEQ,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM CRASRESMAH
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SEQ ASC,
                    LAST_HIST_SEQ ASC;
            EXEC SQL OPEN CDB_CRASRESMAH_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_crasresmah", sel_type);
}


