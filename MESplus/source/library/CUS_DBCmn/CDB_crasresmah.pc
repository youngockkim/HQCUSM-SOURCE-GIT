    CRASRESMAH->DEFAULT_USE_QTY = CRASRESMAH_N->DEFAULT_USE_QTY;
    MEMCPY_DN(CRASRESMAH->ATTACH_TIME, CRASRESMAH_N->ATTACH_TIME, sizeof(CRASRESMAH->ATTACH_TIME));
    MEMCPY_DN(CRASRESMAH->ATTACH_USER_ID, CRASRESMAH_N->ATTACH_USER_ID, sizeof(CRASRESMAH->ATTACH_USER_ID));
    CRASRESMAH->INPUT_QTY = CRASRESMAH_N->INPUT_QTY;
    CRASRESMAH->TOTAL_USED_QTY = CRASRESMAH_N->TOTAL_USED_QTY;
    CRASRESMAH->ETC_QTY = CRASRESMAH_N->ETC_QTY;
    CRASRESMAH->MAX_USE_QTY = CRASRESMAH_N->MAX_USE_QTY;
    MEMCPY_DN(CRASRESMAH->USE_BATCH_ID, CRASRESMAH_N->USE_BATCH_ID, sizeof(CRASRESMAH->USE_BATCH_ID));
    MEMCPY_DN(CRASRESMAH->USE_TYPE, CRASRESMAH_N->USE_TYPE, sizeof(CRASRESMAH->USE_TYPE));
    MEMCPY_DN(CRASRESMAH->MAX_USE_TIME, CRASRESMAH_N->MAX_USE_TIME, sizeof(CRASRESMAH->MAX_USE_TIME));
    MEMCPY_DN(CRASRESMAH->ORDER_ID, CRASRESMAH_N->ORDER_ID, sizeof(CRASRESMAH->ORDER_ID));
    MEMCPY_DN(CRASRESMAH->LAST_ACTION, CRASRESMAH_N->LAST_ACTION, sizeof(CRASRESMAH->LAST_ACTION));
    MEMCPY_DN(CRASRESMAH->DETACH_TIME, CRASRESMAH_N->DETACH_TIME, sizeof(CRASRESMAH->DETACH_TIME));
    MEMCPY_DN(CRASRESMAH->DETACH_USER_ID, CRASRESMAH_N->DETACH_USER_ID, sizeof(CRASRESMAH->DETACH_USER_ID));
    CRASRESMAH->LAST_HIST_SEQ = CRASRESMAH_N->LAST_HIST_SEQ;
    MEMCPY_DN(CRASRESMAH->CMF_1, CRASRESMAH_N->CMF_1, sizeof(CRASRESMAH->CMF_1));
    MEMCPY_DN(CRASRESMAH->CMF_2, CRASRESMAH_N->CMF_2, sizeof(CRASRESMAH->CMF_2));
    MEMCPY_DN(CRASRESMAH->CMF_3, CRASRESMAH_N->CMF_3, sizeof(CRASRESMAH->CMF_3));
