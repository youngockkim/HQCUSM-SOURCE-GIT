    MEMCPY_DN(CRASRESMAH->MATERIALS_KINDS, CRASRESMAH_N->MATERIALS_KINDS, sizeof(CRASRESMAH->MATERIALS_KINDS));
    CRASRESMAH->ATTACH_QTY = CRASRESMAH_N->ATTACH_QTY;
    CRASRESMAH->USED_QTY = CRASRESMAH_N->USED_QTY;
    CRASRESMAH->REMAIN_QTY = CRASRESMAH_N->REMAIN_QTY;
