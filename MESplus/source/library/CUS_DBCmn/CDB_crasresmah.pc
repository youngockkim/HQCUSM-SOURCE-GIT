                :CRASRESMAH_N.INV_MAT_ID,
                :CRASRESMAH_N.INV_LOT_ID,
                :CRASRESMAH_N.INV_LOT_DESC,
                :CRASRESMAH_N.MAT_ID,
                :CRASRESMAH_N.FLOW,
                :CRASRESMAH_N.OPER,
                :CRASRESMAH_N.MATERIALS_KINDS,
                :CRASRESMAH_N.ATTACH_QTY,
                :CRASRESMAH_N.USED_QTY,
                :CRASRESMAH_N.REMAIN_QTY,
                :CRASRESMAH_N.UNIT,
                :CRASRESMAH_N.DEFAULT_USE_QTY,
                :CRASRESMAH_N.ATTACH_TIME,
                :CRASRESMAH_N.ATTACH_USER_ID,
                :CRASRESMAH_N.INPUT_QTY,
                :CRASRESMAH_N.TOTAL_USED_QTY,
                :CRASRESMAH_N.ETC_QTY,
                :CRASRESMAH_N.MAX_USE_QTY,
                :CRASRESMAH_N.USE_BATCH_ID,
                :CRASRESMAH_N.USE_TYPE,
                :CRASRESMAH_N.MAX_USE_TIME,
                :CRASRESMAH_N.ORDER_ID,
                :CRASRESMAH_N.LAST_ACTION,
                :CRASRESMAH_N.DETACH_TIME,
                :CRASRESMAH_N.DETACH_USER_ID,
                :CRASRESMAH_N.LAST_HIST_SEQ,
                :CRASRESMAH_N.CMF_1,
                :CRASRESMAH_N.CMF_2,
                :CRASRESMAH_N.CMF_3,
                :CRASRESMAH_N.CMF_4,
                :CRASRESMAH_N.CMF_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_crasresmah(&CRASRESMAH_N, CRASRESMAH);
    }

    DB_stop_query_timer("CDB_fetch_crasresmah", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_crasresmah(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CRASRESMAH_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_crasresmah", sel_type);
}


/* Initialize Function */
void CDB_init_crasresmah(struct CRASRESMAH_TAG *CRASRESMAH)
{
    /* memset by Space */
    memset(CRASRESMAH, ' ', sizeof(struct CRASRESMAH_TAG));
    
    CRASRESMAH->SEQ = 0;
    CRASRESMAH->ATTACH_QTY = 0;
    CRASRESMAH->USED_QTY = 0;
    CRASRESMAH->REMAIN_QTY = 0;
    CRASRESMAH->DEFAULT_USE_QTY = 0;
    CRASRESMAH->INPUT_QTY = 0;
    CRASRESMAH->TOTAL_USED_QTY = 0;
    CRASRESMAH->ETC_QTY = 0;
    CRASRESMAH->MAX_USE_QTY = 0;
    CRASRESMAH->LAST_HIST_SEQ = 0;
}


/* Add Null Function */
void CDB_add_null_crasresmah(struct CRASRESMAH_N_TAG *CRASRESMAH_N, struct CRASRESMAH_TAG *CRASRESMAH)
{
    /* memset by NULL */
    memset(CRASRESMAH_N, '\0', sizeof(struct CRASRESMAH_N_TAG));
    
    MEMCPY_AN(CRASRESMAH_N->FACTORY, CRASRESMAH->FACTORY, sizeof(CRASRESMAH->FACTORY));
    MEMCPY_AN(CRASRESMAH_N->RES_ID, CRASRESMAH->RES_ID, sizeof(CRASRESMAH->RES_ID));
    CRASRESMAH_N->SEQ = CRASRESMAH->SEQ;
    MEMCPY_AN(CRASRESMAH_N->POSITION_ID, CRASRESMAH->POSITION_ID, sizeof(CRASRESMAH->POSITION_ID));
    MEMCPY_AN(CRASRESMAH_N->INV_BARCODE_ID, CRASRESMAH->INV_BARCODE_ID, sizeof(CRASRESMAH->INV_BARCODE_ID));
    MEMCPY_AN(CRASRESMAH_N->INV_MAT_ID, CRASRESMAH->INV_MAT_ID, sizeof(CRASRESMAH->INV_MAT_ID));
    MEMCPY_AN(CRASRESMAH_N->INV_LOT_ID, CRASRESMAH->INV_LOT_ID, sizeof(CRASRESMAH->INV_LOT_ID));
    MEMCPY_AN(CRASRESMAH_N->INV_LOT_DESC, CRASRESMAH->INV_LOT_DESC, sizeof(CRASRESMAH->INV_LOT_DESC));
    MEMCPY_AN(CRASRESMAH_N->MAT_ID, CRASRESMAH->MAT_ID, sizeof(CRASRESMAH->MAT_ID));
    MEMCPY_AN(CRASRESMAH_N->FLOW, CRASRESMAH->FLOW, sizeof(CRASRESMAH->FLOW));
    MEMCPY_AN(CRASRESMAH_N->OPER, CRASRESMAH->OPER, sizeof(CRASRESMAH->OPER));
    MEMCPY_AN(CRASRESMAH_N->MATERIALS_KINDS, CRASRESMAH->MATERIALS_KINDS, sizeof(CRASRESMAH->MATERIALS_KINDS));
    CRASRESMAH_N->ATTACH_QTY = CRASRESMAH->ATTACH_QTY;
    CRASRESMAH_N->USED_QTY = CRASRESMAH->USED_QTY;
    CRASRESMAH_N->REMAIN_QTY = CRASRESMAH->REMAIN_QTY;
    MEMCPY_AN(CRASRESMAH_N->UNIT, CRASRESMAH->UNIT, sizeof(CRASRESMAH->UNIT));
    CRASRESMAH_N->DEFAULT_USE_QTY = CRASRESMAH->DEFAULT_USE_QTY;
    MEMCPY_AN(CRASRESMAH_N->ATTACH_TIME, CRASRESMAH->ATTACH_TIME, sizeof(CRASRESMAH->ATTACH_TIME));
    MEMCPY_AN(CRASRESMAH_N->ATTACH_USER_ID, CRASRESMAH->ATTACH_USER_ID, sizeof(CRASRESMAH->ATTACH_USER_ID));
    CRASRESMAH_N->INPUT_QTY = CRASRESMAH->INPUT_QTY;
    CRASRESMAH_N->TOTAL_USED_QTY = CRASRESMAH->TOTAL_USED_QTY;
    CRASRESMAH_N->ETC_QTY = CRASRESMAH->ETC_QTY;
    CRASRESMAH_N->MAX_USE_QTY = CRASRESMAH->MAX_USE_QTY;
    MEMCPY_AN(CRASRESMAH_N->USE_BATCH_ID, CRASRESMAH->USE_BATCH_ID, sizeof(CRASRESMAH->USE_BATCH_ID));
    MEMCPY_AN(CRASRESMAH_N->USE_TYPE, CRASRESMAH->USE_TYPE, sizeof(CRASRESMAH->USE_TYPE));
    MEMCPY_AN(CRASRESMAH_N->MAX_USE_TIME, CRASRESMAH->MAX_USE_TIME, sizeof(CRASRESMAH->MAX_USE_TIME));
    MEMCPY_AN(CRASRESMAH_N->ORDER_ID, CRASRESMAH->ORDER_ID, sizeof(CRASRESMAH->ORDER_ID));
    MEMCPY_AN(CRASRESMAH_N->LAST_ACTION, CRASRESMAH->LAST_ACTION, sizeof(CRASRESMAH->LAST_ACTION));
    MEMCPY_AN(CRASRESMAH_N->DETACH_TIME, CRASRESMAH->DETACH_TIME, sizeof(CRASRESMAH->DETACH_TIME));
    MEMCPY_AN(CRASRESMAH_N->DETACH_USER_ID, CRASRESMAH->DETACH_USER_ID, sizeof(CRASRESMAH->DETACH_USER_ID));
    CRASRESMAH_N->LAST_HIST_SEQ = CRASRESMAH->LAST_HIST_SEQ;
    MEMCPY_AN(CRASRESMAH_N->CMF_1, CRASRESMAH->CMF_1, sizeof(CRASRESMAH->CMF_1));
    MEMCPY_AN(CRASRESMAH_N->CMF_2, CRASRESMAH->CMF_2, sizeof(CRASRESMAH->CMF_2));
    MEMCPY_AN(CRASRESMAH_N->CMF_3, CRASRESMAH->CMF_3, sizeof(CRASRESMAH->CMF_3));
    MEMCPY_AN(CRASRESMAH_N->CMF_4, CRASRESMAH->CMF_4, sizeof(CRASRESMAH->CMF_4));
    MEMCPY_AN(CRASRESMAH_N->CMF_5, CRASRESMAH->CMF_5, sizeof(CRASRESMAH->CMF_5));
}


/* Del Null Function */
void CDB_del_null_crasresmah(struct CRASRESMAH_N_TAG *CRASRESMAH_N, struct CRASRESMAH_TAG *CRASRESMAH)
{
    MEMCPY_DN(CRASRESMAH->FACTORY, CRASRESMAH_N->FACTORY, sizeof(CRASRESMAH->FACTORY));
    MEMCPY_DN(CRASRESMAH->RES_ID, CRASRESMAH_N->RES_ID, sizeof(CRASRESMAH->RES_ID));
