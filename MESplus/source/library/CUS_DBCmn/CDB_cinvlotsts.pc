                    PROD_TIME,
                    ASSIGN_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10
                FROM CINVLOTSTS
                ORDER BY FACTORY ASC,
                    INV_LOT_ID ASC;
            EXEC SQL OPEN CDB_CINVLOTSTS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cinvlotsts", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_cinvlotsts(int sel_type, struct CINVLOTSTS_TAG *CINVLOTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CINVLOTSTS_N_TAG CINVLOTSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CINVLOTSTS_CUR_1 INTO
                :CINVLOTSTS_N.FACTORY,
                :CINVLOTSTS_N.INV_LOT_ID,
                :CINVLOTSTS_N.VENDOR_BARCD,
                :CINVLOTSTS_N.OPER,
                :CINVLOTSTS_N.MAT_ID,
                :CINVLOTSTS_N.INV_MAT_TYPE,
                :CINVLOTSTS_N.VENDOR_ID,
                :CINVLOTSTS_N.VENDOR_MAT_TYPE,
                :CINVLOTSTS_N.LOCATION,
                :CINVLOTSTS_N.OLD_LOCATION,
                :CINVLOTSTS_N.BATCH_NO,
                :CINVLOTSTS_N.VEN_BATCH_NO,
                :CINVLOTSTS_N.VENDOR_MAT_ID,
                :CINVLOTSTS_N.QTY_1,
                :CINVLOTSTS_N.QTY_2,
                :CINVLOTSTS_N.QTY_3,
                :CINVLOTSTS_N.UNIT_1,
                :CINVLOTSTS_N.UNIT_2,
                :CINVLOTSTS_N.UNIT_3,
                :CINVLOTSTS_N.VENDOR_LOTID,
                :CINVLOTSTS_N.DELETE_FLAG,
                :CINVLOTSTS_N.LAST_HIST_SEQ,
                :CINVLOTSTS_N.LAST_TRAN_TIME,
                :CINVLOTSTS_N.LAST_TRAN_USER_ID,
                :CINVLOTSTS_N.LAST_TRAN_TYPE,
                :CINVLOTSTS_N.PUR_ORDER_NO,
                :CINVLOTSTS_N.PUR_TYPE,
                :CINVLOTSTS_N.PACKAGE_TYPE,
                :CINVLOTSTS_N.IQC_FLAG,
                :CINVLOTSTS_N.INPUT_TIME,
                :CINVLOTSTS_N.PROD_TIME,
                :CINVLOTSTS_N.ASSIGN_TIME,
                :CINVLOTSTS_N.CMF_1,
                :CINVLOTSTS_N.CMF_2,
                :CINVLOTSTS_N.CMF_3,
                :CINVLOTSTS_N.CMF_4,
                :CINVLOTSTS_N.CMF_5,
                :CINVLOTSTS_N.CMF_6,
                :CINVLOTSTS_N.CMF_7,
                :CINVLOTSTS_N.CMF_8,
                :CINVLOTSTS_N.CMF_9,
                :CINVLOTSTS_N.CMF_10;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cinvlotsts(&CINVLOTSTS_N, CINVLOTSTS);
    }

    DB_stop_query_timer("CDB_fetch_cinvlotsts", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cinvlotsts(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CINVLOTSTS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cinvlotsts", sel_type);
}


/* Initialize Function */
void CDB_init_cinvlotsts(struct CINVLOTSTS_TAG *CINVLOTSTS)
{
    /* memset by Space */
    memset(CINVLOTSTS, ' ', sizeof(struct CINVLOTSTS_TAG));
    
    CINVLOTSTS->QTY_1 = 0;
    CINVLOTSTS->QTY_2 = 0;
    CINVLOTSTS->QTY_3 = 0;
    CINVLOTSTS->LAST_HIST_SEQ = 0;
}


/* Add Null Function */
void CDB_add_null_cinvlotsts(struct CINVLOTSTS_N_TAG *CINVLOTSTS_N, struct CINVLOTSTS_TAG *CINVLOTSTS)
{
    /* memset by NULL */
    memset(CINVLOTSTS_N, '\0', sizeof(struct CINVLOTSTS_N_TAG));
    
    MEMCPY_AN(CINVLOTSTS_N->FACTORY, CINVLOTSTS->FACTORY, sizeof(CINVLOTSTS->FACTORY));
    MEMCPY_AN(CINVLOTSTS_N->INV_LOT_ID, CINVLOTSTS->INV_LOT_ID, sizeof(CINVLOTSTS->INV_LOT_ID));
