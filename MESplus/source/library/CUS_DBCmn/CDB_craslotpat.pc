void CDB_del_null_craslotpat(struct CRASLOTPAT_N_TAG *CRASLOTPAT_N, struct CRASLOTPAT_TAG *CRASLOTPAT)
{
    MEMCPY_DN(CRASLOTPAT->LOT_ID, CRASLOTPAT_N->LOT_ID, sizeof(CRASLOTPAT->LOT_ID));
