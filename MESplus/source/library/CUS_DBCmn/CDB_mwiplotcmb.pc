/* SQL CURSOR CLOSE Function */
void CDB_close_mwiplotcmb(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_MWIPLOTCMB_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_MWIPLOTCMB_CUR_2;
            break;

		case 3:
            EXEC SQL CLOSE CDB_MWIPLOTCMB_CUR_3;
            break;

		case 4:
            EXEC SQL CLOSE CDB_MWIPLOTCMB_CUR_4;
            break;

		case 5:
            EXEC SQL CLOSE CDB_MWIPLOTCMB_CUR_5;
            break;

		case 6:
            EXEC SQL CLOSE CDB_MWIPLOTCMB_CUR_6;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_mwiplotcmb", sel_type);
}


/* Initialize Function */
void CDB_init_mwiplotcmb(struct MWIPLOTCMB_TAG *MWIPLOTCMB)
{
    /* memset by Space */
    memset(MWIPLOTCMB, ' ', sizeof(struct MWIPLOTCMB_TAG));
    
    MWIPLOTCMB->HIST_SEQ = 0;
    MWIPLOTCMB->MAT_VER = 0;
    MWIPLOTCMB->FLOW_SEQ_NUM = 0;
    MWIPLOTCMB->FROM_TO_MAT_VER = 0;
    MWIPLOTCMB->FROM_TO_FLOW_SEQ_NUM = 0;
    MWIPLOTCMB->FROM_TO_QTY_1 = 0;
    MWIPLOTCMB->FROM_TO_QTY_2 = 0;
    MWIPLOTCMB->FROM_TO_QTY_3 = 0;
    MWIPLOTCMB->FROM_TO_HIST_SEQ = 0;
}


/* Add Null Function */
void CDB_add_null_mwiplotcmb(struct MWIPLOTCMB_N_TAG *MWIPLOTCMB_N, struct MWIPLOTCMB_TAG *MWIPLOTCMB)
{
    /* memset by NULL */
    memset(MWIPLOTCMB_N, '\0', sizeof(struct MWIPLOTCMB_N_TAG));
    
    MEMCPY_AN(MWIPLOTCMB_N->LOT_ID, MWIPLOTCMB->LOT_ID, sizeof(MWIPLOTCMB->LOT_ID));
    MWIPLOTCMB_N->HIST_SEQ = MWIPLOTCMB->HIST_SEQ;
    MEMCPY_AN(MWIPLOTCMB_N->TRAN_TIME, MWIPLOTCMB->TRAN_TIME, sizeof(MWIPLOTCMB->TRAN_TIME));
    MWIPLOTCMB_N->HIST_DEL_FLAG[0] = MWIPLOTCMB->HIST_DEL_FLAG;
    MEMCPY_AN(MWIPLOTCMB_N->FACTORY, MWIPLOTCMB->FACTORY, sizeof(MWIPLOTCMB->FACTORY));
    MEMCPY_AN(MWIPLOTCMB_N->MAT_ID, MWIPLOTCMB->MAT_ID, sizeof(MWIPLOTCMB->MAT_ID));
    MWIPLOTCMB_N->MAT_VER = MWIPLOTCMB->MAT_VER;
    MEMCPY_AN(MWIPLOTCMB_N->FLOW, MWIPLOTCMB->FLOW, sizeof(MWIPLOTCMB->FLOW));
    MWIPLOTCMB_N->FLOW_SEQ_NUM = MWIPLOTCMB->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPLOTCMB_N->OPER, MWIPLOTCMB->OPER, sizeof(MWIPLOTCMB->OPER));
    MWIPLOTCMB_N->FROM_TO_FLAG[0] = MWIPLOTCMB->FROM_TO_FLAG;
    MEMCPY_AN(MWIPLOTCMB_N->FROM_TO_LOT_ID, MWIPLOTCMB->FROM_TO_LOT_ID, sizeof(MWIPLOTCMB->FROM_TO_LOT_ID));
    MEMCPY_AN(MWIPLOTCMB_N->FROM_TO_MAT_ID, MWIPLOTCMB->FROM_TO_MAT_ID, sizeof(MWIPLOTCMB->FROM_TO_MAT_ID));
    MWIPLOTCMB_N->FROM_TO_MAT_VER = MWIPLOTCMB->FROM_TO_MAT_VER;
    MEMCPY_AN(MWIPLOTCMB_N->FROM_TO_FLOW, MWIPLOTCMB->FROM_TO_FLOW, sizeof(MWIPLOTCMB->FROM_TO_FLOW));
    MWIPLOTCMB_N->FROM_TO_FLOW_SEQ_NUM = MWIPLOTCMB->FROM_TO_FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPLOTCMB_N->FROM_TO_OPER, MWIPLOTCMB->FROM_TO_OPER, sizeof(MWIPLOTCMB->FROM_TO_OPER));
    MWIPLOTCMB_N->FROM_TO_QTY_1 = MWIPLOTCMB->FROM_TO_QTY_1;
    MWIPLOTCMB_N->FROM_TO_QTY_2 = MWIPLOTCMB->FROM_TO_QTY_2;
    MWIPLOTCMB_N->FROM_TO_QTY_3 = MWIPLOTCMB->FROM_TO_QTY_3;
    MWIPLOTCMB_N->FROM_TO_HIST_SEQ = MWIPLOTCMB->FROM_TO_HIST_SEQ;
}


/* Del Null Function */
void CDB_del_null_mwiplotcmb(struct MWIPLOTCMB_N_TAG *MWIPLOTCMB_N, struct MWIPLOTCMB_TAG *MWIPLOTCMB)
{
    MEMCPY_DN(MWIPLOTCMB->LOT_ID, MWIPLOTCMB_N->LOT_ID, sizeof(MWIPLOTCMB->LOT_ID));
    MWIPLOTCMB->HIST_SEQ = MWIPLOTCMB_N->HIST_SEQ;
    MEMCPY_DN(MWIPLOTCMB->TRAN_TIME, MWIPLOTCMB_N->TRAN_TIME, sizeof(MWIPLOTCMB->TRAN_TIME));
    MWIPLOTCMB->HIST_DEL_FLAG = MWIPLOTCMB_N->HIST_DEL_FLAG[0];
    MEMCPY_DN(MWIPLOTCMB->FACTORY, MWIPLOTCMB_N->FACTORY, sizeof(MWIPLOTCMB->FACTORY));
    MEMCPY_DN(MWIPLOTCMB->MAT_ID, MWIPLOTCMB_N->MAT_ID, sizeof(MWIPLOTCMB->MAT_ID));
    MWIPLOTCMB->MAT_VER = MWIPLOTCMB_N->MAT_VER;
    MEMCPY_DN(MWIPLOTCMB->FLOW, MWIPLOTCMB_N->FLOW, sizeof(MWIPLOTCMB->FLOW));
    MWIPLOTCMB->FLOW_SEQ_NUM = MWIPLOTCMB_N->FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPLOTCMB->OPER, MWIPLOTCMB_N->OPER, sizeof(MWIPLOTCMB->OPER));
    MWIPLOTCMB->FROM_TO_FLAG = MWIPLOTCMB_N->FROM_TO_FLAG[0];
    MEMCPY_DN(MWIPLOTCMB->FROM_TO_LOT_ID, MWIPLOTCMB_N->FROM_TO_LOT_ID, sizeof(MWIPLOTCMB->FROM_TO_LOT_ID));
    MEMCPY_DN(MWIPLOTCMB->FROM_TO_MAT_ID, MWIPLOTCMB_N->FROM_TO_MAT_ID, sizeof(MWIPLOTCMB->FROM_TO_MAT_ID));
    MWIPLOTCMB->FROM_TO_MAT_VER = MWIPLOTCMB_N->FROM_TO_MAT_VER;
    MEMCPY_DN(MWIPLOTCMB->FROM_TO_FLOW, MWIPLOTCMB_N->FROM_TO_FLOW, sizeof(MWIPLOTCMB->FROM_TO_FLOW));
    MWIPLOTCMB->FROM_TO_FLOW_SEQ_NUM = MWIPLOTCMB_N->FROM_TO_FLOW_SEQ_NUM;
    MEMCPY_DN(MWIPLOTCMB->FROM_TO_OPER, MWIPLOTCMB_N->FROM_TO_OPER, sizeof(MWIPLOTCMB->FROM_TO_OPER));
    MWIPLOTCMB->FROM_TO_QTY_1 = MWIPLOTCMB_N->FROM_TO_QTY_1;
    MWIPLOTCMB->FROM_TO_QTY_2 = MWIPLOTCMB_N->FROM_TO_QTY_2;
    MWIPLOTCMB->FROM_TO_QTY_3 = MWIPLOTCMB_N->FROM_TO_QTY_3;
    MWIPLOTCMB->FROM_TO_HIST_SEQ = MWIPLOTCMB_N->FROM_TO_HIST_SEQ;
}


