            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cwiplampts(&CWIPLAMPTS_N, CWIPLAMPTS);
    }

    DB_stop_query_timer("CDB_fetch_cwiplampts", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cwiplampts(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CWIPLAMPTS_CUR_1;
            break;

        case 100:
            EXEC SQL CLOSE CDB_CWIPLAMPTS_CUR_100;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwiplampts", sel_type);
}


/* Initialize Function */
void CDB_init_cwiplampts(struct CWIPLAMPTS_TAG *CWIPLAMPTS)
{
    /* memset by Space */
    memset(CWIPLAMPTS, ' ', sizeof(struct CWIPLAMPTS_TAG));
    
    CWIPLAMPTS->MODULE_NO = 0;
    CWIPLAMPTS->MSMT_POS1 = 0;
    CWIPLAMPTS->MSMT_POS2 = 0;
    CWIPLAMPTS->MSMT_POS3 = 0;
    CWIPLAMPTS->MSMT_POS4 = 0;
    CWIPLAMPTS->MSMT_POS5 = 0;
    CWIPLAMPTS->MSMT_POS6 = 0;
    CWIPLAMPTS->MSMT_POS7 = 0;
    CWIPLAMPTS->MSMT_POS8 = 0;
    CWIPLAMPTS->MSMT_POS9 = 0;
    CWIPLAMPTS->MSMT_POS10 = 0;
}


/* Add Null Function */
void CDB_add_null_cwiplampts(struct CWIPLAMPTS_N_TAG *CWIPLAMPTS_N, struct CWIPLAMPTS_TAG *CWIPLAMPTS)
{
    /* memset by NULL */
    memset(CWIPLAMPTS_N, '\0', sizeof(struct CWIPLAMPTS_N_TAG));
    
    MEMCPY_AN(CWIPLAMPTS_N->FACTORY, CWIPLAMPTS->FACTORY, sizeof(CWIPLAMPTS->FACTORY));
    MEMCPY_AN(CWIPLAMPTS_N->MSMT_DATE, CWIPLAMPTS->MSMT_DATE, sizeof(CWIPLAMPTS->MSMT_DATE));
