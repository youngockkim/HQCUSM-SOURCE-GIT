    CWIPLAMPTS_N->MODULE_NO = CWIPLAMPTS->MODULE_NO;
    MEMCPY_AN(CWIPLAMPTS_N->PART_TYPE, CWIPLAMPTS->PART_TYPE, sizeof(CWIPLAMPTS->PART_TYPE));
    MEMCPY_AN(CWIPLAMPTS_N->SMPL_DATE, CWIPLAMPTS->SMPL_DATE, sizeof(CWIPLAMPTS->SMPL_DATE));
    CWIPLAMPTS_N->MSMT_POS1 = CWIPLAMPTS->MSMT_POS1;
