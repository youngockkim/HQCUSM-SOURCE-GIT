    MEMCPY_AN(CWIPLAMPTS_N->CMF_6, CWIPLAMPTS->CMF_6, sizeof(CWIPLAMPTS->CMF_6));
    MEMCPY_AN(CWIPLAMPTS_N->CMF_7, CWIPLAMPTS->CMF_7, sizeof(CWIPLAMPTS->CMF_7));
    MEMCPY_AN(CWIPLAMPTS_N->CMF_8, CWIPLAMPTS->CMF_8, sizeof(CWIPLAMPTS->CMF_8));
    MEMCPY_AN(CWIPLAMPTS_N->CMF_9, CWIPLAMPTS->CMF_9, sizeof(CWIPLAMPTS->CMF_9));
    MEMCPY_AN(CWIPLAMPTS_N->CMF_10, CWIPLAMPTS->CMF_10, sizeof(CWIPLAMPTS->CMF_10));
    MEMCPY_AN(CWIPLAMPTS_N->CREATE_USER_ID, CWIPLAMPTS->CREATE_USER_ID, sizeof(CWIPLAMPTS->CREATE_USER_ID));
    MEMCPY_AN(CWIPLAMPTS_N->CREATE_TIME, CWIPLAMPTS->CREATE_TIME, sizeof(CWIPLAMPTS->CREATE_TIME));
    MEMCPY_AN(CWIPLAMPTS_N->UPDATE_USER_ID, CWIPLAMPTS->UPDATE_USER_ID, sizeof(CWIPLAMPTS->UPDATE_USER_ID));
    MEMCPY_AN(CWIPLAMPTS_N->UPDATE_TIME, CWIPLAMPTS->UPDATE_TIME, sizeof(CWIPLAMPTS->UPDATE_TIME));
}


