    CWIPLAMPTS_N->MSMT_POS8 = CWIPLAMPTS->MSMT_POS8;
    CWIPLAMPTS_N->MSMT_POS9 = CWIPLAMPTS->MSMT_POS9;
    CWIPLAMPTS_N->MSMT_POS10 = CWIPLAMPTS->MSMT_POS10;
    MEMCPY_AN(CWIPLAMPTS_N->CMF_1, CWIPLAMPTS->CMF_1, sizeof(CWIPLAMPTS->CMF_1));
    MEMCPY_AN(CWIPLAMPTS_N->CMF_2, CWIPLAMPTS->CMF_2, sizeof(CWIPLAMPTS->CMF_2));
    MEMCPY_AN(CWIPLAMPTS_N->CMF_3, CWIPLAMPTS->CMF_3, sizeof(CWIPLAMPTS->CMF_3));
    MEMCPY_AN(CWIPLAMPTS_N->CMF_4, CWIPLAMPTS->CMF_4, sizeof(CWIPLAMPTS->CMF_4));
