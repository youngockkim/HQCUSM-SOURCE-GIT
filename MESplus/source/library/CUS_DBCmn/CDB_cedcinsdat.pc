    MEMCPY_DN(CEDCINSDAT->LINE_ID, CEDCINSDAT_N->LINE_ID, sizeof(CEDCINSDAT->LINE_ID));
    MEMCPY_DN(CEDCINSDAT->OPER, CEDCINSDAT_N->OPER, sizeof(CEDCINSDAT->OPER));
    CEDCINSDAT->LOT_HIST_SEQ = CEDCINSDAT_N->LOT_HIST_SEQ;
    MEMCPY_DN(CEDCINSDAT->PARAM_NAME, CEDCINSDAT_N->PARAM_NAME, sizeof(CEDCINSDAT->PARAM_NAME));
    MEMCPY_DN(CEDCINSDAT->PARAM_VALUE, CEDCINSDAT_N->PARAM_VALUE, sizeof(CEDCINSDAT->PARAM_VALUE));
    MEMCPY_DN(CEDCINSDAT->CMF_1, CEDCINSDAT_N->CMF_1, sizeof(CEDCINSDAT->CMF_1));
    MEMCPY_DN(CEDCINSDAT->CMF_2, CEDCINSDAT_N->CMF_2, sizeof(CEDCINSDAT->CMF_2));
    MEMCPY_DN(CEDCINSDAT->CMF_3, CEDCINSDAT_N->CMF_3, sizeof(CEDCINSDAT->CMF_3));
    MEMCPY_DN(CEDCINSDAT->CMF_4, CEDCINSDAT_N->CMF_4, sizeof(CEDCINSDAT->CMF_4));
    MEMCPY_DN(CEDCINSDAT->CMF_5, CEDCINSDAT_N->CMF_5, sizeof(CEDCINSDAT->CMF_5));
}


