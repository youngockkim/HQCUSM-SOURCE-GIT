    MEMCPY_AN(CEDCINSDAT_N->LINE_ID, CEDCINSDAT->LINE_ID, sizeof(CEDCINSDAT->LINE_ID));
    MEMCPY_AN(CEDCINSDAT_N->OPER, CEDCINSDAT->OPER, sizeof(CEDCINSDAT->OPER));
    CEDCINSDAT_N->LOT_HIST_SEQ = CEDCINSDAT->LOT_HIST_SEQ;
