    EXEC SQL BEGIN DECLARE SECTION;
        struct CEDCINSDAT_N_TAG CEDCINSDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedcinsdat(&CEDCINSDAT_N, CEDCINSDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CEDCINSDAT_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    RES_ID,
                    TRAN_TIME,
                    SEQ_NUM,
                    FACTORY,
                    LINE_ID,
                    OPER,
                    LOT_HIST_SEQ,
                    PARAM_NAME,
                    PARAM_VALUE,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM CEDCINSDAT
                ORDER BY LOT_ID ASC,
                    RES_ID ASC,
                    TRAN_TIME ASC,
                    SEQ_NUM ASC;
            EXEC SQL OPEN CDB_CEDCINSDAT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cedcinsdat", sel_type);
}


