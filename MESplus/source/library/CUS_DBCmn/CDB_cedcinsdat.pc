/* Del Null Function */
void CDB_del_null_cedcinsdat(struct CEDCINSDAT_N_TAG *CEDCINSDAT_N, struct CEDCINSDAT_TAG *CEDCINSDAT)
{
    MEMCPY_DN(CEDCINSDAT->LOT_ID, CEDCINSDAT_N->LOT_ID, sizeof(CEDCINSDAT->LOT_ID));
    MEMCPY_DN(CEDCINSDAT->RES_ID, CEDCINSDAT_N->RES_ID, sizeof(CEDCINSDAT->RES_ID));
    MEMCPY_DN(CEDCINSDAT->TRAN_TIME, CEDCINSDAT_N->TRAN_TIME, sizeof(CEDCINSDAT->TRAN_TIME));
    CEDCINSDAT->SEQ_NUM = CEDCINSDAT_N->SEQ_NUM;
