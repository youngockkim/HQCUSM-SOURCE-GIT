/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_camsadtpln(int sel_type, struct CAMSADTPLN_TAG *CAMSADTPLN)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CAMSADTPLN_N_TAG CAMSADTPLN_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_camsadtpln(&CAMSADTPLN_N, CAMSADTPLN);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CAMSADTPLN_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    AUDIT_ID,
                    AUDIT_DESC,
                    PLAN_DATE,
                    AUDIT_DATE,
                    CUSTOMER_CODE,
                    AUDITOR,
                    MANAGER_ID,
                    AGENDA,
                    STATUS,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CAMSADTPLN
			   WHERE FACTORY = :CAMSADTPLN_N.FACTORY
			     AND PLAN_DATE >= :CAMSADTPLN_N.PLAN_DATE
				 AND PLAN_DATE <= :CAMSADTPLN_N.AUDIT_DATE
				 AND STATUS IN('0','1')
				 AND CUSTOMER_CODE LIKE '%' || TRIM(:CAMSADTPLN_N.CUSTOMER_CODE) ||'%'
				 AND STATUS LIKE '%' || TRIM(:CAMSADTPLN_N.STATUS) ||'%'
				 AND MANAGER_ID LIKE '%' || TRIM(:CAMSADTPLN_N.MANAGER_ID) ||'%'
                ORDER BY FACTORY ASC,
                    AUDIT_ID ASC;
            EXEC SQL OPEN CDB_CAMSADTPLN_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_camsadtpln", sel_type);
}


