                    LAST_ACTIVE_HIST_SEQ = :CRASSRSDEF_N.LAST_ACTIVE_HIST_SEQ,
                    LAST_HIST_SEQ = :CRASSRSDEF_N.LAST_HIST_SEQ
                WHERE FACTORY = :CRASSRSDEF_N.FACTORY
                    AND RES_ID = :CRASSRSDEF_N.RES_ID
                    AND SUBRES_ID = :CRASSRSDEF_N.SUBRES_ID;
            break;

		case 101:
            EXEC SQL UPDATE CRASSRSDEF SET
                    SUBRES_STS_3 = :CRASSRSDEF_N.SUBRES_STS_3,
                    SUBRES_STS_7 = :CRASSRSDEF_N.SUBRES_STS_7,
                    SUBRES_STS_8 = :CRASSRSDEF_N.SUBRES_STS_8
                  WHERE FACTORY = :CRASSRSDEF_N.FACTORY
                    AND RES_ID = :CRASSRSDEF_N.RES_ID
                    AND SUBRES_ID = :CRASSRSDEF_N.SUBRES_ID;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_crassrsdef", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_crassrsdef(int sel_type, struct CRASSRSDEF_TAG *CRASSRSDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASSRSDEF_N_TAG CRASSRSDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_crassrsdef(&CRASSRSDEF_N, CRASSRSDEF);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASSRSDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    SUBRES_DESC,
                    PARENTS_SUBRES_ID,
                    SUBRES_TYPE,
                    USE_FAC_PRT_FLAG,
                    RES_STS_PRT_1,
                    RES_STS_PRT_2,
                    RES_STS_PRT_3,
                    RES_STS_PRT_4,
                    RES_STS_PRT_5,
                    RES_STS_PRT_6,
                    RES_STS_PRT_7,
                    RES_STS_PRT_8,
                    RES_STS_PRT_9,
                    RES_STS_PRT_10,
                    SUBRES_CMF_1,
                    SUBRES_CMF_2,
                    SUBRES_CMF_3,
                    SUBRES_CMF_4,
                    SUBRES_CMF_5,
                    SUBRES_CMF_6,
                    SUBRES_CMF_7,
                    SUBRES_CMF_8,
                    SUBRES_CMF_9,
                    SUBRES_CMF_10,
                    SUBRES_CMF_11,
                    SUBRES_CMF_12,
                    SUBRES_CMF_13,
                    SUBRES_CMF_14,
                    SUBRES_CMF_15,
                    SUBRES_CMF_16,
                    SUBRES_CMF_17,
                    SUBRES_CMF_18,
                    SUBRES_CMF_19,
                    SUBRES_CMF_20,
                    CHAMBER_TYPE_FLAG,
                    CHAMBER_GRP_ID,
                    SUBRES_LOCATION,
                    DELETE_FLAG,
                    DELETE_USER_ID,
                    DELETE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    SUBRES_UP_DOWN_FLAG,
                    SUBRES_PRI_STS,
                    SUBRES_STS_1,
                    SUBRES_STS_2,
                    SUBRES_STS_3,
                    SUBRES_STS_4,
                    SUBRES_STS_5,
                    SUBRES_STS_6,
                    SUBRES_STS_7,
                    SUBRES_STS_8,
                    SUBRES_STS_9,
                    SUBRES_STS_10,
                    LOT_ID,
                    SUBLOT_ID,
                    CRR_ID,
                    LAST_EVENT_ID,
                    LAST_EVENT_TIME,
                    LAST_ACTIVE_HIST_SEQ,
                    LAST_HIST_SEQ
                FROM CRASSRSDEF
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SUBRES_ID ASC;
            EXEC SQL OPEN CDB_CRASSRSDEF_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_crassrsdef", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_crassrsdef(int sel_type, struct CRASSRSDEF_TAG *CRASSRSDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASSRSDEF_N_TAG CRASSRSDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CRASSRSDEF_CUR_1 INTO
                :CRASSRSDEF_N.FACTORY,
                :CRASSRSDEF_N.RES_ID,
                :CRASSRSDEF_N.SUBRES_ID,
                :CRASSRSDEF_N.SUBRES_DESC,
