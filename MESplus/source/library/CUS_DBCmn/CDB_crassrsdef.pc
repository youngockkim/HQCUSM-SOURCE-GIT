                :CRASSRSDEF_N.SUBRES_CMF_11,
                :CRASSRSDEF_N.SUBRES_CMF_12,
                :CRASSRSDEF_N.SUBRES_CMF_13,
                :CRASSRSDEF_N.SUBRES_CMF_14,
                :CRASSRSDEF_N.SUBRES_CMF_15,
                :CRASSRSDEF_N.SUBRES_CMF_16,
                :CRASSRSDEF_N.SUBRES_CMF_17,
                :CRASSRSDEF_N.SUBRES_CMF_18,
                :CRASSRSDEF_N.SUBRES_CMF_19,
                :CRASSRSDEF_N.SUBRES_CMF_20,
                :CRASSRSDEF_N.CHAMBER_TYPE_FLAG,
                :CRASSRSDEF_N.CHAMBER_GRP_ID,
                :CRASSRSDEF_N.SUBRES_LOCATION,
                :CRASSRSDEF_N.DELETE_FLAG,
                :CRASSRSDEF_N.DELETE_USER_ID,
                :CRASSRSDEF_N.DELETE_TIME,
                :CRASSRSDEF_N.CREATE_USER_ID,
                :CRASSRSDEF_N.CREATE_TIME,
                :CRASSRSDEF_N.UPDATE_USER_ID,
                :CRASSRSDEF_N.UPDATE_TIME,
                :CRASSRSDEF_N.SUBRES_UP_DOWN_FLAG,
                :CRASSRSDEF_N.SUBRES_PRI_STS,
                :CRASSRSDEF_N.SUBRES_STS_1,
                :CRASSRSDEF_N.SUBRES_STS_2,
                :CRASSRSDEF_N.SUBRES_STS_3,
                :CRASSRSDEF_N.SUBRES_STS_4,
                :CRASSRSDEF_N.SUBRES_STS_5,
                :CRASSRSDEF_N.SUBRES_STS_6,
                :CRASSRSDEF_N.SUBRES_STS_7,
                :CRASSRSDEF_N.SUBRES_STS_8,
                :CRASSRSDEF_N.SUBRES_STS_9,
                :CRASSRSDEF_N.SUBRES_STS_10,
                :CRASSRSDEF_N.LOT_ID,
                :CRASSRSDEF_N.SUBLOT_ID,
                :CRASSRSDEF_N.CRR_ID,
                :CRASSRSDEF_N.LAST_EVENT_ID,
                :CRASSRSDEF_N.LAST_EVENT_TIME,
                :CRASSRSDEF_N.LAST_ACTIVE_HIST_SEQ,
                :CRASSRSDEF_N.LAST_HIST_SEQ;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_crassrsdef(&CRASSRSDEF_N, CRASSRSDEF);
    }

    DB_stop_query_timer("CDB_fetch_crassrsdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_crassrsdef(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CRASSRSDEF_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_crassrsdef", sel_type);
}


/* Initialize Function */
void CDB_init_crassrsdef(struct CRASSRSDEF_TAG *CRASSRSDEF)
{
    /* memset by Space */
    memset(CRASSRSDEF, ' ', sizeof(struct CRASSRSDEF_TAG));
    
    CRASSRSDEF->LAST_ACTIVE_HIST_SEQ = 0;
    CRASSRSDEF->LAST_HIST_SEQ = 0;
}


