/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwiplotext(int sel_type, struct CWIPLOTEXT_TAG *CWIPLOTEXT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPLOTEXT_N_TAG CWIPLOTEXT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwiplotext(&CWIPLOTEXT_N, CWIPLOTEXT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPLOTEXT_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CMF_11,
                    CMF_12,
                    CMF_13,
                    CMF_14,
                    CMF_15,
                    CMF_16,
                    CMF_17,
                    CMF_18,
                    CMF_19,
                    CMF_20,
                    CMF_21,
                    CMF_22,
                    CMF_23,
                    CMF_24,
                    CMF_25,
                    CMF_26,
                    CMF_27,
                    CMF_28,
                    CMF_29,
                    CMF_30,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CWIPLOTEXT
                ORDER BY LOT_ID ASC;
            EXEC SQL OPEN CDB_CWIPLOTEXT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
