/* SQL UPDATE Function */
void CDB_update_mrasresdef(int sel_type, struct MRASRESDEF_TAG *MRASRESDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASRESDEF_N_TAG MRASRESDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_mrasresdef(&MRASRESDEF_N, MRASRESDEF);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MRASRESDEF SET
                    RES_DESC = :MRASRESDEF_N.RES_DESC,
                    RES_TYPE = :MRASRESDEF_N.RES_TYPE,
                    RES_GRP_1 = :MRASRESDEF_N.RES_GRP_1,
