/* Del Null Function */
void CDB_del_null_cwipordsts(struct CWIPORDSTS_N_TAG *CWIPORDSTS_N, struct CWIPORDSTS_TAG *CWIPORDSTS)
{
    MEMCPY_DN(CWIPORDSTS->FACTORY, CWIPORDSTS_N->FACTORY, sizeof(CWIPORDSTS->FACTORY));
    MEMCPY_DN(CWIPORDSTS->ORDER_ID, CWIPORDSTS_N->ORDER_ID, sizeof(CWIPORDSTS->ORDER_ID));
    MEMCPY_DN(CWIPORDSTS->MAT_ID, CWIPORDSTS_N->MAT_ID, sizeof(CWIPORDSTS->MAT_ID));
    MEMCPY_DN(CWIPORDSTS->PROD_ORDER_VER, CWIPORDSTS_N->PROD_ORDER_VER, sizeof(CWIPORDSTS->PROD_ORDER_VER));
    MEMCPY_DN(CWIPORDSTS->PROD_NO_DESC, CWIPORDSTS_N->PROD_NO_DESC, sizeof(CWIPORDSTS->PROD_NO_DESC));
