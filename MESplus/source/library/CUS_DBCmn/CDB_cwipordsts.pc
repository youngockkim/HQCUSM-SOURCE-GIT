                    ORD.CO_PROD_NUMBER_4,
                    ORD.CO_PROD_NUMBER_5,
                    ORD.CO_PROD_NUMBER_6,
                    ORD.CELL_RATE,
                    ORD.BCR_POWER,
                    ORD.BCR_LIST_CODE,
                    ORD.BCR_PROD_BATCH_NO,
                    ORD.BCR_MOD_CLASS,
                    ORD.BCR_MOD_TYPE,
                    ORD.BCR_MOD_SUBTYPE,
                    ORD.CUST_ISC_YN,
                    ORD.OPER_NO,
                    ORD.WORK_CENTER,
                    ORD.WORK_CENTER_DESC,
                    ORD.STD_TEXT_KEY,
                    ORD.OPER_SHORT_DESC,
                    ORD.DEL_YN,
                    ORD.VALUATION_TYPE,
                    ORD.ZZBOMID,
                    ORD.ZSHIPNO,
                    ORD.ZARTCOR
                FROM CWIPORDSTS ORD
				WHERE ORD.FACTORY = :CWIPORDSTS_N.FACTORY
				  AND ORD.START_DATE BETWEEN :CWIPORDSTS_N.START_DATE AND :CWIPORDSTS_N.FINISH_DATE
				  AND ORD.ORDER_ID LIKE '%' || TRIM(:CWIPORDSTS_N.ORDER_ID) || '%' 
				  AND ORD.MAT_ID LIKE '%' || TRIM(:CWIPORDSTS_N.MAT_ID) || '%' 
				  AND ORD.WORK_CENTER IN (SELECT DATA_2
                                            FROM MGCMTBLDAT 
                                           WHERE FACTORY = ORD.FACTORY 
                                             AND TABLE_NAME = '@LINE_CODE' 
                                             AND KEY_1 LIKE '%' || TRIM(:CWIPORDSTS_N.WORK_CENTER) || '%')
                ORDER BY ORD.FACTORY ASC,
                    ORD.ORDER_ID ASC;
            EXEC SQL OPEN CDB_CWIPORDSTS_CUR_105;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwipordsts", sel_type);
}


