    MEMCPY_DN(CWIPORDSTS->PROD_ORDER_SUBTYPE, CWIPORDSTS_N->PROD_ORDER_SUBTYPE, sizeof(CWIPORDSTS->PROD_ORDER_SUBTYPE));
    CWIPORDSTS->PROD_QTY = CWIPORDSTS_N->PROD_QTY;
    MEMCPY_DN(CWIPORDSTS->PROD_UNIT, CWIPORDSTS_N->PROD_UNIT, sizeof(CWIPORDSTS->PROD_UNIT));
    MEMCPY_DN(CWIPORDSTS->START_DATE, CWIPORDSTS_N->START_DATE, sizeof(CWIPORDSTS->START_DATE));
    MEMCPY_DN(CWIPORDSTS->FINISH_DATE, CWIPORDSTS_N->FINISH_DATE, sizeof(CWIPORDSTS->FINISH_DATE));
    MEMCPY_DN(CWIPORDSTS->WORK_SHOP, CWIPORDSTS_N->WORK_SHOP, sizeof(CWIPORDSTS->WORK_SHOP));
    CWIPORDSTS->BLOCK_YN = CWIPORDSTS_N->BLOCK_YN[0];
    MEMCPY_DN(CWIPORDSTS->ROUTE_GRP, CWIPORDSTS_N->ROUTE_GRP, sizeof(CWIPORDSTS->ROUTE_GRP));
