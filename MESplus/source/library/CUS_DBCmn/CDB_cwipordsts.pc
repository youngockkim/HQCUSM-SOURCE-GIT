/* SQL CURSOR CLOSE Function */
void CDB_close_cwipordsts(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CWIPORDSTS_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CWIPORDSTS_CUR_2;
            break;

		case 101:
            EXEC SQL CLOSE CDB_CWIPORDSTS_CUR_101;
            break;

		case 102:
            EXEC SQL CLOSE CDB_CWIPORDSTS_CUR_102;
            break;

		case 103:
            EXEC SQL CLOSE CDB_CWIPORDSTS_CUR_103;
            break;

		case 104:
            EXEC SQL CLOSE CDB_CWIPORDSTS_CUR_104;
            break;

		case 105:
            EXEC SQL CLOSE CDB_CWIPORDSTS_CUR_105;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwipordsts", sel_type);
}


/* Initialize Function */
void CDB_init_cwipordsts(struct CWIPORDSTS_TAG *CWIPORDSTS)
{
    /* memset by Space */
    memset(CWIPORDSTS, ' ', sizeof(struct CWIPORDSTS_TAG));
    
    CWIPORDSTS->PROD_QTY = 0;
}


