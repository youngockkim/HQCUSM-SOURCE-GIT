				WHERE FACTORY = : CWIPORDSTS_N.FACTORY
				AND ORDER_ID = : CWIPORDSTS_N.ORDER_ID
				AND MAT_ID = : CWIPORDSTS_N.MAT_ID
				AND START_DATE >= : CWIPORDSTS_N.START_DATE
				AND FINISH_DATE <= : CWIPORDSTS_N.FINISH_DATE
                ORDER BY FACTORY ASC,
                    ORDER_ID ASC;
            EXEC SQL OPEN CDB_CWIPORDSTS_CUR_2;
