                    ORD.FACTORY,
                    ORD.ORDER_ID,
                    ORD.MAT_ID,
                    ORD.PROD_ORDER_VER,
                    ORD.PROD_NO_DESC,
                    ORD.PROD_ORDER_TYPE,
