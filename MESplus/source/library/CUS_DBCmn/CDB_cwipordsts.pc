                    ORD.ZZBOMID,
                    ORD.ZSHIPNO,
                    ORD.ZARTCOR
                FROM CWIPORDSTS ORD
				   , CJCMJOBSTS JOB
				WHERE ORD.FACTORY = JOB.FACTORY(+)
				  AND ORD.ORDER_ID = JOB.ORDER_ID(+)
				  AND ORD.FACTORY = : CWIPORDSTS_N.FACTORY
				  AND ORD.START_DATE >= : CWIPORDSTS_N.START_DATE
				  AND ORD.PROD_ORDER_TYPE = 'N'
				  AND JOB.ORDER_ID IS NULL
                ORDER BY ORD.FACTORY ASC,
                    ORD.ORDER_ID ASC;
            EXEC SQL OPEN CDB_CWIPORDSTS_CUR_104;
            break;

		case 105:
            EXEC SQL DECLARE CDB_CWIPORDSTS_CUR_105 CURSOR FOR
