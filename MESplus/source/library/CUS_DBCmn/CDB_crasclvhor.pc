    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASCLVHOR_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    WORK_DATE,
                    WORK_TIME,
                    LINE_ID,
                    RES_ID,
                    ORDER_ID,
                    LD_INPUT,
                    LD_REJECT,
                    ULD_INPUT,
