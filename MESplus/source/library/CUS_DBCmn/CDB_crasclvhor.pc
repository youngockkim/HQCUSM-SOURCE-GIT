                FROM CRASCLVHOR
                ORDER BY FACTORY ASC,
                    WORK_DATE ASC,
                    WORK_TIME ASC,
                    LINE_ID ASC,
                    RES_ID ASC,
                    ORDER_ID ASC;
            EXEC SQL OPEN CDB_CRASCLVHOR_CUR_1;
