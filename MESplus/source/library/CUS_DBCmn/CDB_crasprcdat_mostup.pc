    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASPRCDAT_MOSTUP_CUR_1 CURSOR FOR
                SELECT 
                    RES_ID,
                    PARAM_NAME,
                    TRAN_TIME,
                    LOT_ID,
                    SEQ_NUM,
                    NVL(FACTORY, ' '),
                    NVL(LINE_ID, ' '),
