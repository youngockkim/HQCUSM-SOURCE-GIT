	MEMCPY_AN(CWIPPAKHIS_N->PVM_PN, CWIPPAKHIS->PVM_PN, sizeof(CWIPPAKHIS->PVM_PN));
	MEMCPY_AN(CWIPPAKHIS_N->PVM_SN, CWIPPAKHIS->PVM_SN, sizeof(CWIPPAKHIS->PVM_SN));
	MEMCPY_AN(CWIPPAKHIS_N->PCU_SN, CWIPPAKHIS->PCU_SN, sizeof(CWIPPAKHIS->PCU_SN));
	MEMCPY_AN(CWIPPAKHIS_N->ACM_SN, CWIPPAKHIS->ACM_SN, sizeof(CWIPPAKHIS->ACM_SN));
}


/* Del Null Function */
void CDB_del_null_cwippakhis(struct CWIPPAKHIS_N_TAG *CWIPPAKHIS_N, struct CWIPPAKHIS_TAG *CWIPPAKHIS)
{
    MEMCPY_DN(CWIPPAKHIS->FACTORY, CWIPPAKHIS_N->FACTORY, sizeof(CWIPPAKHIS->FACTORY));
    MEMCPY_DN(CWIPPAKHIS->LOT_ID, CWIPPAKHIS_N->LOT_ID, sizeof(CWIPPAKHIS->LOT_ID));
