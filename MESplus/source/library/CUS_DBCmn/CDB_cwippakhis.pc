    MEMCPY_DN(CWIPPAKHIS->ORDER_ID, CWIPPAKHIS_N->ORDER_ID, sizeof(CWIPPAKHIS->ORDER_ID));
    MEMCPY_DN(CWIPPAKHIS->LINE_ID, CWIPPAKHIS_N->LINE_ID, sizeof(CWIPPAKHIS->LINE_ID));
    MEMCPY_DN(CWIPPAKHIS->RES_ID, CWIPPAKHIS_N->RES_ID, sizeof(CWIPPAKHIS->RES_ID));
    CWIPPAKHIS->STATUS_FLAG = CWIPPAKHIS_N->STATUS_FLAG[0];
    MEMCPY_DN(CWIPPAKHIS->PAK_TYPE, CWIPPAKHIS_N->PAK_TYPE, sizeof(CWIPPAKHIS->PAK_TYPE));
    MEMCPY_DN(CWIPPAKHIS->PAK_TIME, CWIPPAKHIS_N->PAK_TIME, sizeof(CWIPPAKHIS->PAK_TIME));
    MEMCPY_DN(CWIPPAKHIS->GRADE, CWIPPAKHIS_N->GRADE, sizeof(CWIPPAKHIS->GRADE));
    MEMCPY_DN(CWIPPAKHIS->POWER, CWIPPAKHIS_N->POWER, sizeof(CWIPPAKHIS->POWER));
    MEMCPY_DN(CWIPPAKHIS->CMF_1, CWIPPAKHIS_N->CMF_1, sizeof(CWIPPAKHIS->CMF_1));
    MEMCPY_DN(CWIPPAKHIS->CMF_2, CWIPPAKHIS_N->CMF_2, sizeof(CWIPPAKHIS->CMF_2));
    MEMCPY_DN(CWIPPAKHIS->CMF_3, CWIPPAKHIS_N->CMF_3, sizeof(CWIPPAKHIS->CMF_3));
    MEMCPY_DN(CWIPPAKHIS->CMF_4, CWIPPAKHIS_N->CMF_4, sizeof(CWIPPAKHIS->CMF_4));
    MEMCPY_DN(CWIPPAKHIS->CMF_5, CWIPPAKHIS_N->CMF_5, sizeof(CWIPPAKHIS->CMF_5));
    CWIPPAKHIS->HIST_SEQ = CWIPPAKHIS_N->HIST_SEQ;
    MEMCPY_DN(CWIPPAKHIS->CREATE_TIME, CWIPPAKHIS_N->CREATE_TIME, sizeof(CWIPPAKHIS->CREATE_TIME));
    MEMCPY_DN(CWIPPAKHIS->LAST_TRAN_TIME, CWIPPAKHIS_N->LAST_TRAN_TIME, sizeof(CWIPPAKHIS->LAST_TRAN_TIME));

	MEMCPY_DN(CWIPPAKHIS->PVM_PN, CWIPPAKHIS_N->PVM_PN, sizeof(CWIPPAKHIS->PVM_PN));
	MEMCPY_DN(CWIPPAKHIS->PVM_SN, CWIPPAKHIS_N->PVM_SN, sizeof(CWIPPAKHIS->PVM_SN));
	MEMCPY_DN(CWIPPAKHIS->PCU_SN, CWIPPAKHIS_N->PCU_SN, sizeof(CWIPPAKHIS->PCU_SN));
	MEMCPY_DN(CWIPPAKHIS->ACM_SN, CWIPPAKHIS_N->ACM_SN, sizeof(CWIPPAKHIS->ACM_SN));
}


