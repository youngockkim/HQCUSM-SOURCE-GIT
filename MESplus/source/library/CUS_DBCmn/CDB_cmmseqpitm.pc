    MEMCPY_DN(CMMSEQPITM->CREATE_USER_ID, CMMSEQPITM_N->CREATE_USER_ID, sizeof(CMMSEQPITM->CREATE_USER_ID));
    MEMCPY_DN(CMMSEQPITM->CREATE_TIME, CMMSEQPITM_N->CREATE_TIME, sizeof(CMMSEQPITM->CREATE_TIME));
    MEMCPY_DN(CMMSEQPITM->UPDATE_USER_ID, CMMSEQPITM_N->UPDATE_USER_ID, sizeof(CMMSEQPITM->UPDATE_USER_ID));
    MEMCPY_DN(CMMSEQPITM->UPDATE_TIME, CMMSEQPITM_N->UPDATE_TIME, sizeof(CMMSEQPITM->UPDATE_TIME));
