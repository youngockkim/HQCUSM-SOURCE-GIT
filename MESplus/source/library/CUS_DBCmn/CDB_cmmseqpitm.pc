                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSEQPITM
			   WHERE FACTORY = :CMMSEQPITM_N.FACTORY
			     AND EQUIP_ID = :CMMSEQPITM_N.EQUIP_ID
                ORDER BY FACTORY ASC,
                    EQUIP_ID ASC,
                    ITEM_ORDER ASC,
					ITEM_CODE ASC;
            EXEC SQL OPEN CDB_CMMSEQPITM_CUR_2;
            break;

		case 4:
            EXEC SQL DECLARE CDB_CMMSEQPITM_CUR_4 CURSOR FOR
                SELECT 
                    FACTORY,
                    EQUIP_ID,
                    ITEM_CODE,
                    ITEM_NAME,
                    ITEM_SPEC,
                    ITEM_ORDER,
