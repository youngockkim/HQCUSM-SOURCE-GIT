                :CMMSEQPITM_N.CMF_10,
                :CMMSEQPITM_N.CREATE_USER_ID,
                :CMMSEQPITM_N.CREATE_TIME,
                :CMMSEQPITM_N.UPDATE_USER_ID,
                :CMMSEQPITM_N.UPDATE_TIME;
            break;

		case 4:
            EXEC SQL FETCH CDB_CMMSEQPITM_CUR_4 INTO
                :CMMSEQPITM_N.FACTORY,
                :CMMSEQPITM_N.EQUIP_ID,
                :CMMSEQPITM_N.ITEM_CODE,
                :CMMSEQPITM_N.ITEM_NAME,
                :CMMSEQPITM_N.ITEM_SPEC,
                :CMMSEQPITM_N.ITEM_ORDER,
                :CMMSEQPITM_N.LSL,
                :CMMSEQPITM_N.USL,
                :CMMSEQPITM_N.UNIT_CODE,
                :CMMSEQPITM_N.DECIMAL_PLACE,
                :CMMSEQPITM_N.USE_GRR_CONT_FLAG,
                :CMMSEQPITM_N.USE_GRR_DISC_FLAG,
                :CMMSEQPITM_N.USE_BIAS_FLAG,
                :CMMSEQPITM_N.USE_LINE_FLAG,
                :CMMSEQPITM_N.CMF_1,
                :CMMSEQPITM_N.CMF_2,
                :CMMSEQPITM_N.CMF_3,
                :CMMSEQPITM_N.CMF_4,
                :CMMSEQPITM_N.CMF_5,
                :CMMSEQPITM_N.CMF_6,
                :CMMSEQPITM_N.CMF_7,
                :CMMSEQPITM_N.CMF_8,
                :CMMSEQPITM_N.CMF_9,
                :CMMSEQPITM_N.CMF_10,
                :CMMSEQPITM_N.CREATE_USER_ID,
                :CMMSEQPITM_N.CREATE_TIME,
                :CMMSEQPITM_N.UPDATE_USER_ID,
                :CMMSEQPITM_N.UPDATE_TIME;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cmmseqpitm(&CMMSEQPITM_N, CMMSEQPITM);
    }

    DB_stop_query_timer("CDB_fetch_cmmseqpitm", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cmmseqpitm(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CMMSEQPITM_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CMMSEQPITM_CUR_2;
            break;

		case 4:
            EXEC SQL CLOSE CDB_CMMSEQPITM_CUR_4;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cmmseqpitm", sel_type);
}


/* Initialize Function */
void CDB_init_cmmseqpitm(struct CMMSEQPITM_TAG *CMMSEQPITM)
{
    /* memset by Space */
    memset(CMMSEQPITM, ' ', sizeof(struct CMMSEQPITM_TAG));
    
    CMMSEQPITM->ITEM_ORDER = 0;
    CMMSEQPITM->LSL = 0;
    CMMSEQPITM->USL = 0;
    CMMSEQPITM->DECIMAL_PLACE = 0;
}


/* Add Null Function */
void CDB_add_null_cmmseqpitm(struct CMMSEQPITM_N_TAG *CMMSEQPITM_N, struct CMMSEQPITM_TAG *CMMSEQPITM)
{
    /* memset by NULL */
    memset(CMMSEQPITM_N, '\0', sizeof(struct CMMSEQPITM_N_TAG));
    
    MEMCPY_AN(CMMSEQPITM_N->FACTORY, CMMSEQPITM->FACTORY, sizeof(CMMSEQPITM->FACTORY));
    MEMCPY_AN(CMMSEQPITM_N->EQUIP_ID, CMMSEQPITM->EQUIP_ID, sizeof(CMMSEQPITM->EQUIP_ID));
    MEMCPY_AN(CMMSEQPITM_N->ITEM_CODE, CMMSEQPITM->ITEM_CODE, sizeof(CMMSEQPITM->ITEM_CODE));
    MEMCPY_AN(CMMSEQPITM_N->ITEM_NAME, CMMSEQPITM->ITEM_NAME, sizeof(CMMSEQPITM->ITEM_NAME));
    MEMCPY_AN(CMMSEQPITM_N->ITEM_SPEC, CMMSEQPITM->ITEM_SPEC, sizeof(CMMSEQPITM->ITEM_SPEC));
    CMMSEQPITM_N->ITEM_ORDER = CMMSEQPITM->ITEM_ORDER;
    CMMSEQPITM_N->LSL = CMMSEQPITM->LSL;
    CMMSEQPITM_N->USL = CMMSEQPITM->USL;
    MEMCPY_AN(CMMSEQPITM_N->UNIT_CODE, CMMSEQPITM->UNIT_CODE, sizeof(CMMSEQPITM->UNIT_CODE));
    CMMSEQPITM_N->DECIMAL_PLACE = CMMSEQPITM->DECIMAL_PLACE;
    CMMSEQPITM_N->USE_GRR_CONT_FLAG[0] = CMMSEQPITM->USE_GRR_CONT_FLAG;
    CMMSEQPITM_N->USE_GRR_DISC_FLAG[0] = CMMSEQPITM->USE_GRR_DISC_FLAG;
    CMMSEQPITM_N->USE_BIAS_FLAG[0] = CMMSEQPITM->USE_BIAS_FLAG;
    CMMSEQPITM_N->USE_LINE_FLAG[0] = CMMSEQPITM->USE_LINE_FLAG;
    MEMCPY_AN(CMMSEQPITM_N->CMF_1, CMMSEQPITM->CMF_1, sizeof(CMMSEQPITM->CMF_1));
    MEMCPY_AN(CMMSEQPITM_N->CMF_2, CMMSEQPITM->CMF_2, sizeof(CMMSEQPITM->CMF_2));
    MEMCPY_AN(CMMSEQPITM_N->CMF_3, CMMSEQPITM->CMF_3, sizeof(CMMSEQPITM->CMF_3));
    MEMCPY_AN(CMMSEQPITM_N->CMF_4, CMMSEQPITM->CMF_4, sizeof(CMMSEQPITM->CMF_4));
    MEMCPY_AN(CMMSEQPITM_N->CMF_5, CMMSEQPITM->CMF_5, sizeof(CMMSEQPITM->CMF_5));
    MEMCPY_AN(CMMSEQPITM_N->CMF_6, CMMSEQPITM->CMF_6, sizeof(CMMSEQPITM->CMF_6));
    MEMCPY_AN(CMMSEQPITM_N->CMF_7, CMMSEQPITM->CMF_7, sizeof(CMMSEQPITM->CMF_7));
    MEMCPY_AN(CMMSEQPITM_N->CMF_8, CMMSEQPITM->CMF_8, sizeof(CMMSEQPITM->CMF_8));
    MEMCPY_AN(CMMSEQPITM_N->CMF_9, CMMSEQPITM->CMF_9, sizeof(CMMSEQPITM->CMF_9));
    MEMCPY_AN(CMMSEQPITM_N->CMF_10, CMMSEQPITM->CMF_10, sizeof(CMMSEQPITM->CMF_10));
    MEMCPY_AN(CMMSEQPITM_N->CREATE_USER_ID, CMMSEQPITM->CREATE_USER_ID, sizeof(CMMSEQPITM->CREATE_USER_ID));
    MEMCPY_AN(CMMSEQPITM_N->CREATE_TIME, CMMSEQPITM->CREATE_TIME, sizeof(CMMSEQPITM->CREATE_TIME));
    MEMCPY_AN(CMMSEQPITM_N->UPDATE_USER_ID, CMMSEQPITM->UPDATE_USER_ID, sizeof(CMMSEQPITM->UPDATE_USER_ID));
    MEMCPY_AN(CMMSEQPITM_N->UPDATE_TIME, CMMSEQPITM->UPDATE_TIME, sizeof(CMMSEQPITM->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_cmmseqpitm(struct CMMSEQPITM_N_TAG *CMMSEQPITM_N, struct CMMSEQPITM_TAG *CMMSEQPITM)
{
    MEMCPY_DN(CMMSEQPITM->FACTORY, CMMSEQPITM_N->FACTORY, sizeof(CMMSEQPITM->FACTORY));
    MEMCPY_DN(CMMSEQPITM->EQUIP_ID, CMMSEQPITM_N->EQUIP_ID, sizeof(CMMSEQPITM->EQUIP_ID));
    MEMCPY_DN(CMMSEQPITM->ITEM_CODE, CMMSEQPITM_N->ITEM_CODE, sizeof(CMMSEQPITM->ITEM_CODE));
