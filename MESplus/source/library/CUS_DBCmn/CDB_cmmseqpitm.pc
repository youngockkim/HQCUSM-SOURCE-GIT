                FROM CMMSEQPITM
                ORDER BY FACTORY ASC,
                    EQUIP_ID ASC,
                    ITEM_CODE ASC;
            EXEC SQL OPEN CDB_CMMSEQPITM_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CMMSEQPITM_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    EQUIP_ID,
                    ITEM_CODE,
                    ITEM_NAME,
                    ITEM_SPEC,
                    ITEM_ORDER,
