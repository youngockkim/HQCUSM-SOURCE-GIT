                FROM CMMSEQPITM
			   WHERE FACTORY = :CMMSEQPITM_N.FACTORY
			     AND EQUIP_ID = :CMMSEQPITM_N.EQUIP_ID
				 AND USE_GRR_CONT_FLAG = (CASE WHEN TRIM(:CMMSEQPITM_N.USE_GRR_CONT_FLAG) = 'Y' THEN 'Y' ELSE USE_GRR_CONT_FLAG END)
