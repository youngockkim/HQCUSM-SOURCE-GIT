    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_iinvstktrs(&IINVSTKTRS_N, IINVSTKTRS);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM IINVSTKTRS
                WHERE DOC_ID = :IINVSTKTRS_N.DOC_ID
                    AND FR_SITE_ID = :IINVSTKTRS_N.FR_SITE_ID
                    AND FR_LOC_ID = :IINVSTKTRS_N.FR_LOC_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_iinvstktrs_scalar", sel_type);

    return d_value;
}


