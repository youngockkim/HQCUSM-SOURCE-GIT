                    AND FR_SITE_ID = :IINVSTKTRS_N.FR_SITE_ID
                    AND FR_LOC_ID = :IINVSTKTRS_N.FR_LOC_ID;
            break;

		case 2:
            EXEC SQL UPDATE IINVSTKTRS SET                   
                    INF_PROC_TIME = :IINVSTKTRS_N.INF_PROC_TIME,                    
                    RETURN_TYPE = 'E',
                    RETURN_MSG = :IINVSTKTRS_N.RETURN_MSG                   
                WHERE DOC_ID = :IINVSTKTRS_N.DOC_ID
                    AND FR_SITE_ID = :IINVSTKTRS_N.FR_SITE_ID
                    AND FR_LOC_ID = :IINVSTKTRS_N.FR_LOC_ID;
            break;

