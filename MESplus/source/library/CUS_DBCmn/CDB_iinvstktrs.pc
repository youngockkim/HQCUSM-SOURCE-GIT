/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_iinvstktrs(int sel_type, struct IINVSTKTRS_TAG *IINVSTKTRS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IINVSTKTRS_N_TAG IINVSTKTRS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_iinvstktrs(&IINVSTKTRS_N, IINVSTKTRS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IINVSTKTRS_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    FR_SITE_ID,
                    FR_LOC_ID,
                    POST_DATE,
                    TO_SITE_ID,
                    TO_LOC_ID,
                    MATE_NO,
