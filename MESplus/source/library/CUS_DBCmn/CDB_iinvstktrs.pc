                :IINVSTKTRS_N.CMF_2,
                :IINVSTKTRS_N.CMF_3,
                :IINVSTKTRS_N.CMF_4,
                :IINVSTKTRS_N.CMF_5,
                :IINVSTKTRS_N.DATA_FLAG,
                :IINVSTKTRS_N.UPDATE_COUNT,
                :IINVSTKTRS_N.INSERT_COUNT,
                :IINVSTKTRS_N.DELETE_COUNT,
                :IINVSTKTRS_N.SQL_DML_COUNT,
                :IINVSTKTRS_N.ZPICODE,
                :IINVSTKTRS_N.ZPIMSGID,
                :IINVSTKTRS_N.RETURN_TYPE,
                :IINVSTKTRS_N.RETURN_MSG,
                :IINVSTKTRS_N.ZIFERNAM,
                :IINVSTKTRS_N.ZIFDATE,
                :IINVSTKTRS_N.ZIFTIME,
                :IINVSTKTRS_N.ZPISTAT,
                :IINVSTKTRS_N.ZPIMSG;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_iinvstktrs(&IINVSTKTRS_N, IINVSTKTRS);
    }

    DB_stop_query_timer("CDB_fetch_iinvstktrs", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_iinvstktrs(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IINVSTKTRS_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IINVSTKTRS_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_iinvstktrs", sel_type);
}


/* Initialize Function */
void CDB_init_iinvstktrs(struct IINVSTKTRS_TAG *IINVSTKTRS)
{
    /* memset by Space */
    memset(IINVSTKTRS, ' ', sizeof(struct IINVSTKTRS_TAG));
    
}


