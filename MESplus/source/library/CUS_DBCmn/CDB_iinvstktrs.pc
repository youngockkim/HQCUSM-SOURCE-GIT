                    PUR_TYPE,
                    PUR_TYPE_DESC,
                    VEN_MATE_TYPE,
                    VEN_MATE_TYPE_DESC,
                    NM_PLATE_TYPE,
                    NM_PLATE_TYPE_DESC,
                    JB_WIRE_VENDOR,
                    JB_WIRE_VENDOR_DESC,
                    PACKAGE_TYPE,
                    PACKAGE_TYPE_DESC,
                    EXP_DATE,
                    VEN_LIFE,
                    VEN_ACC_NO,
                    VEN_ACC_NO_DESC,
                    REC_DATE,
                    REC_DESC,
                    JB_VENDOR,
                    JB_VENDOR_DESC,
                    PROCU_TYPE,
                    PROCU_TYPE_DESC,
                    PRODU_TYPE,
