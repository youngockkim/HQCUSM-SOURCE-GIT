                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IINVSTKTRS
                ORDER BY DOC_ID ASC,
                    FR_SITE_ID ASC,
                    FR_LOC_ID ASC;
            EXEC SQL OPEN CDB_IINVSTKTRS_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_IINVSTKTRS_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    FR_SITE_ID,
                    FR_LOC_ID,
                    POST_DATE,
                    TO_SITE_ID,
                    TO_LOC_ID,
                    MATE_NO,
                    QTY,
                    UNIT_ID,
                    BATCH_NO,
                    VEN_BATCH_NO,
                    MOV_TYPE,
                    PUR_ORDER_NO,
