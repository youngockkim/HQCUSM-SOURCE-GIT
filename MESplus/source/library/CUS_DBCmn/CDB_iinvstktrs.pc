/* Del Null Function */
void CDB_del_null_iinvstktrs(struct IINVSTKTRS_N_TAG *IINVSTKTRS_N, struct IINVSTKTRS_TAG *IINVSTKTRS)
{
    MEMCPY_DN(IINVSTKTRS->DOC_ID, IINVSTKTRS_N->DOC_ID, sizeof(IINVSTKTRS->DOC_ID));
    MEMCPY_DN(IINVSTKTRS->FR_SITE_ID, IINVSTKTRS_N->FR_SITE_ID, sizeof(IINVSTKTRS->FR_SITE_ID));
    MEMCPY_DN(IINVSTKTRS->FR_LOC_ID, IINVSTKTRS_N->FR_LOC_ID, sizeof(IINVSTKTRS->FR_LOC_ID));
    MEMCPY_DN(IINVSTKTRS->POST_DATE, IINVSTKTRS_N->POST_DATE, sizeof(IINVSTKTRS->POST_DATE));
    MEMCPY_DN(IINVSTKTRS->TO_SITE_ID, IINVSTKTRS_N->TO_SITE_ID, sizeof(IINVSTKTRS->TO_SITE_ID));
    MEMCPY_DN(IINVSTKTRS->TO_LOC_ID, IINVSTKTRS_N->TO_LOC_ID, sizeof(IINVSTKTRS->TO_LOC_ID));
    MEMCPY_DN(IINVSTKTRS->MATE_NO, IINVSTKTRS_N->MATE_NO, sizeof(IINVSTKTRS->MATE_NO));
    MEMCPY_DN(IINVSTKTRS->QTY, IINVSTKTRS_N->QTY, sizeof(IINVSTKTRS->QTY));
