                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IINVSTKTRS
				WHERE RETURN_TYPE <> 'E'
                ORDER BY DOC_ID ASC,
                    FR_SITE_ID ASC,
                    FR_LOC_ID ASC;
            EXEC SQL OPEN CDB_IINVSTKTRS_CUR_2;
            break;

        default:
            DB_error_code = 9999;
