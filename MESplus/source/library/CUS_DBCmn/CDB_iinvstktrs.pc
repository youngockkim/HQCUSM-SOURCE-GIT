                    PRO_ORDER,
                    PRO_ORDER_DESC,
                    PLANT,
                    PLANT_DESC,
                    PRO_LOCATION,
                    PRO_LOCATION_DESC,
                    DEL_YN,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
