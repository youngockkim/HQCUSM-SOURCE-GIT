/* Add Null Function */
void CDB_add_null_cedclotdat(struct CEDCLOTDAT_N_TAG *CEDCLOTDAT_N, struct CEDCLOTDAT_TAG *CEDCLOTDAT)
{
    /* memset by NULL */
    memset(CEDCLOTDAT_N, '\0', sizeof(struct CEDCLOTDAT_N_TAG));
    
    MEMCPY_AN(CEDCLOTDAT_N->LOT_ID, CEDCLOTDAT->LOT_ID, sizeof(CEDCLOTDAT->LOT_ID));
    MEMCPY_AN(CEDCLOTDAT_N->PARAM_NAME, CEDCLOTDAT->PARAM_NAME, sizeof(CEDCLOTDAT->PARAM_NAME));
    MEMCPY_AN(CEDCLOTDAT_N->TRAN_TIME, CEDCLOTDAT->TRAN_TIME, sizeof(CEDCLOTDAT->TRAN_TIME));
    CEDCLOTDAT_N->SEQ_NUM = CEDCLOTDAT->SEQ_NUM;
    MEMCPY_AN(CEDCLOTDAT_N->RES_ID, CEDCLOTDAT->RES_ID, sizeof(CEDCLOTDAT->RES_ID));
    MEMCPY_AN(CEDCLOTDAT_N->LINE_ID, CEDCLOTDAT->LINE_ID, sizeof(CEDCLOTDAT->LINE_ID));
    MEMCPY_AN(CEDCLOTDAT_N->OPER, CEDCLOTDAT->OPER, sizeof(CEDCLOTDAT->OPER));
    CEDCLOTDAT_N->LOT_HIST_SEQ = CEDCLOTDAT->LOT_HIST_SEQ;
    MEMCPY_AN(CEDCLOTDAT_N->PARAM_VALUE, CEDCLOTDAT->PARAM_VALUE, sizeof(CEDCLOTDAT->PARAM_VALUE));
    MEMCPY_AN(CEDCLOTDAT_N->SVID_NAME, CEDCLOTDAT->SVID_NAME, sizeof(CEDCLOTDAT->SVID_NAME));
    MEMCPY_AN(CEDCLOTDAT_N->SVID_VALUE, CEDCLOTDAT->SVID_VALUE, sizeof(CEDCLOTDAT->SVID_VALUE));
    CEDCLOTDAT_N->S_MAX_VALUE = CEDCLOTDAT->S_MAX_VALUE;
    CEDCLOTDAT_N->C_MAX_VALUE = CEDCLOTDAT->C_MAX_VALUE;
    CEDCLOTDAT_N->S_MIN_VALUE = CEDCLOTDAT->S_MIN_VALUE;
    CEDCLOTDAT_N->C_MIN_VALUE = CEDCLOTDAT->C_MIN_VALUE;
    CEDCLOTDAT_N->TYPE_FLAG[0] = CEDCLOTDAT->TYPE_FLAG;
    MEMCPY_AN(CEDCLOTDAT_N->CREATE_TIME, CEDCLOTDAT->CREATE_TIME, sizeof(CEDCLOTDAT->CREATE_TIME));
    MEMCPY_AN(CEDCLOTDAT_N->RCP_PP_ID, CEDCLOTDAT->RCP_PP_ID, sizeof(CEDCLOTDAT->RCP_PP_ID));
    MEMCPY_AN(CEDCLOTDAT_N->RCP_PARA_ID, CEDCLOTDAT->RCP_PARA_ID, sizeof(CEDCLOTDAT->RCP_PARA_ID));
    MEMCPY_AN(CEDCLOTDAT_N->RCP_VALUE, CEDCLOTDAT->RCP_VALUE, sizeof(CEDCLOTDAT->RCP_VALUE));
    MEMCPY_AN(CEDCLOTDAT_N->CMF_1, CEDCLOTDAT->CMF_1, sizeof(CEDCLOTDAT->CMF_1));
    MEMCPY_AN(CEDCLOTDAT_N->CMF_2, CEDCLOTDAT->CMF_2, sizeof(CEDCLOTDAT->CMF_2));
