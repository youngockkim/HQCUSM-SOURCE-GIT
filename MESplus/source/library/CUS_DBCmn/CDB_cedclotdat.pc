/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cedclotdat(int sel_type, struct CEDCLOTDAT_TAG *CEDCLOTDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CEDCLOTDAT_N_TAG CEDCLOTDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedclotdat(&CEDCLOTDAT_N, CEDCLOTDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CEDCLOTDAT_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    PARAM_NAME,
                    TRAN_TIME,
                    SEQ_NUM,
                    RES_ID,
                    LINE_ID,
                    OPER,
                    LOT_HIST_SEQ,
                    PARAM_VALUE,
                    SVID_NAME,
                    SVID_VALUE,
                    S_MAX_VALUE,
                    C_MAX_VALUE,
                    S_MIN_VALUE,
                    C_MIN_VALUE,
                    TYPE_FLAG,
                    CREATE_TIME,
                    RCP_PP_ID,
                    RCP_PARA_ID,
                    RCP_VALUE,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM CEDCLOTDAT
                ORDER BY LOT_ID ASC,
                    PARAM_NAME ASC,
                    TRAN_TIME ASC,
                    SEQ_NUM ASC;
            EXEC SQL OPEN CDB_CEDCLOTDAT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cedclotdat", sel_type);
}


