/* Del Null Function */
void CDB_del_null_cedclotdat(struct CEDCLOTDAT_N_TAG *CEDCLOTDAT_N, struct CEDCLOTDAT_TAG *CEDCLOTDAT)
{
    MEMCPY_DN(CEDCLOTDAT->LOT_ID, CEDCLOTDAT_N->LOT_ID, sizeof(CEDCLOTDAT->LOT_ID));
    MEMCPY_DN(CEDCLOTDAT->PARAM_NAME, CEDCLOTDAT_N->PARAM_NAME, sizeof(CEDCLOTDAT->PARAM_NAME));
    MEMCPY_DN(CEDCLOTDAT->TRAN_TIME, CEDCLOTDAT_N->TRAN_TIME, sizeof(CEDCLOTDAT->TRAN_TIME));
    CEDCLOTDAT->SEQ_NUM = CEDCLOTDAT_N->SEQ_NUM;
    MEMCPY_DN(CEDCLOTDAT->RES_ID, CEDCLOTDAT_N->RES_ID, sizeof(CEDCLOTDAT->RES_ID));
    MEMCPY_DN(CEDCLOTDAT->LINE_ID, CEDCLOTDAT_N->LINE_ID, sizeof(CEDCLOTDAT->LINE_ID));
    MEMCPY_DN(CEDCLOTDAT->OPER, CEDCLOTDAT_N->OPER, sizeof(CEDCLOTDAT->OPER));
    CEDCLOTDAT->LOT_HIST_SEQ = CEDCLOTDAT_N->LOT_HIST_SEQ;
    MEMCPY_DN(CEDCLOTDAT->PARAM_VALUE, CEDCLOTDAT_N->PARAM_VALUE, sizeof(CEDCLOTDAT->PARAM_VALUE));
    MEMCPY_DN(CEDCLOTDAT->SVID_NAME, CEDCLOTDAT_N->SVID_NAME, sizeof(CEDCLOTDAT->SVID_NAME));
    MEMCPY_DN(CEDCLOTDAT->SVID_VALUE, CEDCLOTDAT_N->SVID_VALUE, sizeof(CEDCLOTDAT->SVID_VALUE));
    CEDCLOTDAT->S_MAX_VALUE = CEDCLOTDAT_N->S_MAX_VALUE;
    CEDCLOTDAT->C_MAX_VALUE = CEDCLOTDAT_N->C_MAX_VALUE;
    CEDCLOTDAT->S_MIN_VALUE = CEDCLOTDAT_N->S_MIN_VALUE;
    CEDCLOTDAT->C_MIN_VALUE = CEDCLOTDAT_N->C_MIN_VALUE;
    CEDCLOTDAT->TYPE_FLAG = CEDCLOTDAT_N->TYPE_FLAG[0];
    MEMCPY_DN(CEDCLOTDAT->CREATE_TIME, CEDCLOTDAT_N->CREATE_TIME, sizeof(CEDCLOTDAT->CREATE_TIME));
    MEMCPY_DN(CEDCLOTDAT->RCP_PP_ID, CEDCLOTDAT_N->RCP_PP_ID, sizeof(CEDCLOTDAT->RCP_PP_ID));
    MEMCPY_DN(CEDCLOTDAT->RCP_PARA_ID, CEDCLOTDAT_N->RCP_PARA_ID, sizeof(CEDCLOTDAT->RCP_PARA_ID));
    MEMCPY_DN(CEDCLOTDAT->RCP_VALUE, CEDCLOTDAT_N->RCP_VALUE, sizeof(CEDCLOTDAT->RCP_VALUE));
    MEMCPY_DN(CEDCLOTDAT->CMF_1, CEDCLOTDAT_N->CMF_1, sizeof(CEDCLOTDAT->CMF_1));
    MEMCPY_DN(CEDCLOTDAT->CMF_2, CEDCLOTDAT_N->CMF_2, sizeof(CEDCLOTDAT->CMF_2));
    MEMCPY_DN(CEDCLOTDAT->CMF_3, CEDCLOTDAT_N->CMF_3, sizeof(CEDCLOTDAT->CMF_3));
    MEMCPY_DN(CEDCLOTDAT->CMF_4, CEDCLOTDAT_N->CMF_4, sizeof(CEDCLOTDAT->CMF_4));
    MEMCPY_DN(CEDCLOTDAT->CMF_5, CEDCLOTDAT_N->CMF_5, sizeof(CEDCLOTDAT->CMF_5));
}


