            sprintf(sSql + strlen(sSql), "       A.AVG_NCELL,\r\n");
            sprintf(sSql + strlen(sSql), "       A.MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(A.ORDER_ID) ORDER_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(A.LINE_ID) LINE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       NVL(MAX(TRIM(B.MAT_CMF_8)), 0) HCELL_AREA,\r\n");
            sprintf(sSql + strlen(sSql), "       COUNT(*) CELL_QTY,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(A.PMPP) PMPP,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(A.TRAN_TIME) TRAN_TIME,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(A.TRAN_DATE) TRAN_DATE,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(A.TRAN_SHIFT) TRAN_SHIFT,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(A.TRAN_HOUR) TRAN_HOUR,\r\n");
            sprintf(sSql + strlen(sSql), "       SYSDATE,\r\n");
            sprintf(sSql + strlen(sSql), "       :CREATE_USER_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       TO_CHAR(SYSDATE, 'YYYYMMDDHH24MISS')\r\n");
            sprintf(sSql + strlen(sSql), "  FROM (\r\n");
            sprintf(sSql + strlen(sSql), "        SELECT FACTORY, MODULE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               MAX(ORDER_ID) ORDER_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               MAX(LINE_ID) LINE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               MAX(TRAN_TIME) TRAN_TIME,\r\n");
            sprintf(sSql + strlen(sSql), "               MAX(TRAN_DATE) TRAN_DATE,\r\n");
            sprintf(sSql + strlen(sSql), "               MAX(TRAN_HOUR) TRAN_HOUR,\r\n");
            sprintf(sSql + strlen(sSql), "               MAX(TRAN_SHIFT) TRAN_SHIFT,\r\n");
            sprintf(sSql + strlen(sSql), "               MAX(PMPP) PMPP,\r\n");
            sprintf(sSql + strlen(sSql), "               MAX(AVG_NCELL) KEEP (DENSE_RANK LAST ORDER BY CREATE_TIME) AVG_NCELL\r\n");
            sprintf(sSql + strlen(sSql), "          FROM (\r\n");
            sprintf(sSql + strlen(sSql), "                SELECT /* ORDERE INDEX(F CINVCELRCV_PK) INDEX(K1 CDC_CWIPCELMGZ_P) */\r\n");
            sprintf(sSql + strlen(sSql), "                       D.FACTORY,\r\n");
            sprintf(sSql + strlen(sSql), "                       D.MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "                       B.CELL_ID,\r\n");
            sprintf(sSql + strlen(sSql), "                       D.LINE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "                       D.ORDER_ID,\r\n");
            sprintf(sSql + strlen(sSql), "                       K.VMAGAZINE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "                       K.CELL_BOX_ID,\r\n");
            sprintf(sSql + strlen(sSql), "                       D.CMF_1 TRAN_TIME,\r\n");
            sprintf(sSql + strlen(sSql), "                       E.SYS_DATE TRAN_DATE,\r\n");
            sprintf(sSql + strlen(sSql), "                       D.PMPP,\r\n");
            sprintf(sSql + strlen(sSql), "                       SUBSTR(D.CMF_1, 9, 2) TRAN_HOUR,\r\n");
            sprintf(sSql + strlen(sSql), "                       CASE WHEN SUBSTR(D.CMF_1, 9, 6) BETWEEN '060000' AND '175959' THEN E.CAL_CMF_1 ELSE E.CAL_CMF_2 END TRAN_SHIFT,\r\n");
            sprintf(sSql + strlen(sSql), "                       NVL(F.AVG_NCELL, 0) AVG_NCELL,\r\n");
            sprintf(sSql + strlen(sSql), "                       K.CREATE_TIME,\r\n");
            sprintf(sSql + strlen(sSql), "                       A.LOT_ID MODULE_ID\r\n");
            sprintf(sSql + strlen(sSql), "                  FROM CEDCLOTRLT D, CWIPLOTSTR A, CWIPSTRCEL B, CWIPCELLAM C, CWIPCELMGZ K, CINVCELRCV F, MWIPCALDEF E\r\n");
            sprintf(sSql + strlen(sSql), "                 WHERE D.INS_TYPE = 'SI'\r\n");
            sprintf(sSql + strlen(sSql), "                   AND D.FACTORY = :FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "                   AND D.LOT_ID = :LOT_ID\r\n");
            sprintf(sSql + strlen(sSql), "                   AND A.FACTORY = D.FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "                   AND A.LOT_ID = D.LOT_ID\r\n");
            sprintf(sSql + strlen(sSql), "                   AND D.FACTORY = E.CALENDAR_ID\r\n");
            sprintf(sSql + strlen(sSql), "                   AND E.SYS_DATE = TO_CHAR(TO_DATE(D.CMF_1, 'YYYYMMDDHH24MISS') - (6/24), 'YYYYMMDD')\r\n");
            sprintf(sSql + strlen(sSql), "                   AND A.FACTORY = B.FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "                   AND A.STRING_ID = B.STRING_ID\r\n");
            sprintf(sSql + strlen(sSql), "                   AND B.FACTORY = C.FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "                   AND B.CELL_ID = C.CELL_ID\r\n");
            sprintf(sSql + strlen(sSql), "                   AND C.FACTORY = K.FACTORY(+)\r\n");
            sprintf(sSql + strlen(sSql), "                   AND TRIM(C.VMAGAZINE_ID) = K.VMAGAZINE_ID(+)\r\n");
            sprintf(sSql + strlen(sSql), "                   AND K.FACTORY || ''  = F.FACTORY(+)\r\n");
            sprintf(sSql + strlen(sSql), "                   AND K.CELL_BOX_ID || '' = F.INV_LOT_ID(+)\r\n");
            sprintf(sSql + strlen(sSql), "                   AND F.AVG_NCELL > 0 \r\n");
            sprintf(sSql + strlen(sSql), "               )\r\n");
            sprintf(sSql + strlen(sSql), "         GROUP BY FACTORY, MODULE_ID, CELL_ID, MAT_ID\r\n");
            sprintf(sSql + strlen(sSql), "       ) A,\r\n");
            sprintf(sSql + strlen(sSql), "       MWIPMATDEF B\r\n");
            sprintf(sSql + strlen(sSql), " WHERE A.FACTORY = B.FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "   AND A.MAT_ID = B.MAT_ID\r\n");
            sprintf(sSql + strlen(sSql), " GROUP BY A.FACTORY, MODULE_ID, AVG_NCELL, A.MAT_ID\r\n");

            EXEC SQL PREPARE S FROM :sSql; 
            EXEC SQL EXECUTE S USING :RSUMMDLNCL_N.CREATE_USER_ID, :RSUMMDLNCL_N.FACTORY, :RSUMMDLNCL_N.MODULE_ID;

            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_insert_rsummdlncl", 0);
}


