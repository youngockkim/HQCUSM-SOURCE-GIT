                    MNC_CMF_1 = :RSUMMDLNCL_N.MNC_CMF_1,
                    MNC_CMF_2 = :RSUMMDLNCL_N.MNC_CMF_2,
                    MNC_CMF_3 = :RSUMMDLNCL_N.MNC_CMF_3,
                    MNC_CMF_4 = :RSUMMDLNCL_N.MNC_CMF_4,
                    MNC_CMF_5 = :RSUMMDLNCL_N.MNC_CMF_5,
                    MNC_CMF_6 = :RSUMMDLNCL_N.MNC_CMF_6,
                    MNC_CMF_7 = :RSUMMDLNCL_N.MNC_CMF_7,
                    MNC_CMF_8 = :RSUMMDLNCL_N.MNC_CMF_8,
                    MNC_CMF_9 = :RSUMMDLNCL_N.MNC_CMF_9,
                    MNC_CMF_10 = :RSUMMDLNCL_N.MNC_CMF_10,
                    PARTITION_KEY = TO_DATE(:RSUMMDLNCL_N.PARTITION_KEY, 'YYYYMMDDHH24MISS'),
                    CREATE_USER_ID = :RSUMMDLNCL_N.CREATE_USER_ID,
                    CREATE_TIME = :RSUMMDLNCL_N.CREATE_TIME,
                    UPDATE_USER_ID = :RSUMMDLNCL_N.UPDATE_USER_ID,
                    UPDATE_TIME = :RSUMMDLNCL_N.UPDATE_TIME
                WHERE FACTORY = :RSUMMDLNCL_N.FACTORY
                    AND MODULE_ID = :RSUMMDLNCL_N.MODULE_ID
                    AND AVG_NCELL = :RSUMMDLNCL_N.AVG_NCELL;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_rsummdlncl", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_rsummdlncl(int sel_type, struct RSUMMDLNCL_TAG *RSUMMDLNCL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMMDLNCL_N_TAG RSUMMDLNCL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsummdlncl(&RSUMMDLNCL_N, RSUMMDLNCL);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_RSUMMDLNCL_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    MODULE_ID,
                    AVG_NCELL,
                    MAT_ID,
                    ORDER_ID,
                    LINE_ID,
                    HCELL_AREA,
                    CELL_QTY,
                    PMPP,
                    OFF_SET,
                    TRAN_TIME,
                    TRAN_DATE,
                    TRAN_SHIFT,
                    TRAN_HOUR,
                    MNC_CMF_1,
                    MNC_CMF_2,
                    MNC_CMF_3,
                    MNC_CMF_4,
                    MNC_CMF_5,
                    MNC_CMF_6,
                    MNC_CMF_7,
                    MNC_CMF_8,
                    MNC_CMF_9,
                    MNC_CMF_10,
                    TO_CHAR(PARTITION_KEY, 'YYYYMMDDHH24MISS'),
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM RSUMMDLNCL
                ORDER BY FACTORY ASC,
                    MODULE_ID ASC,
                    AVG_NCELL ASC;
            EXEC SQL OPEN CDB_RSUMMDLNCL_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_rsummdlncl", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_rsummdlncl(int sel_type, struct RSUMMDLNCL_TAG *RSUMMDLNCL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMMDLNCL_N_TAG RSUMMDLNCL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_RSUMMDLNCL_CUR_1 INTO
                :RSUMMDLNCL_N.FACTORY,
                :RSUMMDLNCL_N.MODULE_ID,
                :RSUMMDLNCL_N.AVG_NCELL,
                :RSUMMDLNCL_N.MAT_ID,
                :RSUMMDLNCL_N.ORDER_ID,
                :RSUMMDLNCL_N.LINE_ID,
                :RSUMMDLNCL_N.HCELL_AREA,
                :RSUMMDLNCL_N.CELL_QTY,
                :RSUMMDLNCL_N.PMPP,
                :RSUMMDLNCL_N.OFF_SET,
                :RSUMMDLNCL_N.TRAN_TIME,
                :RSUMMDLNCL_N.TRAN_DATE,
                :RSUMMDLNCL_N.TRAN_SHIFT,
                :RSUMMDLNCL_N.TRAN_HOUR,
                :RSUMMDLNCL_N.MNC_CMF_1,
                :RSUMMDLNCL_N.MNC_CMF_2,
                :RSUMMDLNCL_N.MNC_CMF_3,
                :RSUMMDLNCL_N.MNC_CMF_4,
                :RSUMMDLNCL_N.MNC_CMF_5,
                :RSUMMDLNCL_N.MNC_CMF_6,
                :RSUMMDLNCL_N.MNC_CMF_7,
                :RSUMMDLNCL_N.MNC_CMF_8,
                :RSUMMDLNCL_N.MNC_CMF_9,
                :RSUMMDLNCL_N.MNC_CMF_10,
                :RSUMMDLNCL_N.PARTITION_KEY,
                :RSUMMDLNCL_N.CREATE_USER_ID,
                :RSUMMDLNCL_N.CREATE_TIME,
                :RSUMMDLNCL_N.UPDATE_USER_ID,
                :RSUMMDLNCL_N.UPDATE_TIME;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_rsummdlncl(&RSUMMDLNCL_N, RSUMMDLNCL);
    }

    DB_stop_query_timer("CDB_fetch_rsummdlncl", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_rsummdlncl(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_RSUMMDLNCL_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_rsummdlncl", sel_type);
}


/* Initialize Function */
void CDB_init_rsummdlncl(struct RSUMMDLNCL_TAG *RSUMMDLNCL)
{
    /* memset by Space */
    memset(RSUMMDLNCL, ' ', sizeof(struct RSUMMDLNCL_TAG));
    
    RSUMMDLNCL->AVG_NCELL = 0;
    RSUMMDLNCL->HCELL_AREA = 0;
    RSUMMDLNCL->CELL_QTY = 0;
    RSUMMDLNCL->OFF_SET = 0;
}


/* Add Null Function */
void CDB_add_null_rsummdlncl(struct RSUMMDLNCL_N_TAG *RSUMMDLNCL_N, struct RSUMMDLNCL_TAG *RSUMMDLNCL)
{
    /* memset by NULL */
    memset(RSUMMDLNCL_N, '\0', sizeof(struct RSUMMDLNCL_N_TAG));
    
    MEMCPY_AN(RSUMMDLNCL_N->FACTORY, RSUMMDLNCL->FACTORY, sizeof(RSUMMDLNCL->FACTORY));
    MEMCPY_AN(RSUMMDLNCL_N->MODULE_ID, RSUMMDLNCL->MODULE_ID, sizeof(RSUMMDLNCL->MODULE_ID));
    RSUMMDLNCL_N->AVG_NCELL = RSUMMDLNCL->AVG_NCELL;
    MEMCPY_AN(RSUMMDLNCL_N->MAT_ID, RSUMMDLNCL->MAT_ID, sizeof(RSUMMDLNCL->MAT_ID));
    MEMCPY_AN(RSUMMDLNCL_N->ORDER_ID, RSUMMDLNCL->ORDER_ID, sizeof(RSUMMDLNCL->ORDER_ID));
    MEMCPY_AN(RSUMMDLNCL_N->LINE_ID, RSUMMDLNCL->LINE_ID, sizeof(RSUMMDLNCL->LINE_ID));
    RSUMMDLNCL_N->HCELL_AREA = RSUMMDLNCL->HCELL_AREA;
    RSUMMDLNCL_N->CELL_QTY = RSUMMDLNCL->CELL_QTY;
    MEMCPY_AN(RSUMMDLNCL_N->PMPP, RSUMMDLNCL->PMPP, sizeof(RSUMMDLNCL->PMPP));
    RSUMMDLNCL_N->OFF_SET = RSUMMDLNCL->OFF_SET;
    MEMCPY_AN(RSUMMDLNCL_N->TRAN_TIME, RSUMMDLNCL->TRAN_TIME, sizeof(RSUMMDLNCL->TRAN_TIME));
    MEMCPY_AN(RSUMMDLNCL_N->TRAN_DATE, RSUMMDLNCL->TRAN_DATE, sizeof(RSUMMDLNCL->TRAN_DATE));
    MEMCPY_AN(RSUMMDLNCL_N->TRAN_SHIFT, RSUMMDLNCL->TRAN_SHIFT, sizeof(RSUMMDLNCL->TRAN_SHIFT));
    MEMCPY_AN(RSUMMDLNCL_N->TRAN_HOUR, RSUMMDLNCL->TRAN_HOUR, sizeof(RSUMMDLNCL->TRAN_HOUR));
    MEMCPY_AN(RSUMMDLNCL_N->MNC_CMF_1, RSUMMDLNCL->MNC_CMF_1, sizeof(RSUMMDLNCL->MNC_CMF_1));
    MEMCPY_AN(RSUMMDLNCL_N->MNC_CMF_2, RSUMMDLNCL->MNC_CMF_2, sizeof(RSUMMDLNCL->MNC_CMF_2));
    MEMCPY_AN(RSUMMDLNCL_N->MNC_CMF_3, RSUMMDLNCL->MNC_CMF_3, sizeof(RSUMMDLNCL->MNC_CMF_3));
    MEMCPY_AN(RSUMMDLNCL_N->MNC_CMF_4, RSUMMDLNCL->MNC_CMF_4, sizeof(RSUMMDLNCL->MNC_CMF_4));
    MEMCPY_AN(RSUMMDLNCL_N->MNC_CMF_5, RSUMMDLNCL->MNC_CMF_5, sizeof(RSUMMDLNCL->MNC_CMF_5));
    MEMCPY_AN(RSUMMDLNCL_N->MNC_CMF_6, RSUMMDLNCL->MNC_CMF_6, sizeof(RSUMMDLNCL->MNC_CMF_6));
    MEMCPY_AN(RSUMMDLNCL_N->MNC_CMF_7, RSUMMDLNCL->MNC_CMF_7, sizeof(RSUMMDLNCL->MNC_CMF_7));
    MEMCPY_AN(RSUMMDLNCL_N->MNC_CMF_8, RSUMMDLNCL->MNC_CMF_8, sizeof(RSUMMDLNCL->MNC_CMF_8));
    MEMCPY_AN(RSUMMDLNCL_N->MNC_CMF_9, RSUMMDLNCL->MNC_CMF_9, sizeof(RSUMMDLNCL->MNC_CMF_9));
    MEMCPY_AN(RSUMMDLNCL_N->MNC_CMF_10, RSUMMDLNCL->MNC_CMF_10, sizeof(RSUMMDLNCL->MNC_CMF_10));
    MEMCPY_AN(RSUMMDLNCL_N->PARTITION_KEY, RSUMMDLNCL->PARTITION_KEY, sizeof(RSUMMDLNCL->PARTITION_KEY));
    MEMCPY_AN(RSUMMDLNCL_N->CREATE_USER_ID, RSUMMDLNCL->CREATE_USER_ID, sizeof(RSUMMDLNCL->CREATE_USER_ID));
    MEMCPY_AN(RSUMMDLNCL_N->CREATE_TIME, RSUMMDLNCL->CREATE_TIME, sizeof(RSUMMDLNCL->CREATE_TIME));
    MEMCPY_AN(RSUMMDLNCL_N->UPDATE_USER_ID, RSUMMDLNCL->UPDATE_USER_ID, sizeof(RSUMMDLNCL->UPDATE_USER_ID));
    MEMCPY_AN(RSUMMDLNCL_N->UPDATE_TIME, RSUMMDLNCL->UPDATE_TIME, sizeof(RSUMMDLNCL->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_rsummdlncl(struct RSUMMDLNCL_N_TAG *RSUMMDLNCL_N, struct RSUMMDLNCL_TAG *RSUMMDLNCL)
{
    MEMCPY_DN(RSUMMDLNCL->FACTORY, RSUMMDLNCL_N->FACTORY, sizeof(RSUMMDLNCL->FACTORY));
    MEMCPY_DN(RSUMMDLNCL->MODULE_ID, RSUMMDLNCL_N->MODULE_ID, sizeof(RSUMMDLNCL->MODULE_ID));
    RSUMMDLNCL->AVG_NCELL = RSUMMDLNCL_N->AVG_NCELL;
    MEMCPY_DN(RSUMMDLNCL->MAT_ID, RSUMMDLNCL_N->MAT_ID, sizeof(RSUMMDLNCL->MAT_ID));
    MEMCPY_DN(RSUMMDLNCL->ORDER_ID, RSUMMDLNCL_N->ORDER_ID, sizeof(RSUMMDLNCL->ORDER_ID));
