    MEMCPY_DN(RSUMMDLNCL->PMPP, RSUMMDLNCL_N->PMPP, sizeof(RSUMMDLNCL->PMPP));
    RSUMMDLNCL->OFF_SET = RSUMMDLNCL_N->OFF_SET;
    MEMCPY_DN(RSUMMDLNCL->TRAN_TIME, RSUMMDLNCL_N->TRAN_TIME, sizeof(RSUMMDLNCL->TRAN_TIME));
    MEMCPY_DN(RSUMMDLNCL->TRAN_DATE, RSUMMDLNCL_N->TRAN_DATE, sizeof(RSUMMDLNCL->TRAN_DATE));
    MEMCPY_DN(RSUMMDLNCL->TRAN_SHIFT, RSUMMDLNCL_N->TRAN_SHIFT, sizeof(RSUMMDLNCL->TRAN_SHIFT));
