    MEMCPY_DN(RSUMMDLNCL->MNC_CMF_2, RSUMMDLNCL_N->MNC_CMF_2, sizeof(RSUMMDLNCL->MNC_CMF_2));
    MEMCPY_DN(RSUMMDLNCL->MNC_CMF_3, RSUMMDLNCL_N->MNC_CMF_3, sizeof(RSUMMDLNCL->MNC_CMF_3));
    MEMCPY_DN(RSUMMDLNCL->MNC_CMF_4, RSUMMDLNCL_N->MNC_CMF_4, sizeof(RSUMMDLNCL->MNC_CMF_4));
    MEMCPY_DN(RSUMMDLNCL->MNC_CMF_5, RSUMMDLNCL_N->MNC_CMF_5, sizeof(RSUMMDLNCL->MNC_CMF_5));
    MEMCPY_DN(RSUMMDLNCL->MNC_CMF_6, RSUMMDLNCL_N->MNC_CMF_6, sizeof(RSUMMDLNCL->MNC_CMF_6));
    MEMCPY_DN(RSUMMDLNCL->MNC_CMF_7, RSUMMDLNCL_N->MNC_CMF_7, sizeof(RSUMMDLNCL->MNC_CMF_7));
    MEMCPY_DN(RSUMMDLNCL->MNC_CMF_8, RSUMMDLNCL_N->MNC_CMF_8, sizeof(RSUMMDLNCL->MNC_CMF_8));
    MEMCPY_DN(RSUMMDLNCL->MNC_CMF_9, RSUMMDLNCL_N->MNC_CMF_9, sizeof(RSUMMDLNCL->MNC_CMF_9));
    MEMCPY_DN(RSUMMDLNCL->MNC_CMF_10, RSUMMDLNCL_N->MNC_CMF_10, sizeof(RSUMMDLNCL->MNC_CMF_10));
    MEMCPY_DN(RSUMMDLNCL->PARTITION_KEY, RSUMMDLNCL_N->PARTITION_KEY, sizeof(RSUMMDLNCL->PARTITION_KEY));
    MEMCPY_DN(RSUMMDLNCL->CREATE_USER_ID, RSUMMDLNCL_N->CREATE_USER_ID, sizeof(RSUMMDLNCL->CREATE_USER_ID));
    MEMCPY_DN(RSUMMDLNCL->CREATE_TIME, RSUMMDLNCL_N->CREATE_TIME, sizeof(RSUMMDLNCL->CREATE_TIME));
    MEMCPY_DN(RSUMMDLNCL->UPDATE_USER_ID, RSUMMDLNCL_N->UPDATE_USER_ID, sizeof(RSUMMDLNCL->UPDATE_USER_ID));
