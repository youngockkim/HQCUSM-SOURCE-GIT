                    GRADE_1_DESC = :IBAKSTKTRS_N.GRADE_1_DESC,
                    POWER_GRADE_2 = :IBAKSTKTRS_N.POWER_GRADE_2,
                    GRADE_2_DESC = :IBAKSTKTRS_N.GRADE_2_DESC,
