/* SQL CURSOR CLOSE Function */
void CDB_close_ibakstktrs(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IBAKSTKTRS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ibakstktrs", sel_type);
}


/* Initialize Function */
void CDB_init_ibakstktrs(struct IBAKSTKTRS_TAG *IBAKSTKTRS)
{
    /* memset by Space */
    memset(IBAKSTKTRS, ' ', sizeof(struct IBAKSTKTRS_TAG));
    
}


/* Add Null Function */
void CDB_add_null_ibakstktrs(struct IBAKSTKTRS_N_TAG *IBAKSTKTRS_N, struct IBAKSTKTRS_TAG *IBAKSTKTRS)
{
    /* memset by NULL */
    memset(IBAKSTKTRS_N, '\0', sizeof(struct IBAKSTKTRS_N_TAG));
    
    MEMCPY_AN(IBAKSTKTRS_N->DOC_ID, IBAKSTKTRS->DOC_ID, sizeof(IBAKSTKTRS->DOC_ID));
