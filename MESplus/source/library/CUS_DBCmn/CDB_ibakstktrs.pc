                    PRODU_TYPE = :IBAKSTKTRS_N.PRODU_TYPE,
                    PRODU_TYPE_DESC = :IBAKSTKTRS_N.PRODU_TYPE_DESC,
                    QGRADE = :IBAKSTKTRS_N.QGRADE,
