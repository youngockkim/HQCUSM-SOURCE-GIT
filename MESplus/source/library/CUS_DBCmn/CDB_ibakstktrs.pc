                    PRO_LOCATION_DESC = :IBAKSTKTRS_N.PRO_LOCATION_DESC,
                    DEL_YN = :IBAKSTKTRS_N.DEL_YN,
                    INF_TIME = :IBAKSTKTRS_N.INF_TIME,
                    INF_PROC_TIME = :IBAKSTKTRS_N.INF_PROC_TIME,
                    CMF_1 = :IBAKSTKTRS_N.CMF_1,
                    CMF_2 = :IBAKSTKTRS_N.CMF_2,
                    CMF_3 = :IBAKSTKTRS_N.CMF_3,
                    CMF_4 = :IBAKSTKTRS_N.CMF_4,
                    CMF_5 = :IBAKSTKTRS_N.CMF_5,
                    DATA_FLAG = :IBAKSTKTRS_N.DATA_FLAG,
                    UPDATE_COUNT = :IBAKSTKTRS_N.UPDATE_COUNT,
                    INSERT_COUNT = :IBAKSTKTRS_N.INSERT_COUNT,
                    DELETE_COUNT = :IBAKSTKTRS_N.DELETE_COUNT,
                    SQL_DML_COUNT = :IBAKSTKTRS_N.SQL_DML_COUNT,
                    ZPICODE = :IBAKSTKTRS_N.ZPICODE,
                    ZPIMSGID = :IBAKSTKTRS_N.ZPIMSGID,
                    RETURN_TYPE = :IBAKSTKTRS_N.RETURN_TYPE,
                    RETURN_MSG = :IBAKSTKTRS_N.RETURN_MSG,
                    ZIFERNAM = :IBAKSTKTRS_N.ZIFERNAM,
                    ZIFDATE = :IBAKSTKTRS_N.ZIFDATE,
                    ZIFTIME = :IBAKSTKTRS_N.ZIFTIME,
                    ZPISTAT = :IBAKSTKTRS_N.ZPISTAT,
                    ZPIMSG = :IBAKSTKTRS_N.ZPIMSG
                WHERE DOC_ID = :IBAKSTKTRS_N.DOC_ID
                    AND FR_SITE_ID = :IBAKSTKTRS_N.FR_SITE_ID
                    AND FR_LOC_ID = :IBAKSTKTRS_N.FR_LOC_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_ibakstktrs", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_ibakstktrs(int sel_type, struct IBAKSTKTRS_TAG *IBAKSTKTRS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IBAKSTKTRS_N_TAG IBAKSTKTRS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ibakstktrs(&IBAKSTKTRS_N, IBAKSTKTRS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IBAKSTKTRS_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    FR_SITE_ID,
                    FR_LOC_ID,
                    POST_DATE,
                    TO_SITE_ID,
                    TO_LOC_ID,
                    MATE_NO,
                    QTY,
                    UNIT_ID,
                    BATCH_NO,
                    VEN_BATCH_NO,
                    MOV_TYPE,
                    PUR_ORDER_NO,
                    PUR_ORDER_DESC,
                    HANDBOOK,
                    HANDBOOK_DESC,
                    PUR_TYPE,
                    PUR_TYPE_DESC,
                    VEN_MATE_TYPE,
                    VEN_MATE_TYPE_DESC,
                    NM_PLATE_TYPE,
                    NM_PLATE_TYPE_DESC,
                    JB_WIRE_VENDOR,
                    JB_WIRE_VENDOR_DESC,
                    PACKAGE_TYPE,
                    PACKAGE_TYPE_DESC,
                    EXP_DATE,
                    VEN_LIFE,
                    VEN_ACC_NO,
                    VEN_ACC_NO_DESC,
                    REC_DATE,
                    REC_DESC,
                    JB_VENDOR,
                    JB_VENDOR_DESC,
                    PROCU_TYPE,
                    PROCU_TYPE_DESC,
                    PRODU_TYPE,
                    PRODU_TYPE_DESC,
                    QGRADE,
                    QGRADE_DESC,
                    POWER_GRADE_1,
                    GRADE_1_DESC,
                    POWER_GRADE_2,
                    GRADE_2_DESC,
                    CON_RATE,
                    CON_RATE_DESC,
                    POWER_RATE,
                    POWER_RATE_DESC,
                    COLOR,
                    COLOR_DESC,
                    QC_BOL,
                    QC_BOL_DESC,
                    PRO_ORDER,
                    PRO_ORDER_DESC,
                    PLANT,
                    PLANT_DESC,
                    PRO_LOCATION,
                    PRO_LOCATION_DESC,
                    DEL_YN,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IBAKSTKTRS
                ORDER BY DOC_ID ASC,
                    FR_SITE_ID ASC,
                    FR_LOC_ID ASC;
            EXEC SQL OPEN CDB_IBAKSTKTRS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_ibakstktrs", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_ibakstktrs(int sel_type, struct IBAKSTKTRS_TAG *IBAKSTKTRS)
{
    EXEC SQL BEGIN DECLARE SECTION;
