                    POWER_RATE = :IBAKSTKTRS_N.POWER_RATE,
                    POWER_RATE_DESC = :IBAKSTKTRS_N.POWER_RATE_DESC,
                    COLOR = :IBAKSTKTRS_N.COLOR,
                    COLOR_DESC = :IBAKSTKTRS_N.COLOR_DESC,
                    QC_BOL = :IBAKSTKTRS_N.QC_BOL,
                    QC_BOL_DESC = :IBAKSTKTRS_N.QC_BOL_DESC,
                    PRO_ORDER = :IBAKSTKTRS_N.PRO_ORDER,
                    PRO_ORDER_DESC = :IBAKSTKTRS_N.PRO_ORDER_DESC,
                    PLANT = :IBAKSTKTRS_N.PLANT,
                    PLANT_DESC = :IBAKSTKTRS_N.PLANT_DESC,
