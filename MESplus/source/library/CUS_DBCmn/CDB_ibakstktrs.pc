         );

    DB_stop_query_timer("CDB_insert_ibakstktrs", 0);
}


/* SQL UPDATE Function */
void CDB_update_ibakstktrs(int sel_type, struct IBAKSTKTRS_TAG *IBAKSTKTRS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IBAKSTKTRS_N_TAG IBAKSTKTRS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ibakstktrs(&IBAKSTKTRS_N, IBAKSTKTRS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE IBAKSTKTRS SET
                    POST_DATE = :IBAKSTKTRS_N.POST_DATE,
                    TO_SITE_ID = :IBAKSTKTRS_N.TO_SITE_ID,
                    TO_LOC_ID = :IBAKSTKTRS_N.TO_LOC_ID,
