                    PACKAGE_TYPE_DESC = :IBAKSTKTRS_N.PACKAGE_TYPE_DESC,
                    EXP_DATE = :IBAKSTKTRS_N.EXP_DATE,
                    VEN_LIFE = :IBAKSTKTRS_N.VEN_LIFE,
                    VEN_ACC_NO = :IBAKSTKTRS_N.VEN_ACC_NO,
                    VEN_ACC_NO_DESC = :IBAKSTKTRS_N.VEN_ACC_NO_DESC,
