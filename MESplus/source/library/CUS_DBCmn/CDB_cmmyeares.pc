    MEMCPY_DN(CMMYEARES->CMF_9, CMMYEARES_N->CMF_9, sizeof(CMMYEARES->CMF_9));
    MEMCPY_DN(CMMYEARES->CMF_10, CMMYEARES_N->CMF_10, sizeof(CMMYEARES->CMF_10));
    MEMCPY_DN(CMMYEARES->CREATE_USER_ID, CMMYEARES_N->CREATE_USER_ID, sizeof(CMMYEARES->CREATE_USER_ID));
    MEMCPY_DN(CMMYEARES->CREATE_TIME, CMMYEARES_N->CREATE_TIME, sizeof(CMMYEARES->CREATE_TIME));
    MEMCPY_DN(CMMYEARES->UPDATE_USER_ID, CMMYEARES_N->UPDATE_USER_ID, sizeof(CMMYEARES->UPDATE_USER_ID));
    MEMCPY_DN(CMMYEARES->UPDATE_TIME, CMMYEARES_N->UPDATE_TIME, sizeof(CMMYEARES->UPDATE_TIME));
}


