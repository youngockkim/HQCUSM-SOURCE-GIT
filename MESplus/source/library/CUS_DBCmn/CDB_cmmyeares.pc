/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cmmyeares(int sel_type, struct CMMYEARES_TAG *CMMYEARES)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMMYEARES_N_TAG CMMYEARES_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cmmyeares(&CMMYEARES_N, CMMYEARES);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CMMYEARES_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    DOC_ID,
                    RESULT_YEAR,
                    RESULT_TYPE,
                    ANA_DIV,
                    DEPT_CODE,
                    FILE_NAME,
                    FILE_PATH,
                    PF_FLAG,
                    COMMENTS,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMYEARES
				WHERE FACTORY = :CMMYEARES_N.FACTORY
				  AND RESULT_YEAR = :CMMYEARES_N.RESULT_YEAR
				  AND RESULT_TYPE LIKE '%' || TRIM(:CMMYEARES_N.RESULT_TYPE) || '%'
				  AND ANA_DIV LIKE '%' || TRIM(:CMMYEARES_N.ANA_DIV) || '%'
				  AND DEPT_CODE LIKE '%' || TRIM(:CMMYEARES_N.DEPT_CODE) || '%'
                ORDER BY FACTORY ASC,
                    DOC_ID ASC,
                    RESULT_YEAR ASC;
            EXEC SQL OPEN CDB_CMMYEARES_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cmmyeares", sel_type);
}


