                SELECT 
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    OPT_FLOW_GROUP,
                    OPT_FLOW_OPTION_FLAG,
                    FLOW_SEQ_NUM,
