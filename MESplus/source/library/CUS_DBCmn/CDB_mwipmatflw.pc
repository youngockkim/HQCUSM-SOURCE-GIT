/* Add Null Function */
void CDB_add_null_mwipmatflw(struct MWIPMATFLW_N_TAG *MWIPMATFLW_N, struct MWIPMATFLW_TAG *MWIPMATFLW)
{
    /* memset by NULL */
    memset(MWIPMATFLW_N, '\0', sizeof(struct MWIPMATFLW_N_TAG));
    
    MEMCPY_AN(MWIPMATFLW_N->FACTORY, MWIPMATFLW->FACTORY, sizeof(MWIPMATFLW->FACTORY));
    MEMCPY_AN(MWIPMATFLW_N->MAT_ID, MWIPMATFLW->MAT_ID, sizeof(MWIPMATFLW->MAT_ID));
    MWIPMATFLW_N->MAT_VER = MWIPMATFLW->MAT_VER;
    MEMCPY_AN(MWIPMATFLW_N->FLOW, MWIPMATFLW->FLOW, sizeof(MWIPMATFLW->FLOW));
    MEMCPY_AN(MWIPMATFLW_N->OPT_FLOW_GROUP, MWIPMATFLW->OPT_FLOW_GROUP, sizeof(MWIPMATFLW->OPT_FLOW_GROUP));
    MWIPMATFLW_N->OPT_FLOW_OPTION_FLAG[0] = MWIPMATFLW->OPT_FLOW_OPTION_FLAG;
    MWIPMATFLW_N->FLOW_SEQ_NUM = MWIPMATFLW->FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPMATFLW_N->PREV_FLOW, MWIPMATFLW->PREV_FLOW, sizeof(MWIPMATFLW->PREV_FLOW));
    MWIPMATFLW_N->PREV_FLOW_SEQ_NUM = MWIPMATFLW->PREV_FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPMATFLW_N->NEXT_FLOW, MWIPMATFLW->NEXT_FLOW, sizeof(MWIPMATFLW->NEXT_FLOW));
    MWIPMATFLW_N->NEXT_FLOW_SEQ_NUM = MWIPMATFLW->NEXT_FLOW_SEQ_NUM;
    MEMCPY_AN(MWIPMATFLW_N->CREATE_USER_ID, MWIPMATFLW->CREATE_USER_ID, sizeof(MWIPMATFLW->CREATE_USER_ID));
    MEMCPY_AN(MWIPMATFLW_N->CREATE_TIME, MWIPMATFLW->CREATE_TIME, sizeof(MWIPMATFLW->CREATE_TIME));
    MEMCPY_AN(MWIPMATFLW_N->UPDATE_USER_ID, MWIPMATFLW->UPDATE_USER_ID, sizeof(MWIPMATFLW->UPDATE_USER_ID));
    MEMCPY_AN(MWIPMATFLW_N->UPDATE_TIME, MWIPMATFLW->UPDATE_TIME, sizeof(MWIPMATFLW->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_mwipmatflw(struct MWIPMATFLW_N_TAG *MWIPMATFLW_N, struct MWIPMATFLW_TAG *MWIPMATFLW)
{
    MEMCPY_DN(MWIPMATFLW->FACTORY, MWIPMATFLW_N->FACTORY, sizeof(MWIPMATFLW->FACTORY));
    MEMCPY_DN(MWIPMATFLW->MAT_ID, MWIPMATFLW_N->MAT_ID, sizeof(MWIPMATFLW->MAT_ID));
    MWIPMATFLW->MAT_VER = MWIPMATFLW_N->MAT_VER;
