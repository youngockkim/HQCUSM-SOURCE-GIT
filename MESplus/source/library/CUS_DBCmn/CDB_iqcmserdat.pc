/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_iqcmserdat(int sel_type, struct IQCMSERDAT_TAG *IQCMSERDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IQCMSERDAT_N_TAG IQCMSERDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_iqcmserdat(&IQCMSERDAT_N, IQCMSERDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IQCMSERDAT_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    Z_GROUP,
                    MODULE_ID,
                    ACTION_TYPE,
                    PROD_ORDER_NO,
                    MATE_NO,
                    QC_INSPECTION,
                    STORAGE_LOCATION,
                    LOCATION,
                    SHIFT,
                    QUALITY_GRADE,
                    POWER_GRADE,
                    FQC_DEFECTCODE,
                    DIST_ID,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    INF_TIME,
                    INF_PROC_TIME,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZPICODE,
                    ZPIMSGID,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IQCMSERDAT
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    Z_GROUP ASC,
                    MODULE_ID ASC;
            EXEC SQL OPEN CDB_IQCMSERDAT_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_IQCMSERDAT_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    Z_GROUP,
                    MODULE_ID,
                    ACTION_TYPE,
                    PROD_ORDER_NO,
                    MATE_NO,
                    QC_INSPECTION,
                    STORAGE_LOCATION,
                    LOCATION,
                    SHIFT,
                    QUALITY_GRADE,
                    POWER_GRADE,
                    FQC_DEFECTCODE,
                    DIST_ID,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    INF_TIME,
                    INF_PROC_TIME,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZPICODE,
                    ZPIMSGID,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IQCMSERDAT
			WHERE RETURN_TYPE <> 'E'
			  AND QC_INSPECTION IN ('Q', 'C') /* 23.4.18 Add reject oqc test 'C' */
             ORDER BY DOC_ID ASC,SITE_ID ASC,MODULE_ID ASC;
            EXEC SQL OPEN CDB_IQCMSERDAT_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_IQCMSERDAT_CUR_3 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    Z_GROUP,
                    MODULE_ID,
                    ACTION_TYPE,
                    PROD_ORDER_NO,
                    MATE_NO,
                    QC_INSPECTION,
                    STORAGE_LOCATION,
                    LOCATION,
                    SHIFT,
                    QUALITY_GRADE,
                    POWER_GRADE,
                    FQC_DEFECTCODE,
                    DIST_ID,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    INF_TIME,
                    INF_PROC_TIME,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZPICODE,
                    ZPIMSGID,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IQCMSERDAT
			WHERE RETURN_TYPE <> 'E'
			  AND QC_INSPECTION IN ('R', 'W')
            ORDER BY DOC_ID ASC,SITE_ID ASC,MODULE_ID ASC, ZIFDATE || ZIFTIME ASC;
            EXEC SQL OPEN CDB_IQCMSERDAT_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_iqcmserdat", sel_type);
}


