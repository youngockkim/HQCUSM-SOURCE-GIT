/* Del Null Function */
void CDB_del_null_iqcmserdat(struct IQCMSERDAT_N_TAG *IQCMSERDAT_N, struct IQCMSERDAT_TAG *IQCMSERDAT)
{
    MEMCPY_DN(IQCMSERDAT->DOC_ID, IQCMSERDAT_N->DOC_ID, sizeof(IQCMSERDAT->DOC_ID));
