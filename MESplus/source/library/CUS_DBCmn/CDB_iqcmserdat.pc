/* SQL CURSOR CLOSE Function */
void CDB_close_iqcmserdat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IQCMSERDAT_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IQCMSERDAT_CUR_2;
            break;

		case 3:
            EXEC SQL CLOSE CDB_IQCMSERDAT_CUR_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_iqcmserdat", sel_type);
}


/* Initialize Function */
void CDB_init_iqcmserdat(struct IQCMSERDAT_TAG *IQCMSERDAT)
{
    /* memset by Space */
    memset(IQCMSERDAT, ' ', sizeof(struct IQCMSERDAT_TAG));
    
}


/* Add Null Function */
void CDB_add_null_iqcmserdat(struct IQCMSERDAT_N_TAG *IQCMSERDAT_N, struct IQCMSERDAT_TAG *IQCMSERDAT)
{
    /* memset by NULL */
    memset(IQCMSERDAT_N, '\0', sizeof(struct IQCMSERDAT_N_TAG));
    
    MEMCPY_AN(IQCMSERDAT_N->DOC_ID, IQCMSERDAT->DOC_ID, sizeof(IQCMSERDAT->DOC_ID));
    MEMCPY_AN(IQCMSERDAT_N->SITE_ID, IQCMSERDAT->SITE_ID, sizeof(IQCMSERDAT->SITE_ID));
