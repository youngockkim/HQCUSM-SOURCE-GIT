                    AND Z_GROUP = :IQCMSERDAT_N.Z_GROUP
                    AND MODULE_ID = :IQCMSERDAT_N.MODULE_ID;
            break;

		case 2:
            EXEC SQL UPDATE IQCMSERDAT SET                   
                    INF_PROC_TIME = :IQCMSERDAT_N.INF_PROC_TIME,                    
                    RETURN_TYPE = 'E',
                    RETURN_MSG = :IQCMSERDAT_N.RETURN_MSG       
                WHERE MODULE_ID = :IQCMSERDAT_N.MODULE_ID;
            break;

