    MEMCPY_DN(IQCMSERDAT->INSERT_COUNT, IQCMSERDAT_N->INSERT_COUNT, sizeof(IQCMSERDAT->INSERT_COUNT));
    MEMCPY_DN(IQCMSERDAT->DELETE_COUNT, IQCMSERDAT_N->DELETE_COUNT, sizeof(IQCMSERDAT->DELETE_COUNT));
