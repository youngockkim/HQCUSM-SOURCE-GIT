    memset(CRASWRKLOG, ' ', sizeof(struct CRASWRKLOG_TAG));
    
    CRASWRKLOG->HIST_SEQ = 0;
    CRASWRKLOG->PART_REPLACEMENT_QUANTITIES = 0;
}


/* Add Null Function */
void CDB_add_null_craswrklog(struct CRASWRKLOG_N_TAG *CRASWRKLOG_N, struct CRASWRKLOG_TAG *CRASWRKLOG)
{
    /* memset by NULL */
    memset(CRASWRKLOG_N, '\0', sizeof(struct CRASWRKLOG_N_TAG));
    
