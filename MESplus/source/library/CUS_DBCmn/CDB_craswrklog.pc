/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_craswrklog(int sel_type, struct CRASWRKLOG_TAG *CRASWRKLOG)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASWRKLOG_N_TAG CRASWRKLOG_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_craswrklog(&CRASWRKLOG_N, CRASWRKLOG);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASWRKLOG_CUR_1 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    LINE_ID,
                    HOUR_TYPE,
                    WORK_SHIFT,
                    WORK_TIME,
                    HIST_SEQ,
                    MACHINE,
                    MACHINE_NUMBER,
                    START_TIME,
                    END_TIME,
                    REPAIR_TIME,
                    ISSUES,
                    ISSUES_DETAILS,
                    ROOT_CAUSES,
                    PART_REPLACEMENT,
                    PART_REPLACEMENT_QUANTITIES,
                    TRAN_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CRASWRKLOG
                ORDER BY WORK_DATE ASC,
                    LINE_ID ASC,
                    HOUR_TYPE ASC,
                    WORK_SHIFT ASC,
                    WORK_TIME ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN CDB_CRASWRKLOG_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CRASWRKLOG_CUR_2 CURSOR FOR
                SELECT 
					DECODE(WORK_TIME,'00',WORK_DATE+1,'01',WORK_DATE+1,'02',WORK_DATE+1,'03',WORK_DATE+1,'04',WORK_DATE+1,'05',WORK_DATE+1,WORK_DATE) WORK_DATE,
                    LINE_ID,
                    HOUR_TYPE,
                    WORK_SHIFT,
                    WORK_TIME,
                    HIST_SEQ,
                    MACHINE,
                    MACHINE_NUMBER,
                    START_TIME,
                    END_TIME,
                    REPAIR_TIME,
                    ISSUES,
                    ISSUES_DETAILS,
                    ROOT_CAUSES,
                    PART_REPLACEMENT,
                    PART_REPLACEMENT_QUANTITIES,
                    TRAN_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CRASWRKLOG
				WHERE WORK_DATE = :CRASWRKLOG_N.WORK_DATE
                    AND LINE_ID = :CRASWRKLOG_N.LINE_ID
                    AND HOUR_TYPE = :CRASWRKLOG_N.HOUR_TYPE
                    AND WORK_SHIFT = :CRASWRKLOG_N.WORK_SHIFT 
                ORDER BY WORK_DATE ASC,
                    LINE_ID ASC,
                    HOUR_TYPE ASC,
                    WORK_SHIFT ASC,
                    WORK_TIME ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN CDB_CRASWRKLOG_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_craswrklog", sel_type);
}


