/* Initialize Function */
void CDB_init_cwipclvlos(struct CWIPCLVLOS_TAG *CWIPCLVLOS)
{
    /* memset by Space */
    memset(CWIPCLVLOS, ' ', sizeof(struct CWIPCLVLOS_TAG));
    
    CWIPCLVLOS->LOSS_SEQ = 0;
    CWIPCLVLOS->INPUT_QTY = 0;
    CWIPCLVLOS->OUT_QTY = 0;
    CWIPCLVLOS->FC_CHIP_QTY = 0;
    CWIPCLVLOS->FC_BROKEN_QTY = 0;
    CWIPCLVLOS->HC_HANDLING_QTY = 0;
    CWIPCLVLOS->HC_CRACK_QTY = 0;
    CWIPCLVLOS->HC_SICKLE_QTY = 0;
    CWIPCLVLOS->HC_C_SICKLE_QTY = 0;
    CWIPCLVLOS->HC_ALIGN_QTY = 0;
    CWIPCLVLOS->HC_ETC_QTY = 0;
    CWIPCLVLOS->CJ_BROKEN_QTY = 0;
}


/* Add Null Function */
void CDB_add_null_cwipclvlos(struct CWIPCLVLOS_N_TAG *CWIPCLVLOS_N, struct CWIPCLVLOS_TAG *CWIPCLVLOS)
{
    /* memset by NULL */
    memset(CWIPCLVLOS_N, '\0', sizeof(struct CWIPCLVLOS_N_TAG));
    
    MEMCPY_AN(CWIPCLVLOS_N->FACTORY, CWIPCLVLOS->FACTORY, sizeof(CWIPCLVLOS->FACTORY));
    MEMCPY_AN(CWIPCLVLOS_N->WORK_DATE, CWIPCLVLOS->WORK_DATE, sizeof(CWIPCLVLOS->WORK_DATE));
