/* SQL CURSOR CLOSE Function */
void CDB_close_ibakorddat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IBAKORDDAT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ibakorddat", sel_type);
}


/* Initialize Function */
void CDB_init_ibakorddat(struct IBAKORDDAT_TAG *IBAKORDDAT)
{
    /* memset by Space */
    memset(IBAKORDDAT, ' ', sizeof(struct IBAKORDDAT_TAG));
    
    IBAKORDDAT->PROD_QTY = 0;
}


/* Add Null Function */
