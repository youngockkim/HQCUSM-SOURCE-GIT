    memset(IBAKORDDAT_N, '\0', sizeof(struct IBAKORDDAT_N_TAG));
    
    MEMCPY_AN(IBAKORDDAT_N->DOC_ID, IBAKORDDAT->DOC_ID, sizeof(IBAKORDDAT->DOC_ID));
