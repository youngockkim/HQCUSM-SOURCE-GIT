/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_ibakorddat(int sel_type, struct IBAKORDDAT_TAG *IBAKORDDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IBAKORDDAT_N_TAG IBAKORDDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ibakorddat(&IBAKORDDAT_N, IBAKORDDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IBAKORDDAT_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_ORDER_NO,
                    PROD_ORDER_VER,
                    PROD_NO,
                    PROD_NO_DESC,
                    PROD_ORDER_TYPE,
                    PROD_ORDER_SUBTYPE,
                    PROD_QTY,
                    PROD_UNIT,
                    START_DATE,
                    FINISH_DATE,
                    WORK_SHOP,
                    BLOCK_YN,
                    ROUTE_GRP,
                    ROUTE,
                    BOM_KEY,
                    OPT_BOM,
                    COMMENTS,
                    CRE_ID,
                    CRE_DATE,
                    MOD_ID,
                    MOD_DATE,
                    EX_BATCH_NO,
                    PROD_ORDER_STATE,
                    SALES_ORDER_GRP,
                    HAND_BOOK,
                    CO_PROD_NO_1,
                    CO_PROD_NO_2,
                    CO_PROD_NO_3,
                    CO_PROD_NO_4,
                    CO_PROD_NO_5,
                    CO_PROD_NO_6,
                    CO_PROD_NUMBER_1,
                    CO_PROD_NUMBER_2,
                    CO_PROD_NUMBER_3,
                    CO_PROD_NUMBER_4,
                    CO_PROD_NUMBER_5,
                    CO_PROD_NUMBER_6,
                    CELL_RATE,
                    BCR_POWER,
                    BCR_LIST_CODE,
                    BCR_PROD_BATCH_NO,
                    BCR_MOD_CLASS,
                    BCR_MOD_TYPE,
                    BCR_MOD_SUBTYPE,
                    CUST_ISC_YN,
                    OPER_NO,
                    WORK_CENTER,
                    WORK_CENTER_DESC,
                    STD_TEXT_KEY,
                    OPER_SHORT_DESC,
                    DEL_YN,
                    VALUATION_TYPE,
                    ZZBOMID,
                    ZSHIPNO,
                    ZARTCOR,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IBAKORDDAT
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_ORDER_NO ASC;
            EXEC SQL OPEN CDB_IBAKORDDAT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_ibakorddat", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_ibakorddat(int sel_type, struct IBAKORDDAT_TAG *IBAKORDDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IBAKORDDAT_N_TAG IBAKORDDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_IBAKORDDAT_CUR_1 INTO
                :IBAKORDDAT_N.DOC_ID,
                :IBAKORDDAT_N.SITE_ID,
                :IBAKORDDAT_N.PROD_ORDER_NO,
                :IBAKORDDAT_N.PROD_ORDER_VER,
