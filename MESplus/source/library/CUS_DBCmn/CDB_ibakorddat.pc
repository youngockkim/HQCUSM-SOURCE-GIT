                :IBAKORDDAT_N.INF_PROC_TIME,
                :IBAKORDDAT_N.CMF_1,
                :IBAKORDDAT_N.CMF_2,
                :IBAKORDDAT_N.CMF_3,
                :IBAKORDDAT_N.CMF_4,
                :IBAKORDDAT_N.CMF_5,
                :IBAKORDDAT_N.DATA_FLAG,
                :IBAKORDDAT_N.UPDATE_COUNT,
