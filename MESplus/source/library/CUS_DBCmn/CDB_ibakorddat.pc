            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_ibakorddat(&IBAKORDDAT_N, IBAKORDDAT);
    }

    DB_stop_query_timer("CDB_fetch_ibakorddat", sel_type);
