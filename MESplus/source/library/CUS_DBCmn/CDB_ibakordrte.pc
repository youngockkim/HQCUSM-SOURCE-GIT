/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_ibakordrte(int sel_type, struct IBAKORDRTE_TAG *IBAKORDRTE)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IBAKORDRTE_N_TAG IBAKORDRTE_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ibakordrte(&IBAKORDRTE_N, IBAKORDRTE);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IBAKORDRTE_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_ORDER_NO,
                    SEQ,
                    DEL_YN,
                    OPER_NO,
                    WORK_CENTER,
                    WORK_CENTER_DESC,
                    BASE_QUANTITY,
                    BASE_UNIT,
                    DIRECT_LABOUR_UNIT,
                    DIRECT_LABOUR,
                    INDIRECT_LABOUR_UNIT,
                    INDIRECT_LABOUR,
                    DEPRECIATION_UNIT,
                    DEPRECIATION,
                    UTILITIES_UNIT,
                    UTILITIES,
                    SPARE_PARTS_UNIT,
                    SPARE_PARTS,
                    OTHER_COST_UNIT,
                    OTHER_COST,
                    CRE_ID,
                    CRE_DATE,
                    MOD_ID,
                    MOD_DATE,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IBAKORDRTE
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_ORDER_NO ASC,
                    SEQ ASC;
            EXEC SQL OPEN CDB_IBAKORDRTE_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
