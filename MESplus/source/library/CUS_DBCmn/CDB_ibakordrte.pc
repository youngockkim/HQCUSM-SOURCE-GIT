                :IBAKORDRTE_N.DIRECT_LABOUR_UNIT,
                :IBAKORDRTE_N.DIRECT_LABOUR,
                :IBAKORDRTE_N.INDIRECT_LABOUR_UNIT,
                :IBAKORDRTE_N.INDIRECT_LABOUR,
                :IBAKORDRTE_N.DEPRECIATION_UNIT,
                :IBAKORDRTE_N.DEPRECIATION,
                :IBAKORDRTE_N.UTILITIES_UNIT,
                :IBAKORDRTE_N.UTILITIES,
                :IBAKORDRTE_N.SPARE_PARTS_UNIT,
                :IBAKORDRTE_N.SPARE_PARTS,
                :IBAKORDRTE_N.OTHER_COST_UNIT,
                :IBAKORDRTE_N.OTHER_COST,
                :IBAKORDRTE_N.CRE_ID,
                :IBAKORDRTE_N.CRE_DATE,
                :IBAKORDRTE_N.MOD_ID,
                :IBAKORDRTE_N.MOD_DATE,
                :IBAKORDRTE_N.INF_TIME,
                :IBAKORDRTE_N.INF_PROC_TIME,
                :IBAKORDRTE_N.CMF_1,
                :IBAKORDRTE_N.CMF_2,
                :IBAKORDRTE_N.CMF_3,
                :IBAKORDRTE_N.CMF_4,
                :IBAKORDRTE_N.CMF_5,
                :IBAKORDRTE_N.DATA_FLAG,
                :IBAKORDRTE_N.UPDATE_COUNT,
                :IBAKORDRTE_N.INSERT_COUNT,
                :IBAKORDRTE_N.DELETE_COUNT,
                :IBAKORDRTE_N.SQL_DML_COUNT,
                :IBAKORDRTE_N.ZPICODE,
                :IBAKORDRTE_N.ZPIMSGID,
                :IBAKORDRTE_N.RETURN_TYPE,
                :IBAKORDRTE_N.RETURN_MSG,
                :IBAKORDRTE_N.ZIFERNAM,
                :IBAKORDRTE_N.ZIFDATE,
                :IBAKORDRTE_N.ZIFTIME,
                :IBAKORDRTE_N.ZPISTAT,
                :IBAKORDRTE_N.ZPIMSG;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_ibakordrte(&IBAKORDRTE_N, IBAKORDRTE);
    }

    DB_stop_query_timer("CDB_fetch_ibakordrte", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_ibakordrte(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IBAKORDRTE_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ibakordrte", sel_type);
}


/* Initialize Function */
void CDB_init_ibakordrte(struct IBAKORDRTE_TAG *IBAKORDRTE)
{
    /* memset by Space */
    memset(IBAKORDRTE, ' ', sizeof(struct IBAKORDRTE_TAG));
    
    IBAKORDRTE->BASE_QUANTITY = 0;
    IBAKORDRTE->DIRECT_LABOUR = 0;
    IBAKORDRTE->INDIRECT_LABOUR = 0;
    IBAKORDRTE->DEPRECIATION = 0;
    IBAKORDRTE->UTILITIES = 0;
    IBAKORDRTE->SPARE_PARTS = 0;
    IBAKORDRTE->OTHER_COST = 0;
}


/* Add Null Function */
void CDB_add_null_ibakordrte(struct IBAKORDRTE_N_TAG *IBAKORDRTE_N, struct IBAKORDRTE_TAG *IBAKORDRTE)
{
    /* memset by NULL */
    memset(IBAKORDRTE_N, '\0', sizeof(struct IBAKORDRTE_N_TAG));
    
    MEMCPY_AN(IBAKORDRTE_N->DOC_ID, IBAKORDRTE->DOC_ID, sizeof(IBAKORDRTE->DOC_ID));
    MEMCPY_AN(IBAKORDRTE_N->SITE_ID, IBAKORDRTE->SITE_ID, sizeof(IBAKORDRTE->SITE_ID));
    MEMCPY_AN(IBAKORDRTE_N->PROD_ORDER_NO, IBAKORDRTE->PROD_ORDER_NO, sizeof(IBAKORDRTE->PROD_ORDER_NO));
    MEMCPY_AN(IBAKORDRTE_N->SEQ, IBAKORDRTE->SEQ, sizeof(IBAKORDRTE->SEQ));
    IBAKORDRTE_N->DEL_YN[0] = IBAKORDRTE->DEL_YN;
    MEMCPY_AN(IBAKORDRTE_N->OPER_NO, IBAKORDRTE->OPER_NO, sizeof(IBAKORDRTE->OPER_NO));
    MEMCPY_AN(IBAKORDRTE_N->WORK_CENTER, IBAKORDRTE->WORK_CENTER, sizeof(IBAKORDRTE->WORK_CENTER));
