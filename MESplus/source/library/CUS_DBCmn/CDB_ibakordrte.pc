    MEMCPY_AN(IBAKORDRTE_N->DIRECT_LABOUR_UNIT, IBAKORDRTE->DIRECT_LABOUR_UNIT, sizeof(IBAKORDRTE->DIRECT_LABOUR_UNIT));
    IBAKORDRTE_N->DIRECT_LABOUR = IBAKORDRTE->DIRECT_LABOUR;
    MEMCPY_AN(IBAKORDRTE_N->INDIRECT_LABOUR_UNIT, IBAKORDRTE->INDIRECT_LABOUR_UNIT, sizeof(IBAKORDRTE->INDIRECT_LABOUR_UNIT));
    IBAKORDRTE_N->INDIRECT_LABOUR = IBAKORDRTE->INDIRECT_LABOUR;
    MEMCPY_AN(IBAKORDRTE_N->DEPRECIATION_UNIT, IBAKORDRTE->DEPRECIATION_UNIT, sizeof(IBAKORDRTE->DEPRECIATION_UNIT));
    IBAKORDRTE_N->DEPRECIATION = IBAKORDRTE->DEPRECIATION;
    MEMCPY_AN(IBAKORDRTE_N->UTILITIES_UNIT, IBAKORDRTE->UTILITIES_UNIT, sizeof(IBAKORDRTE->UTILITIES_UNIT));
    IBAKORDRTE_N->UTILITIES = IBAKORDRTE->UTILITIES;
    MEMCPY_AN(IBAKORDRTE_N->SPARE_PARTS_UNIT, IBAKORDRTE->SPARE_PARTS_UNIT, sizeof(IBAKORDRTE->SPARE_PARTS_UNIT));
    IBAKORDRTE_N->SPARE_PARTS = IBAKORDRTE->SPARE_PARTS;
    MEMCPY_AN(IBAKORDRTE_N->OTHER_COST_UNIT, IBAKORDRTE->OTHER_COST_UNIT, sizeof(IBAKORDRTE->OTHER_COST_UNIT));
    IBAKORDRTE_N->OTHER_COST = IBAKORDRTE->OTHER_COST;
    MEMCPY_AN(IBAKORDRTE_N->CRE_ID, IBAKORDRTE->CRE_ID, sizeof(IBAKORDRTE->CRE_ID));
    MEMCPY_AN(IBAKORDRTE_N->CRE_DATE, IBAKORDRTE->CRE_DATE, sizeof(IBAKORDRTE->CRE_DATE));
    MEMCPY_AN(IBAKORDRTE_N->MOD_ID, IBAKORDRTE->MOD_ID, sizeof(IBAKORDRTE->MOD_ID));
    MEMCPY_AN(IBAKORDRTE_N->MOD_DATE, IBAKORDRTE->MOD_DATE, sizeof(IBAKORDRTE->MOD_DATE));
    MEMCPY_AN(IBAKORDRTE_N->INF_TIME, IBAKORDRTE->INF_TIME, sizeof(IBAKORDRTE->INF_TIME));
    MEMCPY_AN(IBAKORDRTE_N->INF_PROC_TIME, IBAKORDRTE->INF_PROC_TIME, sizeof(IBAKORDRTE->INF_PROC_TIME));
    MEMCPY_AN(IBAKORDRTE_N->CMF_1, IBAKORDRTE->CMF_1, sizeof(IBAKORDRTE->CMF_1));
    MEMCPY_AN(IBAKORDRTE_N->CMF_2, IBAKORDRTE->CMF_2, sizeof(IBAKORDRTE->CMF_2));
    MEMCPY_AN(IBAKORDRTE_N->CMF_3, IBAKORDRTE->CMF_3, sizeof(IBAKORDRTE->CMF_3));
    MEMCPY_AN(IBAKORDRTE_N->CMF_4, IBAKORDRTE->CMF_4, sizeof(IBAKORDRTE->CMF_4));
    MEMCPY_AN(IBAKORDRTE_N->CMF_5, IBAKORDRTE->CMF_5, sizeof(IBAKORDRTE->CMF_5));
    IBAKORDRTE_N->DATA_FLAG[0] = IBAKORDRTE->DATA_FLAG;
    MEMCPY_AN(IBAKORDRTE_N->UPDATE_COUNT, IBAKORDRTE->UPDATE_COUNT, sizeof(IBAKORDRTE->UPDATE_COUNT));
    MEMCPY_AN(IBAKORDRTE_N->INSERT_COUNT, IBAKORDRTE->INSERT_COUNT, sizeof(IBAKORDRTE->INSERT_COUNT));
    MEMCPY_AN(IBAKORDRTE_N->DELETE_COUNT, IBAKORDRTE->DELETE_COUNT, sizeof(IBAKORDRTE->DELETE_COUNT));
    MEMCPY_AN(IBAKORDRTE_N->SQL_DML_COUNT, IBAKORDRTE->SQL_DML_COUNT, sizeof(IBAKORDRTE->SQL_DML_COUNT));
    MEMCPY_AN(IBAKORDRTE_N->ZPICODE, IBAKORDRTE->ZPICODE, sizeof(IBAKORDRTE->ZPICODE));
    MEMCPY_AN(IBAKORDRTE_N->ZPIMSGID, IBAKORDRTE->ZPIMSGID, sizeof(IBAKORDRTE->ZPIMSGID));
    IBAKORDRTE_N->RETURN_TYPE[0] = IBAKORDRTE->RETURN_TYPE;
