    MEMCPY_AN(IBAKORDRTE_N->ZPIMSG, IBAKORDRTE->ZPIMSG, sizeof(IBAKORDRTE->ZPIMSG));
}


/* Del Null Function */
void CDB_del_null_ibakordrte(struct IBAKORDRTE_N_TAG *IBAKORDRTE_N, struct IBAKORDRTE_TAG *IBAKORDRTE)
{
    MEMCPY_DN(IBAKORDRTE->DOC_ID, IBAKORDRTE_N->DOC_ID, sizeof(IBAKORDRTE->DOC_ID));
