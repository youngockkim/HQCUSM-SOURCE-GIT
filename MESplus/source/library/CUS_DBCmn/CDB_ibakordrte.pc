    MEMCPY_DN(IBAKORDRTE->INSERT_COUNT, IBAKORDRTE_N->INSERT_COUNT, sizeof(IBAKORDRTE->INSERT_COUNT));
    MEMCPY_DN(IBAKORDRTE->DELETE_COUNT, IBAKORDRTE_N->DELETE_COUNT, sizeof(IBAKORDRTE->DELETE_COUNT));
    MEMCPY_DN(IBAKORDRTE->SQL_DML_COUNT, IBAKORDRTE_N->SQL_DML_COUNT, sizeof(IBAKORDRTE->SQL_DML_COUNT));
