                    CM_KEY_2 ASC,
                    CM_KEY_3 ASC;
            EXEC SQL OPEN CDB_RSUMHORCLV_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_rsumhorclv", sel_type);
}


/* SQL CURSOR FETCH Function */
