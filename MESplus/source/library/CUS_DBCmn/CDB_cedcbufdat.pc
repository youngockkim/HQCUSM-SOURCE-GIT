/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cedcbufdat(int sel_type, struct CEDCBUFDAT_TAG *CEDCBUFDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CEDCBUFDAT_N_TAG CEDCBUFDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedcbufdat(&CEDCBUFDAT_N, CEDCBUFDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CEDCBUFDAT_CUR_1 CURSOR FOR
                SELECT 
                    LINE_ID,
                    RES_ID,
                    TYPE,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    QTY_4,
                    QTY_5,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CEDCBUFDAT
                ORDER BY LINE_ID ASC,
                    RES_ID ASC,
                    TYPE ASC;
            EXEC SQL OPEN CDB_CEDCBUFDAT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cedcbufdat", sel_type);
}


