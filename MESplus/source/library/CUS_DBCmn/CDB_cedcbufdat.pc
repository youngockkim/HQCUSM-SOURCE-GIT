/* Del Null Function */
void CDB_del_null_cedcbufdat(struct CEDCBUFDAT_N_TAG *CEDCBUFDAT_N, struct CEDCBUFDAT_TAG *CEDCBUFDAT)
{
    MEMCPY_DN(CEDCBUFDAT->LINE_ID, CEDCBUFDAT_N->LINE_ID, sizeof(CEDCBUFDAT->LINE_ID));
    MEMCPY_DN(CEDCBUFDAT->RES_ID, CEDCBUFDAT_N->RES_ID, sizeof(CEDCBUFDAT->RES_ID));
    MEMCPY_DN(CEDCBUFDAT->TYPE, CEDCBUFDAT_N->TYPE, sizeof(CEDCBUFDAT->TYPE));
