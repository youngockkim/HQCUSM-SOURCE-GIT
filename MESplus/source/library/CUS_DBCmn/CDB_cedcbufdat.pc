    MEMCPY_AN(CEDCBUFDAT_N->LINE_ID, CEDCBUFDAT->LINE_ID, sizeof(CEDCBUFDAT->LINE_ID));
    MEMCPY_AN(CEDCBUFDAT_N->RES_ID, CEDCBUFDAT->RES_ID, sizeof(CEDCBUFDAT->RES_ID));
    MEMCPY_AN(CEDCBUFDAT_N->TYPE, CEDCBUFDAT->TYPE, sizeof(CEDCBUFDAT->TYPE));
    CEDCBUFDAT_N->QTY_1 = CEDCBUFDAT->QTY_1;
    CEDCBUFDAT_N->QTY_2 = CEDCBUFDAT->QTY_2;
    CEDCBUFDAT_N->QTY_3 = CEDCBUFDAT->QTY_3;
    CEDCBUFDAT_N->QTY_4 = CEDCBUFDAT->QTY_4;
    CEDCBUFDAT_N->QTY_5 = CEDCBUFDAT->QTY_5;
    MEMCPY_AN(CEDCBUFDAT_N->CMF_1, CEDCBUFDAT->CMF_1, sizeof(CEDCBUFDAT->CMF_1));
    MEMCPY_AN(CEDCBUFDAT_N->CMF_2, CEDCBUFDAT->CMF_2, sizeof(CEDCBUFDAT->CMF_2));
