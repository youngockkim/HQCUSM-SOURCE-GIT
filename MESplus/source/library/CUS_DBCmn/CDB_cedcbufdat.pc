/* Add Null Function */
void CDB_add_null_cedcbufdat(struct CEDCBUFDAT_N_TAG *CEDCBUFDAT_N, struct CEDCBUFDAT_TAG *CEDCBUFDAT)
{
    /* memset by NULL */
