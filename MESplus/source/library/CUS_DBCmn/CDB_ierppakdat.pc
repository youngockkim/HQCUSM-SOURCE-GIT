        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_ierppakdat(&IERPPAKDAT_N, IERPPAKDAT);
    }

    DB_stop_query_timer("CDB_fetch_ierppakdat", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_ierppakdat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IERPPAKDAT_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IERPPAKDAT_CUR_2;
            break;

		case 3:
            EXEC SQL CLOSE CDB_IERPPAKDAT_CUR_3;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ierppakdat", sel_type);
}


/* Initialize Function */
void CDB_init_ierppakdat(struct IERPPAKDAT_TAG *IERPPAKDAT)
{
    /* memset by Space */
    memset(IERPPAKDAT, ' ', sizeof(struct IERPPAKDAT_TAG));
    
    IERPPAKDAT->QTY = 0;
}


/* Add Null Function */
void CDB_add_null_ierppakdat(struct IERPPAKDAT_N_TAG *IERPPAKDAT_N, struct IERPPAKDAT_TAG *IERPPAKDAT)
{
    /* memset by NULL */
    memset(IERPPAKDAT_N, '\0', sizeof(struct IERPPAKDAT_N_TAG));
    
    MEMCPY_AN(IERPPAKDAT_N->DOC_ID, IERPPAKDAT->DOC_ID, sizeof(IERPPAKDAT->DOC_ID));
    MEMCPY_AN(IERPPAKDAT_N->PALLET_ID, IERPPAKDAT->PALLET_ID, sizeof(IERPPAKDAT->PALLET_ID));
    MEMCPY_AN(IERPPAKDAT_N->MODULE_ID, IERPPAKDAT->MODULE_ID, sizeof(IERPPAKDAT->MODULE_ID));
    IERPPAKDAT_N->ACTION_TYPE[0] = IERPPAKDAT->ACTION_TYPE;
    MEMCPY_AN(IERPPAKDAT_N->MODULE_SEQ, IERPPAKDAT->MODULE_SEQ, sizeof(IERPPAKDAT->MODULE_SEQ));
    MEMCPY_AN(IERPPAKDAT_N->SITE_ID, IERPPAKDAT->SITE_ID, sizeof(IERPPAKDAT->SITE_ID));
    IERPPAKDAT_N->QTY = IERPPAKDAT->QTY;
    MEMCPY_AN(IERPPAKDAT_N->PACKING_DATE, IERPPAKDAT->PACKING_DATE, sizeof(IERPPAKDAT->PACKING_DATE));
    MEMCPY_AN(IERPPAKDAT_N->PACKING_TIME, IERPPAKDAT->PACKING_TIME, sizeof(IERPPAKDAT->PACKING_TIME));
    MEMCPY_AN(IERPPAKDAT_N->PACKING_ID, IERPPAKDAT->PACKING_ID, sizeof(IERPPAKDAT->PACKING_ID));
    MEMCPY_AN(IERPPAKDAT_N->INTERFACE_DATE, IERPPAKDAT->INTERFACE_DATE, sizeof(IERPPAKDAT->INTERFACE_DATE));
    MEMCPY_AN(IERPPAKDAT_N->INTERFACE_TIME, IERPPAKDAT->INTERFACE_TIME, sizeof(IERPPAKDAT->INTERFACE_TIME));
    MEMCPY_AN(IERPPAKDAT_N->INTERFACE_USERID, IERPPAKDAT->INTERFACE_USERID, sizeof(IERPPAKDAT->INTERFACE_USERID));
    MEMCPY_AN(IERPPAKDAT_N->INF_PROC_TIME, IERPPAKDAT->INF_PROC_TIME, sizeof(IERPPAKDAT->INF_PROC_TIME));
    MEMCPY_AN(IERPPAKDAT_N->CMF_1, IERPPAKDAT->CMF_1, sizeof(IERPPAKDAT->CMF_1));
    MEMCPY_AN(IERPPAKDAT_N->CMF_2, IERPPAKDAT->CMF_2, sizeof(IERPPAKDAT->CMF_2));
    MEMCPY_AN(IERPPAKDAT_N->CMF_3, IERPPAKDAT->CMF_3, sizeof(IERPPAKDAT->CMF_3));
    MEMCPY_AN(IERPPAKDAT_N->CMF_4, IERPPAKDAT->CMF_4, sizeof(IERPPAKDAT->CMF_4));
    MEMCPY_AN(IERPPAKDAT_N->CMF_5, IERPPAKDAT->CMF_5, sizeof(IERPPAKDAT->CMF_5));
    IERPPAKDAT_N->DATA_FLAG[0] = IERPPAKDAT->DATA_FLAG;
    MEMCPY_AN(IERPPAKDAT_N->ZIFERNAM, IERPPAKDAT->ZIFERNAM, sizeof(IERPPAKDAT->ZIFERNAM));
    MEMCPY_AN(IERPPAKDAT_N->ZIFDATE, IERPPAKDAT->ZIFDATE, sizeof(IERPPAKDAT->ZIFDATE));
    MEMCPY_AN(IERPPAKDAT_N->ZIFTIME, IERPPAKDAT->ZIFTIME, sizeof(IERPPAKDAT->ZIFTIME));
    MEMCPY_AN(IERPPAKDAT_N->ZPICODE, IERPPAKDAT->ZPICODE, sizeof(IERPPAKDAT->ZPICODE));
    MEMCPY_AN(IERPPAKDAT_N->ZPIMSGID, IERPPAKDAT->ZPIMSGID, sizeof(IERPPAKDAT->ZPIMSGID));
    IERPPAKDAT_N->ZPISTAT[0] = IERPPAKDAT->ZPISTAT;
    MEMCPY_AN(IERPPAKDAT_N->ZPIMSG, IERPPAKDAT->ZPIMSG, sizeof(IERPPAKDAT->ZPIMSG));
    IERPPAKDAT_N->RETURN_TYPE[0] = IERPPAKDAT->RETURN_TYPE;
    MEMCPY_AN(IERPPAKDAT_N->RETURN_MSG, IERPPAKDAT->RETURN_MSG, sizeof(IERPPAKDAT->RETURN_MSG));
    MEMCPY_AN(IERPPAKDAT_N->ERP_DATE, IERPPAKDAT->ERP_DATE, sizeof(IERPPAKDAT->ERP_DATE));
    MEMCPY_AN(IERPPAKDAT_N->ERP_TIME, IERPPAKDAT->ERP_TIME, sizeof(IERPPAKDAT->ERP_TIME));
    IERPPAKDAT_N->ERP_FLAG[0] = IERPPAKDAT->ERP_FLAG;
    MEMCPY_AN(IERPPAKDAT_N->ERP_MSG, IERPPAKDAT->ERP_MSG, sizeof(IERPPAKDAT->ERP_MSG));
	MEMCPY_AN(IERPPAKDAT_N->PVM_PN, IERPPAKDAT->PVM_PN, sizeof(IERPPAKDAT->PVM_PN));
	MEMCPY_AN(IERPPAKDAT_N->PVM_SN, IERPPAKDAT->PVM_SN, sizeof(IERPPAKDAT->PVM_SN));
	MEMCPY_AN(IERPPAKDAT_N->PCU_SN, IERPPAKDAT->PCU_SN, sizeof(IERPPAKDAT->PCU_SN));
	MEMCPY_AN(IERPPAKDAT_N->ACM_SN, IERPPAKDAT->ACM_SN, sizeof(IERPPAKDAT->ACM_SN));
}


/* Del Null Function */
void CDB_del_null_ierppakdat(struct IERPPAKDAT_N_TAG *IERPPAKDAT_N, struct IERPPAKDAT_TAG *IERPPAKDAT)
{
    MEMCPY_DN(IERPPAKDAT->DOC_ID, IERPPAKDAT_N->DOC_ID, sizeof(IERPPAKDAT->DOC_ID));
    MEMCPY_DN(IERPPAKDAT->PALLET_ID, IERPPAKDAT_N->PALLET_ID, sizeof(IERPPAKDAT->PALLET_ID));
    MEMCPY_DN(IERPPAKDAT->MODULE_ID, IERPPAKDAT_N->MODULE_ID, sizeof(IERPPAKDAT->MODULE_ID));
    IERPPAKDAT->ACTION_TYPE = IERPPAKDAT_N->ACTION_TYPE[0];
    MEMCPY_DN(IERPPAKDAT->MODULE_SEQ, IERPPAKDAT_N->MODULE_SEQ, sizeof(IERPPAKDAT->MODULE_SEQ));
    MEMCPY_DN(IERPPAKDAT->SITE_ID, IERPPAKDAT_N->SITE_ID, sizeof(IERPPAKDAT->SITE_ID));
    IERPPAKDAT->QTY = IERPPAKDAT_N->QTY;
    MEMCPY_DN(IERPPAKDAT->PACKING_DATE, IERPPAKDAT_N->PACKING_DATE, sizeof(IERPPAKDAT->PACKING_DATE));
    MEMCPY_DN(IERPPAKDAT->PACKING_TIME, IERPPAKDAT_N->PACKING_TIME, sizeof(IERPPAKDAT->PACKING_TIME));
    MEMCPY_DN(IERPPAKDAT->PACKING_ID, IERPPAKDAT_N->PACKING_ID, sizeof(IERPPAKDAT->PACKING_ID));
