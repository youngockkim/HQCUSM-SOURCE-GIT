                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPICODE,
                    ZPIMSGID,
                    ZPISTAT,
                    ZPIMSG,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ERP_DATE,
                    ERP_TIME,
                    ERP_FLAG,
                    ERP_MSG,
					PVM_PN,
					PVM_SN,
					PCU_SN,
					ACM_SN
                FROM IERPPAKDAT
                ORDER BY DOC_ID ASC,
                    PALLET_ID ASC,
                    MODULE_ID ASC,
                    ACTION_TYPE ASC;
            EXEC SQL OPEN CDB_IERPPAKDAT_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_IERPPAKDAT_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    PALLET_ID,
                    MODULE_ID,
                    ACTION_TYPE,
                    MODULE_SEQ,
                    SITE_ID,
                    QTY,
                    PACKING_DATE,
                    PACKING_TIME,
                    PACKING_ID,
                    INTERFACE_DATE,
                    INTERFACE_TIME,
                    INTERFACE_USERID,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPICODE,
                    ZPIMSGID,
                    ZPISTAT,
                    ZPIMSG,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ERP_DATE,
                    ERP_TIME,
                    ERP_FLAG,
                    ERP_MSG,
					PVM_PN,
					PVM_SN,
					PCU_SN,
					ACM_SN
                FROM IERPPAKDAT
				WHERE RETURN_TYPE <> 'E'
                ORDER BY DOC_ID ASC,
                    PALLET_ID ASC,
                    MODULE_ID ASC,
                    ACTION_TYPE ASC;
            EXEC SQL OPEN CDB_IERPPAKDAT_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_IERPPAKDAT_CUR_3 CURSOR FOR
                SELECT 
                    DOC_ID,
                    PALLET_ID,
                    MODULE_ID,
                    ACTION_TYPE,
                    MODULE_SEQ,
                    SITE_ID,
                    QTY,
                    PACKING_DATE,
                    PACKING_TIME,
                    PACKING_ID,
                    INTERFACE_DATE,
                    INTERFACE_TIME,
                    INTERFACE_USERID,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPICODE,
                    ZPIMSGID,
                    ZPISTAT,
                    ZPIMSG,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ERP_DATE,
                    ERP_TIME,
                    ERP_FLAG,
                    ERP_MSG,
					PVM_PN,
					PVM_SN,
					PCU_SN,
					ACM_SN
                FROM IERPPAKDAT
				WHERE PALLET_ID = :IERPPAKDAT_N.PALLET_ID
                ORDER BY DOC_ID ASC,
                    PALLET_ID ASC,
                    MODULE_ID ASC,
                    ACTION_TYPE ASC;
            EXEC SQL OPEN CDB_IERPPAKDAT_CUR_3;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_ierppakdat", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_ierppakdat(int sel_type, struct IERPPAKDAT_TAG *IERPPAKDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IERPPAKDAT_N_TAG IERPPAKDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_IERPPAKDAT_CUR_1 INTO
                :IERPPAKDAT_N.DOC_ID,
