                :IERPPAKDAT_N.ERP_TIME,
                :IERPPAKDAT_N.ERP_FLAG,
                :IERPPAKDAT_N.ERP_MSG,
				:IERPPAKDAT_N.PVM_PN,
				:IERPPAKDAT_N.PVM_SN,
				:IERPPAKDAT_N.PCU_SN,
				:IERPPAKDAT_N.ACM_SN;
            break;

		case 2:
            EXEC SQL FETCH CDB_IERPPAKDAT_CUR_2 INTO
                :IERPPAKDAT_N.DOC_ID,
                :IERPPAKDAT_N.PALLET_ID,
                :IERPPAKDAT_N.MODULE_ID,
                :IERPPAKDAT_N.ACTION_TYPE,
                :IERPPAKDAT_N.MODULE_SEQ,
                :IERPPAKDAT_N.SITE_ID,
                :IERPPAKDAT_N.QTY,
