    MEMCPY_DN(IERPPAKDAT->CMF_3, IERPPAKDAT_N->CMF_3, sizeof(IERPPAKDAT->CMF_3));
    MEMCPY_DN(IERPPAKDAT->CMF_4, IERPPAKDAT_N->CMF_4, sizeof(IERPPAKDAT->CMF_4));
    MEMCPY_DN(IERPPAKDAT->CMF_5, IERPPAKDAT_N->CMF_5, sizeof(IERPPAKDAT->CMF_5));
    IERPPAKDAT->DATA_FLAG = IERPPAKDAT_N->DATA_FLAG[0];
    MEMCPY_DN(IERPPAKDAT->ZIFERNAM, IERPPAKDAT_N->ZIFERNAM, sizeof(IERPPAKDAT->ZIFERNAM));
    MEMCPY_DN(IERPPAKDAT->ZIFDATE, IERPPAKDAT_N->ZIFDATE, sizeof(IERPPAKDAT->ZIFDATE));
    MEMCPY_DN(IERPPAKDAT->ZIFTIME, IERPPAKDAT_N->ZIFTIME, sizeof(IERPPAKDAT->ZIFTIME));
    MEMCPY_DN(IERPPAKDAT->ZPICODE, IERPPAKDAT_N->ZPICODE, sizeof(IERPPAKDAT->ZPICODE));
    MEMCPY_DN(IERPPAKDAT->ZPIMSGID, IERPPAKDAT_N->ZPIMSGID, sizeof(IERPPAKDAT->ZPIMSGID));
    IERPPAKDAT->ZPISTAT = IERPPAKDAT_N->ZPISTAT[0];
    MEMCPY_DN(IERPPAKDAT->ZPIMSG, IERPPAKDAT_N->ZPIMSG, sizeof(IERPPAKDAT->ZPIMSG));
    IERPPAKDAT->RETURN_TYPE = IERPPAKDAT_N->RETURN_TYPE[0];
    MEMCPY_DN(IERPPAKDAT->RETURN_MSG, IERPPAKDAT_N->RETURN_MSG, sizeof(IERPPAKDAT->RETURN_MSG));
    MEMCPY_DN(IERPPAKDAT->ERP_DATE, IERPPAKDAT_N->ERP_DATE, sizeof(IERPPAKDAT->ERP_DATE));
    MEMCPY_DN(IERPPAKDAT->ERP_TIME, IERPPAKDAT_N->ERP_TIME, sizeof(IERPPAKDAT->ERP_TIME));
    IERPPAKDAT->ERP_FLAG = IERPPAKDAT_N->ERP_FLAG[0];
    MEMCPY_DN(IERPPAKDAT->ERP_MSG, IERPPAKDAT_N->ERP_MSG, sizeof(IERPPAKDAT->ERP_MSG));
	MEMCPY_DN(IERPPAKDAT->PVM_PN, IERPPAKDAT_N->PVM_PN, sizeof(IERPPAKDAT->PVM_PN));
	MEMCPY_DN(IERPPAKDAT->PVM_SN, IERPPAKDAT_N->PVM_SN, sizeof(IERPPAKDAT->PVM_SN));
