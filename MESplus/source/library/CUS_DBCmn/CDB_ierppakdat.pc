				:IERPPAKDAT_N.PVM_PN,
				:IERPPAKDAT_N.PVM_SN,
				:IERPPAKDAT_N.PCU_SN,
				:IERPPAKDAT_N.ACM_SN;
            break;

		case 3:
            EXEC SQL FETCH CDB_IERPPAKDAT_CUR_3 INTO
                :IERPPAKDAT_N.DOC_ID,
                :IERPPAKDAT_N.PALLET_ID,
                :IERPPAKDAT_N.MODULE_ID,
                :IERPPAKDAT_N.ACTION_TYPE,
                :IERPPAKDAT_N.MODULE_SEQ,
                :IERPPAKDAT_N.SITE_ID,
                :IERPPAKDAT_N.QTY,
                :IERPPAKDAT_N.PACKING_DATE,
                :IERPPAKDAT_N.PACKING_TIME,
                :IERPPAKDAT_N.PACKING_ID,
                :IERPPAKDAT_N.INTERFACE_DATE,
                :IERPPAKDAT_N.INTERFACE_TIME,
                :IERPPAKDAT_N.INTERFACE_USERID,
                :IERPPAKDAT_N.INF_PROC_TIME,
                :IERPPAKDAT_N.CMF_1,
                :IERPPAKDAT_N.CMF_2,
