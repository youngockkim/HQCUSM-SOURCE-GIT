                :IERPPAKDAT_N.INF_PROC_TIME,
                :IERPPAKDAT_N.CMF_1,
                :IERPPAKDAT_N.CMF_2,
                :IERPPAKDAT_N.CMF_3,
                :IERPPAKDAT_N.CMF_4,
                :IERPPAKDAT_N.CMF_5,
                :IERPPAKDAT_N.DATA_FLAG,
                :IERPPAKDAT_N.ZIFERNAM,
                :IERPPAKDAT_N.ZIFDATE,
                :IERPPAKDAT_N.ZIFTIME,
                :IERPPAKDAT_N.ZPICODE,
                :IERPPAKDAT_N.ZPIMSGID,
                :IERPPAKDAT_N.ZPISTAT,
                :IERPPAKDAT_N.ZPIMSG,
                :IERPPAKDAT_N.RETURN_TYPE,
                :IERPPAKDAT_N.RETURN_MSG,
                :IERPPAKDAT_N.ERP_DATE,
                :IERPPAKDAT_N.ERP_TIME,
                :IERPPAKDAT_N.ERP_FLAG,
