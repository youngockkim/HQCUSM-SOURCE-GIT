/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cedcsuadat(int sel_type, struct CEDCSUADAT_TAG *CEDCSUADAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CEDCSUADAT_N_TAG CEDCSUADAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedcsuadat(&CEDCSUADAT_N, CEDCSUADAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CEDCSUADAT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    INS_TYPE,
                    LOT_ID,
                    HIST_SEQ,
                    INS_CNT,
                    DEFECT_SEQ,
                    RES_ID,
                    LINE_ID,
                    OPER,
                    LOT_HIST_SEQ,
                    INS_TIME,
                    INS_USER_ID,
                    RESULT_VALUE,
                    AOI_LOCATION,
                    AOI_REASON_CODE,
                    ML_LOCATION,
                    ML_REASON_CODE,
                    INSPECTION_RESULT,
                    CELL_IMAGE,
                    AOI_IMAGE,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10
                FROM CEDCSUADAT
                ORDER BY FACTORY ASC,
                    INS_TYPE ASC,
                    LOT_ID ASC,
                    HIST_SEQ ASC,
                    INS_CNT ASC,
                    DEFECT_SEQ ASC;
            EXEC SQL OPEN CDB_CEDCSUADAT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cedcsuadat", sel_type);
}


