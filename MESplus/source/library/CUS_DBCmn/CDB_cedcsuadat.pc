    /* memset by NULL */
    memset(CEDCSUADAT_N, '\0', sizeof(struct CEDCSUADAT_N_TAG));
    
    MEMCPY_AN(CEDCSUADAT_N->FACTORY, CEDCSUADAT->FACTORY, sizeof(CEDCSUADAT->FACTORY));
    MEMCPY_AN(CEDCSUADAT_N->INS_TYPE, CEDCSUADAT->INS_TYPE, sizeof(CEDCSUADAT->INS_TYPE));
    MEMCPY_AN(CEDCSUADAT_N->LOT_ID, CEDCSUADAT->LOT_ID, sizeof(CEDCSUADAT->LOT_ID));
    CEDCSUADAT_N->HIST_SEQ = CEDCSUADAT->HIST_SEQ;
    CEDCSUADAT_N->INS_CNT = CEDCSUADAT->INS_CNT;
    CEDCSUADAT_N->DEFECT_SEQ = CEDCSUADAT->DEFECT_SEQ;
    MEMCPY_AN(CEDCSUADAT_N->RES_ID, CEDCSUADAT->RES_ID, sizeof(CEDCSUADAT->RES_ID));
    MEMCPY_AN(CEDCSUADAT_N->LINE_ID, CEDCSUADAT->LINE_ID, sizeof(CEDCSUADAT->LINE_ID));
    MEMCPY_AN(CEDCSUADAT_N->OPER, CEDCSUADAT->OPER, sizeof(CEDCSUADAT->OPER));
    CEDCSUADAT_N->LOT_HIST_SEQ = CEDCSUADAT->LOT_HIST_SEQ;
    MEMCPY_AN(CEDCSUADAT_N->INS_TIME, CEDCSUADAT->INS_TIME, sizeof(CEDCSUADAT->INS_TIME));
    MEMCPY_AN(CEDCSUADAT_N->INS_USER_ID, CEDCSUADAT->INS_USER_ID, sizeof(CEDCSUADAT->INS_USER_ID));
    MEMCPY_AN(CEDCSUADAT_N->RESULT_VALUE, CEDCSUADAT->RESULT_VALUE, sizeof(CEDCSUADAT->RESULT_VALUE));
    MEMCPY_AN(CEDCSUADAT_N->AOI_LOCATION, CEDCSUADAT->AOI_LOCATION, sizeof(CEDCSUADAT->AOI_LOCATION));
    MEMCPY_AN(CEDCSUADAT_N->AOI_REASON_CODE, CEDCSUADAT->AOI_REASON_CODE, sizeof(CEDCSUADAT->AOI_REASON_CODE));
    MEMCPY_AN(CEDCSUADAT_N->ML_LOCATION, CEDCSUADAT->ML_LOCATION, sizeof(CEDCSUADAT->ML_LOCATION));
    MEMCPY_AN(CEDCSUADAT_N->ML_REASON_CODE, CEDCSUADAT->ML_REASON_CODE, sizeof(CEDCSUADAT->ML_REASON_CODE));
    CEDCSUADAT_N->INSPECTION_RESULT[0] = CEDCSUADAT->INSPECTION_RESULT;
    MEMCPY_AN(CEDCSUADAT_N->CELL_IMAGE, CEDCSUADAT->CELL_IMAGE, sizeof(CEDCSUADAT->CELL_IMAGE));
    MEMCPY_AN(CEDCSUADAT_N->AOI_IMAGE, CEDCSUADAT->AOI_IMAGE, sizeof(CEDCSUADAT->AOI_IMAGE));
    MEMCPY_AN(CEDCSUADAT_N->CMF_1, CEDCSUADAT->CMF_1, sizeof(CEDCSUADAT->CMF_1));
    MEMCPY_AN(CEDCSUADAT_N->CMF_2, CEDCSUADAT->CMF_2, sizeof(CEDCSUADAT->CMF_2));
    MEMCPY_AN(CEDCSUADAT_N->CMF_3, CEDCSUADAT->CMF_3, sizeof(CEDCSUADAT->CMF_3));
    MEMCPY_AN(CEDCSUADAT_N->CMF_4, CEDCSUADAT->CMF_4, sizeof(CEDCSUADAT->CMF_4));
    MEMCPY_AN(CEDCSUADAT_N->CMF_5, CEDCSUADAT->CMF_5, sizeof(CEDCSUADAT->CMF_5));
    MEMCPY_AN(CEDCSUADAT_N->CMF_6, CEDCSUADAT->CMF_6, sizeof(CEDCSUADAT->CMF_6));
    MEMCPY_AN(CEDCSUADAT_N->CMF_7, CEDCSUADAT->CMF_7, sizeof(CEDCSUADAT->CMF_7));
    MEMCPY_AN(CEDCSUADAT_N->CMF_8, CEDCSUADAT->CMF_8, sizeof(CEDCSUADAT->CMF_8));
    MEMCPY_AN(CEDCSUADAT_N->CMF_9, CEDCSUADAT->CMF_9, sizeof(CEDCSUADAT->CMF_9));
    MEMCPY_AN(CEDCSUADAT_N->CMF_10, CEDCSUADAT->CMF_10, sizeof(CEDCSUADAT->CMF_10));
}


/* Del Null Function */
void CDB_del_null_cedcsuadat(struct CEDCSUADAT_N_TAG *CEDCSUADAT_N, struct CEDCSUADAT_TAG *CEDCSUADAT)
{
    MEMCPY_DN(CEDCSUADAT->FACTORY, CEDCSUADAT_N->FACTORY, sizeof(CEDCSUADAT->FACTORY));
    MEMCPY_DN(CEDCSUADAT->INS_TYPE, CEDCSUADAT_N->INS_TYPE, sizeof(CEDCSUADAT->INS_TYPE));
    MEMCPY_DN(CEDCSUADAT->LOT_ID, CEDCSUADAT_N->LOT_ID, sizeof(CEDCSUADAT->LOT_ID));
    CEDCSUADAT->HIST_SEQ = CEDCSUADAT_N->HIST_SEQ;
