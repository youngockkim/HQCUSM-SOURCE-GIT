    MEMCPY_DN(CEDCSUADAT->CMF_3, CEDCSUADAT_N->CMF_3, sizeof(CEDCSUADAT->CMF_3));
    MEMCPY_DN(CEDCSUADAT->CMF_4, CEDCSUADAT_N->CMF_4, sizeof(CEDCSUADAT->CMF_4));
    MEMCPY_DN(CEDCSUADAT->CMF_5, CEDCSUADAT_N->CMF_5, sizeof(CEDCSUADAT->CMF_5));
    MEMCPY_DN(CEDCSUADAT->CMF_6, CEDCSUADAT_N->CMF_6, sizeof(CEDCSUADAT->CMF_6));
    MEMCPY_DN(CEDCSUADAT->CMF_7, CEDCSUADAT_N->CMF_7, sizeof(CEDCSUADAT->CMF_7));
