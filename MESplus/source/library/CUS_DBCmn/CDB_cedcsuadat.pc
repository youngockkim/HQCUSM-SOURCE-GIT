                    :CEDCSUADAT_N.CMF_1,
                    :CEDCSUADAT_N.CMF_2,
                    :CEDCSUADAT_N.CMF_3,
                    :CEDCSUADAT_N.CMF_4,
                    :CEDCSUADAT_N.CMF_5,
                    :CEDCSUADAT_N.CMF_6,
                    :CEDCSUADAT_N.CMF_7,
                    :CEDCSUADAT_N.CMF_8,
                    :CEDCSUADAT_N.CMF_9,
                    :CEDCSUADAT_N.CMF_10
                FROM CEDCSUADAT
                WHERE FACTORY = :CEDCSUADAT_N.FACTORY
                    AND INS_TYPE = :CEDCSUADAT_N.INS_TYPE
                    AND LOT_ID = :CEDCSUADAT_N.LOT_ID
                    AND HIST_SEQ = :CEDCSUADAT_N.HIST_SEQ
