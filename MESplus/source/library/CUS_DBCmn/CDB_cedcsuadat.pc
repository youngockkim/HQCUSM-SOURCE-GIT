    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CEDCSUADAT
                WHERE FACTORY = :CEDCSUADAT_N.FACTORY
                    AND INS_TYPE = :CEDCSUADAT_N.INS_TYPE
                    AND LOT_ID = :CEDCSUADAT_N.LOT_ID
                    AND HIST_SEQ = :CEDCSUADAT_N.HIST_SEQ
                    AND INS_CNT = :CEDCSUADAT_N.INS_CNT
                    AND DEFECT_SEQ = :CEDCSUADAT_N.DEFECT_SEQ;
            break;
			
        case 2:
            EXEC SQL SELECT NVL(MAX(DEFECT_SEQ), 0)
                INTO :d_value
                FROM CEDCSUADAT
                WHERE FACTORY = :CEDCSUADAT_N.FACTORY
                    AND INS_TYPE = :CEDCSUADAT_N.INS_TYPE
                    AND LOT_ID = :CEDCSUADAT_N.LOT_ID
                    AND HIST_SEQ = :CEDCSUADAT_N.HIST_SEQ
                    AND INS_CNT = :CEDCSUADAT_N.INS_CNT;
            break;

        case 3:
            EXEC SQL SELECT count(*)                 
                INTO :d_value
                FROM CEDCSUADAT c,
                (
                    SELECT INS_CNT, 
                        LOT_ID 
                    FROM CEDCLOTRLT 
                    WHERE LOT_ID = :CEDCSUADAT_N.LOT_ID 
                        AND INS_TYPE = 'S1'
                ) h
                where c.HIST_SEQ = h.INS_CNT 
                    and c.LOT_ID = h.LOT_ID
                    and c.INSPECTION_RESULT = '1';

            break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_cedcsuadat_scalar", sel_type);

    return d_value;
}


