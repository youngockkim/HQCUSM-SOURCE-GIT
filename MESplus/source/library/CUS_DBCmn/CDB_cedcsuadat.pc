    MEMCPY_DN(CEDCSUADAT->INS_TIME, CEDCSUADAT_N->INS_TIME, sizeof(CEDCSUADAT->INS_TIME));
    MEMCPY_DN(CEDCSUADAT->INS_USER_ID, CEDCSUADAT_N->INS_USER_ID, sizeof(CEDCSUADAT->INS_USER_ID));
    MEMCPY_DN(CEDCSUADAT->RESULT_VALUE, CEDCSUADAT_N->RESULT_VALUE, sizeof(CEDCSUADAT->RESULT_VALUE));
    MEMCPY_DN(CEDCSUADAT->AOI_LOCATION, CEDCSUADAT_N->AOI_LOCATION, sizeof(CEDCSUADAT->AOI_LOCATION));
    MEMCPY_DN(CEDCSUADAT->AOI_REASON_CODE, CEDCSUADAT_N->AOI_REASON_CODE, sizeof(CEDCSUADAT->AOI_REASON_CODE));
    MEMCPY_DN(CEDCSUADAT->ML_LOCATION, CEDCSUADAT_N->ML_LOCATION, sizeof(CEDCSUADAT->ML_LOCATION));
    MEMCPY_DN(CEDCSUADAT->ML_REASON_CODE, CEDCSUADAT_N->ML_REASON_CODE, sizeof(CEDCSUADAT->ML_REASON_CODE));
    CEDCSUADAT->INSPECTION_RESULT = CEDCSUADAT_N->INSPECTION_RESULT[0];
    MEMCPY_DN(CEDCSUADAT->CELL_IMAGE, CEDCSUADAT_N->CELL_IMAGE, sizeof(CEDCSUADAT->CELL_IMAGE));
    MEMCPY_DN(CEDCSUADAT->AOI_IMAGE, CEDCSUADAT_N->AOI_IMAGE, sizeof(CEDCSUADAT->AOI_IMAGE));
    MEMCPY_DN(CEDCSUADAT->CMF_1, CEDCSUADAT_N->CMF_1, sizeof(CEDCSUADAT->CMF_1));
