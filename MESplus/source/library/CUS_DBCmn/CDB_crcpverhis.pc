    MEMCPY_DN(CRCPVERHIS->DELETE_TIME, CRCPVERHIS_N->DELETE_TIME, sizeof(CRCPVERHIS->DELETE_TIME));
    MEMCPY_DN(CRCPVERHIS->CMF_1, CRCPVERHIS_N->CMF_1, sizeof(CRCPVERHIS->CMF_1));
    MEMCPY_DN(CRCPVERHIS->CMF_2, CRCPVERHIS_N->CMF_2, sizeof(CRCPVERHIS->CMF_2));
    MEMCPY_DN(CRCPVERHIS->CMF_3, CRCPVERHIS_N->CMF_3, sizeof(CRCPVERHIS->CMF_3));
    MEMCPY_DN(CRCPVERHIS->CMF_4, CRCPVERHIS_N->CMF_4, sizeof(CRCPVERHIS->CMF_4));
    MEMCPY_DN(CRCPVERHIS->CMF_5, CRCPVERHIS_N->CMF_5, sizeof(CRCPVERHIS->CMF_5));
    MEMCPY_DN(CRCPVERHIS->CMF_6, CRCPVERHIS_N->CMF_6, sizeof(CRCPVERHIS->CMF_6));
    MEMCPY_DN(CRCPVERHIS->CMF_7, CRCPVERHIS_N->CMF_7, sizeof(CRCPVERHIS->CMF_7));
    MEMCPY_DN(CRCPVERHIS->CMF_8, CRCPVERHIS_N->CMF_8, sizeof(CRCPVERHIS->CMF_8));
    MEMCPY_DN(CRCPVERHIS->CMF_9, CRCPVERHIS_N->CMF_9, sizeof(CRCPVERHIS->CMF_9));
    MEMCPY_DN(CRCPVERHIS->CMF_10, CRCPVERHIS_N->CMF_10, sizeof(CRCPVERHIS->CMF_10));
    CRCPVERHIS->ACTION_FLAG = CRCPVERHIS_N->ACTION_FLAG[0];
}


