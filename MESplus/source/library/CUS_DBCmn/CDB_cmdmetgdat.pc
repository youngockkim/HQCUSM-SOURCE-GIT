/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cmdmetgdat(int sel_type, struct CMDMETGDAT_TAG *CMDMETGDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMDMETGDAT_N_TAG CMDMETGDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cmdmetgdat(&CMDMETGDAT_N, CMDMETGDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CMDMETGDAT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    CW,
                    SAMPLING_DATE,
                    TEST_DATE,
                    LINE_ID,
                    MACHINE_NO,
                    POSITION,
                    MEASURE_TYPE,
                    TYPE_EVA_FRONT,
                    GRN_NR_EVA_FRONT,
                    GLASS_TYPE,
                    GRN_NR_GLASS,
                    REPEAT_MEASURE_NO,
                    POS_A,
                    POS_B,
                    POS_C,
                    POS_D,
                    POS_E,
                    POS_F,
                    POS_G,
                    POS_H,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    DATA_COMMENT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMDMETGDAT
                ORDER BY FACTORY ASC,
                    CW ASC,
                    SAMPLING_DATE ASC,
                    TEST_DATE ASC,
                    LINE_ID ASC,
                    MACHINE_NO ASC,
                    POSITION ASC,
                    MEASURE_TYPE ASC;
            EXEC SQL OPEN CDB_CMDMETGDAT_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE CDB_CMDMETGDAT_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    CW,
                    SAMPLING_DATE,
                    TEST_DATE,
                    LINE_ID,
                    MACHINE_NO,
                    POSITION,
                    MEASURE_TYPE,
                    TYPE_EVA_FRONT,
                    GRN_NR_EVA_FRONT,
                    GLASS_TYPE,
                    GRN_NR_GLASS,
                    REPEAT_MEASURE_NO,
                    POS_A,
                    POS_B,
                    POS_C,
                    POS_D,
                    POS_E,
                    POS_F,
                    POS_G,
                    POS_H,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    DATA_COMMENT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMDMETGDAT
                WHERE FACTORY = :CMDMETGDAT_N.FACTORY
                    AND TEST_DATE >= :DBC_Q_COND_N.FROM_DATE 
                    AND TEST_DATE <= :DBC_Q_COND_N.TO_DATE
                    AND CW LIKE :CMDMETGDAT_N.CW
                    AND LINE_ID LIKE :CMDMETGDAT_N.LINE_ID
                    AND MACHINE_NO LIKE :CMDMETGDAT_N.MACHINE_NO
                    AND POSITION LIKE :CMDMETGDAT_N.POSITION
                    AND MEASURE_TYPE LIKE :CMDMETGDAT_N.MEASURE_TYPE
                ORDER BY FACTORY ASC,
                    SAMPLING_DATE ASC,
                    TEST_DATE ASC,
                    CW ASC,
                    LINE_ID ASC,
                    MACHINE_NO ASC,
                    POSITION ASC,
                    MEASURE_TYPE ASC;
            EXEC SQL OPEN CDB_CMDMETGDAT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cmdmetgdat", sel_type);
}


