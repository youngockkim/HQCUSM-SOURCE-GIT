                :CMDMETGDAT_N.GLASS_TYPE,
                :CMDMETGDAT_N.GRN_NR_GLASS,
                :CMDMETGDAT_N.REPEAT_MEASURE_NO,
                :CMDMETGDAT_N.POS_A,
                :CMDMETGDAT_N.POS_B,
                :CMDMETGDAT_N.POS_C,
                :CMDMETGDAT_N.POS_D,
                :CMDMETGDAT_N.POS_E,
                :CMDMETGDAT_N.POS_F,
                :CMDMETGDAT_N.POS_G,
                :CMDMETGDAT_N.POS_H,
                :CMDMETGDAT_N.QTY_1,
                :CMDMETGDAT_N.QTY_2,
                :CMDMETGDAT_N.QTY_3,
                :CMDMETGDAT_N.DATA_COMMENT,
                :CMDMETGDAT_N.CMF_1,
                :CMDMETGDAT_N.CMF_2,
                :CMDMETGDAT_N.CMF_3,
                :CMDMETGDAT_N.CMF_4,
                :CMDMETGDAT_N.CMF_5,
                :CMDMETGDAT_N.CMF_6,
                :CMDMETGDAT_N.CMF_7,
                :CMDMETGDAT_N.CMF_8,
                :CMDMETGDAT_N.CMF_9,
                :CMDMETGDAT_N.CMF_10,
                :CMDMETGDAT_N.CREATE_USER_ID,
                :CMDMETGDAT_N.CREATE_TIME,
                :CMDMETGDAT_N.UPDATE_USER_ID,
                :CMDMETGDAT_N.UPDATE_TIME;
            break;

        case 2:
            EXEC SQL FETCH CDB_CMDMETGDAT_CUR_2 INTO
                :CMDMETGDAT_N.FACTORY,
                :CMDMETGDAT_N.CW,
                :CMDMETGDAT_N.SAMPLING_DATE,
                :CMDMETGDAT_N.TEST_DATE,
                :CMDMETGDAT_N.LINE_ID,
                :CMDMETGDAT_N.MACHINE_NO,
                :CMDMETGDAT_N.POSITION,
                :CMDMETGDAT_N.MEASURE_TYPE,
                :CMDMETGDAT_N.TYPE_EVA_FRONT,
                :CMDMETGDAT_N.GRN_NR_EVA_FRONT,
                :CMDMETGDAT_N.GLASS_TYPE,
                :CMDMETGDAT_N.GRN_NR_GLASS,
                :CMDMETGDAT_N.REPEAT_MEASURE_NO,
                :CMDMETGDAT_N.POS_A,
                :CMDMETGDAT_N.POS_B,
                :CMDMETGDAT_N.POS_C,
                :CMDMETGDAT_N.POS_D,
                :CMDMETGDAT_N.POS_E,
                :CMDMETGDAT_N.POS_F,
                :CMDMETGDAT_N.POS_G,
                :CMDMETGDAT_N.POS_H,
                :CMDMETGDAT_N.QTY_1,
                :CMDMETGDAT_N.QTY_2,
                :CMDMETGDAT_N.QTY_3,
                :CMDMETGDAT_N.DATA_COMMENT,
                :CMDMETGDAT_N.CMF_1,
                :CMDMETGDAT_N.CMF_2,
                :CMDMETGDAT_N.CMF_3,
                :CMDMETGDAT_N.CMF_4,
                :CMDMETGDAT_N.CMF_5,
                :CMDMETGDAT_N.CMF_6,
                :CMDMETGDAT_N.CMF_7,
                :CMDMETGDAT_N.CMF_8,
                :CMDMETGDAT_N.CMF_9,
                :CMDMETGDAT_N.CMF_10,
                :CMDMETGDAT_N.CREATE_USER_ID,
                :CMDMETGDAT_N.CREATE_TIME,
                :CMDMETGDAT_N.UPDATE_USER_ID,
                :CMDMETGDAT_N.UPDATE_TIME;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cmdmetgdat(&CMDMETGDAT_N, CMDMETGDAT);
    }

    DB_stop_query_timer("CDB_fetch_cmdmetgdat", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cmdmetgdat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CMDMETGDAT_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE CDB_CMDMETGDAT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cmdmetgdat", sel_type);
}


/* Initialize Function */
void CDB_init_cmdmetgdat(struct CMDMETGDAT_TAG *CMDMETGDAT)
{
    /* memset by Space */
    memset(CMDMETGDAT, ' ', sizeof(struct CMDMETGDAT_TAG));
    
    CMDMETGDAT->POS_A = 0;
    CMDMETGDAT->POS_B = 0;
    CMDMETGDAT->POS_C = 0;
    CMDMETGDAT->POS_D = 0;
    CMDMETGDAT->POS_E = 0;
    CMDMETGDAT->POS_F = 0;
    CMDMETGDAT->POS_G = 0;
    CMDMETGDAT->POS_H = 0;
    CMDMETGDAT->QTY_1 = 0;
    CMDMETGDAT->QTY_2 = 0;
    CMDMETGDAT->QTY_3 = 0;
}


/* Add Null Function */
void CDB_add_null_cmdmetgdat(struct CMDMETGDAT_N_TAG *CMDMETGDAT_N, struct CMDMETGDAT_TAG *CMDMETGDAT)
{
    /* memset by NULL */
    memset(CMDMETGDAT_N, '\0', sizeof(struct CMDMETGDAT_N_TAG));
    
    MEMCPY_AN(CMDMETGDAT_N->FACTORY, CMDMETGDAT->FACTORY, sizeof(CMDMETGDAT->FACTORY));
    MEMCPY_AN(CMDMETGDAT_N->CW, CMDMETGDAT->CW, sizeof(CMDMETGDAT->CW));
