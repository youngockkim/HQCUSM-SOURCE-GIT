    DB_stop_query_timer("CDB_insert_iwipcelhui", 0);
}


/* SQL UPDATE Function */
void CDB_update_iwipcelhui(int sel_type, struct IWIPCELHUI_TAG *IWIPCELHUI)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IWIPCELHUI_N_TAG IWIPCELHUI_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_iwipcelhui(&IWIPCELHUI_N, IWIPCELHUI);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE IWIPCELHUI SET
                    SITE_ID = :IWIPCELHUI_N.SITE_ID,
                    STORAGE_LOCATION = :IWIPCELHUI_N.STORAGE_LOCATION,
