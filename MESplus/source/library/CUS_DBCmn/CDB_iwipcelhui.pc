/* Initialize Function */
void CDB_init_iwipcelhui(struct IWIPCELHUI_TAG *IWIPCELHUI)
{
    /* memset by Space */
    memset(IWIPCELHUI, ' ', sizeof(struct IWIPCELHUI_TAG));
    
    IWIPCELHUI->ERP_MW = 0;
    IWIPCELHUI->SORTER_MW = 0;
    IWIPCELHUI->AVG_NCELL = 0;
    IWIPCELHUI->AVG_ISC = 0;
    IWIPCELHUI->AVG_UOC = 0;
    IWIPCELHUI->AVG_FF = 0;
    IWIPCELHUI->AVG_RS = 0;
    IWIPCELHUI->AVG_RSH = 0;
    IWIPCELHUI->AVG_TEMPERATURE = 0;
}


/* Add Null Function */
void CDB_add_null_iwipcelhui(struct IWIPCELHUI_N_TAG *IWIPCELHUI_N, struct IWIPCELHUI_TAG *IWIPCELHUI)
{
    /* memset by NULL */
    memset(IWIPCELHUI_N, '\0', sizeof(struct IWIPCELHUI_N_TAG));
    
    MEMCPY_AN(IWIPCELHUI_N->DOC_ID, IWIPCELHUI->DOC_ID, sizeof(IWIPCELHUI->DOC_ID));
    MEMCPY_AN(IWIPCELHUI_N->SMALLBOXID, IWIPCELHUI->SMALLBOXID, sizeof(IWIPCELHUI->SMALLBOXID));
    MEMCPY_AN(IWIPCELHUI_N->ACTION_TYPE, IWIPCELHUI->ACTION_TYPE, sizeof(IWIPCELHUI->ACTION_TYPE));
