                    CELLTYPE = :IWIPCELHUI_N.CELLTYPE,
                    CELLPRODUCTDATE = :IWIPCELHUI_N.CELLPRODUCTDATE,
                    CELLGRADE = :IWIPCELHUI_N.CELLGRADE,
                    CELLBOXBARCODE = :IWIPCELHUI_N.CELLBOXBARCODE,
                    INSPECT_STATUS = :IWIPCELHUI_N.INSPECT_STATUS,
                    BLOCK_STATUS = :IWIPCELHUI_N.BLOCK_STATUS,
                    BLOCK_DATE = :IWIPCELHUI_N.BLOCK_DATE,
                    POWERGRADE = :IWIPCELHUI_N.POWERGRADE,
                    QUALITYGRADE = :IWIPCELHUI_N.QUALITYGRADE,
                    ERP_MW = :IWIPCELHUI_N.ERP_MW,
                    SORTER_MW = :IWIPCELHUI_N.SORTER_MW,
                    AVG_NCELL = :IWIPCELHUI_N.AVG_NCELL,
                    AVG_ISC = :IWIPCELHUI_N.AVG_ISC,
                    AVG_UOC = :IWIPCELHUI_N.AVG_UOC,
                    AVG_FF = :IWIPCELHUI_N.AVG_FF,
                    AVG_RS = :IWIPCELHUI_N.AVG_RS,
                    AVG_RSH = :IWIPCELHUI_N.AVG_RSH,
                    AVG_TEMPERATURE = :IWIPCELHUI_N.AVG_TEMPERATURE,
                    WORKDAY = :IWIPCELHUI_N.WORKDAY,
                    WORKTIME = :IWIPCELHUI_N.WORKTIME,
                    PRODUCTCLASSID = :IWIPCELHUI_N.PRODUCTCLASSID,
                    PRODUCTDEFINITIONTYPE = :IWIPCELHUI_N.PRODUCTDEFINITIONTYPE,
                    INF_TIME = :IWIPCELHUI_N.INF_TIME,
                    INF_PROC_TIME = :IWIPCELHUI_N.INF_PROC_TIME,
                    CMF_1 = :IWIPCELHUI_N.CMF_1,
                    CMF_2 = :IWIPCELHUI_N.CMF_2,
                    CMF_3 = :IWIPCELHUI_N.CMF_3,
                    CMF_4 = :IWIPCELHUI_N.CMF_4,
                    CMF_5 = :IWIPCELHUI_N.CMF_5,
                    DATA_FLAG = :IWIPCELHUI_N.DATA_FLAG,
                    UPDATE_COUNT = :IWIPCELHUI_N.UPDATE_COUNT,
                    INSERT_COUNT = :IWIPCELHUI_N.INSERT_COUNT,
                    DELETE_COUNT = :IWIPCELHUI_N.DELETE_COUNT,
                    SQL_DML_COUNT = :IWIPCELHUI_N.SQL_DML_COUNT,
                    ZPICODE = :IWIPCELHUI_N.ZPICODE,
                    ZPIMSGID = :IWIPCELHUI_N.ZPIMSGID,
                    RETURN_TYPE = :IWIPCELHUI_N.RETURN_TYPE,
                    RETURN_MSG = :IWIPCELHUI_N.RETURN_MSG,
                    ZIFERNAM = :IWIPCELHUI_N.ZIFERNAM,
                    ZIFDATE = :IWIPCELHUI_N.ZIFDATE,
                    ZIFTIME = :IWIPCELHUI_N.ZIFTIME,
                    ZPISTAT = :IWIPCELHUI_N.ZPISTAT,
                    ZPIMSG = :IWIPCELHUI_N.ZPIMSG
                WHERE DOC_ID = :IWIPCELHUI_N.DOC_ID
                    AND SMALLBOXID = :IWIPCELHUI_N.SMALLBOXID
                    AND ACTION_TYPE = :IWIPCELHUI_N.ACTION_TYPE;
            break;

		case 2:
            EXEC SQL UPDATE IWIPCELHUI SET
                    INF_PROC_TIME = :IWIPCELHUI_N.INF_PROC_TIME,
                    RETURN_TYPE = 'E',
                    RETURN_MSG = :IWIPCELHUI_N.RETURN_MSG
                WHERE DOC_ID = :IWIPCELHUI_N.DOC_ID
                    AND SMALLBOXID = :IWIPCELHUI_N.SMALLBOXID
                    AND ACTION_TYPE = :IWIPCELHUI_N.ACTION_TYPE;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_iwipcelhui", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_iwipcelhui(int sel_type, struct IWIPCELHUI_TAG *IWIPCELHUI)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IWIPCELHUI_N_TAG IWIPCELHUI_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_iwipcelhui(&IWIPCELHUI_N, IWIPCELHUI);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IWIPCELHUI_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SMALLBOXID,
                    ACTION_TYPE,
                    SITE_ID,
                    STORAGE_LOCATION,
                    FR_SITE_ID,
                    MATERIALDEFINITIONID,
                    BATCHNO,
                    ORI_QTY,
                    UNIT_ID,
                    MIDDLEBOXID,
                    LARGEBOXID,
                    CELLTYPE,
                    CELLPRODUCTDATE,
                    CELLGRADE,
                    CELLBOXBARCODE,
                    INSPECT_STATUS,
                    BLOCK_STATUS,
                    BLOCK_DATE,
                    POWERGRADE,
                    QUALITYGRADE,
                    ERP_MW,
                    SORTER_MW,
                    AVG_NCELL,
                    AVG_ISC,
                    AVG_UOC,
                    AVG_FF,
                    AVG_RS,
                    AVG_RSH,
                    AVG_TEMPERATURE,
                    WORKDAY,
                    WORKTIME,
                    PRODUCTCLASSID,
                    PRODUCTDEFINITIONTYPE,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IWIPCELHUI
                ORDER BY DOC_ID ASC,
                    SMALLBOXID ASC,
                    ACTION_TYPE ASC;
            EXEC SQL OPEN CDB_IWIPCELHUI_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_IWIPCELHUI_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SMALLBOXID,
                    ACTION_TYPE,
                    SITE_ID,
                    STORAGE_LOCATION,
                    FR_SITE_ID,
                    MATERIALDEFINITIONID,
                    BATCHNO,
                    ORI_QTY,
                    UNIT_ID,
                    MIDDLEBOXID,
                    LARGEBOXID,
                    CELLTYPE,
                    CELLPRODUCTDATE,
                    CELLGRADE,
                    CELLBOXBARCODE,
                    INSPECT_STATUS,
                    BLOCK_STATUS,
                    BLOCK_DATE,
                    POWERGRADE,
                    QUALITYGRADE,
                    ERP_MW,
                    SORTER_MW,
                    AVG_NCELL,
                    AVG_ISC,
                    AVG_UOC,
                    AVG_FF,
                    AVG_RS,
                    AVG_RSH,
                    AVG_TEMPERATURE,
                    WORKDAY,
                    WORKTIME,
                    PRODUCTCLASSID,
                    PRODUCTDEFINITIONTYPE,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IWIPCELHUI
				WHERE RETURN_TYPE <> 'E'
				AND ROWNUM < 10000
                ORDER BY DOC_ID ASC,
                    SMALLBOXID ASC,
                    ACTION_TYPE ASC;
            EXEC SQL OPEN CDB_IWIPCELHUI_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_iwipcelhui", sel_type);
}


