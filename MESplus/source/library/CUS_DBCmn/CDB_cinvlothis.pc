    MEMCPY_DN(CINVLOTHIS->CMF_5, CINVLOTHIS_N->CMF_5, sizeof(CINVLOTHIS->CMF_5));
    MEMCPY_DN(CINVLOTHIS->CMF_6, CINVLOTHIS_N->CMF_6, sizeof(CINVLOTHIS->CMF_6));
    MEMCPY_DN(CINVLOTHIS->CMF_7, CINVLOTHIS_N->CMF_7, sizeof(CINVLOTHIS->CMF_7));
