    MEMCPY_DN(CINVLOTHIS->CMF_9, CINVLOTHIS_N->CMF_9, sizeof(CINVLOTHIS->CMF_9));
    MEMCPY_DN(CINVLOTHIS->CMF_10, CINVLOTHIS_N->CMF_10, sizeof(CINVLOTHIS->CMF_10));
