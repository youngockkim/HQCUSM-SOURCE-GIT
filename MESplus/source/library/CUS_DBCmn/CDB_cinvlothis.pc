                    VEN_BATCH_NO = :CINVLOTHIS_N.VEN_BATCH_NO,
                    VENDOR_MAT_ID = :CINVLOTHIS_N.VENDOR_MAT_ID,
                    QTY_1 = :CINVLOTHIS_N.QTY_1,
                    QTY_2 = :CINVLOTHIS_N.QTY_2,
                    QTY_3 = :CINVLOTHIS_N.QTY_3,
                    UNIT_1 = :CINVLOTHIS_N.UNIT_1,
                    UNIT_2 = :CINVLOTHIS_N.UNIT_2,
                    UNIT_3 = :CINVLOTHIS_N.UNIT_3,
                    VENDOR_LOTID = :CINVLOTHIS_N.VENDOR_LOTID,
                    DELETE_FLAG = :CINVLOTHIS_N.DELETE_FLAG,
                    LAST_TRAN_TIME = :CINVLOTHIS_N.LAST_TRAN_TIME,
                    LAST_TRAN_USER_ID = :CINVLOTHIS_N.LAST_TRAN_USER_ID,
                    LAST_TRAN_TYPE = :CINVLOTHIS_N.LAST_TRAN_TYPE,
                    PUR_ORDER_NO = :CINVLOTHIS_N.PUR_ORDER_NO,
                    PUR_TYPE = :CINVLOTHIS_N.PUR_TYPE,
                    PACKAGE_TYPE = :CINVLOTHIS_N.PACKAGE_TYPE,
                    IQC_FLAG = :CINVLOTHIS_N.IQC_FLAG,
                    INPUT_TIME = :CINVLOTHIS_N.INPUT_TIME,
                    PROD_TIME = :CINVLOTHIS_N.PROD_TIME,
                    ASSIGN_TIME = :CINVLOTHIS_N.ASSIGN_TIME,
                    CMF_1 = :CINVLOTHIS_N.CMF_1,
                    CMF_2 = :CINVLOTHIS_N.CMF_2,
                    CMF_3 = :CINVLOTHIS_N.CMF_3,
                    CMF_4 = :CINVLOTHIS_N.CMF_4,
                    CMF_5 = :CINVLOTHIS_N.CMF_5,
                    CMF_6 = :CINVLOTHIS_N.CMF_6,
                    CMF_7 = :CINVLOTHIS_N.CMF_7,
                    CMF_8 = :CINVLOTHIS_N.CMF_8,
                    CMF_9 = :CINVLOTHIS_N.CMF_9,
                    CMF_10 = :CINVLOTHIS_N.CMF_10
                WHERE FACTORY = :CINVLOTHIS_N.FACTORY
                    AND INV_LOT_ID = :CINVLOTHIS_N.INV_LOT_ID
                    AND HIST_SEQ = :CINVLOTHIS_N.HIST_SEQ;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_cinvlothis", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cinvlothis(int sel_type, struct CINVLOTHIS_TAG *CINVLOTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CINVLOTHIS_N_TAG CINVLOTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cinvlothis(&CINVLOTHIS_N, CINVLOTHIS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CINVLOTHIS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    INV_LOT_ID,
                    HIST_SEQ,
                    VENDOR_BARCD,
                    OPER,
                    MAT_ID,
                    INV_MAT_TYPE,
                    VENDOR_ID,
                    VENDOR_MAT_TYPE,
                    LOCATION,
                    OLD_LOCATION,
                    BATCH_NO,
                    VEN_BATCH_NO,
                    VENDOR_MAT_ID,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    UNIT_1,
                    UNIT_2,
                    UNIT_3,
                    VENDOR_LOTID,
                    DELETE_FLAG,
                    LAST_TRAN_TIME,
                    LAST_TRAN_USER_ID,
                    LAST_TRAN_TYPE,
                    PUR_ORDER_NO,
                    PUR_TYPE,
                    PACKAGE_TYPE,
                    IQC_FLAG,
                    INPUT_TIME,
                    PROD_TIME,
                    ASSIGN_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10
                FROM CINVLOTHIS
                ORDER BY FACTORY ASC,
                    INV_LOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN CDB_CINVLOTHIS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cinvlothis", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_cinvlothis(int sel_type, struct CINVLOTHIS_TAG *CINVLOTHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CINVLOTHIS_N_TAG CINVLOTHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CINVLOTHIS_CUR_1 INTO
                :CINVLOTHIS_N.FACTORY,
                :CINVLOTHIS_N.INV_LOT_ID,
                :CINVLOTHIS_N.HIST_SEQ,
                :CINVLOTHIS_N.VENDOR_BARCD,
                :CINVLOTHIS_N.OPER,
                :CINVLOTHIS_N.MAT_ID,
                :CINVLOTHIS_N.INV_MAT_TYPE,
                :CINVLOTHIS_N.VENDOR_ID,
                :CINVLOTHIS_N.VENDOR_MAT_TYPE,
                :CINVLOTHIS_N.LOCATION,
                :CINVLOTHIS_N.OLD_LOCATION,
                :CINVLOTHIS_N.BATCH_NO,
                :CINVLOTHIS_N.VEN_BATCH_NO,
                :CINVLOTHIS_N.VENDOR_MAT_ID,
                :CINVLOTHIS_N.QTY_1,
                :CINVLOTHIS_N.QTY_2,
                :CINVLOTHIS_N.QTY_3,
                :CINVLOTHIS_N.UNIT_1,
                :CINVLOTHIS_N.UNIT_2,
                :CINVLOTHIS_N.UNIT_3,
                :CINVLOTHIS_N.VENDOR_LOTID,
                :CINVLOTHIS_N.DELETE_FLAG,
                :CINVLOTHIS_N.LAST_TRAN_TIME,
                :CINVLOTHIS_N.LAST_TRAN_USER_ID,
                :CINVLOTHIS_N.LAST_TRAN_TYPE,
                :CINVLOTHIS_N.PUR_ORDER_NO,
                :CINVLOTHIS_N.PUR_TYPE,
                :CINVLOTHIS_N.PACKAGE_TYPE,
                :CINVLOTHIS_N.IQC_FLAG,
                :CINVLOTHIS_N.INPUT_TIME,
                :CINVLOTHIS_N.PROD_TIME,
                :CINVLOTHIS_N.ASSIGN_TIME,
                :CINVLOTHIS_N.CMF_1,
                :CINVLOTHIS_N.CMF_2,
                :CINVLOTHIS_N.CMF_3,
                :CINVLOTHIS_N.CMF_4,
                :CINVLOTHIS_N.CMF_5,
                :CINVLOTHIS_N.CMF_6,
                :CINVLOTHIS_N.CMF_7,
                :CINVLOTHIS_N.CMF_8,
                :CINVLOTHIS_N.CMF_9,
                :CINVLOTHIS_N.CMF_10;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cinvlothis(&CINVLOTHIS_N, CINVLOTHIS);
    }

    DB_stop_query_timer("CDB_fetch_cinvlothis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cinvlothis(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CINVLOTHIS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cinvlothis", sel_type);
}


/* Initialize Function */
void CDB_init_cinvlothis(struct CINVLOTHIS_TAG *CINVLOTHIS)
{
    /* memset by Space */
    memset(CINVLOTHIS, ' ', sizeof(struct CINVLOTHIS_TAG));
    
    CINVLOTHIS->HIST_SEQ = 0;
    CINVLOTHIS->QTY_1 = 0;
    CINVLOTHIS->QTY_2 = 0;
    CINVLOTHIS->QTY_3 = 0;
}


/* Add Null Function */
void CDB_add_null_cinvlothis(struct CINVLOTHIS_N_TAG *CINVLOTHIS_N, struct CINVLOTHIS_TAG *CINVLOTHIS)
{
    /* memset by NULL */
    memset(CINVLOTHIS_N, '\0', sizeof(struct CINVLOTHIS_N_TAG));
    
    MEMCPY_AN(CINVLOTHIS_N->FACTORY, CINVLOTHIS->FACTORY, sizeof(CINVLOTHIS->FACTORY));
    MEMCPY_AN(CINVLOTHIS_N->INV_LOT_ID, CINVLOTHIS->INV_LOT_ID, sizeof(CINVLOTHIS->INV_LOT_ID));
    CINVLOTHIS_N->HIST_SEQ = CINVLOTHIS->HIST_SEQ;
    MEMCPY_AN(CINVLOTHIS_N->VENDOR_BARCD, CINVLOTHIS->VENDOR_BARCD, sizeof(CINVLOTHIS->VENDOR_BARCD));
    MEMCPY_AN(CINVLOTHIS_N->OPER, CINVLOTHIS->OPER, sizeof(CINVLOTHIS->OPER));
    MEMCPY_AN(CINVLOTHIS_N->MAT_ID, CINVLOTHIS->MAT_ID, sizeof(CINVLOTHIS->MAT_ID));
    MEMCPY_AN(CINVLOTHIS_N->INV_MAT_TYPE, CINVLOTHIS->INV_MAT_TYPE, sizeof(CINVLOTHIS->INV_MAT_TYPE));
    MEMCPY_AN(CINVLOTHIS_N->VENDOR_ID, CINVLOTHIS->VENDOR_ID, sizeof(CINVLOTHIS->VENDOR_ID));
    MEMCPY_AN(CINVLOTHIS_N->VENDOR_MAT_TYPE, CINVLOTHIS->VENDOR_MAT_TYPE, sizeof(CINVLOTHIS->VENDOR_MAT_TYPE));
    MEMCPY_AN(CINVLOTHIS_N->LOCATION, CINVLOTHIS->LOCATION, sizeof(CINVLOTHIS->LOCATION));
    MEMCPY_AN(CINVLOTHIS_N->OLD_LOCATION, CINVLOTHIS->OLD_LOCATION, sizeof(CINVLOTHIS->OLD_LOCATION));
    MEMCPY_AN(CINVLOTHIS_N->BATCH_NO, CINVLOTHIS->BATCH_NO, sizeof(CINVLOTHIS->BATCH_NO));
    MEMCPY_AN(CINVLOTHIS_N->VEN_BATCH_NO, CINVLOTHIS->VEN_BATCH_NO, sizeof(CINVLOTHIS->VEN_BATCH_NO));
    MEMCPY_AN(CINVLOTHIS_N->VENDOR_MAT_ID, CINVLOTHIS->VENDOR_MAT_ID, sizeof(CINVLOTHIS->VENDOR_MAT_ID));
    CINVLOTHIS_N->QTY_1 = CINVLOTHIS->QTY_1;
    CINVLOTHIS_N->QTY_2 = CINVLOTHIS->QTY_2;
    CINVLOTHIS_N->QTY_3 = CINVLOTHIS->QTY_3;
    MEMCPY_AN(CINVLOTHIS_N->UNIT_1, CINVLOTHIS->UNIT_1, sizeof(CINVLOTHIS->UNIT_1));
    MEMCPY_AN(CINVLOTHIS_N->UNIT_2, CINVLOTHIS->UNIT_2, sizeof(CINVLOTHIS->UNIT_2));
    MEMCPY_AN(CINVLOTHIS_N->UNIT_3, CINVLOTHIS->UNIT_3, sizeof(CINVLOTHIS->UNIT_3));
    MEMCPY_AN(CINVLOTHIS_N->VENDOR_LOTID, CINVLOTHIS->VENDOR_LOTID, sizeof(CINVLOTHIS->VENDOR_LOTID));
    CINVLOTHIS_N->DELETE_FLAG[0] = CINVLOTHIS->DELETE_FLAG;
    MEMCPY_AN(CINVLOTHIS_N->LAST_TRAN_TIME, CINVLOTHIS->LAST_TRAN_TIME, sizeof(CINVLOTHIS->LAST_TRAN_TIME));
    MEMCPY_AN(CINVLOTHIS_N->LAST_TRAN_USER_ID, CINVLOTHIS->LAST_TRAN_USER_ID, sizeof(CINVLOTHIS->LAST_TRAN_USER_ID));
    MEMCPY_AN(CINVLOTHIS_N->LAST_TRAN_TYPE, CINVLOTHIS->LAST_TRAN_TYPE, sizeof(CINVLOTHIS->LAST_TRAN_TYPE));
    MEMCPY_AN(CINVLOTHIS_N->PUR_ORDER_NO, CINVLOTHIS->PUR_ORDER_NO, sizeof(CINVLOTHIS->PUR_ORDER_NO));
    MEMCPY_AN(CINVLOTHIS_N->PUR_TYPE, CINVLOTHIS->PUR_TYPE, sizeof(CINVLOTHIS->PUR_TYPE));
    MEMCPY_AN(CINVLOTHIS_N->PACKAGE_TYPE, CINVLOTHIS->PACKAGE_TYPE, sizeof(CINVLOTHIS->PACKAGE_TYPE));
    CINVLOTHIS_N->IQC_FLAG[0] = CINVLOTHIS->IQC_FLAG;
    MEMCPY_AN(CINVLOTHIS_N->INPUT_TIME, CINVLOTHIS->INPUT_TIME, sizeof(CINVLOTHIS->INPUT_TIME));
    MEMCPY_AN(CINVLOTHIS_N->PROD_TIME, CINVLOTHIS->PROD_TIME, sizeof(CINVLOTHIS->PROD_TIME));
    MEMCPY_AN(CINVLOTHIS_N->ASSIGN_TIME, CINVLOTHIS->ASSIGN_TIME, sizeof(CINVLOTHIS->ASSIGN_TIME));
    MEMCPY_AN(CINVLOTHIS_N->CMF_1, CINVLOTHIS->CMF_1, sizeof(CINVLOTHIS->CMF_1));
    MEMCPY_AN(CINVLOTHIS_N->CMF_2, CINVLOTHIS->CMF_2, sizeof(CINVLOTHIS->CMF_2));
    MEMCPY_AN(CINVLOTHIS_N->CMF_3, CINVLOTHIS->CMF_3, sizeof(CINVLOTHIS->CMF_3));
    MEMCPY_AN(CINVLOTHIS_N->CMF_4, CINVLOTHIS->CMF_4, sizeof(CINVLOTHIS->CMF_4));
    MEMCPY_AN(CINVLOTHIS_N->CMF_5, CINVLOTHIS->CMF_5, sizeof(CINVLOTHIS->CMF_5));
    MEMCPY_AN(CINVLOTHIS_N->CMF_6, CINVLOTHIS->CMF_6, sizeof(CINVLOTHIS->CMF_6));
    MEMCPY_AN(CINVLOTHIS_N->CMF_7, CINVLOTHIS->CMF_7, sizeof(CINVLOTHIS->CMF_7));
    MEMCPY_AN(CINVLOTHIS_N->CMF_8, CINVLOTHIS->CMF_8, sizeof(CINVLOTHIS->CMF_8));
    MEMCPY_AN(CINVLOTHIS_N->CMF_9, CINVLOTHIS->CMF_9, sizeof(CINVLOTHIS->CMF_9));
    MEMCPY_AN(CINVLOTHIS_N->CMF_10, CINVLOTHIS->CMF_10, sizeof(CINVLOTHIS->CMF_10));
}


/* Del Null Function */
void CDB_del_null_cinvlothis(struct CINVLOTHIS_N_TAG *CINVLOTHIS_N, struct CINVLOTHIS_TAG *CINVLOTHIS)
{
    MEMCPY_DN(CINVLOTHIS->FACTORY, CINVLOTHIS_N->FACTORY, sizeof(CINVLOTHIS->FACTORY));
    MEMCPY_DN(CINVLOTHIS->INV_LOT_ID, CINVLOTHIS_N->INV_LOT_ID, sizeof(CINVLOTHIS->INV_LOT_ID));
    CINVLOTHIS->HIST_SEQ = CINVLOTHIS_N->HIST_SEQ;
    MEMCPY_DN(CINVLOTHIS->VENDOR_BARCD, CINVLOTHIS_N->VENDOR_BARCD, sizeof(CINVLOTHIS->VENDOR_BARCD));
    MEMCPY_DN(CINVLOTHIS->OPER, CINVLOTHIS_N->OPER, sizeof(CINVLOTHIS->OPER));
    MEMCPY_DN(CINVLOTHIS->MAT_ID, CINVLOTHIS_N->MAT_ID, sizeof(CINVLOTHIS->MAT_ID));
    MEMCPY_DN(CINVLOTHIS->INV_MAT_TYPE, CINVLOTHIS_N->INV_MAT_TYPE, sizeof(CINVLOTHIS->INV_MAT_TYPE));
    MEMCPY_DN(CINVLOTHIS->VENDOR_ID, CINVLOTHIS_N->VENDOR_ID, sizeof(CINVLOTHIS->VENDOR_ID));
    MEMCPY_DN(CINVLOTHIS->VENDOR_MAT_TYPE, CINVLOTHIS_N->VENDOR_MAT_TYPE, sizeof(CINVLOTHIS->VENDOR_MAT_TYPE));
    MEMCPY_DN(CINVLOTHIS->LOCATION, CINVLOTHIS_N->LOCATION, sizeof(CINVLOTHIS->LOCATION));
    MEMCPY_DN(CINVLOTHIS->OLD_LOCATION, CINVLOTHIS_N->OLD_LOCATION, sizeof(CINVLOTHIS->OLD_LOCATION));
    MEMCPY_DN(CINVLOTHIS->BATCH_NO, CINVLOTHIS_N->BATCH_NO, sizeof(CINVLOTHIS->BATCH_NO));
    MEMCPY_DN(CINVLOTHIS->VEN_BATCH_NO, CINVLOTHIS_N->VEN_BATCH_NO, sizeof(CINVLOTHIS->VEN_BATCH_NO));
    MEMCPY_DN(CINVLOTHIS->VENDOR_MAT_ID, CINVLOTHIS_N->VENDOR_MAT_ID, sizeof(CINVLOTHIS->VENDOR_MAT_ID));
    CINVLOTHIS->QTY_1 = CINVLOTHIS_N->QTY_1;
    CINVLOTHIS->QTY_2 = CINVLOTHIS_N->QTY_2;
    CINVLOTHIS->QTY_3 = CINVLOTHIS_N->QTY_3;
    MEMCPY_DN(CINVLOTHIS->UNIT_1, CINVLOTHIS_N->UNIT_1, sizeof(CINVLOTHIS->UNIT_1));
    MEMCPY_DN(CINVLOTHIS->UNIT_2, CINVLOTHIS_N->UNIT_2, sizeof(CINVLOTHIS->UNIT_2));
    MEMCPY_DN(CINVLOTHIS->UNIT_3, CINVLOTHIS_N->UNIT_3, sizeof(CINVLOTHIS->UNIT_3));
    MEMCPY_DN(CINVLOTHIS->VENDOR_LOTID, CINVLOTHIS_N->VENDOR_LOTID, sizeof(CINVLOTHIS->VENDOR_LOTID));
    CINVLOTHIS->DELETE_FLAG = CINVLOTHIS_N->DELETE_FLAG[0];
    MEMCPY_DN(CINVLOTHIS->LAST_TRAN_TIME, CINVLOTHIS_N->LAST_TRAN_TIME, sizeof(CINVLOTHIS->LAST_TRAN_TIME));
    MEMCPY_DN(CINVLOTHIS->LAST_TRAN_USER_ID, CINVLOTHIS_N->LAST_TRAN_USER_ID, sizeof(CINVLOTHIS->LAST_TRAN_USER_ID));
    MEMCPY_DN(CINVLOTHIS->LAST_TRAN_TYPE, CINVLOTHIS_N->LAST_TRAN_TYPE, sizeof(CINVLOTHIS->LAST_TRAN_TYPE));
    MEMCPY_DN(CINVLOTHIS->PUR_ORDER_NO, CINVLOTHIS_N->PUR_ORDER_NO, sizeof(CINVLOTHIS->PUR_ORDER_NO));
    MEMCPY_DN(CINVLOTHIS->PUR_TYPE, CINVLOTHIS_N->PUR_TYPE, sizeof(CINVLOTHIS->PUR_TYPE));
    MEMCPY_DN(CINVLOTHIS->PACKAGE_TYPE, CINVLOTHIS_N->PACKAGE_TYPE, sizeof(CINVLOTHIS->PACKAGE_TYPE));
    CINVLOTHIS->IQC_FLAG = CINVLOTHIS_N->IQC_FLAG[0];
    MEMCPY_DN(CINVLOTHIS->INPUT_TIME, CINVLOTHIS_N->INPUT_TIME, sizeof(CINVLOTHIS->INPUT_TIME));
    MEMCPY_DN(CINVLOTHIS->PROD_TIME, CINVLOTHIS_N->PROD_TIME, sizeof(CINVLOTHIS->PROD_TIME));
    MEMCPY_DN(CINVLOTHIS->ASSIGN_TIME, CINVLOTHIS_N->ASSIGN_TIME, sizeof(CINVLOTHIS->ASSIGN_TIME));
    MEMCPY_DN(CINVLOTHIS->CMF_1, CINVLOTHIS_N->CMF_1, sizeof(CINVLOTHIS->CMF_1));
