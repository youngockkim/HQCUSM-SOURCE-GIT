                    POSITION_ID,
                    INV_BARCODE_ID,
                    INV_MAT_ID,
                    INV_LOT_ID,
                    INV_LOT_DESC,
                    MAT_ID,
                    FLOW,
                    OPER,
                    MATERIALS_KINDS,
                    ATTACH_QTY,
                    USED_QTY,
                    REMAIN_QTY,
                    UNIT,
                    DEFAULT_USE_QTY,
                    ATTACH_TIME,
                    ATTACH_USER_ID,
                    INPUT_QTY,
                    TOTAL_USED_QTY,
                    ETC_QTY,
                    MAX_USE_QTY,
                    USE_BATCH_ID,
                    USE_TYPE,
                    MAX_USE_TIME,
                    ORDER_ID,
                    LAST_ACTION,
                    DETACH_TIME,
                    DETACH_USER_ID,
                    LAST_HIST_SEQ,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM CRASRESMAT
                WHERE FACTORY = :CRASRESMAT_N.FACTORY
                    AND RES_ID = :CRASRESMAT_N.RES_ID
					AND MAT_ID = :CRASRESMAT_N.MAT_ID
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SEQ ASC;
            EXEC SQL OPEN CDB_CRASRESMAT_CUR_3;
            break;
		
		case 4:
            EXEC SQL DECLARE CDB_CRASRESMAT_CUR_4 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SEQ,
                    POSITION_ID,
                    INV_BARCODE_ID,
                    INV_MAT_ID,
                    INV_LOT_ID,
                    INV_LOT_DESC,
                    MAT_ID,
                    FLOW,
                    OPER,
                    MATERIALS_KINDS,
                    ATTACH_QTY,
                    USED_QTY,
                    REMAIN_QTY,
                    UNIT,
                    DEFAULT_USE_QTY,
                    ATTACH_TIME,
                    ATTACH_USER_ID,
                    INPUT_QTY,
                    TOTAL_USED_QTY,
                    ETC_QTY,
                    MAX_USE_QTY,
                    USE_BATCH_ID,
                    USE_TYPE,
                    MAX_USE_TIME,
                    ORDER_ID,
                    LAST_ACTION,
                    DETACH_TIME,
                    DETACH_USER_ID,
                    LAST_HIST_SEQ,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM CRASRESMAT
                WHERE FACTORY = :CRASRESMAT_N.FACTORY
                    AND RES_ID = :CRASRESMAT_N.RES_ID
					AND INV_BARCODE_ID = :CRASRESMAT_N.INV_BARCODE_ID
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SEQ ASC;
            EXEC SQL OPEN CDB_CRASRESMAT_CUR_4;

            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_crasresmat", sel_type);
}


/* SQL CURSOR FETCH Function */
