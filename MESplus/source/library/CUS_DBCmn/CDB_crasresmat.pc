                :CRASRESMAT_N.CMF_4,
                :CRASRESMAT_N.CMF_5;

            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_crasresmat(&CRASRESMAT_N, CRASRESMAT);
    }

    DB_stop_query_timer("CDB_fetch_crasresmat", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_crasresmat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CRASRESMAT_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE CDB_CRASRESMAT_CUR_2;
            break;

		case 3:
            EXEC SQL CLOSE CDB_CRASRESMAT_CUR_3;
            break;
		
		case 4:
            EXEC SQL CLOSE CDB_CRASRESMAT_CUR_4;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_crasresmat", sel_type);
}


/* Initialize Function */
void CDB_init_crasresmat(struct CRASRESMAT_TAG *CRASRESMAT)
{
    /* memset by Space */
    memset(CRASRESMAT, ' ', sizeof(struct CRASRESMAT_TAG));
    
    CRASRESMAT->SEQ = 0;
    CRASRESMAT->ATTACH_QTY = 0;
    CRASRESMAT->USED_QTY = 0;
    CRASRESMAT->REMAIN_QTY = 0;
    CRASRESMAT->DEFAULT_USE_QTY = 0;
    CRASRESMAT->INPUT_QTY = 0;
    CRASRESMAT->TOTAL_USED_QTY = 0;
    CRASRESMAT->ETC_QTY = 0;
    CRASRESMAT->MAX_USE_QTY = 0;
    CRASRESMAT->LAST_HIST_SEQ = 0;
}


/* Add Null Function */
void CDB_add_null_crasresmat(struct CRASRESMAT_N_TAG *CRASRESMAT_N, struct CRASRESMAT_TAG *CRASRESMAT)
{
    /* memset by NULL */
    memset(CRASRESMAT_N, '\0', sizeof(struct CRASRESMAT_N_TAG));
    
    MEMCPY_AN(CRASRESMAT_N->FACTORY, CRASRESMAT->FACTORY, sizeof(CRASRESMAT->FACTORY));
    MEMCPY_AN(CRASRESMAT_N->RES_ID, CRASRESMAT->RES_ID, sizeof(CRASRESMAT->RES_ID));
    CRASRESMAT_N->SEQ = CRASRESMAT->SEQ;
    MEMCPY_AN(CRASRESMAT_N->POSITION_ID, CRASRESMAT->POSITION_ID, sizeof(CRASRESMAT->POSITION_ID));
    MEMCPY_AN(CRASRESMAT_N->INV_BARCODE_ID, CRASRESMAT->INV_BARCODE_ID, sizeof(CRASRESMAT->INV_BARCODE_ID));
    MEMCPY_AN(CRASRESMAT_N->INV_MAT_ID, CRASRESMAT->INV_MAT_ID, sizeof(CRASRESMAT->INV_MAT_ID));
    MEMCPY_AN(CRASRESMAT_N->INV_LOT_ID, CRASRESMAT->INV_LOT_ID, sizeof(CRASRESMAT->INV_LOT_ID));
    MEMCPY_AN(CRASRESMAT_N->INV_LOT_DESC, CRASRESMAT->INV_LOT_DESC, sizeof(CRASRESMAT->INV_LOT_DESC));
    MEMCPY_AN(CRASRESMAT_N->MAT_ID, CRASRESMAT->MAT_ID, sizeof(CRASRESMAT->MAT_ID));
    MEMCPY_AN(CRASRESMAT_N->FLOW, CRASRESMAT->FLOW, sizeof(CRASRESMAT->FLOW));
    MEMCPY_AN(CRASRESMAT_N->OPER, CRASRESMAT->OPER, sizeof(CRASRESMAT->OPER));
    MEMCPY_AN(CRASRESMAT_N->MATERIALS_KINDS, CRASRESMAT->MATERIALS_KINDS, sizeof(CRASRESMAT->MATERIALS_KINDS));
    CRASRESMAT_N->ATTACH_QTY = CRASRESMAT->ATTACH_QTY;
    CRASRESMAT_N->USED_QTY = CRASRESMAT->USED_QTY;
    CRASRESMAT_N->REMAIN_QTY = CRASRESMAT->REMAIN_QTY;
    MEMCPY_AN(CRASRESMAT_N->UNIT, CRASRESMAT->UNIT, sizeof(CRASRESMAT->UNIT));
    CRASRESMAT_N->DEFAULT_USE_QTY = CRASRESMAT->DEFAULT_USE_QTY;
    MEMCPY_AN(CRASRESMAT_N->ATTACH_TIME, CRASRESMAT->ATTACH_TIME, sizeof(CRASRESMAT->ATTACH_TIME));
    MEMCPY_AN(CRASRESMAT_N->ATTACH_USER_ID, CRASRESMAT->ATTACH_USER_ID, sizeof(CRASRESMAT->ATTACH_USER_ID));
    CRASRESMAT_N->INPUT_QTY = CRASRESMAT->INPUT_QTY;
    CRASRESMAT_N->TOTAL_USED_QTY = CRASRESMAT->TOTAL_USED_QTY;
    CRASRESMAT_N->ETC_QTY = CRASRESMAT->ETC_QTY;
    CRASRESMAT_N->MAX_USE_QTY = CRASRESMAT->MAX_USE_QTY;
    MEMCPY_AN(CRASRESMAT_N->USE_BATCH_ID, CRASRESMAT->USE_BATCH_ID, sizeof(CRASRESMAT->USE_BATCH_ID));
    MEMCPY_AN(CRASRESMAT_N->USE_TYPE, CRASRESMAT->USE_TYPE, sizeof(CRASRESMAT->USE_TYPE));
    MEMCPY_AN(CRASRESMAT_N->MAX_USE_TIME, CRASRESMAT->MAX_USE_TIME, sizeof(CRASRESMAT->MAX_USE_TIME));
    MEMCPY_AN(CRASRESMAT_N->ORDER_ID, CRASRESMAT->ORDER_ID, sizeof(CRASRESMAT->ORDER_ID));
    MEMCPY_AN(CRASRESMAT_N->LAST_ACTION, CRASRESMAT->LAST_ACTION, sizeof(CRASRESMAT->LAST_ACTION));
    MEMCPY_AN(CRASRESMAT_N->DETACH_TIME, CRASRESMAT->DETACH_TIME, sizeof(CRASRESMAT->DETACH_TIME));
    MEMCPY_AN(CRASRESMAT_N->DETACH_USER_ID, CRASRESMAT->DETACH_USER_ID, sizeof(CRASRESMAT->DETACH_USER_ID));
    CRASRESMAT_N->LAST_HIST_SEQ = CRASRESMAT->LAST_HIST_SEQ;
    MEMCPY_AN(CRASRESMAT_N->CMF_1, CRASRESMAT->CMF_1, sizeof(CRASRESMAT->CMF_1));
    MEMCPY_AN(CRASRESMAT_N->CMF_2, CRASRESMAT->CMF_2, sizeof(CRASRESMAT->CMF_2));
    MEMCPY_AN(CRASRESMAT_N->CMF_3, CRASRESMAT->CMF_3, sizeof(CRASRESMAT->CMF_3));
    MEMCPY_AN(CRASRESMAT_N->CMF_4, CRASRESMAT->CMF_4, sizeof(CRASRESMAT->CMF_4));
    MEMCPY_AN(CRASRESMAT_N->CMF_5, CRASRESMAT->CMF_5, sizeof(CRASRESMAT->CMF_5));
}


/* Del Null Function */
void CDB_del_null_crasresmat(struct CRASRESMAT_N_TAG *CRASRESMAT_N, struct CRASRESMAT_TAG *CRASRESMAT)
{
    MEMCPY_DN(CRASRESMAT->FACTORY, CRASRESMAT_N->FACTORY, sizeof(CRASRESMAT->FACTORY));
    MEMCPY_DN(CRASRESMAT->RES_ID, CRASRESMAT_N->RES_ID, sizeof(CRASRESMAT->RES_ID));
    CRASRESMAT->SEQ = CRASRESMAT_N->SEQ;
    MEMCPY_DN(CRASRESMAT->POSITION_ID, CRASRESMAT_N->POSITION_ID, sizeof(CRASRESMAT->POSITION_ID));
    MEMCPY_DN(CRASRESMAT->INV_BARCODE_ID, CRASRESMAT_N->INV_BARCODE_ID, sizeof(CRASRESMAT->INV_BARCODE_ID));
    MEMCPY_DN(CRASRESMAT->INV_MAT_ID, CRASRESMAT_N->INV_MAT_ID, sizeof(CRASRESMAT->INV_MAT_ID));
    MEMCPY_DN(CRASRESMAT->INV_LOT_ID, CRASRESMAT_N->INV_LOT_ID, sizeof(CRASRESMAT->INV_LOT_ID));
    MEMCPY_DN(CRASRESMAT->INV_LOT_DESC, CRASRESMAT_N->INV_LOT_DESC, sizeof(CRASRESMAT->INV_LOT_DESC));
    MEMCPY_DN(CRASRESMAT->MAT_ID, CRASRESMAT_N->MAT_ID, sizeof(CRASRESMAT->MAT_ID));
    MEMCPY_DN(CRASRESMAT->FLOW, CRASRESMAT_N->FLOW, sizeof(CRASRESMAT->FLOW));
    MEMCPY_DN(CRASRESMAT->OPER, CRASRESMAT_N->OPER, sizeof(CRASRESMAT->OPER));
    MEMCPY_DN(CRASRESMAT->MATERIALS_KINDS, CRASRESMAT_N->MATERIALS_KINDS, sizeof(CRASRESMAT->MATERIALS_KINDS));
    CRASRESMAT->ATTACH_QTY = CRASRESMAT_N->ATTACH_QTY;
    CRASRESMAT->USED_QTY = CRASRESMAT_N->USED_QTY;
    CRASRESMAT->REMAIN_QTY = CRASRESMAT_N->REMAIN_QTY;
    MEMCPY_DN(CRASRESMAT->UNIT, CRASRESMAT_N->UNIT, sizeof(CRASRESMAT->UNIT));
    CRASRESMAT->DEFAULT_USE_QTY = CRASRESMAT_N->DEFAULT_USE_QTY;
    MEMCPY_DN(CRASRESMAT->ATTACH_TIME, CRASRESMAT_N->ATTACH_TIME, sizeof(CRASRESMAT->ATTACH_TIME));
    MEMCPY_DN(CRASRESMAT->ATTACH_USER_ID, CRASRESMAT_N->ATTACH_USER_ID, sizeof(CRASRESMAT->ATTACH_USER_ID));
    CRASRESMAT->INPUT_QTY = CRASRESMAT_N->INPUT_QTY;
    CRASRESMAT->TOTAL_USED_QTY = CRASRESMAT_N->TOTAL_USED_QTY;
    CRASRESMAT->ETC_QTY = CRASRESMAT_N->ETC_QTY;
    CRASRESMAT->MAX_USE_QTY = CRASRESMAT_N->MAX_USE_QTY;
    MEMCPY_DN(CRASRESMAT->USE_BATCH_ID, CRASRESMAT_N->USE_BATCH_ID, sizeof(CRASRESMAT->USE_BATCH_ID));
    MEMCPY_DN(CRASRESMAT->USE_TYPE, CRASRESMAT_N->USE_TYPE, sizeof(CRASRESMAT->USE_TYPE));
    MEMCPY_DN(CRASRESMAT->MAX_USE_TIME, CRASRESMAT_N->MAX_USE_TIME, sizeof(CRASRESMAT->MAX_USE_TIME));
    MEMCPY_DN(CRASRESMAT->ORDER_ID, CRASRESMAT_N->ORDER_ID, sizeof(CRASRESMAT->ORDER_ID));
    MEMCPY_DN(CRASRESMAT->LAST_ACTION, CRASRESMAT_N->LAST_ACTION, sizeof(CRASRESMAT->LAST_ACTION));
    MEMCPY_DN(CRASRESMAT->DETACH_TIME, CRASRESMAT_N->DETACH_TIME, sizeof(CRASRESMAT->DETACH_TIME));
    MEMCPY_DN(CRASRESMAT->DETACH_USER_ID, CRASRESMAT_N->DETACH_USER_ID, sizeof(CRASRESMAT->DETACH_USER_ID));
    CRASRESMAT->LAST_HIST_SEQ = CRASRESMAT_N->LAST_HIST_SEQ;
    MEMCPY_DN(CRASRESMAT->CMF_1, CRASRESMAT_N->CMF_1, sizeof(CRASRESMAT->CMF_1));
    MEMCPY_DN(CRASRESMAT->CMF_2, CRASRESMAT_N->CMF_2, sizeof(CRASRESMAT->CMF_2));
    MEMCPY_DN(CRASRESMAT->CMF_3, CRASRESMAT_N->CMF_3, sizeof(CRASRESMAT->CMF_3));
    MEMCPY_DN(CRASRESMAT->CMF_4, CRASRESMAT_N->CMF_4, sizeof(CRASRESMAT->CMF_4));
    MEMCPY_DN(CRASRESMAT->CMF_5, CRASRESMAT_N->CMF_5, sizeof(CRASRESMAT->CMF_5));
}


