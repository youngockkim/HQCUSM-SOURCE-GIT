                :CRASRESMAT_N.CMF_4,
                :CRASRESMAT_N.CMF_5;
            break;

        case 2:
            EXEC SQL FETCH CDB_CRASRESMAT_CUR_2 INTO
                :CRASRESMAT_N.FACTORY,
