                :CRASRESMAT_N.CMF_5;
            break;

		case 3:
            EXEC SQL FETCH CDB_CRASRESMAT_CUR_3 INTO
                :CRASRESMAT_N.FACTORY,
                :CRASRESMAT_N.RES_ID,
                :CRASRESMAT_N.SEQ,
                :CRASRESMAT_N.POSITION_ID,
                :CRASRESMAT_N.INV_BARCODE_ID,
