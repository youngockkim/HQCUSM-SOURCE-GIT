/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwiptrpsts(int sel_type, struct CWIPTRPSTS_TAG *CWIPTRPSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPTRPSTS_N_TAG CWIPTRPSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwiptrpsts(&CWIPTRPSTS_N, CWIPTRPSTS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPTRPSTS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LINE,
                    RES_ID,
                    GRANDING_PORT_NO,
                    PAK_SEQ,
                    LOT_ID,
                    GRADE,
                    POWER,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_USER_ID,
                    CREATE_TIME
                FROM CWIPTRPSTS
                ORDER BY FACTORY ASC,
                    LINE ASC,
                    RES_ID ASC,
                    GRANDING_PORT_NO ASC,
                    PAK_SEQ ASC;
            EXEC SQL OPEN CDB_CWIPTRPSTS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwiptrpsts", sel_type);
}


