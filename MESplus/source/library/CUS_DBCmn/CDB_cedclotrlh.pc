/* SQL SELECT_SCALAR Function */
double CDB_select_cedclotrlh_scalar(int sel_type, struct CEDCLOTRLH_TAG *CEDCLOTRLH)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CEDCLOTRLH_N_TAG CEDCLOTRLH_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedclotrlh(&CEDCLOTRLH_N, CEDCLOTRLH);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CEDCLOTRLH
                WHERE FACTORY = :CEDCLOTRLH_N.FACTORY
                    AND INS_TYPE = :CEDCLOTRLH_N.INS_TYPE
                    AND LOT_ID = :CEDCLOTRLH_N.LOT_ID
                    AND INS_CNT = :CEDCLOTRLH_N.INS_CNT
                    AND HIST_SEQ = :CEDCLOTRLH_N.HIST_SEQ;

            break;

		case 2:
			EXEC SQL SELECT count(*) 
				INTO :d_value
				FROM CEDCLOTRLH A, CWIPLOTTRC B
				WHERE A.LOT_ID = B.LOT_ID
				AND  A.INS_TYPE =  :CEDCLOTRLH_N.INS_TYPE
				AND INS_CNT = :CEDCLOTRLH_N.INS_CNT
				AND A.FACTORY = :CEDCLOTRLH_N.FACTORY
				AND A.CMF_1 >= :CEDCLOTRLH_N.CMF_1
				AND A.CMF_1 <  :CEDCLOTRLH_N.INS_TIME
				AND A.ORDER_ID = :CEDCLOTRLH_N.ORDER_ID
				AND A.GRADE = :CEDCLOTRLH_N.GRADE
				AND A.POWER =  :CEDCLOTRLH_N.POWER
				AND B.CMF1 = :CEDCLOTRLH_N.CMF_2
				AND B.TAB_RES_ID =  :CEDCLOTRLH_N.CMF_3;
			break;

		case 3:
            EXEC SQL SELECT NVL(MAX(INS_CNT), 0)
                INTO :d_value
                FROM CEDCLOTRLH
                WHERE FACTORY = :CEDCLOTRLH_N.FACTORY
                    AND INS_TYPE = :CEDCLOTRLH_N.INS_TYPE
                    AND LOT_ID = :CEDCLOTRLH_N.LOT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_cedclotrlh_scalar", sel_type);

    return d_value;
}


/* SQL DELETE Function */
void CDB_delete_cedclotrlh(int sel_type, struct CEDCLOTRLH_TAG *CEDCLOTRLH)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CEDCLOTRLH_N_TAG CEDCLOTRLH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedclotrlh(&CEDCLOTRLH_N, CEDCLOTRLH);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM CEDCLOTRLH
                WHERE FACTORY = :CEDCLOTRLH_N.FACTORY
                    AND INS_TYPE = :CEDCLOTRLH_N.INS_TYPE
                    AND LOT_ID = :CEDCLOTRLH_N.LOT_ID
                    AND INS_CNT = :CEDCLOTRLH_N.INS_CNT
                    AND HIST_SEQ = :CEDCLOTRLH_N.HIST_SEQ;

            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_delete_cedclotrlh", sel_type);
}


/* SQL INSERT Function */
