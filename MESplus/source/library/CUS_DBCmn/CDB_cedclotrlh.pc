        case 5:
            EXEC SQL SELECT CASE WHEN NG_PERCENT >= TO_NUMBER(:CEDCLOTRLH_N.CMF_2) THEN 'Y' ELSE 'N' END RESULT_VALUE, 
			                TO_CHAR(NVL(NG_PERCENT,0)) NG_PERCENT,
							NVL(NG_CNT, 0) NG_CNT,
							NVL(INPUT_CNT, 0) INPUT_CNT,
							TO_CHAR(NVL(W100_Below_CNT, 0)) W100_Below_CNT,
                            TO_CHAR(NVL(W300_Below_CNT, 0)) W300_Below_CNT,
                            TO_CHAR(NVL(W300_Avove_CNT, 0)) W300_Avove_CNT,
							NVL(PACK_LINE, ' ') PACK_LINE
                INTO 
                    :CEDCLOTRLH_N.RESULT_VALUE,
					:CEDCLOTRLH_N.RLT_COMMENT,
					:CEDCLOTRLH_N.QTY,
					:CEDCLOTRLH_N.HIST_SEQ,
					:CEDCLOTRLH_N.CMF_4,
					:CEDCLOTRLH_N.CMF_5,
					:CEDCLOTRLH_N.INC_COMMENT,
					:CEDCLOTRLH_N.LINE_ID
				FROM
				(
					SELECT ROUND(SUM(NG_CNT) / COUNT(*) * 100, 1) NG_PERCENT, 
					       SUM(NG_CNT) NG_CNT, 
						   COUNT(*) INPUT_CNT,
						   SUM(W100_Below_CNT) W100_Below_CNT, 
                           SUM(W300_Below_CNT) W300_Below_CNT, 
                           SUM(W300_Avove_CNT) W300_Avove_CNT, 
						   MAX(PACK_LINE) PACK_LINE
					FROM
					(
						SELECT  CASE WHEN PMPP <= TO_NUMBER(:CEDCLOTRLH_N.CMF_3) THEN 1 ELSE  0 END NG_CNT,
							    CASE WHEN PMPP <= TO_NUMBER(99.999999) THEN 1 ELSE 0 END W100_Below_CNT, 
								CASE WHEN PMPP >= TO_NUMBER(100) AND PMPP <= TO_NUMBER(299.999999) THEN 1 ELSE 0 END W300_Below_CNT,
								CASE WHEN PMPP >= TO_NUMBER(300) AND PMPP <= TO_NUMBER(:CEDCLOTRLH_N.CMF_3) THEN 1 ELSE 0 END W300_Avove_CNT,
						        DATA_6 AS PACK_LINE
						FROM CEDCLOTRLH A, MGCMTBLDAT B
						WHERE 1=1
						AND A.FACTORY = :CEDCLOTRLH_N.FACTORY
						AND A.INS_TYPE =:CEDCLOTRLH_N.INS_TYPE
						AND A.LINE_ID = :CEDCLOTRLH_N.LINE_ID
						AND A.FACTORY = B.FACTORY(+)
						AND B.TABLE_NAME(+) = '@LINE_CODE'
						AND A.LINE_ID = B.KEY_1(+)
						AND INS_TIME BETWEEN TO_CHAR(SYSDATE - TO_NUMBER(:CEDCLOTRLH_N.CMF_1)/60/24, 'YYYYMMDDHH24MISS')  AND TO_CHAR(SYSDATE, 'YYYYMMDDHH24MISS')
					)
				);
            break;

		case 6:
            EXEC SQL SELECT NVL(MAX(ins_cnt), 0)
                INTO 
					:CEDCLOTRLH_N.INS_CNT
				FROM CEDCLOTRLH
				WHERE LOT_ID = :CEDCLOTRLH_N.LOT_ID;
				
            break;

		case 7:
            EXEC SQL SELECT 
                    FACTORY,
                    INS_TYPE,
                    LOT_ID,
                    MAT_ID,
                    FLOW,
                    OPER,
                    LINE_ID,
                    RES_ID,
                    INS_CNT,
                    INS_TIME,
                    RESULT_TIME,
                    RESULT_VALUE,
					ORDER_ID,
                    HIST_SEQ,
					TO_CHAR(TO_DATE(INS_TIME,'YYYYMMDDHH24MISS')-6/24,'YYYYMMDD')
                INTO 
                    :CEDCLOTRLH_N.FACTORY,
                    :CEDCLOTRLH_N.INS_TYPE,
                    :CEDCLOTRLH_N.LOT_ID,
                    :CEDCLOTRLH_N.MAT_ID,
                    :CEDCLOTRLH_N.FLOW,
                    :CEDCLOTRLH_N.OPER,
                    :CEDCLOTRLH_N.LINE_ID,
                    :CEDCLOTRLH_N.RES_ID,
                    :CEDCLOTRLH_N.INS_CNT,
                    :CEDCLOTRLH_N.INS_TIME,
                    :CEDCLOTRLH_N.RESULT_TIME,
                    :CEDCLOTRLH_N.RESULT_VALUE,
					:CEDCLOTRLH_N.ORDER_ID,
                    :CEDCLOTRLH_N.HIST_SEQ,
                    :CEDCLOTRLH_N.CMF_1
                FROM CEDCLOTRLH
				WHERE FACTORY = :CEDCLOTRLH_N.FACTORY
                    AND INS_TYPE = :CEDCLOTRLH_N.INS_TYPE
                    AND LOT_ID = :CEDCLOTRLH_N.LOT_ID
					AND INS_CNT = :CEDCLOTRLH_N.INS_CNT
					AND HIST_SEQ = :CEDCLOTRLH_N.HIST_SEQ
					AND RESULT_VALUE = :CEDCLOTRLH_N.RESULT_VALUE;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cedclotrlh(&CEDCLOTRLH_N, CEDCLOTRLH);
    }

    DB_stop_query_timer("CDB_select_cedclotrlh", sel_type);
}


