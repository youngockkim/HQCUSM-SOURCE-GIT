                    :CEDCLOTRLH_N.INS_CNT,
                    :CEDCLOTRLH_N.INS_VALUE,
                    :CEDCLOTRLH_N.INS_USER_ID,
                    :CEDCLOTRLH_N.INS_TIME,
                    :CEDCLOTRLH_N.RESULT_USER_ID,
                    :CEDCLOTRLH_N.RESULT_TIME,
