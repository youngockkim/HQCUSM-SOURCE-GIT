/* SQL CURSOR CLOSE Function */
void CDB_close_cedclotrlh(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CEDCLOTRLH_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CEDCLOTRLH_CUR_2;
            break;

	    case 3:
            EXEC SQL CLOSE CDB_CEDCLOTRLH_CUR_3;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cedclotrlh", sel_type);
}


/* Initialize Function */
void CDB_init_cedclotrlh(struct CEDCLOTRLH_TAG *CEDCLOTRLH)
{
    /* memset by Space */
    memset(CEDCLOTRLH, ' ', sizeof(struct CEDCLOTRLH_TAG));
    
    CEDCLOTRLH->QTY = 0;
    CEDCLOTRLH->INS_CNT = 0;
    CEDCLOTRLH->HIST_SEQ = 0;
}


/* Add Null Function */
void CDB_add_null_cedclotrlh(struct CEDCLOTRLH_N_TAG *CEDCLOTRLH_N, struct CEDCLOTRLH_TAG *CEDCLOTRLH)
{
    /* memset by NULL */
    memset(CEDCLOTRLH_N, '\0', sizeof(struct CEDCLOTRLH_N_TAG));
    
    MEMCPY_AN(CEDCLOTRLH_N->FACTORY, CEDCLOTRLH->FACTORY, sizeof(CEDCLOTRLH->FACTORY));
    MEMCPY_AN(CEDCLOTRLH_N->INS_TYPE, CEDCLOTRLH->INS_TYPE, sizeof(CEDCLOTRLH->INS_TYPE));
    MEMCPY_AN(CEDCLOTRLH_N->LOT_ID, CEDCLOTRLH->LOT_ID, sizeof(CEDCLOTRLH->LOT_ID));
    MEMCPY_AN(CEDCLOTRLH_N->INS_OPER, CEDCLOTRLH->INS_OPER, sizeof(CEDCLOTRLH->INS_OPER));
    MEMCPY_AN(CEDCLOTRLH_N->MAT_ID, CEDCLOTRLH->MAT_ID, sizeof(CEDCLOTRLH->MAT_ID));
    MEMCPY_AN(CEDCLOTRLH_N->FLOW, CEDCLOTRLH->FLOW, sizeof(CEDCLOTRLH->FLOW));
    MEMCPY_AN(CEDCLOTRLH_N->OPER, CEDCLOTRLH->OPER, sizeof(CEDCLOTRLH->OPER));
    CEDCLOTRLH_N->LOT_TYPE[0] = CEDCLOTRLH->LOT_TYPE;
