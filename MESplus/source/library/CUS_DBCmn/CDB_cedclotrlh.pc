/* SQL UPDATE Function */
void CDB_update_cedclotrlh(int sel_type, struct CEDCLOTRLH_TAG *CEDCLOTRLH)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CEDCLOTRLH_N_TAG CEDCLOTRLH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedclotrlh(&CEDCLOTRLH_N, CEDCLOTRLH);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE CEDCLOTRLH SET
                    INS_OPER = :CEDCLOTRLH_N.INS_OPER,
                    MAT_ID = :CEDCLOTRLH_N.MAT_ID,
                    FLOW = :CEDCLOTRLH_N.FLOW,
                    OPER = :CEDCLOTRLH_N.OPER,
                    LOT_TYPE = :CEDCLOTRLH_N.LOT_TYPE,
                    LINE_ID = :CEDCLOTRLH_N.LINE_ID,
                    RES_ID = :CEDCLOTRLH_N.RES_ID,
                    QTY = :CEDCLOTRLH_N.QTY,
                    INS_CNT = :CEDCLOTRLH_N.INS_CNT,
                    INS_VALUE = :CEDCLOTRLH_N.INS_VALUE,
                    INS_USER_ID = :CEDCLOTRLH_N.INS_USER_ID,
                    INS_TIME = :CEDCLOTRLH_N.INS_TIME,
                    RESULT_USER_ID = :CEDCLOTRLH_N.RESULT_USER_ID,
                    RESULT_TIME = :CEDCLOTRLH_N.RESULT_TIME,
                    RESULT_VALUE = :CEDCLOTRLH_N.RESULT_VALUE,
                    INC_COMMENT = :CEDCLOTRLH_N.INC_COMMENT,
                    RLT_COMMENT = :CEDCLOTRLH_N.RLT_COMMENT,
                    TYPE_FLAG = :CEDCLOTRLH_N.TYPE_FLAG,
                    ORDER_ID = :CEDCLOTRLH_N.ORDER_ID,
                    GRADE = :CEDCLOTRLH_N.GRADE,
                    POWER = :CEDCLOTRLH_N.POWER,
                    LOC_ID = :CEDCLOTRLH_N.LOC_ID,
                    EFF = :CEDCLOTRLH_N.EFF,
                    RSH = :CEDCLOTRLH_N.RSH,
                    RS = :CEDCLOTRLH_N.RS,
                    FF = :CEDCLOTRLH_N.FF,
                    ISC = :CEDCLOTRLH_N.ISC,
                    VOC = :CEDCLOTRLH_N.VOC,
                    IMPP = :CEDCLOTRLH_N.IMPP,
                    VMPP = :CEDCLOTRLH_N.VMPP,
                    PMPP = :CEDCLOTRLH_N.PMPP,
                    TEMP = :CEDCLOTRLH_N.TEMP,
                    TREF = :CEDCLOTRLH_N.TREF,
                    SURFTEMP = :CEDCLOTRLH_N.SURFTEMP,
                    SUN = :CEDCLOTRLH_N.SUN,
                    OSC = :CEDCLOTRLH_N.OSC,
                    ESC = :CEDCLOTRLH_N.ESC,
                    EL = :CEDCLOTRLH_N.EL,
                    FLASHER_CODE = :CEDCLOTRLH_N.FLASHER_CODE,
                    CURING_TIME = :CEDCLOTRLH_N.CURING_TIME,
                    ARTICLE_NO = :CEDCLOTRLH_N.ARTICLE_NO,
                    ARTICLE_EXT_NO = :CEDCLOTRLH_N.ARTICLE_EXT_NO,
                    COLOR_CLASS = :CEDCLOTRLH_N.COLOR_CLASS,
                    PALLET_ID = :CEDCLOTRLH_N.PALLET_ID,
                    PAK_BAR_INFO = :CEDCLOTRLH_N.PAK_BAR_INFO,
                    PAK_GROUP = :CEDCLOTRLH_N.PAK_GROUP,
                    PAK_MOD_TYPE = :CEDCLOTRLH_N.PAK_MOD_TYPE,
              --      CMF_1 = :CEDCLOTRLH_N.CMF_1,
                    CMF_2 = :CEDCLOTRLH_N.CMF_2,
                    CMF_3 = :CEDCLOTRLH_N.CMF_3,
                    CMF_4 = :CEDCLOTRLH_N.CMF_4,
                    CMF_5 = :CEDCLOTRLH_N.CMF_5,
                    WORK_SHIFT = :CEDCLOTRLH_N.WORK_SHIFT,
                    WORK_MONTH = :CEDCLOTRLH_N.WORK_MONTH,
                    WORK_WEEK = :CEDCLOTRLH_N.WORK_WEEK,
                    WORK_DAYS = :CEDCLOTRLH_N.WORK_DAYS,
                    WORK_DAY_OF_WEEK = :CEDCLOTRLH_N.WORK_DAY_OF_WEEK
                WHERE FACTORY = :CEDCLOTRLH_N.FACTORY
                    AND INS_TYPE = :CEDCLOTRLH_N.INS_TYPE
                    AND LOT_ID = :CEDCLOTRLH_N.LOT_ID
                    AND INS_CNT = :CEDCLOTRLH_N.INS_CNT
                    AND HIST_SEQ = :CEDCLOTRLH_N.HIST_SEQ;

            break;

		case 2:
            EXEC SQL UPDATE CEDCLOTRLH SET
                    CMF_2 = :CEDCLOTRLH_N.CMF_2
                WHERE FACTORY = :CEDCLOTRLH_N.FACTORY
                    AND INS_TYPE = :CEDCLOTRLH_N.INS_TYPE
                    AND LOT_ID = :CEDCLOTRLH_N.LOT_ID
					AND INS_CNT = :CEDCLOTRLH_N.INS_CNT;
            break;

		case 901:
            EXEC SQL INSERT INTO CEDCLOTRLH 
				SELECT
				  FACTORY, 
                    INS_TYPE, 
                    :CEDCLOTRLH_N.CMF_1, 
                    INS_OPER, 
                    MAT_ID, 
                    FLOW, 
                    OPER, 
                    LOT_TYPE, 
                    LINE_ID, 
                    RES_ID, 
                    QTY, 
                    INS_CNT, 
                    INS_VALUE, 
                    INS_USER_ID, 
                    DECODE(INS_TYPE, 'FC', :CEDCLOTRLH_N.INS_TIME, INS_TIME), 
                    RESULT_USER_ID, 
                    DECODE(INS_TYPE, 'FC', :CEDCLOTRLH_N.RESULT_TIME, RESULT_TIME),  
                    RESULT_VALUE, 
                    INC_COMMENT, 
                    RLT_COMMENT, 
                    TYPE_FLAG, 
                    ORDER_ID, 
                    GRADE, 
                    POWER, 
                    LOC_ID, 
                    EFF, 
                    RSH, 
                    RS, 
                    FF, 
                    ISC, 
                    VOC, 
                    IMPP, 
                    VMPP, 
                    PMPP, 
                    TEMP, 
                    TREF, 
                    SURFTEMP, 
                    SUN, 
                    OSC, 
                    ESC, 
                    EL, 
                    FLASHER_CODE, 
                    CURING_TIME, 
                    ARTICLE_NO, 
                    ARTICLE_EXT_NO, 
                    COLOR_CLASS, 
                    PALLET_ID, 
                    PAK_BAR_INFO, 
                    PAK_GROUP, 
                    PAK_MOD_TYPE, 
                    HIST_SEQ, 
                    DECODE(INS_TYPE, 'FC', :CEDCLOTRLH_N.INS_TIME, INS_TIME),  
                    CMF_2, 
                    CMF_3, 
                    CMF_4, 
                    CMF_5, 
                    WORK_SHIFT, 
                    WORK_MONTH, 
                    WORK_WEEK, 
                    WORK_DAYS, 
                    WORK_DAY_OF_WEEK
				FROM CEDCLOTRLH
                WHERE FACTORY = :CEDCLOTRLH_N.FACTORY
                    AND LOT_ID = :CEDCLOTRLH_N.LOT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_cedclotrlh", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cedclotrlh(int sel_type, struct CEDCLOTRLH_TAG *CEDCLOTRLH)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CEDCLOTRLH_N_TAG CEDCLOTRLH_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedclotrlh(&CEDCLOTRLH_N, CEDCLOTRLH);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CEDCLOTRLH_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    INS_TYPE,
                    LOT_ID,
                    INS_OPER,
                    MAT_ID,
                    FLOW,
                    OPER,
                    LOT_TYPE,
                    LINE_ID,
                    RES_ID,
                    QTY,
                    INS_CNT,
                    INS_VALUE,
                    INS_USER_ID,
                    INS_TIME,
                    RESULT_USER_ID,
                    RESULT_TIME,
                    RESULT_VALUE,
                    INC_COMMENT,
                    RLT_COMMENT,
                    TYPE_FLAG,
                    ORDER_ID,
                    GRADE,
                    POWER,
                    LOC_ID,
                    EFF,
                    RSH,
                    RS,
                    FF,
                    ISC,
                    VOC,
                    IMPP,
                    VMPP,
                    PMPP,
                    TEMP,
                    TREF,
                    SURFTEMP,
                    SUN,
                    OSC,
                    ESC,
                    EL,
                    FLASHER_CODE,
                    CURING_TIME,
                    ARTICLE_NO,
                    ARTICLE_EXT_NO,
                    COLOR_CLASS,
                    PALLET_ID,
                    PAK_BAR_INFO,
                    PAK_GROUP,
                    PAK_MOD_TYPE,
                    HIST_SEQ,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    WORK_SHIFT,
                    WORK_MONTH,
                    WORK_WEEK,
                    WORK_DAYS,
                    WORK_DAY_OF_WEEK
                FROM CEDCLOTRLH
                ORDER BY FACTORY ASC,
                    INS_TYPE ASC,
                    LOT_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN CDB_CEDCLOTRLH_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CEDCLOTRLH_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    INS_TYPE,
                    LOT_ID,
                    INS_OPER,
                    MAT_ID,
                    FLOW,
                    OPER,
                    LOT_TYPE,
                    LINE_ID,
                    RES_ID,
                    QTY,
                    INS_CNT,
                    INS_VALUE,
                    INS_USER_ID,
                    INS_TIME,
                    RESULT_USER_ID,
                    RESULT_TIME,
                    RESULT_VALUE,
                    INC_COMMENT,
                    RLT_COMMENT,
                    TYPE_FLAG,
                    ORDER_ID,
                    GRADE,
                    POWER,
                    LOC_ID,
                    EFF,
                    RSH,
                    RS,
                    FF,
                    ISC,
                    VOC,
                    IMPP,
                    VMPP,
                    PMPP,
                    TEMP,
                    TREF,
                    SURFTEMP,
                    SUN,
                    OSC,
                    ESC,
                    EL,
                    FLASHER_CODE,
                    CURING_TIME,
                    ARTICLE_NO,
                    ARTICLE_EXT_NO,
                    COLOR_CLASS,
                    PALLET_ID,
                    PAK_BAR_INFO,
                    PAK_GROUP,
                    PAK_MOD_TYPE,
                    HIST_SEQ,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    WORK_SHIFT,
                    WORK_MONTH,
                    WORK_WEEK,
                    WORK_DAYS,
                    WORK_DAY_OF_WEEK
                FROM CEDCLOTRLH
				WHERE FACTORY = :CEDCLOTRLH_N.FACTORY
                    AND INS_TYPE = :CEDCLOTRLH_N.INS_TYPE
                    AND LOT_ID = :CEDCLOTRLH_N.LOT_ID
                ORDER BY INS_CNT DESC;
            EXEC SQL OPEN CDB_CEDCLOTRLH_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_CEDCLOTRLH_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    INS_TYPE,
                    LOT_ID,
                    INS_OPER,
                    MAT_ID,
                    FLOW,
                    OPER,
                    LOT_TYPE,
                    LINE_ID,
                    RES_ID,
                    QTY,
                    INS_CNT,
                    INS_VALUE,
                    INS_USER_ID,
                    INS_TIME,
                    RESULT_USER_ID,
                    RESULT_TIME,
                    RESULT_VALUE,
                    INC_COMMENT,
                    RLT_COMMENT,
                    TYPE_FLAG,
                    ORDER_ID,
                    GRADE,
                    POWER,
                    LOC_ID,
                    EFF,
                    RSH,
                    RS,
                    FF,
                    ISC,
                    VOC,
                    IMPP,
                    VMPP,
                    PMPP,
                    TEMP,
                    TREF,
                    SURFTEMP,
                    SUN,
                    OSC,
                    ESC,
                    EL,
                    FLASHER_CODE,
                    CURING_TIME,
                    ARTICLE_NO,
                    ARTICLE_EXT_NO,
                    COLOR_CLASS,
                    PALLET_ID,
                    PAK_BAR_INFO,
                    PAK_GROUP,
                    PAK_MOD_TYPE,
                    HIST_SEQ,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    WORK_SHIFT,
                    WORK_MONTH,
                    WORK_WEEK,
                    WORK_DAYS,
                    WORK_DAY_OF_WEEK
                FROM CEDCLOTRLH
				WHERE FACTORY = :CEDCLOTRLH_N.FACTORY
                    AND INS_TYPE = :CEDCLOTRLH_N.INS_TYPE
                    AND LOT_ID = :CEDCLOTRLH_N.LOT_ID
                ORDER BY INS_CNT;
            EXEC SQL OPEN CDB_CEDCLOTRLH_CUR_3;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cedclotrlh", sel_type);
}


