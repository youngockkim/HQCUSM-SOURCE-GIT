    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cedclotrlh(&CEDCLOTRLH_N, CEDCLOTRLH);
    }

    DB_stop_query_timer("CDB_fetch_cedclotrlh", sel_type);
