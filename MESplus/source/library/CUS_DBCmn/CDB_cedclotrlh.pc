                    :CEDCLOTRLH_N.EFF,
                    :CEDCLOTRLH_N.RSH,
                    :CEDCLOTRLH_N.RS,
                    :CEDCLOTRLH_N.FF,
                    :CEDCLOTRLH_N.ISC,
                    :CEDCLOTRLH_N.VOC,
                    :CEDCLOTRLH_N.IMPP,
                    :CEDCLOTRLH_N.VMPP,
                    :CEDCLOTRLH_N.PMPP,
                    :CEDCLOTRLH_N.TEMP,
                    :CEDCLOTRLH_N.TREF,
                    :CEDCLOTRLH_N.SURFTEMP,
                    :CEDCLOTRLH_N.SUN,
                    :CEDCLOTRLH_N.OSC,
                    :CEDCLOTRLH_N.ESC,
                    :CEDCLOTRLH_N.EL,
                    :CEDCLOTRLH_N.FLASHER_CODE,
                    :CEDCLOTRLH_N.CURING_TIME,
                    :CEDCLOTRLH_N.ARTICLE_NO,
                    :CEDCLOTRLH_N.ARTICLE_EXT_NO,
                    :CEDCLOTRLH_N.COLOR_CLASS,
                    :CEDCLOTRLH_N.PALLET_ID,
                    :CEDCLOTRLH_N.PAK_BAR_INFO,
                    :CEDCLOTRLH_N.PAK_GROUP,
                    :CEDCLOTRLH_N.PAK_MOD_TYPE,
                    :CEDCLOTRLH_N.HIST_SEQ,
                    :CEDCLOTRLH_N.CMF_1,
                    :CEDCLOTRLH_N.CMF_2,
                    :CEDCLOTRLH_N.CMF_3,
                    :CEDCLOTRLH_N.CMF_4,
                    :CEDCLOTRLH_N.CMF_5,
                    :CEDCLOTRLH_N.WORK_SHIFT,
                    :CEDCLOTRLH_N.WORK_MONTH,
                    :CEDCLOTRLH_N.WORK_WEEK,
                    :CEDCLOTRLH_N.WORK_DAYS,
                    :CEDCLOTRLH_N.WORK_DAY_OF_WEEK
