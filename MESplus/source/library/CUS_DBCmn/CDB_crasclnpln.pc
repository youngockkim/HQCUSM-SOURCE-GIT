			' ' AS CLEAN7_COM_DT,
			' ' AS CREATE_TIME,
			' ' AS CMF_1,
			' ' AS CMF_2,
			' ' AS CMF_3,
			' ' AS CMF_4,
			' ' AS CMF_5
			FROM 
			(SELECT RES_ID ,res_cmf_1 FROM MRASRESDEF
			WHERE RES_DESC LIKE '%Tabber%'
			and res_cmf_1 = :CRASCLNPLN_N.LINE_ID) A,
			(SELECT distinct 'USGAM1' AS FACTORY ,PLAN_YEAR,PLAN_WEEK
			FROM MWIPCALDEF
			WHERE PLAN_YEAR = :CRASCLNPLN_N.PLAN_YEAR AND PLAN_WEEK = :CRASCLNPLN_N.PLAN_WEEK
			) B
			ORDER BY RES_ID;
            EXEC SQL OPEN CDB_CRASCLNPLN_CUR_3;
            break;

		case 4:
            EXEC SQL DECLARE CDB_CRASCLNPLN_CUR_4 CURSOR FOR
			SELECT B.FACTORY ,
			B.PLAN_YEAR,
			B.PLAN_WEEK , 
			' ' AS WORK_SHIFT ,
			A.res_cmf_1 AS LINE_ID,
			A.RES_ID,
			' ' AS CLEAN1_PLAN_TIME,
			' ' AS CLEAN1_FLAG,
			' ' AS CLEAN1_COM_DT,
			' ' AS CLEAN2_PLAN_TIME,
			' ' AS CLEAN2_FLAG,
			' ' AS CLEAN2_COM_DT,
			' ' AS CLEAN3_PLAN_TIME,
			' ' AS CLEAN3_FLAG,
			' ' AS CLEAN3_COM_DT,
			' ' AS CLEAN4_PLAN_TIME,
			' ' AS CLEAN4_FLAG,
			' ' AS CLEAN4_COM_DT,
			' ' AS CLEAN5_PLAN_TIME,
			' ' AS CLEAN5_FLAG,
			' ' AS CLEAN5_COM_DT,
			' ' AS CLEAN6_PLAN_TIME,
			' ' AS CLEAN6_FLAG,
			' ' AS CLEAN6_COM_DT,
			' ' AS CLEAN7_PLAN_TIME,
			' ' AS CLEAN7_FLAG,
			' ' AS CLEAN7_COM_DT,
			' ' AS CREATE_TIME,
			' ' AS CMF_1,
			' ' AS CMF_2,
			' ' AS CMF_3,
			' ' AS CMF_4,
			' ' AS CMF_5
			FROM 
			(SELECT KEY_4 AS RES_ID, KEY_3 AS res_cmf_1 
			 FROM MGCMTBLDAT 
			 WHERE TABLE_NAME = '@E10_EQP' 
			 AND KEY_1 = 'TABBER'
			 AND KEY_3 = :CRASCLNPLN_N.LINE_ID) A,
			(SELECT distinct 'USGAM1' AS FACTORY ,PLAN_YEAR,PLAN_WEEK
			FROM MWIPCALDEF
			WHERE PLAN_YEAR = :CRASCLNPLN_N.PLAN_YEAR AND PLAN_WEEK = :CRASCLNPLN_N.PLAN_WEEK
			) B
			ORDER BY RES_ID;
            EXEC SQL OPEN CDB_CRASCLNPLN_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_crasclnpln", sel_type);
}


