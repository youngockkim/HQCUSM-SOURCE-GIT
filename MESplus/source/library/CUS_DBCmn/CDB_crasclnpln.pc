/* SQL CURSOR CLOSE Function */
void CDB_close_crasclnpln(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CRASCLNPLN_CUR_1;
            break;


        case 2:
            EXEC SQL CLOSE CDB_CRASCLNPLN_CUR_2;
            break;


        case 3:
            EXEC SQL CLOSE CDB_CRASCLNPLN_CUR_3;
            break;


        case 4:
            EXEC SQL CLOSE CDB_CRASCLNPLN_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_crasclnpln", sel_type);
}


/* Initialize Function */
void CDB_init_crasclnpln(struct CRASCLNPLN_TAG *CRASCLNPLN)
{
    /* memset by Space */
    memset(CRASCLNPLN, ' ', sizeof(struct CRASCLNPLN_TAG));
    
    CRASCLNPLN->PLAN_YEAR = 0;
    CRASCLNPLN->PLAN_WEEK = 0;
}


/* Add Null Function */
void CDB_add_null_crasclnpln(struct CRASCLNPLN_N_TAG *CRASCLNPLN_N, struct CRASCLNPLN_TAG *CRASCLNPLN)
{
    /* memset by NULL */
    memset(CRASCLNPLN_N, '\0', sizeof(struct CRASCLNPLN_N_TAG));
    
    MEMCPY_AN(CRASCLNPLN_N->FACTORY, CRASCLNPLN->FACTORY, sizeof(CRASCLNPLN->FACTORY));
    CRASCLNPLN_N->PLAN_YEAR = CRASCLNPLN->PLAN_YEAR;
    CRASCLNPLN_N->PLAN_WEEK = CRASCLNPLN->PLAN_WEEK;
    MEMCPY_AN(CRASCLNPLN_N->WORK_SHIFT, CRASCLNPLN->WORK_SHIFT, sizeof(CRASCLNPLN->WORK_SHIFT));
    MEMCPY_AN(CRASCLNPLN_N->LINE_ID, CRASCLNPLN->LINE_ID, sizeof(CRASCLNPLN->LINE_ID));
    MEMCPY_AN(CRASCLNPLN_N->RES_ID, CRASCLNPLN->RES_ID, sizeof(CRASCLNPLN->RES_ID));
    MEMCPY_AN(CRASCLNPLN_N->CLEAN1_PLAN_TIME, CRASCLNPLN->CLEAN1_PLAN_TIME, sizeof(CRASCLNPLN->CLEAN1_PLAN_TIME));
    CRASCLNPLN_N->CLEAN1_FLAG[0] = CRASCLNPLN->CLEAN1_FLAG;
    MEMCPY_AN(CRASCLNPLN_N->CLEAN1_COM_DT, CRASCLNPLN->CLEAN1_COM_DT, sizeof(CRASCLNPLN->CLEAN1_COM_DT));
    MEMCPY_AN(CRASCLNPLN_N->CLEAN2_PLAN_TIME, CRASCLNPLN->CLEAN2_PLAN_TIME, sizeof(CRASCLNPLN->CLEAN2_PLAN_TIME));
    CRASCLNPLN_N->CLEAN2_FLAG[0] = CRASCLNPLN->CLEAN2_FLAG;
    MEMCPY_AN(CRASCLNPLN_N->CLEAN2_COM_DT, CRASCLNPLN->CLEAN2_COM_DT, sizeof(CRASCLNPLN->CLEAN2_COM_DT));
    MEMCPY_AN(CRASCLNPLN_N->CLEAN3_PLAN_TIME, CRASCLNPLN->CLEAN3_PLAN_TIME, sizeof(CRASCLNPLN->CLEAN3_PLAN_TIME));
    CRASCLNPLN_N->CLEAN3_FLAG[0] = CRASCLNPLN->CLEAN3_FLAG;
    MEMCPY_AN(CRASCLNPLN_N->CLEAN3_COM_DT, CRASCLNPLN->CLEAN3_COM_DT, sizeof(CRASCLNPLN->CLEAN3_COM_DT));
    MEMCPY_AN(CRASCLNPLN_N->CLEAN4_PLAN_TIME, CRASCLNPLN->CLEAN4_PLAN_TIME, sizeof(CRASCLNPLN->CLEAN4_PLAN_TIME));
    CRASCLNPLN_N->CLEAN4_FLAG[0] = CRASCLNPLN->CLEAN4_FLAG;
    MEMCPY_AN(CRASCLNPLN_N->CLEAN4_COM_DT, CRASCLNPLN->CLEAN4_COM_DT, sizeof(CRASCLNPLN->CLEAN4_COM_DT));
    MEMCPY_AN(CRASCLNPLN_N->CLEAN5_PLAN_TIME, CRASCLNPLN->CLEAN5_PLAN_TIME, sizeof(CRASCLNPLN->CLEAN5_PLAN_TIME));
    CRASCLNPLN_N->CLEAN5_FLAG[0] = CRASCLNPLN->CLEAN5_FLAG;
    MEMCPY_AN(CRASCLNPLN_N->CLEAN5_COM_DT, CRASCLNPLN->CLEAN5_COM_DT, sizeof(CRASCLNPLN->CLEAN5_COM_DT));
    MEMCPY_AN(CRASCLNPLN_N->CLEAN6_PLAN_TIME, CRASCLNPLN->CLEAN6_PLAN_TIME, sizeof(CRASCLNPLN->CLEAN6_PLAN_TIME));
    CRASCLNPLN_N->CLEAN6_FLAG[0] = CRASCLNPLN->CLEAN6_FLAG;
    MEMCPY_AN(CRASCLNPLN_N->CLEAN6_COM_DT, CRASCLNPLN->CLEAN6_COM_DT, sizeof(CRASCLNPLN->CLEAN6_COM_DT));
    MEMCPY_AN(CRASCLNPLN_N->CLEAN7_PLAN_TIME, CRASCLNPLN->CLEAN7_PLAN_TIME, sizeof(CRASCLNPLN->CLEAN7_PLAN_TIME));
    CRASCLNPLN_N->CLEAN7_FLAG[0] = CRASCLNPLN->CLEAN7_FLAG;
    MEMCPY_AN(CRASCLNPLN_N->CLEAN7_COM_DT, CRASCLNPLN->CLEAN7_COM_DT, sizeof(CRASCLNPLN->CLEAN7_COM_DT));
    MEMCPY_AN(CRASCLNPLN_N->CREATE_TIME, CRASCLNPLN->CREATE_TIME, sizeof(CRASCLNPLN->CREATE_TIME));
    MEMCPY_AN(CRASCLNPLN_N->CMF_1, CRASCLNPLN->CMF_1, sizeof(CRASCLNPLN->CMF_1));
    MEMCPY_AN(CRASCLNPLN_N->CMF_2, CRASCLNPLN->CMF_2, sizeof(CRASCLNPLN->CMF_2));
    MEMCPY_AN(CRASCLNPLN_N->CMF_3, CRASCLNPLN->CMF_3, sizeof(CRASCLNPLN->CMF_3));
    MEMCPY_AN(CRASCLNPLN_N->CMF_4, CRASCLNPLN->CMF_4, sizeof(CRASCLNPLN->CMF_4));
    MEMCPY_AN(CRASCLNPLN_N->CMF_5, CRASCLNPLN->CMF_5, sizeof(CRASCLNPLN->CMF_5));
}


