        case 1:
            EXEC SQL DECLARE CDB_IBAKPAKDAT_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    PALLET_ID,
                    MODULE_ID,
                    ACTION_TYPE,
                    MODULE_SEQ,
                    SITE_ID,
                    QTY,
                    PACKING_DATE,
                    PACKING_TIME,
