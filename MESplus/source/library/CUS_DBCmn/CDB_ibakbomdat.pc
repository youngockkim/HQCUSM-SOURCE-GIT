        CDB_del_null_ibakbomdat(&IBAKBOMDAT_N, IBAKBOMDAT);
    }

    DB_stop_query_timer("CDB_fetch_ibakbomdat", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_ibakbomdat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IBAKBOMDAT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ibakbomdat", sel_type);
}


/* Initialize Function */
void CDB_init_ibakbomdat(struct IBAKBOMDAT_TAG *IBAKBOMDAT)
{
    /* memset by Space */
    memset(IBAKBOMDAT, ' ', sizeof(struct IBAKBOMDAT_TAG));
    
    IBAKBOMDAT->STD_QTY = 0;
    IBAKBOMDAT->QTY = 0;
}


