/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_ibakbomdat(int sel_type, struct IBAKBOMDAT_TAG *IBAKBOMDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IBAKBOMDAT_N_TAG IBAKBOMDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ibakbomdat(&IBAKBOMDAT_N, IBAKBOMDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IBAKBOMDAT_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_NO,
                    BOM_USAGE,
                    BOM_KEY,
                    OPT_BOM,
                    OPT_BOM_DESC,
                    EFF_START_DATE,
                    EFF_END_DATE,
                    STD_QTY,
                    STD_UNIT,
                    BOM_TEXT,
                    BOM_PJT,
                    BOM_PJT_CATE,
                    MATE_NO,
                    MATE_DESC,
                    QTY,
                    UNIT_ID,
                    DEL_YN,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IBAKBOMDAT
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_NO ASC,
                    BOM_USAGE ASC,
                    BOM_KEY ASC,
                    OPT_BOM ASC;
            EXEC SQL OPEN CDB_IBAKBOMDAT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_ibakbomdat", sel_type);
}


