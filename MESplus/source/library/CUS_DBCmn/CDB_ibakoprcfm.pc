                    AND ACTION_TYPE = :IBAKOPRCFM_N.ACTION_TYPE;
            break;

		case 2:
			EXEC SQL DELETE FROM IBAKOPRCFM
				WHERE DOC_ID IN (
						SELECT DOC_ID FROM IERPOPRCFM
						WHERE ERP_FLAG = 'S');
			break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_delete_ibakoprcfm", sel_type);
}


