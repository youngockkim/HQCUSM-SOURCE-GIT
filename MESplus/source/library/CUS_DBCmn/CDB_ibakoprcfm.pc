/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_ibakoprcfm(int sel_type, struct IBAKOPRCFM_TAG *IBAKOPRCFM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IBAKOPRCFM_N_TAG IBAKOPRCFM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ibakoprcfm(&IBAKOPRCFM_N, IBAKOPRCFM);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IBAKOPRCFM_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_ORDER_NO,
                    MODULE_ID,
                    OPER_NO,
                    WORK_CENTER,
                    ACTION_TYPE,
                    MATE_NO,
                    PROD_QTY,
                    SCRAP_QTY,
                    UNIT_ID,
                    FQC_DATE,
                    QUALITY_GRADE,
                    POWER_GRADE,
                    SHIFT,
                    LOCATION,
                    EFF,
                    RSH,
                    RS,
                    FF,
                    ISC,
                    VOC,
                    IMPP,
                    VMPP,
                    PMPP,
                    TEMP,
                    ENVTEMP,
                    SURFTEMP,
                    SUN,
                    FQC_GRADE,
                    FQC_POWER,
                    FQC_OPERATOR,
                    OSC,
                    ESC,
                    EL,
                    FLASHER_CODE,
                    MODULE_CREATEDATE,
                    DELIVERY_NOTE,
                    DELIVERY_NOTE2,
                    ARTICLE_NO,
                    ARTICLE_NO2,
                    ARTICLE_CODE,
                    COLOR_CLASS,
                    MIXING_RATIO,
                    DEGRATION,
                    INF_USER_ID,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPICODE,
                    ZPIMSGID,
                    ZPISTAT,
                    ZPIMSG,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ERP_DATE,
                    ERP_TIME,
                    ERP_FLAG,
                    ERP_MSG,
                    IF_FLAG
                FROM IBAKOPRCFM
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_ORDER_NO ASC,
                    MODULE_ID ASC,
                    OPER_NO ASC,
                    WORK_CENTER ASC,
                    ACTION_TYPE ASC;
            EXEC SQL OPEN CDB_IBAKOPRCFM_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_ibakoprcfm", sel_type);
}


