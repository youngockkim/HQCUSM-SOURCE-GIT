                    RSH = :IBAKOPRCFM_N.RSH,
                    RS = :IBAKOPRCFM_N.RS,
                    FF = :IBAKOPRCFM_N.FF,
                    ISC = :IBAKOPRCFM_N.ISC,
                    VOC = :IBAKOPRCFM_N.VOC,
                    IMPP = :IBAKOPRCFM_N.IMPP,
                    VMPP = :IBAKOPRCFM_N.VMPP,
                    PMPP = :IBAKOPRCFM_N.PMPP,
                    TEMP = :IBAKOPRCFM_N.TEMP,
                    ENVTEMP = :IBAKOPRCFM_N.ENVTEMP,
                    SURFTEMP = :IBAKOPRCFM_N.SURFTEMP,
                    SUN = :IBAKOPRCFM_N.SUN,
                    FQC_GRADE = :IBAKOPRCFM_N.FQC_GRADE,
                    FQC_POWER = :IBAKOPRCFM_N.FQC_POWER,
                    FQC_OPERATOR = :IBAKOPRCFM_N.FQC_OPERATOR,
                    OSC = :IBAKOPRCFM_N.OSC,
                    ESC = :IBAKOPRCFM_N.ESC,
                    EL = :IBAKOPRCFM_N.EL,
                    FLASHER_CODE = :IBAKOPRCFM_N.FLASHER_CODE,
                    MODULE_CREATEDATE = :IBAKOPRCFM_N.MODULE_CREATEDATE,
                    DELIVERY_NOTE = :IBAKOPRCFM_N.DELIVERY_NOTE,
                    DELIVERY_NOTE2 = :IBAKOPRCFM_N.DELIVERY_NOTE2,
                    ARTICLE_NO = :IBAKOPRCFM_N.ARTICLE_NO,
                    ARTICLE_NO2 = :IBAKOPRCFM_N.ARTICLE_NO2,
                    ARTICLE_CODE = :IBAKOPRCFM_N.ARTICLE_CODE,
                    COLOR_CLASS = :IBAKOPRCFM_N.COLOR_CLASS,
                    MIXING_RATIO = :IBAKOPRCFM_N.MIXING_RATIO,
                    DEGRATION = :IBAKOPRCFM_N.DEGRATION,
