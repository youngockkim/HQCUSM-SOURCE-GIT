    DB_start_query_timer();

    CDB_add_null_ibakoprcfm(&IBAKOPRCFM_N, IBAKOPRCFM);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM IBAKOPRCFM
                WHERE DOC_ID = :IBAKOPRCFM_N.DOC_ID
                    AND SITE_ID = :IBAKOPRCFM_N.SITE_ID
                    AND PROD_ORDER_NO = :IBAKOPRCFM_N.PROD_ORDER_NO
                    AND MODULE_ID = :IBAKOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IBAKOPRCFM_N.OPER_NO
