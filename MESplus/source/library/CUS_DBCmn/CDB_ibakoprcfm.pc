}


/* Add Null Function */
void CDB_add_null_ibakoprcfm(struct IBAKOPRCFM_N_TAG *IBAKOPRCFM_N, struct IBAKOPRCFM_TAG *IBAKOPRCFM)
{
    /* memset by NULL */
    memset(IBAKOPRCFM_N, '\0', sizeof(struct IBAKOPRCFM_N_TAG));
    
    MEMCPY_AN(IBAKOPRCFM_N->DOC_ID, IBAKOPRCFM->DOC_ID, sizeof(IBAKOPRCFM->DOC_ID));
