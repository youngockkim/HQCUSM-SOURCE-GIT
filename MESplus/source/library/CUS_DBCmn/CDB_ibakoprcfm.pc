/* SQL UPDATE Function */
void CDB_update_ibakoprcfm(int sel_type, struct IBAKOPRCFM_TAG *IBAKOPRCFM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IBAKOPRCFM_N_TAG IBAKOPRCFM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ibakoprcfm(&IBAKOPRCFM_N, IBAKOPRCFM);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE IBAKOPRCFM SET
                    MATE_NO = :IBAKOPRCFM_N.MATE_NO,
                    PROD_QTY = :IBAKOPRCFM_N.PROD_QTY,
                    SCRAP_QTY = :IBAKOPRCFM_N.SCRAP_QTY,
