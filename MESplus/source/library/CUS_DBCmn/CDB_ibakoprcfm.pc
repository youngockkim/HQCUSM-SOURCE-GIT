                    RETURN_MSG = :IBAKOPRCFM_N.RETURN_MSG,
                    ERP_DATE = :IBAKOPRCFM_N.ERP_DATE,
                    ERP_TIME = :IBAKOPRCFM_N.ERP_TIME,
                    ERP_FLAG = :IBAKOPRCFM_N.ERP_FLAG,
                    ERP_MSG = :IBAKOPRCFM_N.ERP_MSG,
                    IF_FLAG = :IBAKOPRCFM_N.IF_FLAG
                WHERE DOC_ID = :IBAKOPRCFM_N.DOC_ID
                    AND SITE_ID = :IBAKOPRCFM_N.SITE_ID
                    AND PROD_ORDER_NO = :IBAKOPRCFM_N.PROD_ORDER_NO
                    AND MODULE_ID = :IBAKOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IBAKOPRCFM_N.OPER_NO
                    AND WORK_CENTER = :IBAKOPRCFM_N.WORK_CENTER
                    AND ACTION_TYPE = :IBAKOPRCFM_N.ACTION_TYPE;
            break;

