                    ZIFERNAM = :IBAKOPRCFM_N.ZIFERNAM,
                    ZIFDATE = :IBAKOPRCFM_N.ZIFDATE,
                    ZIFTIME = :IBAKOPRCFM_N.ZIFTIME,
                    ZPICODE = :IBAKOPRCFM_N.ZPICODE,
                    ZPIMSGID = :IBAKOPRCFM_N.ZPIMSGID,
                    ZPISTAT = :IBAKOPRCFM_N.ZPISTAT,
                    ZPIMSG = :IBAKOPRCFM_N.ZPIMSG,
