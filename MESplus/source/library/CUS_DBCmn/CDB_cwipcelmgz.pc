                :CWIPCELMGZ_N.CMF_4,
                :CWIPCELMGZ_N.CMF_5,
                :CWIPCELMGZ_N.CMF_6,
                :CWIPCELMGZ_N.CMF_7,
                :CWIPCELMGZ_N.CMF_8,
                :CWIPCELMGZ_N.CMF_9,
                :CWIPCELMGZ_N.CMF_10;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cwipcelmgz(&CWIPCELMGZ_N, CWIPCELMGZ);
    }

    DB_stop_query_timer("CDB_fetch_cwipcelmgz", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cwipcelmgz(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CWIPCELMGZ_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwipcelmgz", sel_type);
}


/* Initialize Function */
