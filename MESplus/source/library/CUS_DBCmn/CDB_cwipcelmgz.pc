              AND BOX_SEQ = :CWIPCELMGZ_N.BOX_SEQ;
            break;

        case 3:
            EXEC SQL 
                UPDATE CWIPCELMGZ A
                   SET VMAGAZINE_ID = :CWIPCELMGZ_N.VMAGAZINE_ID
