        case 4:
            EXEC SQL 
                UPDATE /*+ INDEX(A CWIPCELMGZ_IDX_05) */ CWIPCELMGZ A
                   SET CVMAGAZINE_ID = :CWIPCELMGZ_N.CVMAGAZINE_ID
                 WHERE FACTORY = :CWIPCELMGZ_N.FACTORY
                   AND PACK_TYPE = :CWIPCELMGZ_N.PACK_TYPE
                   AND PACK_ID = :CWIPCELMGZ_N.PACK_ID 
                   AND CMF_1 = :CWIPCELMGZ_N.CMF_1   /* STATUS_FLAG*/
				   AND CMF_2 = :CWIPCELMGZ_N.CMF_2;  /* Start Time */
            break;

        case 6:
            EXEC SQL 
                UPDATE /*+ INDEX(A CWIPCELMGZ_IDX_05) */ CWIPCELMGZ A
                SET CMF_1 = 'C',
                       CMF_2 = :CWIPCELMGZ_N.CMF_2, /* INPUT_TIME */
                       CMF_4 = :CWIPCELMGZ_N.CMF_4  /* RES_ID  */
                 WHERE FACTORY = :CWIPCELMGZ_N.FACTORY
