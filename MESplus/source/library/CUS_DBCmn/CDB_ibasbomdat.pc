                :IBASBOMDAT_N.INSERT_COUNT,
                :IBASBOMDAT_N.DELETE_COUNT,
                :IBASBOMDAT_N.SQL_DML_COUNT,
                :IBASBOMDAT_N.ZPICODE,
                :IBASBOMDAT_N.ZPIMSGID,
                :IBASBOMDAT_N.RETURN_TYPE,
                :IBASBOMDAT_N.RETURN_MSG,
