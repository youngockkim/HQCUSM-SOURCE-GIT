                :IBASBOMDAT_N.ZIFDATE,
                :IBASBOMDAT_N.ZIFTIME,
                :IBASBOMDAT_N.ZPISTAT,
                :IBASBOMDAT_N.ZPIMSG;
            break;

		case 2:
            EXEC SQL FETCH CDB_IBASBOMDAT_CUR_2 INTO
                :IBASBOMDAT_N.DOC_ID,
                :IBASBOMDAT_N.SITE_ID,
                :IBASBOMDAT_N.PROD_NO,
                :IBASBOMDAT_N.BOM_USAGE,
                :IBASBOMDAT_N.BOM_KEY,
                :IBASBOMDAT_N.OPT_BOM,
                :IBASBOMDAT_N.OPT_BOM_DESC,
                :IBASBOMDAT_N.EFF_START_DATE,
                :IBASBOMDAT_N.EFF_END_DATE,
                :IBASBOMDAT_N.STD_QTY,
                :IBASBOMDAT_N.STD_UNIT,
                :IBASBOMDAT_N.BOM_TEXT,
                :IBASBOMDAT_N.BOM_PJT,
                :IBASBOMDAT_N.BOM_PJT_CATE,
                :IBASBOMDAT_N.MATE_NO,
                :IBASBOMDAT_N.MATE_DESC,
                :IBASBOMDAT_N.QTY,
                :IBASBOMDAT_N.UNIT_ID,
                :IBASBOMDAT_N.DEL_YN,
                :IBASBOMDAT_N.INF_TIME,
                :IBASBOMDAT_N.INF_PROC_TIME,
                :IBASBOMDAT_N.CMF_1,
                :IBASBOMDAT_N.CMF_2,
                :IBASBOMDAT_N.CMF_3,
                :IBASBOMDAT_N.CMF_4,
                :IBASBOMDAT_N.CMF_5,
                :IBASBOMDAT_N.DATA_FLAG,
                :IBASBOMDAT_N.UPDATE_COUNT,
                :IBASBOMDAT_N.INSERT_COUNT,
                :IBASBOMDAT_N.DELETE_COUNT,
                :IBASBOMDAT_N.SQL_DML_COUNT,
                :IBASBOMDAT_N.ZPICODE,
                :IBASBOMDAT_N.ZPIMSGID,
                :IBASBOMDAT_N.RETURN_TYPE,
                :IBASBOMDAT_N.RETURN_MSG,
                :IBASBOMDAT_N.ZIFERNAM,
                :IBASBOMDAT_N.ZIFDATE,
                :IBASBOMDAT_N.ZIFTIME,
                :IBASBOMDAT_N.ZPISTAT,
                :IBASBOMDAT_N.ZPIMSG;
            break;

		case 3:
            EXEC SQL FETCH CDB_IBASBOMDAT_CUR_3 INTO                
                :IBASBOMDAT_N.PROD_NO,
                :IBASBOMDAT_N.BOM_KEY,
				:IBASBOMDAT_N.ZIFDATE;
            break;

		case 4:
            EXEC SQL FETCH CDB_IBASBOMDAT_CUR_4 INTO
                :IBASBOMDAT_N.DOC_ID,
                :IBASBOMDAT_N.SITE_ID,
                :IBASBOMDAT_N.PROD_NO,
                :IBASBOMDAT_N.BOM_USAGE,
                :IBASBOMDAT_N.BOM_KEY,
                :IBASBOMDAT_N.OPT_BOM,
                :IBASBOMDAT_N.OPT_BOM_DESC,
                :IBASBOMDAT_N.EFF_START_DATE,
                :IBASBOMDAT_N.EFF_END_DATE,
                :IBASBOMDAT_N.STD_QTY,
                :IBASBOMDAT_N.STD_UNIT,
                :IBASBOMDAT_N.BOM_TEXT,
                :IBASBOMDAT_N.BOM_PJT,
                :IBASBOMDAT_N.BOM_PJT_CATE,
                :IBASBOMDAT_N.MATE_NO,
                :IBASBOMDAT_N.MATE_DESC,
                :IBASBOMDAT_N.QTY,
                :IBASBOMDAT_N.UNIT_ID,
                :IBASBOMDAT_N.DEL_YN,
                :IBASBOMDAT_N.INF_TIME,
                :IBASBOMDAT_N.INF_PROC_TIME,
                :IBASBOMDAT_N.CMF_1,
                :IBASBOMDAT_N.CMF_2,
                :IBASBOMDAT_N.CMF_3,
                :IBASBOMDAT_N.CMF_4,
                :IBASBOMDAT_N.CMF_5,
                :IBASBOMDAT_N.DATA_FLAG,
                :IBASBOMDAT_N.UPDATE_COUNT,
                :IBASBOMDAT_N.INSERT_COUNT,
                :IBASBOMDAT_N.DELETE_COUNT,
                :IBASBOMDAT_N.SQL_DML_COUNT,
                :IBASBOMDAT_N.ZPICODE,
                :IBASBOMDAT_N.ZPIMSGID,
                :IBASBOMDAT_N.RETURN_TYPE,
                :IBASBOMDAT_N.RETURN_MSG,
                :IBASBOMDAT_N.ZIFERNAM,
                :IBASBOMDAT_N.ZIFDATE,
                :IBASBOMDAT_N.ZIFTIME,
                :IBASBOMDAT_N.ZPISTAT,
                :IBASBOMDAT_N.ZPIMSG;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_ibasbomdat(&IBASBOMDAT_N, IBASBOMDAT);
    }

    DB_stop_query_timer("CDB_fetch_ibasbomdat", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_ibasbomdat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IBASBOMDAT_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IBASBOMDAT_CUR_2;
            break;

		case 3:
            EXEC SQL CLOSE CDB_IBASBOMDAT_CUR_3;
            break;

		case 4:
			EXEC SQL CLOSE CDB_IBASBOMDAT_CUR_4;
			break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ibasbomdat", sel_type);
}


/* Initialize Function */
void CDB_init_ibasbomdat(struct IBASBOMDAT_TAG *IBASBOMDAT)
{
    /* memset by Space */
    memset(IBASBOMDAT, ' ', sizeof(struct IBASBOMDAT_TAG));
    
    IBASBOMDAT->STD_QTY = 0;
    IBASBOMDAT->QTY = 0;
}


/* Add Null Function */
void CDB_add_null_ibasbomdat(struct IBASBOMDAT_N_TAG *IBASBOMDAT_N, struct IBASBOMDAT_TAG *IBASBOMDAT)
{
    /* memset by NULL */
    memset(IBASBOMDAT_N, '\0', sizeof(struct IBASBOMDAT_N_TAG));
    
    MEMCPY_AN(IBASBOMDAT_N->DOC_ID, IBASBOMDAT->DOC_ID, sizeof(IBASBOMDAT->DOC_ID));
    MEMCPY_AN(IBASBOMDAT_N->SITE_ID, IBASBOMDAT->SITE_ID, sizeof(IBASBOMDAT->SITE_ID));
    MEMCPY_AN(IBASBOMDAT_N->PROD_NO, IBASBOMDAT->PROD_NO, sizeof(IBASBOMDAT->PROD_NO));
    IBASBOMDAT_N->BOM_USAGE[0] = IBASBOMDAT->BOM_USAGE;
    MEMCPY_AN(IBASBOMDAT_N->BOM_KEY, IBASBOMDAT->BOM_KEY, sizeof(IBASBOMDAT->BOM_KEY));
    MEMCPY_AN(IBASBOMDAT_N->OPT_BOM, IBASBOMDAT->OPT_BOM, sizeof(IBASBOMDAT->OPT_BOM));
    MEMCPY_AN(IBASBOMDAT_N->OPT_BOM_DESC, IBASBOMDAT->OPT_BOM_DESC, sizeof(IBASBOMDAT->OPT_BOM_DESC));
    MEMCPY_AN(IBASBOMDAT_N->EFF_START_DATE, IBASBOMDAT->EFF_START_DATE, sizeof(IBASBOMDAT->EFF_START_DATE));
    MEMCPY_AN(IBASBOMDAT_N->EFF_END_DATE, IBASBOMDAT->EFF_END_DATE, sizeof(IBASBOMDAT->EFF_END_DATE));
    IBASBOMDAT_N->STD_QTY = IBASBOMDAT->STD_QTY;
    MEMCPY_AN(IBASBOMDAT_N->STD_UNIT, IBASBOMDAT->STD_UNIT, sizeof(IBASBOMDAT->STD_UNIT));
    MEMCPY_AN(IBASBOMDAT_N->BOM_TEXT, IBASBOMDAT->BOM_TEXT, sizeof(IBASBOMDAT->BOM_TEXT));
    MEMCPY_AN(IBASBOMDAT_N->BOM_PJT, IBASBOMDAT->BOM_PJT, sizeof(IBASBOMDAT->BOM_PJT));
    MEMCPY_AN(IBASBOMDAT_N->BOM_PJT_CATE, IBASBOMDAT->BOM_PJT_CATE, sizeof(IBASBOMDAT->BOM_PJT_CATE));
    MEMCPY_AN(IBASBOMDAT_N->MATE_NO, IBASBOMDAT->MATE_NO, sizeof(IBASBOMDAT->MATE_NO));
    MEMCPY_AN(IBASBOMDAT_N->MATE_DESC, IBASBOMDAT->MATE_DESC, sizeof(IBASBOMDAT->MATE_DESC));
    IBASBOMDAT_N->QTY = IBASBOMDAT->QTY;
    MEMCPY_AN(IBASBOMDAT_N->UNIT_ID, IBASBOMDAT->UNIT_ID, sizeof(IBASBOMDAT->UNIT_ID));
    IBASBOMDAT_N->DEL_YN[0] = IBASBOMDAT->DEL_YN;
    MEMCPY_AN(IBASBOMDAT_N->INF_TIME, IBASBOMDAT->INF_TIME, sizeof(IBASBOMDAT->INF_TIME));
    MEMCPY_AN(IBASBOMDAT_N->INF_PROC_TIME, IBASBOMDAT->INF_PROC_TIME, sizeof(IBASBOMDAT->INF_PROC_TIME));
    MEMCPY_AN(IBASBOMDAT_N->CMF_1, IBASBOMDAT->CMF_1, sizeof(IBASBOMDAT->CMF_1));
    MEMCPY_AN(IBASBOMDAT_N->CMF_2, IBASBOMDAT->CMF_2, sizeof(IBASBOMDAT->CMF_2));
    MEMCPY_AN(IBASBOMDAT_N->CMF_3, IBASBOMDAT->CMF_3, sizeof(IBASBOMDAT->CMF_3));
    MEMCPY_AN(IBASBOMDAT_N->CMF_4, IBASBOMDAT->CMF_4, sizeof(IBASBOMDAT->CMF_4));
    MEMCPY_AN(IBASBOMDAT_N->CMF_5, IBASBOMDAT->CMF_5, sizeof(IBASBOMDAT->CMF_5));
    IBASBOMDAT_N->DATA_FLAG[0] = IBASBOMDAT->DATA_FLAG;
    MEMCPY_AN(IBASBOMDAT_N->UPDATE_COUNT, IBASBOMDAT->UPDATE_COUNT, sizeof(IBASBOMDAT->UPDATE_COUNT));
    MEMCPY_AN(IBASBOMDAT_N->INSERT_COUNT, IBASBOMDAT->INSERT_COUNT, sizeof(IBASBOMDAT->INSERT_COUNT));
    MEMCPY_AN(IBASBOMDAT_N->DELETE_COUNT, IBASBOMDAT->DELETE_COUNT, sizeof(IBASBOMDAT->DELETE_COUNT));
    MEMCPY_AN(IBASBOMDAT_N->SQL_DML_COUNT, IBASBOMDAT->SQL_DML_COUNT, sizeof(IBASBOMDAT->SQL_DML_COUNT));
    MEMCPY_AN(IBASBOMDAT_N->ZPICODE, IBASBOMDAT->ZPICODE, sizeof(IBASBOMDAT->ZPICODE));
    MEMCPY_AN(IBASBOMDAT_N->ZPIMSGID, IBASBOMDAT->ZPIMSGID, sizeof(IBASBOMDAT->ZPIMSGID));
    IBASBOMDAT_N->RETURN_TYPE[0] = IBASBOMDAT->RETURN_TYPE;
    MEMCPY_AN(IBASBOMDAT_N->RETURN_MSG, IBASBOMDAT->RETURN_MSG, sizeof(IBASBOMDAT->RETURN_MSG));
    MEMCPY_AN(IBASBOMDAT_N->ZIFERNAM, IBASBOMDAT->ZIFERNAM, sizeof(IBASBOMDAT->ZIFERNAM));
    MEMCPY_AN(IBASBOMDAT_N->ZIFDATE, IBASBOMDAT->ZIFDATE, sizeof(IBASBOMDAT->ZIFDATE));
    MEMCPY_AN(IBASBOMDAT_N->ZIFTIME, IBASBOMDAT->ZIFTIME, sizeof(IBASBOMDAT->ZIFTIME));
    IBASBOMDAT_N->ZPISTAT[0] = IBASBOMDAT->ZPISTAT;
    MEMCPY_AN(IBASBOMDAT_N->ZPIMSG, IBASBOMDAT->ZPIMSG, sizeof(IBASBOMDAT->ZPIMSG));
}


/* Del Null Function */
void CDB_del_null_ibasbomdat(struct IBASBOMDAT_N_TAG *IBASBOMDAT_N, struct IBASBOMDAT_TAG *IBASBOMDAT)
{
    MEMCPY_DN(IBASBOMDAT->DOC_ID, IBASBOMDAT_N->DOC_ID, sizeof(IBASBOMDAT->DOC_ID));
    MEMCPY_DN(IBASBOMDAT->SITE_ID, IBASBOMDAT_N->SITE_ID, sizeof(IBASBOMDAT->SITE_ID));
    MEMCPY_DN(IBASBOMDAT->PROD_NO, IBASBOMDAT_N->PROD_NO, sizeof(IBASBOMDAT->PROD_NO));
    IBASBOMDAT->BOM_USAGE = IBASBOMDAT_N->BOM_USAGE[0];
    MEMCPY_DN(IBASBOMDAT->BOM_KEY, IBASBOMDAT_N->BOM_KEY, sizeof(IBASBOMDAT->BOM_KEY));
    MEMCPY_DN(IBASBOMDAT->OPT_BOM, IBASBOMDAT_N->OPT_BOM, sizeof(IBASBOMDAT->OPT_BOM));
    MEMCPY_DN(IBASBOMDAT->OPT_BOM_DESC, IBASBOMDAT_N->OPT_BOM_DESC, sizeof(IBASBOMDAT->OPT_BOM_DESC));
    MEMCPY_DN(IBASBOMDAT->EFF_START_DATE, IBASBOMDAT_N->EFF_START_DATE, sizeof(IBASBOMDAT->EFF_START_DATE));
    MEMCPY_DN(IBASBOMDAT->EFF_END_DATE, IBASBOMDAT_N->EFF_END_DATE, sizeof(IBASBOMDAT->EFF_END_DATE));
    IBASBOMDAT->STD_QTY = IBASBOMDAT_N->STD_QTY;
    MEMCPY_DN(IBASBOMDAT->STD_UNIT, IBASBOMDAT_N->STD_UNIT, sizeof(IBASBOMDAT->STD_UNIT));
