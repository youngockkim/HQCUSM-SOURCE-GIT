                    CMF_1 = :IBASBOMDAT_N.CMF_1,
                    CMF_2 = :IBASBOMDAT_N.CMF_2,
                    CMF_3 = :IBASBOMDAT_N.CMF_3,
                    CMF_4 = :IBASBOMDAT_N.CMF_4,
                    CMF_5 = :IBASBOMDAT_N.CMF_5,
                    DATA_FLAG = :IBASBOMDAT_N.DATA_FLAG,
                    UPDATE_COUNT = :IBASBOMDAT_N.UPDATE_COUNT,
                    INSERT_COUNT = :IBASBOMDAT_N.INSERT_COUNT,
                    DELETE_COUNT = :IBASBOMDAT_N.DELETE_COUNT,
                    SQL_DML_COUNT = :IBASBOMDAT_N.SQL_DML_COUNT,
                    ZPICODE = :IBASBOMDAT_N.ZPICODE,
                    ZPIMSGID = :IBASBOMDAT_N.ZPIMSGID,
                    RETURN_TYPE = :IBASBOMDAT_N.RETURN_TYPE,
                    RETURN_MSG = :IBASBOMDAT_N.RETURN_MSG,
                    ZIFERNAM = :IBASBOMDAT_N.ZIFERNAM,
                    ZIFDATE = :IBASBOMDAT_N.ZIFDATE,
                    ZIFTIME = :IBASBOMDAT_N.ZIFTIME,
                    ZPISTAT = :IBASBOMDAT_N.ZPISTAT,
                    ZPIMSG = :IBASBOMDAT_N.ZPIMSG
                WHERE DOC_ID = :IBASBOMDAT_N.DOC_ID
                    AND SITE_ID = :IBASBOMDAT_N.SITE_ID
                    AND PROD_NO = :IBASBOMDAT_N.PROD_NO
                    AND BOM_USAGE = :IBASBOMDAT_N.BOM_USAGE
                    AND BOM_KEY = :IBASBOMDAT_N.BOM_KEY
                    AND OPT_BOM = :IBASBOMDAT_N.OPT_BOM;
            break;

		case 2:
            EXEC SQL UPDATE IBASBOMDAT SET
					INF_PROC_TIME = :IBASBOMDAT_N.INF_PROC_TIME,                    
                    RETURN_TYPE = 'E',
                    RETURN_MSG = :IBASBOMDAT_N.RETURN_MSG
                WHERE DOC_ID = :IBASBOMDAT_N.DOC_ID
                    AND SITE_ID = :IBASBOMDAT_N.SITE_ID
                    AND PROD_NO = :IBASBOMDAT_N.PROD_NO
                    AND BOM_USAGE = :IBASBOMDAT_N.BOM_USAGE
                    AND BOM_KEY = :IBASBOMDAT_N.BOM_KEY
                    AND OPT_BOM = :IBASBOMDAT_N.OPT_BOM;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_ibasbomdat", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_ibasbomdat(int sel_type, struct IBASBOMDAT_TAG *IBASBOMDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IBASBOMDAT_N_TAG IBASBOMDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ibasbomdat(&IBASBOMDAT_N, IBASBOMDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IBASBOMDAT_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_NO,
                    BOM_USAGE,
                    BOM_KEY,
                    OPT_BOM,
                    OPT_BOM_DESC,
                    EFF_START_DATE,
                    EFF_END_DATE,
                    STD_QTY,
                    STD_UNIT,
                    BOM_TEXT,
                    BOM_PJT,
                    BOM_PJT_CATE,
                    MATE_NO,
                    MATE_DESC,
                    QTY,
                    UNIT_ID,
                    DEL_YN,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IBASBOMDAT
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_NO ASC,
                    BOM_USAGE ASC,
                    BOM_KEY ASC,
                    OPT_BOM ASC;
            EXEC SQL OPEN CDB_IBASBOMDAT_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_IBASBOMDAT_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_NO,
                    BOM_USAGE,
                    BOM_KEY,
                    OPT_BOM,
                    OPT_BOM_DESC,
                    EFF_START_DATE,
                    EFF_END_DATE,
                    STD_QTY,
                    STD_UNIT,
                    BOM_TEXT,
                    BOM_PJT,
                    BOM_PJT_CATE,
                    MATE_NO,
                    MATE_DESC,
                    QTY,
                    UNIT_ID,
                    DEL_YN,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IBASBOMDAT
				WHERE RETURN_TYPE <> 'E'
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_NO ASC,
                    BOM_USAGE ASC,
                    BOM_KEY ASC,
                    OPT_BOM ASC;
            EXEC SQL OPEN CDB_IBASBOMDAT_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_IBASBOMDAT_CUR_3 CURSOR FOR
                SELECT                     
                    PROD_NO,
                    BOM_KEY,
					MAX(ZIFDATE)
                FROM IBASBOMDAT
				WHERE RETURN_TYPE <> 'E'
				GROUP BY PROD_NO, BOM_KEY
                ORDER BY PROD_NO ASC,
                         BOM_KEY ASC;
            EXEC SQL OPEN CDB_IBASBOMDAT_CUR_3;
            break;

		case 4:
            EXEC SQL DECLARE CDB_IBASBOMDAT_CUR_4 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_NO,
                    BOM_USAGE,
                    BOM_KEY,
                    OPT_BOM,
                    OPT_BOM_DESC,
                    EFF_START_DATE,
                    EFF_END_DATE,
                    STD_QTY,
                    STD_UNIT,
                    BOM_TEXT,
                    BOM_PJT,
                    BOM_PJT_CATE,
                    MATE_NO,
                    MATE_DESC,
                    QTY,
                    UNIT_ID,
                    DEL_YN,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IBASBOMDAT
				WHERE RETURN_TYPE <> 'E'
				  AND PROD_NO = : IBASBOMDAT_N.PROD_NO
				  AND BOM_KEY = : IBASBOMDAT_N.BOM_KEY
				  AND ZIFDATE = : IBASBOMDAT_N.ZIFDATE
				  AND ZIFTIME = (SELECT MAX(ZIFTIME) FROM IBASBOMDAT
				                 WHERE PROD_NO = : IBASBOMDAT_N.PROD_NO
								   AND BOM_KEY = : IBASBOMDAT_N.BOM_KEY
								   AND ZIFDATE = : IBASBOMDAT_N.ZIFDATE)
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_NO ASC,
                    BOM_USAGE ASC,
                    BOM_KEY ASC,
                    OPT_BOM ASC;
            EXEC SQL OPEN CDB_IBASBOMDAT_CUR_4;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_ibasbomdat", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_ibasbomdat(int sel_type, struct IBASBOMDAT_TAG *IBASBOMDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IBASBOMDAT_N_TAG IBASBOMDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_IBASBOMDAT_CUR_1 INTO
                :IBASBOMDAT_N.DOC_ID,
                :IBASBOMDAT_N.SITE_ID,
                :IBASBOMDAT_N.PROD_NO,
                :IBASBOMDAT_N.BOM_USAGE,
