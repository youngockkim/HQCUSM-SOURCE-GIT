                SELECT 
                    FACTORY,
                    FACTORY_NO,
                    PALLET_ID,
                    MAT_ID,
                    CAUSE_ID,
                    PACK_TIME,
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
