    MEMCPY_DN(CWIPRPKHIS->CREATE_USER_ID, CWIPRPKHIS_N->CREATE_USER_ID, sizeof(CWIPRPKHIS->CREATE_USER_ID));
    MEMCPY_DN(CWIPRPKHIS->CREATE_TIME, CWIPRPKHIS_N->CREATE_TIME, sizeof(CWIPRPKHIS->CREATE_TIME));
    MEMCPY_DN(CWIPRPKHIS->UPDATE_USER_ID, CWIPRPKHIS_N->UPDATE_USER_ID, sizeof(CWIPRPKHIS->UPDATE_USER_ID));
    MEMCPY_DN(CWIPRPKHIS->UPDATE_TIME, CWIPRPKHIS_N->UPDATE_TIME, sizeof(CWIPRPKHIS->UPDATE_TIME));
}