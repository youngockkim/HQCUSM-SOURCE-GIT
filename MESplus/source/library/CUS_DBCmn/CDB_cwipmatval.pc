    MEMCPY_DN(CWIPMATVAL->CMF_9, CWIPMATVAL_N->CMF_9, sizeof(CWIPMATVAL->CMF_9));
    MEMCPY_DN(CWIPMATVAL->CMF_10, CWIPMATVAL_N->CMF_10, sizeof(CWIPMATVAL->CMF_10));
}


