/* Add Null Function */
void CDB_add_null_cclvcrrbat(struct CCLVCRRBAT_N_TAG *CCLVCRRBAT_N, struct CCLVCRRBAT_TAG *CCLVCRRBAT)
{
    /* memset by NULL */
    memset(CCLVCRRBAT_N, '\0', sizeof(struct CCLVCRRBAT_N_TAG));
    
    MEMCPY_AN(CCLVCRRBAT_N->ORDER_ID, CCLVCRRBAT->ORDER_ID, sizeof(CCLVCRRBAT->ORDER_ID));
    MEMCPY_AN(CCLVCRRBAT_N->CART_ID, CCLVCRRBAT->CART_ID, sizeof(CCLVCRRBAT->CART_ID));
    MEMCPY_AN(CCLVCRRBAT_N->RES_ID, CCLVCRRBAT->RES_ID, sizeof(CCLVCRRBAT->RES_ID));
    MEMCPY_AN(CCLVCRRBAT_N->TRAN_TIME, CCLVCRRBAT->TRAN_TIME, sizeof(CCLVCRRBAT->TRAN_TIME));
    CCLVCRRBAT_N->CLEAR_FLAG[0] = CCLVCRRBAT->CLEAR_FLAG;
    MEMCPY_AN(CCLVCRRBAT_N->CREATE_TIME, CCLVCRRBAT->CREATE_TIME, sizeof(CCLVCRRBAT->CREATE_TIME));
    MEMCPY_AN(CCLVCRRBAT_N->UPDATE_TIME, CCLVCRRBAT->UPDATE_TIME, sizeof(CCLVCRRBAT->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_cclvcrrbat(struct CCLVCRRBAT_N_TAG *CCLVCRRBAT_N, struct CCLVCRRBAT_TAG *CCLVCRRBAT)
{
    MEMCPY_DN(CCLVCRRBAT->ORDER_ID, CCLVCRRBAT_N->ORDER_ID, sizeof(CCLVCRRBAT->ORDER_ID));
    MEMCPY_DN(CCLVCRRBAT->CART_ID, CCLVCRRBAT_N->CART_ID, sizeof(CCLVCRRBAT->CART_ID));
    MEMCPY_DN(CCLVCRRBAT->RES_ID, CCLVCRRBAT_N->RES_ID, sizeof(CCLVCRRBAT->RES_ID));
    MEMCPY_DN(CCLVCRRBAT->TRAN_TIME, CCLVCRRBAT_N->TRAN_TIME, sizeof(CCLVCRRBAT->TRAN_TIME));
    CCLVCRRBAT->CLEAR_FLAG = CCLVCRRBAT_N->CLEAR_FLAG[0];
    MEMCPY_DN(CCLVCRRBAT->CREATE_TIME, CCLVCRRBAT_N->CREATE_TIME, sizeof(CCLVCRRBAT->CREATE_TIME));
    MEMCPY_DN(CCLVCRRBAT->UPDATE_TIME, CCLVCRRBAT_N->UPDATE_TIME, sizeof(CCLVCRRBAT->UPDATE_TIME));
}


