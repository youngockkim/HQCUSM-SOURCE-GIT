/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_iwippakmst_gerp(int sel_type, struct IWIPPAKMST_GERP_TAG *IWIPPAKMST_GERP)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IWIPPAKMST_GERP_N_TAG IWIPPAKMST_GERP_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_iwippakmst_gerp(&IWIPPAKMST_GERP_N, IWIPPAKMST_GERP);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IWIPPAKMST_GERP_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    MATE_NO,
                    QCELL_MODULE_TYPE,
                    ACTION_TYPE,
                    PACK_TYPE,
                    BARCODE_ID,
                    LENGTH,
                    BREADTH,
                    HEIGHT,
                    GROSS_WEIGHT,
                    NET_WEIGHT,
                    TARE_WEIGHT,
                    SITE_ID,
                    ISUSABLE,
                    MODULE_QTY,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG,
                    AC_FLAG,
                    LENGTH_H,
                    BREADTH_H,
                    HEIGHT_H,
                    GROSS_WEIGHT_H,
                    NET_WEIGHT_H,
                    TARE_WEIGHT_H,
                    LENGTH_I,
                    BREADTH_I,
                    HEIGHT_I,
                    GROSSW_I,
                    NETW_I,
                    TAREW_I,
                    LENGTH_H_I,
                    BREADTH_H_I,
                    HEIGHT_H_I,
                    GROSSW_H_I,
                    NETW_H_I,
                    TAREW_H_I
                FROM IWIPPAKMST_GERP
                ORDER BY DOC_ID ASC;
            EXEC SQL OPEN CDB_IWIPPAKMST_GERP_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_IWIPPAKMST_GERP_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    MATE_NO,
                    QCELL_MODULE_TYPE,
                    ACTION_TYPE,
                    PACK_TYPE,
                    BARCODE_ID,
                    LENGTH,
                    BREADTH,
                    HEIGHT,
                    GROSS_WEIGHT,
                    NET_WEIGHT,
                    TARE_WEIGHT,
                    SITE_ID,
                    ISUSABLE,
                    MODULE_QTY,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG,
					AC_FLAG,
					LENGTH_H,
					BREADTH_H,
					HEIGHT_H,
					GROSS_WEIGHT_H,
					NET_WEIGHT_H,
					TARE_WEIGHT_H,
                    LENGTH_I,
                    BREADTH_I,
                    HEIGHT_I,
                    GROSSW_I,
                    NETW_I,
                    TAREW_I,
                    LENGTH_H_I,
                    BREADTH_H_I,
                    HEIGHT_H_I,
                    GROSSW_H_I,
                    NETW_H_I,
                    TAREW_H_I
                FROM IWIPPAKMST_GERP
				WHERE RETURN_TYPE <> 'E'
                ORDER BY DOC_ID ASC;
            EXEC SQL OPEN CDB_IWIPPAKMST_GERP_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_iwippakmst_gerp", sel_type);
}


