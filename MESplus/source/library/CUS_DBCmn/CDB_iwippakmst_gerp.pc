/* Initialize Function */
void CDB_init_iwippakmst_gerp(struct IWIPPAKMST_GERP_TAG *IWIPPAKMST_GERP)
{
    /* memset by Space */
    memset(IWIPPAKMST_GERP, ' ', sizeof(struct IWIPPAKMST_GERP_TAG));
    
    IWIPPAKMST_GERP->MODULE_QTY = 0;
}


/* Add Null Function */
void CDB_add_null_iwippakmst_gerp(struct IWIPPAKMST_GERP_N_TAG *IWIPPAKMST_GERP_N, struct IWIPPAKMST_GERP_TAG *IWIPPAKMST_GERP)
{
    /* memset by NULL */
    memset(IWIPPAKMST_GERP_N, '\0', sizeof(struct IWIPPAKMST_GERP_N_TAG));
    
    MEMCPY_AN(IWIPPAKMST_GERP_N->DOC_ID, IWIPPAKMST_GERP->DOC_ID, sizeof(IWIPPAKMST_GERP->DOC_ID));
    MEMCPY_AN(IWIPPAKMST_GERP_N->MATE_NO, IWIPPAKMST_GERP->MATE_NO, sizeof(IWIPPAKMST_GERP->MATE_NO));
    MEMCPY_AN(IWIPPAKMST_GERP_N->QCELL_MODULE_TYPE, IWIPPAKMST_GERP->QCELL_MODULE_TYPE, sizeof(IWIPPAKMST_GERP->QCELL_MODULE_TYPE));
    MEMCPY_AN(IWIPPAKMST_GERP_N->ACTION_TYPE, IWIPPAKMST_GERP->ACTION_TYPE, sizeof(IWIPPAKMST_GERP->ACTION_TYPE));
    MEMCPY_AN(IWIPPAKMST_GERP_N->PACK_TYPE, IWIPPAKMST_GERP->PACK_TYPE, sizeof(IWIPPAKMST_GERP->PACK_TYPE));
    MEMCPY_AN(IWIPPAKMST_GERP_N->BARCODE_ID, IWIPPAKMST_GERP->BARCODE_ID, sizeof(IWIPPAKMST_GERP->BARCODE_ID));
    MEMCPY_AN(IWIPPAKMST_GERP_N->LENGTH, IWIPPAKMST_GERP->LENGTH, sizeof(IWIPPAKMST_GERP->LENGTH));
    MEMCPY_AN(IWIPPAKMST_GERP_N->BREADTH, IWIPPAKMST_GERP->BREADTH, sizeof(IWIPPAKMST_GERP->BREADTH));
    MEMCPY_AN(IWIPPAKMST_GERP_N->HEIGHT, IWIPPAKMST_GERP->HEIGHT, sizeof(IWIPPAKMST_GERP->HEIGHT));
    MEMCPY_AN(IWIPPAKMST_GERP_N->GROSS_WEIGHT, IWIPPAKMST_GERP->GROSS_WEIGHT, sizeof(IWIPPAKMST_GERP->GROSS_WEIGHT));
    MEMCPY_AN(IWIPPAKMST_GERP_N->NET_WEIGHT, IWIPPAKMST_GERP->NET_WEIGHT, sizeof(IWIPPAKMST_GERP->NET_WEIGHT));
    MEMCPY_AN(IWIPPAKMST_GERP_N->TARE_WEIGHT, IWIPPAKMST_GERP->TARE_WEIGHT, sizeof(IWIPPAKMST_GERP->TARE_WEIGHT));
    MEMCPY_AN(IWIPPAKMST_GERP_N->SITE_ID, IWIPPAKMST_GERP->SITE_ID, sizeof(IWIPPAKMST_GERP->SITE_ID));
    IWIPPAKMST_GERP_N->ISUSABLE[0] = IWIPPAKMST_GERP->ISUSABLE;
    IWIPPAKMST_GERP_N->MODULE_QTY = IWIPPAKMST_GERP->MODULE_QTY;
    MEMCPY_AN(IWIPPAKMST_GERP_N->INF_TIME, IWIPPAKMST_GERP->INF_TIME, sizeof(IWIPPAKMST_GERP->INF_TIME));
    MEMCPY_AN(IWIPPAKMST_GERP_N->INF_PROC_TIME, IWIPPAKMST_GERP->INF_PROC_TIME, sizeof(IWIPPAKMST_GERP->INF_PROC_TIME));
    MEMCPY_AN(IWIPPAKMST_GERP_N->CMF_1, IWIPPAKMST_GERP->CMF_1, sizeof(IWIPPAKMST_GERP->CMF_1));
