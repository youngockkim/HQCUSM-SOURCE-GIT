/* SQL UPDATE Function */
void CDB_update_cwipreqmst(int sel_type, struct CWIPREQMST_TAG *CWIPREQMST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPREQMST_N_TAG CWIPREQMST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwipreqmst(&CWIPREQMST_N, CWIPREQMST);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE CWIPREQMST SET
                    REQ_TYPE = :CWIPREQMST_N.REQ_TYPE,
                    REQ_DATE = :CWIPREQMST_N.REQ_DATE,
                    REQ_TIME = :CWIPREQMST_N.REQ_TIME,
                    REQ_STATUS = :CWIPREQMST_N.REQ_STATUS,
                    FROM_OPER = :CWIPREQMST_N.FROM_OPER,
                    TO_OPER = :CWIPREQMST_N.TO_OPER,
                    REQ_USER_ID = :CWIPREQMST_N.REQ_USER_ID,
                    REQ_CMF_1 = :CWIPREQMST_N.REQ_CMF_1,
                    REQ_CMF_2 = :CWIPREQMST_N.REQ_CMF_2,
                    REQ_CMF_3 = :CWIPREQMST_N.REQ_CMF_3,
                    REQ_CMF_4 = :CWIPREQMST_N.REQ_CMF_4,
                    REQ_CMF_5 = :CWIPREQMST_N.REQ_CMF_5,
                    REQ_CMF_6 = :CWIPREQMST_N.REQ_CMF_6,
                    REQ_CMF_7 = :CWIPREQMST_N.REQ_CMF_7,
                    REQ_CMF_8 = :CWIPREQMST_N.REQ_CMF_8,
                    REQ_CMF_9 = :CWIPREQMST_N.REQ_CMF_9,
                    REQ_CMF_10 = :CWIPREQMST_N.REQ_CMF_10,
                    CREATE_USER_ID = :CWIPREQMST_N.CREATE_USER_ID,
                    CREATE_TIME = :CWIPREQMST_N.CREATE_TIME,
                    UPDATE_USER_ID = :CWIPREQMST_N.UPDATE_USER_ID,
                    UPDATE_TIME = :CWIPREQMST_N.UPDATE_TIME
                WHERE FACTORY = :CWIPREQMST_N.FACTORY
                    AND REQ_NO = :CWIPREQMST_N.REQ_NO;
            break;

		 case 2:
            EXEC SQL UPDATE CWIPREQMST SET
                    REQ_STATUS = RTRIM(:CWIPREQMST_N.REQ_STATUS),
                    UPDATE_USER_ID = :CWIPREQMST_N.UPDATE_USER_ID,
                    UPDATE_TIME = :CWIPREQMST_N.UPDATE_TIME
                WHERE FACTORY = :CWIPREQMST_N.FACTORY
                    AND REQ_NO = :CWIPREQMST_N.REQ_NO;
            break;

		case 3:
            EXEC SQL UPDATE CWIPREQMST B SET 
                    REQ_STATUS = RTRIM('CLOSE'),
                    REQ_CMF_1 = :CWIPREQMST_N.REQ_CMF_1
                    WHERE 1 = 1
                    AND FACTORY = :CWIPREQMST_N.FACTORY
                    AND RTRIM(REQ_STATUS) = 'REQUEST'
                    AND REQ_NO = (SELECT REQ_NO 
                                    FROM CWIPREQDTL A 
                                WHERE A.FACTORY = B.FACTORY 
                                  AND A.REQ_NO = B.REQ_NO 
                                  AND A.LOT_ID = :CWIPREQMST_N.REQ_CMF_2);
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_cwipreqmst", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwipreqmst(int sel_type, struct CWIPREQMST_TAG *CWIPREQMST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPREQMST_N_TAG CWIPREQMST_N;
		char   sql[5120];
        char   ts[1000];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwipreqmst(&CWIPREQMST_N, CWIPREQMST);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPREQMST_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    REQ_NO,
                    REQ_TYPE,
                    REQ_DATE,
                    REQ_TIME,
                    REQ_STATUS,
                    FROM_OPER,
                    TO_OPER,
                    REQ_USER_ID,
                    REQ_CMF_1,
                    REQ_CMF_2,
                    REQ_CMF_3,
                    REQ_CMF_4,
                    REQ_CMF_5,
                    REQ_CMF_6,
                    REQ_CMF_7,
                    REQ_CMF_8,
                    REQ_CMF_9,
                    REQ_CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CWIPREQMST
                ORDER BY FACTORY ASC,
                    REQ_NO ASC;
            EXEC SQL OPEN CDB_CWIPREQMST_CUR_1;
            break;

		case 2:
			sprintf(sql , " SELECT ");
            sprintf(sql + strlen(sql), " REQ_NO,     ");
            sprintf(sql + strlen(sql), " REQ_DATE,   ");
            sprintf(sql + strlen(sql), " REQ_TIME,   "); 
            sprintf(sql + strlen(sql), " REQ_STATUS, ");
            sprintf(sql + strlen(sql), " FROM_OPER,  ");
            sprintf(sql + strlen(sql), " TO_OPER,    ");
            sprintf(sql + strlen(sql), " REQ_USER_ID, ");
            sprintf(sql + strlen(sql), " REQ_CMF_1,  "); /* FROM OPER DESC */
            sprintf(sql + strlen(sql), " REQ_CMF_2,  "); /* TO OPER DESC */
            sprintf(sql + strlen(sql), " REQ_CMF_3,  "); /* USER NM */
            sprintf(sql + strlen(sql), " REQ_CMF_4   "); /* LOT ID */
            sprintf(sql + strlen(sql), " FROM        ");
            sprintf(sql + strlen(sql), " (           ");
            sprintf(sql + strlen(sql), " SELECT      ");
            sprintf(sql + strlen(sql), " A.FACTORY,  ");
            sprintf(sql + strlen(sql), " B.REQ_NO,   ");
            sprintf(sql + strlen(sql), " B.REQ_TYPE, ");
            sprintf(sql + strlen(sql), " B.REQ_DATE, ");
            sprintf(sql + strlen(sql), " B.REQ_TIME, ");
            sprintf(sql + strlen(sql), " B.REQ_STATUS,  ");
            sprintf(sql + strlen(sql), " B.REQ_USER_ID, ");
            sprintf(sql + strlen(sql), " NVL(D.USER_DESC, ' ') AS REQ_CMF_3, ");  
            sprintf(sql + strlen(sql), " B.FROM_OPER, ");
            sprintf(sql + strlen(sql), " ( SELECT OPER_DESC  FROM MWIPOPRDEF WHERE FACTORY = A.FACTORY AND OPER = B.FROM_OPER) AS REQ_CMF_1, ");  
            sprintf(sql + strlen(sql), " B.TO_OPER, ");
            sprintf(sql + strlen(sql), " ( SELECT OPER_DESC  FROM MWIPOPRDEF WHERE FACTORY = A.FACTORY AND OPER = B.TO_OPER) AS REQ_CMF_2, ");  
            sprintf(sql + strlen(sql), " A.LOT_ID AS REQ_CMF_4, ");   
            sprintf(sql + strlen(sql), " DECODE (REQ_STATUS, 'REJECT', 1, 2) AS RK, ");       
            sprintf(sql + strlen(sql), " DECODE (REQ_TYPE, 'M', 'Y', (DECODE (REQ_STATUS, 'REJECT', 'N', 'Y'))) AS CHK ");
            sprintf(sql + strlen(sql), " FROM CWIPREQDTL A, ");
            sprintf(sql + strlen(sql), " CWIPREQMST B, "); 
            sprintf(sql + strlen(sql), " CEDCLOTRLT C, ");
            sprintf(sql + strlen(sql), " MSECUSRDEF D  ");
            sprintf(sql + strlen(sql), " WHERE  1 = 1  ");
		    make_valid_quote(ts, CWIPREQMST_N.FACTORY);
            sprintf(sql + strlen(sql), " AND A.FACTORY = '%s' ", ts);
            if(ISSPACE(CWIPREQMST->REQ_CMF_3, sizeof(CWIPREQMST->REQ_CMF_3)) == DB_FALSE)
			{
				make_valid_quote(ts, CWIPREQMST_N.REQ_CMF_3);
				sprintf(sql + strlen(sql), " AND A.LOT_ID = '%s' ", ts); 
			}
            sprintf(sql + strlen(sql), " AND A.FACTORY = A.FACTORY ");
            sprintf(sql + strlen(sql), " AND A.FACTORY = B.FACTORY ");
            sprintf(sql + strlen(sql), " AND A.REQ_NO = B.REQ_NO   ");
            sprintf(sql + strlen(sql), " AND B.REQ_TYPE IN ('Q', 'M')  ");
            sprintf(sql + strlen(sql), " AND B.REQ_STATUS IN ('REQUEST', 'REJECT')  ");
            if(ISSPACE(CWIPREQMST->FROM_OPER, sizeof(CWIPREQMST->FROM_OPER)) == DB_FALSE)
			{
				make_valid_quote(ts, CWIPREQMST_N.FROM_OPER);
				sprintf(sql + strlen(sql), " AND B.FROM_OPER = '%s' ", ts); 
			}
			if(ISSPACE(CWIPREQMST->TO_OPER, sizeof(CWIPREQMST->TO_OPER)) == DB_FALSE)
			{
				make_valid_quote(ts, CWIPREQMST_N.TO_OPER);
				sprintf(sql + strlen(sql), " AND B.TO_OPER = '%s' ", ts); 
			}
            if(ISSPACE(CWIPREQMST->REQ_DATE, sizeof(CWIPREQMST->REQ_DATE)) == DB_FALSE)
			{
				make_valid_quote(ts, CWIPREQMST_N.REQ_DATE);
				sprintf(sql + strlen(sql), " AND B.REQ_DATE = '%s' ", ts); 
			}
            sprintf(sql + strlen(sql), " AND A.FACTORY = C.FACTORY "); 
            sprintf(sql + strlen(sql), " AND A.LOT_ID = C.LOT_ID   ");
            sprintf(sql + strlen(sql), " AND C.INS_TYPE = 'FC'     ");
            if(ISSPACE(CWIPREQMST->REQ_CMF_1, sizeof(CWIPREQMST->REQ_CMF_1)) == DB_FALSE)
			{
				make_valid_quote(ts, CWIPREQMST_N.REQ_CMF_1); /*GRADE*/				
                sprintf(sql + strlen(sql), " AND C.GRADE = '%s'  ", ts);
			}
            if(ISSPACE(CWIPREQMST->REQ_CMF_2, sizeof(CWIPREQMST->REQ_CMF_2)) == DB_FALSE)
			{
				make_valid_quote(ts, CWIPREQMST_N.REQ_CMF_2); /*POWER*/
                sprintf(sql + strlen(sql), " AND C.POWER = '%s'  ", ts);
			}
			sprintf(sql + strlen(sql), " AND B.FACTORY = D.FACTORY (+) ");
            sprintf(sql + strlen(sql), " AND B.REQ_USER_ID = D.USER_ID (+) ");
            sprintf(sql + strlen(sql), " AND NOT EXISTS (SELECT 'X'    ");
            sprintf(sql + strlen(sql), " FROM CWIPLOTPAK E             ");
            sprintf(sql + strlen(sql), " WHERE A.FACTORY = E.FACTORY   ");
            sprintf(sql + strlen(sql), " AND A.LOT_ID = E.LOT_ID       ");
            sprintf(sql + strlen(sql), " AND E.STATUS_FLAG = 'C')         ");
            sprintf(sql + strlen(sql), " )                             ");
            sprintf(sql + strlen(sql), " WHERE CHK = 'Y'               ");
            sprintf(sql + strlen(sql), " ORDER BY RK, REQ_TIME, REQ_NO, REQ_CMF_4, TO_OPER ");	

			EXEC SQL PREPARE S FROM :sql;
			EXEC SQL DECLARE CDB_CWIPREQMST_CUR_2 CURSOR FOR S; 
			EXEC SQL OPEN CDB_CWIPREQMST_CUR_2;    
            /*  
			LOG_head("DB");
			LOG_add("len", 0, strlen(sql));
			LOG_add("sql", 4, strlen(sql), sql);
			COM_log_write('I', 'S' , 'S');
			*/
            break;

        
		case 3:
				sprintf(sql , "SELECT A.FACTORY,  ");
                sprintf(sql + strlen(sql), "A.REQ_NO, ");
                sprintf(sql + strlen(sql), "A.REQ_TYPE, ");
                sprintf(sql + strlen(sql), "A.REQ_DATE, ");
                sprintf(sql + strlen(sql), "A.REQ_TIME, ");
                sprintf(sql + strlen(sql), "A.REQ_STATUS, ");
                sprintf(sql + strlen(sql), "A.REQ_USER_ID, ");
                sprintf(sql + strlen(sql), "A.REQ_CMF_3, ");
                sprintf(sql + strlen(sql), "A.FROM_OPER, ");
                sprintf(sql + strlen(sql), "A.REQ_CMF_1, ");
                sprintf(sql + strlen(sql), "A.TO_OPER, ");
                sprintf(sql + strlen(sql), "A.REQ_CMF_2, ");
                sprintf(sql + strlen(sql), "A.REQ_CMF_4 ");
                sprintf(sql + strlen(sql), "FROM ( ");
                sprintf(sql + strlen(sql), " SELECT A.FACTORY  ");
				sprintf(sql + strlen(sql), ",A.REQ_NO ");
				sprintf(sql + strlen(sql), ",A.REQ_TYPE  ");
				sprintf(sql + strlen(sql), ",MAX(A.REQ_DATE) AS REQ_DATE "); 
				sprintf(sql + strlen(sql), ",MAX(A.REQ_TIME) AS REQ_TIME ");
				sprintf(sql + strlen(sql), ",MAX(A.REQ_STATUS) AS REQ_STATUS  ");
				sprintf(sql + strlen(sql), ",MAX(A.REQ_USER_ID) AS REQ_USER_ID ");
				sprintf(sql + strlen(sql), ",MAX(NVL(D.USER_DESC, ' ')) AS REQ_CMF_3 ");
				sprintf(sql + strlen(sql), ",A.FROM_OPER ");
				sprintf(sql + strlen(sql), ",B.OPER_DESC AS REQ_CMF_1 ");
				sprintf(sql + strlen(sql), ",A.TO_OPER  ");
				sprintf(sql + strlen(sql), ",C.OPER_DESC AS REQ_CMF_2 ");
				sprintf(sql + strlen(sql), ",'1' AS REQ_CMF_4 ");
				sprintf(sql + strlen(sql), " FROM CWIPREQMST A ");
				sprintf(sql + strlen(sql), "INNER JOIN MWIPOPRDEF B ON A.FACTORY = B.FACTORY AND A.FROM_OPER = B.OPER  ");
				sprintf(sql + strlen(sql), "INNER JOIN MWIPOPRDEF C ON A.FACTORY = C.FACTORY AND A.TO_OPER = C.OPER    ");
				sprintf(sql + strlen(sql), "INNER JOIN CWIPREQDTL E ON A.FACTORY = E.FACTORY AND A.REQ_NO = E.REQ_NO ");
				sprintf(sql + strlen(sql), "INNER JOIN MWIPLOTSTS F ON E.FACTORY = F.FACTORY AND E.LOT_ID = F.LOT_ID ");				
				sprintf(sql + strlen(sql), "LEFT OUTER JOIN MSECUSRDEF D ON A.FACTORY = D.FACTORY AND A.REQ_USER_ID = D.USER_ID ");
                if(ISSPACE(CWIPREQMST->REQ_CMF_3, sizeof(CWIPREQMST->REQ_CMF_3)) == DB_FALSE)
				{
                    make_valid_quote(ts, CWIPREQMST_N.REQ_CMF_3); /*LOT ID*/
                    sprintf(sql + strlen(sql), "AND F.LOT_ID  = '%s' ", ts);
                }
				make_valid_quote(ts, CWIPREQMST_N.FACTORY);
				sprintf(sql + strlen(sql), " WHERE A.FACTORY = '%s' ", ts);
                sprintf(sql + strlen(sql), " AND A.REQ_TYPE IN ('M', 'R', 'W') ");
                sprintf(sql + strlen(sql), " AND RTRIM(A.REQ_STATUS) = 'REQUEST' ");    
                
				if(ISSPACE(CWIPREQMST->FROM_OPER, sizeof(CWIPREQMST->FROM_OPER)) == DB_FALSE)
				{
					make_valid_quote(ts, CWIPREQMST_N.FROM_OPER);
					sprintf(sql + strlen(sql), " AND A.FROM_OPER = '%s' ", ts); 
				}

				if(ISSPACE(CWIPREQMST->TO_OPER, sizeof(CWIPREQMST->TO_OPER)) == DB_FALSE)
				{
					make_valid_quote(ts, CWIPREQMST_N.TO_OPER);
					sprintf(sql + strlen(sql), " AND A.TO_OPER = '%s' ", ts); 
				}

                if(ISSPACE(CWIPREQMST->REQ_CMF_4, sizeof(CWIPREQMST->REQ_CMF_4)) == DB_FALSE)
				{
                    make_valid_quote(ts, CWIPREQMST_N.REQ_CMF_4);
                    sprintf(sql + strlen(sql), " AND A.REQ_DATE = '%s' ", ts);
                }

                if(ISSPACE(CWIPREQMST->REQ_CMF_1, sizeof(CWIPREQMST->REQ_CMF_1)) == DB_FALSE)
				{
					make_valid_quote(ts, CWIPREQMST_N.REQ_CMF_1); /*GRADE*/
					sprintf(sql + strlen(sql), " AND EXISTS (SELECT 'X' FROM CWIPTRPHIS T ");
                    sprintf(sql + strlen(sql), " WHERE F.LOT_ID = T.LOT_ID ");
                    sprintf(sql + strlen(sql), " AND T.CMF_4 = '%s' ", ts);
                    sprintf(sql + strlen(sql), " UNION ");
                    sprintf(sql + strlen(sql), " SELECT 'X' FROM CEDCLOTRLT T ");
                    sprintf(sql + strlen(sql), " WHERE A.FACTORY = T.FACTORY ");
                    sprintf(sql + strlen(sql), " AND F.LOT_ID = T.LOT_ID ");
                    sprintf(sql + strlen(sql), " AND T.INS_TYPE = 'FC' ");
                    sprintf(sql + strlen(sql), " AND GRADE = '%s' ) ", ts);
				}
                if(ISSPACE(CWIPREQMST->REQ_CMF_2, sizeof(CWIPREQMST->REQ_CMF_2)) == DB_FALSE)
				{
					make_valid_quote(ts, CWIPREQMST_N.REQ_CMF_2); /*POWER*/
                    sprintf(sql + strlen(sql), " AND EXISTS (SELECT 'X' FROM CWIPTRPHIS T ");
                    sprintf(sql + strlen(sql), " WHERE F.LOT_ID = T.LOT_ID ");
                    sprintf(sql + strlen(sql), " AND T.CMF_5 = '%s' ", ts);
                    sprintf(sql + strlen(sql), " UNION ");
                    sprintf(sql + strlen(sql), " SELECT 'X' FROM CEDCLOTRLT T ");
                    sprintf(sql + strlen(sql), " WHERE A.FACTORY = T.FACTORY ");
                    sprintf(sql + strlen(sql), " AND F.LOT_ID = T.LOT_ID ");
                    sprintf(sql + strlen(sql), " AND T.INS_TYPE = 'FC' ");
                    sprintf(sql + strlen(sql), " AND POWER = '%s' ) ", ts);
				}  
				sprintf(sql + strlen(sql), " GROUP BY A.FACTORY ,A.REQ_NO ,A.REQ_TYPE, A.FROM_OPER , B.OPER_DESC , A.TO_OPER , C.OPER_DESC  ");
                sprintf(sql + strlen(sql), " ) A ");
                sprintf(sql + strlen(sql), " WHERE 1 = 1 ");
				sprintf(sql + strlen(sql), " ORDER BY A.FACTORY , A.REQ_NO  ");
				EXEC SQL PREPARE S FROM :sql;
				EXEC SQL DECLARE CDB_CWIPREQMST_CUR_3 CURSOR FOR S; 
				EXEC SQL OPEN CDB_CWIPREQMST_CUR_3;  
				/*
				LOG_head("DB");
				LOG_add("len", 0, strlen(sql));
				LOG_add("sql", 4, strlen(sql), sql);
				COM_log_write('I', 'S' , 'S');
				*/
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwipreqmst", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_cwipreqmst(int sel_type, struct CWIPREQMST_TAG *CWIPREQMST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPREQMST_N_TAG CWIPREQMST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CWIPREQMST_CUR_1 INTO
                :CWIPREQMST_N.FACTORY,
                :CWIPREQMST_N.REQ_NO,
                :CWIPREQMST_N.REQ_TYPE,
                :CWIPREQMST_N.REQ_DATE,
                :CWIPREQMST_N.REQ_TIME,
                :CWIPREQMST_N.REQ_STATUS,
                :CWIPREQMST_N.FROM_OPER,
                :CWIPREQMST_N.TO_OPER,
                :CWIPREQMST_N.REQ_USER_ID,
                :CWIPREQMST_N.REQ_CMF_1,
                :CWIPREQMST_N.REQ_CMF_2,
                :CWIPREQMST_N.REQ_CMF_3,
                :CWIPREQMST_N.REQ_CMF_4,
                :CWIPREQMST_N.REQ_CMF_5,
                :CWIPREQMST_N.REQ_CMF_6,
                :CWIPREQMST_N.REQ_CMF_7,
                :CWIPREQMST_N.REQ_CMF_8,
                :CWIPREQMST_N.REQ_CMF_9,
                :CWIPREQMST_N.REQ_CMF_10,
                :CWIPREQMST_N.CREATE_USER_ID,
                :CWIPREQMST_N.CREATE_TIME,
                :CWIPREQMST_N.UPDATE_USER_ID,
                :CWIPREQMST_N.UPDATE_TIME;
            break;

		case 2:
            EXEC SQL FETCH CDB_CWIPREQMST_CUR_2 INTO
                :CWIPREQMST_N.REQ_NO,    
                :CWIPREQMST_N.REQ_DATE,  
                :CWIPREQMST_N.REQ_TIME,  
                :CWIPREQMST_N.REQ_STATUS,
                :CWIPREQMST_N.FROM_OPER, 
                :CWIPREQMST_N.TO_OPER,   
                :CWIPREQMST_N.REQ_USER_ID,
                :CWIPREQMST_N.REQ_CMF_1, 
                :CWIPREQMST_N.REQ_CMF_2, 
                :CWIPREQMST_N.REQ_CMF_3, 
                :CWIPREQMST_N.REQ_CMF_4;  
            break;

        case 3:
            EXEC SQL FETCH CDB_CWIPREQMST_CUR_3 INTO
                :CWIPREQMST_N.FACTORY,
                :CWIPREQMST_N.REQ_NO,
				:CWIPREQMST_N.REQ_TYPE,
                :CWIPREQMST_N.REQ_DATE,
                :CWIPREQMST_N.REQ_TIME,
                :CWIPREQMST_N.REQ_STATUS,
				:CWIPREQMST_N.REQ_USER_ID,
				:CWIPREQMST_N.REQ_CMF_3,
                :CWIPREQMST_N.FROM_OPER,
				:CWIPREQMST_N.REQ_CMF_1,
                :CWIPREQMST_N.TO_OPER,
                :CWIPREQMST_N.REQ_CMF_2,
				:CWIPREQMST_N.REQ_CMF_4;
            break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cwipreqmst(&CWIPREQMST_N, CWIPREQMST);
    }

    DB_stop_query_timer("CDB_fetch_cwipreqmst", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cwipreqmst(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CWIPREQMST_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CWIPREQMST_CUR_2;
            break;

        case 3:
            EXEC SQL CLOSE CDB_CWIPREQMST_CUR_3;
            break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwipreqmst", sel_type);
}


/* Initialize Function */
void CDB_init_cwipreqmst(struct CWIPREQMST_TAG *CWIPREQMST)
{
    /* memset by Space */
    memset(CWIPREQMST, ' ', sizeof(struct CWIPREQMST_TAG));
    
}


/* Add Null Function */
void CDB_add_null_cwipreqmst(struct CWIPREQMST_N_TAG *CWIPREQMST_N, struct CWIPREQMST_TAG *CWIPREQMST)
{
    /* memset by NULL */
    memset(CWIPREQMST_N, '\0', sizeof(struct CWIPREQMST_N_TAG));
    
    MEMCPY_AN(CWIPREQMST_N->FACTORY, CWIPREQMST->FACTORY, sizeof(CWIPREQMST->FACTORY));
    MEMCPY_AN(CWIPREQMST_N->REQ_NO, CWIPREQMST->REQ_NO, sizeof(CWIPREQMST->REQ_NO));
    MEMCPY_AN(CWIPREQMST_N->REQ_TYPE, CWIPREQMST->REQ_TYPE, sizeof(CWIPREQMST->REQ_TYPE));
    MEMCPY_AN(CWIPREQMST_N->REQ_DATE, CWIPREQMST->REQ_DATE, sizeof(CWIPREQMST->REQ_DATE));
    MEMCPY_AN(CWIPREQMST_N->REQ_TIME, CWIPREQMST->REQ_TIME, sizeof(CWIPREQMST->REQ_TIME));
    MEMCPY_AN(CWIPREQMST_N->REQ_STATUS, CWIPREQMST->REQ_STATUS, sizeof(CWIPREQMST->REQ_STATUS));
    MEMCPY_AN(CWIPREQMST_N->FROM_OPER, CWIPREQMST->FROM_OPER, sizeof(CWIPREQMST->FROM_OPER));
    MEMCPY_AN(CWIPREQMST_N->TO_OPER, CWIPREQMST->TO_OPER, sizeof(CWIPREQMST->TO_OPER));
    MEMCPY_AN(CWIPREQMST_N->REQ_USER_ID, CWIPREQMST->REQ_USER_ID, sizeof(CWIPREQMST->REQ_USER_ID));
    MEMCPY_AN(CWIPREQMST_N->REQ_CMF_1, CWIPREQMST->REQ_CMF_1, sizeof(CWIPREQMST->REQ_CMF_1));
    MEMCPY_AN(CWIPREQMST_N->REQ_CMF_2, CWIPREQMST->REQ_CMF_2, sizeof(CWIPREQMST->REQ_CMF_2));
    MEMCPY_AN(CWIPREQMST_N->REQ_CMF_3, CWIPREQMST->REQ_CMF_3, sizeof(CWIPREQMST->REQ_CMF_3));
    MEMCPY_AN(CWIPREQMST_N->REQ_CMF_4, CWIPREQMST->REQ_CMF_4, sizeof(CWIPREQMST->REQ_CMF_4));
    MEMCPY_AN(CWIPREQMST_N->REQ_CMF_5, CWIPREQMST->REQ_CMF_5, sizeof(CWIPREQMST->REQ_CMF_5));
    MEMCPY_AN(CWIPREQMST_N->REQ_CMF_6, CWIPREQMST->REQ_CMF_6, sizeof(CWIPREQMST->REQ_CMF_6));
    MEMCPY_AN(CWIPREQMST_N->REQ_CMF_7, CWIPREQMST->REQ_CMF_7, sizeof(CWIPREQMST->REQ_CMF_7));
    MEMCPY_AN(CWIPREQMST_N->REQ_CMF_8, CWIPREQMST->REQ_CMF_8, sizeof(CWIPREQMST->REQ_CMF_8));
    MEMCPY_AN(CWIPREQMST_N->REQ_CMF_9, CWIPREQMST->REQ_CMF_9, sizeof(CWIPREQMST->REQ_CMF_9));
    MEMCPY_AN(CWIPREQMST_N->REQ_CMF_10, CWIPREQMST->REQ_CMF_10, sizeof(CWIPREQMST->REQ_CMF_10));
    MEMCPY_AN(CWIPREQMST_N->CREATE_USER_ID, CWIPREQMST->CREATE_USER_ID, sizeof(CWIPREQMST->CREATE_USER_ID));
    MEMCPY_AN(CWIPREQMST_N->CREATE_TIME, CWIPREQMST->CREATE_TIME, sizeof(CWIPREQMST->CREATE_TIME));
    MEMCPY_AN(CWIPREQMST_N->UPDATE_USER_ID, CWIPREQMST->UPDATE_USER_ID, sizeof(CWIPREQMST->UPDATE_USER_ID));
    MEMCPY_AN(CWIPREQMST_N->UPDATE_TIME, CWIPREQMST->UPDATE_TIME, sizeof(CWIPREQMST->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_cwipreqmst(struct CWIPREQMST_N_TAG *CWIPREQMST_N, struct CWIPREQMST_TAG *CWIPREQMST)
{
    MEMCPY_DN(CWIPREQMST->FACTORY, CWIPREQMST_N->FACTORY, sizeof(CWIPREQMST->FACTORY));
    MEMCPY_DN(CWIPREQMST->REQ_NO, CWIPREQMST_N->REQ_NO, sizeof(CWIPREQMST->REQ_NO));
    MEMCPY_DN(CWIPREQMST->REQ_TYPE, CWIPREQMST_N->REQ_TYPE, sizeof(CWIPREQMST->REQ_TYPE));
    MEMCPY_DN(CWIPREQMST->REQ_DATE, CWIPREQMST_N->REQ_DATE, sizeof(CWIPREQMST->REQ_DATE));
    MEMCPY_DN(CWIPREQMST->REQ_TIME, CWIPREQMST_N->REQ_TIME, sizeof(CWIPREQMST->REQ_TIME));
    MEMCPY_DN(CWIPREQMST->REQ_STATUS, CWIPREQMST_N->REQ_STATUS, sizeof(CWIPREQMST->REQ_STATUS));
    MEMCPY_DN(CWIPREQMST->FROM_OPER, CWIPREQMST_N->FROM_OPER, sizeof(CWIPREQMST->FROM_OPER));
    MEMCPY_DN(CWIPREQMST->TO_OPER, CWIPREQMST_N->TO_OPER, sizeof(CWIPREQMST->TO_OPER));
    MEMCPY_DN(CWIPREQMST->REQ_USER_ID, CWIPREQMST_N->REQ_USER_ID, sizeof(CWIPREQMST->REQ_USER_ID));
    MEMCPY_DN(CWIPREQMST->REQ_CMF_1, CWIPREQMST_N->REQ_CMF_1, sizeof(CWIPREQMST->REQ_CMF_1));
    MEMCPY_DN(CWIPREQMST->REQ_CMF_2, CWIPREQMST_N->REQ_CMF_2, sizeof(CWIPREQMST->REQ_CMF_2));
    MEMCPY_DN(CWIPREQMST->REQ_CMF_3, CWIPREQMST_N->REQ_CMF_3, sizeof(CWIPREQMST->REQ_CMF_3));
    MEMCPY_DN(CWIPREQMST->REQ_CMF_4, CWIPREQMST_N->REQ_CMF_4, sizeof(CWIPREQMST->REQ_CMF_4));
    MEMCPY_DN(CWIPREQMST->REQ_CMF_5, CWIPREQMST_N->REQ_CMF_5, sizeof(CWIPREQMST->REQ_CMF_5));
    MEMCPY_DN(CWIPREQMST->REQ_CMF_6, CWIPREQMST_N->REQ_CMF_6, sizeof(CWIPREQMST->REQ_CMF_6));
    MEMCPY_DN(CWIPREQMST->REQ_CMF_7, CWIPREQMST_N->REQ_CMF_7, sizeof(CWIPREQMST->REQ_CMF_7));
    MEMCPY_DN(CWIPREQMST->REQ_CMF_8, CWIPREQMST_N->REQ_CMF_8, sizeof(CWIPREQMST->REQ_CMF_8));
    MEMCPY_DN(CWIPREQMST->REQ_CMF_9, CWIPREQMST_N->REQ_CMF_9, sizeof(CWIPREQMST->REQ_CMF_9));
    MEMCPY_DN(CWIPREQMST->REQ_CMF_10, CWIPREQMST_N->REQ_CMF_10, sizeof(CWIPREQMST->REQ_CMF_10));
    MEMCPY_DN(CWIPREQMST->CREATE_USER_ID, CWIPREQMST_N->CREATE_USER_ID, sizeof(CWIPREQMST->CREATE_USER_ID));
    MEMCPY_DN(CWIPREQMST->CREATE_TIME, CWIPREQMST_N->CREATE_TIME, sizeof(CWIPREQMST->CREATE_TIME));
    MEMCPY_DN(CWIPREQMST->UPDATE_USER_ID, CWIPREQMST_N->UPDATE_USER_ID, sizeof(CWIPREQMST->UPDATE_USER_ID));
    MEMCPY_DN(CWIPREQMST->UPDATE_TIME, CWIPREQMST_N->UPDATE_TIME, sizeof(CWIPREQMST->UPDATE_TIME));
}
