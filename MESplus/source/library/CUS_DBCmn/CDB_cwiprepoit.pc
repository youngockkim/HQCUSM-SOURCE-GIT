/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwiprepoit(int sel_type, struct CWIPREPOIT_TAG *CWIPREPOIT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPREPOIT_N_TAG CWIPREPOIT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwiprepoit(&CWIPREPOIT_N, CWIPREPOIT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPREPOIT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    WORKER,
                    LOCATION,
                    START_TIME,
                    END_TIME,
                    STATUS,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM CWIPREPOIT
                ORDER BY FACTORY ASC,
                    WORKER ASC,
                    LOCATION ASC,
                    START_TIME ASC,
                    END_TIME ASC;
            EXEC SQL OPEN CDB_CWIPREPOIT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwiprepoit", sel_type);
}


