            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_cpoplblhis", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cpoplblhis(int sel_type, struct CPOPLBLHIS_TAG *CPOPLBLHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CPOPLBLHIS_N_TAG CPOPLBLHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cpoplblhis(&CPOPLBLHIS_N, CPOPLBLHIS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CPOPLBLHIS_CUR_1 CURSOR FOR
                SELECT 
                    LABEL_ID,
                    PRINTED_ID,
                    TRAN_TIME,
                    NVL(PRINT_QTY, '0'),
                    NVL(ORDER_ID, ' '),
                    NVL(OPERATION, ' '),
                    NVL(MAT_ID, ' '),
                    NVL(FACTORY, ' '),
                    NVL(PRINTED_TYPE, ' '),
                    NVL(REPRINT_FLAG, ' '),
                    NVL(DATA_1, ' '),
                    NVL(DATA_2, ' '),
                    NVL(DATA_3, ' '),
                    NVL(DATA_4, ' '),
                    NVL(DATA_5, ' '),
                    NVL(DATA_6, ' '),
                    NVL(DATA_7, ' '),
                    NVL(DATA_8, ' '),
                    NVL(DATA_9, '0'),
                    NVL(DATA_10, ' '),
                    NVL(DATA_11, ' '),
                    NVL(DATA_12, ' '),
                    NVL(DATA_13, ' '),
                    NVL(DATA_14, ' '),
                    NVL(DATA_15, ' '),
                    NVL(DATA_16, ' '),
                    NVL(DATA_17, ' '),
                    NVL(DATA_18, ' '),
                    NVL(DATA_19, ' '),
                    NVL(DATA_20, ' '),
                    NVL(TRAN_USER_ID, ' '),
                    NVL(UPDATE_USER_ID, ' '),
                    NVL(UPDATE_TIME, ' ')
                FROM CPOPLBLHIS
                ORDER BY LABEL_ID ASC,
                    PRINTED_ID ASC,
                    TRAN_TIME ASC;
            EXEC SQL OPEN CDB_CPOPLBLHIS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cpoplblhis", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_cpoplblhis(int sel_type, struct CPOPLBLHIS_TAG *CPOPLBLHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CPOPLBLHIS_N_TAG CPOPLBLHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CPOPLBLHIS_CUR_1 INTO
                :CPOPLBLHIS_N.LABEL_ID,
                :CPOPLBLHIS_N.PRINTED_ID,
                :CPOPLBLHIS_N.TRAN_TIME,
                :CPOPLBLHIS_N.PRINT_QTY,
                :CPOPLBLHIS_N.ORDER_ID,
                :CPOPLBLHIS_N.OPERATION,
                :CPOPLBLHIS_N.MAT_ID,
                :CPOPLBLHIS_N.FACTORY,
                :CPOPLBLHIS_N.PRINTED_TYPE,
                :CPOPLBLHIS_N.REPRINT_FLAG,
                :CPOPLBLHIS_N.DATA_1,
                :CPOPLBLHIS_N.DATA_2,
                :CPOPLBLHIS_N.DATA_3,
                :CPOPLBLHIS_N.DATA_4,
                :CPOPLBLHIS_N.DATA_5,
                :CPOPLBLHIS_N.DATA_6,
                :CPOPLBLHIS_N.DATA_7,
                :CPOPLBLHIS_N.DATA_8,
                :CPOPLBLHIS_N.DATA_9,
                :CPOPLBLHIS_N.DATA_10,
                :CPOPLBLHIS_N.DATA_11,
                :CPOPLBLHIS_N.DATA_12,
                :CPOPLBLHIS_N.DATA_13,
                :CPOPLBLHIS_N.DATA_14,
                :CPOPLBLHIS_N.DATA_15,
                :CPOPLBLHIS_N.DATA_16,
                :CPOPLBLHIS_N.DATA_17,
                :CPOPLBLHIS_N.DATA_18,
                :CPOPLBLHIS_N.DATA_19,
                :CPOPLBLHIS_N.DATA_20,
                :CPOPLBLHIS_N.TRAN_USER_ID,
                :CPOPLBLHIS_N.UPDATE_USER_ID,
                :CPOPLBLHIS_N.UPDATE_TIME;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cpoplblhis(&CPOPLBLHIS_N, CPOPLBLHIS);
    }

    DB_stop_query_timer("CDB_fetch_cpoplblhis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cpoplblhis(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CPOPLBLHIS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cpoplblhis", sel_type);
}


/* Initialize Function */
void CDB_init_cpoplblhis(struct CPOPLBLHIS_TAG *CPOPLBLHIS)
{
    /* memset by Space */
    memset(CPOPLBLHIS, ' ', sizeof(struct CPOPLBLHIS_TAG));
    
    CPOPLBLHIS->PRINT_QTY = 0;
    CPOPLBLHIS->DATA_9 = 0;
}


/* Add Null Function */
void CDB_add_null_cpoplblhis(struct CPOPLBLHIS_N_TAG *CPOPLBLHIS_N, struct CPOPLBLHIS_TAG *CPOPLBLHIS)
{
    /* memset by NULL */
    memset(CPOPLBLHIS_N, '\0', sizeof(struct CPOPLBLHIS_N_TAG));
    
    MEMCPY_AN(CPOPLBLHIS_N->LABEL_ID, CPOPLBLHIS->LABEL_ID, sizeof(CPOPLBLHIS->LABEL_ID));
    MEMCPY_AN(CPOPLBLHIS_N->PRINTED_ID, CPOPLBLHIS->PRINTED_ID, sizeof(CPOPLBLHIS->PRINTED_ID));
