	case 9:
            EXEC SQL SELECT 
                    ' '  FACTORY
                    , :RSUMHORLOS_N.WORK_DATE WORK_DATE
                    ,' ' WORK_SHIFT
                    ,' ' LINE_ID
                    ,' ' RES_ID
                    ,' ' MAT_ID
                    ,' ' OPER
                    ,' ' CAUSE_OPER
                    ,' ' CAUSE_RES_ID
                    ,' ' ORDER_ID
                    ,' ' FQC_GRADE
                    ,' ' FQC_POWER
                    ,' ' LOSS_GROUP
                    ,' ' LOSS_CODE
                    ,NVL(SUM(LOSS_QTY), 0) LOSS_QTY
					,NVL(SUM(TIME01_LOSS_QTY), 0) TIME01_LOSS_QTY
					,NVL(SUM(TIME02_LOSS_QTY), 0) TIME02_LOSS_QTY
					,NVL(SUM(TIME03_LOSS_QTY), 0) TIME03_LOSS_QTY
					,NVL(SUM(TIME04_LOSS_QTY), 0)TIME04_LOSS_QTY
					,NVL(SUM(TIME05_LOSS_QTY), 0) TIME05_LOSS_QTY
					,NVL(SUM(TIME06_LOSS_QTY), 0) TIME06_LOSS_QTY
					,NVL(SUM(TIME07_LOSS_QTY), 0) TIME07_LOSS_QTY
					,NVL(SUM(TIME08_LOSS_QTY), 0) TIME08_LOSS_QTY
					,NVL(SUM(TIME09_LOSS_QTY), 0) TIME09_LOSS_QTY
					,NVL(SUM(TIME10_LOSS_QTY), 0) TIME10_LOSS_QTY
					,NVL(SUM(TIME11_LOSS_QTY), 0) TIME11_LOSS_QTY
					,NVL(SUM(TIME12_LOSS_QTY), 0) TIME12_LOSS_QTY
					,NVL(SUM(TIME13_LOSS_QTY), 0) TIME13_LOSS_QTY
					,NVL(SUM(TIME14_LOSS_QTY), 0) TIME14_LOSS_QTY
					,NVL(SUM(TIME15_LOSS_QTY), 0) TIME15_LOSS_QTY
					,NVL(SUM(TIME16_LOSS_QTY), 0) TIME16_LOSS_QTY
					,NVL(SUM(TIME17_LOSS_QTY), 0) TIME17_LOSS_QTY
					,NVL(SUM(TIME18_LOSS_QTY), 0) TIME18_LOSS_QTY
					,NVL(SUM(TIME19_LOSS_QTY), 0) TIME19_LOSS_QTY
					,NVL(SUM(TIME20_LOSS_QTY), 0) TIME20_LOSS_QTY
					,NVL(SUM(TIME21_LOSS_QTY), 0) TIME21_LOSS_QTY
					,NVL(SUM(TIME22_LOSS_QTY), 0) TIME22_LOSS_QTY
					,NVL(SUM(TIME23_LOSS_QTY), 0) TIME23_LOSS_QTY
					,NVL(SUM(TIME24_LOSS_QTY), 0) TIME24_LOSS_QTY
                    ,0 ETC1_QTY
                    ,0 ETC2_QTY
                    ,0 ETC3_QTY
                    ,0 ETC4_QTY
                    ,0 ETC5_QTY
                    ,' ' CMF_1
                    ,' ' CMF_2
                    ,' ' CMF_3
                    ,' ' CMF_4
                    ,' ' CMF_5
                INTO 
                    :RSUMHORLOS_N.FACTORY,
                    :RSUMHORLOS_N.WORK_DATE,
                    :RSUMHORLOS_N.WORK_SHIFT,
                    :RSUMHORLOS_N.LINE_ID,
                    :RSUMHORLOS_N.RES_ID,
                    :RSUMHORLOS_N.MAT_ID,
                    :RSUMHORLOS_N.OPER,
                    :RSUMHORLOS_N.CAUSE_OPER,
                    :RSUMHORLOS_N.CAUSE_RES_ID,
                    :RSUMHORLOS_N.ORDER_ID,
                    :RSUMHORLOS_N.FQC_GRADE,
                    :RSUMHORLOS_N.FQC_POWER,
                    :RSUMHORLOS_N.LOSS_GROUP,
                    :RSUMHORLOS_N.LOSS_CODE,
                    :RSUMHORLOS_N.LOSS_QTY,
                    :RSUMHORLOS_N.TIME01_LOSS_QTY,
                    :RSUMHORLOS_N.TIME02_LOSS_QTY,
                    :RSUMHORLOS_N.TIME03_LOSS_QTY,
                    :RSUMHORLOS_N.TIME04_LOSS_QTY,
                    :RSUMHORLOS_N.TIME05_LOSS_QTY,
                    :RSUMHORLOS_N.TIME06_LOSS_QTY,
                    :RSUMHORLOS_N.TIME07_LOSS_QTY,
                    :RSUMHORLOS_N.TIME08_LOSS_QTY,
                    :RSUMHORLOS_N.TIME09_LOSS_QTY,
                    :RSUMHORLOS_N.TIME10_LOSS_QTY,
                    :RSUMHORLOS_N.TIME11_LOSS_QTY,
                    :RSUMHORLOS_N.TIME12_LOSS_QTY,
                    :RSUMHORLOS_N.TIME13_LOSS_QTY,
                    :RSUMHORLOS_N.TIME14_LOSS_QTY,
                    :RSUMHORLOS_N.TIME15_LOSS_QTY,
                    :RSUMHORLOS_N.TIME16_LOSS_QTY,
                    :RSUMHORLOS_N.TIME17_LOSS_QTY,
                    :RSUMHORLOS_N.TIME18_LOSS_QTY,
                    :RSUMHORLOS_N.TIME19_LOSS_QTY,
                    :RSUMHORLOS_N.TIME20_LOSS_QTY,
                    :RSUMHORLOS_N.TIME21_LOSS_QTY,
                    :RSUMHORLOS_N.TIME22_LOSS_QTY,
                    :RSUMHORLOS_N.TIME23_LOSS_QTY,
                    :RSUMHORLOS_N.TIME24_LOSS_QTY,
                    :RSUMHORLOS_N.ETC1_QTY,
                    :RSUMHORLOS_N.ETC2_QTY,
                    :RSUMHORLOS_N.ETC3_QTY,
                    :RSUMHORLOS_N.ETC4_QTY,
                    :RSUMHORLOS_N.ETC5_QTY,
                    :RSUMHORLOS_N.CMF_1,
                    :RSUMHORLOS_N.CMF_2,
                    :RSUMHORLOS_N.CMF_3,
                    :RSUMHORLOS_N.CMF_4,
                    :RSUMHORLOS_N.CMF_5
                FROM RSUMHORLOS@LM1RPT
                WHERE WORK_DATE = :RSUMHORLOS_N.WORK_DATE
				AND OPER = 'M3070'
				AND RES_ID NOT IN ('US-E1-TB-13','US-E2-TB-13','US-E3-TB-13')
				AND LOSS_CODE IN ('E01', 'E02', 'E03', 'E04', 'E05', 'E06', 'E07', 'E08', 'E09', 'E10', 'E11', 'E12', 'E13', 'E14', 'E15', 'E16', 'E17', 'E18', 'E19', 'E30', 'E31', 'E32', 'E33', 'E99')
				AND LINE_ID LIKE  :RSUMHORLOS_N.LINE_ID || '%'
				;
			break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_rsumhorlos(&RSUMHORLOS_N, RSUMHORLOS);
    }

    DB_stop_query_timer("CDB_select_rsumhorlos", sel_type);
}


