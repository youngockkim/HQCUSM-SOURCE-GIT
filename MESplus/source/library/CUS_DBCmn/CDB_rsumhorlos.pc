    RSUMHORLOS_N->TIME18_LOSS_QTY = RSUMHORLOS->TIME18_LOSS_QTY;
    RSUMHORLOS_N->TIME19_LOSS_QTY = RSUMHORLOS->TIME19_LOSS_QTY;
    RSUMHORLOS_N->TIME20_LOSS_QTY = RSUMHORLOS->TIME20_LOSS_QTY;
    RSUMHORLOS_N->TIME21_LOSS_QTY = RSUMHORLOS->TIME21_LOSS_QTY;
    RSUMHORLOS_N->TIME22_LOSS_QTY = RSUMHORLOS->TIME22_LOSS_QTY;
    RSUMHORLOS_N->TIME23_LOSS_QTY = RSUMHORLOS->TIME23_LOSS_QTY;
    RSUMHORLOS_N->TIME24_LOSS_QTY = RSUMHORLOS->TIME24_LOSS_QTY;
    RSUMHORLOS_N->ETC1_QTY = RSUMHORLOS->ETC1_QTY;
    RSUMHORLOS_N->ETC2_QTY = RSUMHORLOS->ETC2_QTY;
    RSUMHORLOS_N->ETC3_QTY = RSUMHORLOS->ETC3_QTY;
    RSUMHORLOS_N->ETC4_QTY = RSUMHORLOS->ETC4_QTY;
    RSUMHORLOS_N->ETC5_QTY = RSUMHORLOS->ETC5_QTY;
    MEMCPY_AN(RSUMHORLOS_N->CMF_1, RSUMHORLOS->CMF_1, sizeof(RSUMHORLOS->CMF_1));
    MEMCPY_AN(RSUMHORLOS_N->CMF_2, RSUMHORLOS->CMF_2, sizeof(RSUMHORLOS->CMF_2));
    MEMCPY_AN(RSUMHORLOS_N->CMF_3, RSUMHORLOS->CMF_3, sizeof(RSUMHORLOS->CMF_3));
    MEMCPY_AN(RSUMHORLOS_N->CMF_4, RSUMHORLOS->CMF_4, sizeof(RSUMHORLOS->CMF_4));
    MEMCPY_AN(RSUMHORLOS_N->CMF_5, RSUMHORLOS->CMF_5, sizeof(RSUMHORLOS->CMF_5));
}


/* Del Null Function */
void CDB_del_null_rsumhorlos(struct RSUMHORLOS_N_TAG *RSUMHORLOS_N, struct RSUMHORLOS_TAG *RSUMHORLOS)
{
    MEMCPY_DN(RSUMHORLOS->FACTORY, RSUMHORLOS_N->FACTORY, sizeof(RSUMHORLOS->FACTORY));
    MEMCPY_DN(RSUMHORLOS->WORK_DATE, RSUMHORLOS_N->WORK_DATE, sizeof(RSUMHORLOS->WORK_DATE));
    MEMCPY_DN(RSUMHORLOS->WORK_SHIFT, RSUMHORLOS_N->WORK_SHIFT, sizeof(RSUMHORLOS->WORK_SHIFT));
    MEMCPY_DN(RSUMHORLOS->LINE_ID, RSUMHORLOS_N->LINE_ID, sizeof(RSUMHORLOS->LINE_ID));
    MEMCPY_DN(RSUMHORLOS->RES_ID, RSUMHORLOS_N->RES_ID, sizeof(RSUMHORLOS->RES_ID));
    MEMCPY_DN(RSUMHORLOS->MAT_ID, RSUMHORLOS_N->MAT_ID, sizeof(RSUMHORLOS->MAT_ID));
