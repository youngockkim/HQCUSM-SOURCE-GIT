/* SQL SELECT_SCALAR Function */
double CDB_select_rsumhorlos_scalar(int sel_type, struct RSUMHORLOS_TAG *RSUMHORLOS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMHORLOS_N_TAG RSUMHORLOS_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumhorlos(&RSUMHORLOS_N, RSUMHORLOS);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM RSUMHORLOS
                WHERE FACTORY = :RSUMHORLOS_N.FACTORY
                    AND WORK_DATE = :RSUMHORLOS_N.WORK_DATE
                    AND WORK_SHIFT = :RSUMHORLOS_N.WORK_SHIFT
                    AND LINE_ID = :RSUMHORLOS_N.LINE_ID
                    AND RES_ID = :RSUMHORLOS_N.RES_ID
                    AND MAT_ID = :RSUMHORLOS_N.MAT_ID
                    AND OPER = :RSUMHORLOS_N.OPER
                    AND CAUSE_OPER = :RSUMHORLOS_N.CAUSE_OPER
                    AND CAUSE_RES_ID = :RSUMHORLOS_N.CAUSE_RES_ID
                    AND ORDER_ID = :RSUMHORLOS_N.ORDER_ID
                    AND FQC_GRADE = :RSUMHORLOS_N.FQC_GRADE
                    AND FQC_POWER = :RSUMHORLOS_N.FQC_POWER
                    AND LOSS_GROUP = :RSUMHORLOS_N.LOSS_GROUP
                    AND LOSS_CODE = :RSUMHORLOS_N.LOSS_CODE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_rsumhorlos_scalar", sel_type);

    return d_value;
}


/* SQL DELETE Function */
void CDB_delete_rsumhorlos(int sel_type, struct RSUMHORLOS_TAG *RSUMHORLOS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMHORLOS_N_TAG RSUMHORLOS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumhorlos(&RSUMHORLOS_N, RSUMHORLOS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM RSUMHORLOS
                WHERE FACTORY = :RSUMHORLOS_N.FACTORY
                    AND WORK_DATE = :RSUMHORLOS_N.WORK_DATE
                    AND WORK_SHIFT = :RSUMHORLOS_N.WORK_SHIFT
                    AND LINE_ID = :RSUMHORLOS_N.LINE_ID
                    AND RES_ID = :RSUMHORLOS_N.RES_ID
                    AND MAT_ID = :RSUMHORLOS_N.MAT_ID
                    AND OPER = :RSUMHORLOS_N.OPER
                    AND CAUSE_OPER = :RSUMHORLOS_N.CAUSE_OPER
                    AND CAUSE_RES_ID = :RSUMHORLOS_N.CAUSE_RES_ID
                    AND ORDER_ID = :RSUMHORLOS_N.ORDER_ID
                    AND FQC_GRADE = :RSUMHORLOS_N.FQC_GRADE
                    AND FQC_POWER = :RSUMHORLOS_N.FQC_POWER
                    AND LOSS_GROUP = :RSUMHORLOS_N.LOSS_GROUP
                    AND LOSS_CODE = :RSUMHORLOS_N.LOSS_CODE;
            break;
		
		case 2:
            EXEC SQL DELETE FROM RSUMHORLOS
                WHERE WORK_DATE >= :RSUMHORLOS_N.CMF_1
                  AND WORK_DATE <= :RSUMHORLOS_N.CMF_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_delete_rsumhorlos", sel_type);
}


/* SQL INSERT Function */
void CDB_insert_rsumhorlos(struct RSUMHORLOS_TAG *RSUMHORLOS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMHORLOS_N_TAG RSUMHORLOS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumhorlos(&RSUMHORLOS_N, RSUMHORLOS);
    DB_error_code = 0;


    EXEC SQL INSERT INTO RSUMHORLOS( 
                    FACTORY, 
                    WORK_DATE, 
                    WORK_SHIFT, 
                    LINE_ID, 
                    RES_ID, 
                    MAT_ID, 
                    OPER, 
                    CAUSE_OPER, 
                    CAUSE_RES_ID, 
                    ORDER_ID, 
                    FQC_GRADE, 
                    FQC_POWER, 
                    LOSS_GROUP, 
                    LOSS_CODE, 
