                    :RSUMHORLOS_N.TIME23_LOSS_QTY,
                    :RSUMHORLOS_N.TIME24_LOSS_QTY,
                    :RSUMHORLOS_N.ETC1_QTY,
                    :RSUMHORLOS_N.ETC2_QTY,
                    :RSUMHORLOS_N.ETC3_QTY,
                    :RSUMHORLOS_N.ETC4_QTY,
                    :RSUMHORLOS_N.ETC5_QTY,
                    :RSUMHORLOS_N.CMF_1,
                    :RSUMHORLOS_N.CMF_2,
                    :RSUMHORLOS_N.CMF_3,
                    :RSUMHORLOS_N.CMF_4,
                    :RSUMHORLOS_N.CMF_5
         );

    DB_stop_query_timer("CDB_insert_rsumhorlos", 0);
}


/* SQL UPDATE Function */
void CDB_update_rsumhorlos(int sel_type, struct RSUMHORLOS_TAG *RSUMHORLOS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMHORLOS_N_TAG RSUMHORLOS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumhorlos(&RSUMHORLOS_N, RSUMHORLOS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE RSUMHORLOS SET
                    LOSS_QTY = :RSUMHORLOS_N.LOSS_QTY,
                    TIME01_LOSS_QTY = :RSUMHORLOS_N.TIME01_LOSS_QTY,
                    TIME02_LOSS_QTY = :RSUMHORLOS_N.TIME02_LOSS_QTY,
                    TIME03_LOSS_QTY = :RSUMHORLOS_N.TIME03_LOSS_QTY,
                    TIME04_LOSS_QTY = :RSUMHORLOS_N.TIME04_LOSS_QTY,
                    TIME05_LOSS_QTY = :RSUMHORLOS_N.TIME05_LOSS_QTY,
                    TIME06_LOSS_QTY = :RSUMHORLOS_N.TIME06_LOSS_QTY,
                    TIME07_LOSS_QTY = :RSUMHORLOS_N.TIME07_LOSS_QTY,
                    TIME08_LOSS_QTY = :RSUMHORLOS_N.TIME08_LOSS_QTY,
                    TIME09_LOSS_QTY = :RSUMHORLOS_N.TIME09_LOSS_QTY,
                    TIME10_LOSS_QTY = :RSUMHORLOS_N.TIME10_LOSS_QTY,
                    TIME11_LOSS_QTY = :RSUMHORLOS_N.TIME11_LOSS_QTY,
                    TIME12_LOSS_QTY = :RSUMHORLOS_N.TIME12_LOSS_QTY,
                    TIME13_LOSS_QTY = :RSUMHORLOS_N.TIME13_LOSS_QTY,
                    TIME14_LOSS_QTY = :RSUMHORLOS_N.TIME14_LOSS_QTY,
                    TIME15_LOSS_QTY = :RSUMHORLOS_N.TIME15_LOSS_QTY,
                    TIME16_LOSS_QTY = :RSUMHORLOS_N.TIME16_LOSS_QTY,
                    TIME17_LOSS_QTY = :RSUMHORLOS_N.TIME17_LOSS_QTY,
                    TIME18_LOSS_QTY = :RSUMHORLOS_N.TIME18_LOSS_QTY,
                    TIME19_LOSS_QTY = :RSUMHORLOS_N.TIME19_LOSS_QTY,
                    TIME20_LOSS_QTY = :RSUMHORLOS_N.TIME20_LOSS_QTY,
                    TIME21_LOSS_QTY = :RSUMHORLOS_N.TIME21_LOSS_QTY,
                    TIME22_LOSS_QTY = :RSUMHORLOS_N.TIME22_LOSS_QTY,
                    TIME23_LOSS_QTY = :RSUMHORLOS_N.TIME23_LOSS_QTY,
                    TIME24_LOSS_QTY = :RSUMHORLOS_N.TIME24_LOSS_QTY,
                    ETC1_QTY = :RSUMHORLOS_N.ETC1_QTY,
                    ETC2_QTY = :RSUMHORLOS_N.ETC2_QTY,
                    ETC3_QTY = :RSUMHORLOS_N.ETC3_QTY,
                    ETC4_QTY = :RSUMHORLOS_N.ETC4_QTY,
                    ETC5_QTY = :RSUMHORLOS_N.ETC5_QTY,
                    CMF_1 = :RSUMHORLOS_N.CMF_1,
                    CMF_2 = :RSUMHORLOS_N.CMF_2,
                    CMF_3 = :RSUMHORLOS_N.CMF_3,
                    CMF_4 = :RSUMHORLOS_N.CMF_4,
                    CMF_5 = :RSUMHORLOS_N.CMF_5
                WHERE FACTORY = :RSUMHORLOS_N.FACTORY
                    AND WORK_DATE = :RSUMHORLOS_N.WORK_DATE
                    AND WORK_SHIFT = :RSUMHORLOS_N.WORK_SHIFT
                    AND LINE_ID = :RSUMHORLOS_N.LINE_ID
                    AND RES_ID = :RSUMHORLOS_N.RES_ID
                    AND MAT_ID = :RSUMHORLOS_N.MAT_ID
                    AND OPER = :RSUMHORLOS_N.OPER
                    AND CAUSE_OPER = :RSUMHORLOS_N.CAUSE_OPER
                    AND CAUSE_RES_ID = :RSUMHORLOS_N.CAUSE_RES_ID
                    AND ORDER_ID = :RSUMHORLOS_N.ORDER_ID
                    AND FQC_GRADE = :RSUMHORLOS_N.FQC_GRADE
                    AND FQC_POWER = :RSUMHORLOS_N.FQC_POWER
                    AND LOSS_GROUP = :RSUMHORLOS_N.LOSS_GROUP
                    AND LOSS_CODE = :RSUMHORLOS_N.LOSS_CODE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_rsumhorlos", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_rsumhorlos(int sel_type, struct RSUMHORLOS_TAG *RSUMHORLOS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMHORLOS_N_TAG RSUMHORLOS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumhorlos(&RSUMHORLOS_N, RSUMHORLOS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_RSUMHORLOS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    WORK_DATE,
                    WORK_SHIFT,
                    LINE_ID,
                    RES_ID,
                    MAT_ID,
                    OPER,
                    CAUSE_OPER,
                    CAUSE_RES_ID,
                    ORDER_ID,
                    FQC_GRADE,
                    FQC_POWER,
                    LOSS_GROUP,
                    LOSS_CODE,
                    NVL(LOSS_QTY, '0'),
                    NVL(TIME01_LOSS_QTY, '0'),
                    NVL(TIME02_LOSS_QTY, '0'),
                    NVL(TIME03_LOSS_QTY, '0'),
                    NVL(TIME04_LOSS_QTY, '0'),
                    NVL(TIME05_LOSS_QTY, '0'),
                    NVL(TIME06_LOSS_QTY, '0'),
                    NVL(TIME07_LOSS_QTY, '0'),
                    NVL(TIME08_LOSS_QTY, '0'),
                    NVL(TIME09_LOSS_QTY, '0'),
                    NVL(TIME10_LOSS_QTY, '0'),
                    NVL(TIME11_LOSS_QTY, '0'),
                    NVL(TIME12_LOSS_QTY, '0'),
                    NVL(TIME13_LOSS_QTY, '0'),
                    NVL(TIME14_LOSS_QTY, '0'),
                    NVL(TIME15_LOSS_QTY, '0'),
                    NVL(TIME16_LOSS_QTY, '0'),
                    NVL(TIME17_LOSS_QTY, '0'),
                    NVL(TIME18_LOSS_QTY, '0'),
                    NVL(TIME19_LOSS_QTY, '0'),
                    NVL(TIME20_LOSS_QTY, '0'),
                    NVL(TIME21_LOSS_QTY, '0'),
                    NVL(TIME22_LOSS_QTY, '0'),
                    NVL(TIME23_LOSS_QTY, '0'),
                    NVL(TIME24_LOSS_QTY, '0'),
                    NVL(ETC1_QTY, '0'),
                    NVL(ETC2_QTY, '0'),
                    NVL(ETC3_QTY, '0'),
                    NVL(ETC4_QTY, '0'),
                    NVL(ETC5_QTY, '0'),
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' ')
                FROM RSUMHORLOS
                ORDER BY FACTORY ASC,
                    WORK_DATE ASC,
                    WORK_SHIFT ASC,
                    LINE_ID ASC,
                    RES_ID ASC,
                    MAT_ID ASC,
                    OPER ASC,
                    CAUSE_OPER ASC,
                    CAUSE_RES_ID ASC,
                    ORDER_ID ASC,
                    FQC_GRADE ASC,
                    FQC_POWER ASC,
                    LOSS_GROUP ASC,
                    LOSS_CODE ASC;
            EXEC SQL OPEN CDB_RSUMHORLOS_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE CDB_RSUMHORLOS_CUR_2 CURSOR FOR
                SELECT 
				     LOSS_CODE 
					,'Top ' || ROWNUM 
				    , LOSS_CODE || '(' || LOSS_QTY || ') ' 
					, CASE WHEN LENGTH(LOSS_DESC) > 29 THEN  SUBSTR(LOSS_DESC,0,29) ELSE LOSS_DESC END 
					,CASE WHEN LENGTH(LOSS_DESC) > 29 THEN  SUBSTR(LOSS_DESC,30,59) ELSE ' ' END 
					FROM (
					SELECT LINE_ID,OPER,WORK_DATE,WORK_TIME,LOSS_CODE,LOSS_QTY,LOSS_ORDER
					,LOSS_DESC
					FROM (
					SELECT 
					LINE_ID,OPER,WORK_DATE
					,TO_CHAR(SYSDATE-1/24,'HH24') WORK_TIME
					, LOSS_CODE, SUM(DECODE( TO_CHAR(SYSDATE-1/24,'HH24')
								,'06',TIME07_LOSS_QTY
								,'07',TIME08_LOSS_QTY
								,'08',TIME09_LOSS_QTY
								,'09',TIME10_LOSS_QTY
								,'10',TIME11_LOSS_QTY
								,'11',TIME12_LOSS_QTY
								,'12',TIME13_LOSS_QTY
								,'13',TIME14_LOSS_QTY
								,'14',TIME15_LOSS_QTY
								,'15',TIME16_LOSS_QTY
								,'16',TIME17_LOSS_QTY
								,'17',TIME18_LOSS_QTY
								,'18',TIME19_LOSS_QTY
								,'19',TIME20_LOSS_QTY
								,'20',TIME21_LOSS_QTY
								,'21',TIME22_LOSS_QTY
								,'22',TIME23_LOSS_QTY
								,'23',TIME24_LOSS_QTY
								,'00',TIME01_LOSS_QTY
								,'01',TIME02_LOSS_QTY
								,'02',TIME03_LOSS_QTY
								,'03',TIME04_LOSS_QTY
								,'04',TIME05_LOSS_QTY
								,'05',TIME06_LOSS_QTY
							   ,0)) LOSS_QTY
					FROM RSUMHORLOS
					WHERE FACTORY = :RSUMHORLOS_N.FACTORY
					AND LINE_ID = :RSUMHORLOS_N.LINE_ID
					AND OPER = :RSUMHORLOS_N.OPER
					AND WORK_DATE = TO_CHAR(SYSDATE-7/24,'YYYYMMDD')
					GROUP BY LINE_ID,OPER,WORK_DATE,TO_CHAR(SYSDATE-1/24,'HH24'),LOSS_CODE
					)D
					,(SELECT KEY_1,DATA_4 AS LOSS_DESC
					,TO_NUMBER(DATA_5) LOSS_ORDER 
					FROM MGCMTBLDAT WHERE FACTORY = 'USGAM1' AND TABLE_NAME = '@DEFECT' AND KEY_2 = 'M3110' 
					) G
					WHERE D.LOSS_CODE = G.KEY_1
					AND LOSS_QTY > 0
					ORDER BY LOSS_QTY DESC, LOSS_ORDER
					) WHERE ROWNUM  < 4;
            EXEC SQL OPEN CDB_RSUMHORLOS_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_rsumhorlos", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_rsumhorlos(int sel_type, struct RSUMHORLOS_TAG *RSUMHORLOS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMHORLOS_N_TAG RSUMHORLOS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_RSUMHORLOS_CUR_1 INTO
                :RSUMHORLOS_N.FACTORY,
                :RSUMHORLOS_N.WORK_DATE,
                :RSUMHORLOS_N.WORK_SHIFT,
                :RSUMHORLOS_N.LINE_ID,
                :RSUMHORLOS_N.RES_ID,
                :RSUMHORLOS_N.MAT_ID,
                :RSUMHORLOS_N.OPER,
                :RSUMHORLOS_N.CAUSE_OPER,
                :RSUMHORLOS_N.CAUSE_RES_ID,
                :RSUMHORLOS_N.ORDER_ID,
                :RSUMHORLOS_N.FQC_GRADE,
                :RSUMHORLOS_N.FQC_POWER,
                :RSUMHORLOS_N.LOSS_GROUP,
                :RSUMHORLOS_N.LOSS_CODE,
                :RSUMHORLOS_N.LOSS_QTY,
                :RSUMHORLOS_N.TIME01_LOSS_QTY,
                :RSUMHORLOS_N.TIME02_LOSS_QTY,
                :RSUMHORLOS_N.TIME03_LOSS_QTY,
                :RSUMHORLOS_N.TIME04_LOSS_QTY,
                :RSUMHORLOS_N.TIME05_LOSS_QTY,
                :RSUMHORLOS_N.TIME06_LOSS_QTY,
                :RSUMHORLOS_N.TIME07_LOSS_QTY,
                :RSUMHORLOS_N.TIME08_LOSS_QTY,
                :RSUMHORLOS_N.TIME09_LOSS_QTY,
                :RSUMHORLOS_N.TIME10_LOSS_QTY,
                :RSUMHORLOS_N.TIME11_LOSS_QTY,
                :RSUMHORLOS_N.TIME12_LOSS_QTY,
                :RSUMHORLOS_N.TIME13_LOSS_QTY,
                :RSUMHORLOS_N.TIME14_LOSS_QTY,
                :RSUMHORLOS_N.TIME15_LOSS_QTY,
                :RSUMHORLOS_N.TIME16_LOSS_QTY,
                :RSUMHORLOS_N.TIME17_LOSS_QTY,
                :RSUMHORLOS_N.TIME18_LOSS_QTY,
                :RSUMHORLOS_N.TIME19_LOSS_QTY,
                :RSUMHORLOS_N.TIME20_LOSS_QTY,
                :RSUMHORLOS_N.TIME21_LOSS_QTY,
                :RSUMHORLOS_N.TIME22_LOSS_QTY,
                :RSUMHORLOS_N.TIME23_LOSS_QTY,
                :RSUMHORLOS_N.TIME24_LOSS_QTY,
                :RSUMHORLOS_N.ETC1_QTY,
                :RSUMHORLOS_N.ETC2_QTY,
                :RSUMHORLOS_N.ETC3_QTY,
                :RSUMHORLOS_N.ETC4_QTY,
                :RSUMHORLOS_N.ETC5_QTY,
                :RSUMHORLOS_N.CMF_1,
                :RSUMHORLOS_N.CMF_2,
                :RSUMHORLOS_N.CMF_3,
                :RSUMHORLOS_N.CMF_4,
                :RSUMHORLOS_N.CMF_5;
            break;

        case 2:
            EXEC SQL FETCH CDB_RSUMHORLOS_CUR_2 INTO
                :RSUMHORLOS_N.CMF_1,
                :RSUMHORLOS_N.CMF_2,
                :RSUMHORLOS_N.CMF_3,
                :RSUMHORLOS_N.CMF_4,
                :RSUMHORLOS_N.CMF_5; 
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_rsumhorlos(&RSUMHORLOS_N, RSUMHORLOS);
    }

    DB_stop_query_timer("CDB_fetch_rsumhorlos", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_rsumhorlos(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_RSUMHORLOS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE CDB_RSUMHORLOS_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_rsumhorlos", sel_type);
}


/* Initialize Function */
void CDB_init_rsumhorlos(struct RSUMHORLOS_TAG *RSUMHORLOS)
{
    /* memset by Space */
    memset(RSUMHORLOS, ' ', sizeof(struct RSUMHORLOS_TAG));
    
    RSUMHORLOS->LOSS_QTY = 0;
    RSUMHORLOS->TIME01_LOSS_QTY = 0;
    RSUMHORLOS->TIME02_LOSS_QTY = 0;
    RSUMHORLOS->TIME03_LOSS_QTY = 0;
    RSUMHORLOS->TIME04_LOSS_QTY = 0;
    RSUMHORLOS->TIME05_LOSS_QTY = 0;
    RSUMHORLOS->TIME06_LOSS_QTY = 0;
    RSUMHORLOS->TIME07_LOSS_QTY = 0;
    RSUMHORLOS->TIME08_LOSS_QTY = 0;
    RSUMHORLOS->TIME09_LOSS_QTY = 0;
    RSUMHORLOS->TIME10_LOSS_QTY = 0;
    RSUMHORLOS->TIME11_LOSS_QTY = 0;
    RSUMHORLOS->TIME12_LOSS_QTY = 0;
    RSUMHORLOS->TIME13_LOSS_QTY = 0;
    RSUMHORLOS->TIME14_LOSS_QTY = 0;
    RSUMHORLOS->TIME15_LOSS_QTY = 0;
    RSUMHORLOS->TIME16_LOSS_QTY = 0;
    RSUMHORLOS->TIME17_LOSS_QTY = 0;
    RSUMHORLOS->TIME18_LOSS_QTY = 0;
    RSUMHORLOS->TIME19_LOSS_QTY = 0;
    RSUMHORLOS->TIME20_LOSS_QTY = 0;
    RSUMHORLOS->TIME21_LOSS_QTY = 0;
    RSUMHORLOS->TIME22_LOSS_QTY = 0;
    RSUMHORLOS->TIME23_LOSS_QTY = 0;
    RSUMHORLOS->TIME24_LOSS_QTY = 0;
    RSUMHORLOS->ETC1_QTY = 0;
    RSUMHORLOS->ETC2_QTY = 0;
    RSUMHORLOS->ETC3_QTY = 0;
    RSUMHORLOS->ETC4_QTY = 0;
    RSUMHORLOS->ETC5_QTY = 0;
}


/* Add Null Function */
void CDB_add_null_rsumhorlos(struct RSUMHORLOS_N_TAG *RSUMHORLOS_N, struct RSUMHORLOS_TAG *RSUMHORLOS)
{
    /* memset by NULL */
    memset(RSUMHORLOS_N, '\0', sizeof(struct RSUMHORLOS_N_TAG));
    
    MEMCPY_AN(RSUMHORLOS_N->FACTORY, RSUMHORLOS->FACTORY, sizeof(RSUMHORLOS->FACTORY));
    MEMCPY_AN(RSUMHORLOS_N->WORK_DATE, RSUMHORLOS->WORK_DATE, sizeof(RSUMHORLOS->WORK_DATE));
    MEMCPY_AN(RSUMHORLOS_N->WORK_SHIFT, RSUMHORLOS->WORK_SHIFT, sizeof(RSUMHORLOS->WORK_SHIFT));
    MEMCPY_AN(RSUMHORLOS_N->LINE_ID, RSUMHORLOS->LINE_ID, sizeof(RSUMHORLOS->LINE_ID));
    MEMCPY_AN(RSUMHORLOS_N->RES_ID, RSUMHORLOS->RES_ID, sizeof(RSUMHORLOS->RES_ID));
    MEMCPY_AN(RSUMHORLOS_N->MAT_ID, RSUMHORLOS->MAT_ID, sizeof(RSUMHORLOS->MAT_ID));
    MEMCPY_AN(RSUMHORLOS_N->OPER, RSUMHORLOS->OPER, sizeof(RSUMHORLOS->OPER));
    MEMCPY_AN(RSUMHORLOS_N->CAUSE_OPER, RSUMHORLOS->CAUSE_OPER, sizeof(RSUMHORLOS->CAUSE_OPER));
    MEMCPY_AN(RSUMHORLOS_N->CAUSE_RES_ID, RSUMHORLOS->CAUSE_RES_ID, sizeof(RSUMHORLOS->CAUSE_RES_ID));
    MEMCPY_AN(RSUMHORLOS_N->ORDER_ID, RSUMHORLOS->ORDER_ID, sizeof(RSUMHORLOS->ORDER_ID));
    MEMCPY_AN(RSUMHORLOS_N->FQC_GRADE, RSUMHORLOS->FQC_GRADE, sizeof(RSUMHORLOS->FQC_GRADE));
    MEMCPY_AN(RSUMHORLOS_N->FQC_POWER, RSUMHORLOS->FQC_POWER, sizeof(RSUMHORLOS->FQC_POWER));
    MEMCPY_AN(RSUMHORLOS_N->LOSS_GROUP, RSUMHORLOS->LOSS_GROUP, sizeof(RSUMHORLOS->LOSS_GROUP));
    MEMCPY_AN(RSUMHORLOS_N->LOSS_CODE, RSUMHORLOS->LOSS_CODE, sizeof(RSUMHORLOS->LOSS_CODE));
    RSUMHORLOS_N->LOSS_QTY = RSUMHORLOS->LOSS_QTY;
    RSUMHORLOS_N->TIME01_LOSS_QTY = RSUMHORLOS->TIME01_LOSS_QTY;
    RSUMHORLOS_N->TIME02_LOSS_QTY = RSUMHORLOS->TIME02_LOSS_QTY;
    RSUMHORLOS_N->TIME03_LOSS_QTY = RSUMHORLOS->TIME03_LOSS_QTY;
    RSUMHORLOS_N->TIME04_LOSS_QTY = RSUMHORLOS->TIME04_LOSS_QTY;
    RSUMHORLOS_N->TIME05_LOSS_QTY = RSUMHORLOS->TIME05_LOSS_QTY;
    RSUMHORLOS_N->TIME06_LOSS_QTY = RSUMHORLOS->TIME06_LOSS_QTY;
    RSUMHORLOS_N->TIME07_LOSS_QTY = RSUMHORLOS->TIME07_LOSS_QTY;
    RSUMHORLOS_N->TIME08_LOSS_QTY = RSUMHORLOS->TIME08_LOSS_QTY;
    RSUMHORLOS_N->TIME09_LOSS_QTY = RSUMHORLOS->TIME09_LOSS_QTY;
    RSUMHORLOS_N->TIME10_LOSS_QTY = RSUMHORLOS->TIME10_LOSS_QTY;
    RSUMHORLOS_N->TIME11_LOSS_QTY = RSUMHORLOS->TIME11_LOSS_QTY;
    RSUMHORLOS_N->TIME12_LOSS_QTY = RSUMHORLOS->TIME12_LOSS_QTY;
