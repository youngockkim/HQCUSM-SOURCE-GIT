                    LAST_EVENT_TIME = :CRASRESDEF_N.LAST_EVENT_TIME,
                    LAST_ACTIVE_HIST_SEQ = :CRASRESDEF_N.LAST_ACTIVE_HIST_SEQ,
                    LAST_HIST_SEQ = :CRASRESDEF_N.LAST_HIST_SEQ,
                    RES_SHORT_DESC = :CRASRESDEF_N.RES_SHORT_DESC
                WHERE FACTORY = :CRASRESDEF_N.FACTORY
                    AND RES_ID = :CRASRESDEF_N.RES_ID;
            break;

		case 104:
            EXEC SQL UPDATE CRASRESDEF SET
                    RES_STS_7 = :CRASRESDEF_N.RES_STS_7,
                    RES_STS_8 = :CRASRESDEF_N.RES_STS_8
                WHERE FACTORY = :CRASRESDEF_N.FACTORY
                    AND RES_ID = :CRASRESDEF_N.RES_ID;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_crasresdef", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_crasresdef(int sel_type, struct CRASRESDEF_TAG *CRASRESDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASRESDEF_N_TAG CRASRESDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_crasresdef(&CRASRESDEF_N, CRASRESDEF);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASRESDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    RES_DESC,
                    RES_TYPE,
                    RES_GRP_1,
                    RES_GRP_2,
                    RES_GRP_3,
                    RES_GRP_4,
                    RES_GRP_5,
                    RES_GRP_6,
                    RES_GRP_7,
                    RES_GRP_8,
                    RES_GRP_9,
                    RES_GRP_10,
                    USE_FAC_PRT_FLAG,
                    RES_STS_PRT_1,
                    RES_STS_PRT_2,
                    RES_STS_PRT_3,
                    RES_STS_PRT_4,
                    RES_STS_PRT_5,
                    RES_STS_PRT_6,
                    RES_STS_PRT_7,
                    RES_STS_PRT_8,
                    RES_STS_PRT_9,
                    RES_STS_PRT_10,
                    RES_CMF_1,
                    RES_CMF_2,
                    RES_CMF_3,
                    RES_CMF_4,
                    RES_CMF_5,
                    RES_CMF_6,
                    RES_CMF_7,
                    RES_CMF_8,
                    RES_CMF_9,
                    RES_CMF_10,
                    RES_CMF_11,
                    RES_CMF_12,
                    RES_CMF_13,
                    RES_CMF_14,
                    RES_CMF_15,
                    RES_CMF_16,
                    RES_CMF_17,
                    RES_CMF_18,
                    RES_CMF_19,
                    RES_CMF_20,
                    AREA_ID,
                    SUB_AREA_ID,
                    RES_LOCATION,
                    PROC_RULE,
                    MAX_PROC_COUNT,
                    BATCH_COND_1,
                    BATCH_COND_2,
                    PM_SCH_ENABLE_FLAG,
                    UNIT_BASE_ST_FLAG,
                    SEC_CHK_FLAG,
                    GATHER_ALARM_FLAG,
                    DELETE_FLAG,
                    DELETE_USER_ID,
                    DELETE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RES_UP_DOWN_FLAG,
                    RES_PRI_STS,
                    RES_STS_1,
                    RES_STS_2,
                    RES_STS_3,
                    RES_STS_4,
                    RES_STS_5,
                    RES_STS_6,
                    RES_STS_7,
                    RES_STS_8,
                    RES_STS_9,
                    RES_STS_10,
                    LOT_ID,
                    SUBLOT_ID,
                    CRR_ID,
                    RES_CTRL_MODE,
                    RES_PROC_MODE,
                    LAST_RECIPE_ID,
                    PROC_COUNT,
                    LAST_START_TIME,
                    LAST_END_TIME,
                    LAST_DOWN_TIME,
                    LAST_DOWN_HIST_SEQ,
                    LAST_EVENT_ID,
                    LAST_EVENT_TIME,
                    LAST_ACTIVE_HIST_SEQ,
                    LAST_HIST_SEQ,
                    RES_SHORT_DESC
                FROM CRASRESDEF
                ORDER BY FACTORY ASC,
                    RES_ID ASC;
            EXEC SQL OPEN CDB_CRASRESDEF_CUR_1;
            break;

case 107:
            EXEC SQL DECLARE CDB_CRASRESDEF_CUR_107 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    RES_DESC,
                    RES_TYPE,
                    RES_GRP_1,
                    RES_GRP_2,
                    RES_GRP_3,
                    RES_GRP_4,
                    RES_GRP_5,
                    RES_GRP_6,
                    RES_GRP_7,
                    RES_GRP_8,
                    RES_GRP_9,
                    RES_GRP_10,
                    USE_FAC_PRT_FLAG,
                    RES_STS_PRT_1,
                    RES_STS_PRT_2,
                    RES_STS_PRT_3,
                    RES_STS_PRT_4,
                    RES_STS_PRT_5,
                    RES_STS_PRT_6,
                    RES_STS_PRT_7,
                    RES_STS_PRT_8,
                    RES_STS_PRT_9,
                    RES_STS_PRT_10,
                    RES_CMF_1,
                    RES_CMF_2,
                    RES_CMF_3,
                    RES_CMF_4,
                    RES_CMF_5,
                    RES_CMF_6,
                    RES_CMF_7,
                    RES_CMF_8,
                    RES_CMF_9,
                    RES_CMF_10,
                    RES_CMF_11,
                    RES_CMF_12,
                    RES_CMF_13,
                    RES_CMF_14,
                    RES_CMF_15,
                    RES_CMF_16,
                    RES_CMF_17,
                    RES_CMF_18,
                    RES_CMF_19,
                    RES_CMF_20,
                    AREA_ID,
                    SUB_AREA_ID,
                    RES_LOCATION,
                    PROC_RULE,
                    MAX_PROC_COUNT,
                    BATCH_COND_1,
                    BATCH_COND_2,
                    PM_SCH_ENABLE_FLAG,
                    UNIT_BASE_ST_FLAG,
                    SEC_CHK_FLAG,
                    GATHER_ALARM_FLAG,
                    DELETE_FLAG,
                    DELETE_USER_ID,
                    DELETE_TIME,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    RES_UP_DOWN_FLAG,
                    RES_PRI_STS,
                    RES_STS_1,
                    RES_STS_2,
                    RES_STS_3,
                    RES_STS_4,
                    RES_STS_5,
                    RES_STS_6,
                    RES_STS_7,
                    RES_STS_8,
                    RES_STS_9,
                    RES_STS_10,
                    LOT_ID,
                    SUBLOT_ID,
                    CRR_ID,
                    RES_CTRL_MODE,
                    RES_PROC_MODE,
                    LAST_RECIPE_ID,
                    PROC_COUNT,
                    LAST_START_TIME,
                    LAST_END_TIME,
                    LAST_DOWN_TIME,
                    LAST_DOWN_HIST_SEQ,
                    LAST_EVENT_ID,
                    LAST_EVENT_TIME,
                    LAST_ACTIVE_HIST_SEQ,
                    LAST_HIST_SEQ,
					RES_SHORT_DESC
                FROM CRASRESDEF
                WHERE FACTORY = :CRASRESDEF_N.FACTORY
				AND RES_CMF_10 = 'Y'
                ORDER BY RES_ID ASC;
            EXEC SQL OPEN CDB_CRASRESDEF_CUR_107;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_crasresdef", sel_type);
}


