                    SUBLOT_ID = :CRASRESDEF_N.SUBLOT_ID,
                    CRR_ID = :CRASRESDEF_N.CRR_ID,
                    RES_CTRL_MODE = :CRASRESDEF_N.RES_CTRL_MODE,
