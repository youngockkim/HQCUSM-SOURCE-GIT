                                                    :CRASRESDEF_N.UNIT_BASE_ST_FLAG,
                                                    :CRASRESDEF_N.SEC_CHK_FLAG,
                                                    :CRASRESDEF_N.GATHER_ALARM_FLAG,
                                                    :CRASRESDEF_N.DELETE_FLAG,
                                                    :CRASRESDEF_N.DELETE_USER_ID,
                                                    :CRASRESDEF_N.DELETE_TIME,
                                                    :CRASRESDEF_N.CREATE_USER_ID,
