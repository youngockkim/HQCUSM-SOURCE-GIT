/* Del Null Function */
void CDB_del_null_crasresdef(struct CRASRESDEF_N_TAG *CRASRESDEF_N, struct CRASRESDEF_TAG *CRASRESDEF)
{
    MEMCPY_DN(CRASRESDEF->FACTORY, CRASRESDEF_N->FACTORY, sizeof(CRASRESDEF->FACTORY));
