                                                    :CRASRESDEF_N.RES_STS_3,
                                                    :CRASRESDEF_N.RES_STS_4,
                                                    :CRASRESDEF_N.RES_STS_5,
                                                    :CRASRESDEF_N.RES_STS_6,
                                                    :CRASRESDEF_N.RES_STS_7,
                                                    :CRASRESDEF_N.RES_STS_8,
                                                    :CRASRESDEF_N.RES_STS_9,
                                                    :CRASRESDEF_N.RES_STS_10,
                                                    :CRASRESDEF_N.LOT_ID,
                                                    :CRASRESDEF_N.SUBLOT_ID,
                                                    :CRASRESDEF_N.CRR_ID,
                                                    :CRASRESDEF_N.RES_CTRL_MODE,
                                                    :CRASRESDEF_N.RES_PROC_MODE,
                                                    :CRASRESDEF_N.LAST_RECIPE_ID,
                                                    :CRASRESDEF_N.PROC_COUNT,
                                                    :CRASRESDEF_N.LAST_START_TIME,
                                                    :CRASRESDEF_N.LAST_END_TIME,
                                                    :CRASRESDEF_N.LAST_DOWN_TIME,
                                                    :CRASRESDEF_N.LAST_DOWN_HIST_SEQ,
                                                    :CRASRESDEF_N.LAST_EVENT_ID,
                                                    :CRASRESDEF_N.LAST_EVENT_TIME,
                                                    :CRASRESDEF_N.LAST_ACTIVE_HIST_SEQ,
                                                    :CRASRESDEF_N.LAST_HIST_SEQ,
													:CRASRESDEF_N.RES_SHORT_DESC;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_crasresdef(&CRASRESDEF_N, CRASRESDEF);
    }

    DB_stop_query_timer("CDB_fetch_crasresdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_crasresdef(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CRASRESDEF_CUR_1;
            break;

		case 107:
            EXEC SQL CLOSE CDB_CRASRESDEF_CUR_107;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_crasresdef", sel_type);
}


/* Initialize Function */
void CDB_init_crasresdef(struct CRASRESDEF_TAG *CRASRESDEF)
{
    /* memset by Space */
    memset(CRASRESDEF, ' ', sizeof(struct CRASRESDEF_TAG));
    
    CRASRESDEF->MAX_PROC_COUNT = 0;
    CRASRESDEF->PROC_COUNT = 0;
    CRASRESDEF->LAST_DOWN_HIST_SEQ = 0;
    CRASRESDEF->LAST_ACTIVE_HIST_SEQ = 0;
    CRASRESDEF->LAST_HIST_SEQ = 0;
}


