                                                    :CRASRESDEF_N.RES_LOCATION,
                                                    :CRASRESDEF_N.PROC_RULE,
                                                    :CRASRESDEF_N.MAX_PROC_COUNT,
                                                    :CRASRESDEF_N.BATCH_COND_1,
                                                    :CRASRESDEF_N.BATCH_COND_2,
