/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwipclvsts(int sel_type, struct CWIPCLVSTS_TAG *CWIPCLVSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPCLVSTS_N_TAG CWIPCLVSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwipclvsts(&CWIPCLVSTS_N, CWIPCLVSTS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPCLVSTS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LINE_ID,
                    RES_ID,
                    TRAN_DATE,
                    TRAN_TIME,
                    SEQ,
                    COMMENT_1,
                    HALF_CELL_SAP,
                    HALF_CELL_LINE,
                    FULL_CELL_SAP,
                    CELL_UNPACK,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_USER_ID,
                    CREATE_TIME
                FROM CWIPCLVSTS
                ORDER BY FACTORY ASC,
                    LINE_ID ASC,
                    RES_ID ASC,
                    TRAN_DATE ASC,
                    TRAN_TIME ASC,
                    SEQ ASC;
            EXEC SQL OPEN CDB_CWIPCLVSTS_CUR_1;
            break;
		
		case 2:
            EXEC SQL DECLARE CDB_CWIPCLVSTS_CUR_2 CURSOR FOR
                SELECT 
                    C.FACTORY,
                    C.LINE_ID,
                    C.RES_ID,
                    C.TRAN_DATE,
                    C.TRAN_TIME,
                    C.SEQ,
                    C.COMMENT_1,
                    C.HALF_CELL_SAP,
                    C.HALF_CELL_LINE,
                    C.FULL_CELL_SAP,
                    C.CELL_UNPACK,
                    C.CMF_1,
                    C.CMF_2,
                    C.CMF_3,
                    C.CMF_4,
                    C.CMF_5,
                    C.CREATE_USER_ID,
                    C.CREATE_TIME
				FROM CWIPCLVSTS C, (SELECT LINE_ID,RES_ID,TRAN_DATE,TRAN_TIME,MAX(SEQ) SEQ FROM CWIPCLVSTS GROUP BY LINE_ID,RES_ID,TRAN_DATE,TRAN_TIME) S
				WHERE C.FACTORY = :CWIPCLVSTS_N.FACTORY					
                    AND C.LINE_ID = :CWIPCLVSTS_N.LINE_ID
                    AND C.TRAN_DATE = :CWIPCLVSTS_N.TRAN_DATE
                    AND C.TRAN_TIME = :CWIPCLVSTS_N.TRAN_TIME
					AND C.LINE_ID = S.LINE_ID
					AND C.TRAN_DATE = S.TRAN_DATE
					AND C.TRAN_TIME = S.TRAN_TIME
					AND C.RES_ID = S.RES_ID
					AND C.SEQ = S.SEQ
					ORDER BY C.RES_ID ASC;                
            EXEC SQL OPEN CDB_CWIPCLVSTS_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwipclvsts", sel_type);
}


