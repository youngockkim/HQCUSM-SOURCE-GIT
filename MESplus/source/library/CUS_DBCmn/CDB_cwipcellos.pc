/* SQL SELECT_SCALAR Function */
double CDB_select_cwipcellos_scalar(int sel_type, struct CWIPCELLOS_TAG *CWIPCELLOS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPCELLOS_N_TAG CWIPCELLOS_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwipcellos(&CWIPCELLOS_N, CWIPCELLOS);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPCELLOS
                WHERE FACTORY = :CWIPCELLOS_N.FACTORY
                    AND LOSS_CATEGORY = :CWIPCELLOS_N.LOSS_CATEGORY
                    AND CELL_ID = :CWIPCELLOS_N.CELL_ID
                    AND LOSS_SEQ = :CWIPCELLOS_N.LOSS_SEQ;
            break;
		case 2:
            EXEC SQL SELECT NVL(MAX(LOSS_SEQ),0) 
                INTO :d_value
                FROM CWIPCELLOS
                WHERE FACTORY = :CWIPCELLOS_N.FACTORY
                    AND LOSS_CATEGORY = :CWIPCELLOS_N.LOSS_CATEGORY
                    AND CELL_ID = :CWIPCELLOS_N.CELL_ID;
            break;

		case 3:
			EXEC SQL SELECT NVL(COUNT(L.LOT_ID) ,0) OUT_QTY 
				INTO :d_value
				FROM CWIPCELLOS L
				,(
				SELECT LOT_ID,INS_TYPE, MAX(INS_CNT) INS_CNT
				FROM CEDCLOTRLT
				WHERE FACTORY = :CWIPCELLOS_N.FACTORY
				AND INS_TYPE IN ('E1','B1')
				AND LOT_ID = :CWIPCELLOS_N.LOT_ID
				AND RESULT_VALUE = 'NG'
				GROUP BY LOT_ID,INS_TYPE
				) R
				WHERE L.FACTORY = :CWIPCELLOS_N.FACTORY
				AND L.LOSS_CATEGORY = R.INS_TYPE
				AND L.LOT_ID = R.LOT_ID
				AND L.INS_CNT = R.INS_CNT;
			break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_cwipcellos_scalar", sel_type);

    return d_value;
}


