                    LOSS_TYPE,
                    LOSS_GROUP,
                    LOCATION_ID,
                    LOT_ID,
                    MAT_ID,
                    FLOW,
                    OPER,
                    ORDER_ID,
                    LINE_ID,
                    RES_ID,
                    STATUS_FLAG,
                    INV_LOT_ID,
                    LOC_X,
                    LOC_Y,
                    TYPE_FLAG,
                    LOSS_COMMENT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_TIME,
                    TRAN_TIME,
                    WORK_DATE,
                    WORK_SHIFT,
                    WORKER,
                    INS_CNT,
                    RESULT_VALUE,
                    LOT_HIST_SEQ
                FROM CWIPCELLOS
                ORDER BY FACTORY ASC,
                    LOSS_CATEGORY ASC,
                    CELL_ID ASC,
                    LOSS_SEQ ASC;
            EXEC SQL OPEN CDB_CWIPCELLOS_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CWIPCELLOS_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOSS_CATEGORY,
                    CELL_ID,
                    LOSS_SEQ,
                    LOSS_QTY,
                    STRING_ID,
                    LOSS_CODE,
                    LOSS_TYPE,
                    LOSS_GROUP,
                    LOCATION_ID,
                    LOT_ID,
                    MAT_ID,
                    FLOW,
                    OPER,
                    ORDER_ID,
                    LINE_ID,
                    RES_ID,
                    STATUS_FLAG,
                    INV_LOT_ID,
                    LOC_X,
                    LOC_Y,
                    TYPE_FLAG,
                    LOSS_COMMENT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_TIME,
                    TRAN_TIME,
                    WORK_DATE,
                    WORK_SHIFT,
					WORKER,
                    INS_CNT,
                    RESULT_VALUE,
                    LOT_HIST_SEQ
                FROM CWIPCELLOS
				WHERE FACTORY = :CWIPCELLOS_N.FACTORY
                    AND LOSS_CATEGORY = :CWIPCELLOS_N.LOSS_CATEGORY
                    AND LOT_ID = :CWIPCELLOS_N.LOT_ID
					AND LOT_HIST_SEQ = (
									SELECT MAX(LOT_HIST_SEQ) 
									FROM CWIPCELLOS 
									WHERE FACTORY = :CWIPCELLOS_N.FACTORY
									AND LOSS_CATEGORY = :CWIPCELLOS_N.LOSS_CATEGORY
									AND LOT_ID = :CWIPCELLOS_N.LOT_ID )
                ORDER BY FACTORY ASC,
                    LOSS_CATEGORY ASC,
                    CELL_ID ASC,
                    LOSS_SEQ ASC;
            EXEC SQL OPEN CDB_CWIPCELLOS_CUR_2;
			break;

		case 3:
            EXEC SQL DECLARE CDB_CWIPCELLOS_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOSS_CATEGORY,
                    CELL_ID,
                    LOSS_SEQ,
                    LOSS_QTY,
                    STRING_ID,
                    LOSS_CODE,
                    LOSS_TYPE,
                    LOSS_GROUP,
                    LOCATION_ID,
                    LOT_ID,
                    MAT_ID,
                    FLOW,
                    OPER,
                    ORDER_ID,
                    LINE_ID,
                    RES_ID,
                    STATUS_FLAG,
                    INV_LOT_ID,
                    LOC_X,
                    LOC_Y,
                    TYPE_FLAG,
                    LOSS_COMMENT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_TIME,
                    TRAN_TIME,
                    WORK_DATE,
                    WORK_SHIFT,
					WORKER,
                    INS_CNT,
                    RESULT_VALUE,
                    LOT_HIST_SEQ
                FROM CWIPCELLOS
				WHERE FACTORY = :CWIPCELLOS_N.FACTORY
                    AND LOSS_CATEGORY = :CWIPCELLOS_N.LOSS_CATEGORY
                    AND LOT_ID = :CWIPCELLOS_N.LOT_ID
					AND INS_CNT = (SELECT MAX(INS_CNT) INS_CNT
								   FROM CEDCLOTRLH 
								   WHERE FACTORY = :CWIPCELLOS_N.FACTORY 
								   AND INS_TYPE = :CWIPCELLOS_N.LOSS_CATEGORY
								   AND LOT_ID = :CWIPCELLOS_N.LOT_ID
								   AND RESULT_VALUE = 'NG')
                ORDER BY FACTORY ASC,
						 LOSS_CATEGORY ASC,
						 CELL_ID ASC,
						 LOSS_SEQ ASC;
            EXEC SQL OPEN CDB_CWIPCELLOS_CUR_3;

			break;

			case 4:
            EXEC SQL DECLARE CDB_CWIPCELLOS_CUR_4 CURSOR FOR
                SELECT 
                    L.FACTORY,
                    L.LOSS_CATEGORY,
                    L.CELL_ID,
                    L.LOSS_SEQ,
                    L.LOSS_QTY,
                    L.STRING_ID,
                    L.LOSS_CODE,
                    L.LOSS_TYPE,
                    L.LOSS_GROUP,
                    L.LOCATION_ID,
                    L.LOT_ID,
                    L.MAT_ID,
                    L.FLOW,
                    L.OPER,
                    L.ORDER_ID,
                    L.LINE_ID,
                    L.RES_ID,
                    L.STATUS_FLAG,
                    L.INV_LOT_ID,
					DECODE(LENGTH(L.LOCATION_ID),2, SUBSTR(L.LOCATION_ID,0,1)  , L.LOC_X)  LOC_X,
					DECODE(LENGTH(L.LOCATION_ID),2, '0'|| SUBSTR(L.LOCATION_ID,2,1), L.LOC_Y)  LOC_Y,
                    L.TYPE_FLAG,
                    L.LOSS_COMMENT,
                    L.CMF_1,
                    L.CMF_2,
                    L.CMF_3,
                    L.CMF_4,
                    L.CMF_5,
                    L.CREATE_TIME,
                    L.TRAN_TIME,
                    L.WORK_DATE,
                    L.WORK_SHIFT,
					L.WORKER,
                    L.INS_CNT,
                    L.RESULT_VALUE,
                    L.LOT_HIST_SEQ
                FROM CWIPCELLOS L, CEDCLOTRLT R
				WHERE L.FACTORY = :CWIPCELLOS_N.FACTORY
                    AND L.LOSS_CATEGORY IN ('E1','E2','B1','B2')
                    AND L.LOT_ID = :CWIPCELLOS_N.LOT_ID
                    AND R.FACTORY = L.FACTORY
                    AND R.LOT_ID = L.LOT_ID
                    AND R.INS_TYPE = L.LOSS_CATEGORY
					AND R.INS_CNT = L.INS_CNT
                ORDER BY L.FACTORY ASC,
				         LOSS_CODE ASC,
                         L.LOSS_CATEGORY ASC,
                         L.LOSS_SEQ ASC;

            EXEC SQL OPEN CDB_CWIPCELLOS_CUR_4;
			break;

		case 5:
            EXEC SQL DECLARE CDB_CWIPCELLOS_CUR_5 CURSOR FOR
				SELECT 
					L.FACTORY,
					L.LOSS_CATEGORY,
					L.CELL_ID,
					L.LOSS_SEQ,
					L.LOSS_QTY,
					L.STRING_ID,
					L.LOSS_CODE,
					L.LOSS_TYPE,
					L.LOSS_GROUP,
					DECODE(LENGTH(L.LOCATION_ID),2, SUBSTR(L.LOCATION_ID,0,1)  || '0'|| SUBSTR(L.LOCATION_ID,2,1), L.LOCATION_ID) AS LOCATION_ID,
					L.LOT_ID,
					L.MAT_ID,
					L.FLOW,
					L.OPER,
					L.ORDER_ID,
					L.LINE_ID,
					L.RES_ID,
					L.STATUS_FLAG,
					L.INV_LOT_ID,
					DECODE(LENGTH(L.LOCATION_ID),2, SUBSTR(L.LOCATION_ID,0,1)  , L.LOC_X)  LOC_X,
					DECODE(LENGTH(L.LOCATION_ID),2, '0'|| SUBSTR(L.LOCATION_ID,2,1), L.LOC_Y)  LOC_Y,
					L.TYPE_FLAG,
					L.LOSS_COMMENT,
					L.CMF_1,
					L.CMF_2,
					L.CMF_3,
					L.CMF_4,
					L.CMF_5,
					L.CREATE_TIME,
					L.TRAN_TIME,
					L.WORK_DATE,
					L.WORK_SHIFT,
					L.WORKER,
					L.INS_CNT,
					L.RESULT_VALUE,
					L.LOT_HIST_SEQ
				FROM CWIPCELLOS L
				,(
					SELECT LOT_ID, INS_TYPE , MAX(INS_CNT) INS_CNT
					FROM CEDCLOTRLH 
					WHERE FACTORY = :CWIPCELLOS_N.FACTORY
					AND LOT_ID = :CWIPCELLOS_N.LOT_ID
					AND INS_TYPE IN ('E1','E2','B1','B2')
					AND RESULT_VALUE = 'NG'
					GROUP BY LOT_ID, INS_TYPE
				) R 
				WHERE L.FACTORY = :CWIPCELLOS_N.FACTORY
				AND L.LOSS_CATEGORY IN ('R-E1','R-E2','R-B1','R-B2')
				AND L.LOT_ID = :CWIPCELLOS_N.LOT_ID
				AND R.LOT_ID = L.LOT_ID
				AND R.INS_CNT = L.INS_CNT
				AND R.INS_TYPE = REPLACE(L.LOSS_CATEGORY,'R-')
				ORDER BY L.LOCATION_ID;

            EXEC SQL OPEN CDB_CWIPCELLOS_CUR_5;
			break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwipcellos", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_cwipcellos(int sel_type, struct CWIPCELLOS_TAG *CWIPCELLOS)
{
    EXEC SQL BEGIN DECLARE SECTION;
