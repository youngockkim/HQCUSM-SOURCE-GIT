/* SQL UPDATE Function */
void CDB_update_cwipcellos(int sel_type, struct CWIPCELLOS_TAG *CWIPCELLOS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPCELLOS_N_TAG CWIPCELLOS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwipcellos(&CWIPCELLOS_N, CWIPCELLOS);
