                :CWIPCELLOS_N.FLOW,
                :CWIPCELLOS_N.OPER,
                :CWIPCELLOS_N.ORDER_ID,
                :CWIPCELLOS_N.LINE_ID,
                :CWIPCELLOS_N.RES_ID,
                :CWIPCELLOS_N.STATUS_FLAG,
                :CWIPCELLOS_N.INV_LOT_ID,
