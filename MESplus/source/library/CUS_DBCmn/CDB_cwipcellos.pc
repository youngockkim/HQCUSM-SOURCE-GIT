                    :CWIPCELLOS_N.TRAN_TIME,
                    :CWIPCELLOS_N.WORK_DATE,
                    :CWIPCELLOS_N.WORK_SHIFT,
                    :CWIPCELLOS_N.WORKER,
                    :CWIPCELLOS_N.INS_CNT,
                    :CWIPCELLOS_N.RESULT_VALUE,
                    :CWIPCELLOS_N.LOT_HIST_SEQ
                FROM CWIPCELLOS
                WHERE FACTORY = :CWIPCELLOS_N.FACTORY
