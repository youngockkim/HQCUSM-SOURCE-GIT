        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cwipcellos(&CWIPCELLOS_N, CWIPCELLOS);
    }

    DB_stop_query_timer("CDB_fetch_cwipcellos", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cwipcellos(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CWIPCELLOS_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CWIPCELLOS_CUR_2;
            break;
		
		case 3:
            EXEC SQL CLOSE CDB_CWIPCELLOS_CUR_3;
            break;

		case 4:
            EXEC SQL CLOSE CDB_CWIPCELLOS_CUR_4;
            break;

		case 5:
            EXEC SQL CLOSE CDB_CWIPCELLOS_CUR_5;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwipcellos", sel_type);
}


/* Initialize Function */
void CDB_init_cwipcellos(struct CWIPCELLOS_TAG *CWIPCELLOS)
{
    /* memset by Space */
    memset(CWIPCELLOS, ' ', sizeof(struct CWIPCELLOS_TAG));
    
    CWIPCELLOS->LOSS_SEQ = 0;
    CWIPCELLOS->LOSS_QTY = 0;
    CWIPCELLOS->INS_CNT = 0;
    CWIPCELLOS->LOT_HIST_SEQ = 0;
}


/* Add Null Function */
void CDB_add_null_cwipcellos(struct CWIPCELLOS_N_TAG *CWIPCELLOS_N, struct CWIPCELLOS_TAG *CWIPCELLOS)
{
    /* memset by NULL */
    memset(CWIPCELLOS_N, '\0', sizeof(struct CWIPCELLOS_N_TAG));
    
    MEMCPY_AN(CWIPCELLOS_N->FACTORY, CWIPCELLOS->FACTORY, sizeof(CWIPCELLOS->FACTORY));
    MEMCPY_AN(CWIPCELLOS_N->LOSS_CATEGORY, CWIPCELLOS->LOSS_CATEGORY, sizeof(CWIPCELLOS->LOSS_CATEGORY));
    MEMCPY_AN(CWIPCELLOS_N->CELL_ID, CWIPCELLOS->CELL_ID, sizeof(CWIPCELLOS->CELL_ID));
    CWIPCELLOS_N->LOSS_SEQ = CWIPCELLOS->LOSS_SEQ;
    CWIPCELLOS_N->LOSS_QTY = CWIPCELLOS->LOSS_QTY;
    MEMCPY_AN(CWIPCELLOS_N->STRING_ID, CWIPCELLOS->STRING_ID, sizeof(CWIPCELLOS->STRING_ID));
    MEMCPY_AN(CWIPCELLOS_N->LOSS_CODE, CWIPCELLOS->LOSS_CODE, sizeof(CWIPCELLOS->LOSS_CODE));
    MEMCPY_AN(CWIPCELLOS_N->LOSS_TYPE, CWIPCELLOS->LOSS_TYPE, sizeof(CWIPCELLOS->LOSS_TYPE));
    MEMCPY_AN(CWIPCELLOS_N->LOSS_GROUP, CWIPCELLOS->LOSS_GROUP, sizeof(CWIPCELLOS->LOSS_GROUP));
    MEMCPY_AN(CWIPCELLOS_N->LOCATION_ID, CWIPCELLOS->LOCATION_ID, sizeof(CWIPCELLOS->LOCATION_ID));
    MEMCPY_AN(CWIPCELLOS_N->LOT_ID, CWIPCELLOS->LOT_ID, sizeof(CWIPCELLOS->LOT_ID));
    MEMCPY_AN(CWIPCELLOS_N->MAT_ID, CWIPCELLOS->MAT_ID, sizeof(CWIPCELLOS->MAT_ID));
    MEMCPY_AN(CWIPCELLOS_N->FLOW, CWIPCELLOS->FLOW, sizeof(CWIPCELLOS->FLOW));
    MEMCPY_AN(CWIPCELLOS_N->OPER, CWIPCELLOS->OPER, sizeof(CWIPCELLOS->OPER));
    MEMCPY_AN(CWIPCELLOS_N->ORDER_ID, CWIPCELLOS->ORDER_ID, sizeof(CWIPCELLOS->ORDER_ID));
    MEMCPY_AN(CWIPCELLOS_N->LINE_ID, CWIPCELLOS->LINE_ID, sizeof(CWIPCELLOS->LINE_ID));
    MEMCPY_AN(CWIPCELLOS_N->RES_ID, CWIPCELLOS->RES_ID, sizeof(CWIPCELLOS->RES_ID));
    CWIPCELLOS_N->STATUS_FLAG[0] = CWIPCELLOS->STATUS_FLAG;
    MEMCPY_AN(CWIPCELLOS_N->INV_LOT_ID, CWIPCELLOS->INV_LOT_ID, sizeof(CWIPCELLOS->INV_LOT_ID));
    MEMCPY_AN(CWIPCELLOS_N->LOC_X, CWIPCELLOS->LOC_X, sizeof(CWIPCELLOS->LOC_X));
    MEMCPY_AN(CWIPCELLOS_N->LOC_Y, CWIPCELLOS->LOC_Y, sizeof(CWIPCELLOS->LOC_Y));
    MEMCPY_AN(CWIPCELLOS_N->TYPE_FLAG, CWIPCELLOS->TYPE_FLAG, sizeof(CWIPCELLOS->TYPE_FLAG));
    MEMCPY_AN(CWIPCELLOS_N->LOSS_COMMENT, CWIPCELLOS->LOSS_COMMENT, sizeof(CWIPCELLOS->LOSS_COMMENT));
    MEMCPY_AN(CWIPCELLOS_N->CMF_1, CWIPCELLOS->CMF_1, sizeof(CWIPCELLOS->CMF_1));
    MEMCPY_AN(CWIPCELLOS_N->CMF_2, CWIPCELLOS->CMF_2, sizeof(CWIPCELLOS->CMF_2));
