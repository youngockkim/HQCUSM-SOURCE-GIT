                    :CWIPCELLOS_N.LOSS_QTY,
                    :CWIPCELLOS_N.STRING_ID,
                    :CWIPCELLOS_N.LOSS_CODE,
                    :CWIPCELLOS_N.LOSS_TYPE,
                    :CWIPCELLOS_N.LOSS_GROUP,
                    :CWIPCELLOS_N.LOCATION_ID,
                    :CWIPCELLOS_N.LOT_ID,
                    :CWIPCELLOS_N.MAT_ID,
                    :CWIPCELLOS_N.FLOW,
                    :CWIPCELLOS_N.OPER,
                    :CWIPCELLOS_N.ORDER_ID,
                    :CWIPCELLOS_N.LINE_ID,
                    :CWIPCELLOS_N.RES_ID,
                    :CWIPCELLOS_N.STATUS_FLAG,
                    :CWIPCELLOS_N.INV_LOT_ID,
                    :CWIPCELLOS_N.LOC_X,
                    :CWIPCELLOS_N.LOC_Y,
                    :CWIPCELLOS_N.TYPE_FLAG,
                    :CWIPCELLOS_N.LOSS_COMMENT,
                    :CWIPCELLOS_N.CMF_1,
                    :CWIPCELLOS_N.CMF_2,
                    :CWIPCELLOS_N.CMF_3,
                    :CWIPCELLOS_N.CMF_4,
                    :CWIPCELLOS_N.CMF_5,
                    :CWIPCELLOS_N.CREATE_TIME,
                    :CWIPCELLOS_N.TRAN_TIME,
                    :CWIPCELLOS_N.WORK_DATE,
                    :CWIPCELLOS_N.WORK_SHIFT,
                    :CWIPCELLOS_N.WORKER,
                    :CWIPCELLOS_N.INS_CNT,
                    :CWIPCELLOS_N.RESULT_VALUE,
                    :CWIPCELLOS_N.LOT_HIST_SEQ
                FROM CWIPCELLOS
                WHERE FACTORY = :CWIPCELLOS_N.FACTORY
                    AND LOSS_CATEGORY = :CWIPCELLOS_N.LOSS_CATEGORY
                    AND LOT_ID = :CWIPCELLOS_N.LOT_ID
					AND INS_CNT = TO_NUMBER(NVL(TRIM(:CWIPCELLOS_N.INS_CNT), '0'))
                    AND LOSS_CODE = :CWIPCELLOS_N.LOSS_CODE
					AND ROWNUM = 1;
            break;

			case 3:
				EXEC SQL SELECT 
						CHR(13) || CHR(10) ||'- ' || COL1 || '('|| LOSS1 || ')' || CHR(13) || CHR(10) || '- ' || COL2 || '('|| LOSS2  || ')' || CHR(13) || CHR(10) || '- ' || COL3 || '('|| LOSS3  || ')' LOSS_RES
					 INTO
						:CWIPCELLOS_N.LOSS_COMMENT
					 FROM 
					 (
						SELECT
							MAX(DECODE(ROWNUM, 1, RES_ID, 1)) COL1
							,MAX(DECODE(ROWNUM, 2, RES_ID, 1)) COL2
							,MAX(DECODE(ROWNUM, 3, RES_ID, 1)) COL3 
							,MAX(DECODE(ROWNUM, 1, LOSS_QTY, 1)) LOSS1
							,MAX(DECODE(ROWNUM, 2, LOSS_QTY, 1)) LOSS2
							,MAX(DECODE(ROWNUM, 3, LOSS_QTY, 1)) LOSS3
						FROM 
						(
								SELECT  A.RES_ID
										, COUNT(1) AS LOSS_QTY
								FROM 
								(
										SELECT DISTINCT
											R.RES_CMF_3 RES_ID
											, L.LOT_ID 
										FROM CWIPCELLOS L, MRASRESDEF R
										WHERE 1=1
											AND L.FACTORY = :CWIPCELLOS_N.FACTORY
											AND L.LOSS_CATEGORY ='TA'
											AND L.LOT_ID NOT LIKE '5%' -- EXCEPT REPAIR
											AND L.RESULT_VALUE = 'NG'
											AND L.TRAN_TIME BETWEEN TO_CHAR(SYSDATE-6/24,'YYYYMMDD') || '060000' AND  TO_CHAR(SYSDATE+1-6/24,'YYYYMMDD') || '055959'
											AND L.LINE_ID = :CWIPCELLOS_N.LINE_ID
											AND L.FACTORY = R.FACTORY
											AND L.RES_ID = R.RES_ID
								) A
								GROUP BY A.RES_ID      
								ORDER BY LOSS_QTY DESC, RES_ID  
						)
						WHERE ROWNUM < 4
					);
			break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


