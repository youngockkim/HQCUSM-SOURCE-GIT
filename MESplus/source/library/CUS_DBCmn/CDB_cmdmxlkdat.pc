    MEMCPY_AN(CMDMXLKDAT_N->CMF_4, CMDMXLKDAT->CMF_4, sizeof(CMDMXLKDAT->CMF_4));
    MEMCPY_AN(CMDMXLKDAT_N->CMF_5, CMDMXLKDAT->CMF_5, sizeof(CMDMXLKDAT->CMF_5));
