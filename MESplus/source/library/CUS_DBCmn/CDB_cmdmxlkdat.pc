/* SQL CURSOR CLOSE Function */
void CDB_close_cmdmxlkdat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CMDMXLKDAT_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE CDB_CMDMXLKDAT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cmdmxlkdat", sel_type);
}


/* Initialize Function */
void CDB_init_cmdmxlkdat(struct CMDMXLKDAT_TAG *CMDMXLKDAT)
{
    /* memset by Space */
    memset(CMDMXLKDAT, ' ', sizeof(struct CMDMXLKDAT_TAG));
    
    CMDMXLKDAT->LXM_X1_Y1 = 0;
    CMDMXLKDAT->LXM_X1_Y2 = 0;
    CMDMXLKDAT->LXM_X2_Y1 = 0;
    CMDMXLKDAT->LXM_X2_Y2 = 0;
    CMDMXLKDAT->LXM_X3_Y1 = 0;
    CMDMXLKDAT->LXM_X3_Y2 = 0;
    CMDMXLKDAT->LXM_X4_Y1 = 0;
    CMDMXLKDAT->LXM_X4_Y2 = 0;
    CMDMXLKDAT->LXM_X5_Y1 = 0;
    CMDMXLKDAT->LXM_X5_Y2 = 0;
    CMDMXLKDAT->GC_X1_Y1 = 0;
    CMDMXLKDAT->GC_X1_Y2 = 0;
    CMDMXLKDAT->GC_X2_Y1 = 0;
    CMDMXLKDAT->GC_X2_Y2 = 0;
    CMDMXLKDAT->GC_X3_Y1 = 0;
    CMDMXLKDAT->GC_X3_Y2 = 0;
    CMDMXLKDAT->GC_X4_Y1 = 0;
    CMDMXLKDAT->GC_X4_Y2 = 0;
    CMDMXLKDAT->GC_X5_Y1 = 0;
    CMDMXLKDAT->GC_X5_Y2 = 0;
    CMDMXLKDAT->QTY_1 = 0;
    CMDMXLKDAT->QTY_2 = 0;
    CMDMXLKDAT->QTY_3 = 0;
}


/* Add Null Function */
void CDB_add_null_cmdmxlkdat(struct CMDMXLKDAT_N_TAG *CMDMXLKDAT_N, struct CMDMXLKDAT_TAG *CMDMXLKDAT)
{
    /* memset by NULL */
    memset(CMDMXLKDAT_N, '\0', sizeof(struct CMDMXLKDAT_N_TAG));
    
    MEMCPY_AN(CMDMXLKDAT_N->FACTORY, CMDMXLKDAT->FACTORY, sizeof(CMDMXLKDAT->FACTORY));
    MEMCPY_AN(CMDMXLKDAT_N->CW, CMDMXLKDAT->CW, sizeof(CMDMXLKDAT->CW));
    MEMCPY_AN(CMDMXLKDAT_N->LOT_ID, CMDMXLKDAT->LOT_ID, sizeof(CMDMXLKDAT->LOT_ID));
    MEMCPY_AN(CMDMXLKDAT_N->X_LINK_TEST_DATE, CMDMXLKDAT->X_LINK_TEST_DATE, sizeof(CMDMXLKDAT->X_LINK_TEST_DATE));
    MEMCPY_AN(CMDMXLKDAT_N->X_LINK_TEST_START_TIME, CMDMXLKDAT->X_LINK_TEST_START_TIME, sizeof(CMDMXLKDAT->X_LINK_TEST_START_TIME));
    MEMCPY_AN(CMDMXLKDAT_N->LINE_ID, CMDMXLKDAT->LINE_ID, sizeof(CMDMXLKDAT->LINE_ID));
    MEMCPY_AN(CMDMXLKDAT_N->MACHINE_NO, CMDMXLKDAT->MACHINE_NO, sizeof(CMDMXLKDAT->MACHINE_NO));
    MEMCPY_AN(CMDMXLKDAT_N->POSITION, CMDMXLKDAT->POSITION, sizeof(CMDMXLKDAT->POSITION));
