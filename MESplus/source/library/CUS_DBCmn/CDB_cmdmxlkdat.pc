                    GC_X2_Y1 = :CMDMXLKDAT_N.GC_X2_Y1,
                    GC_X2_Y2 = :CMDMXLKDAT_N.GC_X2_Y2,
                    GC_X3_Y1 = :CMDMXLKDAT_N.GC_X3_Y1,
                    GC_X3_Y2 = :CMDMXLKDAT_N.GC_X3_Y2,
                    GC_X4_Y1 = :CMDMXLKDAT_N.GC_X4_Y1,
                    GC_X4_Y2 = :CMDMXLKDAT_N.GC_X4_Y2,
                    GC_X5_Y1 = :CMDMXLKDAT_N.GC_X5_Y1,
                    GC_X5_Y2 = :CMDMXLKDAT_N.GC_X5_Y2,
                    QTY_1 = :CMDMXLKDAT_N.QTY_1,
                    QTY_2 = :CMDMXLKDAT_N.QTY_2,
                    QTY_3 = :CMDMXLKDAT_N.QTY_3,
                    DATA_COMMENT = :CMDMXLKDAT_N.DATA_COMMENT,
                    CMF_1 = :CMDMXLKDAT_N.CMF_1,
                    CMF_2 = :CMDMXLKDAT_N.CMF_2,
                    CMF_3 = :CMDMXLKDAT_N.CMF_3,
                    CMF_4 = :CMDMXLKDAT_N.CMF_4,
                    CMF_5 = :CMDMXLKDAT_N.CMF_5,
                    CMF_6 = :CMDMXLKDAT_N.CMF_6,
                    CMF_7 = :CMDMXLKDAT_N.CMF_7,
                    CMF_8 = :CMDMXLKDAT_N.CMF_8,
                    CMF_9 = :CMDMXLKDAT_N.CMF_9,
                    CMF_10 = :CMDMXLKDAT_N.CMF_10,
                    CREATE_USER_ID = :CMDMXLKDAT_N.CREATE_USER_ID,
                    CREATE_TIME = :CMDMXLKDAT_N.CREATE_TIME,
                    UPDATE_USER_ID = :CMDMXLKDAT_N.UPDATE_USER_ID,
                    UPDATE_TIME = :CMDMXLKDAT_N.UPDATE_TIME
                WHERE FACTORY = :CMDMXLKDAT_N.FACTORY
                    AND CW = :CMDMXLKDAT_N.CW
                    AND LOT_ID = :CMDMXLKDAT_N.LOT_ID
                    AND X_LINK_TEST_DATE = :CMDMXLKDAT_N.X_LINK_TEST_DATE
                    AND X_LINK_TEST_START_TIME = :CMDMXLKDAT_N.X_LINK_TEST_START_TIME
                    AND LINE_ID = :CMDMXLKDAT_N.LINE_ID
                    AND MACHINE_NO = :CMDMXLKDAT_N.MACHINE_NO
                    AND POSITION = :CMDMXLKDAT_N.POSITION
                    AND MEASURE_TYPE = :CMDMXLKDAT_N.MEASURE_TYPE;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_cmdmxlkdat", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cmdmxlkdat(int sel_type, struct CMDMXLKDAT_TAG *CMDMXLKDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMDMXLKDAT_N_TAG CMDMXLKDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cmdmxlkdat(&CMDMXLKDAT_N, CMDMXLKDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CMDMXLKDAT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    CW,
                    LOT_ID,
                    X_LINK_TEST_DATE,
                    X_LINK_TEST_START_TIME,
                    LINE_ID,
                    MACHINE_NO,
                    POSITION,
                    MEASURE_TYPE,
                    MAT_ID,
                    LAMI_DATE,
                    LAMI_END_TIME,
                    BS_TYPE,
                    BS_BATCH_NO,
                    EVA_TYPE,
                    EVA_BATCH_NO,
                    LAMI_RECIPE,
                    REPEAT_MEASURE_NO,
                    CORRELATION_FILE,
                    LXM_X1_Y1,
                    LXM_X1_Y2,
                    LXM_X2_Y1,
                    LXM_X2_Y2,
                    LXM_X3_Y1,
                    LXM_X3_Y2,
                    LXM_X4_Y1,
                    LXM_X4_Y2,
                    LXM_X5_Y1,
                    LXM_X5_Y2,
                    GC_X1_Y1,
                    GC_X1_Y2,
                    GC_X2_Y1,
                    GC_X2_Y2,
                    GC_X3_Y1,
                    GC_X3_Y2,
                    GC_X4_Y1,
                    GC_X4_Y2,
                    GC_X5_Y1,
                    GC_X5_Y2,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    DATA_COMMENT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMDMXLKDAT
                ORDER BY FACTORY ASC,
                    CW ASC,
                    LOT_ID ASC,
                    X_LINK_TEST_DATE ASC,
                    X_LINK_TEST_START_TIME ASC,
                    LINE_ID ASC,
                    MACHINE_NO ASC,
                    POSITION ASC,
                    MEASURE_TYPE ASC;
            EXEC SQL OPEN CDB_CMDMXLKDAT_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE CDB_CMDMXLKDAT_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    CW,
                    LOT_ID,
                    X_LINK_TEST_DATE,
                    X_LINK_TEST_START_TIME,
                    LINE_ID,
                    MACHINE_NO,
                    POSITION,
                    MEASURE_TYPE,
                    MAT_ID,
                    LAMI_DATE,
                    LAMI_END_TIME,
                    BS_TYPE,
                    BS_BATCH_NO,
                    EVA_TYPE,
                    EVA_BATCH_NO,
                    LAMI_RECIPE,
                    REPEAT_MEASURE_NO,
                    CORRELATION_FILE,
                    LXM_X1_Y1,
                    LXM_X1_Y2,
                    LXM_X2_Y1,
                    LXM_X2_Y2,
                    LXM_X3_Y1,
                    LXM_X3_Y2,
                    LXM_X4_Y1,
                    LXM_X4_Y2,
                    LXM_X5_Y1,
                    LXM_X5_Y2,
                    GC_X1_Y1,
                    GC_X1_Y2,
                    GC_X2_Y1,
                    GC_X2_Y2,
                    GC_X3_Y1,
                    GC_X3_Y2,
                    GC_X4_Y1,
                    GC_X4_Y2,
                    GC_X5_Y1,
                    GC_X5_Y2,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    DATA_COMMENT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMDMXLKDAT
                WHERE FACTORY = :CMDMXLKDAT_N.FACTORY
                    AND X_LINK_TEST_DATE >= :DBC_Q_COND_N.FROM_DATE 
                    AND X_LINK_TEST_DATE <= :DBC_Q_COND_N.TO_DATE
                    AND CW LIKE :CMDMXLKDAT_N.CW
                    AND MAT_ID LIKE :CMDMXLKDAT_N.MAT_ID
                    AND LINE_ID LIKE :CMDMXLKDAT_N.LINE_ID
                    AND MACHINE_NO LIKE :CMDMXLKDAT_N.MACHINE_NO
                    AND POSITION LIKE :CMDMXLKDAT_N.POSITION
                    AND MEASURE_TYPE LIKE :CMDMXLKDAT_N.MEASURE_TYPE
                ORDER BY FACTORY ASC,
                    X_LINK_TEST_DATE ASC,
                    X_LINK_TEST_START_TIME ASC,
                    CW ASC,
                    LOT_ID ASC,
                    LINE_ID ASC,
                    MACHINE_NO ASC,
                    POSITION ASC,
                    MEASURE_TYPE ASC;
            EXEC SQL OPEN CDB_CMDMXLKDAT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cmdmxlkdat", sel_type);
}


