    MEMCPY_AN(CMDMXLKDAT_N->MAT_ID, CMDMXLKDAT->MAT_ID, sizeof(CMDMXLKDAT->MAT_ID));
    MEMCPY_AN(CMDMXLKDAT_N->LAMI_DATE, CMDMXLKDAT->LAMI_DATE, sizeof(CMDMXLKDAT->LAMI_DATE));
    MEMCPY_AN(CMDMXLKDAT_N->LAMI_END_TIME, CMDMXLKDAT->LAMI_END_TIME, sizeof(CMDMXLKDAT->LAMI_END_TIME));
