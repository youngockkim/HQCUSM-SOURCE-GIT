    CMDMXLKDAT_N->LXM_X2_Y1 = CMDMXLKDAT->LXM_X2_Y1;
    CMDMXLKDAT_N->LXM_X2_Y2 = CMDMXLKDAT->LXM_X2_Y2;
    CMDMXLKDAT_N->LXM_X3_Y1 = CMDMXLKDAT->LXM_X3_Y1;
