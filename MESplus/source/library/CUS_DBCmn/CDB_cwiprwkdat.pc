/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwiprwkdat(int sel_type, struct CWIPRWKDAT_TAG *CWIPRWKDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
    struct CWIPRWKDAT_N_TAG CWIPRWKDAT_N;
	char   sql[5120];
    char ts1[100];
    char ts2[100];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwiprwkdat(&CWIPRWKDAT_N, CWIPRWKDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPRWKDAT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    PROD_ORDER_NO,
                    MODULE_ID,
                    MAT_ID,
                    PROD_NO,
                    MATE_NM,
                    REQUIRE_QTY,
                    UNIT,
                    BATCH_NO,
                    R_REASON,
                    PALLET_ID,
                    PAK_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    REWORK_JUDGE,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CWIPRWKDAT
                ORDER BY FACTORY ASC,
                    PROD_ORDER_NO ASC,
                    MODULE_ID ASC;
            EXEC SQL OPEN CDB_CWIPRWKDAT_CUR_1;
            break;

       case 2:

				sprintf(sql , " SELECT A.PROD_ORDER_NO  ");
				sprintf(sql + strlen(sql), " , A.MODULE_ID   ");
				sprintf(sql + strlen(sql), " , A.REWORK_JUDGE ");
				sprintf(sql + strlen(sql), " , B.GRADE AS CMF_1  ");
				sprintf(sql + strlen(sql), " , A.PROD_NO ");
				sprintf(sql + strlen(sql), " , B.POWER_GRADE AS CMF_2 ");

				make_valid_quote(ts1, CWIPRWKDAT_N.FACTORY);
				make_valid_quote(ts2, CWIPRWKDAT_N.MODULE_ID);

				sprintf(sql + strlen(sql), " , NVL((SELECT COUNT(REWORK_JUDGE)  FROM CWIPRWKDAT WHERE FACTORY = '%s'  AND MODULE_ID = '%s' AND REWORK_JUDGE <> ' ' ), 0) AS REQUIRE_QTY ", ts1, ts2);
				sprintf(sql + strlen(sql), " , COUNT(A.PROD_ORDER_NO) AS CMF_3 ");
				sprintf(sql + strlen(sql), " , NVL((SELECT COUNT(REWORK_JUDGE) FROM CWIPRWKDAT WHERE FACTORY = '%s'  AND MODULE_ID = '%s' AND REWORK_JUDGE <> ' ' ), 0) / COUNT(A.PROD_ORDER_NO) * 100 AS CMF_4 ", ts1, ts2);
				sprintf(sql + strlen(sql), " , MAX(INS_CNT) AS CMF_5 ");
				sprintf(sql + strlen(sql), "  FROM CWIPRWKDAT A ");
				sprintf(sql + strlen(sql), "  INNER JOIN CEDCLOTFQC B  ON A.FACTORY = B.FACTORY AND A.MODULE_ID = B.LOT_ID  ");
				sprintf(sql + strlen(sql), "  WHERE A.FACTORY = '%s' ", ts1);
				sprintf(sql + strlen(sql), "  AND A.MODULE_ID LIKE '%s%%' ", ts2);
				sprintf(sql + strlen(sql), " GROUP BY A.PROD_ORDER_NO, A.MODULE_ID, A.REWORK_JUDGE, B.GRADE, B.POWER_GRADE, A.PROD_NO ");

				EXEC SQL PREPARE S FROM :sql;
				EXEC SQL DECLARE CDB_CWIPRWKDAT_CUR_2 CURSOR FOR S; 
				EXEC SQL OPEN CDB_CWIPRWKDAT_CUR_2;    

				LOG_head("DB");
				LOG_add("len", 0, strlen(sql));
				LOG_add("sql", 4, strlen(sql), sql);
				COM_log_write('I', 'S' , 'S');
         break;

		 case 3:
            EXEC SQL DECLARE CDB_CWIPRWKDAT_CUR_3 CURSOR FOR
                SELECT DISTINCT
                    A.MODULE_ID,
                    A.MAT_ID,
                    ' ' as CMF_1,
                    ' ' as CMF_2
                FROM CWIPRWKDAT A
						, MWIPLOTSTS B
				WHERE A.FACTORY = :CWIPRWKDAT_N.FACTORY
                    AND A.PROD_ORDER_NO = :CWIPRWKDAT_N.PROD_ORDER_NO
					AND REWORK_JUDGE = ' ' 
					AND A.FACTORY = B.FACTORY
					AND A.PROD_ORDER_NO = B.ORDER_ID  
                ORDER BY A.MODULE_ID ASC;
            EXEC SQL OPEN CDB_CWIPRWKDAT_CUR_3;
            break;	
			
		 case 4:
            EXEC SQL DECLARE CDB_CWIPRWKDAT_CUR_4 CURSOR FOR
                SELECT DISTINCT
                    A.MODULE_ID,
                    A.MAT_ID
                FROM CWIPRWKDAT A
				WHERE A.FACTORY = :CWIPRWKDAT_N.FACTORY
                    AND A.MODULE_ID = :CWIPRWKDAT_N.MODULE_ID
                    AND A.CMF_1 <> 'D'      /* 23.4.12 add check delete rework order */
                ORDER BY A.MODULE_ID ASC;
            EXEC SQL OPEN CDB_CWIPRWKDAT_CUR_4;
            break;		

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwiprwkdat", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_cwiprwkdat(int sel_type, struct CWIPRWKDAT_TAG *CWIPRWKDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPRWKDAT_N_TAG CWIPRWKDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CWIPRWKDAT_CUR_1 INTO
                :CWIPRWKDAT_N.FACTORY,
                :CWIPRWKDAT_N.PROD_ORDER_NO,
                :CWIPRWKDAT_N.MODULE_ID,
                :CWIPRWKDAT_N.MAT_ID,
                :CWIPRWKDAT_N.PROD_NO,
                :CWIPRWKDAT_N.MATE_NM,
                :CWIPRWKDAT_N.REQUIRE_QTY,
                :CWIPRWKDAT_N.UNIT,
                :CWIPRWKDAT_N.BATCH_NO,
                :CWIPRWKDAT_N.R_REASON,
                :CWIPRWKDAT_N.PALLET_ID,
                :CWIPRWKDAT_N.PAK_TIME,
                :CWIPRWKDAT_N.CMF_1,
                :CWIPRWKDAT_N.CMF_2,
                :CWIPRWKDAT_N.CMF_3,
                :CWIPRWKDAT_N.CMF_4,
                :CWIPRWKDAT_N.CMF_5,
                :CWIPRWKDAT_N.REWORK_JUDGE,
                :CWIPRWKDAT_N.CREATE_USER_ID,
                :CWIPRWKDAT_N.CREATE_TIME,
                :CWIPRWKDAT_N.UPDATE_USER_ID,
                :CWIPRWKDAT_N.UPDATE_TIME;
            break;

		case 2:
            EXEC SQL FETCH CDB_CWIPRWKDAT_CUR_2 INTO
                :CWIPRWKDAT_N.PROD_ORDER_NO,
				:CWIPRWKDAT_N.MODULE_ID,
				:CWIPRWKDAT_N.REWORK_JUDGE,
                :CWIPRWKDAT_N.CMF_1,
     			:CWIPRWKDAT_N.PROD_NO,
				:CWIPRWKDAT_N.CMF_2,
                :CWIPRWKDAT_N.REQUIRE_QTY,
                :CWIPRWKDAT_N.CMF_3,
                :CWIPRWKDAT_N.CMF_4,
                :CWIPRWKDAT_N.CMF_5;
            break;

		case 3:
            EXEC SQL FETCH CDB_CWIPRWKDAT_CUR_3 INTO
				:CWIPRWKDAT_N.MODULE_ID,
				:CWIPRWKDAT_N.MAT_ID,
                :CWIPRWKDAT_N.CMF_1,
				:CWIPRWKDAT_N.CMF_2;
            break;
			
		case 4:
            EXEC SQL FETCH CDB_CWIPRWKDAT_CUR_4 INTO
				:CWIPRWKDAT_N.MODULE_ID,
				:CWIPRWKDAT_N.MAT_ID;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cwiprwkdat(&CWIPRWKDAT_N, CWIPRWKDAT);
    }

    DB_stop_query_timer("CDB_fetch_cwiprwkdat", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cwiprwkdat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CWIPRWKDAT_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CWIPRWKDAT_CUR_2;
            break;

		case 3:
            EXEC SQL CLOSE CDB_CWIPRWKDAT_CUR_3;
            break;
			
		case 4:
            EXEC SQL CLOSE CDB_CWIPRWKDAT_CUR_4;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwiprwkdat", sel_type);
}


/* Initialize Function */
void CDB_init_cwiprwkdat(struct CWIPRWKDAT_TAG *CWIPRWKDAT)
{
    /* memset by Space */
    memset(CWIPRWKDAT, ' ', sizeof(struct CWIPRWKDAT_TAG));
    
}


/* Add Null Function */
void CDB_add_null_cwiprwkdat(struct CWIPRWKDAT_N_TAG *CWIPRWKDAT_N, struct CWIPRWKDAT_TAG *CWIPRWKDAT)
{
    /* memset by NULL */
    memset(CWIPRWKDAT_N, '\0', sizeof(struct CWIPRWKDAT_N_TAG));
    
    MEMCPY_AN(CWIPRWKDAT_N->FACTORY, CWIPRWKDAT->FACTORY, sizeof(CWIPRWKDAT->FACTORY));
    MEMCPY_AN(CWIPRWKDAT_N->PROD_ORDER_NO, CWIPRWKDAT->PROD_ORDER_NO, sizeof(CWIPRWKDAT->PROD_ORDER_NO));
    MEMCPY_AN(CWIPRWKDAT_N->MODULE_ID, CWIPRWKDAT->MODULE_ID, sizeof(CWIPRWKDAT->MODULE_ID));
    MEMCPY_AN(CWIPRWKDAT_N->MAT_ID, CWIPRWKDAT->MAT_ID, sizeof(CWIPRWKDAT->MAT_ID));
    MEMCPY_AN(CWIPRWKDAT_N->PROD_NO, CWIPRWKDAT->PROD_NO, sizeof(CWIPRWKDAT->PROD_NO));
    MEMCPY_AN(CWIPRWKDAT_N->MATE_NM, CWIPRWKDAT->MATE_NM, sizeof(CWIPRWKDAT->MATE_NM));
    MEMCPY_AN(CWIPRWKDAT_N->REQUIRE_QTY, CWIPRWKDAT->REQUIRE_QTY, sizeof(CWIPRWKDAT->REQUIRE_QTY));
    MEMCPY_AN(CWIPRWKDAT_N->UNIT, CWIPRWKDAT->UNIT, sizeof(CWIPRWKDAT->UNIT));
    MEMCPY_AN(CWIPRWKDAT_N->BATCH_NO, CWIPRWKDAT->BATCH_NO, sizeof(CWIPRWKDAT->BATCH_NO));
    MEMCPY_AN(CWIPRWKDAT_N->R_REASON, CWIPRWKDAT->R_REASON, sizeof(CWIPRWKDAT->R_REASON));
    MEMCPY_AN(CWIPRWKDAT_N->PALLET_ID, CWIPRWKDAT->PALLET_ID, sizeof(CWIPRWKDAT->PALLET_ID));
    MEMCPY_AN(CWIPRWKDAT_N->PAK_TIME, CWIPRWKDAT->PAK_TIME, sizeof(CWIPRWKDAT->PAK_TIME));
    MEMCPY_AN(CWIPRWKDAT_N->CMF_1, CWIPRWKDAT->CMF_1, sizeof(CWIPRWKDAT->CMF_1));
    MEMCPY_AN(CWIPRWKDAT_N->CMF_2, CWIPRWKDAT->CMF_2, sizeof(CWIPRWKDAT->CMF_2));
    MEMCPY_AN(CWIPRWKDAT_N->CMF_3, CWIPRWKDAT->CMF_3, sizeof(CWIPRWKDAT->CMF_3));
    MEMCPY_AN(CWIPRWKDAT_N->CMF_4, CWIPRWKDAT->CMF_4, sizeof(CWIPRWKDAT->CMF_4));
    MEMCPY_AN(CWIPRWKDAT_N->CMF_5, CWIPRWKDAT->CMF_5, sizeof(CWIPRWKDAT->CMF_5));
    MEMCPY_AN(CWIPRWKDAT_N->REWORK_JUDGE, CWIPRWKDAT->REWORK_JUDGE, sizeof(CWIPRWKDAT->REWORK_JUDGE));
    MEMCPY_AN(CWIPRWKDAT_N->CREATE_USER_ID, CWIPRWKDAT->CREATE_USER_ID, sizeof(CWIPRWKDAT->CREATE_USER_ID));
    MEMCPY_AN(CWIPRWKDAT_N->CREATE_TIME, CWIPRWKDAT->CREATE_TIME, sizeof(CWIPRWKDAT->CREATE_TIME));
    MEMCPY_AN(CWIPRWKDAT_N->UPDATE_USER_ID, CWIPRWKDAT->UPDATE_USER_ID, sizeof(CWIPRWKDAT->UPDATE_USER_ID));
    MEMCPY_AN(CWIPRWKDAT_N->UPDATE_TIME, CWIPRWKDAT->UPDATE_TIME, sizeof(CWIPRWKDAT->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_cwiprwkdat(struct CWIPRWKDAT_N_TAG *CWIPRWKDAT_N, struct CWIPRWKDAT_TAG *CWIPRWKDAT)
{
    MEMCPY_DN(CWIPRWKDAT->FACTORY, CWIPRWKDAT_N->FACTORY, sizeof(CWIPRWKDAT->FACTORY));
    MEMCPY_DN(CWIPRWKDAT->PROD_ORDER_NO, CWIPRWKDAT_N->PROD_ORDER_NO, sizeof(CWIPRWKDAT->PROD_ORDER_NO));
    MEMCPY_DN(CWIPRWKDAT->MODULE_ID, CWIPRWKDAT_N->MODULE_ID, sizeof(CWIPRWKDAT->MODULE_ID));
    MEMCPY_DN(CWIPRWKDAT->MAT_ID, CWIPRWKDAT_N->MAT_ID, sizeof(CWIPRWKDAT->MAT_ID));
    MEMCPY_DN(CWIPRWKDAT->PROD_NO, CWIPRWKDAT_N->PROD_NO, sizeof(CWIPRWKDAT->PROD_NO));
    MEMCPY_DN(CWIPRWKDAT->MATE_NM, CWIPRWKDAT_N->MATE_NM, sizeof(CWIPRWKDAT->MATE_NM));
    MEMCPY_DN(CWIPRWKDAT->REQUIRE_QTY, CWIPRWKDAT_N->REQUIRE_QTY, sizeof(CWIPRWKDAT->REQUIRE_QTY));
    MEMCPY_DN(CWIPRWKDAT->UNIT, CWIPRWKDAT_N->UNIT, sizeof(CWIPRWKDAT->UNIT));
    MEMCPY_DN(CWIPRWKDAT->BATCH_NO, CWIPRWKDAT_N->BATCH_NO, sizeof(CWIPRWKDAT->BATCH_NO));
    MEMCPY_DN(CWIPRWKDAT->R_REASON, CWIPRWKDAT_N->R_REASON, sizeof(CWIPRWKDAT->R_REASON));
    MEMCPY_DN(CWIPRWKDAT->PALLET_ID, CWIPRWKDAT_N->PALLET_ID, sizeof(CWIPRWKDAT->PALLET_ID));
    MEMCPY_DN(CWIPRWKDAT->PAK_TIME, CWIPRWKDAT_N->PAK_TIME, sizeof(CWIPRWKDAT->PAK_TIME));
    MEMCPY_DN(CWIPRWKDAT->CMF_1, CWIPRWKDAT_N->CMF_1, sizeof(CWIPRWKDAT->CMF_1));
    MEMCPY_DN(CWIPRWKDAT->CMF_2, CWIPRWKDAT_N->CMF_2, sizeof(CWIPRWKDAT->CMF_2));
    MEMCPY_DN(CWIPRWKDAT->CMF_3, CWIPRWKDAT_N->CMF_3, sizeof(CWIPRWKDAT->CMF_3));
    MEMCPY_DN(CWIPRWKDAT->CMF_4, CWIPRWKDAT_N->CMF_4, sizeof(CWIPRWKDAT->CMF_4));
    MEMCPY_DN(CWIPRWKDAT->CMF_5, CWIPRWKDAT_N->CMF_5, sizeof(CWIPRWKDAT->CMF_5));
    MEMCPY_DN(CWIPRWKDAT->REWORK_JUDGE, CWIPRWKDAT_N->REWORK_JUDGE, sizeof(CWIPRWKDAT->REWORK_JUDGE));
    MEMCPY_DN(CWIPRWKDAT->CREATE_USER_ID, CWIPRWKDAT_N->CREATE_USER_ID, sizeof(CWIPRWKDAT->CREATE_USER_ID));
    MEMCPY_DN(CWIPRWKDAT->CREATE_TIME, CWIPRWKDAT_N->CREATE_TIME, sizeof(CWIPRWKDAT->CREATE_TIME));
    MEMCPY_DN(CWIPRWKDAT->UPDATE_USER_ID, CWIPRWKDAT_N->UPDATE_USER_ID, sizeof(CWIPRWKDAT->UPDATE_USER_ID));
    MEMCPY_DN(CWIPRWKDAT->UPDATE_TIME, CWIPRWKDAT_N->UPDATE_TIME, sizeof(CWIPRWKDAT->UPDATE_TIME));
}


