    MEMCPY_AN(CRASTOLHIS_N->CREATE_TIME, CRASTOLHIS->CREATE_TIME, sizeof(CRASTOLHIS->CREATE_TIME));
    MEMCPY_AN(CRASTOLHIS_N->UPDATE_USER_ID, CRASTOLHIS->UPDATE_USER_ID, sizeof(CRASTOLHIS->UPDATE_USER_ID));
    MEMCPY_AN(CRASTOLHIS_N->UPDATE_TIME, CRASTOLHIS->UPDATE_TIME, sizeof(CRASTOLHIS->UPDATE_TIME));
}


