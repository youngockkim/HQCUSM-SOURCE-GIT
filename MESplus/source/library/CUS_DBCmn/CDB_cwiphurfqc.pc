/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwiphurfqc(int sel_type, struct CWIPHURFQC_TAG *CWIPHURFQC)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPHURFQC_N_TAG CWIPHURFQC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwiphurfqc(&CWIPHURFQC_N, CWIPHURFQC);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPHURFQC_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LINE_ID,
                    WORK_DATE,
                    WORK_SHIFT,
                    HIST_SEQ,
                    BEFE_TYPE,
                    SIML_TYPE,
                    WORK_TIME,
                    PIC_NAME,
                    MACHINE_NO,
                    ACTION_STTM,
                    ACTION_EDTM,
                    DEFECT_CODE,
                    DEFECT_DETAIL,
                    ROOT_CAUSE,
                    ACTION_PLAN,
                    MONITORING_RESULT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CWIPHURFQC
				WHERE FACTORY	= :CWIPHURFQC_N.FACTORY
				AND   WORK_DATE = :CWIPHURFQC_N.WORK_DATE
				AND   LINE_ID	= :CWIPHURFQC_N.LINE_ID
				AND   WORK_SHIFT= :CWIPHURFQC_N.WORK_SHIFT
				AND   BEFE_TYPE = :CWIPHURFQC_N.BEFE_TYPE
				AND   SIML_TYPE = :CWIPHURFQC_N.SIML_TYPE
                ORDER BY FACTORY ASC,
                    LINE_ID ASC,
                    WORK_DATE ASC,
                    WORK_SHIFT ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN CDB_CWIPHURFQC_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwiphurfqc", sel_type);
}


