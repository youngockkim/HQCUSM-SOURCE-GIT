/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_crastbrjgr(int sel_type, struct CRASTBRJGR_TAG *CRASTBRJGR)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASTBRJGR_N_TAG CRASTBRJGR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_crastbrjgr(&CRASTBRJGR_N, CRASTBRJGR);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASTBRJGR_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    WORK_DATE,
                    JGR_SEQ,
					JGR_PROC,
                    LINE_ID,
                    RES_ID,
                    WORK_TIME,
                    JIG_NO,
                    WRKR_NAME,
                    DEPT_CD,
                    JGR_RSN,
                    NVL(JGR_REMARKS, ' '),
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' '),
                    NVL(CMF_6, ' '),
                    NVL(CMF_7, ' '),
                    NVL(CMF_8, ' '),
                    NVL(CMF_9, ' '),
                    NVL(CMF_10, ' '),
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CRASTBRJGR
			   WHERE FACTORY   = :CRASTBRJGR_N.FACTORY
                 AND WORK_DATE = :CRASTBRJGR_N.WORK_DATE
                ORDER BY JGR_SEQ ASC;
            EXEC SQL OPEN CDB_CRASTBRJGR_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
