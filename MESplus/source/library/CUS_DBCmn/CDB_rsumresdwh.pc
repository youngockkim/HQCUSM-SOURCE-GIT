/* SQL CURSOR CLOSE Function */
void CDB_close_rsumresdwh(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_RSUMRESDWH_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_RSUMRESDWH_CUR_2;
            break;

		case 3:
            EXEC SQL CLOSE CDB_RSUMRESDWH_CUR_3;
            break;

		case 4:
            EXEC SQL CLOSE CDB_RSUMRESDWH_CUR_4;
            break;

		case 5:
            EXEC SQL CLOSE CDB_RSUMRESDWH_CUR_5;
            break;

		case 100:
            EXEC SQL CLOSE CDB_RSUMRESDWH_CUR_100;
            break;

		case 101:
            EXEC SQL CLOSE CDB_RSUMRESDWH_CUR_101;
            break;

		
		case 102:
            EXEC SQL CLOSE CDB_RSUMRESDWH_CUR_102;
            break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_rsumresdwh", sel_type);
}

/* Initialize Function */
void CDB_init_rsumresdwh(struct RSUMRESDWH_TAG *RSUMRESDWH)
{
    /* memset by Space */
    memset(RSUMRESDWH, ' ', sizeof(struct RSUMRESDWH_TAG));
    
    RSUMRESDWH->STATE_TIME = 0;
}


/* Add Null Function */
void CDB_add_null_rsumresdwh(struct RSUMRESDWH_N_TAG *RSUMRESDWH_N, struct RSUMRESDWH_TAG *RSUMRESDWH)
{
    /* memset by NULL */
    memset(RSUMRESDWH_N, '\0', sizeof(struct RSUMRESDWH_N_TAG));
    
    MEMCPY_AN(RSUMRESDWH_N->WORK_DATE, RSUMRESDWH->WORK_DATE, sizeof(RSUMRESDWH->WORK_DATE));
    MEMCPY_AN(RSUMRESDWH_N->LINE_ID, RSUMRESDWH->LINE_ID, sizeof(RSUMRESDWH->LINE_ID));
    MEMCPY_AN(RSUMRESDWH_N->OPER, RSUMRESDWH->OPER, sizeof(RSUMRESDWH->OPER));
    MEMCPY_AN(RSUMRESDWH_N->RES_ID, RSUMRESDWH->RES_ID, sizeof(RSUMRESDWH->RES_ID));
    MEMCPY_AN(RSUMRESDWH_N->CURR_CODE, RSUMRESDWH->CURR_CODE, sizeof(RSUMRESDWH->CURR_CODE));
    MEMCPY_AN(RSUMRESDWH_N->TRAN_MSEC, RSUMRESDWH->TRAN_MSEC, sizeof(RSUMRESDWH->TRAN_MSEC));
    MEMCPY_AN(RSUMRESDWH_N->TRAN_TIME, RSUMRESDWH->TRAN_TIME, sizeof(RSUMRESDWH->TRAN_TIME));
    MEMCPY_AN(RSUMRESDWH_N->FACTORY, RSUMRESDWH->FACTORY, sizeof(RSUMRESDWH->FACTORY));
    RSUMRESDWH_N->WORK_SHIFT[0] = RSUMRESDWH->WORK_SHIFT;
    MEMCPY_AN(RSUMRESDWH_N->CURR_ACRO, RSUMRESDWH->CURR_ACRO, sizeof(RSUMRESDWH->CURR_ACRO));
    MEMCPY_AN(RSUMRESDWH_N->CURR_GROUP, RSUMRESDWH->CURR_GROUP, sizeof(RSUMRESDWH->CURR_GROUP));
    MEMCPY_AN(RSUMRESDWH_N->END_TIME, RSUMRESDWH->END_TIME, sizeof(RSUMRESDWH->END_TIME));
    RSUMRESDWH_N->STATE_TIME = RSUMRESDWH->STATE_TIME;
    MEMCPY_AN(RSUMRESDWH_N->PREV_CODE, RSUMRESDWH->PREV_CODE, sizeof(RSUMRESDWH->PREV_CODE));
    MEMCPY_AN(RSUMRESDWH_N->SUB_RES_ID, RSUMRESDWH->SUB_RES_ID, sizeof(RSUMRESDWH->SUB_RES_ID));
    MEMCPY_AN(RSUMRESDWH_N->ALID, RSUMRESDWH->ALID, sizeof(RSUMRESDWH->ALID));
    MEMCPY_AN(RSUMRESDWH_N->ALCD, RSUMRESDWH->ALCD, sizeof(RSUMRESDWH->ALCD));
    MEMCPY_AN(RSUMRESDWH_N->ALTX, RSUMRESDWH->ALTX, sizeof(RSUMRESDWH->ALTX));
    MEMCPY_AN(RSUMRESDWH_N->MSG_NO, RSUMRESDWH->MSG_NO, sizeof(RSUMRESDWH->MSG_NO));
    MEMCPY_AN(RSUMRESDWH_N->END_MSEC, RSUMRESDWH->END_MSEC, sizeof(RSUMRESDWH->END_MSEC));
    MEMCPY_AN(RSUMRESDWH_N->CTRL_MODE, RSUMRESDWH->CTRL_MODE, sizeof(RSUMRESDWH->CTRL_MODE));
    MEMCPY_AN(RSUMRESDWH_N->OLD_CTRL_MODE, RSUMRESDWH->OLD_CTRL_MODE, sizeof(RSUMRESDWH->OLD_CTRL_MODE));
    RSUMRESDWH_N->INPUT_FLAG[0] = RSUMRESDWH->INPUT_FLAG;
    MEMCPY_AN(RSUMRESDWH_N->CHANGE_MODE_TIME, RSUMRESDWH->CHANGE_MODE_TIME, sizeof(RSUMRESDWH->CHANGE_MODE_TIME));
    MEMCPY_AN(RSUMRESDWH_N->CMF_1, RSUMRESDWH->CMF_1, sizeof(RSUMRESDWH->CMF_1));
    MEMCPY_AN(RSUMRESDWH_N->CMF_2, RSUMRESDWH->CMF_2, sizeof(RSUMRESDWH->CMF_2));
    MEMCPY_AN(RSUMRESDWH_N->CMF_3, RSUMRESDWH->CMF_3, sizeof(RSUMRESDWH->CMF_3));
    MEMCPY_AN(RSUMRESDWH_N->CMF_4, RSUMRESDWH->CMF_4, sizeof(RSUMRESDWH->CMF_4));
    MEMCPY_AN(RSUMRESDWH_N->CMF_5, RSUMRESDWH->CMF_5, sizeof(RSUMRESDWH->CMF_5));
}


/* Del Null Function */
void CDB_del_null_rsumresdwh(struct RSUMRESDWH_N_TAG *RSUMRESDWH_N, struct RSUMRESDWH_TAG *RSUMRESDWH)
{
    MEMCPY_DN(RSUMRESDWH->WORK_DATE, RSUMRESDWH_N->WORK_DATE, sizeof(RSUMRESDWH->WORK_DATE));
    MEMCPY_DN(RSUMRESDWH->LINE_ID, RSUMRESDWH_N->LINE_ID, sizeof(RSUMRESDWH->LINE_ID));
    MEMCPY_DN(RSUMRESDWH->OPER, RSUMRESDWH_N->OPER, sizeof(RSUMRESDWH->OPER));
    MEMCPY_DN(RSUMRESDWH->RES_ID, RSUMRESDWH_N->RES_ID, sizeof(RSUMRESDWH->RES_ID));
    MEMCPY_DN(RSUMRESDWH->CURR_CODE, RSUMRESDWH_N->CURR_CODE, sizeof(RSUMRESDWH->CURR_CODE));
    MEMCPY_DN(RSUMRESDWH->TRAN_MSEC, RSUMRESDWH_N->TRAN_MSEC, sizeof(RSUMRESDWH->TRAN_MSEC));
    MEMCPY_DN(RSUMRESDWH->TRAN_TIME, RSUMRESDWH_N->TRAN_TIME, sizeof(RSUMRESDWH->TRAN_TIME));
    MEMCPY_DN(RSUMRESDWH->FACTORY, RSUMRESDWH_N->FACTORY, sizeof(RSUMRESDWH->FACTORY));
    RSUMRESDWH->WORK_SHIFT = RSUMRESDWH_N->WORK_SHIFT[0];
    MEMCPY_DN(RSUMRESDWH->CURR_ACRO, RSUMRESDWH_N->CURR_ACRO, sizeof(RSUMRESDWH->CURR_ACRO));
    MEMCPY_DN(RSUMRESDWH->CURR_GROUP, RSUMRESDWH_N->CURR_GROUP, sizeof(RSUMRESDWH->CURR_GROUP));
    MEMCPY_DN(RSUMRESDWH->END_TIME, RSUMRESDWH_N->END_TIME, sizeof(RSUMRESDWH->END_TIME));
    RSUMRESDWH->STATE_TIME = RSUMRESDWH_N->STATE_TIME;
    MEMCPY_DN(RSUMRESDWH->PREV_CODE, RSUMRESDWH_N->PREV_CODE, sizeof(RSUMRESDWH->PREV_CODE));
    MEMCPY_DN(RSUMRESDWH->SUB_RES_ID, RSUMRESDWH_N->SUB_RES_ID, sizeof(RSUMRESDWH->SUB_RES_ID));
    MEMCPY_DN(RSUMRESDWH->ALID, RSUMRESDWH_N->ALID, sizeof(RSUMRESDWH->ALID));
    MEMCPY_DN(RSUMRESDWH->ALCD, RSUMRESDWH_N->ALCD, sizeof(RSUMRESDWH->ALCD));
    MEMCPY_DN(RSUMRESDWH->ALTX, RSUMRESDWH_N->ALTX, sizeof(RSUMRESDWH->ALTX));
    MEMCPY_DN(RSUMRESDWH->MSG_NO, RSUMRESDWH_N->MSG_NO, sizeof(RSUMRESDWH->MSG_NO));
    MEMCPY_DN(RSUMRESDWH->END_MSEC, RSUMRESDWH_N->END_MSEC, sizeof(RSUMRESDWH->END_MSEC));
    MEMCPY_DN(RSUMRESDWH->CTRL_MODE, RSUMRESDWH_N->CTRL_MODE, sizeof(RSUMRESDWH->CTRL_MODE));
    MEMCPY_DN(RSUMRESDWH->OLD_CTRL_MODE, RSUMRESDWH_N->OLD_CTRL_MODE, sizeof(RSUMRESDWH->OLD_CTRL_MODE));
    RSUMRESDWH->INPUT_FLAG = RSUMRESDWH_N->INPUT_FLAG[0];
    MEMCPY_DN(RSUMRESDWH->CHANGE_MODE_TIME, RSUMRESDWH_N->CHANGE_MODE_TIME, sizeof(RSUMRESDWH->CHANGE_MODE_TIME));
    MEMCPY_DN(RSUMRESDWH->CMF_1, RSUMRESDWH_N->CMF_1, sizeof(RSUMRESDWH->CMF_1));
    MEMCPY_DN(RSUMRESDWH->CMF_2, RSUMRESDWH_N->CMF_2, sizeof(RSUMRESDWH->CMF_2));
    MEMCPY_DN(RSUMRESDWH->CMF_3, RSUMRESDWH_N->CMF_3, sizeof(RSUMRESDWH->CMF_3));
    MEMCPY_DN(RSUMRESDWH->CMF_4, RSUMRESDWH_N->CMF_4, sizeof(RSUMRESDWH->CMF_4));
    MEMCPY_DN(RSUMRESDWH->CMF_5, RSUMRESDWH_N->CMF_5, sizeof(RSUMRESDWH->CMF_5));
}


