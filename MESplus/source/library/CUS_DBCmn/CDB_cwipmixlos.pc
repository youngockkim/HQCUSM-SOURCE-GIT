                    :CWIPMIXLOS_N.LOT_ID_1,
                    :CWIPMIXLOS_N.TRAN_TIME_1,
                    :CWIPMIXLOS_N.INS_TYPE_1,
                    :CWIPMIXLOS_N.INS_VALUE_1,
                    :CWIPMIXLOS_N.DEFECT_CODE_1,
                    :CWIPMIXLOS_N.CELL_LOCATION_1,
                    :CWIPMIXLOS_N.LOT_ID_2,
                    :CWIPMIXLOS_N.TRAN_TIME_2,
                    :CWIPMIXLOS_N.INS_TYPE_2,
                    :CWIPMIXLOS_N.INS_VALUE_2,
                    :CWIPMIXLOS_N.DEFECT_CODE_2,
                    :CWIPMIXLOS_N.CELL_LOCATION_2,
                    :CWIPMIXLOS_N.LOT_ID_3,
                    :CWIPMIXLOS_N.TRAN_TIME_3,
                    :CWIPMIXLOS_N.INS_TYPE_3,
                    :CWIPMIXLOS_N.INS_VALUE_3,
                    :CWIPMIXLOS_N.DEFECT_CODE_3,
                    :CWIPMIXLOS_N.CELL_LOCATION_3,
                    :CWIPMIXLOS_N.CMF_1,
                    :CWIPMIXLOS_N.CMF_2,
                    :CWIPMIXLOS_N.CMF_3,
                    :CWIPMIXLOS_N.CMF_4,
                    :CWIPMIXLOS_N.CMF_5
                FROM CWIPMIXLOS
                WHERE MATRIX_ID = :CWIPMIXLOS_N.MATRIX_ID;
            break;

		case 2:
            EXEC SQL SELECT 
                    M.MATRIX_ID,
					M.LOT_ID_1,
					M.TRAN_TIME_1,
					M.INS_TYPE_1,
					M.INS_VALUE_1,
					NVL(E1.KEY_1,'E99') DEFECT_CODE_1,
					M.CELL_LOCATION_1,
					M.LOT_ID_2,
					M.TRAN_TIME_2,
					M.INS_TYPE_2,
					M.INS_VALUE_2,
					NVL(E2.KEY_1,'E99') DEFECT_CODE_2,
					M.CELL_LOCATION_2,
					M.LOT_ID_3,
					M.TRAN_TIME_3,
					M.INS_TYPE_3,
					M.INS_VALUE_3,
					NVL(E3.KEY_1,'E99') DEFECT_CODE_3,
					M.CELL_LOCATION_3,
					NVL(E1.DATA_4,'unregistered') CMF_1,
					NVL(E2.DATA_4,'unregistered') CMF_2,
					NVL(E3.DATA_4,'unregistered') CMF_3,
					M.CMF_4,
					M.CMF_5
                INTO 
                    :CWIPMIXLOS_N.MATRIX_ID,
                    :CWIPMIXLOS_N.LOT_ID_1,
                    :CWIPMIXLOS_N.TRAN_TIME_1,
                    :CWIPMIXLOS_N.INS_TYPE_1,
                    :CWIPMIXLOS_N.INS_VALUE_1,
                    :CWIPMIXLOS_N.DEFECT_CODE_1,
                    :CWIPMIXLOS_N.CELL_LOCATION_1,
                    :CWIPMIXLOS_N.LOT_ID_2,
                    :CWIPMIXLOS_N.TRAN_TIME_2,
                    :CWIPMIXLOS_N.INS_TYPE_2,
                    :CWIPMIXLOS_N.INS_VALUE_2,
                    :CWIPMIXLOS_N.DEFECT_CODE_2,
                    :CWIPMIXLOS_N.CELL_LOCATION_2,
                    :CWIPMIXLOS_N.LOT_ID_3,
                    :CWIPMIXLOS_N.TRAN_TIME_3,
                    :CWIPMIXLOS_N.INS_TYPE_3,
                    :CWIPMIXLOS_N.INS_VALUE_3,
                    :CWIPMIXLOS_N.DEFECT_CODE_3,
                    :CWIPMIXLOS_N.CELL_LOCATION_3,
                    :CWIPMIXLOS_N.CMF_1,
                    :CWIPMIXLOS_N.CMF_2,
                    :CWIPMIXLOS_N.CMF_3,
                    :CWIPMIXLOS_N.CMF_4,
                    :CWIPMIXLOS_N.CMF_5
                FROM CWIPMIXLOS M
				, (SELECT KEY_1,DATA_4 FROM MGCMTBLDAT WHERE FACTORY = 'USGAM1'
					AND TABLE_NAME = '@DEFECT'
					AND KEY_2 IN ('M2040','M2030') ) E1
				, (SELECT KEY_1,DATA_4 FROM MGCMTBLDAT WHERE FACTORY = 'USGAM1'
					AND TABLE_NAME = '@DEFECT'
					AND KEY_2 IN ('M2040','M2030') ) E2
				, (SELECT KEY_1,DATA_4 FROM MGCMTBLDAT WHERE FACTORY = 'USGAM1'
					AND TABLE_NAME = '@DEFECT'
					AND KEY_2 IN ('M2040','M2030') ) E3
				WHERE M.MATRIX_ID = :CWIPMIXLOS_N.MATRIX_ID
				AND M.DEFECT_CODE_1 =   E1.KEY_1(+)
				AND M.DEFECT_CODE_2 =   E2.KEY_1(+)
				AND M.DEFECT_CODE_3 =   E3.KEY_1(+);
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


