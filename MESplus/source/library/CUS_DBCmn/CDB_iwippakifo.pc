/* SQL CURSOR CLOSE Function */
void CDB_close_iwippakifo(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IWIPPAKIFO_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IWIPPAKIFO_CUR_2;
            break;
		case 3:						/* IS-20-12-012 */
            EXEC SQL CLOSE CDB_IWIPPAKIFO_CUR_3;
            break;
		case 4:						/* IS-20-12-012 */
            EXEC SQL CLOSE CDB_IWIPPAKIFO_CUR_4;
            break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_iwippakifo", sel_type);
}


/* Initialize Function */
void CDB_init_iwippakifo(struct IWIPPAKIFO_TAG *IWIPPAKIFO)
{
    /* memset by Space */
    memset(IWIPPAKIFO, ' ', sizeof(struct IWIPPAKIFO_TAG));
    
    IWIPPAKIFO->QTY = 0;
}


/* Add Null Function */
void CDB_add_null_iwippakifo(struct IWIPPAKIFO_N_TAG *IWIPPAKIFO_N, struct IWIPPAKIFO_TAG *IWIPPAKIFO)
{
    /* memset by NULL */
    memset(IWIPPAKIFO_N, '\0', sizeof(struct IWIPPAKIFO_N_TAG));
    
    MEMCPY_AN(IWIPPAKIFO_N->DOC_ID, IWIPPAKIFO->DOC_ID, sizeof(IWIPPAKIFO->DOC_ID));
    MEMCPY_AN(IWIPPAKIFO_N->PALLET_ID, IWIPPAKIFO->PALLET_ID, sizeof(IWIPPAKIFO->PALLET_ID));
    MEMCPY_AN(IWIPPAKIFO_N->MODULE_ID, IWIPPAKIFO->MODULE_ID, sizeof(IWIPPAKIFO->MODULE_ID));
    IWIPPAKIFO_N->ACTION_TYPE[0] = IWIPPAKIFO->ACTION_TYPE;
    MEMCPY_AN(IWIPPAKIFO_N->MODULE_SEQ, IWIPPAKIFO->MODULE_SEQ, sizeof(IWIPPAKIFO->MODULE_SEQ));
    MEMCPY_AN(IWIPPAKIFO_N->SITE_ID, IWIPPAKIFO->SITE_ID, sizeof(IWIPPAKIFO->SITE_ID));
    IWIPPAKIFO_N->QTY = IWIPPAKIFO->QTY;
    MEMCPY_AN(IWIPPAKIFO_N->PACKING_DATE, IWIPPAKIFO->PACKING_DATE, sizeof(IWIPPAKIFO->PACKING_DATE));
    MEMCPY_AN(IWIPPAKIFO_N->PACKING_TIME, IWIPPAKIFO->PACKING_TIME, sizeof(IWIPPAKIFO->PACKING_TIME));
    MEMCPY_AN(IWIPPAKIFO_N->PACKING_ID, IWIPPAKIFO->PACKING_ID, sizeof(IWIPPAKIFO->PACKING_ID));
    MEMCPY_AN(IWIPPAKIFO_N->INTERFACE_DATE, IWIPPAKIFO->INTERFACE_DATE, sizeof(IWIPPAKIFO->INTERFACE_DATE));
    MEMCPY_AN(IWIPPAKIFO_N->INTERFACE_TIME, IWIPPAKIFO->INTERFACE_TIME, sizeof(IWIPPAKIFO->INTERFACE_TIME));
    MEMCPY_AN(IWIPPAKIFO_N->INTERFACE_USERID, IWIPPAKIFO->INTERFACE_USERID, sizeof(IWIPPAKIFO->INTERFACE_USERID));
    MEMCPY_AN(IWIPPAKIFO_N->INF_PROC_TIME, IWIPPAKIFO->INF_PROC_TIME, sizeof(IWIPPAKIFO->INF_PROC_TIME));
    MEMCPY_AN(IWIPPAKIFO_N->CMF_1, IWIPPAKIFO->CMF_1, sizeof(IWIPPAKIFO->CMF_1));
    MEMCPY_AN(IWIPPAKIFO_N->CMF_2, IWIPPAKIFO->CMF_2, sizeof(IWIPPAKIFO->CMF_2));
    MEMCPY_AN(IWIPPAKIFO_N->CMF_3, IWIPPAKIFO->CMF_3, sizeof(IWIPPAKIFO->CMF_3));
    MEMCPY_AN(IWIPPAKIFO_N->CMF_4, IWIPPAKIFO->CMF_4, sizeof(IWIPPAKIFO->CMF_4));
    MEMCPY_AN(IWIPPAKIFO_N->CMF_5, IWIPPAKIFO->CMF_5, sizeof(IWIPPAKIFO->CMF_5));
    IWIPPAKIFO_N->DATA_FLAG[0] = IWIPPAKIFO->DATA_FLAG;
    MEMCPY_AN(IWIPPAKIFO_N->UPDATE_COUNT, IWIPPAKIFO->UPDATE_COUNT, sizeof(IWIPPAKIFO->UPDATE_COUNT));
    MEMCPY_AN(IWIPPAKIFO_N->INSERT_COUNT, IWIPPAKIFO->INSERT_COUNT, sizeof(IWIPPAKIFO->INSERT_COUNT));
    MEMCPY_AN(IWIPPAKIFO_N->DELETE_COUNT, IWIPPAKIFO->DELETE_COUNT, sizeof(IWIPPAKIFO->DELETE_COUNT));
    MEMCPY_AN(IWIPPAKIFO_N->SQL_DML_COUNT, IWIPPAKIFO->SQL_DML_COUNT, sizeof(IWIPPAKIFO->SQL_DML_COUNT));
    MEMCPY_AN(IWIPPAKIFO_N->ZPICODE, IWIPPAKIFO->ZPICODE, sizeof(IWIPPAKIFO->ZPICODE));
    MEMCPY_AN(IWIPPAKIFO_N->ZPIMSGID, IWIPPAKIFO->ZPIMSGID, sizeof(IWIPPAKIFO->ZPIMSGID));
    IWIPPAKIFO_N->RETURN_TYPE[0] = IWIPPAKIFO->RETURN_TYPE;
    MEMCPY_AN(IWIPPAKIFO_N->RETURN_MSG, IWIPPAKIFO->RETURN_MSG, sizeof(IWIPPAKIFO->RETURN_MSG));
    MEMCPY_AN(IWIPPAKIFO_N->ZIFERNAM, IWIPPAKIFO->ZIFERNAM, sizeof(IWIPPAKIFO->ZIFERNAM));
