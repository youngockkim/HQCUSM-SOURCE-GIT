            EXEC SQL DECLARE CDB_IWIPPAKIFO_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    PALLET_ID,
                    MODULE_ID,
                    ACTION_TYPE,
                    MODULE_SEQ,
                    SITE_ID,
                    QTY,
                    PACKING_DATE,
                    PACKING_TIME,
                    PACKING_ID,
                    INTERFACE_DATE,
                    INTERFACE_TIME,
                    INTERFACE_USERID,
                    NVL(INF_PROC_TIME,' ' ) as INF_PROC_TIME,
