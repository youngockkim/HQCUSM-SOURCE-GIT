                ORDER BY DOC_ID ASC,
                    PALLET_ID ASC,
                    MODULE_ID ASC,
                    ACTION_TYPE ASC;
            EXEC SQL OPEN CDB_IWIPPAKIFO_CUR_3;
            break;

			case 4:			/* IS-20-12-012 */
            EXEC SQL DECLARE CDB_IWIPPAKIFO_CUR_4 CURSOR FOR
                SELECT 
                    DOC_ID,
                    PALLET_ID,
                    MODULE_ID,
                    ACTION_TYPE,
                    MODULE_SEQ,
                    SITE_ID,
                    QTY,
                    PACKING_DATE,
                    PACKING_TIME,
                    PACKING_ID,
                    INTERFACE_DATE,
                    INTERFACE_TIME,
                    INTERFACE_USERID,
                    INF_PROC_TIME,
                    NVL(CMF_1,' ' ) as CMF_1,
                    NVL(CMF_2,' ' ) as CMF_2,
                    NVL(CMF_3,' ' ) as CMF_3,
                    NVL(CMF_4,' ' ) as CMF_4,
                    NVL(CMF_5,' ' ) AS CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IWIPPAKIFO
				WHERE ACTION_TYPE = 'P'
                ORDER BY DOC_ID ASC,
                    PALLET_ID ASC,
                    MODULE_ID ASC,
                    ACTION_TYPE ASC;
            EXEC SQL OPEN CDB_IWIPPAKIFO_CUR_4;
            break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_iwippakifo", sel_type);
}


