                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IBASARTDEF
                ORDER BY DOC_ID ASC;
            EXEC SQL OPEN CDB_IBASARTDEF_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_IBASARTDEF_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    MATE_NO,
                    ARTICLE_NO,
                    ACTION_TYPE,
                    MODULE_TYPE,
                    MODULEARTICLE_DESC,
                    POWER,
                    GRADE,
                    POWER_CLASS,
                    INF_TIME,
