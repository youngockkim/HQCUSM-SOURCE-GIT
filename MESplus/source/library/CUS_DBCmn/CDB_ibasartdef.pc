/* Add Null Function */
void CDB_add_null_ibasartdef(struct IBASARTDEF_N_TAG *IBASARTDEF_N, struct IBASARTDEF_TAG *IBASARTDEF)
{
    /* memset by NULL */
    memset(IBASARTDEF_N, '\0', sizeof(struct IBASARTDEF_N_TAG));
    
    MEMCPY_AN(IBASARTDEF_N->DOC_ID, IBASARTDEF->DOC_ID, sizeof(IBASARTDEF->DOC_ID));
    MEMCPY_AN(IBASARTDEF_N->SITE_ID, IBASARTDEF->SITE_ID, sizeof(IBASARTDEF->SITE_ID));
    MEMCPY_AN(IBASARTDEF_N->MATE_NO, IBASARTDEF->MATE_NO, sizeof(IBASARTDEF->MATE_NO));
    MEMCPY_AN(IBASARTDEF_N->ARTICLE_NO, IBASARTDEF->ARTICLE_NO, sizeof(IBASARTDEF->ARTICLE_NO));
    IBASARTDEF_N->ACTION_TYPE[0] = IBASARTDEF->ACTION_TYPE;
    MEMCPY_AN(IBASARTDEF_N->MODULE_TYPE, IBASARTDEF->MODULE_TYPE, sizeof(IBASARTDEF->MODULE_TYPE));
    MEMCPY_AN(IBASARTDEF_N->MODULEARTICLE_DESC, IBASARTDEF->MODULEARTICLE_DESC, sizeof(IBASARTDEF->MODULEARTICLE_DESC));
    MEMCPY_AN(IBASARTDEF_N->POWER, IBASARTDEF->POWER, sizeof(IBASARTDEF->POWER));
    MEMCPY_AN(IBASARTDEF_N->GRADE, IBASARTDEF->GRADE, sizeof(IBASARTDEF->GRADE));
    MEMCPY_AN(IBASARTDEF_N->POWER_CLASS, IBASARTDEF->POWER_CLASS, sizeof(IBASARTDEF->POWER_CLASS));
    MEMCPY_AN(IBASARTDEF_N->INF_TIME, IBASARTDEF->INF_TIME, sizeof(IBASARTDEF->INF_TIME));
    MEMCPY_AN(IBASARTDEF_N->INF_PROC_TIME, IBASARTDEF->INF_PROC_TIME, sizeof(IBASARTDEF->INF_PROC_TIME));
    MEMCPY_AN(IBASARTDEF_N->CMF_1, IBASARTDEF->CMF_1, sizeof(IBASARTDEF->CMF_1));
    MEMCPY_AN(IBASARTDEF_N->CMF_2, IBASARTDEF->CMF_2, sizeof(IBASARTDEF->CMF_2));
