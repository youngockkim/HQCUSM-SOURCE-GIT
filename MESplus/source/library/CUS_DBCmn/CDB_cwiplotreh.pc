    MEMCPY_AN(CWIPLOTREH_N->CMF_5, CWIPLOTREH->CMF_5, sizeof(CWIPLOTREH->CMF_5));
    MEMCPY_AN(CWIPLOTREH_N->CREATE_TIME, CWIPLOTREH->CREATE_TIME, sizeof(CWIPLOTREH->CREATE_TIME));
    MEMCPY_AN(CWIPLOTREH_N->TRAN_TIME, CWIPLOTREH->TRAN_TIME, sizeof(CWIPLOTREH->TRAN_TIME));
    MEMCPY_AN(CWIPLOTREH_N->WORK_DATE, CWIPLOTREH->WORK_DATE, sizeof(CWIPLOTREH->WORK_DATE));
    CWIPLOTREH_N->WORK_SHIFT[0] = CWIPLOTREH->WORK_SHIFT;
    CWIPLOTREH_N->LOT_HIST_SEQ = CWIPLOTREH->LOT_HIST_SEQ;
}


