/* Add Null Function */
void CDB_add_null_cwiplotrep(struct CWIPLOTREP_N_TAG *CWIPLOTREP_N, struct CWIPLOTREP_TAG *CWIPLOTREP)
{
    /* memset by NULL */
    memset(CWIPLOTREP_N, '\0', sizeof(struct CWIPLOTREP_N_TAG));
    
    MEMCPY_AN(CWIPLOTREP_N->FACTORY, CWIPLOTREP->FACTORY, sizeof(CWIPLOTREP->FACTORY));
    MEMCPY_AN(CWIPLOTREP_N->CATEGORY, CWIPLOTREP->CATEGORY, sizeof(CWIPLOTREP->CATEGORY));
    MEMCPY_AN(CWIPLOTREP_N->LOT_ID, CWIPLOTREP->LOT_ID, sizeof(CWIPLOTREP->LOT_ID));
