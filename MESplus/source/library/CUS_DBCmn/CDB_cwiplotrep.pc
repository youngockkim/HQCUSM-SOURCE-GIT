    MEMCPY_AN(CWIPLOTREP_N->CMF_3, CWIPLOTREP->CMF_3, sizeof(CWIPLOTREP->CMF_3));
    MEMCPY_AN(CWIPLOTREP_N->CMF_4, CWIPLOTREP->CMF_4, sizeof(CWIPLOTREP->CMF_4));
    MEMCPY_AN(CWIPLOTREP_N->CMF_5, CWIPLOTREP->CMF_5, sizeof(CWIPLOTREP->CMF_5));
    MEMCPY_AN(CWIPLOTREP_N->CREATE_TIME, CWIPLOTREP->CREATE_TIME, sizeof(CWIPLOTREP->CREATE_TIME));
    MEMCPY_AN(CWIPLOTREP_N->TRAN_TIME, CWIPLOTREP->TRAN_TIME, sizeof(CWIPLOTREP->TRAN_TIME));
    MEMCPY_AN(CWIPLOTREP_N->WORK_DATE, CWIPLOTREP->WORK_DATE, sizeof(CWIPLOTREP->WORK_DATE));
    CWIPLOTREP_N->WORK_SHIFT[0] = CWIPLOTREP->WORK_SHIFT;
    CWIPLOTREP_N->LOT_HIST_SEQ = CWIPLOTREP->LOT_HIST_SEQ;
}


/* Del Null Function */
void CDB_del_null_cwiplotrep(struct CWIPLOTREP_N_TAG *CWIPLOTREP_N, struct CWIPLOTREP_TAG *CWIPLOTREP)
