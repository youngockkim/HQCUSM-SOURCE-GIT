    MEMCPY_AN(CWIPLOTREP_N->TYPE_FLAG, CWIPLOTREP->TYPE_FLAG, sizeof(CWIPLOTREP->TYPE_FLAG));
    MEMCPY_AN(CWIPLOTREP_N->REP_COMMENT, CWIPLOTREP->REP_COMMENT, sizeof(CWIPLOTREP->REP_COMMENT));
