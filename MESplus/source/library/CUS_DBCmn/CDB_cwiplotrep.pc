/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwiplotrep(int sel_type, struct CWIPLOTREP_TAG *CWIPLOTREP)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPLOTREP_N_TAG CWIPLOTREP_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwiplotrep(&CWIPLOTREP_N, CWIPLOTREP);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPLOTREP_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    CATEGORY,
                    LOT_ID,
                    HIST_SEQ,
                    REPAIR_TABLE,
                    SOLDERING,
                    REPAIR_WORKER,
                    REPAIR_QTY,
                    REPAIR_COUNT,
                    REPAIR_DETAIL,
                    OPER,
                    ORDER_ID,
                    LINE_ID,
                    RES_ID,
                    STATUS_FLAG,
                    TYPE_FLAG,
                    REP_COMMENT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_TIME,
                    TRAN_TIME,
                    WORK_DATE,
                    WORK_SHIFT,
                    LOT_HIST_SEQ
                FROM CWIPLOTREP
                ORDER BY FACTORY ASC,
                    CATEGORY ASC,
                    LOT_ID ASC;
            EXEC SQL OPEN CDB_CWIPLOTREP_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwiplotrep", sel_type);
}


