    MEMCPY_AN(CWIPLOTREP_N->REPAIR_TABLE, CWIPLOTREP->REPAIR_TABLE, sizeof(CWIPLOTREP->REPAIR_TABLE));
    MEMCPY_AN(CWIPLOTREP_N->SOLDERING, CWIPLOTREP->SOLDERING, sizeof(CWIPLOTREP->SOLDERING));
    MEMCPY_AN(CWIPLOTREP_N->REPAIR_WORKER, CWIPLOTREP->REPAIR_WORKER, sizeof(CWIPLOTREP->REPAIR_WORKER));
