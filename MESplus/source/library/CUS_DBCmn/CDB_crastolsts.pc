/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_crastolsts(int sel_type, struct CRASTOLSTS_TAG *CRASTOLSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASTOLSTS_N_TAG CRASTOLSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_crastolsts(&CRASTOLSTS_N, CRASTOLSTS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASTOLSTS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    PART_NAME,
                    CHANGE_CNT,
                    CURR_USE_CNT,
                    MAX_USE_CNT,
                    LIMIT_USE_CNT,
                    LINE_ID,
                    LAST_HIST_SEQ,
                    CNT_1,
                    CNT_2,
                    CNT_3,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CRASTOLSTS
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    PART_NAME ASC;
            EXEC SQL OPEN CDB_CRASTOLSTS_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CRASTOLSTS_CUR_2 CURSOR FOR
                SELECT 
                    A.FACTORY,
					A.RES_ID,
                    B.KEY_1,
                    TO_CHAR(A.CHANGE_CNT),
                    A.PART_NAME,
                    TO_CHAR(A.CURR_USE_CNT, '9,999,999,999') CMF_1,
                    A.MAX_USE_CNT,
                    TO_CHAR(A.LIMIT_USE_CNT, '9,999,999,999') CMF_2,
                    A.LINE_ID
                FROM CRASTOLSTS A, MGCMTBLDAT B
				WHERE 1=1
				 AND A.FACTORY = :CRASTOLSTS_N.FACTORY
				 AND A.CURR_USE_CNT >= A.LIMIT_USE_CNT
				 AND A.FACTORY = B.FACTORY
				 AND A.RES_ID = B.KEY_2
				 AND ( A.RES_ID LIKE 'US-E0%' OR A.RES_ID LIKE 'US-E1%' OR A.RES_ID LIKE 'US-E2%' OR A.RES_ID LIKE 'US-E3%' )
				 AND B.TABLE_NAME = '@PLC_RES_MAPPING'
                ORDER BY A.RES_ID, A.PART_NAME ;
            EXEC SQL OPEN CDB_CRASTOLSTS_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_CRASTOLSTS_CUR_3 CURSOR FOR
                SELECT 
                    A.FACTORY,
					A.RES_ID,
                    B.KEY_1,
                    TO_CHAR(A.CHANGE_CNT),
                    A.PART_NAME,
                    TO_CHAR(A.CURR_USE_CNT, '9,999,999,999') CMF_1,
                    A.MAX_USE_CNT,
                    TO_CHAR(A.LIMIT_USE_CNT, '9,999,999,999') CMF_2,
                    A.LINE_ID
                FROM CRASTOLSTS A, MGCMTBLDAT B
				WHERE 1=1
				 AND A.FACTORY = :CRASTOLSTS_N.FACTORY
				 AND A.CURR_USE_CNT >= A.LIMIT_USE_CNT
				 AND A.FACTORY = B.FACTORY
				 AND A.RES_ID = B.KEY_2
				 AND ( A.RES_ID LIKE 'US-E4%' OR A.RES_ID LIKE 'US-E5%' OR A.RES_ID LIKE 'US-E6%' OR A.RES_ID LIKE 'US-E7%' )
				 AND B.TABLE_NAME = '@PLC_RES_MAPPING'
                ORDER BY A.RES_ID, A.PART_NAME ;
            EXEC SQL OPEN CDB_CRASTOLSTS_CUR_3;
            break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_crastolsts", sel_type);
}


