            break;
    }

    DB_stop_query_timer("CDB_update_rsumhorwrk", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_rsumhorwrk(int sel_type, struct RSUMHORWRK_TAG *RSUMHORWRK)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMHORWRK_N_TAG RSUMHORWRK_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumhorwrk(&RSUMHORWRK_N, RSUMHORWRK);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_RSUMHORWRK_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    WORK_DATE,
                    WORK_SHIFT,
                    LINE_ID,
                    RES_ID,
                    MAT_ID,
                    OPER,
                    ORDER_ID,
                    FQC_GRADE,
                    FQC_POWER,
                    CM_KEY_1,
                    CM_KEY_2,
                    CM_KEY_3,
                    INPUT_QTY,
                    LOSS_QTY,
                    TIME01_QTY,
                    TIME02_QTY,
                    TIME03_QTY,
                    TIME04_QTY,
                    TIME05_QTY,
                    TIME06_QTY,
                    TIME07_QTY,
                    TIME08_QTY,
                    TIME09_QTY,
                    TIME10_QTY,
                    TIME11_QTY,
                    TIME12_QTY,
                    TIME13_QTY,
                    TIME14_QTY,
                    TIME15_QTY,
                    TIME16_QTY,
                    TIME17_QTY,
                    TIME18_QTY,
                    TIME19_QTY,
                    TIME20_QTY,
                    TIME21_QTY,
                    TIME22_QTY,
                    TIME23_QTY,
                    TIME24_QTY,
                    TIME01_LOSS_QTY,
                    TIME02_LOSS_QTY,
                    TIME03_LOSS_QTY,
                    TIME04_LOSS_QTY,
                    TIME05_LOSS_QTY,
                    TIME06_LOSS_QTY,
                    TIME07_LOSS_QTY,
                    TIME08_LOSS_QTY,
                    TIME09_LOSS_QTY,
                    TIME10_LOSS_QTY,
                    TIME11_LOSS_QTY,
                    TIME12_LOSS_QTY,
                    TIME13_LOSS_QTY,
                    TIME14_LOSS_QTY,
                    TIME15_LOSS_QTY,
                    TIME16_LOSS_QTY,
                    TIME17_LOSS_QTY,
                    TIME18_LOSS_QTY,
                    TIME19_LOSS_QTY,
                    TIME20_LOSS_QTY,
                    TIME21_LOSS_QTY,
                    TIME22_LOSS_QTY,
                    TIME23_LOSS_QTY,
                    TIME24_LOSS_QTY,
                    ETC1_QTY,
                    ETC2_QTY,
                    ETC3_QTY,
                    ETC4_QTY,
                    ETC5_QTY,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM RSUMHORWRK
                ORDER BY FACTORY ASC,
                    WORK_DATE ASC,
                    WORK_SHIFT ASC,
                    LINE_ID ASC,
                    RES_ID ASC,
                    MAT_ID ASC,
                    OPER ASC,
                    ORDER_ID ASC,
                    FQC_GRADE ASC,
                    FQC_POWER ASC,
                    CM_KEY_1 ASC,
                    CM_KEY_2 ASC,
                    CM_KEY_3 ASC;
            EXEC SQL OPEN CDB_RSUMHORWRK_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_rsumhorwrk", sel_type);
}


