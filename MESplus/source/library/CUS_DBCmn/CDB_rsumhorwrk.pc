/* Add Null Function */
void CDB_add_null_rsumhorwrk(struct RSUMHORWRK_N_TAG *RSUMHORWRK_N, struct RSUMHORWRK_TAG *RSUMHORWRK)
{
    /* memset by NULL */
    memset(RSUMHORWRK_N, '\0', sizeof(struct RSUMHORWRK_N_TAG));
    
    MEMCPY_AN(RSUMHORWRK_N->FACTORY, RSUMHORWRK->FACTORY, sizeof(RSUMHORWRK->FACTORY));
    MEMCPY_AN(RSUMHORWRK_N->WORK_DATE, RSUMHORWRK->WORK_DATE, sizeof(RSUMHORWRK->WORK_DATE));
    MEMCPY_AN(RSUMHORWRK_N->WORK_SHIFT, RSUMHORWRK->WORK_SHIFT, sizeof(RSUMHORWRK->WORK_SHIFT));
    MEMCPY_AN(RSUMHORWRK_N->LINE_ID, RSUMHORWRK->LINE_ID, sizeof(RSUMHORWRK->LINE_ID));
