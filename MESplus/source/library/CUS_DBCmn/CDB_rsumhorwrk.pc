/* SQL UPDATE Function */
void CDB_update_rsumhorwrk(int sel_type, struct RSUMHORWRK_TAG *RSUMHORWRK)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMHORWRK_N_TAG RSUMHORWRK_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumhorwrk(&RSUMHORWRK_N, RSUMHORWRK);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
