/* Del Null Function */
void CDB_del_null_cmmseqpdef(struct CMMSEQPDEF_N_TAG *CMMSEQPDEF_N, struct CMMSEQPDEF_TAG *CMMSEQPDEF)
{
    MEMCPY_DN(CMMSEQPDEF->FACTORY, CMMSEQPDEF_N->FACTORY, sizeof(CMMSEQPDEF->FACTORY));
    MEMCPY_DN(CMMSEQPDEF->EQUIP_ID, CMMSEQPDEF_N->EQUIP_ID, sizeof(CMMSEQPDEF->EQUIP_ID));
    MEMCPY_DN(CMMSEQPDEF->EQUIP_CODE, CMMSEQPDEF_N->EQUIP_CODE, sizeof(CMMSEQPDEF->EQUIP_CODE));
