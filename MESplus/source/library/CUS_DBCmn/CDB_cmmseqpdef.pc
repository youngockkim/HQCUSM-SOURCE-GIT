                    CREATE_TIME = :CMMSEQPDEF_N.CREATE_TIME,
                    UPDATE_USER_ID = :CMMSEQPDEF_N.UPDATE_USER_ID,
                    UPDATE_TIME = :CMMSEQPDEF_N.UPDATE_TIME
                WHERE FACTORY = :CMMSEQPDEF_N.FACTORY
                    AND EQUIP_ID = :CMMSEQPDEF_N.EQUIP_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_cmmseqpdef", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cmmseqpdef(int sel_type, struct CMMSEQPDEF_TAG *CMMSEQPDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMMSEQPDEF_N_TAG CMMSEQPDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cmmseqpdef(&CMMSEQPDEF_N, CMMSEQPDEF);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CMMSEQPDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    EQUIP_ID,
                    EQUIP_CODE,
                    EQUIP_NAME,
					EQUIP_TYPE,
                    EQUIP_NO,
                    MGT_DEPT_CODE,
                    MGT_USER_ID,
                    USE_DEPT_CODE,
                    USE_USER_ID,
                    USE_DIV,
                    CALI_DIV,
                    PARTNER_CODE,
                    PROP_NO,
                    SUPPLY_CODE,
                    EQUIP_MAKER,
                    EQUIP_MODEL,
                    EQUIP_PURPOSE,
                    EQUIP_FEATURE,
                    EQUIP_PLACE_CODE,
                    SERIAL_NO,
                    EQUIP_SPEC,
                    BUY_DATE,
                    BUY_COST,
                    CALI_CYCLE,
                    MSA_CYCLE,
                    EQUIP_DESC,
                    LAST_EQUIP_SEQ,
                    APPROVE_USER_ID,
                    APPROVE_FLAG,
                    MSA_FLAG,
                    SPC_FLAG,
                    CALI_FLAG,
                    CHECK_FLAG,
                    NONE_FLAG,
                    STANDARD_FLAG,
                    CMF_FLAG_01,
                    CMF_FLAG_02,
                    CMF_FLAG_03,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSEQPDEF
				WHERE FACTORY = :CMMSEQPDEF_N.FACTORY		
				    AND EQUIP_ID >= :CMMSEQPDEF_N.EQUIP_ID	
                ORDER BY FACTORY ASC,
                    EQUIP_ID ASC;
            EXEC SQL OPEN CDB_CMMSEQPDEF_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CMMSEQPDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    EQUIP_ID,
                    EQUIP_CODE,
                    EQUIP_NAME,
					EQUIP_TYPE,
                    EQUIP_NO,
                    MGT_DEPT_CODE,
                    MGT_USER_ID,
                    USE_DEPT_CODE,
                    USE_USER_ID,
                    USE_DIV,
                    CALI_DIV,
                    PARTNER_CODE,
                    PROP_NO,
                    SUPPLY_CODE,
                    EQUIP_MAKER,
                    EQUIP_MODEL,
                    EQUIP_PURPOSE,
                    EQUIP_FEATURE,
                    EQUIP_PLACE_CODE,
                    SERIAL_NO,
                    EQUIP_SPEC,
                    BUY_DATE,
                    BUY_COST,
                    CALI_CYCLE,
                    MSA_CYCLE,
                    EQUIP_DESC,
                    LAST_EQUIP_SEQ,
                    APPROVE_USER_ID,
                    APPROVE_FLAG,
                    MSA_FLAG,
                    SPC_FLAG,
                    CALI_FLAG,
                    CHECK_FLAG,
                    NONE_FLAG,
                    STANDARD_FLAG,
                    CMF_FLAG_01,
                    CMF_FLAG_02,
                    CMF_FLAG_03,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSEQPDEF
			    WHERE FACTORY = :CMMSEQPDEF_N.FACTORY		
				    AND EQUIP_ID >= :CMMSEQPDEF_N.EQUIP_ID			
					AND USE_DEPT_CODE LIKE '%' || TRIM(:CMMSEQPDEF_N.USE_DEPT_CODE) || '%'
					AND MGT_DEPT_CODE LIKE '%' || TRIM(:CMMSEQPDEF_N.MGT_DEPT_CODE) || '%'
					AND USE_DIV LIKE '%' || TRIM(:CMMSEQPDEF_N.USE_DIV) || '%'
                ORDER BY FACTORY ASC,
                    EQUIP_ID ASC;
            EXEC SQL OPEN CDB_CMMSEQPDEF_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_CMMSEQPDEF_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    EQUIP_ID,
                    EQUIP_CODE,
                    EQUIP_NAME,
					EQUIP_TYPE,
                    EQUIP_NO,
                    MGT_DEPT_CODE,
                    MGT_USER_ID,
                    USE_DEPT_CODE,
                    USE_USER_ID,
                    USE_DIV,
                    CALI_DIV,
                    PARTNER_CODE,
                    PROP_NO,
                    SUPPLY_CODE,
                    EQUIP_MAKER,
                    EQUIP_MODEL,
                    EQUIP_PURPOSE,
                    EQUIP_FEATURE,
                    EQUIP_PLACE_CODE,
                    SERIAL_NO,
                    EQUIP_SPEC,
                    BUY_DATE,
                    BUY_COST,
                    CALI_CYCLE,
                    MSA_CYCLE,
                    EQUIP_DESC,
                    LAST_EQUIP_SEQ,
                    APPROVE_USER_ID,
                    APPROVE_FLAG,
                    MSA_FLAG,
                    SPC_FLAG,
                    CALI_FLAG,
                    CHECK_FLAG,
                    NONE_FLAG,
                    STANDARD_FLAG,
                    CMF_FLAG_01,
                    CMF_FLAG_02,
                    CMF_FLAG_03,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSEQPDEF
			    WHERE FACTORY = :CMMSEQPDEF_N.FACTORY	
				    AND EQUIP_ID >= :CMMSEQPDEF_N.EQUIP_ID 				
					AND USE_DEPT_CODE LIKE '%' || TRIM(:CMMSEQPDEF_N.USE_DEPT_CODE) || '%'
					AND MGT_DEPT_CODE LIKE '%' || TRIM(:CMMSEQPDEF_N.MGT_DEPT_CODE) || '%'
					AND USE_DIV = :CMMSEQPDEF_N.USE_DIV
					AND CALI_FLAG = :CMMSEQPDEF_N.CALI_FLAG
                ORDER BY FACTORY ASC,
                    EQUIP_ID ASC;
            EXEC SQL OPEN CDB_CMMSEQPDEF_CUR_3;
            break;

		case 4:
            EXEC SQL DECLARE CDB_CMMSEQPDEF_CUR_4 CURSOR FOR
                SELECT 
                    EQUIP_ID,
                    EQUIP_NAME
                FROM CMMSEQPDEF
				WHERE FACTORY = :CMMSEQPDEF_N.FACTORY	
				    AND EQUIP_ID >= :CMMSEQPDEF_N.EQUIP_ID 		
					AND EQUIP_TYPE LIKE '%' || TRIM(:CMMSEQPDEF_N.EQUIP_TYPE) || '%'		
					AND USE_DIV = :CMMSEQPDEF_N.USE_DIV
					AND CALI_FLAG = :CMMSEQPDEF_N.CALI_FLAG
					AND STANDARD_FLAG = :CMMSEQPDEF_N.STANDARD_FLAG
                ORDER BY FACTORY ASC,
                    EQUIP_ID ASC;
            EXEC SQL OPEN CDB_CMMSEQPDEF_CUR_4;
            break;

		case 5:
            EXEC SQL DECLARE CDB_CMMSEQPDEF_CUR_5 CURSOR FOR
                SELECT 
                    EQUIP_ID,
                    EQUIP_NAME
                FROM CMMSEQPDEF
			    WHERE FACTORY = :CMMSEQPDEF_N.FACTORY		
				    AND EQUIP_ID >= :CMMSEQPDEF_N.EQUIP_ID		
					AND EQUIP_TYPE LIKE '%' || TRIM(:CMMSEQPDEF_N.EQUIP_TYPE) || '%'	
					AND USE_DEPT_CODE LIKE '%' || TRIM(:CMMSEQPDEF_N.USE_DEPT_CODE) || '%'
					AND MGT_DEPT_CODE LIKE '%' || TRIM(:CMMSEQPDEF_N.MGT_DEPT_CODE) || '%'
					AND USE_DIV LIKE '%' || TRIM(:CMMSEQPDEF_N.USE_DIV) || '%'
                ORDER BY FACTORY ASC,
                    EQUIP_ID ASC;
            EXEC SQL OPEN CDB_CMMSEQPDEF_CUR_5;
            break;

		case 6:
            EXEC SQL DECLARE CDB_CMMSEQPDEF_CUR_6 CURSOR FOR
                SELECT 
                    EQUIP_ID,
                    EQUIP_NAME
                FROM CMMSEQPDEF
			    WHERE FACTORY = :CMMSEQPDEF_N.FACTORY	
				    AND EQUIP_ID >= :CMMSEQPDEF_N.EQUIP_ID 		
					AND EQUIP_TYPE LIKE '%' || TRIM(:CMMSEQPDEF_N.EQUIP_TYPE) || '%'		
					AND USE_DEPT_CODE LIKE '%' || TRIM(:CMMSEQPDEF_N.USE_DEPT_CODE) || '%'
					AND MGT_DEPT_CODE LIKE '%' || TRIM(:CMMSEQPDEF_N.MGT_DEPT_CODE) || '%'
					AND USE_DIV = :CMMSEQPDEF_N.USE_DIV
					AND CALI_FLAG = :CMMSEQPDEF_N.CALI_FLAG
                ORDER BY FACTORY ASC,
                    EQUIP_ID ASC;
            EXEC SQL OPEN CDB_CMMSEQPDEF_CUR_6;
            break;

		case 7:
            EXEC SQL DECLARE CDB_CMMSEQPDEF_CUR_7 CURSOR FOR
                SELECT 
                    EQUIP_ID,
                    EQUIP_NAME
                FROM CMMSEQPDEF
			    WHERE FACTORY = :CMMSEQPDEF_N.FACTORY	
				    AND EQUIP_ID >= :CMMSEQPDEF_N.EQUIP_ID 		
					AND EQUIP_TYPE LIKE '%' || TRIM(:CMMSEQPDEF_N.EQUIP_TYPE) || '%'		
					AND USE_DEPT_CODE LIKE '%' || TRIM(:CMMSEQPDEF_N.USE_DEPT_CODE) || '%'
					AND MGT_DEPT_CODE LIKE '%' || TRIM(:CMMSEQPDEF_N.MGT_DEPT_CODE) || '%'
					AND USE_DIV = :CMMSEQPDEF_N.USE_DIV
					AND MSA_FLAG = :CMMSEQPDEF_N.MSA_FLAG
                ORDER BY FACTORY ASC,
                    EQUIP_ID ASC;
            EXEC SQL OPEN CDB_CMMSEQPDEF_CUR_7;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cmmseqpdef", sel_type);
}


