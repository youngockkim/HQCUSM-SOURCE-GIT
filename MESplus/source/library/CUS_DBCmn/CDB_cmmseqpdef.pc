                    NONE_FLAG = :CMMSEQPDEF_N.NONE_FLAG,
                    STANDARD_FLAG = :CMMSEQPDEF_N.STANDARD_FLAG,
                    CMF_FLAG_01 = :CMMSEQPDEF_N.CMF_FLAG_01,
                    CMF_FLAG_02 = :CMMSEQPDEF_N.CMF_FLAG_02,
