        CDB_del_null_cmmseqpdef(&CMMSEQPDEF_N, CMMSEQPDEF);
    }

    DB_stop_query_timer("CDB_fetch_cmmseqpdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cmmseqpdef(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CMMSEQPDEF_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CMMSEQPDEF_CUR_2;
            break;

		case 3:
            EXEC SQL CLOSE CDB_CMMSEQPDEF_CUR_3;
            break;

		case 4:
            EXEC SQL CLOSE CDB_CMMSEQPDEF_CUR_4;
            break;

		case 5:
            EXEC SQL CLOSE CDB_CMMSEQPDEF_CUR_5;
            break;

		case 6:
            EXEC SQL CLOSE CDB_CMMSEQPDEF_CUR_6;
            break;

		case 7:
            EXEC SQL CLOSE CDB_CMMSEQPDEF_CUR_7;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cmmseqpdef", sel_type);
}


/* Initialize Function */
void CDB_init_cmmseqpdef(struct CMMSEQPDEF_TAG *CMMSEQPDEF)
{
    /* memset by Space */
    memset(CMMSEQPDEF, ' ', sizeof(struct CMMSEQPDEF_TAG));
    
    CMMSEQPDEF->BUY_COST = 0;
    CMMSEQPDEF->CALI_CYCLE = 0;
    CMMSEQPDEF->MSA_CYCLE = 0;
    CMMSEQPDEF->LAST_EQUIP_SEQ = 0;
}


/* Add Null Function */
void CDB_add_null_cmmseqpdef(struct CMMSEQPDEF_N_TAG *CMMSEQPDEF_N, struct CMMSEQPDEF_TAG *CMMSEQPDEF)
{
    /* memset by NULL */
    memset(CMMSEQPDEF_N, '\0', sizeof(struct CMMSEQPDEF_N_TAG));
    
    MEMCPY_AN(CMMSEQPDEF_N->FACTORY, CMMSEQPDEF->FACTORY, sizeof(CMMSEQPDEF->FACTORY));
    MEMCPY_AN(CMMSEQPDEF_N->EQUIP_ID, CMMSEQPDEF->EQUIP_ID, sizeof(CMMSEQPDEF->EQUIP_ID));
