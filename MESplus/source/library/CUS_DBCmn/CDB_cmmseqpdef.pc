                    EQUIP_SPEC = :CMMSEQPDEF_N.EQUIP_SPEC,
                    BUY_DATE = :CMMSEQPDEF_N.BUY_DATE,
                    BUY_COST = :CMMSEQPDEF_N.BUY_COST,
                    CALI_CYCLE = :CMMSEQPDEF_N.CALI_CYCLE,
                    MSA_CYCLE = :CMMSEQPDEF_N.MSA_CYCLE,
                    EQUIP_DESC = :CMMSEQPDEF_N.EQUIP_DESC,
                    LAST_EQUIP_SEQ = :CMMSEQPDEF_N.LAST_EQUIP_SEQ,
                    APPROVE_USER_ID = :CMMSEQPDEF_N.APPROVE_USER_ID,
                    APPROVE_FLAG = :CMMSEQPDEF_N.APPROVE_FLAG,
