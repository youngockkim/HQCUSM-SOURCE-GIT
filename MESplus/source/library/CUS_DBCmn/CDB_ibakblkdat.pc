    MEMCPY_AN(IBAKBLKDAT_N->SQL_DML_COUNT, IBAKBLKDAT->SQL_DML_COUNT, sizeof(IBAKBLKDAT->SQL_DML_COUNT));
    MEMCPY_AN(IBAKBLKDAT_N->ZPICODE, IBAKBLKDAT->ZPICODE, sizeof(IBAKBLKDAT->ZPICODE));
    MEMCPY_AN(IBAKBLKDAT_N->ZPIMSGID, IBAKBLKDAT->ZPIMSGID, sizeof(IBAKBLKDAT->ZPIMSGID));
