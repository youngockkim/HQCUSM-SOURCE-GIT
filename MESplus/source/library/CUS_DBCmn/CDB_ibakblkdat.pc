    MEMCPY_AN(IBAKBLKDAT_N->RETURN_MSG, IBAKBLKDAT->RETURN_MSG, sizeof(IBAKBLKDAT->RETURN_MSG));
    MEMCPY_AN(IBAKBLKDAT_N->ZIFERNAM, IBAKBLKDAT->ZIFERNAM, sizeof(IBAKBLKDAT->ZIFERNAM));
    MEMCPY_AN(IBAKBLKDAT_N->ZIFDATE, IBAKBLKDAT->ZIFDATE, sizeof(IBAKBLKDAT->ZIFDATE));
    MEMCPY_AN(IBAKBLKDAT_N->ZIFTIME, IBAKBLKDAT->ZIFTIME, sizeof(IBAKBLKDAT->ZIFTIME));
    IBAKBLKDAT_N->ZPISTAT[0] = IBAKBLKDAT->ZPISTAT;
    MEMCPY_AN(IBAKBLKDAT_N->ZPIMSG, IBAKBLKDAT->ZPIMSG, sizeof(IBAKBLKDAT->ZPIMSG));
}


