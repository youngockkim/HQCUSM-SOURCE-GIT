                    IMPP = :IERPOPRCFM_N.IMPP,
                    VMPP = :IERPOPRCFM_N.VMPP,
                    PMPP = :IERPOPRCFM_N.PMPP,
                    TEMP = :IERPOPRCFM_N.TEMP,
                    ENVTEMP = :IERPOPRCFM_N.ENVTEMP,
                    SURFTEMP = :IERPOPRCFM_N.SURFTEMP,
                    SUN = :IERPOPRCFM_N.SUN,
