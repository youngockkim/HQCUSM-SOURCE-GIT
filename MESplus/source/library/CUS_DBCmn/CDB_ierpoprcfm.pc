/* SQL SELECT_SCALAR Function */
double CDB_select_ierpoprcfm_scalar(int sel_type, struct IERPOPRCFM_TAG *IERPOPRCFM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IERPOPRCFM_N_TAG IERPOPRCFM_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ierpoprcfm(&IERPOPRCFM_N, IERPOPRCFM);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM IERPOPRCFM
                WHERE DOC_ID = :IERPOPRCFM_N.DOC_ID
                    AND SITE_ID = :IERPOPRCFM_N.SITE_ID
                    AND PROD_ORDER_NO = :IERPOPRCFM_N.PROD_ORDER_NO
                    AND MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO
                    AND WORK_CENTER = :IERPOPRCFM_N.WORK_CENTER
                    AND ACTION_TYPE = :IERPOPRCFM_N.ACTION_TYPE;
            break;

        case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM IERPOPRCFM
                WHERE SITE_ID = :IERPOPRCFM_N.SITE_ID
                    AND PROD_ORDER_NO = :IERPOPRCFM_N.PROD_ORDER_NO
                    AND MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO
                    AND WORK_CENTER = :IERPOPRCFM_N.WORK_CENTER;
            break;

		case 3:
            EXEC SQL SELECT count(*) 
                INTO :d_value
				FROM (
				SELECT *
                FROM IERPOPRCFM
                WHERE SITE_ID = :IERPOPRCFM_N.SITE_ID
                    --AND PROD_ORDER_NO = :IERPOPRCFM_N.PROD_ORDER_NO // IS-21-10-046
                    AND MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO
                    --AND WORK_CENTER = :IERPOPRCFM_N.WORK_CENTER	//IS-21-01-005
					AND ZPISTAT != 'M'
					AND QUALITY_GRADE != 'R01'
				UNION
				SELECT *
                FROM IBAKOPRCFM
                WHERE SITE_ID = :IERPOPRCFM_N.SITE_ID
                    --AND PROD_ORDER_NO = :IERPOPRCFM_N.PROD_ORDER_NO // IS-21-10-046
                    AND MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO
                    --AND WORK_CENTER = :IERPOPRCFM_N.WORK_CENTER		//IS-21-01-005
					AND ZPISTAT != 'M'
					AND QUALITY_GRADE != 'R01'
				) ;
            break;
		
		case 4:
            EXEC SQL SELECT count(*) 
                INTO :d_value
				FROM (
				SELECT *
                FROM IERPOPRCFM
                WHERE SITE_ID = :IERPOPRCFM_N.SITE_ID
                    AND MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO
                	AND ZPISTAT != 'M'
				UNION
				SELECT *
                FROM IBAKOPRCFM
                WHERE SITE_ID = :IERPOPRCFM_N.SITE_ID
                    AND MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO
					AND ZPISTAT != 'M'
				) ;
            break;

        case 5:
            EXEC SQL SELECT count(*) 
                INTO :d_value
				FROM (
				SELECT *
                FROM IERPOPRCFM
                WHERE SITE_ID = :IERPOPRCFM_N.SITE_ID
                    AND MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO
                	AND ZPISTAT = 'S'
                    AND ERP_FLAG = 'S'
				UNION
				SELECT *
                FROM IBAKOPRCFM
                WHERE SITE_ID = :IERPOPRCFM_N.SITE_ID
                    AND MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO
					AND ZPISTAT = 'S'
                    AND ERP_FLAG = 'S'
				) ;
            break;
			
           case 6:
            EXEC SQL SELECT count(*) 
                INTO :d_value
				FROM (
				SELECT *
                FROM IERPOPRCFM
                WHERE 1 = 1
                    AND MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO
                	AND ZPISTAT != 'M'
				UNION
				SELECT *
                FROM IBAKOPRCFM
                WHERE 1 = 1
                    AND MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO
					AND ZPISTAT != 'M'
				) ;
            break;

		case 7:
            EXEC SQL SELECT count(*) 
                INTO :d_value
				FROM (
				SELECT *
                FROM IERPOPRCFM
                WHERE SITE_ID = :IERPOPRCFM_N.SITE_ID
                    AND PROD_ORDER_NO = :IERPOPRCFM_N.PROD_ORDER_NO // IS-21-10-046
                    AND MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO
                    --AND WORK_CENTER = :IERPOPRCFM_N.WORK_CENTER	//IS-21-01-005
					AND ZPISTAT != 'M'
					AND QUALITY_GRADE != 'R01'
				UNION
				SELECT *
                FROM IBAKOPRCFM
                WHERE SITE_ID = :IERPOPRCFM_N.SITE_ID
                    AND PROD_ORDER_NO = :IERPOPRCFM_N.PROD_ORDER_NO // IS-21-10-046
                    AND MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO
                    --AND WORK_CENTER = :IERPOPRCFM_N.WORK_CENTER		//IS-21-01-005
					AND ZPISTAT != 'M'
					AND QUALITY_GRADE != 'R01'
				) ;
            break;

        case 8:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM IERPOPRCFM
                WHERE MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO;

            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_ierpoprcfm_scalar", sel_type);

    return d_value;
}


/* SQL DELETE Function */
void CDB_delete_ierpoprcfm(int sel_type, struct IERPOPRCFM_TAG *IERPOPRCFM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IERPOPRCFM_N_TAG IERPOPRCFM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ierpoprcfm(&IERPOPRCFM_N, IERPOPRCFM);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM IERPOPRCFM
                WHERE DOC_ID = :IERPOPRCFM_N.DOC_ID
                    AND SITE_ID = :IERPOPRCFM_N.SITE_ID
                    AND PROD_ORDER_NO = :IERPOPRCFM_N.PROD_ORDER_NO
                    AND MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO
                    AND WORK_CENTER = :IERPOPRCFM_N.WORK_CENTER
                    AND ACTION_TYPE = :IERPOPRCFM_N.ACTION_TYPE;
            break;
		case 2:
            EXEC SQL DELETE FROM IERPOPRCFM
				WHERE ERP_FLAG = 'S';
            break;
		
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_delete_ierpoprcfm", sel_type);
}


