                    FQC_POWER = :IERPOPRCFM_N.FQC_POWER,
                    FQC_OPERATOR = :IERPOPRCFM_N.FQC_OPERATOR,
                    OSC = :IERPOPRCFM_N.OSC,
                    ESC = :IERPOPRCFM_N.ESC,
                    EL = :IERPOPRCFM_N.EL,
                    FLASHER_CODE = :IERPOPRCFM_N.FLASHER_CODE,
                    MODULE_CREATEDATE = :IERPOPRCFM_N.MODULE_CREATEDATE,
                    DELIVERY_NOTE = :IERPOPRCFM_N.DELIVERY_NOTE,
                    DELIVERY_NOTE2 = :IERPOPRCFM_N.DELIVERY_NOTE2,
                    ARTICLE_NO = :IERPOPRCFM_N.ARTICLE_NO,
                    ARTICLE_NO2 = :IERPOPRCFM_N.ARTICLE_NO2,
                    ARTICLE_CODE = :IERPOPRCFM_N.ARTICLE_CODE,
                    COLOR_CLASS = :IERPOPRCFM_N.COLOR_CLASS,
                    MIXING_RATIO = :IERPOPRCFM_N.MIXING_RATIO,
                    DEGRATION = :IERPOPRCFM_N.DEGRATION,
                    INF_USER_ID = :IERPOPRCFM_N.INF_USER_ID,
                    INF_TIME = :IERPOPRCFM_N.INF_TIME,
                    INF_PROC_TIME = :IERPOPRCFM_N.INF_PROC_TIME,
                    CMF_1 = :IERPOPRCFM_N.CMF_1,
                    CMF_2 = :IERPOPRCFM_N.CMF_2,
                    CMF_3 = :IERPOPRCFM_N.CMF_3,
                    CMF_4 = :IERPOPRCFM_N.CMF_4,
                    CMF_5 = :IERPOPRCFM_N.CMF_5,
                    DATA_FLAG = :IERPOPRCFM_N.DATA_FLAG,
                    ZIFERNAM = :IERPOPRCFM_N.ZIFERNAM,
                    ZIFDATE = :IERPOPRCFM_N.ZIFDATE,
                    ZIFTIME = :IERPOPRCFM_N.ZIFTIME,
                    ZPICODE = :IERPOPRCFM_N.ZPICODE,
                    ZPIMSGID = :IERPOPRCFM_N.ZPIMSGID,
                    ZPISTAT = :IERPOPRCFM_N.ZPISTAT,
                    ZPIMSG = :IERPOPRCFM_N.ZPIMSG,
                    RETURN_TYPE = :IERPOPRCFM_N.RETURN_TYPE,
                    RETURN_MSG = :IERPOPRCFM_N.RETURN_MSG,
                    ERP_DATE = :IERPOPRCFM_N.ERP_DATE,
                    ERP_TIME = :IERPOPRCFM_N.ERP_TIME,
                    ERP_FLAG = :IERPOPRCFM_N.ERP_FLAG,
                    ERP_MSG = :IERPOPRCFM_N.ERP_MSG,
                    IF_FLAG = :IERPOPRCFM_N.IF_FLAG
                WHERE DOC_ID = :IERPOPRCFM_N.DOC_ID
                    AND SITE_ID = :IERPOPRCFM_N.SITE_ID
                    AND PROD_ORDER_NO = :IERPOPRCFM_N.PROD_ORDER_NO
                    AND MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO
                    AND WORK_CENTER = :IERPOPRCFM_N.WORK_CENTER
                    AND ACTION_TYPE = :IERPOPRCFM_N.ACTION_TYPE;
            break;

        case 2:
            EXEC SQL UPDATE IERPOPRCFM SET
					INF_PROC_TIME = :IERPOPRCFM_N.INF_PROC_TIME,
                    RETURN_TYPE = 'E',
                    RETURN_MSG = :IERPOPRCFM_N.RETURN_MSG
                WHERE DOC_ID = :IERPOPRCFM_N.DOC_ID
                    AND SITE_ID = :IERPOPRCFM_N.SITE_ID
                    AND PROD_ORDER_NO = :IERPOPRCFM_N.PROD_ORDER_NO
                    AND MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND OPER_NO = :IERPOPRCFM_N.OPER_NO
                    AND WORK_CENTER = :IERPOPRCFM_N.WORK_CENTER
                    AND ACTION_TYPE = :IERPOPRCFM_N.ACTION_TYPE;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_ierpoprcfm", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_ierpoprcfm(int sel_type, struct IERPOPRCFM_TAG *IERPOPRCFM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IERPOPRCFM_N_TAG IERPOPRCFM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ierpoprcfm(&IERPOPRCFM_N, IERPOPRCFM);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IERPOPRCFM_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_ORDER_NO,
                    MODULE_ID,
                    OPER_NO,
                    WORK_CENTER,
                    ACTION_TYPE,
                    MATE_NO,
                    PROD_QTY,
                    SCRAP_QTY,
                    UNIT_ID,
                    FQC_DATE,
                    QUALITY_GRADE,
                    POWER_GRADE,
                    SHIFT,
                    LOCATION,
                    EFF,
                    RSH,
                    RS,
                    FF,
                    ISC,
                    VOC,
                    IMPP,
                    VMPP,
                    PMPP,
                    TEMP,
                    ENVTEMP,
                    SURFTEMP,
                    SUN,
                    FQC_GRADE,
                    FQC_POWER,
                    FQC_OPERATOR,
                    OSC,
                    ESC,
                    EL,
                    FLASHER_CODE,
                    MODULE_CREATEDATE,
                    DELIVERY_NOTE,
                    DELIVERY_NOTE2,
                    ARTICLE_NO,
                    ARTICLE_NO2,
                    ARTICLE_CODE,
                    COLOR_CLASS,
                    MIXING_RATIO,
                    DEGRATION,
                    INF_USER_ID,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPICODE,
                    ZPIMSGID,
                    ZPISTAT,
                    ZPIMSG,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ERP_DATE,
                    ERP_TIME,
                    ERP_FLAG,
                    ERP_MSG,
                    IF_FLAG
                FROM IERPOPRCFM
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_ORDER_NO ASC,
                    MODULE_ID ASC,
                    OPER_NO ASC,
                    WORK_CENTER ASC,
                    ACTION_TYPE ASC;
            EXEC SQL OPEN CDB_IERPOPRCFM_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_IERPOPRCFM_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_ORDER_NO,
                    MODULE_ID,
                    OPER_NO,
                    WORK_CENTER,
                    ACTION_TYPE,
                    MATE_NO,
                    PROD_QTY,
                    SCRAP_QTY,
                    UNIT_ID,
                    FQC_DATE,
                    QUALITY_GRADE,
                    POWER_GRADE,
                    SHIFT,
                    LOCATION,
                    EFF,
                    RSH,
                    RS,
                    FF,
                    ISC,
                    VOC,
                    IMPP,
                    VMPP,
                    PMPP,
                    TEMP,
                    ENVTEMP,
                    SURFTEMP,
                    SUN,
                    FQC_GRADE,
                    FQC_POWER,
                    FQC_OPERATOR,
                    OSC,
                    ESC,
                    EL,
                    FLASHER_CODE,
                    MODULE_CREATEDATE,
                    DELIVERY_NOTE,
                    DELIVERY_NOTE2,
                    ARTICLE_NO,
                    ARTICLE_NO2,
                    ARTICLE_CODE,
                    COLOR_CLASS,
                    MIXING_RATIO,
                    DEGRATION,
                    INF_USER_ID,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPICODE,
                    ZPIMSGID,
                    ZPISTAT,
                    ZPIMSG,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ERP_DATE,
                    ERP_TIME,
                    ERP_FLAG,
                    ERP_MSG,
                    IF_FLAG
                FROM IERPOPRCFM
				WHERE RETURN_TYPE <> 'E'
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_ORDER_NO ASC,
                    MODULE_ID ASC,
                    OPER_NO ASC,
                    WORK_CENTER ASC,
                    ACTION_TYPE ASC;
            EXEC SQL OPEN CDB_IERPOPRCFM_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_ierpoprcfm", sel_type);
}


