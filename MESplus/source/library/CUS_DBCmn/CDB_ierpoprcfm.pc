                    :IERPOPRCFM_N.IF_FLAG
                FROM IERPOPRCFM
                WHERE MODULE_ID = :IERPOPRCFM_N.MODULE_ID
                    AND DOC_ID = ( SELECT MAX(DOC_ID) FROM IERPOPRCFM
										WHERE MODULE_ID = :IERPOPRCFM_N.MODULE_ID
										) 
					AND ZPISTAT = 'S'
					AND ERP_FLAG = 'S'
					AND ROWNUM = 1;
            break;

		case 999:
            EXEC SQL SELECT 
                     NVL(MAX(DOC_ID), '201901021117565690000'),
					to_char(SYSTIMESTAMP, 'YYYYMMDDHH24MISSFF7')
                INTO 
                    :IERPOPRCFM_N.DOC_ID,
					:IERPOPRCFM_N.CMF_1
                FROM IERPOPRCFM
               ;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_ierpoprcfm(&IERPOPRCFM_N, IERPOPRCFM);
    }

    DB_stop_query_timer("CDB_select_ierpoprcfm", sel_type);
}


