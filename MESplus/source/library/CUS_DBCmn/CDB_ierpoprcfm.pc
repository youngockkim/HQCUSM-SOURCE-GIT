/* SQL UPDATE Function */
void CDB_update_ierpoprcfm(int sel_type, struct IERPOPRCFM_TAG *IERPOPRCFM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IERPOPRCFM_N_TAG IERPOPRCFM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ierpoprcfm(&IERPOPRCFM_N, IERPOPRCFM);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE IERPOPRCFM SET
                    MATE_NO = :IERPOPRCFM_N.MATE_NO,
                    PROD_QTY = :IERPOPRCFM_N.PROD_QTY,
                    SCRAP_QTY = :IERPOPRCFM_N.SCRAP_QTY,
