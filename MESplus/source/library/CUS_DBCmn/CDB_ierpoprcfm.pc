/* SQL CURSOR CLOSE Function */
void CDB_close_ierpoprcfm(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IERPOPRCFM_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IERPOPRCFM_CUR_2;
            break;
			
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ierpoprcfm", sel_type);
}


/* Initialize Function */
void CDB_init_ierpoprcfm(struct IERPOPRCFM_TAG *IERPOPRCFM)
{
    /* memset by Space */
    memset(IERPOPRCFM, ' ', sizeof(struct IERPOPRCFM_TAG));
    
}


/* Add Null Function */
void CDB_add_null_ierpoprcfm(struct IERPOPRCFM_N_TAG *IERPOPRCFM_N, struct IERPOPRCFM_TAG *IERPOPRCFM)
{
    /* memset by NULL */
    memset(IERPOPRCFM_N, '\0', sizeof(struct IERPOPRCFM_N_TAG));
    
    MEMCPY_AN(IERPOPRCFM_N->DOC_ID, IERPOPRCFM->DOC_ID, sizeof(IERPOPRCFM->DOC_ID));
    MEMCPY_AN(IERPOPRCFM_N->SITE_ID, IERPOPRCFM->SITE_ID, sizeof(IERPOPRCFM->SITE_ID));
    MEMCPY_AN(IERPOPRCFM_N->PROD_ORDER_NO, IERPOPRCFM->PROD_ORDER_NO, sizeof(IERPOPRCFM->PROD_ORDER_NO));
    MEMCPY_AN(IERPOPRCFM_N->MODULE_ID, IERPOPRCFM->MODULE_ID, sizeof(IERPOPRCFM->MODULE_ID));
    MEMCPY_AN(IERPOPRCFM_N->OPER_NO, IERPOPRCFM->OPER_NO, sizeof(IERPOPRCFM->OPER_NO));
