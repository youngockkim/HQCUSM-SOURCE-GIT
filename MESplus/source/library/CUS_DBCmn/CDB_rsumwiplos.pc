                    AND CM_KEY_5 = :RSUMWIPLOS_N.CM_KEY_5
                    AND LOSS_CODE = :RSUMWIPLOS_N.LOSS_CODE;
            break;

        case 2:
            EXEC SQL UPDATE RSUMWIPLOS SET
                    LOSS_QTY = :RSUMWIPLOS_N.LOSS_QTY,
                    LOSS_TYPE = :RSUMWIPLOS_N.LOSS_TYPE,
                    LOSS_GROUP = :RSUMWIPLOS_N.LOSS_GROUP,
                    LOSS_COMMENT = :RSUMWIPLOS_N.LOSS_COMMENT,
                    ORDER_ID = :RSUMWIPLOS_N.ORDER_ID,
                    CMF_1 = :RSUMWIPLOS_N.CMF_1,
                    CMF_2 = :RSUMWIPLOS_N.CMF_2,
                    CMF_3 = :RSUMWIPLOS_N.CMF_3,
                    CMF_4 = :RSUMWIPLOS_N.CMF_4,
                    CMF_5 = :RSUMWIPLOS_N.CMF_5,
                    LINE_ID = :RSUMWIPLOS_N.LINE_ID,
                    WORK_SHIFT = :RSUMWIPLOS_N.WORK_SHIFT,
                    WORK_MONTH = :RSUMWIPLOS_N.WORK_MONTH,
                    WORK_WEEK = :RSUMWIPLOS_N.WORK_WEEK,
                    WORK_DAYS = :RSUMWIPLOS_N.WORK_DAYS,
                    WORK_DAY_OF_WEEK = :RSUMWIPLOS_N.WORK_DAY_OF_WEEK,
                    UPDATE_USER_ID = :RSUMWIPLOS_N.UPDATE_USER_ID,
                    UPDATE_TIME = :RSUMWIPLOS_N.UPDATE_TIME
                WHERE WORK_DATE = :RSUMWIPLOS_N.WORK_DATE
                    AND FACTORY = :RSUMWIPLOS_N.FACTORY
                    AND RES_ID = :RSUMWIPLOS_N.RES_ID
                    AND LOSS_OPER = :RSUMWIPLOS_N.LOSS_OPER
                    AND CM_KEY_1 = :RSUMWIPLOS_N.CM_KEY_1
                    AND CM_KEY_2 = :RSUMWIPLOS_N.CM_KEY_2
                    AND CM_KEY_3 = :RSUMWIPLOS_N.CM_KEY_3;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_rsumwiplos", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_rsumwiplos(int sel_type, struct RSUMWIPLOS_TAG *RSUMWIPLOS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMWIPLOS_N_TAG RSUMWIPLOS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumwiplos(&RSUMWIPLOS_N, RSUMWIPLOS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_RSUMWIPLOS_CUR_1 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    FACTORY,
                    RES_ID,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    LOSS_OPER,
                    LOT_TYPE,
                    CM_KEY_1,
                    CM_KEY_2,
                    CM_KEY_3,
                    CM_KEY_4,
                    CM_KEY_5,
                    LOSS_CODE,
                    LOSS_QTY,
                    LOSS_TYPE,
                    LOSS_GROUP,
                    LOSS_COMMENT,
                    ORDER_ID,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    LINE_ID,
                    WORK_SHIFT,
                    WORK_MONTH,
                    WORK_WEEK,
                    WORK_DAYS,
                    WORK_DAY_OF_WEEK,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM RSUMWIPLOS
                ORDER BY WORK_DATE ASC,
                    FACTORY ASC,
                    RES_ID ASC,
                    MAT_ID ASC,
                    MAT_VER ASC,
                    FLOW ASC,
                    FLOW_SEQ_NUM ASC,
                    LOSS_OPER ASC,
                    LOT_TYPE ASC,
                    CM_KEY_1 ASC,
                    CM_KEY_2 ASC,
                    CM_KEY_3 ASC,
                    CM_KEY_4 ASC,
                    CM_KEY_5 ASC,
                    LOSS_CODE ASC;
            EXEC SQL OPEN CDB_RSUMWIPLOS_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE CDB_RSUMWIPLOS_CUR_2 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    FACTORY,
                    RES_ID,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    LOSS_OPER,
                    LOT_TYPE,
                    CM_KEY_1,
                    CM_KEY_2,
                    CM_KEY_3,
                    CM_KEY_4,
                    CM_KEY_5,
                    LOSS_CODE,
                    LOSS_QTY,
                    LOSS_TYPE,
                    LOSS_GROUP,
                    LOSS_COMMENT,
                    ORDER_ID,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    LINE_ID,
                    WORK_SHIFT,
                    WORK_MONTH,
                    WORK_WEEK,
                    WORK_DAYS,
                    WORK_DAY_OF_WEEK,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM RSUMWIPLOS
                WHERE FACTORY = :RSUMWIPLOS_N.FACTORY
	                AND WORK_DATE >= :DBC_Q_COND_N.FROM_DATE 
	                AND WORK_DATE <= :DBC_Q_COND_N.TO_DATE
                    AND CM_KEY_1 LIKE :RSUMWIPLOS_N.CM_KEY_1
                    AND CM_KEY_2 LIKE :RSUMWIPLOS_N.CM_KEY_2
                    AND CM_KEY_3 <> 'C006'
                ORDER BY WORK_DATE ASC,
                    FACTORY ASC,
                    CM_KEY_1 ASC,
                    CM_KEY_2 ASC,
                    LOSS_OPER ASC,
                    RES_ID ASC,
                    CM_KEY_3 ASC;
            EXEC SQL OPEN CDB_RSUMWIPLOS_CUR_2;
            break;

 case 3:											/* IS-20-09-182  */					
            EXEC SQL DECLARE CDB_RSUMWIPLOS_CUR_3 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    FACTORY,
                    RES_ID,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    LOSS_OPER,
                    LOT_TYPE,
                    CM_KEY_1,
                    CM_KEY_2,
                    CM_KEY_3,
                    CM_KEY_4,
                    CM_KEY_5,
                    LOSS_CODE,
                    LOSS_QTY,
                    LOSS_TYPE,
                    LOSS_GROUP,
                    LOSS_COMMENT,
                    ORDER_ID,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    LINE_ID,
                    WORK_SHIFT,
                    WORK_MONTH,
                    WORK_WEEK,
                    WORK_DAYS,
                    WORK_DAY_OF_WEEK,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM RSUMWIPLOS
                WHERE FACTORY = :RSUMWIPLOS_N.FACTORY
					AND WORK_DATE >= :RSUMWIPLOS_N.CMF_4
					AND WORK_DATE <= :RSUMWIPLOS_N.CMF_5
				    AND CM_KEY_1 LIKE :RSUMWIPLOS_N.CM_KEY_1
                    AND CM_KEY_2 LIKE :RSUMWIPLOS_N.CM_KEY_2
                    AND CM_KEY_3 = 'C001'
					AND MAT_ID LIKE :RSUMWIPLOS_N.MAT_ID
                ORDER BY WORK_DATE ASC,
                    FACTORY ASC,
                    CM_KEY_1 ASC,
                    CM_KEY_2 ASC,
                    LOSS_OPER ASC,
                    RES_ID ASC,
                    CM_KEY_3 ASC;
            EXEC SQL OPEN CDB_RSUMWIPLOS_CUR_3;
            break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_rsumwiplos", sel_type);
}


