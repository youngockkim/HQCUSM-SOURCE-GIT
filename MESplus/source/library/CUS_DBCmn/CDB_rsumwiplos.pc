/* SQL CURSOR CLOSE Function */
void CDB_close_rsumwiplos(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_RSUMWIPLOS_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE CDB_RSUMWIPLOS_CUR_2;
            break;

        case 3:										/* IS-20-09-182  */	
            EXEC SQL CLOSE CDB_RSUMWIPLOS_CUR_3;

            break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_rsumwiplos", sel_type);
}


/* Initialize Function */
void CDB_init_rsumwiplos(struct RSUMWIPLOS_TAG *RSUMWIPLOS)
{
    /* memset by Space */
    memset(RSUMWIPLOS, ' ', sizeof(struct RSUMWIPLOS_TAG));
    
    RSUMWIPLOS->MAT_VER = 0;
    RSUMWIPLOS->FLOW_SEQ_NUM = 0;
    RSUMWIPLOS->LOSS_QTY = 0;
}


/* Add Null Function */
void CDB_add_null_rsumwiplos(struct RSUMWIPLOS_N_TAG *RSUMWIPLOS_N, struct RSUMWIPLOS_TAG *RSUMWIPLOS)
{
    /* memset by NULL */
    memset(RSUMWIPLOS_N, '\0', sizeof(struct RSUMWIPLOS_N_TAG));
    
    MEMCPY_AN(RSUMWIPLOS_N->WORK_DATE, RSUMWIPLOS->WORK_DATE, sizeof(RSUMWIPLOS->WORK_DATE));
    MEMCPY_AN(RSUMWIPLOS_N->FACTORY, RSUMWIPLOS->FACTORY, sizeof(RSUMWIPLOS->FACTORY));
    MEMCPY_AN(RSUMWIPLOS_N->RES_ID, RSUMWIPLOS->RES_ID, sizeof(RSUMWIPLOS->RES_ID));
    MEMCPY_AN(RSUMWIPLOS_N->MAT_ID, RSUMWIPLOS->MAT_ID, sizeof(RSUMWIPLOS->MAT_ID));
    RSUMWIPLOS_N->MAT_VER = RSUMWIPLOS->MAT_VER;
    MEMCPY_AN(RSUMWIPLOS_N->FLOW, RSUMWIPLOS->FLOW, sizeof(RSUMWIPLOS->FLOW));
    RSUMWIPLOS_N->FLOW_SEQ_NUM = RSUMWIPLOS->FLOW_SEQ_NUM;
    MEMCPY_AN(RSUMWIPLOS_N->LOSS_OPER, RSUMWIPLOS->LOSS_OPER, sizeof(RSUMWIPLOS->LOSS_OPER));
    MEMCPY_AN(RSUMWIPLOS_N->LOT_TYPE, RSUMWIPLOS->LOT_TYPE, sizeof(RSUMWIPLOS->LOT_TYPE));
    MEMCPY_AN(RSUMWIPLOS_N->CM_KEY_1, RSUMWIPLOS->CM_KEY_1, sizeof(RSUMWIPLOS->CM_KEY_1));
    MEMCPY_AN(RSUMWIPLOS_N->CM_KEY_2, RSUMWIPLOS->CM_KEY_2, sizeof(RSUMWIPLOS->CM_KEY_2));
    MEMCPY_AN(RSUMWIPLOS_N->CM_KEY_3, RSUMWIPLOS->CM_KEY_3, sizeof(RSUMWIPLOS->CM_KEY_3));
    MEMCPY_AN(RSUMWIPLOS_N->CM_KEY_4, RSUMWIPLOS->CM_KEY_4, sizeof(RSUMWIPLOS->CM_KEY_4));
    MEMCPY_AN(RSUMWIPLOS_N->CM_KEY_5, RSUMWIPLOS->CM_KEY_5, sizeof(RSUMWIPLOS->CM_KEY_5));
    MEMCPY_AN(RSUMWIPLOS_N->LOSS_CODE, RSUMWIPLOS->LOSS_CODE, sizeof(RSUMWIPLOS->LOSS_CODE));
    RSUMWIPLOS_N->LOSS_QTY = RSUMWIPLOS->LOSS_QTY;
    MEMCPY_AN(RSUMWIPLOS_N->LOSS_TYPE, RSUMWIPLOS->LOSS_TYPE, sizeof(RSUMWIPLOS->LOSS_TYPE));
    MEMCPY_AN(RSUMWIPLOS_N->LOSS_GROUP, RSUMWIPLOS->LOSS_GROUP, sizeof(RSUMWIPLOS->LOSS_GROUP));
    MEMCPY_AN(RSUMWIPLOS_N->LOSS_COMMENT, RSUMWIPLOS->LOSS_COMMENT, sizeof(RSUMWIPLOS->LOSS_COMMENT));
    MEMCPY_AN(RSUMWIPLOS_N->ORDER_ID, RSUMWIPLOS->ORDER_ID, sizeof(RSUMWIPLOS->ORDER_ID));
    MEMCPY_AN(RSUMWIPLOS_N->CMF_1, RSUMWIPLOS->CMF_1, sizeof(RSUMWIPLOS->CMF_1));
    MEMCPY_AN(RSUMWIPLOS_N->CMF_2, RSUMWIPLOS->CMF_2, sizeof(RSUMWIPLOS->CMF_2));
    MEMCPY_AN(RSUMWIPLOS_N->CMF_3, RSUMWIPLOS->CMF_3, sizeof(RSUMWIPLOS->CMF_3));
    MEMCPY_AN(RSUMWIPLOS_N->CMF_4, RSUMWIPLOS->CMF_4, sizeof(RSUMWIPLOS->CMF_4));
    MEMCPY_AN(RSUMWIPLOS_N->CMF_5, RSUMWIPLOS->CMF_5, sizeof(RSUMWIPLOS->CMF_5));
    MEMCPY_AN(RSUMWIPLOS_N->LINE_ID, RSUMWIPLOS->LINE_ID, sizeof(RSUMWIPLOS->LINE_ID));
    MEMCPY_AN(RSUMWIPLOS_N->WORK_SHIFT, RSUMWIPLOS->WORK_SHIFT, sizeof(RSUMWIPLOS->WORK_SHIFT));
    MEMCPY_AN(RSUMWIPLOS_N->WORK_MONTH, RSUMWIPLOS->WORK_MONTH, sizeof(RSUMWIPLOS->WORK_MONTH));
    MEMCPY_AN(RSUMWIPLOS_N->WORK_WEEK, RSUMWIPLOS->WORK_WEEK, sizeof(RSUMWIPLOS->WORK_WEEK));
    MEMCPY_AN(RSUMWIPLOS_N->WORK_DAYS, RSUMWIPLOS->WORK_DAYS, sizeof(RSUMWIPLOS->WORK_DAYS));
    MEMCPY_AN(RSUMWIPLOS_N->WORK_DAY_OF_WEEK, RSUMWIPLOS->WORK_DAY_OF_WEEK, sizeof(RSUMWIPLOS->WORK_DAY_OF_WEEK));
    MEMCPY_AN(RSUMWIPLOS_N->CREATE_USER_ID, RSUMWIPLOS->CREATE_USER_ID, sizeof(RSUMWIPLOS->CREATE_USER_ID));
    MEMCPY_AN(RSUMWIPLOS_N->CREATE_TIME, RSUMWIPLOS->CREATE_TIME, sizeof(RSUMWIPLOS->CREATE_TIME));
    MEMCPY_AN(RSUMWIPLOS_N->UPDATE_USER_ID, RSUMWIPLOS->UPDATE_USER_ID, sizeof(RSUMWIPLOS->UPDATE_USER_ID));
    MEMCPY_AN(RSUMWIPLOS_N->UPDATE_TIME, RSUMWIPLOS->UPDATE_TIME, sizeof(RSUMWIPLOS->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_rsumwiplos(struct RSUMWIPLOS_N_TAG *RSUMWIPLOS_N, struct RSUMWIPLOS_TAG *RSUMWIPLOS)
{
    MEMCPY_DN(RSUMWIPLOS->WORK_DATE, RSUMWIPLOS_N->WORK_DATE, sizeof(RSUMWIPLOS->WORK_DATE));
    MEMCPY_DN(RSUMWIPLOS->FACTORY, RSUMWIPLOS_N->FACTORY, sizeof(RSUMWIPLOS->FACTORY));
    MEMCPY_DN(RSUMWIPLOS->RES_ID, RSUMWIPLOS_N->RES_ID, sizeof(RSUMWIPLOS->RES_ID));
    MEMCPY_DN(RSUMWIPLOS->MAT_ID, RSUMWIPLOS_N->MAT_ID, sizeof(RSUMWIPLOS->MAT_ID));
    RSUMWIPLOS->MAT_VER = RSUMWIPLOS_N->MAT_VER;
    MEMCPY_DN(RSUMWIPLOS->FLOW, RSUMWIPLOS_N->FLOW, sizeof(RSUMWIPLOS->FLOW));
    RSUMWIPLOS->FLOW_SEQ_NUM = RSUMWIPLOS_N->FLOW_SEQ_NUM;
    MEMCPY_DN(RSUMWIPLOS->LOSS_OPER, RSUMWIPLOS_N->LOSS_OPER, sizeof(RSUMWIPLOS->LOSS_OPER));
    MEMCPY_DN(RSUMWIPLOS->LOT_TYPE, RSUMWIPLOS_N->LOT_TYPE, sizeof(RSUMWIPLOS->LOT_TYPE));
    MEMCPY_DN(RSUMWIPLOS->CM_KEY_1, RSUMWIPLOS_N->CM_KEY_1, sizeof(RSUMWIPLOS->CM_KEY_1));
    MEMCPY_DN(RSUMWIPLOS->CM_KEY_2, RSUMWIPLOS_N->CM_KEY_2, sizeof(RSUMWIPLOS->CM_KEY_2));
    MEMCPY_DN(RSUMWIPLOS->CM_KEY_3, RSUMWIPLOS_N->CM_KEY_3, sizeof(RSUMWIPLOS->CM_KEY_3));
    MEMCPY_DN(RSUMWIPLOS->CM_KEY_4, RSUMWIPLOS_N->CM_KEY_4, sizeof(RSUMWIPLOS->CM_KEY_4));
    MEMCPY_DN(RSUMWIPLOS->CM_KEY_5, RSUMWIPLOS_N->CM_KEY_5, sizeof(RSUMWIPLOS->CM_KEY_5));
    MEMCPY_DN(RSUMWIPLOS->LOSS_CODE, RSUMWIPLOS_N->LOSS_CODE, sizeof(RSUMWIPLOS->LOSS_CODE));
    RSUMWIPLOS->LOSS_QTY = RSUMWIPLOS_N->LOSS_QTY;
    MEMCPY_DN(RSUMWIPLOS->LOSS_TYPE, RSUMWIPLOS_N->LOSS_TYPE, sizeof(RSUMWIPLOS->LOSS_TYPE));
    MEMCPY_DN(RSUMWIPLOS->LOSS_GROUP, RSUMWIPLOS_N->LOSS_GROUP, sizeof(RSUMWIPLOS->LOSS_GROUP));
