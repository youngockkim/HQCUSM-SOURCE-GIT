    MEMCPY_AN(DSP_CPORTLIST_N->PORT_CMF_19, DSP_CPORTLIST->PORT_CMF_19, sizeof(DSP_CPORTLIST->PORT_CMF_19));
    MEMCPY_AN(DSP_CPORTLIST_N->PORT_CMF_20, DSP_CPORTLIST->PORT_CMF_20, sizeof(DSP_CPORTLIST->PORT_CMF_20));
}


