/* SQL UPDATE Function */
void CDB_update_cwipordbom(int sel_type, struct CWIPORDBOM_TAG *CWIPORDBOM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPORDBOM_N_TAG CWIPORDBOM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwipordbom(&CWIPORDBOM_N, CWIPORDBOM);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE CWIPORDBOM SET
                    RS_NUM = :CWIPORDBOM_N.RS_NUM,
                    RS_POS = :CWIPORDBOM_N.RS_POS,
                    BOM_PJT_NO = :CWIPORDBOM_N.BOM_PJT_NO,
                    BOM_PJT_CATE = :CWIPORDBOM_N.BOM_PJT_CATE,
                    MAT_ID = :CWIPORDBOM_N.MAT_ID,
                    MATE_TYPE = :CWIPORDBOM_N.MATE_TYPE,
                    MATE_NO_DESC = :CWIPORDBOM_N.MATE_NO_DESC,
                    QTY = :CWIPORDBOM_N.QTY,
                    UNIT_ID = :CWIPORDBOM_N.UNIT_ID,
                    BATCH_NO = :CWIPORDBOM_N.BATCH_NO,
                    VEN_BATCH_NO = :CWIPORDBOM_N.VEN_BATCH_NO,
                    LOC_ID = :CWIPORDBOM_N.LOC_ID,
                    BACKFLUSH_YN = :CWIPORDBOM_N.BACKFLUSH_YN,
                    HAND_BOOK = :CWIPORDBOM_N.HAND_BOOK,
                    VENDOR = :CWIPORDBOM_N.VENDOR,
                    COMMENTS = :CWIPORDBOM_N.COMMENTS,
                    CELL_PROD_TYPE = :CWIPORDBOM_N.CELL_PROD_TYPE,
                    CELL_POWER_GRADE_1 = :CWIPORDBOM_N.CELL_POWER_GRADE_1,
                    CELL_POWER_GRADE_2 = :CWIPORDBOM_N.CELL_POWER_GRADE_2,
                    CELL_CONVERSION_RATE = :CWIPORDBOM_N.CELL_CONVERSION_RATE,
                    CELL_POWER_RATE = :CWIPORDBOM_N.CELL_POWER_RATE,
                    DEL_YN = :CWIPORDBOM_N.DEL_YN,
                    CMF_1 = :CWIPORDBOM_N.CMF_1,
                    CMF_2 = :CWIPORDBOM_N.CMF_2,
                    CMF_3 = :CWIPORDBOM_N.CMF_3,
                    CMF_4 = :CWIPORDBOM_N.CMF_4,
                    CMF_5 = :CWIPORDBOM_N.CMF_5
                WHERE FACTORY = :CWIPORDBOM_N.FACTORY
                    AND ORDER_ID = :CWIPORDBOM_N.ORDER_ID
                    AND SEQ = :CWIPORDBOM_N.SEQ;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_cwipordbom", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwipordbom(int sel_type, struct CWIPORDBOM_TAG *CWIPORDBOM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPORDBOM_N_TAG CWIPORDBOM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwipordbom(&CWIPORDBOM_N, CWIPORDBOM);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPORDBOM_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    ORDER_ID,
                    SEQ,
                    RS_NUM,
                    RS_POS,
                    BOM_PJT_NO,
                    BOM_PJT_CATE,
                    MAT_ID,
                    MATE_TYPE,
                    MATE_NO_DESC,
                    QTY,
                    UNIT_ID,
                    BATCH_NO,
                    VEN_BATCH_NO,
                    LOC_ID,
                    BACKFLUSH_YN,
                    HAND_BOOK,
                    VENDOR,
                    COMMENTS,
                    CELL_PROD_TYPE,
                    CELL_POWER_GRADE_1,
                    CELL_POWER_GRADE_2,
                    CELL_CONVERSION_RATE,
                    CELL_POWER_RATE,
                    DEL_YN,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM CWIPORDBOM
                ORDER BY FACTORY ASC,
                    ORDER_ID ASC,
                    SEQ ASC;
            EXEC SQL OPEN CDB_CWIPORDBOM_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE CDB_CWIPORDBOM_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    ORDER_ID,
                    SEQ,
                    RS_NUM,
                    RS_POS,
                    BOM_PJT_NO,
                    BOM_PJT_CATE,
                    MAT_ID,
                    MATE_TYPE,
                    MATE_NO_DESC,
                    QTY,
                    UNIT_ID,
                    BATCH_NO,
                    VEN_BATCH_NO,
                    LOC_ID,
                    BACKFLUSH_YN,
                    HAND_BOOK,
                    VENDOR,
                    COMMENTS,
                    CELL_PROD_TYPE,
                    CELL_POWER_GRADE_1,
                    CELL_POWER_GRADE_2,
                    CELL_CONVERSION_RATE,
                    CELL_POWER_RATE,
                    DEL_YN,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM CWIPORDBOM
                WHERE FACTORY = :CWIPORDBOM_N.FACTORY
                    AND ORDER_ID = :CWIPORDBOM_N.ORDER_ID
                ORDER BY FACTORY ASC,
                    ORDER_ID ASC,
                    SEQ ASC;
            EXEC SQL OPEN CDB_CWIPORDBOM_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_CWIPORDBOM_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    ORDER_ID,
                    SEQ,
                    RS_NUM,
                    RS_POS,
                    BOM_PJT_NO,
                    BOM_PJT_CATE,
                    MAT_ID,
                    MATE_TYPE,
                    MATE_NO_DESC,
                    QTY,
                    UNIT_ID,
                    BATCH_NO,
                    VEN_BATCH_NO,
                    LOC_ID,
                    BACKFLUSH_YN,
                    HAND_BOOK,
                    VENDOR,
                    COMMENTS,
                    CELL_PROD_TYPE,
                    CELL_POWER_GRADE_1,
                    CELL_POWER_GRADE_2,
                    CELL_CONVERSION_RATE,
                    CELL_POWER_RATE,
                    DEL_YN,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM CWIPORDBOM
                WHERE FACTORY = :CWIPORDBOM_N.FACTORY
                    AND ORDER_ID = :CWIPORDBOM_N.ORDER_ID
					AND MATE_TYPE = :CWIPORDBOM_N.MATE_TYPE
                ORDER BY FACTORY ASC,
                    ORDER_ID ASC,
                    SEQ ASC;
            EXEC SQL OPEN CDB_CWIPORDBOM_CUR_3;
            break;

		case 4:
            EXEC SQL DECLARE CDB_CWIPORDBOM_CUR_4 CURSOR FOR
                SELECT 
                    DISTINCT CELL_POWER_GRADE_1
                FROM CWIPORDBOM
                WHERE FACTORY = :CWIPORDBOM_N.FACTORY
                    AND ORDER_ID = :CWIPORDBOM_N.ORDER_ID
					AND MATE_TYPE = :CWIPORDBOM_N.MATE_TYPE
                GROUP BY CELL_POWER_GRADE_1;
            EXEC SQL OPEN CDB_CWIPORDBOM_CUR_4;
            break;

		case 5:
            EXEC SQL DECLARE CDB_CWIPORDBOM_CUR_5 CURSOR FOR
                SELECT 
                    DISTINCT CELL_POWER_GRADE_2
                FROM CWIPORDBOM
                WHERE FACTORY = :CWIPORDBOM_N.FACTORY
                    AND ORDER_ID = :CWIPORDBOM_N.ORDER_ID
					AND MATE_TYPE = :CWIPORDBOM_N.MATE_TYPE
                GROUP BY CELL_POWER_GRADE_2;
            EXEC SQL OPEN CDB_CWIPORDBOM_CUR_5;
            break;

		case 6:
            EXEC SQL DECLARE CDB_CWIPORDBOM_CUR_6 CURSOR FOR
                SELECT 
                    CELL_POWER_GRADE_1,
                    CELL_POWER_GRADE_2
                FROM CWIPORDBOM
                WHERE FACTORY = :CWIPORDBOM_N.FACTORY
                    AND ORDER_ID = :CWIPORDBOM_N.ORDER_ID
					AND MATE_TYPE = :CWIPORDBOM_N.MATE_TYPE
                GROUP BY CELL_POWER_GRADE_1, CELL_POWER_GRADE_2
                ORDER BY CELL_POWER_GRADE_1 ASC,
                    CELL_POWER_GRADE_2 ASC;
            EXEC SQL OPEN CDB_CWIPORDBOM_CUR_6;
            break;

		case 10:
            EXEC SQL DECLARE CDB_CWIPORDBOM_CUR_10 CURSOR FOR
                SELECT 
                    FACTORY,
                    ORDER_ID,
                    SEQ,
                    RS_NUM,
                    RS_POS,
                    BOM_PJT_NO,
                    BOM_PJT_CATE,
                    MAT_ID,
                    MATE_TYPE,
                    MATE_NO_DESC,
                    QTY,
                    UNIT_ID,
                    BATCH_NO,
                    VEN_BATCH_NO,
                    LOC_ID,
                    BACKFLUSH_YN,
                    HAND_BOOK,
                    VENDOR,
                    COMMENTS,
                    CELL_PROD_TYPE,
                    CELL_POWER_GRADE_1,
                    CELL_POWER_GRADE_2,
                    CELL_CONVERSION_RATE,
                    CELL_POWER_RATE,
                    DEL_YN,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM CWIPORDBOM
                WHERE FACTORY = :CWIPORDBOM_N.FACTORY
                    AND ORDER_ID like :CWIPORDBOM_N.ORDER_ID
					AND MAT_ID like :CWIPORDBOM_N.MAT_ID
                ORDER BY FACTORY ASC,
                    ORDER_ID ASC,
                    SEQ ASC;
            EXEC SQL OPEN CDB_CWIPORDBOM_CUR_10;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwipordbom", sel_type);
}


