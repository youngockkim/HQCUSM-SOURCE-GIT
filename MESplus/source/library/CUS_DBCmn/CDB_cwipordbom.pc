/* Initialize Function */
void CDB_init_cwipordbom(struct CWIPORDBOM_TAG *CWIPORDBOM)
{
    /* memset by Space */
    memset(CWIPORDBOM, ' ', sizeof(struct CWIPORDBOM_TAG));
    
    CWIPORDBOM->SEQ = 0;
    CWIPORDBOM->QTY = 0;
}


/* Add Null Function */
void CDB_add_null_cwipordbom(struct CWIPORDBOM_N_TAG *CWIPORDBOM_N, struct CWIPORDBOM_TAG *CWIPORDBOM)
{
    /* memset by NULL */
    memset(CWIPORDBOM_N, '\0', sizeof(struct CWIPORDBOM_N_TAG));
    
    MEMCPY_AN(CWIPORDBOM_N->FACTORY, CWIPORDBOM->FACTORY, sizeof(CWIPORDBOM->FACTORY));
    MEMCPY_AN(CWIPORDBOM_N->ORDER_ID, CWIPORDBOM->ORDER_ID, sizeof(CWIPORDBOM->ORDER_ID));
    CWIPORDBOM_N->SEQ = CWIPORDBOM->SEQ;
    MEMCPY_AN(CWIPORDBOM_N->RS_NUM, CWIPORDBOM->RS_NUM, sizeof(CWIPORDBOM->RS_NUM));
    MEMCPY_AN(CWIPORDBOM_N->RS_POS, CWIPORDBOM->RS_POS, sizeof(CWIPORDBOM->RS_POS));
    MEMCPY_AN(CWIPORDBOM_N->BOM_PJT_NO, CWIPORDBOM->BOM_PJT_NO, sizeof(CWIPORDBOM->BOM_PJT_NO));
    MEMCPY_AN(CWIPORDBOM_N->BOM_PJT_CATE, CWIPORDBOM->BOM_PJT_CATE, sizeof(CWIPORDBOM->BOM_PJT_CATE));
    MEMCPY_AN(CWIPORDBOM_N->MAT_ID, CWIPORDBOM->MAT_ID, sizeof(CWIPORDBOM->MAT_ID));
    MEMCPY_AN(CWIPORDBOM_N->MATE_TYPE, CWIPORDBOM->MATE_TYPE, sizeof(CWIPORDBOM->MATE_TYPE));
