/* SQL SELECT_SCALAR Function */
double CDB_select_cwipordbom_scalar(int sel_type, struct CWIPORDBOM_TAG *CWIPORDBOM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPORDBOM_N_TAG CWIPORDBOM_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwipordbom(&CWIPORDBOM_N, CWIPORDBOM);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPORDBOM
                WHERE FACTORY = :CWIPORDBOM_N.FACTORY
                    AND ORDER_ID = :CWIPORDBOM_N.ORDER_ID
                    AND SEQ = :CWIPORDBOM_N.SEQ;
            break;

		case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPORDBOM
                WHERE FACTORY = :CWIPORDBOM_N.FACTORY
                    AND ORDER_ID = :CWIPORDBOM_N.ORDER_ID
					AND MATE_TYPE = :CWIPORDBOM_N.MATE_TYPE
					AND CELL_POWER_GRADE_1 = :CWIPORDBOM_N.CELL_POWER_GRADE_1;
            break;

		case 3:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPORDBOM
                WHERE FACTORY = :CWIPORDBOM_N.FACTORY
                    AND ORDER_ID = :CWIPORDBOM_N.ORDER_ID
					AND MATE_TYPE = :CWIPORDBOM_N.MATE_TYPE
					AND CELL_POWER_GRADE_2 = :CWIPORDBOM_N.CELL_POWER_GRADE_2;
            break;

		case 4:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPORDBOM
                WHERE FACTORY = :CWIPORDBOM_N.FACTORY
                    AND ORDER_ID = :CWIPORDBOM_N.ORDER_ID
					AND MATE_TYPE = :CWIPORDBOM_N.MATE_TYPE
					AND CELL_POWER_GRADE_1 = TRIM(TO_CHAR(TO_NUMBER(:CWIPORDBOM_N.CELL_POWER_GRADE_1)* 100, '999999')) ;
           break;

		case 5:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPORDBOM
                WHERE FACTORY = :CWIPORDBOM_N.FACTORY
                    AND ORDER_ID = :CWIPORDBOM_N.ORDER_ID
					AND MATE_TYPE = :CWIPORDBOM_N.MATE_TYPE
					AND CELL_POWER_GRADE_1 = TRIM(TO_CHAR(TO_NUMBER(:CWIPORDBOM_N.CELL_POWER_GRADE_1)* 100, '999999')) 
					AND CELL_POWER_GRADE_2 = :CWIPORDBOM_N.CELL_POWER_GRADE_2;
           break;

	   case 6:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPORDBOM
                WHERE FACTORY = :CWIPORDBOM_N.FACTORY
                    AND ORDER_ID = :CWIPORDBOM_N.ORDER_ID
					AND MAT_ID IN ( SELECT MAT_ID 
									FROM CINVLOTSTS 
									WHERE FACTORY =  :CWIPORDBOM_N.FACTORY
					                AND INV_LOT_ID = :CWIPORDBOM_N.VENDOR
									UNION 
									SELECT MAT_ID 
									FROM CINVLOTSTS 
									WHERE FACTORY =  :CWIPORDBOM_N.FACTORY
					                AND VENDOR_BARCD = :CWIPORDBOM_N.VENDOR
									) ;
           break;

        case 7:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPORDBOM
                WHERE FACTORY = :CWIPORDBOM_N.FACTORY
                    AND ORDER_ID = :CWIPORDBOM_N.ORDER_ID
					AND MATE_TYPE = :CWIPORDBOM_N.MATE_TYPE
					AND MAT_ID = :CWIPORDBOM_N.MAT_ID;
           break;

	   case 8:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPORDBOM
                WHERE FACTORY = :CWIPORDBOM_N.FACTORY
                    AND ORDER_ID = :CWIPORDBOM_N.ORDER_ID
					AND MATE_TYPE =:CWIPORDBOM_N.MATE_TYPE
					AND MAT_ID IN ( SELECT MAT_ID 
									FROM CINVLOTSTS 
									WHERE FACTORY =  :CWIPORDBOM_N.FACTORY
					                AND INV_LOT_ID = :CWIPORDBOM_N.VENDOR
									UNION 
									SELECT MAT_ID 
									FROM CINVLOTSTS 
									WHERE FACTORY =  :CWIPORDBOM_N.FACTORY
					                AND VENDOR_BARCD = :CWIPORDBOM_N.VENDOR
									) ;
           break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_cwipordbom_scalar", sel_type);

    return d_value;
}


