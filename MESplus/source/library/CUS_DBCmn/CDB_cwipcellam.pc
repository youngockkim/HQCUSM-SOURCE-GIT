                    CMF_4 = :CWIPCELLAM_N.CMF_4,
                    CMF_5 = :CWIPCELLAM_N.CMF_5,
            --        CREATE_TIME = :CWIPCELLAM_N.CREATE_TIME,
                    LAST_TRAN_TIME = :CWIPCELLAM_N.LAST_TRAN_TIME
                WHERE FACTORY = :CWIPCELLAM_N.FACTORY
                    AND CELL_ID = :CWIPCELLAM_N.CELL_ID
                    AND LAMA_ID = :CWIPCELLAM_N.LAMA_ID;
            break;

		case 100:
            EXEC SQL UPDATE CWIPCELLAM SET
                    CMF_2 = :CWIPCELLAM_N.CMF_2
                WHERE FACTORY = :CWIPCELLAM_N.FACTORY
                    AND ( CELL_ID, LAMA_ID ) IN ( SELECT C.CELL_ID, C.LAMA_ID
												  FROM CWIPLOTSTR T
													 , CWIPSTRCEL S
													 , CWIPCELLAM C
												  WHERE T.FACTORY = :CWIPCELLAM_N.FACTORY
												  AND T.LOT_ID = :CWIPCELLAM_N.CMF_2
												  AND S.FACTORY = T.FACTORY
												  AND S.STRING_ID = T.STRING_ID
												  AND C.FACTORY = T.FACTORY
												  AND C.CELL_ID = S.CELL_ID );

            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_cwipcellam", sel_type);
}


