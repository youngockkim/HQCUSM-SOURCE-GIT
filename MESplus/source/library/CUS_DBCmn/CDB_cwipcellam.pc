                    LOCATION_ID = :CWIPCELLAM_N.LOCATION_ID,
                    VMAGAZINE_ID = :CWIPCELLAM_N.VMAGAZINE_ID,
                    WORK_TYPE = :CWIPCELLAM_N.WORK_TYPE,
                    RES_ID = :CWIPCELLAM_N.RES_ID,
                    LINE_ID = :CWIPCELLAM_N.LINE_ID,
                    CMF_1 = :CWIPCELLAM_N.CMF_1,
                    CMF_2 = :CWIPCELLAM_N.CMF_2,
