    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPCELLAM_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    CELL_ID,
                    LAMA_ID,
                    LOCATION_ID,
                    VMAGAZINE_ID,
                    WORK_TYPE,
                    RES_ID,
                    LINE_ID,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_TIME,
                    LAST_TRAN_TIME
                FROM CWIPCELLAM
                ORDER BY FACTORY ASC,
                    CELL_ID ASC,
                    LAMA_ID ASC;
            EXEC SQL OPEN CDB_CWIPCELLAM_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
