/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwipptsrpt(int sel_type, struct CWIPPTSRPT_TAG *CWIPPTSRPT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPPTSRPT_N_TAG CWIPPTSRPT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwipptsrpt(&CWIPPTSRPT_N, CWIPPTSRPT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPPTSRPT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LINE_ID,
                    PTST_DATE,
                    BSBR_POS,
                    POS_POINT,
                    PEAK,
                    MENISCUS,
                    WIDTH_LEFT,
                    WIDTH_RIGHT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CWIPPTSRPT
                ORDER BY FACTORY ASC,
                    LINE_ID ASC,
                    PTST_DATE ASC,
                    BSBR_POS ASC,
                    POS_POINT ASC;
            EXEC SQL OPEN CDB_CWIPPTSRPT_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CWIPPTSRPT_CUR_2 CURSOR FOR
                SELECT 
                    NVL(B.FACTORY,' ')  AS FACTORY,
                    NVL(C.KEY_1,' ')    AS LINE_ID,
                    ' '  AS PTST_DATE,
                    NVL(B.KEY_2, ' ')    AS BSBR_POS,
                    NVL(B.KEY_3, ' ')    AS POS_POINT,
                    NVL(A.PEAK,0) AS PEAK, 
                    NVL(A.MENISCUS,' ') AS MENISCUS,
                    NVL(A.WIDTH_LEFT,0) AS WIDTH_LEFT, 
                    NVL(A.WIDTH_RIGHT,0) AS WIDTH_RIGHT,
                    NVL(A.CMF_1, ' ') AS CMF_1,
                    NVL(A.CMF_2, ' ') AS CMF_2, 
                    NVL(A.CMF_3, ' ') AS CMF_3,
                    NVL(A.CMF_4, ' ') AS CMF_4,
                    NVL(A.CMF_5, ' ') AS CMF_5,
                    NVL(A.CMF_6, ' ') AS CMF_6,
                    NVL(A.CMF_7, ' ') AS CMF_7,
                    NVL(A.CMF_8, ' ') AS CMF_8,
                    NVL(A.CMF_9, ' ') AS CMF_9,
                    NVL(B.BSBR_NAME, ' ') AS CMF_10,
                    NVL(A.CREATE_USER_ID,' ') AS CREATE_USER_ID,
                    NVL(A.CREATE_TIME, SYSDATE) AS CREATE_TIME,
                    NVL(A.UPDATE_USER_ID,' ') AS UPDATE_USER_ID,
                    NVL(A.UPDATE_TIME, SYSDATE) AS UPDATE_TIME
                FROM (SELECT * 
				      FROM CWIPPTSRPT 
					  WHERE FACTORY    = :CWIPPTSRPT_N.FACTORY		
					  AND   PTST_DATE  = :CWIPPTSRPT_N.PTST_DATE
					  AND   LINE_ID    = :CWIPPTSRPT_N.LINE_ID  )A, 
				     ( SELECT T1.FACTORY, T1.KEY_1, T1.KEY_2, T1.KEY_3, T2.DATA_1 AS BSBR_NAME , T2.DATA_2 AS SORTCOL 
				       FROM MGCMTBLDAT T1, MGCMTBLDAT T2
				       WHERE T1.KEY_2       = T2.KEY_1
				       AND   T1.FACTORY    = T2.FACTORY
				       AND   T1.TABLE_NAME = '@PEEL_TEST_LIST'
				       AND   T1.FACTORY    = :CWIPPTSRPT_N.FACTORY
				       AND   T2.TABLE_NAME = '@PEEL_TEST_POSITION'				       
				      ) B,
				     ( SELECT FACTORY, KEY_1, DATA_7 
				       FROM MGCMTBLDAT 
				       WHERE TABLE_NAME = '@LINE_CODE'
				       AND   KEY_1      = :CWIPPTSRPT_N.LINE_ID
				       AND   FACTORY    = :CWIPPTSRPT_N.FACTORY				       
				      ) C
			    WHERE B.FACTORY  = A.FACTORY(+)
				AND   C.FACTORY  = A.FACTORY(+)
				AND   C.KEY_1    = A.LINE_ID(+)
				AND   B.KEY_2    = A.BSBR_POS(+)
				AND   B.KEY_3    = A.POS_POINT(+)
				AND   B.KEY_1    = C.DATA_7 
                ORDER BY FACTORY ASC,
                    LINE_ID ASC,
                    PTST_DATE ASC,
                    B.SORTCOL ASC,
                    TO_NUMBER(POS_POINT) ASC;
            EXEC SQL OPEN CDB_CWIPPTSRPT_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwipptsrpt", sel_type);
}


