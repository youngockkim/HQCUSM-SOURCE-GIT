/* Add Null Function */
void CDB_add_null_cwipptsrpt(struct CWIPPTSRPT_N_TAG *CWIPPTSRPT_N, struct CWIPPTSRPT_TAG *CWIPPTSRPT)
{
    /* memset by NULL */
    memset(CWIPPTSRPT_N, '\0', sizeof(struct CWIPPTSRPT_N_TAG));
    
    MEMCPY_AN(CWIPPTSRPT_N->FACTORY, CWIPPTSRPT->FACTORY, sizeof(CWIPPTSRPT->FACTORY));
    MEMCPY_AN(CWIPPTSRPT_N->LINE_ID, CWIPPTSRPT->LINE_ID, sizeof(CWIPPTSRPT->LINE_ID));
    MEMCPY_AN(CWIPPTSRPT_N->PTST_DATE, CWIPPTSRPT->PTST_DATE, sizeof(CWIPPTSRPT->PTST_DATE));
    MEMCPY_AN(CWIPPTSRPT_N->BSBR_POS, CWIPPTSRPT->BSBR_POS, sizeof(CWIPPTSRPT->BSBR_POS));
    CWIPPTSRPT_N->POS_POINT = CWIPPTSRPT->POS_POINT;
    CWIPPTSRPT_N->PEAK = CWIPPTSRPT->PEAK;
    MEMCPY_AN(CWIPPTSRPT_N->MENISCUS, CWIPPTSRPT->MENISCUS, sizeof(CWIPPTSRPT->MENISCUS));
