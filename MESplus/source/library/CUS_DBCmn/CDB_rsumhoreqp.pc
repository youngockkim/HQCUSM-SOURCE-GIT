/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_rsumhoreqp(int sel_type, struct RSUMHOREQP_TAG *RSUMHOREQP)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMHOREQP_N_TAG RSUMHOREQP_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumhoreqp(&RSUMHOREQP_N, RSUMHOREQP);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_RSUMHOREQP_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    WORK_DATE,
                    WORK_SHIFT,
                    LINE_ID,
                    RES_ID,
                    SUB_RES_ID,
                    MAT_ID,
                    OPER,
                    ORDER_ID,
                    CM_KEY_1,
                    CM_KEY_2,
                    CM_KEY_3,
                    TOT_PROC_TIME,
                    TOT_TACK_TIME,
                    TIME01_TACK,
                    TIME02_TACK,
                    TIME03_TACK,
                    TIME04_TACK,
                    TIME05_TACK,
                    TIME06_TACK,
                    TIME07_TACK,
                    TIME08_TACK,
                    TIME09_TACK,
                    TIME10_TACK,
                    TIME11_TACK,
                    TIME12_TACK,
                    TIME13_TACK,
                    TIME14_TACK,
                    TIME15_TACK,
                    TIME16_TACK,
                    TIME17_TACK,
                    TIME18_TACK,
                    TIME19_TACK,
                    TIME20_TACK,
                    TIME21_TACK,
                    TIME22_TACK,
                    TIME23_TACK,
                    TIME24_TACK,
                    TIME01_PROCESS_TIME,
                    TIME02_PROCESS_TIME,
                    TIME03_PROCESS_TIME,
                    TIME04_PROCESS_TIME,
                    TIME05_PROCESS_TIME,
                    TIME06_PROCESS_TIME,
                    TIME07_PROCESS_TIME,
                    TIME08_PROCESS_TIME,
                    TIME09_PROCESS_TIME,
                    TIME10_PROCESS_TIME,
                    TIME11_PROCESS_TIME,
                    TIME12_PROCESS_TIME,
                    TIME13_PROCESS_TIME,
                    TIME14_PROCESS_TIME,
                    TIME15_PROCESS_TIME,
                    TIME16_PROCESS_TIME,
                    TIME17_PROCESS_TIME,
                    TIME18_PROCESS_TIME,
                    TIME19_PROCESS_TIME,
                    TIME20_PROCESS_TIME,
                    TIME21_PROCESS_TIME,
                    TIME22_PROCESS_TIME,
                    TIME23_PROCESS_TIME,
                    TIME24_PROCESS_TIME,
                    ETC1_VALUE,
                    ETC2_VALUE,
                    ETC3_VALUE,
                    ETC4_VALUE,
                    ETC5_VALUE,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM RSUMHOREQP
                ORDER BY FACTORY ASC,
                    WORK_DATE ASC,
                    WORK_SHIFT ASC,
                    LINE_ID ASC,
                    RES_ID ASC,
                    SUB_RES_ID ASC,
                    MAT_ID ASC,
                    OPER ASC,
                    ORDER_ID ASC,
                    CM_KEY_1 ASC,
                    CM_KEY_2 ASC,
                    CM_KEY_3 ASC;
            EXEC SQL OPEN CDB_RSUMHOREQP_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_rsumhoreqp", sel_type);
}


