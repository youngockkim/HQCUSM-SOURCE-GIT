                :IWIPORDRTE_N.BASE_QUANTITY,
                :IWIPORDRTE_N.BASE_UNIT,
                :IWIPORDRTE_N.DIRECT_LABOUR_UNIT,
                :IWIPORDRTE_N.DIRECT_LABOUR,
                :IWIPORDRTE_N.INDIRECT_LABOUR_UNIT,
                :IWIPORDRTE_N.INDIRECT_LABOUR,
                :IWIPORDRTE_N.DEPRECIATION_UNIT,
                :IWIPORDRTE_N.DEPRECIATION,
                :IWIPORDRTE_N.UTILITIES_UNIT,
                :IWIPORDRTE_N.UTILITIES,
                :IWIPORDRTE_N.SPARE_PARTS_UNIT,
                :IWIPORDRTE_N.SPARE_PARTS,
                :IWIPORDRTE_N.OTHER_COST_UNIT,
                :IWIPORDRTE_N.OTHER_COST,
                :IWIPORDRTE_N.CRE_ID,
                :IWIPORDRTE_N.CRE_DATE,
                :IWIPORDRTE_N.MOD_ID,
                :IWIPORDRTE_N.MOD_DATE,
                :IWIPORDRTE_N.INF_TIME,
                :IWIPORDRTE_N.INF_PROC_TIME,
                :IWIPORDRTE_N.CMF_1,
                :IWIPORDRTE_N.CMF_2,
                :IWIPORDRTE_N.CMF_3,
                :IWIPORDRTE_N.CMF_4,
                :IWIPORDRTE_N.CMF_5,
                :IWIPORDRTE_N.DATA_FLAG,
                :IWIPORDRTE_N.UPDATE_COUNT,
                :IWIPORDRTE_N.INSERT_COUNT,
                :IWIPORDRTE_N.DELETE_COUNT,
                :IWIPORDRTE_N.SQL_DML_COUNT,
                :IWIPORDRTE_N.ZPICODE,
                :IWIPORDRTE_N.ZPIMSGID,
                :IWIPORDRTE_N.RETURN_TYPE,
                :IWIPORDRTE_N.RETURN_MSG,
