    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IWIPORDRTE_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IWIPORDRTE_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_iwipordrte", sel_type);
}


/* Initialize Function */
void CDB_init_iwipordrte(struct IWIPORDRTE_TAG *IWIPORDRTE)
{
    /* memset by Space */
    memset(IWIPORDRTE, ' ', sizeof(struct IWIPORDRTE_TAG));
    
    IWIPORDRTE->BASE_QUANTITY = 0;
    IWIPORDRTE->DIRECT_LABOUR = 0;
    IWIPORDRTE->INDIRECT_LABOUR = 0;
    IWIPORDRTE->DEPRECIATION = 0;
    IWIPORDRTE->UTILITIES = 0;
    IWIPORDRTE->SPARE_PARTS = 0;
    IWIPORDRTE->OTHER_COST = 0;
}


/* Add Null Function */
void CDB_add_null_iwipordrte(struct IWIPORDRTE_N_TAG *IWIPORDRTE_N, struct IWIPORDRTE_TAG *IWIPORDRTE)
{
    /* memset by NULL */
    memset(IWIPORDRTE_N, '\0', sizeof(struct IWIPORDRTE_N_TAG));
    
    MEMCPY_AN(IWIPORDRTE_N->DOC_ID, IWIPORDRTE->DOC_ID, sizeof(IWIPORDRTE->DOC_ID));
    MEMCPY_AN(IWIPORDRTE_N->SITE_ID, IWIPORDRTE->SITE_ID, sizeof(IWIPORDRTE->SITE_ID));
    MEMCPY_AN(IWIPORDRTE_N->PROD_ORDER_NO, IWIPORDRTE->PROD_ORDER_NO, sizeof(IWIPORDRTE->PROD_ORDER_NO));
    MEMCPY_AN(IWIPORDRTE_N->SEQ, IWIPORDRTE->SEQ, sizeof(IWIPORDRTE->SEQ));
    IWIPORDRTE_N->DEL_YN[0] = IWIPORDRTE->DEL_YN;
    MEMCPY_AN(IWIPORDRTE_N->OPER_NO, IWIPORDRTE->OPER_NO, sizeof(IWIPORDRTE->OPER_NO));
    MEMCPY_AN(IWIPORDRTE_N->WORK_CENTER, IWIPORDRTE->WORK_CENTER, sizeof(IWIPORDRTE->WORK_CENTER));
    MEMCPY_AN(IWIPORDRTE_N->WORK_CENTER_DESC, IWIPORDRTE->WORK_CENTER_DESC, sizeof(IWIPORDRTE->WORK_CENTER_DESC));
    IWIPORDRTE_N->BASE_QUANTITY = IWIPORDRTE->BASE_QUANTITY;
    MEMCPY_AN(IWIPORDRTE_N->BASE_UNIT, IWIPORDRTE->BASE_UNIT, sizeof(IWIPORDRTE->BASE_UNIT));
    MEMCPY_AN(IWIPORDRTE_N->DIRECT_LABOUR_UNIT, IWIPORDRTE->DIRECT_LABOUR_UNIT, sizeof(IWIPORDRTE->DIRECT_LABOUR_UNIT));
    IWIPORDRTE_N->DIRECT_LABOUR = IWIPORDRTE->DIRECT_LABOUR;
    MEMCPY_AN(IWIPORDRTE_N->INDIRECT_LABOUR_UNIT, IWIPORDRTE->INDIRECT_LABOUR_UNIT, sizeof(IWIPORDRTE->INDIRECT_LABOUR_UNIT));
    IWIPORDRTE_N->INDIRECT_LABOUR = IWIPORDRTE->INDIRECT_LABOUR;
    MEMCPY_AN(IWIPORDRTE_N->DEPRECIATION_UNIT, IWIPORDRTE->DEPRECIATION_UNIT, sizeof(IWIPORDRTE->DEPRECIATION_UNIT));
    IWIPORDRTE_N->DEPRECIATION = IWIPORDRTE->DEPRECIATION;
    MEMCPY_AN(IWIPORDRTE_N->UTILITIES_UNIT, IWIPORDRTE->UTILITIES_UNIT, sizeof(IWIPORDRTE->UTILITIES_UNIT));
    IWIPORDRTE_N->UTILITIES = IWIPORDRTE->UTILITIES;
    MEMCPY_AN(IWIPORDRTE_N->SPARE_PARTS_UNIT, IWIPORDRTE->SPARE_PARTS_UNIT, sizeof(IWIPORDRTE->SPARE_PARTS_UNIT));
    IWIPORDRTE_N->SPARE_PARTS = IWIPORDRTE->SPARE_PARTS;
    MEMCPY_AN(IWIPORDRTE_N->OTHER_COST_UNIT, IWIPORDRTE->OTHER_COST_UNIT, sizeof(IWIPORDRTE->OTHER_COST_UNIT));
    IWIPORDRTE_N->OTHER_COST = IWIPORDRTE->OTHER_COST;
    MEMCPY_AN(IWIPORDRTE_N->CRE_ID, IWIPORDRTE->CRE_ID, sizeof(IWIPORDRTE->CRE_ID));
    MEMCPY_AN(IWIPORDRTE_N->CRE_DATE, IWIPORDRTE->CRE_DATE, sizeof(IWIPORDRTE->CRE_DATE));
    MEMCPY_AN(IWIPORDRTE_N->MOD_ID, IWIPORDRTE->MOD_ID, sizeof(IWIPORDRTE->MOD_ID));
    MEMCPY_AN(IWIPORDRTE_N->MOD_DATE, IWIPORDRTE->MOD_DATE, sizeof(IWIPORDRTE->MOD_DATE));
    MEMCPY_AN(IWIPORDRTE_N->INF_TIME, IWIPORDRTE->INF_TIME, sizeof(IWIPORDRTE->INF_TIME));
    MEMCPY_AN(IWIPORDRTE_N->INF_PROC_TIME, IWIPORDRTE->INF_PROC_TIME, sizeof(IWIPORDRTE->INF_PROC_TIME));
    MEMCPY_AN(IWIPORDRTE_N->CMF_1, IWIPORDRTE->CMF_1, sizeof(IWIPORDRTE->CMF_1));
    MEMCPY_AN(IWIPORDRTE_N->CMF_2, IWIPORDRTE->CMF_2, sizeof(IWIPORDRTE->CMF_2));
    MEMCPY_AN(IWIPORDRTE_N->CMF_3, IWIPORDRTE->CMF_3, sizeof(IWIPORDRTE->CMF_3));
    MEMCPY_AN(IWIPORDRTE_N->CMF_4, IWIPORDRTE->CMF_4, sizeof(IWIPORDRTE->CMF_4));
    MEMCPY_AN(IWIPORDRTE_N->CMF_5, IWIPORDRTE->CMF_5, sizeof(IWIPORDRTE->CMF_5));
    IWIPORDRTE_N->DATA_FLAG[0] = IWIPORDRTE->DATA_FLAG;
    MEMCPY_AN(IWIPORDRTE_N->UPDATE_COUNT, IWIPORDRTE->UPDATE_COUNT, sizeof(IWIPORDRTE->UPDATE_COUNT));
    MEMCPY_AN(IWIPORDRTE_N->INSERT_COUNT, IWIPORDRTE->INSERT_COUNT, sizeof(IWIPORDRTE->INSERT_COUNT));
    MEMCPY_AN(IWIPORDRTE_N->DELETE_COUNT, IWIPORDRTE->DELETE_COUNT, sizeof(IWIPORDRTE->DELETE_COUNT));
    MEMCPY_AN(IWIPORDRTE_N->SQL_DML_COUNT, IWIPORDRTE->SQL_DML_COUNT, sizeof(IWIPORDRTE->SQL_DML_COUNT));
    MEMCPY_AN(IWIPORDRTE_N->ZPICODE, IWIPORDRTE->ZPICODE, sizeof(IWIPORDRTE->ZPICODE));
    MEMCPY_AN(IWIPORDRTE_N->ZPIMSGID, IWIPORDRTE->ZPIMSGID, sizeof(IWIPORDRTE->ZPIMSGID));
    IWIPORDRTE_N->RETURN_TYPE[0] = IWIPORDRTE->RETURN_TYPE;
    MEMCPY_AN(IWIPORDRTE_N->RETURN_MSG, IWIPORDRTE->RETURN_MSG, sizeof(IWIPORDRTE->RETURN_MSG));
    MEMCPY_AN(IWIPORDRTE_N->ZIFERNAM, IWIPORDRTE->ZIFERNAM, sizeof(IWIPORDRTE->ZIFERNAM));
    MEMCPY_AN(IWIPORDRTE_N->ZIFDATE, IWIPORDRTE->ZIFDATE, sizeof(IWIPORDRTE->ZIFDATE));
    MEMCPY_AN(IWIPORDRTE_N->ZIFTIME, IWIPORDRTE->ZIFTIME, sizeof(IWIPORDRTE->ZIFTIME));
    IWIPORDRTE_N->ZPISTAT[0] = IWIPORDRTE->ZPISTAT;
    MEMCPY_AN(IWIPORDRTE_N->ZPIMSG, IWIPORDRTE->ZPIMSG, sizeof(IWIPORDRTE->ZPIMSG));
}


/* Del Null Function */
void CDB_del_null_iwipordrte(struct IWIPORDRTE_N_TAG *IWIPORDRTE_N, struct IWIPORDRTE_TAG *IWIPORDRTE)
{
    MEMCPY_DN(IWIPORDRTE->DOC_ID, IWIPORDRTE_N->DOC_ID, sizeof(IWIPORDRTE->DOC_ID));
    MEMCPY_DN(IWIPORDRTE->SITE_ID, IWIPORDRTE_N->SITE_ID, sizeof(IWIPORDRTE->SITE_ID));
    MEMCPY_DN(IWIPORDRTE->PROD_ORDER_NO, IWIPORDRTE_N->PROD_ORDER_NO, sizeof(IWIPORDRTE->PROD_ORDER_NO));
    MEMCPY_DN(IWIPORDRTE->SEQ, IWIPORDRTE_N->SEQ, sizeof(IWIPORDRTE->SEQ));
    IWIPORDRTE->DEL_YN = IWIPORDRTE_N->DEL_YN[0];
    MEMCPY_DN(IWIPORDRTE->OPER_NO, IWIPORDRTE_N->OPER_NO, sizeof(IWIPORDRTE->OPER_NO));
    MEMCPY_DN(IWIPORDRTE->WORK_CENTER, IWIPORDRTE_N->WORK_CENTER, sizeof(IWIPORDRTE->WORK_CENTER));
    MEMCPY_DN(IWIPORDRTE->WORK_CENTER_DESC, IWIPORDRTE_N->WORK_CENTER_DESC, sizeof(IWIPORDRTE->WORK_CENTER_DESC));
    IWIPORDRTE->BASE_QUANTITY = IWIPORDRTE_N->BASE_QUANTITY;
    MEMCPY_DN(IWIPORDRTE->BASE_UNIT, IWIPORDRTE_N->BASE_UNIT, sizeof(IWIPORDRTE->BASE_UNIT));
    MEMCPY_DN(IWIPORDRTE->DIRECT_LABOUR_UNIT, IWIPORDRTE_N->DIRECT_LABOUR_UNIT, sizeof(IWIPORDRTE->DIRECT_LABOUR_UNIT));
    IWIPORDRTE->DIRECT_LABOUR = IWIPORDRTE_N->DIRECT_LABOUR;
    MEMCPY_DN(IWIPORDRTE->INDIRECT_LABOUR_UNIT, IWIPORDRTE_N->INDIRECT_LABOUR_UNIT, sizeof(IWIPORDRTE->INDIRECT_LABOUR_UNIT));
    IWIPORDRTE->INDIRECT_LABOUR = IWIPORDRTE_N->INDIRECT_LABOUR;
    MEMCPY_DN(IWIPORDRTE->DEPRECIATION_UNIT, IWIPORDRTE_N->DEPRECIATION_UNIT, sizeof(IWIPORDRTE->DEPRECIATION_UNIT));
    IWIPORDRTE->DEPRECIATION = IWIPORDRTE_N->DEPRECIATION;
    MEMCPY_DN(IWIPORDRTE->UTILITIES_UNIT, IWIPORDRTE_N->UTILITIES_UNIT, sizeof(IWIPORDRTE->UTILITIES_UNIT));
    IWIPORDRTE->UTILITIES = IWIPORDRTE_N->UTILITIES;
    MEMCPY_DN(IWIPORDRTE->SPARE_PARTS_UNIT, IWIPORDRTE_N->SPARE_PARTS_UNIT, sizeof(IWIPORDRTE->SPARE_PARTS_UNIT));
    IWIPORDRTE->SPARE_PARTS = IWIPORDRTE_N->SPARE_PARTS;
    MEMCPY_DN(IWIPORDRTE->OTHER_COST_UNIT, IWIPORDRTE_N->OTHER_COST_UNIT, sizeof(IWIPORDRTE->OTHER_COST_UNIT));
    IWIPORDRTE->OTHER_COST = IWIPORDRTE_N->OTHER_COST;
    MEMCPY_DN(IWIPORDRTE->CRE_ID, IWIPORDRTE_N->CRE_ID, sizeof(IWIPORDRTE->CRE_ID));
    MEMCPY_DN(IWIPORDRTE->CRE_DATE, IWIPORDRTE_N->CRE_DATE, sizeof(IWIPORDRTE->CRE_DATE));
    MEMCPY_DN(IWIPORDRTE->MOD_ID, IWIPORDRTE_N->MOD_ID, sizeof(IWIPORDRTE->MOD_ID));
    MEMCPY_DN(IWIPORDRTE->MOD_DATE, IWIPORDRTE_N->MOD_DATE, sizeof(IWIPORDRTE->MOD_DATE));
    MEMCPY_DN(IWIPORDRTE->INF_TIME, IWIPORDRTE_N->INF_TIME, sizeof(IWIPORDRTE->INF_TIME));
    MEMCPY_DN(IWIPORDRTE->INF_PROC_TIME, IWIPORDRTE_N->INF_PROC_TIME, sizeof(IWIPORDRTE->INF_PROC_TIME));
