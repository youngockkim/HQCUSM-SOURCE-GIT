		case 2:
            EXEC SQL FETCH CDB_IWIPORDRTE_CUR_2 INTO
                :IWIPORDRTE_N.DOC_ID,
                :IWIPORDRTE_N.SITE_ID,
                :IWIPORDRTE_N.PROD_ORDER_NO,
