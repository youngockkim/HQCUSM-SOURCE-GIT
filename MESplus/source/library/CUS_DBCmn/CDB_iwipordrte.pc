                    CMF_2 = :IWIPORDRTE_N.CMF_2,
                    CMF_3 = :IWIPORDRTE_N.CMF_3,
                    CMF_4 = :IWIPORDRTE_N.CMF_4,
                    CMF_5 = :IWIPORDRTE_N.CMF_5,
                    DATA_FLAG = :IWIPORDRTE_N.DATA_FLAG,
                    UPDATE_COUNT = :IWIPORDRTE_N.UPDATE_COUNT,
                    INSERT_COUNT = :IWIPORDRTE_N.INSERT_COUNT,
                    DELETE_COUNT = :IWIPORDRTE_N.DELETE_COUNT,
                    SQL_DML_COUNT = :IWIPORDRTE_N.SQL_DML_COUNT,
                    ZPICODE = :IWIPORDRTE_N.ZPICODE,
                    ZPIMSGID = :IWIPORDRTE_N.ZPIMSGID,
                    RETURN_TYPE = :IWIPORDRTE_N.RETURN_TYPE,
                    RETURN_MSG = :IWIPORDRTE_N.RETURN_MSG,
                    ZIFERNAM = :IWIPORDRTE_N.ZIFERNAM,
                    ZIFDATE = :IWIPORDRTE_N.ZIFDATE,
                    ZIFTIME = :IWIPORDRTE_N.ZIFTIME,
                    ZPISTAT = :IWIPORDRTE_N.ZPISTAT,
                    ZPIMSG = :IWIPORDRTE_N.ZPIMSG
                WHERE DOC_ID = :IWIPORDRTE_N.DOC_ID
                    AND SITE_ID = :IWIPORDRTE_N.SITE_ID
                    AND PROD_ORDER_NO = :IWIPORDRTE_N.PROD_ORDER_NO
                    AND SEQ = :IWIPORDRTE_N.SEQ;
            break;

		case 2:
            EXEC SQL UPDATE IWIPORDRTE SET
					INF_PROC_TIME = :IWIPORDRTE_N.INF_PROC_TIME,
                    RETURN_TYPE = 'E',
                    RETURN_MSG = :IWIPORDRTE_N.RETURN_MSG
                WHERE DOC_ID = :IWIPORDRTE_N.DOC_ID
                    AND SITE_ID = :IWIPORDRTE_N.SITE_ID
                    AND PROD_ORDER_NO = :IWIPORDRTE_N.PROD_ORDER_NO
                    AND SEQ = :IWIPORDRTE_N.SEQ;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_iwipordrte", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_iwipordrte(int sel_type, struct IWIPORDRTE_TAG *IWIPORDRTE)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IWIPORDRTE_N_TAG IWIPORDRTE_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_iwipordrte(&IWIPORDRTE_N, IWIPORDRTE);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IWIPORDRTE_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_ORDER_NO,
                    SEQ,
                    DEL_YN,
                    OPER_NO,
                    WORK_CENTER,
                    WORK_CENTER_DESC,
                    BASE_QUANTITY,
                    BASE_UNIT,
                    DIRECT_LABOUR_UNIT,
                    DIRECT_LABOUR,
                    INDIRECT_LABOUR_UNIT,
                    INDIRECT_LABOUR,
                    DEPRECIATION_UNIT,
                    DEPRECIATION,
                    UTILITIES_UNIT,
                    UTILITIES,
                    SPARE_PARTS_UNIT,
                    SPARE_PARTS,
                    OTHER_COST_UNIT,
                    OTHER_COST,
                    CRE_ID,
                    CRE_DATE,
                    MOD_ID,
                    MOD_DATE,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IWIPORDRTE
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_ORDER_NO ASC,
                    SEQ ASC;
            EXEC SQL OPEN CDB_IWIPORDRTE_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_IWIPORDRTE_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_ORDER_NO,
                    SEQ,
                    DEL_YN,
                    OPER_NO,
                    WORK_CENTER,
                    WORK_CENTER_DESC,
                    BASE_QUANTITY,
                    BASE_UNIT,
                    DIRECT_LABOUR_UNIT,
                    DIRECT_LABOUR,
                    INDIRECT_LABOUR_UNIT,
                    INDIRECT_LABOUR,
                    DEPRECIATION_UNIT,
                    DEPRECIATION,
                    UTILITIES_UNIT,
                    UTILITIES,
                    SPARE_PARTS_UNIT,
                    SPARE_PARTS,
                    OTHER_COST_UNIT,
                    OTHER_COST,
                    CRE_ID,
                    CRE_DATE,
                    MOD_ID,
                    MOD_DATE,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IWIPORDRTE
				WHERE RETURN_TYPE <> 'E'
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_ORDER_NO ASC,
                    SEQ ASC;
            EXEC SQL OPEN CDB_IWIPORDRTE_CUR_2;
            break;			

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_iwipordrte", sel_type);
}


