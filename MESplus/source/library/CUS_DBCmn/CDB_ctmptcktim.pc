    CDB_add_null_ctmptcktim(&CTMPTCKTIM_N, CTMPTCKTIM);
    DB_error_code = 0;
    d_value = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CTMPTCKTIM
                WHERE FACTORY = :CTMPTCKTIM_N.FACTORY
                    AND RES_ID = :CTMPTCKTIM_N.RES_ID
                    AND SUB_RES_ID = :CTMPTCKTIM_N.SUB_RES_ID
                    AND CREATE_TIME = :CTMPTCKTIM_N.CREATE_TIME;
            break;

		case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CTMPTCKTIM
                WHERE FACTORY = :CTMPTCKTIM_N.FACTORY
                    AND RES_ID = :CTMPTCKTIM_N.RES_ID
                    AND SUB_RES_ID = :CTMPTCKTIM_N.SUB_RES_ID;
            break;

		case 3:
            EXEC SQL SELECT ROUND(SUM(TACK_TIME)/6,2) TACK_TIME 
                INTO :d_value
				FROM
				 (
				 SELECT TACK_TIME FROM
				 (
				 SELECT TACK_TIME  FROM CTMPTCKTIM
				 WHERE FACTORY = :CTMPTCKTIM_N.FACTORY
				 AND RES_ID = :CTMPTCKTIM_N.RES_ID
				 AND SUB_RES_ID = :CTMPTCKTIM_N.SUB_RES_ID
				 ORDER BY TACK_TIME ASC
				 )
				 WHERE ROWNUM <= 8
				 ORDER BY TACK_TIME DESC
				 )
				 WHERE ROWNUM <= 6;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_ctmptcktim_scalar", sel_type);

    return d_value;
}


