    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CTMPTCKTIM_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUB_RES_ID,
                    TACK_TIME,
                    CREATE_TIME
                FROM CTMPTCKTIM
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SUB_RES_ID ASC;
            EXEC SQL OPEN CDB_CTMPTCKTIM_CUR_1;
            break;

		case 2:
                sprintf(sql, "SELECT ");
				sprintf(sql + strlen(sql), "A.FACTORY, ");
				sprintf(sql + strlen(sql), "A.RES_ID, ");
				sprintf(sql + strlen(sql), "A.SUB_RES_ID, ");
				sprintf(sql + strlen(sql), "A.TACK_TIME, ");
				sprintf(sql + strlen(sql), "A.CREATE_TIME ");
