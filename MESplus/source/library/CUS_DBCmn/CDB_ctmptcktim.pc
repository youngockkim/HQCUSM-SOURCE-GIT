    memset(CTMPTCKTIM_N, '\0', sizeof(struct CTMPTCKTIM_N_TAG));
    
    MEMCPY_AN(CTMPTCKTIM_N->FACTORY, CTMPTCKTIM->FACTORY, sizeof(CTMPTCKTIM->FACTORY));
    MEMCPY_AN(CTMPTCKTIM_N->RES_ID, CTMPTCKTIM->RES_ID, sizeof(CTMPTCKTIM->RES_ID));
    MEMCPY_AN(CTMPTCKTIM_N->SUB_RES_ID, CTMPTCKTIM->SUB_RES_ID, sizeof(CTMPTCKTIM->SUB_RES_ID));
    CTMPTCKTIM_N->TACK_TIME = CTMPTCKTIM->TACK_TIME;
    MEMCPY_AN(CTMPTCKTIM_N->CREATE_TIME, CTMPTCKTIM->CREATE_TIME, sizeof(CTMPTCKTIM->CREATE_TIME));
