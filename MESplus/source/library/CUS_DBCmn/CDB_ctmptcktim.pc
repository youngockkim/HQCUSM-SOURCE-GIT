/* Del Null Function */
void CDB_del_null_ctmptcktim(struct CTMPTCKTIM_N_TAG *CTMPTCKTIM_N, struct CTMPTCKTIM_TAG *CTMPTCKTIM)
{
    MEMCPY_DN(CTMPTCKTIM->FACTORY, CTMPTCKTIM_N->FACTORY, sizeof(CTMPTCKTIM->FACTORY));
    MEMCPY_DN(CTMPTCKTIM->RES_ID, CTMPTCKTIM_N->RES_ID, sizeof(CTMPTCKTIM->RES_ID));
    MEMCPY_DN(CTMPTCKTIM->SUB_RES_ID, CTMPTCKTIM_N->SUB_RES_ID, sizeof(CTMPTCKTIM->SUB_RES_ID));
    CTMPTCKTIM->TACK_TIME = CTMPTCKTIM_N->TACK_TIME;
    MEMCPY_DN(CTMPTCKTIM->CREATE_TIME, CTMPTCKTIM_N->CREATE_TIME, sizeof(CTMPTCKTIM->CREATE_TIME));
