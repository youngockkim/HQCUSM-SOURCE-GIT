				sprintf(sql + strlen(sql), ") ");
				sprintf(sql + strlen(sql), "WHERE RNK >9) B ");
				sprintf(sql + strlen(sql), "WHERE A.FACTORY = B.FACTORY ");
				sprintf(sql + strlen(sql), "AND A.RES_ID = B.RES_ID ");
				sprintf(sql + strlen(sql), "AND A.SUB_RES_ID = B.SUB_RES_ID ");
				sprintf(sql + strlen(sql), "AND A.CREATE_TIME = B.CREATE_TIME ");

            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE CDB_CTMPTCKTIM_CUR_2 CURSOR FOR S; 
            EXEC SQL OPEN CDB_CTMPTCKTIM_CUR_2;    

			LOG_head("DB");
            LOG_add("len", 0, strlen(sql));
            LOG_add("sql", 4, strlen(sql), sql);
            COM_log_write('I', 'S' , 'S');

            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
