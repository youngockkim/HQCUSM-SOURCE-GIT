				sprintf(sql + strlen(sql), ",(SELECT * FROM ");
				sprintf(sql + strlen(sql), "( ");
				sprintf(sql + strlen(sql), "SELECT FACTORY, RES_ID, SUB_RES_ID, CREATE_TIME,  RANK() OVER(ORDER BY CREATE_TIME DESC) RNK ");
				sprintf(sql + strlen(sql), "FROM CTMPTCKTIM ");

			    make_valid_quote(ts, CTMPTCKTIM_N.FACTORY);
