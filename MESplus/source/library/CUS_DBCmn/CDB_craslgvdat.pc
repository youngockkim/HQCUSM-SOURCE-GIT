    MEMCPY_DN(CRASLGVDAT->CREATE_TIME, CRASLGVDAT_N->CREATE_TIME, sizeof(CRASLGVDAT->CREATE_TIME));
    MEMCPY_DN(CRASLGVDAT->UPDATE_USER_ID, CRASLGVDAT_N->UPDATE_USER_ID, sizeof(CRASLGVDAT->UPDATE_USER_ID));
    MEMCPY_DN(CRASLGVDAT->UPDATE_TIME, CRASLGVDAT_N->UPDATE_TIME, sizeof(CRASLGVDAT->UPDATE_TIME));
}


