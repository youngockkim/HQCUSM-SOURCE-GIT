    CDB_add_null_ibasvdrmst(&IBASVDRMST_N, IBASVDRMST);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IBASVDRMST_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    VEN_ID,
                    VEN_NM,
                    VEN_GRP,
                    VEN_GRP_NM,
                    VEN_SHORT_NM,
                    ADDRESS,
                    COUNTRY,
                    DELIVERY_BLOCK,
                    DEL_YN,
                    REG_DATE,
                    REG_TIME,
                    FLAG,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
