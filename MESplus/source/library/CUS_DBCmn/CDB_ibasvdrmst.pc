                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IBASVDRMST
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    VEN_ID ASC;
            EXEC SQL OPEN CDB_IBASVDRMST_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_IBASVDRMST_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    VEN_ID,
                    VEN_NM,
                    VEN_GRP,
                    VEN_GRP_NM,
                    VEN_SHORT_NM,
                    ADDRESS,
                    COUNTRY,
