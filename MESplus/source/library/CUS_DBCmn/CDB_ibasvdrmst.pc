                :IBASVDRMST_N.ADDRESS,
                :IBASVDRMST_N.COUNTRY,
                :IBASVDRMST_N.DELIVERY_BLOCK,
                :IBASVDRMST_N.DEL_YN,
                :IBASVDRMST_N.REG_DATE,
                :IBASVDRMST_N.REG_TIME,
                :IBASVDRMST_N.FLAG,
                :IBASVDRMST_N.INF_TIME,
                :IBASVDRMST_N.INF_PROC_TIME,
                :IBASVDRMST_N.CMF_1,
                :IBASVDRMST_N.CMF_2,
                :IBASVDRMST_N.CMF_3,
                :IBASVDRMST_N.CMF_4,
                :IBASVDRMST_N.CMF_5,
                :IBASVDRMST_N.DATA_FLAG,
                :IBASVDRMST_N.UPDATE_COUNT,
                :IBASVDRMST_N.INSERT_COUNT,
                :IBASVDRMST_N.DELETE_COUNT,
                :IBASVDRMST_N.SQL_DML_COUNT,
                :IBASVDRMST_N.ZPICODE,
                :IBASVDRMST_N.ZPIMSGID,
                :IBASVDRMST_N.RETURN_TYPE,
                :IBASVDRMST_N.RETURN_MSG,
                :IBASVDRMST_N.ZIFERNAM,
                :IBASVDRMST_N.ZIFDATE,
                :IBASVDRMST_N.ZIFTIME,
                :IBASVDRMST_N.ZPISTAT,
                :IBASVDRMST_N.ZPIMSG;
            break;

		case 2:
            EXEC SQL FETCH CDB_IBASVDRMST_CUR_2 INTO
                :IBASVDRMST_N.DOC_ID,
                :IBASVDRMST_N.SITE_ID,
                :IBASVDRMST_N.VEN_ID,
                :IBASVDRMST_N.VEN_NM,
                :IBASVDRMST_N.VEN_GRP,
                :IBASVDRMST_N.VEN_GRP_NM,
                :IBASVDRMST_N.VEN_SHORT_NM,
                :IBASVDRMST_N.ADDRESS,
                :IBASVDRMST_N.COUNTRY,
                :IBASVDRMST_N.DELIVERY_BLOCK,
                :IBASVDRMST_N.DEL_YN,
                :IBASVDRMST_N.REG_DATE,
                :IBASVDRMST_N.REG_TIME,
                :IBASVDRMST_N.FLAG,
                :IBASVDRMST_N.INF_TIME,
                :IBASVDRMST_N.INF_PROC_TIME,
                :IBASVDRMST_N.CMF_1,
                :IBASVDRMST_N.CMF_2,
                :IBASVDRMST_N.CMF_3,
                :IBASVDRMST_N.CMF_4,
                :IBASVDRMST_N.CMF_5,
                :IBASVDRMST_N.DATA_FLAG,
                :IBASVDRMST_N.UPDATE_COUNT,
                :IBASVDRMST_N.INSERT_COUNT,
                :IBASVDRMST_N.DELETE_COUNT,
                :IBASVDRMST_N.SQL_DML_COUNT,
                :IBASVDRMST_N.ZPICODE,
                :IBASVDRMST_N.ZPIMSGID,
                :IBASVDRMST_N.RETURN_TYPE,
                :IBASVDRMST_N.RETURN_MSG,
                :IBASVDRMST_N.ZIFERNAM,
                :IBASVDRMST_N.ZIFDATE,
                :IBASVDRMST_N.ZIFTIME,
                :IBASVDRMST_N.ZPISTAT,
                :IBASVDRMST_N.ZPIMSG;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_ibasvdrmst(&IBASVDRMST_N, IBASVDRMST);
    }

    DB_stop_query_timer("CDB_fetch_ibasvdrmst", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_ibasvdrmst(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IBASVDRMST_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IBASVDRMST_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ibasvdrmst", sel_type);
}


/* Initialize Function */
void CDB_init_ibasvdrmst(struct IBASVDRMST_TAG *IBASVDRMST)
{
    /* memset by Space */
    memset(IBASVDRMST, ' ', sizeof(struct IBASVDRMST_TAG));
    
}


/* Add Null Function */
void CDB_add_null_ibasvdrmst(struct IBASVDRMST_N_TAG *IBASVDRMST_N, struct IBASVDRMST_TAG *IBASVDRMST)
{
    /* memset by NULL */
    memset(IBASVDRMST_N, '\0', sizeof(struct IBASVDRMST_N_TAG));
    
    MEMCPY_AN(IBASVDRMST_N->DOC_ID, IBASVDRMST->DOC_ID, sizeof(IBASVDRMST->DOC_ID));
    MEMCPY_AN(IBASVDRMST_N->SITE_ID, IBASVDRMST->SITE_ID, sizeof(IBASVDRMST->SITE_ID));
