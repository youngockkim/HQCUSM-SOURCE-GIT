/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_ibasvdrmst(int sel_type, struct IBASVDRMST_TAG *IBASVDRMST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IBASVDRMST_N_TAG IBASVDRMST_N;
