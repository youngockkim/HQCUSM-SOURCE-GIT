    IBASVDRMST_N->DATA_FLAG[0] = IBASVDRMST->DATA_FLAG;
    MEMCPY_AN(IBASVDRMST_N->UPDATE_COUNT, IBASVDRMST->UPDATE_COUNT, sizeof(IBASVDRMST->UPDATE_COUNT));
    MEMCPY_AN(IBASVDRMST_N->INSERT_COUNT, IBASVDRMST->INSERT_COUNT, sizeof(IBASVDRMST->INSERT_COUNT));
    MEMCPY_AN(IBASVDRMST_N->DELETE_COUNT, IBASVDRMST->DELETE_COUNT, sizeof(IBASVDRMST->DELETE_COUNT));
    MEMCPY_AN(IBASVDRMST_N->SQL_DML_COUNT, IBASVDRMST->SQL_DML_COUNT, sizeof(IBASVDRMST->SQL_DML_COUNT));
    MEMCPY_AN(IBASVDRMST_N->ZPICODE, IBASVDRMST->ZPICODE, sizeof(IBASVDRMST->ZPICODE));
