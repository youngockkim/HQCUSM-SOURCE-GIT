/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cmdmrefdat(int sel_type, struct CMDMREFDAT_TAG *CMDMREFDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMDMREFDAT_N_TAG CMDMREFDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cmdmrefdat(&CMDMREFDAT_N, CMDMREFDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CMDMREFDAT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    CW,
                    X_LINK_NO,
                    TEST_DATE,
                    POINT1_LXM,
                    POINT1_GC,
                    POINT2_LXM,
                    POINT2_GC,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    DATA_COMMENT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMDMREFDAT
                ORDER BY FACTORY ASC,
                    CW ASC,
                    X_LINK_NO ASC,
                    TEST_DATE ASC;
            EXEC SQL OPEN CDB_CMDMREFDAT_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE CDB_CMDMREFDAT_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    CW,
                    X_LINK_NO,
                    TEST_DATE,
                    POINT1_LXM,
                    POINT1_GC,
                    POINT2_LXM,
                    POINT2_GC,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    DATA_COMMENT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMDMREFDAT
                WHERE FACTORY = :CMDMREFDAT_N.FACTORY
                    AND TEST_DATE >= :DBC_Q_COND_N.FROM_DATE 
                    AND TEST_DATE <= :DBC_Q_COND_N.TO_DATE
                    AND CW LIKE :CMDMREFDAT_N.CW
                    AND X_LINK_NO LIKE :CMDMREFDAT_N.X_LINK_NO
                ORDER BY FACTORY ASC,
                    TEST_DATE ASC,
                    CW ASC,
                    X_LINK_NO ASC;
            EXEC SQL OPEN CDB_CMDMREFDAT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cmdmrefdat", sel_type);
}


