    CMDMREFDAT->POINT2_GC = 0;
    CMDMREFDAT->QTY_1 = 0;
    CMDMREFDAT->QTY_2 = 0;
    CMDMREFDAT->QTY_3 = 0;
}


/* Add Null Function */
void CDB_add_null_cmdmrefdat(struct CMDMREFDAT_N_TAG *CMDMREFDAT_N, struct CMDMREFDAT_TAG *CMDMREFDAT)
{
    /* memset by NULL */
    memset(CMDMREFDAT_N, '\0', sizeof(struct CMDMREFDAT_N_TAG));
    
    MEMCPY_AN(CMDMREFDAT_N->FACTORY, CMDMREFDAT->FACTORY, sizeof(CMDMREFDAT->FACTORY));
    MEMCPY_AN(CMDMREFDAT_N->CW, CMDMREFDAT->CW, sizeof(CMDMREFDAT->CW));
    MEMCPY_AN(CMDMREFDAT_N->X_LINK_NO, CMDMREFDAT->X_LINK_NO, sizeof(CMDMREFDAT->X_LINK_NO));
    MEMCPY_AN(CMDMREFDAT_N->TEST_DATE, CMDMREFDAT->TEST_DATE, sizeof(CMDMREFDAT->TEST_DATE));
    CMDMREFDAT_N->POINT1_LXM = CMDMREFDAT->POINT1_LXM;
    CMDMREFDAT_N->POINT1_GC = CMDMREFDAT->POINT1_GC;
    CMDMREFDAT_N->POINT2_LXM = CMDMREFDAT->POINT2_LXM;
    CMDMREFDAT_N->POINT2_GC = CMDMREFDAT->POINT2_GC;
    CMDMREFDAT_N->QTY_1 = CMDMREFDAT->QTY_1;
    CMDMREFDAT_N->QTY_2 = CMDMREFDAT->QTY_2;
    CMDMREFDAT_N->QTY_3 = CMDMREFDAT->QTY_3;
    MEMCPY_AN(CMDMREFDAT_N->DATA_COMMENT, CMDMREFDAT->DATA_COMMENT, sizeof(CMDMREFDAT->DATA_COMMENT));
    MEMCPY_AN(CMDMREFDAT_N->CMF_1, CMDMREFDAT->CMF_1, sizeof(CMDMREFDAT->CMF_1));
    MEMCPY_AN(CMDMREFDAT_N->CMF_2, CMDMREFDAT->CMF_2, sizeof(CMDMREFDAT->CMF_2));
