/* SQL SELECT_SCALAR Function */
double CDB_select_rsumhormov_scalar(int sel_type, struct RSUMHORMOV_TAG *RSUMHORMOV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMHORMOV_N_TAG RSUMHORMOV_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumhormov(&RSUMHORMOV_N, RSUMHORMOV);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM RSUMHORMOV
                WHERE FACTORY = :RSUMHORMOV_N.FACTORY
                    AND WORK_DATE = :RSUMHORMOV_N.WORK_DATE
                    AND WORK_SHIFT = :RSUMHORMOV_N.WORK_SHIFT
                    AND LINE_ID = :RSUMHORMOV_N.LINE_ID
                    AND RES_ID = :RSUMHORMOV_N.RES_ID
                    AND MAT_ID = :RSUMHORMOV_N.MAT_ID
                    AND OPER = :RSUMHORMOV_N.OPER
                    AND ORDER_ID = :RSUMHORMOV_N.ORDER_ID
                    AND FQC_GRADE = :RSUMHORMOV_N.FQC_GRADE
                    AND FQC_POWER = :RSUMHORMOV_N.FQC_POWER
                    AND CM_KEY_1 = :RSUMHORMOV_N.CM_KEY_1
                    AND CM_KEY_2 = :RSUMHORMOV_N.CM_KEY_2
                    AND CM_KEY_3 = :RSUMHORMOV_N.CM_KEY_3;
            break;
		
		case 2:
            EXEC SQL SELECT SUM(INPUT_QTY )
                INTO :d_value
                FROM RSUMHORMOV
                WHERE FACTORY = :RSUMHORMOV_N.FACTORY
                    AND WORK_DATE = :RSUMHORMOV_N.WORK_DATE
                    AND OPER = :RSUMHORMOV_N.OPER
                    AND ORDER_ID = :RSUMHORMOV_N.ORDER_ID
                    AND FQC_GRADE = :RSUMHORMOV_N.FQC_GRADE
                    AND FQC_POWER = :RSUMHORMOV_N.FQC_POWER
                    AND CM_KEY_1 = :RSUMHORMOV_N.CM_KEY_1
                    AND CM_KEY_3 = :RSUMHORMOV_N.CM_KEY_3;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_rsumhormov_scalar", sel_type);

    return d_value;
}


/* SQL DELETE Function */
void CDB_delete_rsumhormov(int sel_type, struct RSUMHORMOV_TAG *RSUMHORMOV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMHORMOV_N_TAG RSUMHORMOV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumhormov(&RSUMHORMOV_N, RSUMHORMOV);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM RSUMHORMOV
                WHERE FACTORY = :RSUMHORMOV_N.FACTORY
                    AND WORK_DATE = :RSUMHORMOV_N.WORK_DATE
                    AND WORK_SHIFT = :RSUMHORMOV_N.WORK_SHIFT
                    AND LINE_ID = :RSUMHORMOV_N.LINE_ID
                    AND RES_ID = :RSUMHORMOV_N.RES_ID
                    AND MAT_ID = :RSUMHORMOV_N.MAT_ID
                    AND OPER = :RSUMHORMOV_N.OPER
                    AND ORDER_ID = :RSUMHORMOV_N.ORDER_ID
                    AND FQC_GRADE = :RSUMHORMOV_N.FQC_GRADE
                    AND FQC_POWER = :RSUMHORMOV_N.FQC_POWER
                    AND CM_KEY_1 = :RSUMHORMOV_N.CM_KEY_1
                    AND CM_KEY_2 = :RSUMHORMOV_N.CM_KEY_2
                    AND CM_KEY_3 = :RSUMHORMOV_N.CM_KEY_3;
            break;

		case 2:
            EXEC SQL DELETE FROM RSUMHORMOV
                WHERE WORK_DATE >= :RSUMHORMOV_N.CM_KEY_1
                  AND WORK_DATE <= :RSUMHORMOV_N.CM_KEY_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_delete_rsumhormov", sel_type);
}


