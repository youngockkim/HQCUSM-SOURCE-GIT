                    TIME18_LOSS_QTY = :RSUMHORMOV_N.TIME18_LOSS_QTY,
                    TIME19_LOSS_QTY = :RSUMHORMOV_N.TIME19_LOSS_QTY,
                    TIME20_LOSS_QTY = :RSUMHORMOV_N.TIME20_LOSS_QTY,
                    TIME21_LOSS_QTY = :RSUMHORMOV_N.TIME21_LOSS_QTY,
                    TIME22_LOSS_QTY = :RSUMHORMOV_N.TIME22_LOSS_QTY,
                    TIME23_LOSS_QTY = :RSUMHORMOV_N.TIME23_LOSS_QTY,
                    TIME24_LOSS_QTY = :RSUMHORMOV_N.TIME24_LOSS_QTY,
                    ETC1_QTY = :RSUMHORMOV_N.ETC1_QTY,
                    ETC2_QTY = :RSUMHORMOV_N.ETC2_QTY,
                    ETC3_QTY = :RSUMHORMOV_N.ETC3_QTY,
                    ETC4_QTY = :RSUMHORMOV_N.ETC4_QTY,
                    ETC5_QTY = :RSUMHORMOV_N.ETC5_QTY,
                    CMF_1 = :RSUMHORMOV_N.CMF_1,
                    CMF_2 = :RSUMHORMOV_N.CMF_2,
                    CMF_3 = :RSUMHORMOV_N.CMF_3,
                    CMF_4 = :RSUMHORMOV_N.CMF_4,
                    CMF_5 = :RSUMHORMOV_N.CMF_5
                WHERE FACTORY = :RSUMHORMOV_N.FACTORY
                    AND WORK_DATE = :RSUMHORMOV_N.WORK_DATE
                    AND WORK_SHIFT = :RSUMHORMOV_N.WORK_SHIFT
                    AND LINE_ID = :RSUMHORMOV_N.LINE_ID
                    AND RES_ID = :RSUMHORMOV_N.RES_ID
                    AND MAT_ID = :RSUMHORMOV_N.MAT_ID
                    AND OPER = :RSUMHORMOV_N.OPER
                    AND ORDER_ID = :RSUMHORMOV_N.ORDER_ID
                    AND FQC_GRADE = :RSUMHORMOV_N.FQC_GRADE
                    AND FQC_POWER = :RSUMHORMOV_N.FQC_POWER
                    AND CM_KEY_1 = :RSUMHORMOV_N.CM_KEY_1
                    AND CM_KEY_2 = :RSUMHORMOV_N.CM_KEY_2
                    AND CM_KEY_3 = :RSUMHORMOV_N.CM_KEY_3;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_rsumhormov", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_rsumhormov(int sel_type, struct RSUMHORMOV_TAG *RSUMHORMOV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMHORMOV_N_TAG RSUMHORMOV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumhormov(&RSUMHORMOV_N, RSUMHORMOV);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_RSUMHORMOV_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    WORK_DATE,
                    WORK_SHIFT,
                    LINE_ID,
                    RES_ID,
                    MAT_ID,
                    OPER,
                    ORDER_ID,
                    FQC_GRADE,
                    FQC_POWER,
                    CM_KEY_1,
                    CM_KEY_2,
                    CM_KEY_3,
                    INPUT_QTY,
                    LOSS_QTY,
                    TIME01_QTY,
                    TIME02_QTY,
                    TIME03_QTY,
                    TIME04_QTY,
                    TIME05_QTY,
                    TIME06_QTY,
                    TIME07_QTY,
                    TIME08_QTY,
                    TIME09_QTY,
                    TIME10_QTY,
                    TIME11_QTY,
                    TIME12_QTY,
                    TIME13_QTY,
                    TIME14_QTY,
                    TIME15_QTY,
                    TIME16_QTY,
                    TIME17_QTY,
                    TIME18_QTY,
                    TIME19_QTY,
                    TIME20_QTY,
                    TIME21_QTY,
                    TIME22_QTY,
                    TIME23_QTY,
                    TIME24_QTY,
                    TIME01_LOSS_QTY,
                    TIME02_LOSS_QTY,
                    TIME03_LOSS_QTY,
                    TIME04_LOSS_QTY,
                    TIME05_LOSS_QTY,
                    TIME06_LOSS_QTY,
                    TIME07_LOSS_QTY,
                    TIME08_LOSS_QTY,
                    TIME09_LOSS_QTY,
                    TIME10_LOSS_QTY,
                    TIME11_LOSS_QTY,
                    TIME12_LOSS_QTY,
                    TIME13_LOSS_QTY,
                    TIME14_LOSS_QTY,
                    TIME15_LOSS_QTY,
                    TIME16_LOSS_QTY,
                    TIME17_LOSS_QTY,
                    TIME18_LOSS_QTY,
                    TIME19_LOSS_QTY,
                    TIME20_LOSS_QTY,
                    TIME21_LOSS_QTY,
                    TIME22_LOSS_QTY,
                    TIME23_LOSS_QTY,
                    TIME24_LOSS_QTY,
                    ETC1_QTY,
                    ETC2_QTY,
                    ETC3_QTY,
                    ETC4_QTY,
                    ETC5_QTY,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM RSUMHORMOV
                ORDER BY FACTORY ASC,
                    WORK_DATE ASC,
                    WORK_SHIFT ASC,
                    LINE_ID ASC,
                    RES_ID ASC,
                    MAT_ID ASC,
                    OPER ASC,
                    ORDER_ID ASC,
                    FQC_GRADE ASC,
                    FQC_POWER ASC,
                    CM_KEY_1 ASC,
                    CM_KEY_2 ASC,
                    CM_KEY_3 ASC;
            EXEC SQL OPEN CDB_RSUMHORMOV_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_RSUMHORMOV_CUR_2 CURSOR FOR
                SELECT DISTINCT
                    FACTORY,
                    WORK_DATE,
                    LINE_ID,
                    MAT_ID
                FROM RSUMHORMOV
				WHERE FACTORY = :RSUMHORMOV_N.FACTORY
				  AND WORK_DATE = :RSUMHORMOV_N.WORK_DATE
				  AND LINE_ID = :RSUMHORMOV_N.LINE_ID	
				  AND OPER = :RSUMHORMOV_N.OPER			  
                ORDER BY FACTORY ASC,
                    WORK_DATE ASC,
                    LINE_ID ASC,
                    MAT_ID ASC;
            EXEC SQL OPEN CDB_RSUMHORMOV_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_rsumhormov", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_rsumhormov(int sel_type, struct RSUMHORMOV_TAG *RSUMHORMOV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMHORMOV_N_TAG RSUMHORMOV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_RSUMHORMOV_CUR_1 INTO
                :RSUMHORMOV_N.FACTORY,
                :RSUMHORMOV_N.WORK_DATE,
                :RSUMHORMOV_N.WORK_SHIFT,
                :RSUMHORMOV_N.LINE_ID,
                :RSUMHORMOV_N.RES_ID,
                :RSUMHORMOV_N.MAT_ID,
