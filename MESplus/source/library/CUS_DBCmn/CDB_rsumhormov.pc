/* Add Null Function */
void CDB_add_null_rsumhormov(struct RSUMHORMOV_N_TAG *RSUMHORMOV_N, struct RSUMHORMOV_TAG *RSUMHORMOV)
{
    /* memset by NULL */
    memset(RSUMHORMOV_N, '\0', sizeof(struct RSUMHORMOV_N_TAG));
    
    MEMCPY_AN(RSUMHORMOV_N->FACTORY, RSUMHORMOV->FACTORY, sizeof(RSUMHORMOV->FACTORY));
    MEMCPY_AN(RSUMHORMOV_N->WORK_DATE, RSUMHORMOV->WORK_DATE, sizeof(RSUMHORMOV->WORK_DATE));
    MEMCPY_AN(RSUMHORMOV_N->WORK_SHIFT, RSUMHORMOV->WORK_SHIFT, sizeof(RSUMHORMOV->WORK_SHIFT));
    MEMCPY_AN(RSUMHORMOV_N->LINE_ID, RSUMHORMOV->LINE_ID, sizeof(RSUMHORMOV->LINE_ID));
