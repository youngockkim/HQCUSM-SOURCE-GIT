					,NVL(TIME21_QTY,0) TIME21_QTY 
					,NVL(TIME22_QTY,0) TIME22_QTY 
					,NVL(TIME23_QTY,0) TIME23_QTY 
					,NVL(TIME24_QTY,0) TIME24_QTY 
					,NVL(TIME01_LOSS_QTY,0) TIME01_LOSS_QTY
					,NVL(TIME02_LOSS_QTY,0) TIME02_LOSS_QTY
					,NVL(TIME03_LOSS_QTY,0) TIME03_LOSS_QTY
					,NVL(TIME04_LOSS_QTY,0) TIME04_LOSS_QTY
					,NVL(TIME05_LOSS_QTY,0) TIME05_LOSS_QTY
					,NVL(TIME06_LOSS_QTY,0) TIME06_LOSS_QTY
					,NVL(TIME07_LOSS_QTY,0) TIME07_LOSS_QTY
					,NVL(TIME08_LOSS_QTY,0) TIME08_LOSS_QTY
					,NVL(TIME09_LOSS_QTY,0) TIME09_LOSS_QTY
					,NVL(TIME10_LOSS_QTY,0) TIME10_LOSS_QTY
