                    :RSUMHORMOV_N.ETC1_QTY,
                    :RSUMHORMOV_N.ETC2_QTY,
                    :RSUMHORMOV_N.ETC3_QTY,
                    :RSUMHORMOV_N.ETC4_QTY,
                    :RSUMHORMOV_N.ETC5_QTY,
