					,NVL(TIME16_LOSS_QTY,0) TIME16_LOSS_QTY
					,NVL(TIME17_LOSS_QTY,0) TIME17_LOSS_QTY
					,NVL(TIME18_LOSS_QTY,0) TIME18_LOSS_QTY
					,NVL(TIME19_LOSS_QTY,0) TIME19_LOSS_QTY
					,NVL(TIME20_LOSS_QTY,0) TIME20_LOSS_QTY
					,NVL(TIME21_LOSS_QTY,0) TIME21_LOSS_QTY
					,NVL(TIME22_LOSS_QTY,0) TIME22_LOSS_QTY
					,NVL(TIME23_LOSS_QTY,0) TIME23_LOSS_QTY
					,NVL(TIME24_LOSS_QTY,0) TIME24_LOSS_QTY
                    ,0 ETC1_QTY
                    ,0 ETC2_QTY
                    ,0 ETC3_QTY
                    ,0 ETC4_QTY
                    ,0 ETC5_QTY
                    ,0 CMF_1
                    ,0 CMF_2
                    ,0 CMF_3
                    ,0 CMF_4
                    ,0 CMF_5
                INTO 
                    :RSUMHORMOV_N.FACTORY,
                    :RSUMHORMOV_N.WORK_DATE,
                    :RSUMHORMOV_N.WORK_SHIFT,
                    :RSUMHORMOV_N.LINE_ID,
                    :RSUMHORMOV_N.RES_ID,
                    :RSUMHORMOV_N.MAT_ID,
                    :RSUMHORMOV_N.OPER,
                    :RSUMHORMOV_N.ORDER_ID,
                    :RSUMHORMOV_N.FQC_GRADE,
                    :RSUMHORMOV_N.FQC_POWER,
                    :RSUMHORMOV_N.CM_KEY_1,
                    :RSUMHORMOV_N.CM_KEY_2,
                    :RSUMHORMOV_N.CM_KEY_3,
                    :RSUMHORMOV_N.INPUT_QTY,
                    :RSUMHORMOV_N.LOSS_QTY,
                    :RSUMHORMOV_N.TIME01_QTY,
                    :RSUMHORMOV_N.TIME02_QTY,
                    :RSUMHORMOV_N.TIME03_QTY,
                    :RSUMHORMOV_N.TIME04_QTY,
                    :RSUMHORMOV_N.TIME05_QTY,
                    :RSUMHORMOV_N.TIME06_QTY,
                    :RSUMHORMOV_N.TIME07_QTY,
                    :RSUMHORMOV_N.TIME08_QTY,
                    :RSUMHORMOV_N.TIME09_QTY,
                    :RSUMHORMOV_N.TIME10_QTY,
                    :RSUMHORMOV_N.TIME11_QTY,
                    :RSUMHORMOV_N.TIME12_QTY,
                    :RSUMHORMOV_N.TIME13_QTY,
                    :RSUMHORMOV_N.TIME14_QTY,
                    :RSUMHORMOV_N.TIME15_QTY,
                    :RSUMHORMOV_N.TIME16_QTY,
                    :RSUMHORMOV_N.TIME17_QTY,
                    :RSUMHORMOV_N.TIME18_QTY,
                    :RSUMHORMOV_N.TIME19_QTY,
                    :RSUMHORMOV_N.TIME20_QTY,
                    :RSUMHORMOV_N.TIME21_QTY,
                    :RSUMHORMOV_N.TIME22_QTY,
                    :RSUMHORMOV_N.TIME23_QTY,
                    :RSUMHORMOV_N.TIME24_QTY,
                    :RSUMHORMOV_N.TIME01_LOSS_QTY,
                    :RSUMHORMOV_N.TIME02_LOSS_QTY,
                    :RSUMHORMOV_N.TIME03_LOSS_QTY,
                    :RSUMHORMOV_N.TIME04_LOSS_QTY,
                    :RSUMHORMOV_N.TIME05_LOSS_QTY,
                    :RSUMHORMOV_N.TIME06_LOSS_QTY,
                    :RSUMHORMOV_N.TIME07_LOSS_QTY,
                    :RSUMHORMOV_N.TIME08_LOSS_QTY,
                    :RSUMHORMOV_N.TIME09_LOSS_QTY,
                    :RSUMHORMOV_N.TIME10_LOSS_QTY,
                    :RSUMHORMOV_N.TIME11_LOSS_QTY,
                    :RSUMHORMOV_N.TIME12_LOSS_QTY,
                    :RSUMHORMOV_N.TIME13_LOSS_QTY,
                    :RSUMHORMOV_N.TIME14_LOSS_QTY,
                    :RSUMHORMOV_N.TIME15_LOSS_QTY,
                    :RSUMHORMOV_N.TIME16_LOSS_QTY,
                    :RSUMHORMOV_N.TIME17_LOSS_QTY,
                    :RSUMHORMOV_N.TIME18_LOSS_QTY,
                    :RSUMHORMOV_N.TIME19_LOSS_QTY,
                    :RSUMHORMOV_N.TIME20_LOSS_QTY,
                    :RSUMHORMOV_N.TIME21_LOSS_QTY,
                    :RSUMHORMOV_N.TIME22_LOSS_QTY,
                    :RSUMHORMOV_N.TIME23_LOSS_QTY,
                    :RSUMHORMOV_N.TIME24_LOSS_QTY,
                    :RSUMHORMOV_N.ETC1_QTY,
                    :RSUMHORMOV_N.ETC2_QTY,
                    :RSUMHORMOV_N.ETC3_QTY,
                    :RSUMHORMOV_N.ETC4_QTY,
                    :RSUMHORMOV_N.ETC5_QTY,
                    :RSUMHORMOV_N.CMF_1,
                    :RSUMHORMOV_N.CMF_2,
                    :RSUMHORMOV_N.CMF_3,
                    :RSUMHORMOV_N.CMF_4,
                    :RSUMHORMOV_N.CMF_5                 
				FROM 
				 (  
					SELECT  SUM(DECODE(LOSS_TIME,'06',OUT_QTY)) AS TIME06_QTY
					,SUM(DECODE(LOSS_TIME,'07',OUT_QTY)) AS TIME07_QTY
					,SUM(DECODE(LOSS_TIME,'08',OUT_QTY)) AS TIME08_QTY
					,SUM(DECODE(LOSS_TIME,'09',OUT_QTY)) AS TIME09_QTY
					,SUM(DECODE(LOSS_TIME,'10',OUT_QTY)) AS TIME10_QTY
					,SUM(DECODE(LOSS_TIME,'11',OUT_QTY)) AS TIME11_QTY
					,SUM(DECODE(LOSS_TIME,'12',OUT_QTY)) AS TIME12_QTY
					,SUM(DECODE(LOSS_TIME,'13',OUT_QTY)) AS TIME13_QTY
					,SUM(DECODE(LOSS_TIME,'14',OUT_QTY)) AS TIME14_QTY
					,SUM(DECODE(LOSS_TIME,'15',OUT_QTY)) AS TIME15_QTY
					,SUM(DECODE(LOSS_TIME,'16',OUT_QTY)) AS TIME16_QTY
					,SUM(DECODE(LOSS_TIME,'17',OUT_QTY)) AS TIME17_QTY
					,SUM(DECODE(LOSS_TIME,'18',OUT_QTY)) AS TIME18_QTY
					,SUM(DECODE(LOSS_TIME,'19',OUT_QTY)) AS TIME19_QTY
					,SUM(DECODE(LOSS_TIME,'20',OUT_QTY)) AS TIME20_QTY
					,SUM(DECODE(LOSS_TIME,'21',OUT_QTY)) AS TIME21_QTY
					,SUM(DECODE(LOSS_TIME,'22',OUT_QTY)) AS TIME22_QTY
					,SUM(DECODE(LOSS_TIME,'23',OUT_QTY)) AS TIME23_QTY
					,SUM(DECODE(LOSS_TIME,'00',OUT_QTY)) AS TIME24_QTY
					,SUM(DECODE(LOSS_TIME,'01',OUT_QTY)) AS TIME01_QTY
					,SUM(DECODE(LOSS_TIME,'02',OUT_QTY)) AS TIME02_QTY
					,SUM(DECODE(LOSS_TIME,'03',OUT_QTY)) AS TIME03_QTY
					,SUM(DECODE(LOSS_TIME,'04',OUT_QTY)) AS TIME04_QTY
					,SUM(DECODE(LOSS_TIME,'05',OUT_QTY)) AS TIME05_QTY
					,SUM(DECODE(LOSS_TIME,'06',LOSS_QTY)) AS TIME06_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'07',LOSS_QTY)) AS TIME07_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'08',LOSS_QTY)) AS TIME08_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'09',LOSS_QTY)) AS TIME09_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'10',LOSS_QTY)) AS TIME10_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'11',LOSS_QTY)) AS TIME11_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'12',LOSS_QTY)) AS TIME12_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'13',LOSS_QTY)) AS TIME13_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'14',LOSS_QTY)) AS TIME14_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'15',LOSS_QTY)) AS TIME15_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'16',LOSS_QTY)) AS TIME16_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'17',LOSS_QTY)) AS TIME17_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'18',LOSS_QTY)) AS TIME18_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'19',LOSS_QTY)) AS TIME19_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'20',LOSS_QTY)) AS TIME20_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'21',LOSS_QTY)) AS TIME21_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'22',LOSS_QTY)) AS TIME22_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'23',LOSS_QTY)) AS TIME23_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'00',LOSS_QTY)) AS TIME24_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'01',LOSS_QTY)) AS TIME01_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'02',LOSS_QTY)) AS TIME02_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'03',LOSS_QTY)) AS TIME03_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'04',LOSS_QTY)) AS TIME04_LOSS_QTY
					,SUM(DECODE(LOSS_TIME,'05',LOSS_QTY)) AS TIME05_LOSS_QTY
					FROM (
					SELECT DECODE(T.GRADE,'RWK','REWORK','RW','REWORK','REWOR','REWORK','G01','G01','G02','G02','G06','SC',T.GRADE) GRADE
						, SUBSTR(T.CMF_3,9,2) LOSS_TIME
						, SUM(DECODE(T.RESULT_VALUE,'A',0,1)) LOSS_QTY
						, COUNT(T.CMF_3) OUT_QTY
					FROM  CEDCLOTRLT T
					WHERE 1=1
					AND T.FACTORY	 = :RSUMHORMOV_N.FACTORY
					AND T.INS_TYPE	 = 'FC'
					AND T.LINE_ID	 = :RSUMHORMOV_N.LINE_ID  
					AND T.GRADE  IN ('G01','G02','B','C','RWK') 
					AND T.WORK_SHIFT = :RSUMHORMOV_N.WORK_SHIFT
					AND T.CMF_3 BETWEEN :RSUMHORMOV_N.WORK_DATE || '060000' AND  TO_CHAR(TO_DATE(:RSUMHORMOV_N.WORK_DATE,'YYYYMMDD')+1,'YYYYMMDD') || '055959'
					GROUP BY T.GRADE, SUBSTR(T.CMF_3,9,2) )
				);
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_rsumhormov(&RSUMHORMOV_N, RSUMHORMOV);
    }

    DB_stop_query_timer("CDB_select_rsumhormov", sel_type);
}


