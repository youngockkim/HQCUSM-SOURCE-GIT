    CRASWRKTIM->WORK_TIME = CRASWRKTIM_N->WORK_TIME;
    MEMCPY_DN(CRASWRKTIM->CMF_1, CRASWRKTIM_N->CMF_1, sizeof(CRASWRKTIM->CMF_1));
    MEMCPY_DN(CRASWRKTIM->CMF_2, CRASWRKTIM_N->CMF_2, sizeof(CRASWRKTIM->CMF_2));
