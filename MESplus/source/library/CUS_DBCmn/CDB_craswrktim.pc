    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASWRKTIM_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    TRAN_TIME,
                    ARRIVAL_TIME,
                    DEPARTURE_TIME,
                    WORK_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10
                FROM CRASWRKTIM
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    TRAN_TIME ASC;
            EXEC SQL OPEN CDB_CRASWRKTIM_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
