/* Del Null Function */
void CDB_del_null_craswrktim(struct CRASWRKTIM_N_TAG *CRASWRKTIM_N, struct CRASWRKTIM_TAG *CRASWRKTIM)
{
    MEMCPY_DN(CRASWRKTIM->FACTORY, CRASWRKTIM_N->FACTORY, sizeof(CRASWRKTIM->FACTORY));
    MEMCPY_DN(CRASWRKTIM->RES_ID, CRASWRKTIM_N->RES_ID, sizeof(CRASWRKTIM->RES_ID));
