                    NVL(ZPIMSGID, ' '),
                    NVL(RETURN_TYPE, ' '),
                    NVL(RETURN_MSG, ' '),
                    NVL(ZIFERNAM, ' '),
                    NVL(ZIFDATE, ' '),
                    NVL(ZIFTIME, ' '),
                    NVL(ZPISTAT, ' '),
                    NVL(ZPIMSG, ' ')
                FROM IWIPCELGRB
				WHERE RETURN_TYPE <> 'E'
				AND ROWNUM < 10000
                ORDER BY DOC_ID ASC,
                    ACTION_TYPE ASC,
                    SMALLBOXID ASC,
                    SITE_ID ASC,
                    GR_BATCHNO ASC;
            EXEC SQL OPEN CDB_IWIPCELGRB_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_iwipcelgrb", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_iwipcelgrb(int sel_type, struct IWIPCELGRB_TAG *IWIPCELGRB)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IWIPCELGRB_N_TAG IWIPCELGRB_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_IWIPCELGRB_CUR_1 INTO
                :IWIPCELGRB_N.DOC_ID,
                :IWIPCELGRB_N.ACTION_TYPE,
                :IWIPCELGRB_N.DEL_YN,
                :IWIPCELGRB_N.SMALLBOXID,
                :IWIPCELGRB_N.SITE_ID,
                :IWIPCELGRB_N.GR_BATCHNO,
                :IWIPCELGRB_N.GR_DATE,
                :IWIPCELGRB_N.GI_BATCHNO,
                :IWIPCELGRB_N.INF_TIME,
                :IWIPCELGRB_N.INF_PROC_TIME,
                :IWIPCELGRB_N.CMF_1,
                :IWIPCELGRB_N.CMF_2,
                :IWIPCELGRB_N.CMF_3,
                :IWIPCELGRB_N.CMF_4,
                :IWIPCELGRB_N.CMF_5,
                :IWIPCELGRB_N.DATA_FLAG,
                :IWIPCELGRB_N.UPDATE_COUNT,
                :IWIPCELGRB_N.INSERT_COUNT,
                :IWIPCELGRB_N.DELETE_COUNT,
                :IWIPCELGRB_N.SQL_DML_COUNT,
                :IWIPCELGRB_N.ZPICODE,
                :IWIPCELGRB_N.ZPIMSGID,
                :IWIPCELGRB_N.RETURN_TYPE,
                :IWIPCELGRB_N.RETURN_MSG,
                :IWIPCELGRB_N.ZIFERNAM,
                :IWIPCELGRB_N.ZIFDATE,
                :IWIPCELGRB_N.ZIFTIME,
                :IWIPCELGRB_N.ZPISTAT,
                :IWIPCELGRB_N.ZPIMSG;
            break;

		case 2:
            EXEC SQL FETCH CDB_IWIPCELGRB_CUR_2 INTO
                :IWIPCELGRB_N.DOC_ID,
                :IWIPCELGRB_N.ACTION_TYPE,
                :IWIPCELGRB_N.DEL_YN,
                :IWIPCELGRB_N.SMALLBOXID,
                :IWIPCELGRB_N.SITE_ID,
                :IWIPCELGRB_N.GR_BATCHNO,
                :IWIPCELGRB_N.GR_DATE,
                :IWIPCELGRB_N.GI_BATCHNO,
                :IWIPCELGRB_N.INF_TIME,
                :IWIPCELGRB_N.INF_PROC_TIME,
                :IWIPCELGRB_N.CMF_1,
                :IWIPCELGRB_N.CMF_2,
                :IWIPCELGRB_N.CMF_3,
                :IWIPCELGRB_N.CMF_4,
                :IWIPCELGRB_N.CMF_5,
                :IWIPCELGRB_N.DATA_FLAG,
                :IWIPCELGRB_N.UPDATE_COUNT,
                :IWIPCELGRB_N.INSERT_COUNT,
                :IWIPCELGRB_N.DELETE_COUNT,
                :IWIPCELGRB_N.SQL_DML_COUNT,
                :IWIPCELGRB_N.ZPICODE,
                :IWIPCELGRB_N.ZPIMSGID,
                :IWIPCELGRB_N.RETURN_TYPE,
                :IWIPCELGRB_N.RETURN_MSG,
                :IWIPCELGRB_N.ZIFERNAM,
                :IWIPCELGRB_N.ZIFDATE,
                :IWIPCELGRB_N.ZIFTIME,
                :IWIPCELGRB_N.ZPISTAT,
                :IWIPCELGRB_N.ZPIMSG;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_iwipcelgrb(&IWIPCELGRB_N, IWIPCELGRB);
    }

    DB_stop_query_timer("CDB_fetch_iwipcelgrb", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_iwipcelgrb(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IWIPCELGRB_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IWIPCELGRB_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_iwipcelgrb", sel_type);
}


/* Initialize Function */
void CDB_init_iwipcelgrb(struct IWIPCELGRB_TAG *IWIPCELGRB)
{
    /* memset by Space */
    memset(IWIPCELGRB, ' ', sizeof(struct IWIPCELGRB_TAG));
    
}


/* Add Null Function */
void CDB_add_null_iwipcelgrb(struct IWIPCELGRB_N_TAG *IWIPCELGRB_N, struct IWIPCELGRB_TAG *IWIPCELGRB)
{
    /* memset by NULL */
    memset(IWIPCELGRB_N, '\0', sizeof(struct IWIPCELGRB_N_TAG));
    
    MEMCPY_AN(IWIPCELGRB_N->DOC_ID, IWIPCELGRB->DOC_ID, sizeof(IWIPCELGRB->DOC_ID));
    MEMCPY_AN(IWIPCELGRB_N->ACTION_TYPE, IWIPCELGRB->ACTION_TYPE, sizeof(IWIPCELGRB->ACTION_TYPE));
    IWIPCELGRB_N->DEL_YN[0] = IWIPCELGRB->DEL_YN;
    MEMCPY_AN(IWIPCELGRB_N->SMALLBOXID, IWIPCELGRB->SMALLBOXID, sizeof(IWIPCELGRB->SMALLBOXID));
    MEMCPY_AN(IWIPCELGRB_N->SITE_ID, IWIPCELGRB->SITE_ID, sizeof(IWIPCELGRB->SITE_ID));
    MEMCPY_AN(IWIPCELGRB_N->GR_BATCHNO, IWIPCELGRB->GR_BATCHNO, sizeof(IWIPCELGRB->GR_BATCHNO));
    MEMCPY_AN(IWIPCELGRB_N->GR_DATE, IWIPCELGRB->GR_DATE, sizeof(IWIPCELGRB->GR_DATE));
    MEMCPY_AN(IWIPCELGRB_N->GI_BATCHNO, IWIPCELGRB->GI_BATCHNO, sizeof(IWIPCELGRB->GI_BATCHNO));
    MEMCPY_AN(IWIPCELGRB_N->INF_TIME, IWIPCELGRB->INF_TIME, sizeof(IWIPCELGRB->INF_TIME));
    MEMCPY_AN(IWIPCELGRB_N->INF_PROC_TIME, IWIPCELGRB->INF_PROC_TIME, sizeof(IWIPCELGRB->INF_PROC_TIME));
    MEMCPY_AN(IWIPCELGRB_N->CMF_1, IWIPCELGRB->CMF_1, sizeof(IWIPCELGRB->CMF_1));
    MEMCPY_AN(IWIPCELGRB_N->CMF_2, IWIPCELGRB->CMF_2, sizeof(IWIPCELGRB->CMF_2));
    MEMCPY_AN(IWIPCELGRB_N->CMF_3, IWIPCELGRB->CMF_3, sizeof(IWIPCELGRB->CMF_3));
    MEMCPY_AN(IWIPCELGRB_N->CMF_4, IWIPCELGRB->CMF_4, sizeof(IWIPCELGRB->CMF_4));
    MEMCPY_AN(IWIPCELGRB_N->CMF_5, IWIPCELGRB->CMF_5, sizeof(IWIPCELGRB->CMF_5));
    IWIPCELGRB_N->DATA_FLAG[0] = IWIPCELGRB->DATA_FLAG;
    MEMCPY_AN(IWIPCELGRB_N->UPDATE_COUNT, IWIPCELGRB->UPDATE_COUNT, sizeof(IWIPCELGRB->UPDATE_COUNT));
    MEMCPY_AN(IWIPCELGRB_N->INSERT_COUNT, IWIPCELGRB->INSERT_COUNT, sizeof(IWIPCELGRB->INSERT_COUNT));
    MEMCPY_AN(IWIPCELGRB_N->DELETE_COUNT, IWIPCELGRB->DELETE_COUNT, sizeof(IWIPCELGRB->DELETE_COUNT));
    MEMCPY_AN(IWIPCELGRB_N->SQL_DML_COUNT, IWIPCELGRB->SQL_DML_COUNT, sizeof(IWIPCELGRB->SQL_DML_COUNT));
    MEMCPY_AN(IWIPCELGRB_N->ZPICODE, IWIPCELGRB->ZPICODE, sizeof(IWIPCELGRB->ZPICODE));
    MEMCPY_AN(IWIPCELGRB_N->ZPIMSGID, IWIPCELGRB->ZPIMSGID, sizeof(IWIPCELGRB->ZPIMSGID));
    IWIPCELGRB_N->RETURN_TYPE[0] = IWIPCELGRB->RETURN_TYPE;
    MEMCPY_AN(IWIPCELGRB_N->RETURN_MSG, IWIPCELGRB->RETURN_MSG, sizeof(IWIPCELGRB->RETURN_MSG));
    MEMCPY_AN(IWIPCELGRB_N->ZIFERNAM, IWIPCELGRB->ZIFERNAM, sizeof(IWIPCELGRB->ZIFERNAM));
    MEMCPY_AN(IWIPCELGRB_N->ZIFDATE, IWIPCELGRB->ZIFDATE, sizeof(IWIPCELGRB->ZIFDATE));
    MEMCPY_AN(IWIPCELGRB_N->ZIFTIME, IWIPCELGRB->ZIFTIME, sizeof(IWIPCELGRB->ZIFTIME));
    IWIPCELGRB_N->ZPISTAT[0] = IWIPCELGRB->ZPISTAT;
    MEMCPY_AN(IWIPCELGRB_N->ZPIMSG, IWIPCELGRB->ZPIMSG, sizeof(IWIPCELGRB->ZPIMSG));
}


/* Del Null Function */
void CDB_del_null_iwipcelgrb(struct IWIPCELGRB_N_TAG *IWIPCELGRB_N, struct IWIPCELGRB_TAG *IWIPCELGRB)
{
    MEMCPY_DN(IWIPCELGRB->DOC_ID, IWIPCELGRB_N->DOC_ID, sizeof(IWIPCELGRB->DOC_ID));
    MEMCPY_DN(IWIPCELGRB->ACTION_TYPE, IWIPCELGRB_N->ACTION_TYPE, sizeof(IWIPCELGRB->ACTION_TYPE));
    IWIPCELGRB->DEL_YN = IWIPCELGRB_N->DEL_YN[0];
    MEMCPY_DN(IWIPCELGRB->SMALLBOXID, IWIPCELGRB_N->SMALLBOXID, sizeof(IWIPCELGRB->SMALLBOXID));
    MEMCPY_DN(IWIPCELGRB->SITE_ID, IWIPCELGRB_N->SITE_ID, sizeof(IWIPCELGRB->SITE_ID));
    MEMCPY_DN(IWIPCELGRB->GR_BATCHNO, IWIPCELGRB_N->GR_BATCHNO, sizeof(IWIPCELGRB->GR_BATCHNO));
    MEMCPY_DN(IWIPCELGRB->GR_DATE, IWIPCELGRB_N->GR_DATE, sizeof(IWIPCELGRB->GR_DATE));
    MEMCPY_DN(IWIPCELGRB->GI_BATCHNO, IWIPCELGRB_N->GI_BATCHNO, sizeof(IWIPCELGRB->GI_BATCHNO));
    MEMCPY_DN(IWIPCELGRB->INF_TIME, IWIPCELGRB_N->INF_TIME, sizeof(IWIPCELGRB->INF_TIME));
    MEMCPY_DN(IWIPCELGRB->INF_PROC_TIME, IWIPCELGRB_N->INF_PROC_TIME, sizeof(IWIPCELGRB->INF_PROC_TIME));
    MEMCPY_DN(IWIPCELGRB->CMF_1, IWIPCELGRB_N->CMF_1, sizeof(IWIPCELGRB->CMF_1));
    MEMCPY_DN(IWIPCELGRB->CMF_2, IWIPCELGRB_N->CMF_2, sizeof(IWIPCELGRB->CMF_2));
    MEMCPY_DN(IWIPCELGRB->CMF_3, IWIPCELGRB_N->CMF_3, sizeof(IWIPCELGRB->CMF_3));
    MEMCPY_DN(IWIPCELGRB->CMF_4, IWIPCELGRB_N->CMF_4, sizeof(IWIPCELGRB->CMF_4));
    MEMCPY_DN(IWIPCELGRB->CMF_5, IWIPCELGRB_N->CMF_5, sizeof(IWIPCELGRB->CMF_5));
    IWIPCELGRB->DATA_FLAG = IWIPCELGRB_N->DATA_FLAG[0];
    MEMCPY_DN(IWIPCELGRB->UPDATE_COUNT, IWIPCELGRB_N->UPDATE_COUNT, sizeof(IWIPCELGRB->UPDATE_COUNT));
    MEMCPY_DN(IWIPCELGRB->INSERT_COUNT, IWIPCELGRB_N->INSERT_COUNT, sizeof(IWIPCELGRB->INSERT_COUNT));
    MEMCPY_DN(IWIPCELGRB->DELETE_COUNT, IWIPCELGRB_N->DELETE_COUNT, sizeof(IWIPCELGRB->DELETE_COUNT));
    MEMCPY_DN(IWIPCELGRB->SQL_DML_COUNT, IWIPCELGRB_N->SQL_DML_COUNT, sizeof(IWIPCELGRB->SQL_DML_COUNT));
    MEMCPY_DN(IWIPCELGRB->ZPICODE, IWIPCELGRB_N->ZPICODE, sizeof(IWIPCELGRB->ZPICODE));
    MEMCPY_DN(IWIPCELGRB->ZPIMSGID, IWIPCELGRB_N->ZPIMSGID, sizeof(IWIPCELGRB->ZPIMSGID));
    IWIPCELGRB->RETURN_TYPE = IWIPCELGRB_N->RETURN_TYPE[0];
    MEMCPY_DN(IWIPCELGRB->RETURN_MSG, IWIPCELGRB_N->RETURN_MSG, sizeof(IWIPCELGRB->RETURN_MSG));
    MEMCPY_DN(IWIPCELGRB->ZIFERNAM, IWIPCELGRB_N->ZIFERNAM, sizeof(IWIPCELGRB->ZIFERNAM));
    MEMCPY_DN(IWIPCELGRB->ZIFDATE, IWIPCELGRB_N->ZIFDATE, sizeof(IWIPCELGRB->ZIFDATE));
    MEMCPY_DN(IWIPCELGRB->ZIFTIME, IWIPCELGRB_N->ZIFTIME, sizeof(IWIPCELGRB->ZIFTIME));
    IWIPCELGRB->ZPISTAT = IWIPCELGRB_N->ZPISTAT[0];
    MEMCPY_DN(IWIPCELGRB->ZPIMSG, IWIPCELGRB_N->ZPIMSG, sizeof(IWIPCELGRB->ZPIMSG));
}


