                    TIME13_QTY,
                    TIME14_QTY,
                    TIME15_QTY,
                    TIME16_QTY,
                    TIME17_QTY,
                    TIME18_QTY,
                    TIME19_QTY,
                    TIME20_QTY,
                    TIME21_QTY,
                    TIME22_QTY,
                    TIME23_QTY,
                    TIME24_QTY,
                    ETC1_QTY,
                    ETC2_QTY,
                    ETC3_QTY,
                    ETC4_QTY,
                    ETC5_QTY,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM RSUMHORCEL
                ORDER BY FACTORY ASC,
                    WORK_DATE ASC,
                    LINE_ID ASC,
                    RES_ID ASC,
                    ORDER_ID ASC,
                    RESULT_VALUE ASC,
                    DEFECT ASC,
                    CM_KEY_1 ASC,
                    CM_KEY_2 ASC,
                    CM_KEY_3 ASC;
            EXEC SQL OPEN CDB_RSUMHORCEL_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_rsumhorcel", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_rsumhorcel(int sel_type, struct RSUMHORCEL_TAG *RSUMHORCEL)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMHORCEL_N_TAG RSUMHORCEL_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_RSUMHORCEL_CUR_1 INTO
                :RSUMHORCEL_N.FACTORY,
                :RSUMHORCEL_N.WORK_DATE,
                :RSUMHORCEL_N.LINE_ID,
                :RSUMHORCEL_N.RES_ID,
                :RSUMHORCEL_N.ORDER_ID,
                :RSUMHORCEL_N.RESULT_VALUE,
                :RSUMHORCEL_N.DEFECT,
                :RSUMHORCEL_N.CM_KEY_1,
                :RSUMHORCEL_N.CM_KEY_2,
                :RSUMHORCEL_N.CM_KEY_3,
                :RSUMHORCEL_N.TOTAL_QTY,
                :RSUMHORCEL_N.TIME01_QTY,
                :RSUMHORCEL_N.TIME02_QTY,
                :RSUMHORCEL_N.TIME03_QTY,
                :RSUMHORCEL_N.TIME04_QTY,
                :RSUMHORCEL_N.TIME05_QTY,
                :RSUMHORCEL_N.TIME06_QTY,
                :RSUMHORCEL_N.TIME07_QTY,
                :RSUMHORCEL_N.TIME08_QTY,
                :RSUMHORCEL_N.TIME09_QTY,
                :RSUMHORCEL_N.TIME10_QTY,
                :RSUMHORCEL_N.TIME11_QTY,
                :RSUMHORCEL_N.TIME12_QTY,
                :RSUMHORCEL_N.TIME13_QTY,
                :RSUMHORCEL_N.TIME14_QTY,
                :RSUMHORCEL_N.TIME15_QTY,
                :RSUMHORCEL_N.TIME16_QTY,
                :RSUMHORCEL_N.TIME17_QTY,
                :RSUMHORCEL_N.TIME18_QTY,
                :RSUMHORCEL_N.TIME19_QTY,
                :RSUMHORCEL_N.TIME20_QTY,
                :RSUMHORCEL_N.TIME21_QTY,
                :RSUMHORCEL_N.TIME22_QTY,
                :RSUMHORCEL_N.TIME23_QTY,
                :RSUMHORCEL_N.TIME24_QTY,
                :RSUMHORCEL_N.ETC1_QTY,
                :RSUMHORCEL_N.ETC2_QTY,
                :RSUMHORCEL_N.ETC3_QTY,
                :RSUMHORCEL_N.ETC4_QTY,
                :RSUMHORCEL_N.ETC5_QTY,
                :RSUMHORCEL_N.CMF_1,
                :RSUMHORCEL_N.CMF_2,
                :RSUMHORCEL_N.CMF_3,
                :RSUMHORCEL_N.CMF_4,
                :RSUMHORCEL_N.CMF_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_rsumhorcel(&RSUMHORCEL_N, RSUMHORCEL);
    }

    DB_stop_query_timer("CDB_fetch_rsumhorcel", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_rsumhorcel(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_RSUMHORCEL_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_rsumhorcel", sel_type);
}


