/* Add Null Function */
void CDB_add_null_rsumhorcel(struct RSUMHORCEL_N_TAG *RSUMHORCEL_N, struct RSUMHORCEL_TAG *RSUMHORCEL)
{
    /* memset by NULL */
    memset(RSUMHORCEL_N, '\0', sizeof(struct RSUMHORCEL_N_TAG));
    
    MEMCPY_AN(RSUMHORCEL_N->FACTORY, RSUMHORCEL->FACTORY, sizeof(RSUMHORCEL->FACTORY));
