                    NVL(BCR_POWER, ' '),
                    NVL(BCR_LIST_CODE, ' '),
                    NVL(BCR_PROD_BATCH_NO, ' '),
                    NVL(BCR_MOD_CLASS, ' '),
                    NVL(BCR_MOD_TYPE, ' '),
                    NVL(BCR_MOD_SUBTYPE, ' '),
                    NVL(CUST_ISC_YN, ' '),
                    NVL(OPER_NO, ' '),
                    NVL(WORK_CENTER, ' '),
                    NVL(WORK_CENTER_DESC, ' '),
                    NVL(STD_TEXT_KEY, ' '),
                    NVL(OPER_SHORT_DESC, ' '),
                    NVL(DEL_YN, ' '),
                    NVL(VALUATION_TYPE, ' '),
                    NVL(ZZBOMID, ' '),
                    NVL(ZSHIPNO, ' '),
                    NVL(ZARTCOR, ' '),
                    NVL(INF_TIME, ' '),
                    NVL(INF_PROC_TIME, ' '),
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' '),
                    NVL(DATA_FLAG, ' '),
                    NVL(UPDATE_COUNT, ' '),
                    NVL(INSERT_COUNT, ' '),
                    NVL(DELETE_COUNT, ' '),
                    NVL(SQL_DML_COUNT, ' '),
                    NVL(ZPICODE, ' '),
                    NVL(ZPIMSGID, ' '),
                    NVL(RETURN_TYPE, ' '),
                    NVL(RETURN_MSG, ' '),
                    NVL(ZIFERNAM, ' '),
                    NVL(ZIFDATE, ' '),
                    NVL(ZIFTIME, ' '),
                    NVL(ZPISTAT, ' '),
                    NVL(ZPIMSG, ' ')
                FROM IWIPORDDAT
				WHERE RETURN_TYPE <> 'E'
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_ORDER_NO ASC;
            EXEC SQL OPEN CDB_IWIPORDDAT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_iwiporddat", sel_type);
}


/* SQL CURSOR FETCH Function */
