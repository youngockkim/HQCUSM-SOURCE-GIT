/* Del Null Function */
void CDB_del_null_iwiporddat(struct IWIPORDDAT_N_TAG *IWIPORDDAT_N, struct IWIPORDDAT_TAG *IWIPORDDAT)
{
    MEMCPY_DN(IWIPORDDAT->DOC_ID, IWIPORDDAT_N->DOC_ID, sizeof(IWIPORDDAT->DOC_ID));
