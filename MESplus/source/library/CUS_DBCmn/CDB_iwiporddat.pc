                    INF_TIME = :IWIPORDDAT_N.INF_TIME,
                    INF_PROC_TIME = :IWIPORDDAT_N.INF_PROC_TIME,
                    CMF_1 = :IWIPORDDAT_N.CMF_1,
                    CMF_2 = :IWIPORDDAT_N.CMF_2,
