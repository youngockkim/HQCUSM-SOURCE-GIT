/* SQL CURSOR CLOSE Function */
void CDB_close_iwiporddat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IWIPORDDAT_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IWIPORDDAT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_iwiporddat", sel_type);
}


/* Initialize Function */
void CDB_init_iwiporddat(struct IWIPORDDAT_TAG *IWIPORDDAT)
{
    /* memset by Space */
    memset(IWIPORDDAT, ' ', sizeof(struct IWIPORDDAT_TAG));
    
    IWIPORDDAT->PROD_QTY = 0;
}


/* Add Null Function */
void CDB_add_null_iwiporddat(struct IWIPORDDAT_N_TAG *IWIPORDDAT_N, struct IWIPORDDAT_TAG *IWIPORDDAT)
{
    /* memset by NULL */
    memset(IWIPORDDAT_N, '\0', sizeof(struct IWIPORDDAT_N_TAG));
    
    MEMCPY_AN(IWIPORDDAT_N->DOC_ID, IWIPORDDAT->DOC_ID, sizeof(IWIPORDDAT->DOC_ID));
    MEMCPY_AN(IWIPORDDAT_N->SITE_ID, IWIPORDDAT->SITE_ID, sizeof(IWIPORDDAT->SITE_ID));
    MEMCPY_AN(IWIPORDDAT_N->PROD_ORDER_NO, IWIPORDDAT->PROD_ORDER_NO, sizeof(IWIPORDDAT->PROD_ORDER_NO));
    MEMCPY_AN(IWIPORDDAT_N->PROD_ORDER_VER, IWIPORDDAT->PROD_ORDER_VER, sizeof(IWIPORDDAT->PROD_ORDER_VER));
    MEMCPY_AN(IWIPORDDAT_N->PROD_NO, IWIPORDDAT->PROD_NO, sizeof(IWIPORDDAT->PROD_NO));
    MEMCPY_AN(IWIPORDDAT_N->PROD_NO_DESC, IWIPORDDAT->PROD_NO_DESC, sizeof(IWIPORDDAT->PROD_NO_DESC));
    MEMCPY_AN(IWIPORDDAT_N->PROD_ORDER_TYPE, IWIPORDDAT->PROD_ORDER_TYPE, sizeof(IWIPORDDAT->PROD_ORDER_TYPE));
    MEMCPY_AN(IWIPORDDAT_N->PROD_ORDER_SUBTYPE, IWIPORDDAT->PROD_ORDER_SUBTYPE, sizeof(IWIPORDDAT->PROD_ORDER_SUBTYPE));
    IWIPORDDAT_N->PROD_QTY = IWIPORDDAT->PROD_QTY;
