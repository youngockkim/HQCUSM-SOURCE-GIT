                    :IWIPORDDAT_N.OPER_SHORT_DESC,
                    :IWIPORDDAT_N.DEL_YN,
                    :IWIPORDDAT_N.VALUATION_TYPE,
                    :IWIPORDDAT_N.ZZBOMID,
                    :IWIPORDDAT_N.ZSHIPNO,
                    :IWIPORDDAT_N.ZARTCOR,
                    :IWIPORDDAT_N.INF_TIME,
                    :IWIPORDDAT_N.INF_PROC_TIME,
                    :IWIPORDDAT_N.CMF_1,
                    :IWIPORDDAT_N.CMF_2,
                    :IWIPORDDAT_N.CMF_3,
                    :IWIPORDDAT_N.CMF_4,
                    :IWIPORDDAT_N.CMF_5,
                    :IWIPORDDAT_N.DATA_FLAG,
                    :IWIPORDDAT_N.UPDATE_COUNT,
                    :IWIPORDDAT_N.INSERT_COUNT,
                    :IWIPORDDAT_N.DELETE_COUNT,
                    :IWIPORDDAT_N.SQL_DML_COUNT,
                    :IWIPORDDAT_N.ZPICODE,
                    :IWIPORDDAT_N.ZPIMSGID,
                    :IWIPORDDAT_N.RETURN_TYPE,
                    :IWIPORDDAT_N.RETURN_MSG,
                    :IWIPORDDAT_N.ZIFERNAM,
                    :IWIPORDDAT_N.ZIFDATE,
                    :IWIPORDDAT_N.ZIFTIME,
                    :IWIPORDDAT_N.ZPISTAT,
                    :IWIPORDDAT_N.ZPIMSG
                FROM IWIPORDDAT
                WHERE DOC_ID = :IWIPORDDAT_N.DOC_ID
                    AND SITE_ID = :IWIPORDDAT_N.SITE_ID
                    AND PROD_ORDER_NO = :IWIPORDDAT_N.PROD_ORDER_NO
                FOR UPDATE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_iwiporddat(&IWIPORDDAT_N, IWIPORDDAT);
    }

    DB_stop_query_timer("CDB_select_iwiporddat_for_update", sel_type);
}


/* SQL SELECT_SCALAR Function */
double CDB_select_iwiporddat_scalar(int sel_type, struct IWIPORDDAT_TAG *IWIPORDDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IWIPORDDAT_N_TAG IWIPORDDAT_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_iwiporddat(&IWIPORDDAT_N, IWIPORDDAT);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM IWIPORDDAT
                WHERE DOC_ID = :IWIPORDDAT_N.DOC_ID
                    AND SITE_ID = :IWIPORDDAT_N.SITE_ID
                    AND PROD_ORDER_NO = :IWIPORDDAT_N.PROD_ORDER_NO;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_iwiporddat_scalar", sel_type);

    return d_value;
}


/* SQL DELETE Function */
void CDB_delete_iwiporddat(int sel_type, struct IWIPORDDAT_TAG *IWIPORDDAT)
