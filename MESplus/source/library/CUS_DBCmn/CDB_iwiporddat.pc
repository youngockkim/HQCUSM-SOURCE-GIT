                :IWIPORDDAT_N.ZPISTAT,
                :IWIPORDDAT_N.ZPIMSG;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_iwiporddat(&IWIPORDDAT_N, IWIPORDDAT);
    }

    DB_stop_query_timer("CDB_fetch_iwiporddat", sel_type);
