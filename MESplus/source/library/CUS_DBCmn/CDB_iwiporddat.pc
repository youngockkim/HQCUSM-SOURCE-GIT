    MEMCPY_AN(IWIPORDDAT_N->WORK_SHOP, IWIPORDDAT->WORK_SHOP, sizeof(IWIPORDDAT->WORK_SHOP));
    IWIPORDDAT_N->BLOCK_YN[0] = IWIPORDDAT->BLOCK_YN;
