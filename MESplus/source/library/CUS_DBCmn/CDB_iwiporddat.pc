                    ZIFTIME = :IWIPORDDAT_N.ZIFTIME,
                    ZPISTAT = :IWIPORDDAT_N.ZPISTAT,
                    ZPIMSG = :IWIPORDDAT_N.ZPIMSG
                WHERE DOC_ID = :IWIPORDDAT_N.DOC_ID
                    AND SITE_ID = :IWIPORDDAT_N.SITE_ID
                    AND PROD_ORDER_NO = :IWIPORDDAT_N.PROD_ORDER_NO;
            break;

		case 2:
            EXEC SQL UPDATE IWIPORDDAT SET                    
                    INF_PROC_TIME = :IWIPORDDAT_N.INF_PROC_TIME,                    
                    RETURN_TYPE = 'E',
                    RETURN_MSG = :IWIPORDDAT_N.RETURN_MSG
                WHERE DOC_ID = :IWIPORDDAT_N.DOC_ID
                    AND SITE_ID = :IWIPORDDAT_N.SITE_ID
                    AND PROD_ORDER_NO = :IWIPORDDAT_N.PROD_ORDER_NO;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_iwiporddat", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_iwiporddat(int sel_type, struct IWIPORDDAT_TAG *IWIPORDDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IWIPORDDAT_N_TAG IWIPORDDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_iwiporddat(&IWIPORDDAT_N, IWIPORDDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IWIPORDDAT_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_ORDER_NO,
                    NVL(PROD_ORDER_VER, ' '),
                    NVL(PROD_NO, ' '),
