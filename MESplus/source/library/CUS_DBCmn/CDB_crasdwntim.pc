}


/* Add Null Function */
void CDB_add_null_crasdwntim(struct CRASDWNTIM_N_TAG *CRASDWNTIM_N, struct CRASDWNTIM_TAG *CRASDWNTIM)
{
    /* memset by NULL */
    memset(CRASDWNTIM_N, '\0', sizeof(struct CRASDWNTIM_N_TAG));
    
    MEMCPY_AN(CRASDWNTIM_N->WORK_DATE, CRASDWNTIM->WORK_DATE, sizeof(CRASDWNTIM->WORK_DATE));
    MEMCPY_AN(CRASDWNTIM_N->LINE_ID, CRASDWNTIM->LINE_ID, sizeof(CRASDWNTIM->LINE_ID));
    MEMCPY_AN(CRASDWNTIM_N->WORK_SHIFT, CRASDWNTIM->WORK_SHIFT, sizeof(CRASDWNTIM->WORK_SHIFT));
    MEMCPY_AN(CRASDWNTIM_N->PROCESS_TYPE, CRASDWNTIM->PROCESS_TYPE, sizeof(CRASDWNTIM->PROCESS_TYPE));
    CRASDWNTIM_N->EFF_TIME = CRASDWNTIM->EFF_TIME;
    MEMCPY_AN(CRASDWNTIM_N->CREATE_USER_ID, CRASDWNTIM->CREATE_USER_ID, sizeof(CRASDWNTIM->CREATE_USER_ID));
    MEMCPY_AN(CRASDWNTIM_N->UPDATE_USER_ID, CRASDWNTIM->UPDATE_USER_ID, sizeof(CRASDWNTIM->UPDATE_USER_ID));
    MEMCPY_AN(CRASDWNTIM_N->TRAN_TIME, CRASDWNTIM->TRAN_TIME, sizeof(CRASDWNTIM->TRAN_TIME));
    MEMCPY_AN(CRASDWNTIM_N->REMARK, CRASDWNTIM->REMARK, sizeof(CRASDWNTIM->REMARK));
    MEMCPY_AN(CRASDWNTIM_N->CMF_1, CRASDWNTIM->CMF_1, sizeof(CRASDWNTIM->CMF_1));
    MEMCPY_AN(CRASDWNTIM_N->CMF_2, CRASDWNTIM->CMF_2, sizeof(CRASDWNTIM->CMF_2));
    MEMCPY_AN(CRASDWNTIM_N->CMF_3, CRASDWNTIM->CMF_3, sizeof(CRASDWNTIM->CMF_3));
    MEMCPY_AN(CRASDWNTIM_N->CMF_4, CRASDWNTIM->CMF_4, sizeof(CRASDWNTIM->CMF_4));
    MEMCPY_AN(CRASDWNTIM_N->CMF_5, CRASDWNTIM->CMF_5, sizeof(CRASDWNTIM->CMF_5));
}


/* Del Null Function */
void CDB_del_null_crasdwntim(struct CRASDWNTIM_N_TAG *CRASDWNTIM_N, struct CRASDWNTIM_TAG *CRASDWNTIM)
{
    MEMCPY_DN(CRASDWNTIM->WORK_DATE, CRASDWNTIM_N->WORK_DATE, sizeof(CRASDWNTIM->WORK_DATE));
    MEMCPY_DN(CRASDWNTIM->LINE_ID, CRASDWNTIM_N->LINE_ID, sizeof(CRASDWNTIM->LINE_ID));
    MEMCPY_DN(CRASDWNTIM->WORK_SHIFT, CRASDWNTIM_N->WORK_SHIFT, sizeof(CRASDWNTIM->WORK_SHIFT));
    MEMCPY_DN(CRASDWNTIM->PROCESS_TYPE, CRASDWNTIM_N->PROCESS_TYPE, sizeof(CRASDWNTIM->PROCESS_TYPE));
    CRASDWNTIM->EFF_TIME = CRASDWNTIM_N->EFF_TIME;
    MEMCPY_DN(CRASDWNTIM->CREATE_USER_ID, CRASDWNTIM_N->CREATE_USER_ID, sizeof(CRASDWNTIM->CREATE_USER_ID));
    MEMCPY_DN(CRASDWNTIM->UPDATE_USER_ID, CRASDWNTIM_N->UPDATE_USER_ID, sizeof(CRASDWNTIM->UPDATE_USER_ID));
    MEMCPY_DN(CRASDWNTIM->TRAN_TIME, CRASDWNTIM_N->TRAN_TIME, sizeof(CRASDWNTIM->TRAN_TIME));
    MEMCPY_DN(CRASDWNTIM->REMARK, CRASDWNTIM_N->REMARK, sizeof(CRASDWNTIM->REMARK));
    MEMCPY_DN(CRASDWNTIM->CMF_1, CRASDWNTIM_N->CMF_1, sizeof(CRASDWNTIM->CMF_1));
    MEMCPY_DN(CRASDWNTIM->CMF_2, CRASDWNTIM_N->CMF_2, sizeof(CRASDWNTIM->CMF_2));
    MEMCPY_DN(CRASDWNTIM->CMF_3, CRASDWNTIM_N->CMF_3, sizeof(CRASDWNTIM->CMF_3));
    MEMCPY_DN(CRASDWNTIM->CMF_4, CRASDWNTIM_N->CMF_4, sizeof(CRASDWNTIM->CMF_4));
    MEMCPY_DN(CRASDWNTIM->CMF_5, CRASDWNTIM_N->CMF_5, sizeof(CRASDWNTIM->CMF_5));
}


