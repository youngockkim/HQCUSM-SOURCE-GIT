/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_crasdwntim(int sel_type, struct CRASDWNTIM_TAG *CRASDWNTIM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASDWNTIM_N_TAG CRASDWNTIM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_crasdwntim(&CRASDWNTIM_N, CRASDWNTIM);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASDWNTIM_CUR_1 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    LINE_ID,
                    WORK_SHIFT,
                    PROCESS_TYPE,
                    NVL(EFF_TIME, '0'),
                    NVL(CREATE_USER_ID, ' '),
                    NVL(UPDATE_USER_ID, ' '),
                    NVL(TRAN_TIME, ' '),
                    NVL(REMARK, ' '),
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' ')
                FROM CRASDWNTIM
                ORDER BY WORK_DATE ASC,
                    LINE_ID ASC,
                    WORK_SHIFT ASC,
                    PROCESS_TYPE ASC;
            EXEC SQL OPEN CDB_CRASDWNTIM_CUR_1;
            break;

           case 2:         
			EXEC SQL DECLARE CDB_CRASDWNTIM_CUR_2 CURSOR FOR
                SELECT 
				A.Shift as WORK_SHIFT , 
				A.Line as LINE_ID, 
				A.Process as PROCESS_TYPE, 
				NVL(SUM_EFF_TIME, '0') as EFF_TIME,
				NVL(D.REMARK,' ') AS REMARK
				FROM (
				SELECT WORK_SHIFT Shift, LINE_ID Line, PROCESS_TYPE Process, SUM_EFF_TIME, ' ' Remark
				FROM (
				SELECT 
				WORK_SHIFT
				,LINE_ID  
				,PROCESS_TYPE, NVL(SUM(EFF_TIME),0) SUM_EFF_TIME, ' ' Remark
				FROM CRASHURGAP E
				WHERE 1=1
				AND (E.TYPE_4M != ' ' OR E.TYPE_4M IS NOT NULL)
				AND E.WORK_DATE(+)  = :CRASDWNTIM_N.WORK_DATE
				AND (PROCESS_TYPE != ' ' AND PROCESS_TYPE != 'FRONTEND' AND PROCESS_TYPE != 'BACKEND')
				GROUP BY WORK_SHIFT, LINE_ID, PROCESS_TYPE
				ORDER BY WORK_SHIFT, LINE_ID, NVL(SUM(EFF_TIME),0) DESC)
				WHERE 1=1
				) A , crasdwntim D  
				WHERE 1=1 
				AND A.Process = D.PROCESS_TYPE(+)
				AND A.Line = D.LINE_ID(+)
				AND A.Shift = D.WORK_SHIFT(+)
				AND D.WORK_DATE(+) = :CRASDWNTIM_N.WORK_DATE
				AND A.Shift = :CRASDWNTIM_N.WORK_SHIFT 
				ORDER BY LINE_ID,EFF_TIME DESC;
            EXEC SQL OPEN CDB_CRASDWNTIM_CUR_2;
            break;

		case 3:         
			EXEC SQL DECLARE CDB_CRASDWNTIM_CUR_3 CURSOR FOR
                SELECT 
				A.Shift as WORK_SHIFT , 
				A.Line as LINE_ID, 
				A.Process as PROCESS_TYPE, 
				NVL(SUM_EFF_TIME, '0') as EFF_TIME,
				NVL(D.REMARK,' ') AS REMARK
				FROM (
				SELECT WORK_SHIFT Shift, LINE_ID Line, PROCESS_TYPE Process, SUM_EFF_TIME, ' ' Remark
				FROM (
				SELECT 
				WORK_SHIFT
				,LINE_ID  
				,PROCESS_TYPE, NVL(SUM(EFF_TIME),0) SUM_EFF_TIME, ' ' Remark
				FROM CRASHURGAP E
				WHERE 1=1
				AND (E.TYPE_4M != ' ' OR E.TYPE_4M IS NOT NULL)
				AND E.WORK_DATE(+)  = :CRASDWNTIM_N.WORK_DATE
				AND (PROCESS_TYPE != ' ' AND PROCESS_TYPE != 'FRONTEND' AND PROCESS_TYPE != 'BACKEND')
				AND LINE_ID IN ( SELECT KEY_1 FROM MGCMTBLDAT WHERE TABLE_NAME  = '@LINE_CODE' AND DATA_5 = 'MA' AND DATA_7 = :CRASDWNTIM_N.CMF_5 )
				GROUP BY WORK_SHIFT, LINE_ID, PROCESS_TYPE
				ORDER BY WORK_SHIFT, LINE_ID, NVL(SUM(EFF_TIME),0) DESC)
				WHERE 1=1
				) A , crasdwntim D  
				WHERE 1=1 
				AND A.Process = D.PROCESS_TYPE(+)
				AND A.Line = D.LINE_ID(+)
				AND A.Shift = D.WORK_SHIFT(+)
				AND D.WORK_DATE(+) = :CRASDWNTIM_N.WORK_DATE
				AND A.Shift = :CRASDWNTIM_N.WORK_SHIFT 
				ORDER BY LINE_ID,EFF_TIME DESC;
            EXEC SQL OPEN CDB_CRASDWNTIM_CUR_3;
            break;



		case 4:         
			EXEC SQL DECLARE CDB_CRASDWNTIM_CUR_4 CURSOR FOR
                SELECT 
				A.Shift as WORK_SHIFT , 
				A.Line as LINE_ID, 
				A.Process as PROCESS_TYPE, 
				NVL(SUM_EFF_TIME, '0') as EFF_TIME,
				NVL(D.REMARK,' ') AS REMARK
				FROM (
				SELECT WORK_SHIFT Shift, LINE_ID Line, PROCESS_TYPE Process, SUM_EFF_TIME, ' ' Remark
				FROM (
				SELECT 
				WORK_SHIFT
				,LINE_ID  
				,PROCESS_TYPE, NVL(SUM(EFF_TIME),0) SUM_EFF_TIME, ' ' Remark
				FROM CRASHURGAP E
				WHERE 1=1
				AND (E.TYPE_4M != ' ' OR E.TYPE_4M IS NOT NULL)
				AND E.WORK_DATE(+)  = :CRASDWNTIM_N.WORK_DATE
				AND (PROCESS_TYPE != ' ' AND PROCESS_TYPE != 'FRONTEND' AND PROCESS_TYPE != 'BACKEND')
				AND LINE_ID IN ( SELECT KEY_1 FROM MGCMTBLDAT WHERE TABLE_NAME  = '@LINE_CODE' AND DATA_5 = 'MA' AND DATA_7 = :CRASDWNTIM_N.CMF_5 )
				AND HOUR_TYPE IN ( 'FE','BE')
				GROUP BY WORK_SHIFT, LINE_ID, PROCESS_TYPE
				ORDER BY WORK_SHIFT, LINE_ID, NVL(SUM(EFF_TIME),0) DESC)
				WHERE 1=1
				) A , crasdwntim D  
				WHERE 1=1 
				AND A.Process = D.PROCESS_TYPE(+)
				AND A.Line = D.LINE_ID(+)
				AND A.Shift = D.WORK_SHIFT(+)
				AND D.WORK_DATE(+) = :CRASDWNTIM_N.WORK_DATE
				AND A.Shift = :CRASDWNTIM_N.WORK_SHIFT 
				ORDER BY LINE_ID,EFF_TIME DESC;
            EXEC SQL OPEN CDB_CRASDWNTIM_CUR_4;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_crasdwntim", sel_type);
}


