    MEMCPY_DN(CWIPORDRTE->WORK_CENTER_DESC, CWIPORDRTE_N->WORK_CENTER_DESC, sizeof(CWIPORDRTE->WORK_CENTER_DESC));
    CWIPORDRTE->BASE_QUANTITY = CWIPORDRTE_N->BASE_QUANTITY;
    MEMCPY_DN(CWIPORDRTE->BASE_UNIT, CWIPORDRTE_N->BASE_UNIT, sizeof(CWIPORDRTE->BASE_UNIT));
    MEMCPY_DN(CWIPORDRTE->DIRECT_LABOUR_UNIT, CWIPORDRTE_N->DIRECT_LABOUR_UNIT, sizeof(CWIPORDRTE->DIRECT_LABOUR_UNIT));
    CWIPORDRTE->DIRECT_LABOUR = CWIPORDRTE_N->DIRECT_LABOUR;
    MEMCPY_DN(CWIPORDRTE->INDIRECT_LABOUR_UNIT, CWIPORDRTE_N->INDIRECT_LABOUR_UNIT, sizeof(CWIPORDRTE->INDIRECT_LABOUR_UNIT));
    CWIPORDRTE->INDIRECT_LABOUR = CWIPORDRTE_N->INDIRECT_LABOUR;
    MEMCPY_DN(CWIPORDRTE->DEPRECIATION_UNIT, CWIPORDRTE_N->DEPRECIATION_UNIT, sizeof(CWIPORDRTE->DEPRECIATION_UNIT));
    CWIPORDRTE->DEPRECIATION = CWIPORDRTE_N->DEPRECIATION;
    MEMCPY_DN(CWIPORDRTE->UTILITIES_UNIT, CWIPORDRTE_N->UTILITIES_UNIT, sizeof(CWIPORDRTE->UTILITIES_UNIT));
    CWIPORDRTE->UTILITIES = CWIPORDRTE_N->UTILITIES;
    MEMCPY_DN(CWIPORDRTE->SPARE_PARTS_UNIT, CWIPORDRTE_N->SPARE_PARTS_UNIT, sizeof(CWIPORDRTE->SPARE_PARTS_UNIT));
    CWIPORDRTE->SPARE_PARTS = CWIPORDRTE_N->SPARE_PARTS;
    MEMCPY_DN(CWIPORDRTE->OTHER_COST_UNIT, CWIPORDRTE_N->OTHER_COST_UNIT, sizeof(CWIPORDRTE->OTHER_COST_UNIT));
    CWIPORDRTE->OTHER_COST = CWIPORDRTE_N->OTHER_COST;
    MEMCPY_DN(CWIPORDRTE->CRE_ID, CWIPORDRTE_N->CRE_ID, sizeof(CWIPORDRTE->CRE_ID));
    MEMCPY_DN(CWIPORDRTE->CRE_DATE, CWIPORDRTE_N->CRE_DATE, sizeof(CWIPORDRTE->CRE_DATE));
    MEMCPY_DN(CWIPORDRTE->MOD_ID, CWIPORDRTE_N->MOD_ID, sizeof(CWIPORDRTE->MOD_ID));
    MEMCPY_DN(CWIPORDRTE->MOD_DATE, CWIPORDRTE_N->MOD_DATE, sizeof(CWIPORDRTE->MOD_DATE));
    MEMCPY_DN(CWIPORDRTE->CMF_1, CWIPORDRTE_N->CMF_1, sizeof(CWIPORDRTE->CMF_1));
    MEMCPY_DN(CWIPORDRTE->CMF_2, CWIPORDRTE_N->CMF_2, sizeof(CWIPORDRTE->CMF_2));
    MEMCPY_DN(CWIPORDRTE->CMF_3, CWIPORDRTE_N->CMF_3, sizeof(CWIPORDRTE->CMF_3));
    MEMCPY_DN(CWIPORDRTE->CMF_4, CWIPORDRTE_N->CMF_4, sizeof(CWIPORDRTE->CMF_4));
    MEMCPY_DN(CWIPORDRTE->CMF_5, CWIPORDRTE_N->CMF_5, sizeof(CWIPORDRTE->CMF_5));
