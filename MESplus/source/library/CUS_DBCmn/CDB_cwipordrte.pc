    memset(CWIPORDRTE_N, '\0', sizeof(struct CWIPORDRTE_N_TAG));
    
    MEMCPY_AN(CWIPORDRTE_N->FACTORY, CWIPORDRTE->FACTORY, sizeof(CWIPORDRTE->FACTORY));
    MEMCPY_AN(CWIPORDRTE_N->ORDER_ID, CWIPORDRTE->ORDER_ID, sizeof(CWIPORDRTE->ORDER_ID));
    CWIPORDRTE_N->SEQ = CWIPORDRTE->SEQ;
    CWIPORDRTE_N->DEL_YN[0] = CWIPORDRTE->DEL_YN;
    MEMCPY_AN(CWIPORDRTE_N->OPER_NO, CWIPORDRTE->OPER_NO, sizeof(CWIPORDRTE->OPER_NO));
    MEMCPY_AN(CWIPORDRTE_N->WORK_CENTER, CWIPORDRTE->WORK_CENTER, sizeof(CWIPORDRTE->WORK_CENTER));
    MEMCPY_AN(CWIPORDRTE_N->WORK_CENTER_DESC, CWIPORDRTE->WORK_CENTER_DESC, sizeof(CWIPORDRTE->WORK_CENTER_DESC));
    CWIPORDRTE_N->BASE_QUANTITY = CWIPORDRTE->BASE_QUANTITY;
    MEMCPY_AN(CWIPORDRTE_N->BASE_UNIT, CWIPORDRTE->BASE_UNIT, sizeof(CWIPORDRTE->BASE_UNIT));
    MEMCPY_AN(CWIPORDRTE_N->DIRECT_LABOUR_UNIT, CWIPORDRTE->DIRECT_LABOUR_UNIT, sizeof(CWIPORDRTE->DIRECT_LABOUR_UNIT));
    CWIPORDRTE_N->DIRECT_LABOUR = CWIPORDRTE->DIRECT_LABOUR;
    MEMCPY_AN(CWIPORDRTE_N->INDIRECT_LABOUR_UNIT, CWIPORDRTE->INDIRECT_LABOUR_UNIT, sizeof(CWIPORDRTE->INDIRECT_LABOUR_UNIT));
    CWIPORDRTE_N->INDIRECT_LABOUR = CWIPORDRTE->INDIRECT_LABOUR;
    MEMCPY_AN(CWIPORDRTE_N->DEPRECIATION_UNIT, CWIPORDRTE->DEPRECIATION_UNIT, sizeof(CWIPORDRTE->DEPRECIATION_UNIT));
    CWIPORDRTE_N->DEPRECIATION = CWIPORDRTE->DEPRECIATION;
    MEMCPY_AN(CWIPORDRTE_N->UTILITIES_UNIT, CWIPORDRTE->UTILITIES_UNIT, sizeof(CWIPORDRTE->UTILITIES_UNIT));
    CWIPORDRTE_N->UTILITIES = CWIPORDRTE->UTILITIES;
    MEMCPY_AN(CWIPORDRTE_N->SPARE_PARTS_UNIT, CWIPORDRTE->SPARE_PARTS_UNIT, sizeof(CWIPORDRTE->SPARE_PARTS_UNIT));
    CWIPORDRTE_N->SPARE_PARTS = CWIPORDRTE->SPARE_PARTS;
    MEMCPY_AN(CWIPORDRTE_N->OTHER_COST_UNIT, CWIPORDRTE->OTHER_COST_UNIT, sizeof(CWIPORDRTE->OTHER_COST_UNIT));
    CWIPORDRTE_N->OTHER_COST = CWIPORDRTE->OTHER_COST;
    MEMCPY_AN(CWIPORDRTE_N->CRE_ID, CWIPORDRTE->CRE_ID, sizeof(CWIPORDRTE->CRE_ID));
    MEMCPY_AN(CWIPORDRTE_N->CRE_DATE, CWIPORDRTE->CRE_DATE, sizeof(CWIPORDRTE->CRE_DATE));
    MEMCPY_AN(CWIPORDRTE_N->MOD_ID, CWIPORDRTE->MOD_ID, sizeof(CWIPORDRTE->MOD_ID));
    MEMCPY_AN(CWIPORDRTE_N->MOD_DATE, CWIPORDRTE->MOD_DATE, sizeof(CWIPORDRTE->MOD_DATE));
    MEMCPY_AN(CWIPORDRTE_N->CMF_1, CWIPORDRTE->CMF_1, sizeof(CWIPORDRTE->CMF_1));
    MEMCPY_AN(CWIPORDRTE_N->CMF_2, CWIPORDRTE->CMF_2, sizeof(CWIPORDRTE->CMF_2));
    MEMCPY_AN(CWIPORDRTE_N->CMF_3, CWIPORDRTE->CMF_3, sizeof(CWIPORDRTE->CMF_3));
    MEMCPY_AN(CWIPORDRTE_N->CMF_4, CWIPORDRTE->CMF_4, sizeof(CWIPORDRTE->CMF_4));
    MEMCPY_AN(CWIPORDRTE_N->CMF_5, CWIPORDRTE->CMF_5, sizeof(CWIPORDRTE->CMF_5));
}


/* Del Null Function */
void CDB_del_null_cwipordrte(struct CWIPORDRTE_N_TAG *CWIPORDRTE_N, struct CWIPORDRTE_TAG *CWIPORDRTE)
{
    MEMCPY_DN(CWIPORDRTE->FACTORY, CWIPORDRTE_N->FACTORY, sizeof(CWIPORDRTE->FACTORY));
    MEMCPY_DN(CWIPORDRTE->ORDER_ID, CWIPORDRTE_N->ORDER_ID, sizeof(CWIPORDRTE->ORDER_ID));
    CWIPORDRTE->SEQ = CWIPORDRTE_N->SEQ;
    CWIPORDRTE->DEL_YN = CWIPORDRTE_N->DEL_YN[0];
    MEMCPY_DN(CWIPORDRTE->OPER_NO, CWIPORDRTE_N->OPER_NO, sizeof(CWIPORDRTE->OPER_NO));
