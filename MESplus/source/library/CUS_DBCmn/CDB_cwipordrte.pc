            EXEC SQL DECLARE CDB_CWIPORDRTE_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    ORDER_ID,
                    SEQ,
                    DEL_YN,
                    OPER_NO,
                    WORK_CENTER,
                    WORK_CENTER_DESC,
                    BASE_QUANTITY,
                    BASE_UNIT,
