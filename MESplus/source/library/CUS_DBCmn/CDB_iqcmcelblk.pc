                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IQCMCELBLK
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    SMALLBOXID ASC;
            EXEC SQL OPEN CDB_IQCMCELBLK_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_IQCMCELBLK_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    SMALLBOXID,
                    REPORT_NO,
                    BERGER_NO,
                    MATE_NO,
                    BLOCK_STATUS,
                    BLOCK_DATE,
