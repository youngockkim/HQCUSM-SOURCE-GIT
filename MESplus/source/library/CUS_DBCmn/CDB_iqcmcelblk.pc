                :IQCMCELBLK_N.REPORT_NO,
                :IQCMCELBLK_N.BERGER_NO,
                :IQCMCELBLK_N.MATE_NO,
                :IQCMCELBLK_N.BLOCK_STATUS,
                :IQCMCELBLK_N.BLOCK_DATE,
                :IQCMCELBLK_N.BLOCK_REASONCODE,
                :IQCMCELBLK_N.BLOCK_COMMENTS,
                :IQCMCELBLK_N.BLOCK_REASONCODE_SMALLBOX,
                :IQCMCELBLK_N.BLOCK_COMMENTS_SMALLBOX,
                :IQCMCELBLK_N.BLOCK_REASONCODE_LARA,
                :IQCMCELBLK_N.BLOCK_COMMENTS_LARA,
                :IQCMCELBLK_N.INF_TIME,
                :IQCMCELBLK_N.INF_PROC_TIME,
                :IQCMCELBLK_N.CMF_1,
                :IQCMCELBLK_N.CMF_2,
                :IQCMCELBLK_N.CMF_3,
                :IQCMCELBLK_N.CMF_4,
                :IQCMCELBLK_N.CMF_5,
                :IQCMCELBLK_N.DATA_FLAG,
                :IQCMCELBLK_N.UPDATE_COUNT,
                :IQCMCELBLK_N.INSERT_COUNT,
                :IQCMCELBLK_N.DELETE_COUNT,
                :IQCMCELBLK_N.SQL_DML_COUNT,
                :IQCMCELBLK_N.ZPICODE,
                :IQCMCELBLK_N.ZPIMSGID,
                :IQCMCELBLK_N.RETURN_TYPE,
                :IQCMCELBLK_N.RETURN_MSG,
                :IQCMCELBLK_N.ZIFERNAM,
                :IQCMCELBLK_N.ZIFDATE,
                :IQCMCELBLK_N.ZIFTIME,
                :IQCMCELBLK_N.ZPISTAT,
                :IQCMCELBLK_N.ZPIMSG;
            break;

		case 2:
            EXEC SQL FETCH CDB_IQCMCELBLK_CUR_2 INTO
                :IQCMCELBLK_N.DOC_ID,
                :IQCMCELBLK_N.SITE_ID,
                :IQCMCELBLK_N.SMALLBOXID,
                :IQCMCELBLK_N.REPORT_NO,
                :IQCMCELBLK_N.BERGER_NO,
                :IQCMCELBLK_N.MATE_NO,
                :IQCMCELBLK_N.BLOCK_STATUS,
                :IQCMCELBLK_N.BLOCK_DATE,
                :IQCMCELBLK_N.BLOCK_REASONCODE,
                :IQCMCELBLK_N.BLOCK_COMMENTS,
                :IQCMCELBLK_N.BLOCK_REASONCODE_SMALLBOX,
                :IQCMCELBLK_N.BLOCK_COMMENTS_SMALLBOX,
                :IQCMCELBLK_N.BLOCK_REASONCODE_LARA,
                :IQCMCELBLK_N.BLOCK_COMMENTS_LARA,
                :IQCMCELBLK_N.INF_TIME,
                :IQCMCELBLK_N.INF_PROC_TIME,
                :IQCMCELBLK_N.CMF_1,
                :IQCMCELBLK_N.CMF_2,
                :IQCMCELBLK_N.CMF_3,
                :IQCMCELBLK_N.CMF_4,
                :IQCMCELBLK_N.CMF_5,
                :IQCMCELBLK_N.DATA_FLAG,
                :IQCMCELBLK_N.UPDATE_COUNT,
                :IQCMCELBLK_N.INSERT_COUNT,
                :IQCMCELBLK_N.DELETE_COUNT,
                :IQCMCELBLK_N.SQL_DML_COUNT,
                :IQCMCELBLK_N.ZPICODE,
                :IQCMCELBLK_N.ZPIMSGID,
                :IQCMCELBLK_N.RETURN_TYPE,
                :IQCMCELBLK_N.RETURN_MSG,
                :IQCMCELBLK_N.ZIFERNAM,
                :IQCMCELBLK_N.ZIFDATE,
                :IQCMCELBLK_N.ZIFTIME,
                :IQCMCELBLK_N.ZPISTAT,
                :IQCMCELBLK_N.ZPIMSG;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_iqcmcelblk(&IQCMCELBLK_N, IQCMCELBLK);
    }

    DB_stop_query_timer("CDB_fetch_iqcmcelblk", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_iqcmcelblk(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IQCMCELBLK_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IQCMCELBLK_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_iqcmcelblk", sel_type);
}


/* Initialize Function */
void CDB_init_iqcmcelblk(struct IQCMCELBLK_TAG *IQCMCELBLK)
{
    /* memset by Space */
    memset(IQCMCELBLK, ' ', sizeof(struct IQCMCELBLK_TAG));
    
}


