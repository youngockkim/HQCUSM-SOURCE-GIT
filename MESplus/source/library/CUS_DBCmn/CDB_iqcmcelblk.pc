/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_iqcmcelblk(int sel_type, struct IQCMCELBLK_TAG *IQCMCELBLK)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IQCMCELBLK_N_TAG IQCMCELBLK_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_iqcmcelblk(&IQCMCELBLK_N, IQCMCELBLK);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IQCMCELBLK_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    SMALLBOXID,
                    REPORT_NO,
                    BERGER_NO,
                    MATE_NO,
                    BLOCK_STATUS,
                    BLOCK_DATE,
                    BLOCK_REASONCODE,
                    BLOCK_COMMENTS,
                    BLOCK_REASONCODE_SMALLBOX,
                    BLOCK_COMMENTS_SMALLBOX,
                    BLOCK_REASONCODE_LARA,
