        case 1:
            EXEC SQL CLOSE CDB_CWIPLOTOVR_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwiplotovr", sel_type);
}


/* Initialize Function */
void CDB_init_cwiplotovr(struct CWIPLOTOVR_TAG *CWIPLOTOVR)
{
    /* memset by Space */
    memset(CWIPLOTOVR, ' ', sizeof(struct CWIPLOTOVR_TAG));
    
}


/* Add Null Function */
void CDB_add_null_cwiplotovr(struct CWIPLOTOVR_N_TAG *CWIPLOTOVR_N, struct CWIPLOTOVR_TAG *CWIPLOTOVR)
{
    /* memset by NULL */
    memset(CWIPLOTOVR_N, '\0', sizeof(struct CWIPLOTOVR_N_TAG));
    
    MEMCPY_AN(CWIPLOTOVR_N->FACTORY, CWIPLOTOVR->FACTORY, sizeof(CWIPLOTOVR->FACTORY));
    MEMCPY_AN(CWIPLOTOVR_N->LOT_ID, CWIPLOTOVR->LOT_ID, sizeof(CWIPLOTOVR->LOT_ID));
