                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_TIME,
                    TRAN_TIME
                FROM CWIPLOTOVR
                ORDER BY FACTORY ASC,
                    LOT_ID ASC,
                    WORK_DATE ASC,
                    WORK_SHIFT ASC;
            EXEC SQL OPEN CDB_CWIPLOTOVR_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
