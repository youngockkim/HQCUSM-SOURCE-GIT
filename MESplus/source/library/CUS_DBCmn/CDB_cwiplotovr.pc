    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPLOTOVR_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOT_ID,
                    WORK_DATE,
                    WORK_SHIFT,
                    OVERKILL_FLAG,
                    REPAIR_TIME,
                    ORDER_ID,
                    LINE_ID,
                    RES_ID,
                    OPER,
