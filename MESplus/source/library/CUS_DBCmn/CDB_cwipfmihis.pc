                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10
                FROM CWIPFMIHIS
				WHERE FACTORY = :CWIPFMIHIS_N.FACTORY
					AND FM_TYPE = :CWIPFMIHIS_N.FM_TYPE
                    AND WORK_DATE >= :CWIPFMIHIS_N.WORK_DATE 
					AND WORK_DATE <= :CWIPFMIHIS_N.APPLY_TIME
                    AND LINE_ID LIKE :CWIPFMIHIS_N.LINE_ID
                ORDER BY FACTORY ASC,
                    WORK_DATE ASC,
                    LINE_ID ASC,
                    SEQ_NUM ASC;
            EXEC SQL OPEN CDB_CWIPFMIHIS_CUR_100;
            break;

		case 101:
		
            EXEC SQL DECLARE CDB_CWIPFMIHIS_CUR_101 CURSOR FOR
                SELECT 
                    FACTORY,
					FM_TYPE,
                    WORK_DATE,
                    LINE_ID,
                    SEQ_NUM,
                    OPER,
                    RES_ID,
                    APPLY_TIME,
                    KIND,
                    BEFORE,
                    AFTER,
                    DEPARTMENT,
                    CHARGE_USER_ID,
                    UNUSUAL_DESC,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10
                FROM CWIPFMIHIS
				WHERE FACTORY = :CWIPFMIHIS_N.FACTORY
					AND FM_TYPE = :CWIPFMIHIS_N.FM_TYPE
                    AND APPLY_TIME BETWEEN :CWIPFMIHIS_N.CMF_10  AND  :CWIPFMIHIS_N.APPLY_TIME
                    AND LINE_ID LIKE :CWIPFMIHIS_N.LINE_ID
					AND CMF_1 LIKE :CWIPFMIHIS_N.CMF_1
					AND CMF_2 LIKE :CWIPFMIHIS_N.CMF_2
					AND CMF_3 LIKE :CWIPFMIHIS_N.CMF_3
					AND CMF_4 LIKE :CWIPFMIHIS_N.CMF_4
                ORDER BY FACTORY ASC,
                    WORK_DATE ASC,
                    LINE_ID ASC,
                    SEQ_NUM ASC,
					APPLY_TIME ASC;
            EXEC SQL OPEN CDB_CWIPFMIHIS_CUR_101;
            break;


		case 102:
		
            EXEC SQL DECLARE CDB_CWIPFMIHIS_CUR_102 CURSOR FOR
                SELECT 
                    FACTORY,
					FM_TYPE,
                    WORK_DATE,
                    LINE_ID,
                    SEQ_NUM,
                    OPER,
                    RES_ID,
                    APPLY_TIME,
                    KIND,
                    BEFORE,
                    AFTER,
                    DEPARTMENT,
                    CHARGE_USER_ID,
                    UNUSUAL_DESC,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10
                FROM CWIPFMIHIS
				WHERE FACTORY = :CWIPFMIHIS_N.FACTORY
					AND FM_TYPE = :CWIPFMIHIS_N.FM_TYPE
                    AND APPLY_TIME BETWEEN :CWIPFMIHIS_N.CMF_10  AND  :CWIPFMIHIS_N.APPLY_TIME
                    AND LINE_ID LIKE :CWIPFMIHIS_N.LINE_ID
					AND RES_ID LIKE :CWIPFMIHIS_N.RES_ID
                    AND KIND LIKE :CWIPFMIHIS_N.KIND
					AND OPER LIKE :CWIPFMIHIS_N.OPER
					AND CMF_1 LIKE :CWIPFMIHIS_N.CMF_1
					AND DEPARTMENT LIKE :CWIPFMIHIS_N.DEPARTMENT
					AND LINE_ID IN ( SELECT KEY_1  
									 FROM MGCMTBLDAT 
									 WHERE FACTORY = 'USGAM1' 
									 AND TABLE_NAME = '@LINE_CODE' 
									 AND DATA_5 = 'MA' 
									 AND ( DATA_7 = :CWIPFMIHIS_N.CMF_8 
									 OR    DATA_7 = :CWIPFMIHIS_N.CMF_9 ))
                ORDER BY FACTORY ASC,
                    WORK_DATE ASC,
                    LINE_ID ASC,
                    SEQ_NUM ASC,
					APPLY_TIME ASC;
            EXEC SQL OPEN CDB_CWIPFMIHIS_CUR_102;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwipfmihis", sel_type);
}


