                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10
                FROM CWIPFMIHIS
                ORDER BY FACTORY ASC,
                    FM_TYPE ASC,
                    WORK_DATE ASC,
                    LINE_ID ASC,
                    SEQ_NUM ASC;
            EXEC SQL OPEN CDB_CWIPFMIHIS_CUR_1;
            break;

		case 100:
		
            EXEC SQL DECLARE CDB_CWIPFMIHIS_CUR_100 CURSOR FOR
                SELECT 
                    FACTORY,
					FM_TYPE,
                    WORK_DATE,
                    LINE_ID,
                    SEQ_NUM,
                    OPER,
                    RES_ID,
                    APPLY_TIME,
                    KIND,
                    BEFORE,
                    AFTER,
                    DEPARTMENT,
                    CHARGE_USER_ID,
                    UNUSUAL_DESC,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME,
                    CMF_1,
