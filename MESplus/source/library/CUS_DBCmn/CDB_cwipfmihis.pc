/* SQL CURSOR CLOSE Function */
void CDB_close_cwipfmihis(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CWIPFMIHIS_CUR_1;
            break;

		case 100:
            EXEC SQL CLOSE CDB_CWIPFMIHIS_CUR_100;
            break;

		case 101:
            EXEC SQL CLOSE CDB_CWIPFMIHIS_CUR_101;
            break;

		case 102:
            EXEC SQL CLOSE CDB_CWIPFMIHIS_CUR_102;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwipfmihis", sel_type);
}


/* Initialize Function */
void CDB_init_cwipfmihis(struct CWIPFMIHIS_TAG *CWIPFMIHIS)
{
    /* memset by Space */
    memset(CWIPFMIHIS, ' ', sizeof(struct CWIPFMIHIS_TAG));
    
    CWIPFMIHIS->SEQ_NUM = 0;
}


/* Add Null Function */
void CDB_add_null_cwipfmihis(struct CWIPFMIHIS_N_TAG *CWIPFMIHIS_N, struct CWIPFMIHIS_TAG *CWIPFMIHIS)
{
