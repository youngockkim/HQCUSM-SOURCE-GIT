/* Add Null Function */
void CDB_add_null_cmmscalrst(struct CMMSCALRST_N_TAG *CMMSCALRST_N, struct CMMSCALRST_TAG *CMMSCALRST)
{
    /* memset by NULL */
    memset(CMMSCALRST_N, '\0', sizeof(struct CMMSCALRST_N_TAG));
    
    MEMCPY_AN(CMMSCALRST_N->FACTORY, CMMSCALRST->FACTORY, sizeof(CMMSCALRST->FACTORY));
