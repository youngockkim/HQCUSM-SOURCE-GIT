    MEMCPY_AN(CMMSCALRST_N->CALI_USER_ID, CMMSCALRST->CALI_USER_ID, sizeof(CMMSCALRST->CALI_USER_ID));
    MEMCPY_AN(CMMSCALRST_N->FILE_NAME, CMMSCALRST->FILE_NAME, sizeof(CMMSCALRST->FILE_NAME));
