/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cpsmmntsts(int sel_type, struct CPSMMNTSTS_TAG *CPSMMNTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CPSMMNTSTS_N_TAG CPSMMNTSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cpsmmntsts(&CPSMMNTSTS_N, CPSMMNTSTS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CPSMMNTSTS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    CATEGORY,
                    BASE_CODE,
                    SUB_CODE,
                    DESCRIPTION,
                    PRINT_CHECK,
                    BASE_DT_TIME,
                    OPTION_1,
                    OPTION_2,
                    OPTION_3,
                    OPTION_4,
                    OPTION_5,
                    LAST_TRAN_TIME,
                    TRAN_USER_ID,
                    STATUS,
                    STATUS_MSG,
                    CLIENT_VERSION,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CPSMMNTSTS
				WHERE FACTORY = :CPSMMNTSTS_N.FACTORY
				  AND CATEGORY = :CPSMMNTSTS_N.CATEGORY
				  AND BASE_CODE LIKE '%' || TRiM(:CPSMMNTSTS_N.BASE_CODE) || '%'
				  AND SUB_CODE LIKE '%' || TRiM(:CPSMMNTSTS_N.SUB_CODE) || '%'
                ORDER BY FACTORY ASC,
                    CATEGORY ASC,
                    BASE_CODE ASC,
                    SUB_CODE ASC;
            EXEC SQL OPEN CDB_CPSMMNTSTS_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CPSMMNTSTS_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    CATEGORY,
                    BASE_CODE,
                    SUB_CODE,
                    DESCRIPTION,
                    PRINT_CHECK,
                    BASE_DT_TIME,
                    LAST_TRAN_TIME,
                    TRAN_USER_ID,
                    STATUS,
                    STATUS_MSG,
                    CLIENT_VERSION,
                    (CASE WHEN LENGTH(LAST_TRAN_TIME) = 14 THEN 
						(CASE WHEN (TO_DATE(LAST_TRAN_TIME, 'YYYYMMDDHH24MISS') < (SYSDATE - (BASE_DT_TIME/60/24))) THEN 'DT' ELSE ' ' END)
					ELSE ' ' END) AS CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CPSMMNTSTS
				WHERE FACTORY = :CPSMMNTSTS_N.FACTORY
				  AND CATEGORY = :CPSMMNTSTS_N.CATEGORY
				  AND BASE_CODE LIKE '%' || TRiM(:CPSMMNTSTS_N.BASE_CODE) || '%'
				  AND SUB_CODE LIKE '%' || TRiM(:CPSMMNTSTS_N.SUB_CODE) || '%'
                ORDER BY FACTORY ASC,
                    CATEGORY ASC,
                    BASE_CODE ASC,
                    SUB_CODE ASC;
            EXEC SQL OPEN CDB_CPSMMNTSTS_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cpsmmntsts", sel_type);
}


