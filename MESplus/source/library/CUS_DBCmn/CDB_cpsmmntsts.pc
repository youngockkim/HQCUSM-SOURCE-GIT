}


/* SQL CURSOR CLOSE Function */
void CDB_close_cpsmmntsts(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CPSMMNTSTS_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CPSMMNTSTS_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cpsmmntsts", sel_type);
}


/* Initialize Function */
void CDB_init_cpsmmntsts(struct CPSMMNTSTS_TAG *CPSMMNTSTS)
{
    /* memset by Space */
    memset(CPSMMNTSTS, ' ', sizeof(struct CPSMMNTSTS_TAG));
    
    CPSMMNTSTS->BASE_DT_TIME = 0;
}


/* Add Null Function */
void CDB_add_null_cpsmmntsts(struct CPSMMNTSTS_N_TAG *CPSMMNTSTS_N, struct CPSMMNTSTS_TAG *CPSMMNTSTS)
{
    /* memset by NULL */
    memset(CPSMMNTSTS_N, '\0', sizeof(struct CPSMMNTSTS_N_TAG));
    
    MEMCPY_AN(CPSMMNTSTS_N->FACTORY, CPSMMNTSTS->FACTORY, sizeof(CPSMMNTSTS->FACTORY));
    MEMCPY_AN(CPSMMNTSTS_N->CATEGORY, CPSMMNTSTS->CATEGORY, sizeof(CPSMMNTSTS->CATEGORY));
    MEMCPY_AN(CPSMMNTSTS_N->BASE_CODE, CPSMMNTSTS->BASE_CODE, sizeof(CPSMMNTSTS->BASE_CODE));
    MEMCPY_AN(CPSMMNTSTS_N->SUB_CODE, CPSMMNTSTS->SUB_CODE, sizeof(CPSMMNTSTS->SUB_CODE));
    MEMCPY_AN(CPSMMNTSTS_N->DESCRIPTION, CPSMMNTSTS->DESCRIPTION, sizeof(CPSMMNTSTS->DESCRIPTION));
    CPSMMNTSTS_N->PRINT_CHECK[0] = CPSMMNTSTS->PRINT_CHECK;
    CPSMMNTSTS_N->BASE_DT_TIME = CPSMMNTSTS->BASE_DT_TIME;
    MEMCPY_AN(CPSMMNTSTS_N->OPTION_1, CPSMMNTSTS->OPTION_1, sizeof(CPSMMNTSTS->OPTION_1));
    MEMCPY_AN(CPSMMNTSTS_N->OPTION_2, CPSMMNTSTS->OPTION_2, sizeof(CPSMMNTSTS->OPTION_2));
    MEMCPY_AN(CPSMMNTSTS_N->OPTION_3, CPSMMNTSTS->OPTION_3, sizeof(CPSMMNTSTS->OPTION_3));
    MEMCPY_AN(CPSMMNTSTS_N->OPTION_4, CPSMMNTSTS->OPTION_4, sizeof(CPSMMNTSTS->OPTION_4));
    MEMCPY_AN(CPSMMNTSTS_N->OPTION_5, CPSMMNTSTS->OPTION_5, sizeof(CPSMMNTSTS->OPTION_5));
    MEMCPY_AN(CPSMMNTSTS_N->LAST_TRAN_TIME, CPSMMNTSTS->LAST_TRAN_TIME, sizeof(CPSMMNTSTS->LAST_TRAN_TIME));
    MEMCPY_AN(CPSMMNTSTS_N->TRAN_USER_ID, CPSMMNTSTS->TRAN_USER_ID, sizeof(CPSMMNTSTS->TRAN_USER_ID));
    MEMCPY_AN(CPSMMNTSTS_N->STATUS, CPSMMNTSTS->STATUS, sizeof(CPSMMNTSTS->STATUS));
    MEMCPY_AN(CPSMMNTSTS_N->STATUS_MSG, CPSMMNTSTS->STATUS_MSG, sizeof(CPSMMNTSTS->STATUS_MSG));
    MEMCPY_AN(CPSMMNTSTS_N->CLIENT_VERSION, CPSMMNTSTS->CLIENT_VERSION, sizeof(CPSMMNTSTS->CLIENT_VERSION));
    MEMCPY_AN(CPSMMNTSTS_N->CMF_1, CPSMMNTSTS->CMF_1, sizeof(CPSMMNTSTS->CMF_1));
    MEMCPY_AN(CPSMMNTSTS_N->CMF_2, CPSMMNTSTS->CMF_2, sizeof(CPSMMNTSTS->CMF_2));
    MEMCPY_AN(CPSMMNTSTS_N->CMF_3, CPSMMNTSTS->CMF_3, sizeof(CPSMMNTSTS->CMF_3));
    MEMCPY_AN(CPSMMNTSTS_N->CMF_4, CPSMMNTSTS->CMF_4, sizeof(CPSMMNTSTS->CMF_4));
    MEMCPY_AN(CPSMMNTSTS_N->CMF_5, CPSMMNTSTS->CMF_5, sizeof(CPSMMNTSTS->CMF_5));
    MEMCPY_AN(CPSMMNTSTS_N->CMF_6, CPSMMNTSTS->CMF_6, sizeof(CPSMMNTSTS->CMF_6));
    MEMCPY_AN(CPSMMNTSTS_N->CMF_7, CPSMMNTSTS->CMF_7, sizeof(CPSMMNTSTS->CMF_7));
    MEMCPY_AN(CPSMMNTSTS_N->CMF_8, CPSMMNTSTS->CMF_8, sizeof(CPSMMNTSTS->CMF_8));
    MEMCPY_AN(CPSMMNTSTS_N->CMF_9, CPSMMNTSTS->CMF_9, sizeof(CPSMMNTSTS->CMF_9));
    MEMCPY_AN(CPSMMNTSTS_N->CMF_10, CPSMMNTSTS->CMF_10, sizeof(CPSMMNTSTS->CMF_10));
    MEMCPY_AN(CPSMMNTSTS_N->CREATE_USER_ID, CPSMMNTSTS->CREATE_USER_ID, sizeof(CPSMMNTSTS->CREATE_USER_ID));
    MEMCPY_AN(CPSMMNTSTS_N->CREATE_TIME, CPSMMNTSTS->CREATE_TIME, sizeof(CPSMMNTSTS->CREATE_TIME));
    MEMCPY_AN(CPSMMNTSTS_N->UPDATE_USER_ID, CPSMMNTSTS->UPDATE_USER_ID, sizeof(CPSMMNTSTS->UPDATE_USER_ID));
    MEMCPY_AN(CPSMMNTSTS_N->UPDATE_TIME, CPSMMNTSTS->UPDATE_TIME, sizeof(CPSMMNTSTS->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_cpsmmntsts(struct CPSMMNTSTS_N_TAG *CPSMMNTSTS_N, struct CPSMMNTSTS_TAG *CPSMMNTSTS)
{
    MEMCPY_DN(CPSMMNTSTS->FACTORY, CPSMMNTSTS_N->FACTORY, sizeof(CPSMMNTSTS->FACTORY));
    MEMCPY_DN(CPSMMNTSTS->CATEGORY, CPSMMNTSTS_N->CATEGORY, sizeof(CPSMMNTSTS->CATEGORY));
