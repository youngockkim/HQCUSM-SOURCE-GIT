/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwiptsclos(int sel_type, struct CWIPTSCLOS_TAG *CWIPTSCLOS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPTSCLOS_N_TAG CWIPTSCLOS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwiptsclos(&CWIPTSCLOS_N, CWIPTSCLOS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPTSCLOS_CUR_1 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    LINE_ID,
                    WORK_SHIFT,
                    TABBER,
                    SIDE,
                    TYPE_RECOVERY,
                    ADD_COMMENTS,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CWIPTSCLOS
                ORDER BY WORK_DATE ASC,
                    LINE_ID ASC,
                    WORK_SHIFT ASC,
                    CREATE_TIME ASC;
            EXEC SQL OPEN CDB_CWIPTSCLOS_CUR_1;
            break;
        
        case 2:
            EXEC SQL DECLARE CDB_CWIPTSCLOS_CUR_2 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    LINE_ID,
                    WORK_SHIFT,
                    TABBER,
                    SIDE,
                    TYPE_RECOVERY,
                    ADD_COMMENTS,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CWIPTSCLOS
                WHERE WORK_DATE >= :DBC_Q_COND_N.FROM_DATE 
	                AND WORK_DATE <= :DBC_Q_COND_N.TO_DATE
                    AND LINE_ID LIKE :CWIPTSCLOS_N.LINE_ID
                    AND WORK_SHIFT LIKE :CWIPTSCLOS_N.WORK_SHIFT
                ORDER BY WORK_DATE ASC,
                    LINE_ID ASC,
                    WORK_SHIFT ASC,
                    CREATE_TIME ASC;
            EXEC SQL OPEN CDB_CWIPTSCLOS_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwiptsclos", sel_type);
}


