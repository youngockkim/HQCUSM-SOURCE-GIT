                    FACTORY,
                    AUDIT_ID,
                    SORT_ORDER,
                    ITEM_DIVISION,
                    ITEM_NAME,
                    CHECK_DETAIL,
                    CHECK_RESULT,
                    FILE_NAME,
                    FILE_PATH,
                    ACTION_MGR_ID,
                    ACTION_LIMIT_DATE,
                    ACTION_DATE,
                    ACTION_USER_ID,
                    ACTION_FILE_NAME,
                    ACTION_FILE_PATH,
                    ACTION_RESULT,
                    REMARKS,
                    STATUS,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CAMSADTITM
				WHERE FACTORY = :CAMSADTITM_N.FACTORY
				  AND AUDIT_ID = :CAMSADTITM_N.AUDIT_ID
                ORDER BY FACTORY ASC,
                    AUDIT_ID ASC,
                    SORT_ORDER ASC;
            EXEC SQL OPEN CDB_CAMSADTITM_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_camsadtitm", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_camsadtitm(int sel_type, struct CAMSADTITM_TAG *CAMSADTITM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CAMSADTITM_N_TAG CAMSADTITM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CAMSADTITM_CUR_1 INTO
                :CAMSADTITM_N.FACTORY,
                :CAMSADTITM_N.AUDIT_ID,
                :CAMSADTITM_N.SORT_ORDER,
                :CAMSADTITM_N.ITEM_DIVISION,
                :CAMSADTITM_N.ITEM_NAME,
                :CAMSADTITM_N.CHECK_DETAIL,
                :CAMSADTITM_N.CHECK_RESULT,
                :CAMSADTITM_N.FILE_NAME,
                :CAMSADTITM_N.FILE_PATH,
                :CAMSADTITM_N.ACTION_MGR_ID,
                :CAMSADTITM_N.ACTION_LIMIT_DATE,
                :CAMSADTITM_N.ACTION_DATE,
                :CAMSADTITM_N.ACTION_USER_ID,
                :CAMSADTITM_N.ACTION_FILE_NAME,
                :CAMSADTITM_N.ACTION_FILE_PATH,
                :CAMSADTITM_N.ACTION_RESULT,
                :CAMSADTITM_N.REMARKS,
                :CAMSADTITM_N.STATUS,
                :CAMSADTITM_N.CMF_1,
                :CAMSADTITM_N.CMF_2,
                :CAMSADTITM_N.CMF_3,
                :CAMSADTITM_N.CMF_4,
                :CAMSADTITM_N.CMF_5,
                :CAMSADTITM_N.CMF_6,
                :CAMSADTITM_N.CMF_7,
                :CAMSADTITM_N.CMF_8,
                :CAMSADTITM_N.CMF_9,
                :CAMSADTITM_N.CMF_10,
                :CAMSADTITM_N.CREATE_USER_ID,
                :CAMSADTITM_N.CREATE_TIME,
                :CAMSADTITM_N.UPDATE_USER_ID,
                :CAMSADTITM_N.UPDATE_TIME;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_camsadtitm(&CAMSADTITM_N, CAMSADTITM);
    }

    DB_stop_query_timer("CDB_fetch_camsadtitm", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_camsadtitm(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CAMSADTITM_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_camsadtitm", sel_type);
}


/* Initialize Function */
void CDB_init_camsadtitm(struct CAMSADTITM_TAG *CAMSADTITM)
{
    /* memset by Space */
    memset(CAMSADTITM, ' ', sizeof(struct CAMSADTITM_TAG));
    
    CAMSADTITM->SORT_ORDER = 0;
}


/* Add Null Function */
void CDB_add_null_camsadtitm(struct CAMSADTITM_N_TAG *CAMSADTITM_N, struct CAMSADTITM_TAG *CAMSADTITM)
{
    /* memset by NULL */
    memset(CAMSADTITM_N, '\0', sizeof(struct CAMSADTITM_N_TAG));
    
    MEMCPY_AN(CAMSADTITM_N->FACTORY, CAMSADTITM->FACTORY, sizeof(CAMSADTITM->FACTORY));
    MEMCPY_AN(CAMSADTITM_N->AUDIT_ID, CAMSADTITM->AUDIT_ID, sizeof(CAMSADTITM->AUDIT_ID));
    CAMSADTITM_N->SORT_ORDER = CAMSADTITM->SORT_ORDER;
    MEMCPY_AN(CAMSADTITM_N->ITEM_DIVISION, CAMSADTITM->ITEM_DIVISION, sizeof(CAMSADTITM->ITEM_DIVISION));
    MEMCPY_AN(CAMSADTITM_N->ITEM_NAME, CAMSADTITM->ITEM_NAME, sizeof(CAMSADTITM->ITEM_NAME));
    MEMCPY_AN(CAMSADTITM_N->CHECK_DETAIL, CAMSADTITM->CHECK_DETAIL, sizeof(CAMSADTITM->CHECK_DETAIL));
	CAMSADTITM_N->CHECK_RESULT[0] = CAMSADTITM->CHECK_RESULT;
    MEMCPY_AN(CAMSADTITM_N->FILE_NAME, CAMSADTITM->FILE_NAME, sizeof(CAMSADTITM->FILE_NAME));
    MEMCPY_AN(CAMSADTITM_N->FILE_PATH, CAMSADTITM->FILE_PATH, sizeof(CAMSADTITM->FILE_PATH));
    MEMCPY_AN(CAMSADTITM_N->ACTION_MGR_ID, CAMSADTITM->ACTION_MGR_ID, sizeof(CAMSADTITM->ACTION_MGR_ID));
    MEMCPY_AN(CAMSADTITM_N->ACTION_LIMIT_DATE, CAMSADTITM->ACTION_LIMIT_DATE, sizeof(CAMSADTITM->ACTION_LIMIT_DATE));
    MEMCPY_AN(CAMSADTITM_N->ACTION_DATE, CAMSADTITM->ACTION_DATE, sizeof(CAMSADTITM->ACTION_DATE));
    MEMCPY_AN(CAMSADTITM_N->ACTION_USER_ID, CAMSADTITM->ACTION_USER_ID, sizeof(CAMSADTITM->ACTION_USER_ID));
    MEMCPY_AN(CAMSADTITM_N->ACTION_FILE_NAME, CAMSADTITM->ACTION_FILE_NAME, sizeof(CAMSADTITM->ACTION_FILE_NAME));
    MEMCPY_AN(CAMSADTITM_N->ACTION_FILE_PATH, CAMSADTITM->ACTION_FILE_PATH, sizeof(CAMSADTITM->ACTION_FILE_PATH));
    CAMSADTITM_N->ACTION_RESULT[0] = CAMSADTITM->ACTION_RESULT;
    MEMCPY_AN(CAMSADTITM_N->REMARKS, CAMSADTITM->REMARKS, sizeof(CAMSADTITM->REMARKS));
    CAMSADTITM_N->STATUS[0] = CAMSADTITM->STATUS;
    MEMCPY_AN(CAMSADTITM_N->CMF_1, CAMSADTITM->CMF_1, sizeof(CAMSADTITM->CMF_1));
    MEMCPY_AN(CAMSADTITM_N->CMF_2, CAMSADTITM->CMF_2, sizeof(CAMSADTITM->CMF_2));
    MEMCPY_AN(CAMSADTITM_N->CMF_3, CAMSADTITM->CMF_3, sizeof(CAMSADTITM->CMF_3));
    MEMCPY_AN(CAMSADTITM_N->CMF_4, CAMSADTITM->CMF_4, sizeof(CAMSADTITM->CMF_4));
    MEMCPY_AN(CAMSADTITM_N->CMF_5, CAMSADTITM->CMF_5, sizeof(CAMSADTITM->CMF_5));
    MEMCPY_AN(CAMSADTITM_N->CMF_6, CAMSADTITM->CMF_6, sizeof(CAMSADTITM->CMF_6));
    MEMCPY_AN(CAMSADTITM_N->CMF_7, CAMSADTITM->CMF_7, sizeof(CAMSADTITM->CMF_7));
    MEMCPY_AN(CAMSADTITM_N->CMF_8, CAMSADTITM->CMF_8, sizeof(CAMSADTITM->CMF_8));
    MEMCPY_AN(CAMSADTITM_N->CMF_9, CAMSADTITM->CMF_9, sizeof(CAMSADTITM->CMF_9));
    MEMCPY_AN(CAMSADTITM_N->CMF_10, CAMSADTITM->CMF_10, sizeof(CAMSADTITM->CMF_10));
    MEMCPY_AN(CAMSADTITM_N->CREATE_USER_ID, CAMSADTITM->CREATE_USER_ID, sizeof(CAMSADTITM->CREATE_USER_ID));
    MEMCPY_AN(CAMSADTITM_N->CREATE_TIME, CAMSADTITM->CREATE_TIME, sizeof(CAMSADTITM->CREATE_TIME));
    MEMCPY_AN(CAMSADTITM_N->UPDATE_USER_ID, CAMSADTITM->UPDATE_USER_ID, sizeof(CAMSADTITM->UPDATE_USER_ID));
    MEMCPY_AN(CAMSADTITM_N->UPDATE_TIME, CAMSADTITM->UPDATE_TIME, sizeof(CAMSADTITM->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_camsadtitm(struct CAMSADTITM_N_TAG *CAMSADTITM_N, struct CAMSADTITM_TAG *CAMSADTITM)
{
    MEMCPY_DN(CAMSADTITM->FACTORY, CAMSADTITM_N->FACTORY, sizeof(CAMSADTITM->FACTORY));
    MEMCPY_DN(CAMSADTITM->AUDIT_ID, CAMSADTITM_N->AUDIT_ID, sizeof(CAMSADTITM->AUDIT_ID));
    CAMSADTITM->SORT_ORDER = CAMSADTITM_N->SORT_ORDER;
    MEMCPY_DN(CAMSADTITM->ITEM_DIVISION, CAMSADTITM_N->ITEM_DIVISION, sizeof(CAMSADTITM->ITEM_DIVISION));
    MEMCPY_DN(CAMSADTITM->ITEM_NAME, CAMSADTITM_N->ITEM_NAME, sizeof(CAMSADTITM->ITEM_NAME));
    MEMCPY_DN(CAMSADTITM->CHECK_DETAIL, CAMSADTITM_N->CHECK_DETAIL, sizeof(CAMSADTITM->CHECK_DETAIL));
	CAMSADTITM->CHECK_RESULT = CAMSADTITM_N->CHECK_RESULT[0];
    MEMCPY_DN(CAMSADTITM->FILE_NAME, CAMSADTITM_N->FILE_NAME, sizeof(CAMSADTITM->FILE_NAME));
    MEMCPY_DN(CAMSADTITM->FILE_PATH, CAMSADTITM_N->FILE_PATH, sizeof(CAMSADTITM->FILE_PATH));
    MEMCPY_DN(CAMSADTITM->ACTION_MGR_ID, CAMSADTITM_N->ACTION_MGR_ID, sizeof(CAMSADTITM->ACTION_MGR_ID));
    MEMCPY_DN(CAMSADTITM->ACTION_LIMIT_DATE, CAMSADTITM_N->ACTION_LIMIT_DATE, sizeof(CAMSADTITM->ACTION_LIMIT_DATE));
    MEMCPY_DN(CAMSADTITM->ACTION_DATE, CAMSADTITM_N->ACTION_DATE, sizeof(CAMSADTITM->ACTION_DATE));
    MEMCPY_DN(CAMSADTITM->ACTION_USER_ID, CAMSADTITM_N->ACTION_USER_ID, sizeof(CAMSADTITM->ACTION_USER_ID));
    MEMCPY_DN(CAMSADTITM->ACTION_FILE_NAME, CAMSADTITM_N->ACTION_FILE_NAME, sizeof(CAMSADTITM->ACTION_FILE_NAME));
    MEMCPY_DN(CAMSADTITM->ACTION_FILE_PATH, CAMSADTITM_N->ACTION_FILE_PATH, sizeof(CAMSADTITM->ACTION_FILE_PATH));
    CAMSADTITM->ACTION_RESULT = CAMSADTITM_N->ACTION_RESULT[0];
    MEMCPY_DN(CAMSADTITM->REMARKS, CAMSADTITM_N->REMARKS, sizeof(CAMSADTITM->REMARKS));
    CAMSADTITM->STATUS = CAMSADTITM_N->STATUS[0];
    MEMCPY_DN(CAMSADTITM->CMF_1, CAMSADTITM_N->CMF_1, sizeof(CAMSADTITM->CMF_1));
    MEMCPY_DN(CAMSADTITM->CMF_2, CAMSADTITM_N->CMF_2, sizeof(CAMSADTITM->CMF_2));
    MEMCPY_DN(CAMSADTITM->CMF_3, CAMSADTITM_N->CMF_3, sizeof(CAMSADTITM->CMF_3));
    MEMCPY_DN(CAMSADTITM->CMF_4, CAMSADTITM_N->CMF_4, sizeof(CAMSADTITM->CMF_4));
    MEMCPY_DN(CAMSADTITM->CMF_5, CAMSADTITM_N->CMF_5, sizeof(CAMSADTITM->CMF_5));
    MEMCPY_DN(CAMSADTITM->CMF_6, CAMSADTITM_N->CMF_6, sizeof(CAMSADTITM->CMF_6));
    MEMCPY_DN(CAMSADTITM->CMF_7, CAMSADTITM_N->CMF_7, sizeof(CAMSADTITM->CMF_7));
    MEMCPY_DN(CAMSADTITM->CMF_8, CAMSADTITM_N->CMF_8, sizeof(CAMSADTITM->CMF_8));
    MEMCPY_DN(CAMSADTITM->CMF_9, CAMSADTITM_N->CMF_9, sizeof(CAMSADTITM->CMF_9));
    MEMCPY_DN(CAMSADTITM->CMF_10, CAMSADTITM_N->CMF_10, sizeof(CAMSADTITM->CMF_10));
    MEMCPY_DN(CAMSADTITM->CREATE_USER_ID, CAMSADTITM_N->CREATE_USER_ID, sizeof(CAMSADTITM->CREATE_USER_ID));
    MEMCPY_DN(CAMSADTITM->CREATE_TIME, CAMSADTITM_N->CREATE_TIME, sizeof(CAMSADTITM->CREATE_TIME));
    MEMCPY_DN(CAMSADTITM->UPDATE_USER_ID, CAMSADTITM_N->UPDATE_USER_ID, sizeof(CAMSADTITM->UPDATE_USER_ID));
    MEMCPY_DN(CAMSADTITM->UPDATE_TIME, CAMSADTITM_N->UPDATE_TIME, sizeof(CAMSADTITM->UPDATE_TIME));
}


