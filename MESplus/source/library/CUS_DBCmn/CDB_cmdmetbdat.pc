    MEMCPY_AN(CMDMETBDAT_N->REPEAT_MEASURE_NO, CMDMETBDAT->REPEAT_MEASURE_NO, sizeof(CMDMETBDAT->REPEAT_MEASURE_NO));
    CMDMETBDAT_N->POS_A = CMDMETBDAT->POS_A;
