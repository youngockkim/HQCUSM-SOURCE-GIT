                :CMDMETBDAT_N.GRN_NR_EVA_BACK,
                :CMDMETBDAT_N.BACKSHEET_TYPE,
                :CMDMETBDAT_N.GRN_NR_BACKSHEET,
                :CMDMETBDAT_N.REPEAT_MEASURE_NO,
                :CMDMETBDAT_N.POS_A,
                :CMDMETBDAT_N.POS_B,
                :CMDMETBDAT_N.POS_C,
                :CMDMETBDAT_N.POS_D,
                :CMDMETBDAT_N.POS_E,
                :CMDMETBDAT_N.POS_F,
                :CMDMETBDAT_N.POS_G,
                :CMDMETBDAT_N.POS_H,
                :CMDMETBDAT_N.QTY_1,
                :CMDMETBDAT_N.QTY_2,
                :CMDMETBDAT_N.QTY_3,
                :CMDMETBDAT_N.DATA_COMMENT,
                :CMDMETBDAT_N.CMF_1,
                :CMDMETBDAT_N.CMF_2,
                :CMDMETBDAT_N.CMF_3,
                :CMDMETBDAT_N.CMF_4,
                :CMDMETBDAT_N.CMF_5,
                :CMDMETBDAT_N.CMF_6,
                :CMDMETBDAT_N.CMF_7,
                :CMDMETBDAT_N.CMF_8,
                :CMDMETBDAT_N.CMF_9,
                :CMDMETBDAT_N.CMF_10,
                :CMDMETBDAT_N.CREATE_USER_ID,
                :CMDMETBDAT_N.CREATE_TIME,
                :CMDMETBDAT_N.UPDATE_USER_ID,
                :CMDMETBDAT_N.UPDATE_TIME;
            break;

        case 2:
            EXEC SQL FETCH CDB_CMDMETBDAT_CUR_2 INTO
                :CMDMETBDAT_N.FACTORY,
                :CMDMETBDAT_N.CW,
                :CMDMETBDAT_N.SAMPLING_DATE,
                :CMDMETBDAT_N.TEST_DATE,
                :CMDMETBDAT_N.LINE_ID,
                :CMDMETBDAT_N.MACHINE_NO,
                :CMDMETBDAT_N.POSITION,
                :CMDMETBDAT_N.MEASURE_TYPE,
                :CMDMETBDAT_N.TYPE_EVA_BACK,
                :CMDMETBDAT_N.GRN_NR_EVA_BACK,
                :CMDMETBDAT_N.BACKSHEET_TYPE,
                :CMDMETBDAT_N.GRN_NR_BACKSHEET,
                :CMDMETBDAT_N.REPEAT_MEASURE_NO,
                :CMDMETBDAT_N.POS_A,
                :CMDMETBDAT_N.POS_B,
                :CMDMETBDAT_N.POS_C,
                :CMDMETBDAT_N.POS_D,
                :CMDMETBDAT_N.POS_E,
                :CMDMETBDAT_N.POS_F,
                :CMDMETBDAT_N.POS_G,
                :CMDMETBDAT_N.POS_H,
                :CMDMETBDAT_N.QTY_1,
                :CMDMETBDAT_N.QTY_2,
                :CMDMETBDAT_N.QTY_3,
                :CMDMETBDAT_N.DATA_COMMENT,
                :CMDMETBDAT_N.CMF_1,
                :CMDMETBDAT_N.CMF_2,
                :CMDMETBDAT_N.CMF_3,
                :CMDMETBDAT_N.CMF_4,
                :CMDMETBDAT_N.CMF_5,
                :CMDMETBDAT_N.CMF_6,
                :CMDMETBDAT_N.CMF_7,
                :CMDMETBDAT_N.CMF_8,
                :CMDMETBDAT_N.CMF_9,
                :CMDMETBDAT_N.CMF_10,
                :CMDMETBDAT_N.CREATE_USER_ID,
                :CMDMETBDAT_N.CREATE_TIME,
                :CMDMETBDAT_N.UPDATE_USER_ID,
                :CMDMETBDAT_N.UPDATE_TIME;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cmdmetbdat(&CMDMETBDAT_N, CMDMETBDAT);
    }

    DB_stop_query_timer("CDB_fetch_cmdmetbdat", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cmdmetbdat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CMDMETBDAT_CUR_1;
            break;

        case 2:
            EXEC SQL CLOSE CDB_CMDMETBDAT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cmdmetbdat", sel_type);
}


/* Initialize Function */
void CDB_init_cmdmetbdat(struct CMDMETBDAT_TAG *CMDMETBDAT)
{
    /* memset by Space */
    memset(CMDMETBDAT, ' ', sizeof(struct CMDMETBDAT_TAG));
    
    CMDMETBDAT->POS_A = 0;
    CMDMETBDAT->POS_B = 0;
    CMDMETBDAT->POS_C = 0;
    CMDMETBDAT->POS_D = 0;
    CMDMETBDAT->POS_E = 0;
    CMDMETBDAT->POS_F = 0;
    CMDMETBDAT->POS_G = 0;
    CMDMETBDAT->POS_H = 0;
    CMDMETBDAT->QTY_1 = 0;
    CMDMETBDAT->QTY_2 = 0;
    CMDMETBDAT->QTY_3 = 0;
}


/* Add Null Function */
void CDB_add_null_cmdmetbdat(struct CMDMETBDAT_N_TAG *CMDMETBDAT_N, struct CMDMETBDAT_TAG *CMDMETBDAT)
{
    /* memset by NULL */
    memset(CMDMETBDAT_N, '\0', sizeof(struct CMDMETBDAT_N_TAG));
    
    MEMCPY_AN(CMDMETBDAT_N->FACTORY, CMDMETBDAT->FACTORY, sizeof(CMDMETBDAT->FACTORY));
    MEMCPY_AN(CMDMETBDAT_N->CW, CMDMETBDAT->CW, sizeof(CMDMETBDAT->CW));
