    MEMCPY_AN(IBAKFCLMOV_N->CMF_1, IBAKFCLMOV->CMF_1, sizeof(IBAKFCLMOV->CMF_1));
    MEMCPY_AN(IBAKFCLMOV_N->CMF_2, IBAKFCLMOV->CMF_2, sizeof(IBAKFCLMOV->CMF_2));
