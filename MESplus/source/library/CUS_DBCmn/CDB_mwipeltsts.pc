		case 3:
            EXEC SQL UPDATE MWIPELTSTS SET
                    PALLET_ID = :MWIPELTSTS_N.PALLET_ID,
                    PAK_MOD_TYPE = :MWIPELTSTS_N.PAK_MOD_TYPE
                WHERE LOT_ID = :MWIPELTSTS_N.LOT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_mwipeltsts", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_mwipeltsts(int sel_type, struct MWIPELTSTS_TAG *MWIPELTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPELTSTS_N_TAG MWIPELTSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_mwipeltsts(&MWIPELTSTS_N, MWIPELTSTS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_MWIPELTSTS_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    NVL(HIST_SEQ, '0'),
                    NVL(FQC_TIME, ' '),
                    NVL(GRADE, ' '),
                    NVL(POWER, ' '),
                    NVL(LOC_ID, ' '),
                    NVL(LINE_ID, ' '),
                    NVL(EFF, ' '),
                    NVL(RSH, ' '),
                    NVL(RS, ' '),
                    NVL(FF, ' '),
                    NVL(ISC, ' '),
                    NVL(VOC, ' '),
                    NVL(IMPP, ' '),
                    NVL(VMPP, ' '),
                    NVL(PMPP, ' '),
                    NVL(TEMP, ' '),
                    NVL(TREF, ' '),
                    NVL(SURFTEMP, ' '),
                    NVL(SUN, ' '),
                    NVL(OSC, ' '),
                    NVL(ESC, ' '),
                    NVL(EL, ' '),
                    NVL(FLASHER_CODE, ' '),
                    NVL(CURING_TIME, ' '),
                    NVL(ARTICLE_NO, ' '),
                    NVL(ARTICLE_EXT_NO, ' '),
                    NVL(COLOR_CLASS, ' '),
                    NVL(PALLET_ID, ' '),
                    NVL(PAK_BAR_INFO, ' '),
                    NVL(PAK_GROUP, ' '),
                    NVL(PAK_MOD_TYPE, ' '),
                    NVL(EL_IMAGE_PATH, ' '),
                    EL_IMAGE_PATH2,
                    EL_IMAGE_PATH3
                FROM MWIPELTSTS
                ORDER BY LOT_ID ASC;
            EXEC SQL OPEN CDB_MWIPELTSTS_CUR_1;
            break;
		case 2:
            EXEC SQL DECLARE CDB_MWIPELTSTS_CUR_2 CURSOR FOR
                SELECT 
                    LOT_ID,
                    HIST_SEQ,
                    FQC_TIME,
                    GRADE,
                    POWER,
                    LOC_ID,
                    LINE_ID,
                    EFF,
                    RSH,
                    RS,
                    FF,
                    ISC,
                    VOC,
                    IMPP,
                    VMPP,
                    PMPP,
                    TEMP,
                    TREF,
                    SURFTEMP,
                    SUN,
                    OSC,
                    ESC,
                    EL,
                    FLASHER_CODE,
                    CURING_TIME,
                    ARTICLE_NO,
                    ARTICLE_EXT_NO,
                    COLOR_CLASS,
                    PALLET_ID,
                    PAK_BAR_INFO,
                    PAK_GROUP,
                    PAK_MOD_TYPE,
                    EL_IMAGE_PATH,
                    EL_IMAGE_PATH2,
                    EL_IMAGE_PATH3
                FROM MWIPELTSTS
				WHERE LOT_ID = :MWIPELTSTS_N.LOT_ID
                ORDER BY LOT_ID ASC;
            EXEC SQL OPEN CDB_MWIPELTSTS_CUR_2;
            break;

		case 101:
			EXEC SQL DECLARE CDB_MWIPELTSTS_CUR_101 CURSOR FOR
				SELECT
					B.DATA_5 AS LOT_ID,
					C.POWER,
					C.PMPP,
					C.ISC,
					C.VOC,
					C.IMPP,
					C.VMPP
				FROM MWIPLOTSTS A,
					 MGCMLAGDAT B,
					 MWIPELTSTS C
				WHERE A.FACTORY = 'USGAM1'
					AND A.MAT_ID = B.KEY_1
					AND A.LOT_ID = C.LOT_ID
					AND B.TABLE_NAME = '@ARTICLE'
					AND A.LOT_ID = TRIM(:MWIPELTSTS_N.LOT_ID);
			EXEC SQL OPEN CDB_MWIPELTSTS_CUR_101;
			break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_mwipeltsts", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_mwipeltsts(int sel_type, struct MWIPELTSTS_TAG *MWIPELTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPELTSTS_N_TAG MWIPELTSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_MWIPELTSTS_CUR_1 INTO
                :MWIPELTSTS_N.LOT_ID,
                :MWIPELTSTS_N.HIST_SEQ,
                :MWIPELTSTS_N.FQC_TIME,
                :MWIPELTSTS_N.GRADE,
                :MWIPELTSTS_N.POWER,
                :MWIPELTSTS_N.LOC_ID,
                :MWIPELTSTS_N.LINE_ID,
                :MWIPELTSTS_N.EFF,
                :MWIPELTSTS_N.RSH,
                :MWIPELTSTS_N.RS,
                :MWIPELTSTS_N.FF,
                :MWIPELTSTS_N.ISC,
                :MWIPELTSTS_N.VOC,
                :MWIPELTSTS_N.IMPP,
                :MWIPELTSTS_N.VMPP,
                :MWIPELTSTS_N.PMPP,
                :MWIPELTSTS_N.TEMP,
                :MWIPELTSTS_N.TREF,
                :MWIPELTSTS_N.SURFTEMP,
                :MWIPELTSTS_N.SUN,
                :MWIPELTSTS_N.OSC,
                :MWIPELTSTS_N.ESC,
                :MWIPELTSTS_N.EL,
                :MWIPELTSTS_N.FLASHER_CODE,
                :MWIPELTSTS_N.CURING_TIME,
                :MWIPELTSTS_N.ARTICLE_NO,
                :MWIPELTSTS_N.ARTICLE_EXT_NO,
                :MWIPELTSTS_N.COLOR_CLASS,
                :MWIPELTSTS_N.PALLET_ID,
                :MWIPELTSTS_N.PAK_BAR_INFO,
                :MWIPELTSTS_N.PAK_GROUP,
                :MWIPELTSTS_N.PAK_MOD_TYPE,
                :MWIPELTSTS_N.EL_IMAGE_PATH,
                :MWIPELTSTS_N.EL_IMAGE_PATH2,
                :MWIPELTSTS_N.EL_IMAGE_PATH3;
            break;
		case 2:
            EXEC SQL FETCH CDB_MWIPELTSTS_CUR_2 INTO
                :MWIPELTSTS_N.LOT_ID,
                :MWIPELTSTS_N.HIST_SEQ,
                :MWIPELTSTS_N.FQC_TIME,
                :MWIPELTSTS_N.GRADE,
                :MWIPELTSTS_N.POWER,
                :MWIPELTSTS_N.LOC_ID,
                :MWIPELTSTS_N.LINE_ID,
                :MWIPELTSTS_N.EFF,
                :MWIPELTSTS_N.RSH,
                :MWIPELTSTS_N.RS,
                :MWIPELTSTS_N.FF,
                :MWIPELTSTS_N.ISC,
                :MWIPELTSTS_N.VOC,
                :MWIPELTSTS_N.IMPP,
                :MWIPELTSTS_N.VMPP,
                :MWIPELTSTS_N.PMPP,
                :MWIPELTSTS_N.TEMP,
                :MWIPELTSTS_N.TREF,
                :MWIPELTSTS_N.SURFTEMP,
                :MWIPELTSTS_N.SUN,
                :MWIPELTSTS_N.OSC,
                :MWIPELTSTS_N.ESC,
                :MWIPELTSTS_N.EL,
                :MWIPELTSTS_N.FLASHER_CODE,
                :MWIPELTSTS_N.CURING_TIME,
                :MWIPELTSTS_N.ARTICLE_NO,
                :MWIPELTSTS_N.ARTICLE_EXT_NO,
                :MWIPELTSTS_N.COLOR_CLASS,
                :MWIPELTSTS_N.PALLET_ID,
                :MWIPELTSTS_N.PAK_BAR_INFO,
                :MWIPELTSTS_N.PAK_GROUP,
                :MWIPELTSTS_N.PAK_MOD_TYPE,
                :MWIPELTSTS_N.EL_IMAGE_PATH,
                :MWIPELTSTS_N.EL_IMAGE_PATH2,
                :MWIPELTSTS_N.EL_IMAGE_PATH3;
            break;
		
		case 101:
			EXEC SQL FETCH CDB_MWIPELTSTS_CUR_101 INTO
                :MWIPELTSTS_N.LOT_ID,
                :MWIPELTSTS_N.POWER,
                :MWIPELTSTS_N.PMPP,
                :MWIPELTSTS_N.ISC,
                :MWIPELTSTS_N.POWER,
                :MWIPELTSTS_N.VOC,
                :MWIPELTSTS_N.IMPP,
                :MWIPELTSTS_N.VMPP;
			break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_mwipeltsts(&MWIPELTSTS_N, MWIPELTSTS);
    }

    DB_stop_query_timer("CDB_fetch_mwipeltsts", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_mwipeltsts(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_MWIPELTSTS_CUR_1;
            break;
		case 2:
            EXEC SQL CLOSE CDB_MWIPELTSTS_CUR_2;
            break;

		case 101:
			EXEC SQL CLOSE CDB_MWIPELTSTS_CUR_101;
			break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_mwipeltsts", sel_type);
}


/* Initialize Function */
void CDB_init_mwipeltsts(struct MWIPELTSTS_TAG *MWIPELTSTS)
{
    /* memset by Space */
    memset(MWIPELTSTS, ' ', sizeof(struct MWIPELTSTS_TAG));
    
    MWIPELTSTS->HIST_SEQ = 0;
}


/* Add Null Function */
void CDB_add_null_mwipeltsts(struct MWIPELTSTS_N_TAG *MWIPELTSTS_N, struct MWIPELTSTS_TAG *MWIPELTSTS)
{
    /* memset by NULL */
    memset(MWIPELTSTS_N, '\0', sizeof(struct MWIPELTSTS_N_TAG));
    
    MEMCPY_AN(MWIPELTSTS_N->LOT_ID, MWIPELTSTS->LOT_ID, sizeof(MWIPELTSTS->LOT_ID));
    MWIPELTSTS_N->HIST_SEQ = MWIPELTSTS->HIST_SEQ;
    MEMCPY_AN(MWIPELTSTS_N->FQC_TIME, MWIPELTSTS->FQC_TIME, sizeof(MWIPELTSTS->FQC_TIME));
    MEMCPY_AN(MWIPELTSTS_N->GRADE, MWIPELTSTS->GRADE, sizeof(MWIPELTSTS->GRADE));
    MEMCPY_AN(MWIPELTSTS_N->POWER, MWIPELTSTS->POWER, sizeof(MWIPELTSTS->POWER));
    MEMCPY_AN(MWIPELTSTS_N->LOC_ID, MWIPELTSTS->LOC_ID, sizeof(MWIPELTSTS->LOC_ID));
    MEMCPY_AN(MWIPELTSTS_N->LINE_ID, MWIPELTSTS->LINE_ID, sizeof(MWIPELTSTS->LINE_ID));
    MEMCPY_AN(MWIPELTSTS_N->EFF, MWIPELTSTS->EFF, sizeof(MWIPELTSTS->EFF));
    MEMCPY_AN(MWIPELTSTS_N->RSH, MWIPELTSTS->RSH, sizeof(MWIPELTSTS->RSH));
    MEMCPY_AN(MWIPELTSTS_N->RS, MWIPELTSTS->RS, sizeof(MWIPELTSTS->RS));
    MEMCPY_AN(MWIPELTSTS_N->FF, MWIPELTSTS->FF, sizeof(MWIPELTSTS->FF));
    MEMCPY_AN(MWIPELTSTS_N->ISC, MWIPELTSTS->ISC, sizeof(MWIPELTSTS->ISC));
    MEMCPY_AN(MWIPELTSTS_N->VOC, MWIPELTSTS->VOC, sizeof(MWIPELTSTS->VOC));
    MEMCPY_AN(MWIPELTSTS_N->IMPP, MWIPELTSTS->IMPP, sizeof(MWIPELTSTS->IMPP));
    MEMCPY_AN(MWIPELTSTS_N->VMPP, MWIPELTSTS->VMPP, sizeof(MWIPELTSTS->VMPP));
    MEMCPY_AN(MWIPELTSTS_N->PMPP, MWIPELTSTS->PMPP, sizeof(MWIPELTSTS->PMPP));
    MEMCPY_AN(MWIPELTSTS_N->TEMP, MWIPELTSTS->TEMP, sizeof(MWIPELTSTS->TEMP));
    MEMCPY_AN(MWIPELTSTS_N->TREF, MWIPELTSTS->TREF, sizeof(MWIPELTSTS->TREF));
    MEMCPY_AN(MWIPELTSTS_N->SURFTEMP, MWIPELTSTS->SURFTEMP, sizeof(MWIPELTSTS->SURFTEMP));
    MEMCPY_AN(MWIPELTSTS_N->SUN, MWIPELTSTS->SUN, sizeof(MWIPELTSTS->SUN));
    MEMCPY_AN(MWIPELTSTS_N->OSC, MWIPELTSTS->OSC, sizeof(MWIPELTSTS->OSC));
    MEMCPY_AN(MWIPELTSTS_N->ESC, MWIPELTSTS->ESC, sizeof(MWIPELTSTS->ESC));
    MEMCPY_AN(MWIPELTSTS_N->EL, MWIPELTSTS->EL, sizeof(MWIPELTSTS->EL));
    MEMCPY_AN(MWIPELTSTS_N->FLASHER_CODE, MWIPELTSTS->FLASHER_CODE, sizeof(MWIPELTSTS->FLASHER_CODE));
    MEMCPY_AN(MWIPELTSTS_N->CURING_TIME, MWIPELTSTS->CURING_TIME, sizeof(MWIPELTSTS->CURING_TIME));
    MEMCPY_AN(MWIPELTSTS_N->ARTICLE_NO, MWIPELTSTS->ARTICLE_NO, sizeof(MWIPELTSTS->ARTICLE_NO));
    MEMCPY_AN(MWIPELTSTS_N->ARTICLE_EXT_NO, MWIPELTSTS->ARTICLE_EXT_NO, sizeof(MWIPELTSTS->ARTICLE_EXT_NO));
    MEMCPY_AN(MWIPELTSTS_N->COLOR_CLASS, MWIPELTSTS->COLOR_CLASS, sizeof(MWIPELTSTS->COLOR_CLASS));
    MEMCPY_AN(MWIPELTSTS_N->PALLET_ID, MWIPELTSTS->PALLET_ID, sizeof(MWIPELTSTS->PALLET_ID));
    MEMCPY_AN(MWIPELTSTS_N->PAK_BAR_INFO, MWIPELTSTS->PAK_BAR_INFO, sizeof(MWIPELTSTS->PAK_BAR_INFO));
    MEMCPY_AN(MWIPELTSTS_N->PAK_GROUP, MWIPELTSTS->PAK_GROUP, sizeof(MWIPELTSTS->PAK_GROUP));
    MEMCPY_AN(MWIPELTSTS_N->PAK_MOD_TYPE, MWIPELTSTS->PAK_MOD_TYPE, sizeof(MWIPELTSTS->PAK_MOD_TYPE));
    MEMCPY_AN(MWIPELTSTS_N->EL_IMAGE_PATH, MWIPELTSTS->EL_IMAGE_PATH, sizeof(MWIPELTSTS->EL_IMAGE_PATH));
    MEMCPY_AN(MWIPELTSTS_N->EL_IMAGE_PATH2, MWIPELTSTS->EL_IMAGE_PATH2, sizeof(MWIPELTSTS->EL_IMAGE_PATH2));
    MEMCPY_AN(MWIPELTSTS_N->EL_IMAGE_PATH3, MWIPELTSTS->EL_IMAGE_PATH3, sizeof(MWIPELTSTS->EL_IMAGE_PATH3));
}


/* Del Null Function */
void CDB_del_null_mwipeltsts(struct MWIPELTSTS_N_TAG *MWIPELTSTS_N, struct MWIPELTSTS_TAG *MWIPELTSTS)
{
    MEMCPY_DN(MWIPELTSTS->LOT_ID, MWIPELTSTS_N->LOT_ID, sizeof(MWIPELTSTS->LOT_ID));
    MWIPELTSTS->HIST_SEQ = MWIPELTSTS_N->HIST_SEQ;
    MEMCPY_DN(MWIPELTSTS->FQC_TIME, MWIPELTSTS_N->FQC_TIME, sizeof(MWIPELTSTS->FQC_TIME));
    MEMCPY_DN(MWIPELTSTS->GRADE, MWIPELTSTS_N->GRADE, sizeof(MWIPELTSTS->GRADE));
    MEMCPY_DN(MWIPELTSTS->POWER, MWIPELTSTS_N->POWER, sizeof(MWIPELTSTS->POWER));
    MEMCPY_DN(MWIPELTSTS->LOC_ID, MWIPELTSTS_N->LOC_ID, sizeof(MWIPELTSTS->LOC_ID));
    MEMCPY_DN(MWIPELTSTS->LINE_ID, MWIPELTSTS_N->LINE_ID, sizeof(MWIPELTSTS->LINE_ID));
    MEMCPY_DN(MWIPELTSTS->EFF, MWIPELTSTS_N->EFF, sizeof(MWIPELTSTS->EFF));
    MEMCPY_DN(MWIPELTSTS->RSH, MWIPELTSTS_N->RSH, sizeof(MWIPELTSTS->RSH));
    MEMCPY_DN(MWIPELTSTS->RS, MWIPELTSTS_N->RS, sizeof(MWIPELTSTS->RS));
    MEMCPY_DN(MWIPELTSTS->FF, MWIPELTSTS_N->FF, sizeof(MWIPELTSTS->FF));
    MEMCPY_DN(MWIPELTSTS->ISC, MWIPELTSTS_N->ISC, sizeof(MWIPELTSTS->ISC));
    MEMCPY_DN(MWIPELTSTS->VOC, MWIPELTSTS_N->VOC, sizeof(MWIPELTSTS->VOC));
    MEMCPY_DN(MWIPELTSTS->IMPP, MWIPELTSTS_N->IMPP, sizeof(MWIPELTSTS->IMPP));
    MEMCPY_DN(MWIPELTSTS->VMPP, MWIPELTSTS_N->VMPP, sizeof(MWIPELTSTS->VMPP));
    MEMCPY_DN(MWIPELTSTS->PMPP, MWIPELTSTS_N->PMPP, sizeof(MWIPELTSTS->PMPP));
    MEMCPY_DN(MWIPELTSTS->TEMP, MWIPELTSTS_N->TEMP, sizeof(MWIPELTSTS->TEMP));
    MEMCPY_DN(MWIPELTSTS->TREF, MWIPELTSTS_N->TREF, sizeof(MWIPELTSTS->TREF));
    MEMCPY_DN(MWIPELTSTS->SURFTEMP, MWIPELTSTS_N->SURFTEMP, sizeof(MWIPELTSTS->SURFTEMP));
    MEMCPY_DN(MWIPELTSTS->SUN, MWIPELTSTS_N->SUN, sizeof(MWIPELTSTS->SUN));
    MEMCPY_DN(MWIPELTSTS->OSC, MWIPELTSTS_N->OSC, sizeof(MWIPELTSTS->OSC));
    MEMCPY_DN(MWIPELTSTS->ESC, MWIPELTSTS_N->ESC, sizeof(MWIPELTSTS->ESC));
    MEMCPY_DN(MWIPELTSTS->EL, MWIPELTSTS_N->EL, sizeof(MWIPELTSTS->EL));
    MEMCPY_DN(MWIPELTSTS->FLASHER_CODE, MWIPELTSTS_N->FLASHER_CODE, sizeof(MWIPELTSTS->FLASHER_CODE));
    MEMCPY_DN(MWIPELTSTS->CURING_TIME, MWIPELTSTS_N->CURING_TIME, sizeof(MWIPELTSTS->CURING_TIME));
    MEMCPY_DN(MWIPELTSTS->ARTICLE_NO, MWIPELTSTS_N->ARTICLE_NO, sizeof(MWIPELTSTS->ARTICLE_NO));
    MEMCPY_DN(MWIPELTSTS->ARTICLE_EXT_NO, MWIPELTSTS_N->ARTICLE_EXT_NO, sizeof(MWIPELTSTS->ARTICLE_EXT_NO));
    MEMCPY_DN(MWIPELTSTS->COLOR_CLASS, MWIPELTSTS_N->COLOR_CLASS, sizeof(MWIPELTSTS->COLOR_CLASS));
    MEMCPY_DN(MWIPELTSTS->PALLET_ID, MWIPELTSTS_N->PALLET_ID, sizeof(MWIPELTSTS->PALLET_ID));
    MEMCPY_DN(MWIPELTSTS->PAK_BAR_INFO, MWIPELTSTS_N->PAK_BAR_INFO, sizeof(MWIPELTSTS->PAK_BAR_INFO));
    MEMCPY_DN(MWIPELTSTS->PAK_GROUP, MWIPELTSTS_N->PAK_GROUP, sizeof(MWIPELTSTS->PAK_GROUP));
    MEMCPY_DN(MWIPELTSTS->PAK_MOD_TYPE, MWIPELTSTS_N->PAK_MOD_TYPE, sizeof(MWIPELTSTS->PAK_MOD_TYPE));
    MEMCPY_DN(MWIPELTSTS->EL_IMAGE_PATH, MWIPELTSTS_N->EL_IMAGE_PATH, sizeof(MWIPELTSTS->EL_IMAGE_PATH));
    MEMCPY_DN(MWIPELTSTS->EL_IMAGE_PATH2, MWIPELTSTS_N->EL_IMAGE_PATH2, sizeof(MWIPELTSTS->EL_IMAGE_PATH2));
    MEMCPY_DN(MWIPELTSTS->EL_IMAGE_PATH3, MWIPELTSTS_N->EL_IMAGE_PATH3, sizeof(MWIPELTSTS->EL_IMAGE_PATH3));
}


