                :IBAKMATDEF_N.DATA_FLAG,
                :IBAKMATDEF_N.UPDATE_COUNT,
                :IBAKMATDEF_N.INSERT_COUNT,
                :IBAKMATDEF_N.DELETE_COUNT,
                :IBAKMATDEF_N.SQL_DML_COUNT,
                :IBAKMATDEF_N.ZPICODE,
                :IBAKMATDEF_N.ZPIMSGID,
                :IBAKMATDEF_N.RETURN_TYPE,
                :IBAKMATDEF_N.RETURN_MSG,
                :IBAKMATDEF_N.ZIFERNAM,
                :IBAKMATDEF_N.ZIFDATE,
                :IBAKMATDEF_N.ZIFTIME,
                :IBAKMATDEF_N.ZPISTAT,
                :IBAKMATDEF_N.ZPIMSG;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_ibakmatdef(&IBAKMATDEF_N, IBAKMATDEF);
    }

    DB_stop_query_timer("CDB_fetch_ibakmatdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_ibakmatdef(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IBAKMATDEF_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ibakmatdef", sel_type);
}


/* Initialize Function */
void CDB_init_ibakmatdef(struct IBAKMATDEF_TAG *IBAKMATDEF)
{
    /* memset by Space */
    memset(IBAKMATDEF, ' ', sizeof(struct IBAKMATDEF_TAG));
    
}


