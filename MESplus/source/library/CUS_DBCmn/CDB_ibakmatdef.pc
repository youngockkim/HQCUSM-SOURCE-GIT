/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_ibakmatdef(int sel_type, struct IBAKMATDEF_TAG *IBAKMATDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IBAKMATDEF_N_TAG IBAKMATDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ibakmatdef(&IBAKMATDEF_N, IBAKMATDEF);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IBAKMATDEF_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    MATE_NO,
                    MATE_NM,
                    UNIT_ID,
                    SAP_MATE_TYPE,
                    MATE_CLASS,
                    MATE_TYPE,
                    MATE_TYPE_DESC,
                    MATE_SUBTYPE,
                    MATE_SUBTYPE_DESC,
                    PROD_TYPE,
                    PROD_TYPE_DESC,
                    PROD_SUBTYPE,
                    PROD_SUBTYPE_DESC,
                    PROD_DETAILTYPE,
                    PROD_DETAILTYPE_DESC,
                    PROD_CERT,
                    PROD_CERT_DESC,
                    BACKFLUSH_YN,
                    INSPECT_YN,
                    DEL_YN,
                    ITEM_CAT_GRP,
                    CELL_QTY,
                    MONO_POLY,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IBAKMATDEF
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    MATE_NO ASC;
            EXEC SQL OPEN CDB_IBAKMATDEF_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_ibakmatdef", sel_type);
}


