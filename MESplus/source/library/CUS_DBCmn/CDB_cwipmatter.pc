/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwipmatter(int sel_type, struct CWIPMATTER_TAG *CWIPMATTER)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPMATTER_N_TAG CWIPMATTER_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwipmatter(&CWIPMATTER_N, CWIPMATTER);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPMATTER_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    ORDER_ID,
                    LINE_ID,
                    WORK_SHIFT,
                    MAT_ID,
                    HIST_SEQ,
                    SEQ,
                    TERMINATION_DT,
                    MATE_NO_DESC,
                    MATE_TYPE,
                    QTY,
                    UNIT_ID,
                    REASON_CODE,
                    TER_COMMENT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CWIPMATTER
                ORDER BY ORDER_ID ASC,
                    LINE_ID ASC,
                    WORK_SHIFT ASC,
                    MAT_ID ASC,
                    HIST_SEQ ASC,
                    SEQ ASC;
            EXEC SQL OPEN CDB_CWIPMATTER_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CWIPMATTER_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    ORDER_ID,
                    LINE_ID,
                    WORK_SHIFT,
                    MAT_ID,
                    HIST_SEQ,
                    SEQ,
                    TERMINATION_DT,
                    MATE_NO_DESC,
                    MATE_TYPE,
                    QTY,
                    UNIT_ID,
                    REASON_CODE,
                    TER_COMMENT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CWIPMATTER
				WHERE TERMINATION_DT >= :DBC_Q_COND_N.FROM_DATE 
	                AND TERMINATION_DT <= :DBC_Q_COND_N.TO_DATE
					AND ORDER_ID like :CWIPMATTER_N.ORDER_ID
                    AND MAT_ID like :CWIPMATTER_N.MAT_ID
					AND LINE_ID like :CWIPMATTER_N.LINE_ID
                    AND WORK_SHIFT like :CWIPMATTER_N.WORK_SHIFT
					AND CMF_1 <> 'CANCEL'
                ORDER BY TERMINATION_DT ASC,
					LINE_ID ASC,
                    WORK_SHIFT ASC,
					SEQ ASC,
					HIST_SEQ ASC;
            EXEC SQL OPEN CDB_CWIPMATTER_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwipmatter", sel_type);
}


