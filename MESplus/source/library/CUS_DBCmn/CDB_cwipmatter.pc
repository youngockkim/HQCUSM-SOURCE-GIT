/* Initialize Function */
void CDB_init_cwipmatter(struct CWIPMATTER_TAG *CWIPMATTER)
{
    /* memset by Space */
    memset(CWIPMATTER, ' ', sizeof(struct CWIPMATTER_TAG));
    
    CWIPMATTER->HIST_SEQ = 0;
    CWIPMATTER->SEQ = 0;
    CWIPMATTER->QTY = 0;
}


/* Add Null Function */
void CDB_add_null_cwipmatter(struct CWIPMATTER_N_TAG *CWIPMATTER_N, struct CWIPMATTER_TAG *CWIPMATTER)
{
    /* memset by NULL */
    memset(CWIPMATTER_N, '\0', sizeof(struct CWIPMATTER_N_TAG));
    
    MEMCPY_AN(CWIPMATTER_N->FACTORY, CWIPMATTER->FACTORY, sizeof(CWIPMATTER->FACTORY));
    MEMCPY_AN(CWIPMATTER_N->ORDER_ID, CWIPMATTER->ORDER_ID, sizeof(CWIPMATTER->ORDER_ID));
    MEMCPY_AN(CWIPMATTER_N->LINE_ID, CWIPMATTER->LINE_ID, sizeof(CWIPMATTER->LINE_ID));
    MEMCPY_AN(CWIPMATTER_N->WORK_SHIFT, CWIPMATTER->WORK_SHIFT, sizeof(CWIPMATTER->WORK_SHIFT));
    MEMCPY_AN(CWIPMATTER_N->MAT_ID, CWIPMATTER->MAT_ID, sizeof(CWIPMATTER->MAT_ID));
    CWIPMATTER_N->HIST_SEQ = CWIPMATTER->HIST_SEQ;
    CWIPMATTER_N->SEQ = CWIPMATTER->SEQ;
    MEMCPY_AN(CWIPMATTER_N->TERMINATION_DT, CWIPMATTER->TERMINATION_DT, sizeof(CWIPMATTER->TERMINATION_DT));
    MEMCPY_AN(CWIPMATTER_N->MATE_NO_DESC, CWIPMATTER->MATE_NO_DESC, sizeof(CWIPMATTER->MATE_NO_DESC));
    MEMCPY_AN(CWIPMATTER_N->MATE_TYPE, CWIPMATTER->MATE_TYPE, sizeof(CWIPMATTER->MATE_TYPE));
    CWIPMATTER_N->QTY = CWIPMATTER->QTY;
    MEMCPY_AN(CWIPMATTER_N->UNIT_ID, CWIPMATTER->UNIT_ID, sizeof(CWIPMATTER->UNIT_ID));
    MEMCPY_AN(CWIPMATTER_N->REASON_CODE, CWIPMATTER->REASON_CODE, sizeof(CWIPMATTER->REASON_CODE));
    MEMCPY_AN(CWIPMATTER_N->TER_COMMENT, CWIPMATTER->TER_COMMENT, sizeof(CWIPMATTER->TER_COMMENT));
    MEMCPY_AN(CWIPMATTER_N->CMF_1, CWIPMATTER->CMF_1, sizeof(CWIPMATTER->CMF_1));
    MEMCPY_AN(CWIPMATTER_N->CMF_2, CWIPMATTER->CMF_2, sizeof(CWIPMATTER->CMF_2));
    MEMCPY_AN(CWIPMATTER_N->CMF_3, CWIPMATTER->CMF_3, sizeof(CWIPMATTER->CMF_3));
    MEMCPY_AN(CWIPMATTER_N->CMF_4, CWIPMATTER->CMF_4, sizeof(CWIPMATTER->CMF_4));
    MEMCPY_AN(CWIPMATTER_N->CMF_5, CWIPMATTER->CMF_5, sizeof(CWIPMATTER->CMF_5));
    MEMCPY_AN(CWIPMATTER_N->CREATE_USER_ID, CWIPMATTER->CREATE_USER_ID, sizeof(CWIPMATTER->CREATE_USER_ID));
    MEMCPY_AN(CWIPMATTER_N->CREATE_TIME, CWIPMATTER->CREATE_TIME, sizeof(CWIPMATTER->CREATE_TIME));
    MEMCPY_AN(CWIPMATTER_N->UPDATE_USER_ID, CWIPMATTER->UPDATE_USER_ID, sizeof(CWIPMATTER->UPDATE_USER_ID));
    MEMCPY_AN(CWIPMATTER_N->UPDATE_TIME, CWIPMATTER->UPDATE_TIME, sizeof(CWIPMATTER->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_cwipmatter(struct CWIPMATTER_N_TAG *CWIPMATTER_N, struct CWIPMATTER_TAG *CWIPMATTER)
{
