                    DOC_ID,
                    SITE_ID,
                    PROD_ORDER_NO,
                    OPER_NO,
                    WORK_CENTER,
                    ACTION_TYPE,
                    MATE_NO,
                    PROD_QTY,
                    SCRAP_QTY,
                    UNIT_ID,
                    FQC_DATE,
                    SHIFT,
                    INF_USER_ID,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPICODE,
                    ZPIMSGID,
                    ZPISTAT,
                    ZPIMSG,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ERP_DATE,
                    ERP_TIME,
                    ERP_FLAG,
                    ERP_MSG,
                    IF_FLAG
                FROM IERPCLVCFM
				WHERE RETURN_TYPE <> 'E'
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_ORDER_NO ASC,
                    OPER_NO ASC,
                    WORK_CENTER ASC,
                    ACTION_TYPE ASC;
            EXEC SQL OPEN CDB_IERPCLVCFM_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_ierpclvcfm", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_ierpclvcfm(int sel_type, struct IERPCLVCFM_TAG *IERPCLVCFM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IERPCLVCFM_N_TAG IERPCLVCFM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_IERPCLVCFM_CUR_1 INTO
                :IERPCLVCFM_N.DOC_ID,
                :IERPCLVCFM_N.SITE_ID,
                :IERPCLVCFM_N.PROD_ORDER_NO,
                :IERPCLVCFM_N.OPER_NO,
