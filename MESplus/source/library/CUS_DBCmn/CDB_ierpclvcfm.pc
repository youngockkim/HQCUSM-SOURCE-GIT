                :IERPCLVCFM_N.FQC_DATE,
                :IERPCLVCFM_N.SHIFT,
                :IERPCLVCFM_N.INF_USER_ID,
                :IERPCLVCFM_N.INF_TIME,
                :IERPCLVCFM_N.INF_PROC_TIME,
                :IERPCLVCFM_N.CMF_1,
                :IERPCLVCFM_N.CMF_2,
                :IERPCLVCFM_N.CMF_3,
                :IERPCLVCFM_N.CMF_4,
                :IERPCLVCFM_N.CMF_5,
                :IERPCLVCFM_N.DATA_FLAG,
                :IERPCLVCFM_N.ZIFERNAM,
                :IERPCLVCFM_N.ZIFDATE,
                :IERPCLVCFM_N.ZIFTIME,
                :IERPCLVCFM_N.ZPICODE,
                :IERPCLVCFM_N.ZPIMSGID,
                :IERPCLVCFM_N.ZPISTAT,
                :IERPCLVCFM_N.ZPIMSG,
                :IERPCLVCFM_N.RETURN_TYPE,
                :IERPCLVCFM_N.RETURN_MSG,
                :IERPCLVCFM_N.ERP_DATE,
                :IERPCLVCFM_N.ERP_TIME,
                :IERPCLVCFM_N.ERP_FLAG,
                :IERPCLVCFM_N.ERP_MSG,
                :IERPCLVCFM_N.IF_FLAG;
            break;

		case 2:
            EXEC SQL FETCH CDB_IERPCLVCFM_CUR_2 INTO
                :IERPCLVCFM_N.DOC_ID,
                :IERPCLVCFM_N.SITE_ID,
                :IERPCLVCFM_N.PROD_ORDER_NO,
                :IERPCLVCFM_N.OPER_NO,
                :IERPCLVCFM_N.WORK_CENTER,
                :IERPCLVCFM_N.ACTION_TYPE,
                :IERPCLVCFM_N.MATE_NO,
                :IERPCLVCFM_N.PROD_QTY,
                :IERPCLVCFM_N.SCRAP_QTY,
                :IERPCLVCFM_N.UNIT_ID,
                :IERPCLVCFM_N.FQC_DATE,
                :IERPCLVCFM_N.SHIFT,
                :IERPCLVCFM_N.INF_USER_ID,
                :IERPCLVCFM_N.INF_TIME,
                :IERPCLVCFM_N.INF_PROC_TIME,
                :IERPCLVCFM_N.CMF_1,
                :IERPCLVCFM_N.CMF_2,
                :IERPCLVCFM_N.CMF_3,
                :IERPCLVCFM_N.CMF_4,
                :IERPCLVCFM_N.CMF_5,
                :IERPCLVCFM_N.DATA_FLAG,
                :IERPCLVCFM_N.ZIFERNAM,
                :IERPCLVCFM_N.ZIFDATE,
                :IERPCLVCFM_N.ZIFTIME,
                :IERPCLVCFM_N.ZPICODE,
                :IERPCLVCFM_N.ZPIMSGID,
                :IERPCLVCFM_N.ZPISTAT,
                :IERPCLVCFM_N.ZPIMSG,
                :IERPCLVCFM_N.RETURN_TYPE,
                :IERPCLVCFM_N.RETURN_MSG,
                :IERPCLVCFM_N.ERP_DATE,
                :IERPCLVCFM_N.ERP_TIME,
                :IERPCLVCFM_N.ERP_FLAG,
                :IERPCLVCFM_N.ERP_MSG,
                :IERPCLVCFM_N.IF_FLAG;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_ierpclvcfm(&IERPCLVCFM_N, IERPCLVCFM);
    }

    DB_stop_query_timer("CDB_fetch_ierpclvcfm", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_ierpclvcfm(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IERPCLVCFM_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IERPCLVCFM_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ierpclvcfm", sel_type);
}


/* Initialize Function */
void CDB_init_ierpclvcfm(struct IERPCLVCFM_TAG *IERPCLVCFM)
{
    /* memset by Space */
    memset(IERPCLVCFM, ' ', sizeof(struct IERPCLVCFM_TAG));
    
    IERPCLVCFM->PROD_QTY = 0;
    IERPCLVCFM->SCRAP_QTY = 0;
}


/* Add Null Function */
void CDB_add_null_ierpclvcfm(struct IERPCLVCFM_N_TAG *IERPCLVCFM_N, struct IERPCLVCFM_TAG *IERPCLVCFM)
{
    /* memset by NULL */
