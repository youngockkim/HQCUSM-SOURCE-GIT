                    :MGCMTBLDAT_N.KEY_9,
                    :MGCMTBLDAT_N.KEY_10,
                    :MGCMTBLDAT_N.DATA_1,
                    :MGCMTBLDAT_N.DATA_2,
                    :MGCMTBLDAT_N.DATA_3,
                    :MGCMTBLDAT_N.DATA_4,
                    :MGCMTBLDAT_N.DATA_5,
                    :MGCMTBLDAT_N.DATA_6,
                    :MGCMTBLDAT_N.DATA_7,
                    :MGCMTBLDAT_N.DATA_8,
                    :MGCMTBLDAT_N.DATA_9,
                    :MGCMTBLDAT_N.DATA_10,
                    :MGCMTBLDAT_N.CREATE_USER_ID,
                    :MGCMTBLDAT_N.CREATE_TIME,
                    :MGCMTBLDAT_N.UPDATE_USER_ID,
                    :MGCMTBLDAT_N.UPDATE_TIME
         );

    DB_stop_query_timer("CDB_insert_mgcmtbldat", 0);
}


/* SQL UPDATE Function */
void CDB_update_mgcmtbldat(int sel_type, struct MGCMTBLDAT_TAG *MGCMTBLDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MGCMTBLDAT_N_TAG MGCMTBLDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_mgcmtbldat(&MGCMTBLDAT_N, MGCMTBLDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MGCMTBLDAT SET
                    DATA_1 = :MGCMTBLDAT_N.DATA_1,
                    DATA_2 = :MGCMTBLDAT_N.DATA_2,
                    DATA_3 = :MGCMTBLDAT_N.DATA_3,
                    DATA_4 = :MGCMTBLDAT_N.DATA_4,
                    DATA_5 = :MGCMTBLDAT_N.DATA_5,
                    DATA_6 = :MGCMTBLDAT_N.DATA_6,
                    DATA_7 = :MGCMTBLDAT_N.DATA_7,
                    DATA_8 = :MGCMTBLDAT_N.DATA_8,
                    DATA_9 = :MGCMTBLDAT_N.DATA_9,
                    DATA_10 = :MGCMTBLDAT_N.DATA_10,
                    CREATE_USER_ID = :MGCMTBLDAT_N.CREATE_USER_ID,
                    CREATE_TIME = :MGCMTBLDAT_N.CREATE_TIME,
                    UPDATE_USER_ID = :MGCMTBLDAT_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MGCMTBLDAT_N.UPDATE_TIME
                WHERE FACTORY = :MGCMTBLDAT_N.FACTORY
                    AND TABLE_NAME = :MGCMTBLDAT_N.TABLE_NAME
                    AND KEY_1 = :MGCMTBLDAT_N.KEY_1
                    AND KEY_2 = :MGCMTBLDAT_N.KEY_2
                    AND KEY_3 = :MGCMTBLDAT_N.KEY_3
                    AND KEY_4 = :MGCMTBLDAT_N.KEY_4
                    AND KEY_5 = :MGCMTBLDAT_N.KEY_5
                    AND KEY_6 = :MGCMTBLDAT_N.KEY_6
                    AND KEY_7 = :MGCMTBLDAT_N.KEY_7
                    AND KEY_8 = :MGCMTBLDAT_N.KEY_8
                    AND KEY_9 = :MGCMTBLDAT_N.KEY_9
                    AND KEY_10 = :MGCMTBLDAT_N.KEY_10;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_mgcmtbldat", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_mgcmtbldat(int sel_type, struct MGCMTBLDAT_TAG *MGCMTBLDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MGCMTBLDAT_N_TAG MGCMTBLDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_mgcmtbldat(&MGCMTBLDAT_N, MGCMTBLDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_MGCMTBLDAT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    TABLE_NAME,
                    KEY_1,
                    KEY_2,
                    KEY_3,
                    KEY_4,
                    KEY_5,
                    KEY_6,
                    KEY_7,
                    KEY_8,
                    KEY_9,
                    KEY_10,
                    DATA_1,
                    DATA_2,
                    DATA_3,
                    DATA_4,
                    DATA_5,
                    DATA_6,
                    DATA_7,
                    DATA_8,
                    DATA_9,
                    DATA_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MGCMTBLDAT
                ORDER BY FACTORY ASC,
                    TABLE_NAME ASC,
                    KEY_1 ASC,
                    KEY_2 ASC,
                    KEY_3 ASC,
                    KEY_4 ASC,
                    KEY_5 ASC,
                    KEY_6 ASC,
                    KEY_7 ASC,
                    KEY_8 ASC,
                    KEY_9 ASC,
                    KEY_10 ASC;
            EXEC SQL OPEN CDB_MGCMTBLDAT_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_MGCMTBLDAT_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    TABLE_NAME,
                    KEY_1,
                    KEY_2,
                    KEY_3,
                    KEY_4,
                    KEY_5,
                    KEY_6,
                    KEY_7,
                    KEY_8,
                    KEY_9,
                    KEY_10,
                    DATA_1,
                    DATA_2,
                    DATA_3,
                    DATA_4,
                    DATA_5,
                    DATA_6,
                    DATA_7,
                    DATA_8,
                    DATA_9,
                    DATA_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MGCMTBLDAT
				WHERE  FACTORY = :MGCMTBLDAT_N.FACTORY
                    AND TABLE_NAME = :MGCMTBLDAT_N.TABLE_NAME
                ORDER BY DATA_3;
            EXEC SQL OPEN CDB_MGCMTBLDAT_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_MGCMTBLDAT_CUR_3 CURSOR FOR
                SELECT 
