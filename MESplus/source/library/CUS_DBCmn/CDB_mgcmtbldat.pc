/* SQL INSERT Function */
void CDB_insert_mgcmtbldat(struct MGCMTBLDAT_TAG *MGCMTBLDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MGCMTBLDAT_N_TAG MGCMTBLDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_mgcmtbldat(&MGCMTBLDAT_N, MGCMTBLDAT);
    DB_error_code = 0;


    EXEC SQL INSERT INTO MGCMTBLDAT( 
                    FACTORY, 
                    TABLE_NAME, 
                    KEY_1, 
                    KEY_2, 
                    KEY_3, 
                    KEY_4, 
                    KEY_5, 
                    KEY_6, 
                    KEY_7, 
                    KEY_8, 
                    KEY_9, 
                    KEY_10, 
                    DATA_1, 
                    DATA_2, 
                    DATA_3, 
                    DATA_4, 
                    DATA_5, 
                    DATA_6, 
                    DATA_7, 
                    DATA_8, 
                    DATA_9, 
                    DATA_10, 
                    CREATE_USER_ID, 
                    CREATE_TIME, 
                    UPDATE_USER_ID, 
                    UPDATE_TIME
         ) 
        VALUES (
                    :MGCMTBLDAT_N.FACTORY,
                    :MGCMTBLDAT_N.TABLE_NAME,
                    :MGCMTBLDAT_N.KEY_1,
                    :MGCMTBLDAT_N.KEY_2,
