    CMMSITMHIS_N->SPEC_TYPE[0] = CMMSITMHIS->SPEC_TYPE;
    CMMSITMHIS_N->USL = CMMSITMHIS->USL;
    CMMSITMHIS_N->TARGET = CMMSITMHIS->TARGET;
    CMMSITMHIS_N->LSL = CMMSITMHIS->LSL;
