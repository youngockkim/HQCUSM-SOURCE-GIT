        struct CMMSITMHIS_N_TAG CMMSITMHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cmmsitmhis(&CMMSITMHIS_N, CMMSITMHIS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CMMSITMHIS_CUR_1 CURSOR FOR
                SELECT 
					FACTORY,
                    ITEM_CODE,
                    HIST_SEQ,
                    ITEM_NAME,
                    ITEM_SPEC,
                    ITEM_GROUP_CODE,
                    TAG_NAME,
                    SPEC_TYPE,
                    USL,
                    TARGET,
                    LSL,
                    UCL,
                    LCL,
                    UNIT_CODE,
                    DECIMAL_PLACE,
                    USE_FLAG,
					DELETE_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSITMHIS
                ORDER BY ITEM_CODE ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN CDB_CMMSITMHIS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
