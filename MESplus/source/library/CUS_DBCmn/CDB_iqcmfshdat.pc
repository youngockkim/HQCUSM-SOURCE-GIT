                    ZPIMSG = :IQCMFSHDAT_N.ZPIMSG,
                    RETURN_TYPE = :IQCMFSHDAT_N.RETURN_TYPE,
                    RETURN_MSG = :IQCMFSHDAT_N.RETURN_MSG,
                    ERP_DATE = :IQCMFSHDAT_N.ERP_DATE,
                    ERP_TIME = :IQCMFSHDAT_N.ERP_TIME,
                    ERP_FLAG = :IQCMFSHDAT_N.ERP_FLAG,
                    ERP_MSG = :IQCMFSHDAT_N.ERP_MSG,
                    IF_FLAG = :IQCMFSHDAT_N.IF_FLAG
                WHERE DOC_ID = :IQCMFSHDAT_N.DOC_ID
                    AND SITE_ID = :IQCMFSHDAT_N.SITE_ID
                    AND PROD_ORDER_NO = :IQCMFSHDAT_N.PROD_ORDER_NO
                    AND MODULE_ID = :IQCMFSHDAT_N.MODULE_ID
                    AND OPER_NO = :IQCMFSHDAT_N.OPER_NO
                    AND WORK_CENTER = :IQCMFSHDAT_N.WORK_CENTER
                    AND ACTION_TYPE = :IQCMFSHDAT_N.ACTION_TYPE;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_iqcmfshdat", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_iqcmfshdat(int sel_type, struct IQCMFSHDAT_TAG *IQCMFSHDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IQCMFSHDAT_N_TAG IQCMFSHDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_iqcmfshdat(&IQCMFSHDAT_N, IQCMFSHDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IQCMFSHDAT_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_ORDER_NO,
                    MODULE_ID,
                    OPER_NO,
                    WORK_CENTER,
                    ACTION_TYPE,
                    MATE_NO,
                    PROD_QTY,
                    SCRAP_QTY,
                    UNIT_ID,
                    FQC_DATE,
                    QUALITY_GRADE,
                    POWER_GRADE,
                    SHIFT,
                    LOCATION,
                    EFF,
                    RSH,
                    RS,
                    FF,
                    ISC,
                    VOC,
                    IMPP,
                    VMPP,
                    PMPP,
                    TEMP,
                    ENVTEMP,
                    SURFTEMP,
                    SUN,
                    FQC_GRADE,
                    FQC_POWER,
                    FQC_OPERATOR,
                    OSC,
                    ESC,
                    EL,
                    NVL(FLASHER_CODE, ' '),
                    MODULE_CREATEDATE,
                    DELIVERY_NOTE,
                    DELIVERY_NOTE2,
                    ARTICLE_NO,
                    ARTICLE_NO2,
                    ARTICLE_CODE,
                    COLOR_CLASS,
                    MIXING_RATIO,
                    DEGRATION,
                    INF_USER_ID,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPICODE,
                    ZPIMSGID,
                    ZPISTAT,
                    ZPIMSG,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ERP_DATE,
                    ERP_TIME,
                    ERP_FLAG,
                    ERP_MSG,
                    IF_FLAG
                FROM IQCMFSHDAT
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_ORDER_NO ASC,
                    MODULE_ID ASC,
                    OPER_NO ASC,
                    WORK_CENTER ASC,
                    ACTION_TYPE ASC;
            EXEC SQL OPEN CDB_IQCMFSHDAT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_iqcmfshdat", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_iqcmfshdat(int sel_type, struct IQCMFSHDAT_TAG *IQCMFSHDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
