                :IQCMFSHDAT_N.ZPIMSGID,
                :IQCMFSHDAT_N.ZPISTAT,
                :IQCMFSHDAT_N.ZPIMSG,
                :IQCMFSHDAT_N.RETURN_TYPE,
                :IQCMFSHDAT_N.RETURN_MSG,
                :IQCMFSHDAT_N.ERP_DATE,
                :IQCMFSHDAT_N.ERP_TIME,
                :IQCMFSHDAT_N.ERP_FLAG,
                :IQCMFSHDAT_N.ERP_MSG,
                :IQCMFSHDAT_N.IF_FLAG;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_iqcmfshdat(&IQCMFSHDAT_N, IQCMFSHDAT);
    }

    DB_stop_query_timer("CDB_fetch_iqcmfshdat", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_iqcmfshdat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IQCMFSHDAT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_iqcmfshdat", sel_type);
}


