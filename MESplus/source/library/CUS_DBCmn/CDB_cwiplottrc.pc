                    TAB_ZONE = :CWIPLOTTRC_N.TAB_ZONE,
                    TAB_RES_ID = :CWIPLOTTRC_N.TAB_RES_ID,
                    TAB_RIB_MAT_ID = :CWIPLOTTRC_N.TAB_RIB_MAT_ID,
                    TAB_RIB_INVLOT_ID = :CWIPLOTTRC_N.TAB_RIB_INVLOT_ID,
                    GLS_MAT_ID = :CWIPLOTTRC_N.GLS_MAT_ID,
                    GLS_INVLOT_ID = :CWIPLOTTRC_N.GLS_INVLOT_ID,
                    EVA1_MAT_ID = :CWIPLOTTRC_N.EVA1_MAT_ID,
                    EVA1_INVLOT_ID = :CWIPLOTTRC_N.EVA1_INVLOT_ID,
                    EVA1_TIME = :CWIPLOTTRC_N.EVA1_TIME,
                    EVA1_RES_ID = :CWIPLOTTRC_N.EVA1_RES_ID,
                    FEED_TIME = :CWIPLOTTRC_N.FEED_TIME,
                    FEED_RES_ID = :CWIPLOTTRC_N.FEED_RES_ID,
