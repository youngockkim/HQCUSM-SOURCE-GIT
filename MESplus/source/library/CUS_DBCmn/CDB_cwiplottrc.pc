/* SQL UPDATE Function */
void CDB_update_cwiplottrc(int sel_type, struct CWIPLOTTRC_TAG *CWIPLOTTRC)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPLOTTRC_N_TAG CWIPLOTTRC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwiplottrc(&CWIPLOTTRC_N, CWIPLOTTRC);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE CWIPLOTTRC SET
                    WORK_ORDER = :CWIPLOTTRC_N.WORK_ORDER,
                    -- WORK_DATE = :CWIPLOTTRC_N.WORK_DATE,
                    WORK_SHIFT = :CWIPLOTTRC_N.WORK_SHIFT,
