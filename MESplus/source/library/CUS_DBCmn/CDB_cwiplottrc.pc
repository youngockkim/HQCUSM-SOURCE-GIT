                    FRM_MID_MAT_ID = :CWIPLOTTRC_N.FRM_MID_MAT_ID,
                    FRM_MID_INVLOT_ID = :CWIPLOTTRC_N.FRM_MID_INVLOT_ID,
                    JBX_INS_TIME = :CWIPLOTTRC_N.JBX_INS_TIME,
                    JBX_INS_RES_ID = :CWIPLOTTRC_N.JBX_INS_RES_ID,
                    JBX_MAT_ID = :CWIPLOTTRC_N.JBX_MAT_ID,
                    JBX_INVLOT_ID = :CWIPLOTTRC_N.JBX_INVLOT_ID,
                    JBX_SIL_MAT_ID = :CWIPLOTTRC_N.JBX_SIL_MAT_ID,
                    JBX_SIL_INVLOT_ID = :CWIPLOTTRC_N.JBX_SIL_INVLOT_ID,
                    JBX_POT_TIME = :CWIPLOTTRC_N.JBX_POT_TIME,
                    JBX_POT_RES_ID = :CWIPLOTTRC_N.JBX_POT_RES_ID,
                    JBX_POT_SIL_MAT_ID = :CWIPLOTTRC_N.JBX_POT_SIL_MAT_ID,
                    JBX_POT_SIL_INVLOT_ID = :CWIPLOTTRC_N.JBX_POT_SIL_INVLOT_ID,
                    CUR_TIME = :CWIPLOTTRC_N.CUR_TIME,
                    CUR_RES_ID = :CWIPLOTTRC_N.CUR_RES_ID,
                    CUR_EXE_TIME = :CWIPLOTTRC_N.CUR_EXE_TIME,
                    JBX_POT_MAT_ID = :CWIPLOTTRC_N.JBX_POT_MAT_ID,
                    JBX_POT_INVLOT_ID = :CWIPLOTTRC_N.JBX_POT_INVLOT_ID,
                    CLN_TIME = :CWIPLOTTRC_N.CLN_TIME,
                    CLN_RES_ID = :CWIPLOTTRC_N.CLN_RES_ID,
                    FQC1_RESULT = :CWIPLOTTRC_N.FQC1_RESULT,
                    FQC1_TIME = :CWIPLOTTRC_N.FQC1_TIME,
                    FQC1_RES_ID = :CWIPLOTTRC_N.FQC1_RES_ID,
                    FQC2_RESULT = :CWIPLOTTRC_N.FQC2_RESULT,
                    FQC2_TIME = :CWIPLOTTRC_N.FQC2_TIME,
                    FQC2_RES_ID = :CWIPLOTTRC_N.FQC2_RES_ID,
                    HIP_TIME = :CWIPLOTTRC_N.HIP_TIME,
                    HIP_RES_ID = :CWIPLOTTRC_N.HIP_RES_ID,
                    FQC_COUNT = :CWIPLOTTRC_N.FQC_COUNT,
                    PALLET_ID = :CWIPLOTTRC_N.PALLET_ID,
                    PACKING_TIME = :CWIPLOTTRC_N.PACKING_TIME,
                    IV_TIME = :CWIPLOTTRC_N.IV_TIME,
                    IV_RES_ID = :CWIPLOTTRC_N.IV_RES_ID,
                    EL2_TIME = :CWIPLOTTRC_N.EL2_TIME,
                    EL2_RES_ID = :CWIPLOTTRC_N.EL2_RES_ID,
                    SOT_TIME = :CWIPLOTTRC_N.SOT_TIME,
                    SOT_RES_ID = :CWIPLOTTRC_N.SOT_RES_ID,
                    SIM_TIME = :CWIPLOTTRC_N.SIM_TIME,
                    SIM_RES_ID = :CWIPLOTTRC_N.SIM_RES_ID,
                    EXT_DATA_1 = :CWIPLOTTRC_N.EXT_DATA_1,
                    EXT_DATA_2 = :CWIPLOTTRC_N.EXT_DATA_2,
                    EXT_DATA_3 = :CWIPLOTTRC_N.EXT_DATA_3,
                    EXT_DATA_4 = :CWIPLOTTRC_N.EXT_DATA_4,
                    EXT_DATA_5 = :CWIPLOTTRC_N.EXT_DATA_5,
                    CMF1 = :CWIPLOTTRC_N.CMF1,
                    CMF2 = :CWIPLOTTRC_N.CMF2,
                    CMF3 = :CWIPLOTTRC_N.CMF3,
                    CMF4 = :CWIPLOTTRC_N.CMF4,
                    CMF5 = :CWIPLOTTRC_N.CMF5
                WHERE LOT_ID = :CWIPLOTTRC_N.LOT_ID;
            break;

        case 2:
            EXEC SQL UPDATE CWIPLOTTRC SET
                    FACTORY = :CWIPLOTTRC_N.FACTORY,
                    EL_IMAGE_PATH1 = :CWIPLOTTRC_N.EL_IMAGE_PATH1
                WHERE LOT_ID = :CWIPLOTTRC_N.LOT_ID;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_cwiplottrc", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwiplottrc(int sel_type, struct CWIPLOTTRC_TAG *CWIPLOTTRC)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPLOTTRC_N_TAG CWIPLOTTRC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwiplottrc(&CWIPLOTTRC_N, CWIPLOTTRC);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPLOTTRC_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    WORK_ORDER,
                    WORK_DATE,
                    WORK_SHIFT,
                    WORK_LINE,
                    FACTORY,
                    MAT_ID,
                    FLOW,
                    OPER,
                    EL_IMAGE_PATH1,
                    EL_IMAGE_PATH2,
                    STOCK_IN_TRAN_TIME,
                    SHIP_TRAN_TIME,
                    CELL_MAT_ID,
                    CELL_INVLOT_ID,
                    CLV_TIME,
                    CLV_MOV_TRAN_TIME,
                    CLV_ORDER_ID,
                    CLV_MAT_ID,
                    CLV_RES_ID,
                    SHIP_NO,
                    SHIP_SEQ,
                    TAB_TIME,
                    TAB_ZONE,
                    TAB_RES_ID,
                    TAB_RIB_MAT_ID,
                    TAB_RIB_INVLOT_ID,
                    GLS_MAT_ID,
                    GLS_INVLOT_ID,
                    EVA1_MAT_ID,
                    EVA1_INVLOT_ID,
                    EVA1_TIME,
                    EVA1_RES_ID,
                    FEED_TIME,
                    FEED_RES_ID,
                    LAY_TIME,
                    LAY_RES_ID,
                    BUS_TIME,
                    BUS_RES_ID,
                    EVA2_MAT_ID,
                    EVA2_INVLOT_ID,
                    EVA2_TIME,
                    EVA2_RES_ID,
                    TPT_TIME,
                    TPT_RES_ID,
                    TPT_MAT_ID,
                    TPT_INVMAT_ID,
                    EPE_TIME,
                    EPE_RES_ID,
                    EL1_TIME,
                    EL1_RES_ID,
                    LAM_TIME,
                    LAM_RES_ID,
                    FRM_SIL_MAT_ID,
                    FRM_SIL_INVLOT_ID,
                    AOI_TIME,
                    AOI_RES_ID,
                    AOI_TYPE,
                    FRM_MAT_ID,
                    FRM_INVLOT_ID,
                    FRM_TIME,
                    FRM_RES_ID,
                    FRM_MID_MAT_ID,
                    FRM_MID_INVLOT_ID,
                    JBX_INS_TIME,
                    JBX_INS_RES_ID,
                    JBX_MAT_ID,
                    JBX_INVLOT_ID,
                    JBX_SIL_MAT_ID,
                    JBX_SIL_INVLOT_ID,
                    JBX_POT_TIME,
                    JBX_POT_RES_ID,
                    JBX_POT_SIL_MAT_ID,
                    JBX_POT_SIL_INVLOT_ID,
                    CUR_TIME,
                    CUR_RES_ID,
                    CUR_EXE_TIME,
                    JBX_POT_MAT_ID,
                    JBX_POT_INVLOT_ID,
                    CLN_TIME,
                    CLN_RES_ID,
                    FQC1_RESULT,
                    FQC1_TIME,
                    FQC1_RES_ID,
                    FQC2_RESULT,
                    FQC2_TIME,
                    FQC2_RES_ID,
                    HIP_TIME,
                    HIP_RES_ID,
                    FQC_COUNT,
                    PALLET_ID,
                    PACKING_TIME,
                    IV_TIME,
                    IV_RES_ID,
                    EL2_TIME,
                    EL2_RES_ID,
                    SOT_TIME,
                    SOT_RES_ID,
                    SIM_TIME,
                    SIM_RES_ID,
                    EXT_DATA_1,
                    EXT_DATA_2,
                    EXT_DATA_3,
                    EXT_DATA_4,
                    EXT_DATA_5,
                    CMF1,
                    CMF2,
                    CMF3,
                    CMF4,
                    CMF5
                FROM CWIPLOTTRC
                ORDER BY LOT_ID ASC;
            EXEC SQL OPEN CDB_CWIPLOTTRC_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwiplottrc", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_cwiplottrc(int sel_type, struct CWIPLOTTRC_TAG *CWIPLOTTRC)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPLOTTRC_N_TAG CWIPLOTTRC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CWIPLOTTRC_CUR_1 INTO
                :CWIPLOTTRC_N.LOT_ID,
                :CWIPLOTTRC_N.WORK_ORDER,
                :CWIPLOTTRC_N.WORK_DATE,
