                :CWIPLOTTRC_N.FQC2_RESULT,
                :CWIPLOTTRC_N.FQC2_TIME,
                :CWIPLOTTRC_N.FQC2_RES_ID,
                :CWIPLOTTRC_N.HIP_TIME,
                :CWIPLOTTRC_N.HIP_RES_ID,
                :CWIPLOTTRC_N.FQC_COUNT,
                :CWIPLOTTRC_N.PALLET_ID,
                :CWIPLOTTRC_N.PACKING_TIME,
                :CWIPLOTTRC_N.IV_TIME,
                :CWIPLOTTRC_N.IV_RES_ID,
                :CWIPLOTTRC_N.EL2_TIME,
                :CWIPLOTTRC_N.EL2_RES_ID,
                :CWIPLOTTRC_N.SOT_TIME,
                :CWIPLOTTRC_N.SOT_RES_ID,
                :CWIPLOTTRC_N.SIM_TIME,
                :CWIPLOTTRC_N.SIM_RES_ID,
                :CWIPLOTTRC_N.EXT_DATA_1,
                :CWIPLOTTRC_N.EXT_DATA_2,
                :CWIPLOTTRC_N.EXT_DATA_3,
                :CWIPLOTTRC_N.EXT_DATA_4,
                :CWIPLOTTRC_N.EXT_DATA_5,
                :CWIPLOTTRC_N.CMF1,
                :CWIPLOTTRC_N.CMF2,
                :CWIPLOTTRC_N.CMF3,
                :CWIPLOTTRC_N.CMF4,
                :CWIPLOTTRC_N.CMF5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cwiplottrc(&CWIPLOTTRC_N, CWIPLOTTRC);
    }

    DB_stop_query_timer("CDB_fetch_cwiplottrc", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cwiplottrc(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CWIPLOTTRC_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwiplottrc", sel_type);
}


/* Initialize Function */
void CDB_init_cwiplottrc(struct CWIPLOTTRC_TAG *CWIPLOTTRC)
{
    /* memset by Space */
    memset(CWIPLOTTRC, ' ', sizeof(struct CWIPLOTTRC_TAG));
    
    CWIPLOTTRC->FQC_COUNT = 0;
}


