                :CWIPCTWPFT_N.WORK_DATE,
                :CWIPCTWPFT_N.WORK_TIME,
                :CWIPCTWPFT_N.TYPE,
                :CWIPCTWPFT_N.LINE_ID,
                :CWIPCTWPFT_N.TAB_NO,
                :CWIPCTWPFT_N.LR,
                :CWIPCTWPFT_N.POS,
                :CWIPCTWPFT_N.POS_FR_1,
                :CWIPCTWPFT_N.POS_FR_2,
                :CWIPCTWPFT_N.POS_FR_3,
                :CWIPCTWPFT_N.POS_FR_4,
                :CWIPCTWPFT_N.POS_FR_5,
                :CWIPCTWPFT_N.POS_FR_6,
                :CWIPCTWPFT_N.POS_FR_7,
                :CWIPCTWPFT_N.POS_FR_8,
                :CWIPCTWPFT_N.POS_FR_9,
                :CWIPCTWPFT_N.POS_FR_10,
                :CWIPCTWPFT_N.POS_FR_11,
                :CWIPCTWPFT_N.POS_FR_12,
                :CWIPCTWPFT_N.POS_RE_1,
                :CWIPCTWPFT_N.POS_RE_2,
                :CWIPCTWPFT_N.POS_RE_3,
                :CWIPCTWPFT_N.POS_RE_4,
                :CWIPCTWPFT_N.POS_RE_5,
                :CWIPCTWPFT_N.POS_RE_6,
                :CWIPCTWPFT_N.POS_RE_7,
                :CWIPCTWPFT_N.POS_RE_8,
                :CWIPCTWPFT_N.POS_RE_9,
                :CWIPCTWPFT_N.POS_RE_10,
                :CWIPCTWPFT_N.POS_RE_11,
                :CWIPCTWPFT_N.POS_RE_12,
                :CWIPCTWPFT_N.INS_CNT,
                :CWIPCTWPFT_N.INS_TIME,
                :CWIPCTWPFT_N.INS_USER_ID,
                :CWIPCTWPFT_N.LAST_HIST_SEQ,
                :CWIPCTWPFT_N.CMF_1,
                :CWIPCTWPFT_N.CMF_2,
                :CWIPCTWPFT_N.CMF_3,
                :CWIPCTWPFT_N.CMF_4,
                :CWIPCTWPFT_N.CMF_5,
                :CWIPCTWPFT_N.CMF_6,
                :CWIPCTWPFT_N.CMF_7,
                :CWIPCTWPFT_N.CMF_8,
                :CWIPCTWPFT_N.CMF_9,
                :CWIPCTWPFT_N.CMF_10;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cwipctwpft(&CWIPCTWPFT_N, CWIPCTWPFT);
    }

    DB_stop_query_timer("CDB_fetch_cwipctwpft", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cwipctwpft(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CWIPCTWPFT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwipctwpft", sel_type);
}


/* Initialize Function */
void CDB_init_cwipctwpft(struct CWIPCTWPFT_TAG *CWIPCTWPFT)
{
    /* memset by Space */
    memset(CWIPCTWPFT, ' ', sizeof(struct CWIPCTWPFT_TAG));
    
    CWIPCTWPFT->TAB_NO = 0;
    CWIPCTWPFT->POS = 0;
    CWIPCTWPFT->INS_CNT = 0;
    CWIPCTWPFT->LAST_HIST_SEQ = 0;
}


