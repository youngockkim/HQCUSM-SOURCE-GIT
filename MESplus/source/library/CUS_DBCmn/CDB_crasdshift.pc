    MEMCPY_DN(CRASDSHIFT->CMF_2, CRASDSHIFT_N->CMF_2, sizeof(CRASDSHIFT->CMF_2));
    MEMCPY_DN(CRASDSHIFT->CMF_3, CRASDSHIFT_N->CMF_3, sizeof(CRASDSHIFT->CMF_3));
    MEMCPY_DN(CRASDSHIFT->CMF_4, CRASDSHIFT_N->CMF_4, sizeof(CRASDSHIFT->CMF_4));
    MEMCPY_DN(CRASDSHIFT->CMF_5, CRASDSHIFT_N->CMF_5, sizeof(CRASDSHIFT->CMF_5));
}


