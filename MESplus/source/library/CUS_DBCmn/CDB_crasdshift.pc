}


/* Add Null Function */
void CDB_add_null_crasdshift(struct CRASDSHIFT_N_TAG *CRASDSHIFT_N, struct CRASDSHIFT_TAG *CRASDSHIFT)
{
    /* memset by NULL */
    memset(CRASDSHIFT_N, '\0', sizeof(struct CRASDSHIFT_N_TAG));
    
    MEMCPY_AN(CRASDSHIFT_N->WORK_DATE, CRASDSHIFT->WORK_DATE, sizeof(CRASDSHIFT->WORK_DATE));
    MEMCPY_AN(CRASDSHIFT_N->LINE_ID, CRASDSHIFT->LINE_ID, sizeof(CRASDSHIFT->LINE_ID));
    MEMCPY_AN(CRASDSHIFT_N->WORK_SHIFT, CRASDSHIFT->WORK_SHIFT, sizeof(CRASDSHIFT->WORK_SHIFT));
    CRASDSHIFT_N->RW = CRASDSHIFT->RW;
    CRASDSHIFT_N->FRA = CRASDSHIFT->FRA;
    CRASDSHIFT_N->ETC = CRASDSHIFT->ETC;
    CRASDSHIFT_N->OK = CRASDSHIFT->OK;
    CRASDSHIFT_N->NG = CRASDSHIFT->NG;
    MEMCPY_AN(CRASDSHIFT_N->CREATE_USER_ID, CRASDSHIFT->CREATE_USER_ID, sizeof(CRASDSHIFT->CREATE_USER_ID));
    MEMCPY_AN(CRASDSHIFT_N->UPDATE_USER_ID, CRASDSHIFT->UPDATE_USER_ID, sizeof(CRASDSHIFT->UPDATE_USER_ID));
    MEMCPY_AN(CRASDSHIFT_N->TRAN_TIME, CRASDSHIFT->TRAN_TIME, sizeof(CRASDSHIFT->TRAN_TIME));
    MEMCPY_AN(CRASDSHIFT_N->CMF_1, CRASDSHIFT->CMF_1, sizeof(CRASDSHIFT->CMF_1));
    MEMCPY_AN(CRASDSHIFT_N->CMF_2, CRASDSHIFT->CMF_2, sizeof(CRASDSHIFT->CMF_2));
    MEMCPY_AN(CRASDSHIFT_N->CMF_3, CRASDSHIFT->CMF_3, sizeof(CRASDSHIFT->CMF_3));
    MEMCPY_AN(CRASDSHIFT_N->CMF_4, CRASDSHIFT->CMF_4, sizeof(CRASDSHIFT->CMF_4));
    MEMCPY_AN(CRASDSHIFT_N->CMF_5, CRASDSHIFT->CMF_5, sizeof(CRASDSHIFT->CMF_5));
}


