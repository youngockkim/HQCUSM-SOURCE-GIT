                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' ')
                FROM CRASDSHIFT
				WHERE WORK_DATE = :CRASDSHIFT_N.WORK_DATE
				AND WORK_SHIFT =  :CRASDSHIFT_N.WORK_SHIFT
				AND LINE_ID IN ( SELECT KEY_1 FROM MGCMTBLDAT WHERE TABLE_NAME  = '@LINE_CODE' AND DATA_5 = 'MA' AND DATA_7 = :CRASDSHIFT_N.CMF_5 )
                ORDER BY WORK_DATE ASC,
                    LINE_ID ASC,
