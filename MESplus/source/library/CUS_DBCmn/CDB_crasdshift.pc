    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASDSHIFT_CUR_1 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    LINE_ID,
                    WORK_SHIFT,
                    NVL(RW, '0'),
                    NVL(FRA, '0'),
                    NVL(ETC, '0'),
                    NVL(OK, '0'),
                    NVL(NG, '0'),
                    NVL(CREATE_USER_ID, ' '),
                    NVL(UPDATE_USER_ID, ' '),
                    NVL(TRAN_TIME, ' '),
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' ')
                FROM CRASDSHIFT
                ORDER BY WORK_DATE ASC,
                    LINE_ID ASC,
                    WORK_SHIFT ASC;
            EXEC SQL OPEN CDB_CRASDSHIFT_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CRASDSHIFT_CUR_2 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    LINE_ID,
                    WORK_SHIFT,
                    NVL(RW, '0'),
                    NVL(FRA, '0'),
                    NVL(ETC, '0'),
                    NVL(OK, '0'),
                    NVL(NG, '0'),
                    NVL(CREATE_USER_ID, ' '),
                    NVL(UPDATE_USER_ID, ' '),
                    NVL(TRAN_TIME, ' '),
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' ')
                FROM CRASDSHIFT
				WHERE WORK_DATE = :CRASDSHIFT_N.WORK_DATE
				AND WORK_SHIFT =  :CRASDSHIFT_N.WORK_SHIFT
                ORDER BY WORK_DATE ASC,
                    LINE_ID ASC,
                    WORK_SHIFT ASC;
            EXEC SQL OPEN CDB_CRASDSHIFT_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_CRASDSHIFT_CUR_3 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    LINE_ID,
                    WORK_SHIFT,
                    NVL(RW, '0'),
                    NVL(FRA, '0'),
                    NVL(ETC, '0'),
                    NVL(OK, '0'),
                    NVL(NG, '0'),
                    NVL(CREATE_USER_ID, ' '),
                    NVL(UPDATE_USER_ID, ' '),
                    NVL(TRAN_TIME, ' '),
