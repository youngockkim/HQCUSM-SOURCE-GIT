/* SQL SELECT_SCALAR Function */
double CDB_select_rsumwipmov_scalar(int sel_type, struct RSUMWIPMOV_TAG *RSUMWIPMOV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMWIPMOV_N_TAG RSUMWIPMOV_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumwipmov(&RSUMWIPMOV_N, RSUMWIPMOV);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM RSUMWIPMOV
                WHERE WORK_DATE = :RSUMWIPMOV_N.WORK_DATE
                    AND FACTORY = :RSUMWIPMOV_N.FACTORY
                    AND MAT_ID = :RSUMWIPMOV_N.MAT_ID
                    AND MAT_VER = :RSUMWIPMOV_N.MAT_VER
                    AND FLOW = :RSUMWIPMOV_N.FLOW
                    AND FLOW_SEQ_NUM = :RSUMWIPMOV_N.FLOW_SEQ_NUM
                    AND OPER = :RSUMWIPMOV_N.OPER
                    AND LOT_TYPE = :RSUMWIPMOV_N.LOT_TYPE
                    AND ORDER_ID = :RSUMWIPMOV_N.ORDER_ID
                    AND CM_KEY_1 = :RSUMWIPMOV_N.CM_KEY_1
                    AND CM_KEY_2 = :RSUMWIPMOV_N.CM_KEY_2
                    AND CM_KEY_3 = :RSUMWIPMOV_N.CM_KEY_3
                    AND CM_KEY_4 = :RSUMWIPMOV_N.CM_KEY_4
                    AND CM_KEY_5 = :RSUMWIPMOV_N.CM_KEY_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_rsumwipmov_scalar", sel_type);

    return d_value;
}


/* SQL DELETE Function */
void CDB_delete_rsumwipmov(int sel_type, struct RSUMWIPMOV_TAG *RSUMWIPMOV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMWIPMOV_N_TAG RSUMWIPMOV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumwipmov(&RSUMWIPMOV_N, RSUMWIPMOV);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM RSUMWIPMOV
                WHERE WORK_DATE = :RSUMWIPMOV_N.WORK_DATE
                    AND FACTORY = :RSUMWIPMOV_N.FACTORY
                    AND MAT_ID = :RSUMWIPMOV_N.MAT_ID
                    AND MAT_VER = :RSUMWIPMOV_N.MAT_VER
                    AND FLOW = :RSUMWIPMOV_N.FLOW
                    AND FLOW_SEQ_NUM = :RSUMWIPMOV_N.FLOW_SEQ_NUM
                    AND OPER = :RSUMWIPMOV_N.OPER
                    AND LOT_TYPE = :RSUMWIPMOV_N.LOT_TYPE
                    AND ORDER_ID = :RSUMWIPMOV_N.ORDER_ID
                    AND CM_KEY_1 = :RSUMWIPMOV_N.CM_KEY_1
                    AND CM_KEY_2 = :RSUMWIPMOV_N.CM_KEY_2
                    AND CM_KEY_3 = :RSUMWIPMOV_N.CM_KEY_3
                    AND CM_KEY_4 = :RSUMWIPMOV_N.CM_KEY_4
                    AND CM_KEY_5 = :RSUMWIPMOV_N.CM_KEY_5;
            break;

		case 2:
            EXEC SQL DELETE FROM RSUMWIPMOV
                WHERE WORK_DATE >= :RSUMWIPMOV_N.CM_KEY_1
                  AND WORK_DATE <= :RSUMWIPMOV_N.CM_KEY_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_delete_rsumwipmov", sel_type);
}


