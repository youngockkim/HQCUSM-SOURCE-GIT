                    :RSUMWIPMOV_N.S2_LOSS_RWK_QTY_2,
                    :RSUMWIPMOV_N.S3_LOSS_RWK_QTY_2,
                    :RSUMWIPMOV_N.S4_LOSS_RWK_QTY_2,
