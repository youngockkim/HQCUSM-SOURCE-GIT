/* SQL UPDATE Function */
void CDB_update_rsumwipmov(int sel_type, struct RSUMWIPMOV_TAG *RSUMWIPMOV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMWIPMOV_N_TAG RSUMWIPMOV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumwipmov(&RSUMWIPMOV_N, RSUMWIPMOV);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE RSUMWIPMOV SET
                    WORK_MONTH = :RSUMWIPMOV_N.WORK_MONTH,
                    WORK_WEEK = :RSUMWIPMOV_N.WORK_WEEK,
