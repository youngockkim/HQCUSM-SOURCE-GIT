                    S4_PULL_TIME
                FROM RSUMWIPMOV
				WHERE 	
				WORK_DATE >= :RSUMWIPMOV_N.CM_KEY_3
	            AND WORK_DATE <= :RSUMWIPMOV_N.CM_KEY_4
				AND CM_KEY_1 LIKE :RSUMWIPMOV_N.CM_KEY_1
				AND OPER LIKE :RSUMWIPMOV_N.OPER
				AND MAT_ID LIKE :RSUMWIPMOV_N.MAT_ID
                ORDER BY WORK_DATE ASC,
                    FACTORY ASC,
                    MAT_ID ASC,
                    MAT_VER ASC,
                    FLOW ASC,
                    FLOW_SEQ_NUM ASC,
                    OPER ASC,
                    LOT_TYPE ASC,
                    ORDER_ID ASC,
                    CM_KEY_1 ASC,
                    CM_KEY_2 ASC,
                    CM_KEY_3 ASC,
                    CM_KEY_4 ASC,
                    CM_KEY_5 ASC;
            EXEC SQL OPEN CDB_RSUMWIPMOV_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_rsumwipmov", sel_type);
}


