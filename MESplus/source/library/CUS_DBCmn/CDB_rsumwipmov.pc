                    :RSUMWIPMOV_N.S1_CV_QTY_2,
                    :RSUMWIPMOV_N.S2_CV_QTY_2,
                    :RSUMWIPMOV_N.S3_CV_QTY_2,
                    :RSUMWIPMOV_N.S4_CV_QTY_2,
