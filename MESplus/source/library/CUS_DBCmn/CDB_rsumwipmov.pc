                    :RSUMWIPMOV_N.S1_CHG_QTY_1,
                    :RSUMWIPMOV_N.S2_CHG_QTY_1,
                    :RSUMWIPMOV_N.S3_CHG_QTY_1,
                    :RSUMWIPMOV_N.S4_CHG_QTY_1,
                    :RSUMWIPMOV_N.S1_CHG_QTY_2,
                    :RSUMWIPMOV_N.S2_CHG_QTY_2,
                    :RSUMWIPMOV_N.S3_CHG_QTY_2,
                    :RSUMWIPMOV_N.S4_CHG_QTY_2,
                    :RSUMWIPMOV_N.S1_CHG_QTY_3,
                    :RSUMWIPMOV_N.S2_CHG_QTY_3,
                    :RSUMWIPMOV_N.S3_CHG_QTY_3,
                    :RSUMWIPMOV_N.S4_CHG_QTY_3,
                    :RSUMWIPMOV_N.S1_QUEUE_TIME,
                    :RSUMWIPMOV_N.S2_QUEUE_TIME,
                    :RSUMWIPMOV_N.S3_QUEUE_TIME,
                    :RSUMWIPMOV_N.S4_QUEUE_TIME,
                    :RSUMWIPMOV_N.S1_HOLD_TIME,
                    :RSUMWIPMOV_N.S2_HOLD_TIME,
                    :RSUMWIPMOV_N.S3_HOLD_TIME,
                    :RSUMWIPMOV_N.S4_HOLD_TIME,
                    :RSUMWIPMOV_N.S1_PROC_TIME,
                    :RSUMWIPMOV_N.S2_PROC_TIME,
                    :RSUMWIPMOV_N.S3_PROC_TIME,
                    :RSUMWIPMOV_N.S4_PROC_TIME,
                    :RSUMWIPMOV_N.S1_PULL_TIME,
                    :RSUMWIPMOV_N.S2_PULL_TIME,
                    :RSUMWIPMOV_N.S3_PULL_TIME,
                    :RSUMWIPMOV_N.S4_PULL_TIME
                FROM RSUMWIPMOV
                WHERE WORK_DATE = :RSUMWIPMOV_N.WORK_DATE
                    AND FACTORY = :RSUMWIPMOV_N.FACTORY
                    AND MAT_ID = :RSUMWIPMOV_N.MAT_ID
                    AND MAT_VER = :RSUMWIPMOV_N.MAT_VER
                    AND FLOW = :RSUMWIPMOV_N.FLOW
                    AND FLOW_SEQ_NUM = :RSUMWIPMOV_N.FLOW_SEQ_NUM
                    AND OPER = :RSUMWIPMOV_N.OPER
                    AND LOT_TYPE = :RSUMWIPMOV_N.LOT_TYPE
                    AND ORDER_ID = :RSUMWIPMOV_N.ORDER_ID
                    AND CM_KEY_1 = :RSUMWIPMOV_N.CM_KEY_1
                    AND CM_KEY_2 = :RSUMWIPMOV_N.CM_KEY_2
                    AND CM_KEY_3 = :RSUMWIPMOV_N.CM_KEY_3
                    AND CM_KEY_4 = :RSUMWIPMOV_N.CM_KEY_4
                    AND CM_KEY_5 = :RSUMWIPMOV_N.CM_KEY_5;
            break;

		case 2:
				EXEC SQL SELECT 
                    ORDER_ID,
                    SUM(S1_OPER_IN_QTY_1 + S2_OPER_IN_QTY_1) IN_QTY,
					SUM(S1_END_QTY_1 + S2_END_QTY_1)          OUT_QTY,
					SUM(S1_LOSS_QTY_1 + S2_LOSS_QTY_1)			LOSS_QTY  
                INTO 
                    :RSUMWIPMOV_N.ORDER_ID,
                    :RSUMWIPMOV_N.S1_OPER_IN_QTY_1,
					:RSUMWIPMOV_N.S1_END_QTY_1,
					:RSUMWIPMOV_N.S1_LOSS_QTY_1
                FROM RSUMWIPMOV
                WHERE FACTORY = :RSUMWIPMOV_N.FACTORY
                    AND ORDER_ID = :RSUMWIPMOV_N.ORDER_ID
					AND OPER = :RSUMWIPMOV_N.OPER
				GROUP BY ORDER_ID;
			break;

		case 3:
				EXEC SQL SELECT 
                    ORDER_ID,
                    SUM(S1_OPER_IN_QTY_1 + S2_OPER_IN_QTY_1) IN_QTY,
					SUM(S1_END_QTY_1 + S2_END_QTY_1)          OUT_QTY,
					SUM(S1_LOSS_QTY_1 + S2_LOSS_QTY_1)			LOSS_QTY  
                INTO 
                    :RSUMWIPMOV_N.ORDER_ID,
                    :RSUMWIPMOV_N.S1_OPER_IN_QTY_1,
					:RSUMWIPMOV_N.S1_END_QTY_1,
					:RSUMWIPMOV_N.S1_LOSS_QTY_1
                FROM RSUMWIPMOV
                WHERE FACTORY = :RSUMWIPMOV_N.FACTORY
                    AND ORDER_ID = :RSUMWIPMOV_N.ORDER_ID
					AND CM_KEY_3 =  :RSUMWIPMOV_N.CM_KEY_3
				GROUP BY ORDER_ID;
            break;
		case 4:
			EXEC SQL SELECT 
                   ORDER_ID,
                   SUM(S1_OPER_IN_QTY_1 + S2_OPER_IN_QTY_1) IN_QTY,
					SUM(S1_END_QTY_1 + S2_END_QTY_1)          OUT_QTY,
					SUM(S1_LOSS_QTY_1 + S2_LOSS_QTY_1)			LOSS_QTY  
				INTO 
                    :RSUMWIPMOV_N.ORDER_ID,
                    :RSUMWIPMOV_N.S1_OPER_IN_QTY_1,
					:RSUMWIPMOV_N.S1_END_QTY_1,
					:RSUMWIPMOV_N.S1_LOSS_QTY_1
                FROM RSUMWIPMOV
                WHERE FACTORY = :RSUMWIPMOV_N.FACTORY
                    AND ORDER_ID = :RSUMWIPMOV_N.ORDER_ID
					AND OPER = :RSUMWIPMOV_N.OPER
					AND CM_KEY_3 =  :RSUMWIPMOV_N.CM_KEY_3
				GROUP BY ORDER_ID;
			break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_rsumwipmov(&RSUMWIPMOV_N, RSUMWIPMOV);
    }

    DB_stop_query_timer("CDB_select_rsumwipmov", sel_type);
}


