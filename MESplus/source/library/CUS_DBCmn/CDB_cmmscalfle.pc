/* Add Null Function */
void CDB_add_null_cmmscalfle(struct CMMSCALFLE_N_TAG *CMMSCALFLE_N, struct CMMSCALFLE_TAG *CMMSCALFLE)
{
    /* memset by NULL */
    memset(CMMSCALFLE_N, '\0', sizeof(struct CMMSCALFLE_N_TAG));
    
    MEMCPY_AN(CMMSCALFLE_N->FACTORY, CMMSCALFLE->FACTORY, sizeof(CMMSCALFLE->FACTORY));
    MEMCPY_AN(CMMSCALFLE_N->CALI_ID, CMMSCALFLE->CALI_ID, sizeof(CMMSCALFLE->CALI_ID));
    CMMSCALFLE_N->FILE_ORDER = CMMSCALFLE->FILE_ORDER;
    MEMCPY_AN(CMMSCALFLE_N->FILE_NAME, CMMSCALFLE->FILE_NAME, sizeof(CMMSCALFLE->FILE_NAME));
    MEMCPY_AN(CMMSCALFLE_N->FILE_PATH, CMMSCALFLE->FILE_PATH, sizeof(CMMSCALFLE->FILE_PATH));
    MEMCPY_AN(CMMSCALFLE_N->FILE_DESC, CMMSCALFLE->FILE_DESC, sizeof(CMMSCALFLE->FILE_DESC));
    MEMCPY_AN(CMMSCALFLE_N->CREATE_USER_ID, CMMSCALFLE->CREATE_USER_ID, sizeof(CMMSCALFLE->CREATE_USER_ID));
    MEMCPY_AN(CMMSCALFLE_N->CREATE_TIME, CMMSCALFLE->CREATE_TIME, sizeof(CMMSCALFLE->CREATE_TIME));
    MEMCPY_AN(CMMSCALFLE_N->UPDATE_USER_ID, CMMSCALFLE->UPDATE_USER_ID, sizeof(CMMSCALFLE->UPDATE_USER_ID));
    MEMCPY_AN(CMMSCALFLE_N->UPDATE_TIME, CMMSCALFLE->UPDATE_TIME, sizeof(CMMSCALFLE->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_cmmscalfle(struct CMMSCALFLE_N_TAG *CMMSCALFLE_N, struct CMMSCALFLE_TAG *CMMSCALFLE)
{
    MEMCPY_DN(CMMSCALFLE->FACTORY, CMMSCALFLE_N->FACTORY, sizeof(CMMSCALFLE->FACTORY));
    MEMCPY_DN(CMMSCALFLE->CALI_ID, CMMSCALFLE_N->CALI_ID, sizeof(CMMSCALFLE->CALI_ID));
