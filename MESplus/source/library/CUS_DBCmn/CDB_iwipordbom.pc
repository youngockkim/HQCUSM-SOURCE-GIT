                    CMF_3 = :IWIPORDBOM_N.CMF_3,
                    CMF_4 = :IWIPORDBOM_N.CMF_4,
                    CMF_5 = :IWIPORDBOM_N.CMF_5,
                    DATA_FLAG = :IWIPORDBOM_N.DATA_FLAG,
                    UPDATE_COUNT = :IWIPORDBOM_N.UPDATE_COUNT,
                    INSERT_COUNT = :IWIPORDBOM_N.INSERT_COUNT,
                    DELETE_COUNT = :IWIPORDBOM_N.DELETE_COUNT,
                    SQL_DML_COUNT = :IWIPORDBOM_N.SQL_DML_COUNT,
                    ZPICODE = :IWIPORDBOM_N.ZPICODE,
                    ZPIMSGID = :IWIPORDBOM_N.ZPIMSGID,
                    RETURN_TYPE = :IWIPORDBOM_N.RETURN_TYPE,
                    RETURN_MSG = :IWIPORDBOM_N.RETURN_MSG,
                    ZIFERNAM = :IWIPORDBOM_N.ZIFERNAM,
                    ZIFDATE = :IWIPORDBOM_N.ZIFDATE,
                    ZIFTIME = :IWIPORDBOM_N.ZIFTIME,
                    ZPISTAT = :IWIPORDBOM_N.ZPISTAT,
                    ZPIMSG = :IWIPORDBOM_N.ZPIMSG
                WHERE DOC_ID = :IWIPORDBOM_N.DOC_ID
                    AND SITE_ID = :IWIPORDBOM_N.SITE_ID
                    AND PROD_ORDER_NO = :IWIPORDBOM_N.PROD_ORDER_NO
                    AND RS_NUM = :IWIPORDBOM_N.RS_NUM
                    AND RS_POS = :IWIPORDBOM_N.RS_POS;
            break;

		 case 2:
            EXEC SQL UPDATE IWIPORDBOM SET
                    INF_PROC_TIME = :IWIPORDBOM_N.INF_PROC_TIME,
                    RETURN_TYPE = 'E',
                    RETURN_MSG = :IWIPORDBOM_N.RETURN_MSG
                WHERE DOC_ID = :IWIPORDBOM_N.DOC_ID
                    AND SITE_ID = :IWIPORDBOM_N.SITE_ID
                    AND PROD_ORDER_NO = :IWIPORDBOM_N.PROD_ORDER_NO
                    AND RS_NUM = :IWIPORDBOM_N.RS_NUM
                    AND RS_POS = :IWIPORDBOM_N.RS_POS;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_iwipordbom", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_iwipordbom(int sel_type, struct IWIPORDBOM_TAG *IWIPORDBOM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IWIPORDBOM_N_TAG IWIPORDBOM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_iwipordbom(&IWIPORDBOM_N, IWIPORDBOM);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IWIPORDBOM_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_ORDER_NO,
                    RS_NUM,
                    RS_POS,
                    BOM_PJT_NO,
                    BOM_PJT_CATE,
                    MATE_NO,
                    MATE_TYPE,
                    MATE_NO_DESC,
                    QTY,
                    UNIT_ID,
                    BATCH_NO,
                    VEN_BATCH_NO,
                    LOC_ID,
                    BACKFLUSH_YN,
                    HAND_BOOK,
                    VENDOR,
                    COMMENTS,
                    CELL_PROD_TYPE,
                    CELL_POWER_GRADE_1,
                    CELL_POWER_GRADE_2,
                    CELL_CONVERSION_RATE,
                    CELL_POWER_RATE,
                    DEL_YN,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IWIPORDBOM
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_ORDER_NO ASC,
                    RS_NUM ASC,
                    RS_POS ASC;
            EXEC SQL OPEN CDB_IWIPORDBOM_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE CDB_IWIPORDBOM_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_ORDER_NO,
                    RS_NUM,
                    RS_POS,
                    BOM_PJT_NO,
                    BOM_PJT_CATE,
                    MATE_NO,
                    MATE_TYPE,
                    MATE_NO_DESC,
                    QTY,
                    UNIT_ID,
                    BATCH_NO,
                    VEN_BATCH_NO,
                    LOC_ID,
                    BACKFLUSH_YN,
                    HAND_BOOK,
                    VENDOR,
                    COMMENTS,
                    CELL_PROD_TYPE,
                    CELL_POWER_GRADE_1,
                    CELL_POWER_GRADE_2,
                    CELL_CONVERSION_RATE,
                    CELL_POWER_RATE,
                    DEL_YN,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IWIPORDBOM
				WHERE RETURN_TYPE <> 'E'
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    PROD_ORDER_NO ASC,
                    RS_NUM ASC,
                    RS_POS ASC;
            EXEC SQL OPEN CDB_IWIPORDBOM_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_iwipordbom", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_iwipordbom(int sel_type, struct IWIPORDBOM_TAG *IWIPORDBOM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IWIPORDBOM_N_TAG IWIPORDBOM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
