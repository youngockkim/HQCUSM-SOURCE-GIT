		case 2:
            EXEC SQL FETCH CDB_IWIPORDBOM_CUR_2 INTO
                :IWIPORDBOM_N.DOC_ID,
                :IWIPORDBOM_N.SITE_ID,
                :IWIPORDBOM_N.PROD_ORDER_NO,
                :IWIPORDBOM_N.RS_NUM,
                :IWIPORDBOM_N.RS_POS,
                :IWIPORDBOM_N.BOM_PJT_NO,
                :IWIPORDBOM_N.BOM_PJT_CATE,
                :IWIPORDBOM_N.MATE_NO,
                :IWIPORDBOM_N.MATE_TYPE,
                :IWIPORDBOM_N.MATE_NO_DESC,
                :IWIPORDBOM_N.QTY,
                :IWIPORDBOM_N.UNIT_ID,
                :IWIPORDBOM_N.BATCH_NO,
                :IWIPORDBOM_N.VEN_BATCH_NO,
                :IWIPORDBOM_N.LOC_ID,
                :IWIPORDBOM_N.BACKFLUSH_YN,
                :IWIPORDBOM_N.HAND_BOOK,
                :IWIPORDBOM_N.VENDOR,
                :IWIPORDBOM_N.COMMENTS,
                :IWIPORDBOM_N.CELL_PROD_TYPE,
                :IWIPORDBOM_N.CELL_POWER_GRADE_1,
                :IWIPORDBOM_N.CELL_POWER_GRADE_2,
                :IWIPORDBOM_N.CELL_CONVERSION_RATE,
                :IWIPORDBOM_N.CELL_POWER_RATE,
                :IWIPORDBOM_N.DEL_YN,
                :IWIPORDBOM_N.INF_TIME,
                :IWIPORDBOM_N.INF_PROC_TIME,
                :IWIPORDBOM_N.CMF_1,
                :IWIPORDBOM_N.CMF_2,
                :IWIPORDBOM_N.CMF_3,
                :IWIPORDBOM_N.CMF_4,
                :IWIPORDBOM_N.CMF_5,
                :IWIPORDBOM_N.DATA_FLAG,
                :IWIPORDBOM_N.UPDATE_COUNT,
                :IWIPORDBOM_N.INSERT_COUNT,
                :IWIPORDBOM_N.DELETE_COUNT,
                :IWIPORDBOM_N.SQL_DML_COUNT,
                :IWIPORDBOM_N.ZPICODE,
                :IWIPORDBOM_N.ZPIMSGID,
                :IWIPORDBOM_N.RETURN_TYPE,
                :IWIPORDBOM_N.RETURN_MSG,
                :IWIPORDBOM_N.ZIFERNAM,
