/* SQL CURSOR CLOSE Function */
void CDB_close_iwipordbom(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IWIPORDBOM_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IWIPORDBOM_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_iwipordbom", sel_type);
}


/* Initialize Function */
void CDB_init_iwipordbom(struct IWIPORDBOM_TAG *IWIPORDBOM)
{
    /* memset by Space */
    memset(IWIPORDBOM, ' ', sizeof(struct IWIPORDBOM_TAG));
    
    IWIPORDBOM->QTY = 0;
}


/* Add Null Function */
void CDB_add_null_iwipordbom(struct IWIPORDBOM_N_TAG *IWIPORDBOM_N, struct IWIPORDBOM_TAG *IWIPORDBOM)
{
    /* memset by NULL */
    memset(IWIPORDBOM_N, '\0', sizeof(struct IWIPORDBOM_N_TAG));
    
    MEMCPY_AN(IWIPORDBOM_N->DOC_ID, IWIPORDBOM->DOC_ID, sizeof(IWIPORDBOM->DOC_ID));
    MEMCPY_AN(IWIPORDBOM_N->SITE_ID, IWIPORDBOM->SITE_ID, sizeof(IWIPORDBOM->SITE_ID));
    MEMCPY_AN(IWIPORDBOM_N->PROD_ORDER_NO, IWIPORDBOM->PROD_ORDER_NO, sizeof(IWIPORDBOM->PROD_ORDER_NO));
    MEMCPY_AN(IWIPORDBOM_N->RS_NUM, IWIPORDBOM->RS_NUM, sizeof(IWIPORDBOM->RS_NUM));
    MEMCPY_AN(IWIPORDBOM_N->RS_POS, IWIPORDBOM->RS_POS, sizeof(IWIPORDBOM->RS_POS));
    MEMCPY_AN(IWIPORDBOM_N->BOM_PJT_NO, IWIPORDBOM->BOM_PJT_NO, sizeof(IWIPORDBOM->BOM_PJT_NO));
    MEMCPY_AN(IWIPORDBOM_N->BOM_PJT_CATE, IWIPORDBOM->BOM_PJT_CATE, sizeof(IWIPORDBOM->BOM_PJT_CATE));
    MEMCPY_AN(IWIPORDBOM_N->MATE_NO, IWIPORDBOM->MATE_NO, sizeof(IWIPORDBOM->MATE_NO));
    MEMCPY_AN(IWIPORDBOM_N->MATE_TYPE, IWIPORDBOM->MATE_TYPE, sizeof(IWIPORDBOM->MATE_TYPE));
    MEMCPY_AN(IWIPORDBOM_N->MATE_NO_DESC, IWIPORDBOM->MATE_NO_DESC, sizeof(IWIPORDBOM->MATE_NO_DESC));
    IWIPORDBOM_N->QTY = IWIPORDBOM->QTY;
    MEMCPY_AN(IWIPORDBOM_N->UNIT_ID, IWIPORDBOM->UNIT_ID, sizeof(IWIPORDBOM->UNIT_ID));
    MEMCPY_AN(IWIPORDBOM_N->BATCH_NO, IWIPORDBOM->BATCH_NO, sizeof(IWIPORDBOM->BATCH_NO));
    MEMCPY_AN(IWIPORDBOM_N->VEN_BATCH_NO, IWIPORDBOM->VEN_BATCH_NO, sizeof(IWIPORDBOM->VEN_BATCH_NO));
    MEMCPY_AN(IWIPORDBOM_N->LOC_ID, IWIPORDBOM->LOC_ID, sizeof(IWIPORDBOM->LOC_ID));
    IWIPORDBOM_N->BACKFLUSH_YN[0] = IWIPORDBOM->BACKFLUSH_YN;
    MEMCPY_AN(IWIPORDBOM_N->HAND_BOOK, IWIPORDBOM->HAND_BOOK, sizeof(IWIPORDBOM->HAND_BOOK));
    MEMCPY_AN(IWIPORDBOM_N->VENDOR, IWIPORDBOM->VENDOR, sizeof(IWIPORDBOM->VENDOR));
    MEMCPY_AN(IWIPORDBOM_N->COMMENTS, IWIPORDBOM->COMMENTS, sizeof(IWIPORDBOM->COMMENTS));
    MEMCPY_AN(IWIPORDBOM_N->CELL_PROD_TYPE, IWIPORDBOM->CELL_PROD_TYPE, sizeof(IWIPORDBOM->CELL_PROD_TYPE));
    MEMCPY_AN(IWIPORDBOM_N->CELL_POWER_GRADE_1, IWIPORDBOM->CELL_POWER_GRADE_1, sizeof(IWIPORDBOM->CELL_POWER_GRADE_1));
    MEMCPY_AN(IWIPORDBOM_N->CELL_POWER_GRADE_2, IWIPORDBOM->CELL_POWER_GRADE_2, sizeof(IWIPORDBOM->CELL_POWER_GRADE_2));
    MEMCPY_AN(IWIPORDBOM_N->CELL_CONVERSION_RATE, IWIPORDBOM->CELL_CONVERSION_RATE, sizeof(IWIPORDBOM->CELL_CONVERSION_RATE));
    MEMCPY_AN(IWIPORDBOM_N->CELL_POWER_RATE, IWIPORDBOM->CELL_POWER_RATE, sizeof(IWIPORDBOM->CELL_POWER_RATE));
    IWIPORDBOM_N->DEL_YN[0] = IWIPORDBOM->DEL_YN;
    MEMCPY_AN(IWIPORDBOM_N->INF_TIME, IWIPORDBOM->INF_TIME, sizeof(IWIPORDBOM->INF_TIME));
    MEMCPY_AN(IWIPORDBOM_N->INF_PROC_TIME, IWIPORDBOM->INF_PROC_TIME, sizeof(IWIPORDBOM->INF_PROC_TIME));
    MEMCPY_AN(IWIPORDBOM_N->CMF_1, IWIPORDBOM->CMF_1, sizeof(IWIPORDBOM->CMF_1));
    MEMCPY_AN(IWIPORDBOM_N->CMF_2, IWIPORDBOM->CMF_2, sizeof(IWIPORDBOM->CMF_2));
    MEMCPY_AN(IWIPORDBOM_N->CMF_3, IWIPORDBOM->CMF_3, sizeof(IWIPORDBOM->CMF_3));
    MEMCPY_AN(IWIPORDBOM_N->CMF_4, IWIPORDBOM->CMF_4, sizeof(IWIPORDBOM->CMF_4));
    MEMCPY_AN(IWIPORDBOM_N->CMF_5, IWIPORDBOM->CMF_5, sizeof(IWIPORDBOM->CMF_5));
    IWIPORDBOM_N->DATA_FLAG[0] = IWIPORDBOM->DATA_FLAG;
    MEMCPY_AN(IWIPORDBOM_N->UPDATE_COUNT, IWIPORDBOM->UPDATE_COUNT, sizeof(IWIPORDBOM->UPDATE_COUNT));
    MEMCPY_AN(IWIPORDBOM_N->INSERT_COUNT, IWIPORDBOM->INSERT_COUNT, sizeof(IWIPORDBOM->INSERT_COUNT));
    MEMCPY_AN(IWIPORDBOM_N->DELETE_COUNT, IWIPORDBOM->DELETE_COUNT, sizeof(IWIPORDBOM->DELETE_COUNT));
    MEMCPY_AN(IWIPORDBOM_N->SQL_DML_COUNT, IWIPORDBOM->SQL_DML_COUNT, sizeof(IWIPORDBOM->SQL_DML_COUNT));
    MEMCPY_AN(IWIPORDBOM_N->ZPICODE, IWIPORDBOM->ZPICODE, sizeof(IWIPORDBOM->ZPICODE));
    MEMCPY_AN(IWIPORDBOM_N->ZPIMSGID, IWIPORDBOM->ZPIMSGID, sizeof(IWIPORDBOM->ZPIMSGID));
    IWIPORDBOM_N->RETURN_TYPE[0] = IWIPORDBOM->RETURN_TYPE;
    MEMCPY_AN(IWIPORDBOM_N->RETURN_MSG, IWIPORDBOM->RETURN_MSG, sizeof(IWIPORDBOM->RETURN_MSG));
    MEMCPY_AN(IWIPORDBOM_N->ZIFERNAM, IWIPORDBOM->ZIFERNAM, sizeof(IWIPORDBOM->ZIFERNAM));
    MEMCPY_AN(IWIPORDBOM_N->ZIFDATE, IWIPORDBOM->ZIFDATE, sizeof(IWIPORDBOM->ZIFDATE));
    MEMCPY_AN(IWIPORDBOM_N->ZIFTIME, IWIPORDBOM->ZIFTIME, sizeof(IWIPORDBOM->ZIFTIME));
    IWIPORDBOM_N->ZPISTAT[0] = IWIPORDBOM->ZPISTAT;
    MEMCPY_AN(IWIPORDBOM_N->ZPIMSG, IWIPORDBOM->ZPIMSG, sizeof(IWIPORDBOM->ZPIMSG));
}


/* Del Null Function */
void CDB_del_null_iwipordbom(struct IWIPORDBOM_N_TAG *IWIPORDBOM_N, struct IWIPORDBOM_TAG *IWIPORDBOM)
{
    MEMCPY_DN(IWIPORDBOM->DOC_ID, IWIPORDBOM_N->DOC_ID, sizeof(IWIPORDBOM->DOC_ID));
    MEMCPY_DN(IWIPORDBOM->SITE_ID, IWIPORDBOM_N->SITE_ID, sizeof(IWIPORDBOM->SITE_ID));
    MEMCPY_DN(IWIPORDBOM->PROD_ORDER_NO, IWIPORDBOM_N->PROD_ORDER_NO, sizeof(IWIPORDBOM->PROD_ORDER_NO));
    MEMCPY_DN(IWIPORDBOM->RS_NUM, IWIPORDBOM_N->RS_NUM, sizeof(IWIPORDBOM->RS_NUM));
    MEMCPY_DN(IWIPORDBOM->RS_POS, IWIPORDBOM_N->RS_POS, sizeof(IWIPORDBOM->RS_POS));
    MEMCPY_DN(IWIPORDBOM->BOM_PJT_NO, IWIPORDBOM_N->BOM_PJT_NO, sizeof(IWIPORDBOM->BOM_PJT_NO));
    MEMCPY_DN(IWIPORDBOM->BOM_PJT_CATE, IWIPORDBOM_N->BOM_PJT_CATE, sizeof(IWIPORDBOM->BOM_PJT_CATE));
    MEMCPY_DN(IWIPORDBOM->MATE_NO, IWIPORDBOM_N->MATE_NO, sizeof(IWIPORDBOM->MATE_NO));
    MEMCPY_DN(IWIPORDBOM->MATE_TYPE, IWIPORDBOM_N->MATE_TYPE, sizeof(IWIPORDBOM->MATE_TYPE));
    MEMCPY_DN(IWIPORDBOM->MATE_NO_DESC, IWIPORDBOM_N->MATE_NO_DESC, sizeof(IWIPORDBOM->MATE_NO_DESC));
    IWIPORDBOM->QTY = IWIPORDBOM_N->QTY;
    MEMCPY_DN(IWIPORDBOM->UNIT_ID, IWIPORDBOM_N->UNIT_ID, sizeof(IWIPORDBOM->UNIT_ID));
    MEMCPY_DN(IWIPORDBOM->BATCH_NO, IWIPORDBOM_N->BATCH_NO, sizeof(IWIPORDBOM->BATCH_NO));
    MEMCPY_DN(IWIPORDBOM->VEN_BATCH_NO, IWIPORDBOM_N->VEN_BATCH_NO, sizeof(IWIPORDBOM->VEN_BATCH_NO));
    MEMCPY_DN(IWIPORDBOM->LOC_ID, IWIPORDBOM_N->LOC_ID, sizeof(IWIPORDBOM->LOC_ID));
    IWIPORDBOM->BACKFLUSH_YN = IWIPORDBOM_N->BACKFLUSH_YN[0];
    MEMCPY_DN(IWIPORDBOM->HAND_BOOK, IWIPORDBOM_N->HAND_BOOK, sizeof(IWIPORDBOM->HAND_BOOK));
    MEMCPY_DN(IWIPORDBOM->VENDOR, IWIPORDBOM_N->VENDOR, sizeof(IWIPORDBOM->VENDOR));
    MEMCPY_DN(IWIPORDBOM->COMMENTS, IWIPORDBOM_N->COMMENTS, sizeof(IWIPORDBOM->COMMENTS));
    MEMCPY_DN(IWIPORDBOM->CELL_PROD_TYPE, IWIPORDBOM_N->CELL_PROD_TYPE, sizeof(IWIPORDBOM->CELL_PROD_TYPE));
    MEMCPY_DN(IWIPORDBOM->CELL_POWER_GRADE_1, IWIPORDBOM_N->CELL_POWER_GRADE_1, sizeof(IWIPORDBOM->CELL_POWER_GRADE_1));
    MEMCPY_DN(IWIPORDBOM->CELL_POWER_GRADE_2, IWIPORDBOM_N->CELL_POWER_GRADE_2, sizeof(IWIPORDBOM->CELL_POWER_GRADE_2));
    MEMCPY_DN(IWIPORDBOM->CELL_CONVERSION_RATE, IWIPORDBOM_N->CELL_CONVERSION_RATE, sizeof(IWIPORDBOM->CELL_CONVERSION_RATE));
