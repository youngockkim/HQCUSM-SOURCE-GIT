/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cmmscalpln(int sel_type, struct CMMSCALPLN_TAG *CMMSCALPLN)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMMSCALPLN_N_TAG CMMSCALPLN_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cmmscalpln(&CMMSCALPLN_N, CMMSCALPLN);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CMMSCALPLN_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    EQUIP_ID,
                    PLAN_DATE,
                    CALI_DATE,
                    CALI_INSTITUTE,
                    CALI_METHOD,
                    CALI_RESULT,
                    CALI_COST,
                    CALI_STATUS,
                    FILE_NAME,
                    FILE_PATH,
                    ALARM_FLAG,
                    ALARM_CODE,
                    ALARM_PERIOD,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSCALPLN
                ORDER BY FACTORY ASC,
                    EQUIP_ID ASC;
            EXEC SQL OPEN CDB_CMMSCALPLN_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CMMSCALPLN_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    EQUIP_ID,
                    PLAN_DATE,
                    CALI_DATE,
                    CALI_INSTITUTE,
                    CALI_METHOD,
                    CALI_RESULT,
                    CALI_COST,
                    CALI_STATUS,
                    FILE_NAME,
                    FILE_PATH,
                    ALARM_FLAG,
                    ALARM_CODE,
                    ALARM_PERIOD,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSCALPLN
			   WHERE FACTORY = :CMMSCALPLN_N.FACTORY
				 AND EQUIP_ID LIKE '%' || TRIM(:CMMSCALPLN_N.EQUIP_ID) || '%'
				 AND PLAN_DATE >= :CMMSCALPLN_N.PLAN_DATE
				 AND PLAN_DATE <= :CMMSCALPLN_N.CALI_DATE 
				 AND EQUIP_ID IN (SELECT EQUIP_ID 
				                    FROM CMMSEQPDEF 
								   WHERE FACTORY = :CMMSCALPLN_N.FACTORY 
								     AND EQUIP_TYPE LIKE '%' || TRIM(:CMMSCALPLN_N.CMF_1) || '%'
									 AND MGT_DEPT_CODE LIKE '%' || TRIM(:CMMSCALPLN_N.CMF_2) || '%'
									 AND USE_DEPT_CODE LIKE '%' || TRIM(:CMMSCALPLN_N.CMF_3) || '%'
									 AND CALI_FLAG = 'Y' AND USE_DIV = '0')				 
                ORDER BY FACTORY ASC,
                    EQUIP_ID ASC;
            EXEC SQL OPEN CDB_CMMSCALPLN_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_CMMSCALPLN_CUR_3 CURSOR FOR
                SELECT 
                   FACTORY,
                    EQUIP_ID,
                    PLAN_DATE,
                    CALI_DATE,
                    CALI_INSTITUTE,
                    CALI_METHOD,
                    ALARM_FLAG,
                    ALARM_CODE,
                    ALARM_PERIOD,
                    TO_CHAR(TO_DATE(PLAN_DATE,'YYYYMMDD'), 'FMMM/DD/YYYY') AS CMF_1
                FROM CMMSCALPLN
				WHERE FACTORY = :CMMSCALPLN_N.FACTORY
				  AND ALARM_FLAG = 'Y'
				  AND PLAN_DATE = TO_CHAR((SYSDATE + ALARM_PERIOD), 'YYYYMMDD')				  
                ORDER BY FACTORY ASC,
				    ALARM_CODE ASC,
					PLAN_DATE ASC,
                    EQUIP_ID ASC;
            EXEC SQL OPEN CDB_CMMSCALPLN_CUR_3;
            break;

		case 4:
            EXEC SQL DECLARE CDB_CMMSCALPLN_CUR_4 CURSOR FOR
                SELECT 
                    FACTORY,
                    EQUIP_ID,
                    PLAN_DATE,
                    CALI_DATE,
                    CALI_INSTITUTE,
                    CALI_METHOD,
                    ALARM_FLAG,
                    ALARM_CODE,
                    ALARM_PERIOD,
                    TO_CHAR(TO_DATE(PLAN_DATE,'YYYYMMDD'), 'FMMM/DD/YYYY') AS CMF_1
                FROM CMMSCALPLN
				WHERE FACTORY = :CMMSCALPLN_N.FACTORY
				  AND PLAN_DATE BETWEEN TO_CHAR((SYSDATE + :CMMSCALPLN_N.ALARM_PERIOD), 'YYYYMMDD') AND TO_CHAR(SYSDATE, 'YYYYMMDD')
                ORDER BY FACTORY ASC,
				    ALARM_CODE ASC,
					PLAN_DATE ASC,
                    EQUIP_ID ASC;
            EXEC SQL OPEN CDB_CMMSCALPLN_CUR_4;
            break;

		case 5:
            EXEC SQL DECLARE CDB_CMMSCALPLN_CUR_5 CURSOR FOR
                SELECT 
                    FACTORY,
                    EQUIP_ID,
                    PLAN_DATE,
                    CALI_DATE,
                    CALI_INSTITUTE,
                    CALI_METHOD,
                    ALARM_FLAG,
                    ALARM_CODE,
                    ALARM_PERIOD,
                    TO_CHAR(TO_DATE(PLAN_DATE,'YYYYMMDD'), 'FMMM/DD/YYYY') AS CMF_1
                FROM CMMSCALPLN
				WHERE FACTORY = :CMMSCALPLN_N.FACTORY
				  AND PLAN_DATE = TO_CHAR((SYSDATE + :CMMSCALPLN_N.ALARM_PERIOD), 'YYYYMMDD')
                ORDER BY FACTORY ASC,
				    ALARM_CODE ASC,
					PLAN_DATE ASC,
                    EQUIP_ID ASC;
            EXEC SQL OPEN CDB_CMMSCALPLN_CUR_5;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cmmscalpln", sel_type);
}


