            EXEC SQL FETCH CDB_CMMSCALPLN_CUR_3 INTO
                :CMMSCALPLN_N.FACTORY,
                :CMMSCALPLN_N.EQUIP_ID,
                :CMMSCALPLN_N.PLAN_DATE,
                :CMMSCALPLN_N.CALI_DATE,
                :CMMSCALPLN_N.CALI_INSTITUTE,
                :CMMSCALPLN_N.CALI_METHOD,
                :CMMSCALPLN_N.ALARM_FLAG,
                :CMMSCALPLN_N.ALARM_CODE,
                :CMMSCALPLN_N.ALARM_PERIOD,
                :CMMSCALPLN_N.CMF_1;
            break;

		case 4:
            EXEC SQL FETCH CDB_CMMSCALPLN_CUR_4 INTO
                :CMMSCALPLN_N.FACTORY,
                :CMMSCALPLN_N.EQUIP_ID,
                :CMMSCALPLN_N.PLAN_DATE,
                :CMMSCALPLN_N.CALI_DATE,
                :CMMSCALPLN_N.CALI_INSTITUTE,
                :CMMSCALPLN_N.CALI_METHOD,
                :CMMSCALPLN_N.ALARM_FLAG,
                :CMMSCALPLN_N.ALARM_CODE,
                :CMMSCALPLN_N.ALARM_PERIOD,
                :CMMSCALPLN_N.CMF_1;
            break;

		case 5:
            EXEC SQL FETCH CDB_CMMSCALPLN_CUR_5 INTO
                :CMMSCALPLN_N.FACTORY,
                :CMMSCALPLN_N.EQUIP_ID,
                :CMMSCALPLN_N.PLAN_DATE,
                :CMMSCALPLN_N.CALI_DATE,
                :CMMSCALPLN_N.CALI_INSTITUTE,
                :CMMSCALPLN_N.CALI_METHOD,
                :CMMSCALPLN_N.ALARM_FLAG,
                :CMMSCALPLN_N.ALARM_CODE,
                :CMMSCALPLN_N.ALARM_PERIOD,
                :CMMSCALPLN_N.CMF_1;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cmmscalpln(&CMMSCALPLN_N, CMMSCALPLN);
    }

    DB_stop_query_timer("CDB_fetch_cmmscalpln", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cmmscalpln(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CMMSCALPLN_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CMMSCALPLN_CUR_2;
            break;

		case 3:
            EXEC SQL CLOSE CDB_CMMSCALPLN_CUR_3;
            break;

		case 4:
            EXEC SQL CLOSE CDB_CMMSCALPLN_CUR_4;
            break;

		case 5:
            EXEC SQL CLOSE CDB_CMMSCALPLN_CUR_5;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cmmscalpln", sel_type);
}


/* Initialize Function */
void CDB_init_cmmscalpln(struct CMMSCALPLN_TAG *CMMSCALPLN)
{
    /* memset by Space */
    memset(CMMSCALPLN, ' ', sizeof(struct CMMSCALPLN_TAG));
    
    CMMSCALPLN->CALI_COST = 0;
    CMMSCALPLN->ALARM_PERIOD = 0;
}


/* Add Null Function */
void CDB_add_null_cmmscalpln(struct CMMSCALPLN_N_TAG *CMMSCALPLN_N, struct CMMSCALPLN_TAG *CMMSCALPLN)
{
