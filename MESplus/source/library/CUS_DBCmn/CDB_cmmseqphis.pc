    MEMCPY_AN(CMMSEQPHIS_N->CMF_7, CMMSEQPHIS->CMF_7, sizeof(CMMSEQPHIS->CMF_7));
    MEMCPY_AN(CMMSEQPHIS_N->CMF_8, CMMSEQPHIS->CMF_8, sizeof(CMMSEQPHIS->CMF_8));
