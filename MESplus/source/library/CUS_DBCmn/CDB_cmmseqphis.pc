    MEMCPY_AN(CMMSEQPHIS_N->UPDATE_TIME, CMMSEQPHIS->UPDATE_TIME, sizeof(CMMSEQPHIS->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_cmmseqphis(struct CMMSEQPHIS_N_TAG *CMMSEQPHIS_N, struct CMMSEQPHIS_TAG *CMMSEQPHIS)
{
    MEMCPY_DN(CMMSEQPHIS->FACTORY, CMMSEQPHIS_N->FACTORY, sizeof(CMMSEQPHIS->FACTORY));
    MEMCPY_DN(CMMSEQPHIS->EQUIP_ID, CMMSEQPHIS_N->EQUIP_ID, sizeof(CMMSEQPHIS->EQUIP_ID));
    CMMSEQPHIS->HIST_SEQ = CMMSEQPHIS_N->HIST_SEQ;
    MEMCPY_DN(CMMSEQPHIS->EQUIP_CODE, CMMSEQPHIS_N->EQUIP_CODE, sizeof(CMMSEQPHIS->EQUIP_CODE));
    MEMCPY_DN(CMMSEQPHIS->EQUIP_NAME, CMMSEQPHIS_N->EQUIP_NAME, sizeof(CMMSEQPHIS->EQUIP_NAME));
	MEMCPY_DN(CMMSEQPHIS->EQUIP_TYPE, CMMSEQPHIS_N->EQUIP_TYPE, sizeof(CMMSEQPHIS->EQUIP_TYPE));
    MEMCPY_DN(CMMSEQPHIS->EQUIP_NO, CMMSEQPHIS_N->EQUIP_NO, sizeof(CMMSEQPHIS->EQUIP_NO));
    MEMCPY_DN(CMMSEQPHIS->MGT_DEPT_CODE, CMMSEQPHIS_N->MGT_DEPT_CODE, sizeof(CMMSEQPHIS->MGT_DEPT_CODE));
    MEMCPY_DN(CMMSEQPHIS->MGT_USER_ID, CMMSEQPHIS_N->MGT_USER_ID, sizeof(CMMSEQPHIS->MGT_USER_ID));
    MEMCPY_DN(CMMSEQPHIS->USE_DEPT_CODE, CMMSEQPHIS_N->USE_DEPT_CODE, sizeof(CMMSEQPHIS->USE_DEPT_CODE));
    MEMCPY_DN(CMMSEQPHIS->USE_USER_ID, CMMSEQPHIS_N->USE_USER_ID, sizeof(CMMSEQPHIS->USE_USER_ID));
