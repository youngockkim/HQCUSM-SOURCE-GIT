                SELECT 
                    FACTORY,
                    EQUIP_ID,
                    HIST_SEQ,
                    EQUIP_CODE,
                    EQUIP_NAME,
					EQUIP_TYPE,
                    EQUIP_NO,
                    MGT_DEPT_CODE,
                    MGT_USER_ID,
                    USE_DEPT_CODE,
                    USE_USER_ID,
                    USE_DIV,
                    CALI_DIV,
                    PARTNER_CODE,
                    PROP_NO,
                    SUPPLY_CODE,
                    EQUIP_MAKER,
                    EQUIP_MODEL,
                    EQUIP_PURPOSE,
                    EQUIP_FEATURE,
                    EQUIP_PLACE_CODE,
                    SERIAL_NO,
                    EQUIP_SPEC,
                    BUY_DATE,
                    BUY_COST,
                    CALI_CYCLE,
                    MSA_CYCLE,
                    EQUIP_DESC,
                    LAST_EQUIP_SEQ,
                    APPROVE_USER_ID,
                    APPROVE_FLAG,
                    MSA_FLAG,
                    SPC_FLAG,
                    CALI_FLAG,
                    CHECK_FLAG,
                    NONE_FLAG,
                    STANDARD_FLAG,
                    CMF_FLAG_01,
                    CMF_FLAG_02,
                    CMF_FLAG_03,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSEQPHIS
                ORDER BY FACTORY ASC,
                    EQUIP_ID ASC,
                    HIST_SEQ ASC;
            EXEC SQL OPEN CDB_CMMSEQPHIS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cmmseqphis", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_cmmseqphis(int sel_type, struct CMMSEQPHIS_TAG *CMMSEQPHIS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMMSEQPHIS_N_TAG CMMSEQPHIS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CMMSEQPHIS_CUR_1 INTO
                :CMMSEQPHIS_N.FACTORY,
                :CMMSEQPHIS_N.EQUIP_ID,
                :CMMSEQPHIS_N.HIST_SEQ,
                :CMMSEQPHIS_N.EQUIP_CODE,
                :CMMSEQPHIS_N.EQUIP_NAME,
				:CMMSEQPHIS_N.EQUIP_TYPE,
                :CMMSEQPHIS_N.EQUIP_NO,
                :CMMSEQPHIS_N.MGT_DEPT_CODE,
                :CMMSEQPHIS_N.MGT_USER_ID,
                :CMMSEQPHIS_N.USE_DEPT_CODE,
                :CMMSEQPHIS_N.USE_USER_ID,
                :CMMSEQPHIS_N.USE_DIV,
                :CMMSEQPHIS_N.CALI_DIV,
                :CMMSEQPHIS_N.PARTNER_CODE,
                :CMMSEQPHIS_N.PROP_NO,
                :CMMSEQPHIS_N.SUPPLY_CODE,
                :CMMSEQPHIS_N.EQUIP_MAKER,
                :CMMSEQPHIS_N.EQUIP_MODEL,
                :CMMSEQPHIS_N.EQUIP_PURPOSE,
                :CMMSEQPHIS_N.EQUIP_FEATURE,
                :CMMSEQPHIS_N.EQUIP_PLACE_CODE,
                :CMMSEQPHIS_N.SERIAL_NO,
                :CMMSEQPHIS_N.EQUIP_SPEC,
                :CMMSEQPHIS_N.BUY_DATE,
                :CMMSEQPHIS_N.BUY_COST,
                :CMMSEQPHIS_N.CALI_CYCLE,
                :CMMSEQPHIS_N.MSA_CYCLE,
                :CMMSEQPHIS_N.EQUIP_DESC,
                :CMMSEQPHIS_N.LAST_EQUIP_SEQ,
                :CMMSEQPHIS_N.APPROVE_USER_ID,
                :CMMSEQPHIS_N.APPROVE_FLAG,
                :CMMSEQPHIS_N.MSA_FLAG,
                :CMMSEQPHIS_N.SPC_FLAG,
                :CMMSEQPHIS_N.CALI_FLAG,
                :CMMSEQPHIS_N.CHECK_FLAG,
                :CMMSEQPHIS_N.NONE_FLAG,
                :CMMSEQPHIS_N.STANDARD_FLAG,
                :CMMSEQPHIS_N.CMF_FLAG_01,
                :CMMSEQPHIS_N.CMF_FLAG_02,
                :CMMSEQPHIS_N.CMF_FLAG_03,
                :CMMSEQPHIS_N.CMF_1,
                :CMMSEQPHIS_N.CMF_2,
                :CMMSEQPHIS_N.CMF_3,
                :CMMSEQPHIS_N.CMF_4,
                :CMMSEQPHIS_N.CMF_5,
                :CMMSEQPHIS_N.CMF_6,
                :CMMSEQPHIS_N.CMF_7,
                :CMMSEQPHIS_N.CMF_8,
                :CMMSEQPHIS_N.CMF_9,
                :CMMSEQPHIS_N.CMF_10,
                :CMMSEQPHIS_N.CREATE_USER_ID,
                :CMMSEQPHIS_N.CREATE_TIME,
                :CMMSEQPHIS_N.UPDATE_USER_ID,
                :CMMSEQPHIS_N.UPDATE_TIME;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cmmseqphis(&CMMSEQPHIS_N, CMMSEQPHIS);
    }

    DB_stop_query_timer("CDB_fetch_cmmseqphis", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cmmseqphis(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CMMSEQPHIS_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cmmseqphis", sel_type);
}


/* Initialize Function */
void CDB_init_cmmseqphis(struct CMMSEQPHIS_TAG *CMMSEQPHIS)
{
    /* memset by Space */
    memset(CMMSEQPHIS, ' ', sizeof(struct CMMSEQPHIS_TAG));
    
    CMMSEQPHIS->HIST_SEQ = 0;
    CMMSEQPHIS->BUY_COST = 0;
    CMMSEQPHIS->CALI_CYCLE = 0;
    CMMSEQPHIS->MSA_CYCLE = 0;
    CMMSEQPHIS->LAST_EQUIP_SEQ = 0;
}


/* Add Null Function */
void CDB_add_null_cmmseqphis(struct CMMSEQPHIS_N_TAG *CMMSEQPHIS_N, struct CMMSEQPHIS_TAG *CMMSEQPHIS)
{
    /* memset by NULL */
    memset(CMMSEQPHIS_N, '\0', sizeof(struct CMMSEQPHIS_N_TAG));
    
    MEMCPY_AN(CMMSEQPHIS_N->FACTORY, CMMSEQPHIS->FACTORY, sizeof(CMMSEQPHIS->FACTORY));
    MEMCPY_AN(CMMSEQPHIS_N->EQUIP_ID, CMMSEQPHIS->EQUIP_ID, sizeof(CMMSEQPHIS->EQUIP_ID));
    CMMSEQPHIS_N->HIST_SEQ = CMMSEQPHIS->HIST_SEQ;
    MEMCPY_AN(CMMSEQPHIS_N->EQUIP_CODE, CMMSEQPHIS->EQUIP_CODE, sizeof(CMMSEQPHIS->EQUIP_CODE));
    MEMCPY_AN(CMMSEQPHIS_N->EQUIP_NAME, CMMSEQPHIS->EQUIP_NAME, sizeof(CMMSEQPHIS->EQUIP_NAME));
	MEMCPY_AN(CMMSEQPHIS_N->EQUIP_TYPE, CMMSEQPHIS->EQUIP_TYPE, sizeof(CMMSEQPHIS->EQUIP_TYPE));
    MEMCPY_AN(CMMSEQPHIS_N->EQUIP_NO, CMMSEQPHIS->EQUIP_NO, sizeof(CMMSEQPHIS->EQUIP_NO));
    MEMCPY_AN(CMMSEQPHIS_N->MGT_DEPT_CODE, CMMSEQPHIS->MGT_DEPT_CODE, sizeof(CMMSEQPHIS->MGT_DEPT_CODE));
