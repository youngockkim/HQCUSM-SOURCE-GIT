    MEMCPY_AN(CWIPWRKDAY_N->CMF_1, CWIPWRKDAY->CMF_1, sizeof(CWIPWRKDAY->CMF_1));
    MEMCPY_AN(CWIPWRKDAY_N->CMF_2, CWIPWRKDAY->CMF_2, sizeof(CWIPWRKDAY->CMF_2));
