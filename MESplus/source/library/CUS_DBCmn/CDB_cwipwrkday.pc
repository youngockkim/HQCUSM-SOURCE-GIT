            EXEC SQL FETCH CDB_CWIPWRKDAY_CUR_100 INTO
                :CWIPWRKDAY_N.FACTORY,
                :CWIPWRKDAY_N.LINE_ID,
                :CWIPWRKDAY_N.RES_ID,
                :CWIPWRKDAY_N.START_TIME,
                :CWIPWRKDAY_N.SEQ_NUM,
                :CWIPWRKDAY_N.END_TIME,
                :CWIPWRKDAY_N.STATE_TIME,
                :CWIPWRKDAY_N.LOSS_QTY,
                :CWIPWRKDAY_N.DEFECT_QTY,
                :CWIPWRKDAY_N.EQ_STATUS_CODE,
                :CWIPWRKDAY_N.EQ_STATUS_FLAG,
                :CWIPWRKDAY_N.EQ_TROUBLE_CODE,
                :CWIPWRKDAY_N.OPER,
                :CWIPWRKDAY_N.WORK_DATE,
                :CWIPWRKDAY_N.WORK_SHIFT,
                :CWIPWRKDAY_N.RES_GROUP,
                :CWIPWRKDAY_N.RES_CONFIGURE,
                :CWIPWRKDAY_N.DETAIL_CATEGORY,
                :CWIPWRKDAY_N.CHARGE_USER_ID,
                :CWIPWRKDAY_N.TROUBLE_STATUS,
                :CWIPWRKDAY_N.CAUSE_ANALYSIS,
                :CWIPWRKDAY_N.CORRECTIVE_MEASURE,
                :CWIPWRKDAY_N.CREATE_USER_ID,
                :CWIPWRKDAY_N.CREATE_TIME,
                :CWIPWRKDAY_N.UPDATE_USER_ID,
                :CWIPWRKDAY_N.UPDATE_TIME,
                :CWIPWRKDAY_N.CMF_1,
                :CWIPWRKDAY_N.CMF_2,
                :CWIPWRKDAY_N.CMF_3,
                :CWIPWRKDAY_N.CMF_4,
                :CWIPWRKDAY_N.CMF_5,
                :CWIPWRKDAY_N.CMF_6,
                :CWIPWRKDAY_N.CMF_7,
                :CWIPWRKDAY_N.CMF_8,
                :CWIPWRKDAY_N.CMF_9,
                :CWIPWRKDAY_N.CMF_10;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cwipwrkday(&CWIPWRKDAY_N, CWIPWRKDAY);
    }

    DB_stop_query_timer("CDB_fetch_cwipwrkday", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cwipwrkday(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CWIPWRKDAY_CUR_1;
            break;

		case 100:
            EXEC SQL CLOSE CDB_CWIPWRKDAY_CUR_100;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwipwrkday", sel_type);
}


/* Initialize Function */
void CDB_init_cwipwrkday(struct CWIPWRKDAY_TAG *CWIPWRKDAY)
{
    /* memset by Space */
    memset(CWIPWRKDAY, ' ', sizeof(struct CWIPWRKDAY_TAG));
    
    CWIPWRKDAY->SEQ_NUM = 0;
    CWIPWRKDAY->STATE_TIME = 0;
    CWIPWRKDAY->LOSS_QTY = 0;
    CWIPWRKDAY->DEFECT_QTY = 0;
}


/* Add Null Function */
void CDB_add_null_cwipwrkday(struct CWIPWRKDAY_N_TAG *CWIPWRKDAY_N, struct CWIPWRKDAY_TAG *CWIPWRKDAY)
{
    /* memset by NULL */
    memset(CWIPWRKDAY_N, '\0', sizeof(struct CWIPWRKDAY_N_TAG));
    
    MEMCPY_AN(CWIPWRKDAY_N->FACTORY, CWIPWRKDAY->FACTORY, sizeof(CWIPWRKDAY->FACTORY));
    MEMCPY_AN(CWIPWRKDAY_N->LINE_ID, CWIPWRKDAY->LINE_ID, sizeof(CWIPWRKDAY->LINE_ID));
