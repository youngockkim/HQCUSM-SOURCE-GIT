/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_ibascstdef(int sel_type, struct IBASCSTDEF_TAG *IBASCSTDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IBASCSTDEF_N_TAG IBASCSTDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ibascstdef(&IBASCSTDEF_N, IBASCSTDEF);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IBASCSTDEF_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    COST_CENTER,
                    CTRL_AREA,
                    VLD_FR_DATE,
                    VLD_TO_DATE,
                    DESCRIPTION,
                    COMPANY,
                    CURRENCY,
                    DEL_YN,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IBASCSTDEF
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    COST_CENTER ASC,
                    CTRL_AREA ASC,
                    VLD_FR_DATE ASC,
                    VLD_TO_DATE ASC;
            EXEC SQL OPEN CDB_IBASCSTDEF_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_IBASCSTDEF_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    COST_CENTER,
                    CTRL_AREA,
                    VLD_FR_DATE,
                    VLD_TO_DATE,
                    DESCRIPTION,
                    COMPANY,
                    CURRENCY,
                    DEL_YN,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IBASCSTDEF
				WHERE RETURN_TYPE <> 'E'
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    COST_CENTER ASC,
                    CTRL_AREA ASC,
                    VLD_FR_DATE ASC,
                    VLD_TO_DATE ASC;
            EXEC SQL OPEN CDB_IBASCSTDEF_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_ibascstdef", sel_type);
}


