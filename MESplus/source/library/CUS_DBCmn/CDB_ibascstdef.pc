            EXEC SQL FETCH CDB_IBASCSTDEF_CUR_2 INTO
                :IBASCSTDEF_N.DOC_ID,
                :IBASCSTDEF_N.SITE_ID,
                :IBASCSTDEF_N.COST_CENTER,
                :IBASCSTDEF_N.CTRL_AREA,
                :IBASCSTDEF_N.VLD_FR_DATE,
                :IBASCSTDEF_N.VLD_TO_DATE,
                :IBASCSTDEF_N.DESCRIPTION,
                :IBASCSTDEF_N.COMPANY,
                :IBASCSTDEF_N.CURRENCY,
                :IBASCSTDEF_N.DEL_YN,
                :IBASCSTDEF_N.INF_TIME,
                :IBASCSTDEF_N.INF_PROC_TIME,
                :IBASCSTDEF_N.CMF_1,
                :IBASCSTDEF_N.CMF_2,
                :IBASCSTDEF_N.CMF_3,
                :IBASCSTDEF_N.CMF_4,
                :IBASCSTDEF_N.CMF_5,
                :IBASCSTDEF_N.DATA_FLAG,
                :IBASCSTDEF_N.UPDATE_COUNT,
                :IBASCSTDEF_N.INSERT_COUNT,
                :IBASCSTDEF_N.DELETE_COUNT,
                :IBASCSTDEF_N.SQL_DML_COUNT,
                :IBASCSTDEF_N.ZPICODE,
                :IBASCSTDEF_N.ZPIMSGID,
                :IBASCSTDEF_N.RETURN_TYPE,
                :IBASCSTDEF_N.RETURN_MSG,
                :IBASCSTDEF_N.ZIFERNAM,
                :IBASCSTDEF_N.ZIFDATE,
                :IBASCSTDEF_N.ZIFTIME,
                :IBASCSTDEF_N.ZPISTAT,
                :IBASCSTDEF_N.ZPIMSG;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_ibascstdef(&IBASCSTDEF_N, IBASCSTDEF);
    }

    DB_stop_query_timer("CDB_fetch_ibascstdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_ibascstdef(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IBASCSTDEF_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IBASCSTDEF_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ibascstdef", sel_type);
}


/* Initialize Function */
void CDB_init_ibascstdef(struct IBASCSTDEF_TAG *IBASCSTDEF)
{
    /* memset by Space */
    memset(IBASCSTDEF, ' ', sizeof(struct IBASCSTDEF_TAG));
    
}


/* Add Null Function */
void CDB_add_null_ibascstdef(struct IBASCSTDEF_N_TAG *IBASCSTDEF_N, struct IBASCSTDEF_TAG *IBASCSTDEF)
{
    /* memset by NULL */
    memset(IBASCSTDEF_N, '\0', sizeof(struct IBASCSTDEF_N_TAG));
    
    MEMCPY_AN(IBASCSTDEF_N->DOC_ID, IBASCSTDEF->DOC_ID, sizeof(IBASCSTDEF->DOC_ID));
    MEMCPY_AN(IBASCSTDEF_N->SITE_ID, IBASCSTDEF->SITE_ID, sizeof(IBASCSTDEF->SITE_ID));
    MEMCPY_AN(IBASCSTDEF_N->COST_CENTER, IBASCSTDEF->COST_CENTER, sizeof(IBASCSTDEF->COST_CENTER));
    MEMCPY_AN(IBASCSTDEF_N->CTRL_AREA, IBASCSTDEF->CTRL_AREA, sizeof(IBASCSTDEF->CTRL_AREA));
    MEMCPY_AN(IBASCSTDEF_N->VLD_FR_DATE, IBASCSTDEF->VLD_FR_DATE, sizeof(IBASCSTDEF->VLD_FR_DATE));
    MEMCPY_AN(IBASCSTDEF_N->VLD_TO_DATE, IBASCSTDEF->VLD_TO_DATE, sizeof(IBASCSTDEF->VLD_TO_DATE));
    MEMCPY_AN(IBASCSTDEF_N->DESCRIPTION, IBASCSTDEF->DESCRIPTION, sizeof(IBASCSTDEF->DESCRIPTION));
    MEMCPY_AN(IBASCSTDEF_N->COMPANY, IBASCSTDEF->COMPANY, sizeof(IBASCSTDEF->COMPANY));
    MEMCPY_AN(IBASCSTDEF_N->CURRENCY, IBASCSTDEF->CURRENCY, sizeof(IBASCSTDEF->CURRENCY));
    IBASCSTDEF_N->DEL_YN[0] = IBASCSTDEF->DEL_YN;
    MEMCPY_AN(IBASCSTDEF_N->INF_TIME, IBASCSTDEF->INF_TIME, sizeof(IBASCSTDEF->INF_TIME));
    MEMCPY_AN(IBASCSTDEF_N->INF_PROC_TIME, IBASCSTDEF->INF_PROC_TIME, sizeof(IBASCSTDEF->INF_PROC_TIME));
    MEMCPY_AN(IBASCSTDEF_N->CMF_1, IBASCSTDEF->CMF_1, sizeof(IBASCSTDEF->CMF_1));
    MEMCPY_AN(IBASCSTDEF_N->CMF_2, IBASCSTDEF->CMF_2, sizeof(IBASCSTDEF->CMF_2));
    MEMCPY_AN(IBASCSTDEF_N->CMF_3, IBASCSTDEF->CMF_3, sizeof(IBASCSTDEF->CMF_3));
    MEMCPY_AN(IBASCSTDEF_N->CMF_4, IBASCSTDEF->CMF_4, sizeof(IBASCSTDEF->CMF_4));
    MEMCPY_AN(IBASCSTDEF_N->CMF_5, IBASCSTDEF->CMF_5, sizeof(IBASCSTDEF->CMF_5));
    IBASCSTDEF_N->DATA_FLAG[0] = IBASCSTDEF->DATA_FLAG;
    MEMCPY_AN(IBASCSTDEF_N->UPDATE_COUNT, IBASCSTDEF->UPDATE_COUNT, sizeof(IBASCSTDEF->UPDATE_COUNT));
    MEMCPY_AN(IBASCSTDEF_N->INSERT_COUNT, IBASCSTDEF->INSERT_COUNT, sizeof(IBASCSTDEF->INSERT_COUNT));
    MEMCPY_AN(IBASCSTDEF_N->DELETE_COUNT, IBASCSTDEF->DELETE_COUNT, sizeof(IBASCSTDEF->DELETE_COUNT));
    MEMCPY_AN(IBASCSTDEF_N->SQL_DML_COUNT, IBASCSTDEF->SQL_DML_COUNT, sizeof(IBASCSTDEF->SQL_DML_COUNT));
    MEMCPY_AN(IBASCSTDEF_N->ZPICODE, IBASCSTDEF->ZPICODE, sizeof(IBASCSTDEF->ZPICODE));
    MEMCPY_AN(IBASCSTDEF_N->ZPIMSGID, IBASCSTDEF->ZPIMSGID, sizeof(IBASCSTDEF->ZPIMSGID));
    IBASCSTDEF_N->RETURN_TYPE[0] = IBASCSTDEF->RETURN_TYPE;
    MEMCPY_AN(IBASCSTDEF_N->RETURN_MSG, IBASCSTDEF->RETURN_MSG, sizeof(IBASCSTDEF->RETURN_MSG));
    MEMCPY_AN(IBASCSTDEF_N->ZIFERNAM, IBASCSTDEF->ZIFERNAM, sizeof(IBASCSTDEF->ZIFERNAM));
    MEMCPY_AN(IBASCSTDEF_N->ZIFDATE, IBASCSTDEF->ZIFDATE, sizeof(IBASCSTDEF->ZIFDATE));
    MEMCPY_AN(IBASCSTDEF_N->ZIFTIME, IBASCSTDEF->ZIFTIME, sizeof(IBASCSTDEF->ZIFTIME));
    IBASCSTDEF_N->ZPISTAT[0] = IBASCSTDEF->ZPISTAT;
    MEMCPY_AN(IBASCSTDEF_N->ZPIMSG, IBASCSTDEF->ZPIMSG, sizeof(IBASCSTDEF->ZPIMSG));
}


/* Del Null Function */
void CDB_del_null_ibascstdef(struct IBASCSTDEF_N_TAG *IBASCSTDEF_N, struct IBASCSTDEF_TAG *IBASCSTDEF)
{
    MEMCPY_DN(IBASCSTDEF->DOC_ID, IBASCSTDEF_N->DOC_ID, sizeof(IBASCSTDEF->DOC_ID));
    MEMCPY_DN(IBASCSTDEF->SITE_ID, IBASCSTDEF_N->SITE_ID, sizeof(IBASCSTDEF->SITE_ID));
    MEMCPY_DN(IBASCSTDEF->COST_CENTER, IBASCSTDEF_N->COST_CENTER, sizeof(IBASCSTDEF->COST_CENTER));
    MEMCPY_DN(IBASCSTDEF->CTRL_AREA, IBASCSTDEF_N->CTRL_AREA, sizeof(IBASCSTDEF->CTRL_AREA));
    MEMCPY_DN(IBASCSTDEF->VLD_FR_DATE, IBASCSTDEF_N->VLD_FR_DATE, sizeof(IBASCSTDEF->VLD_FR_DATE));
    MEMCPY_DN(IBASCSTDEF->VLD_TO_DATE, IBASCSTDEF_N->VLD_TO_DATE, sizeof(IBASCSTDEF->VLD_TO_DATE));
    MEMCPY_DN(IBASCSTDEF->DESCRIPTION, IBASCSTDEF_N->DESCRIPTION, sizeof(IBASCSTDEF->DESCRIPTION));
    MEMCPY_DN(IBASCSTDEF->COMPANY, IBASCSTDEF_N->COMPANY, sizeof(IBASCSTDEF->COMPANY));
    MEMCPY_DN(IBASCSTDEF->CURRENCY, IBASCSTDEF_N->CURRENCY, sizeof(IBASCSTDEF->CURRENCY));
    IBASCSTDEF->DEL_YN = IBASCSTDEF_N->DEL_YN[0];
    MEMCPY_DN(IBASCSTDEF->INF_TIME, IBASCSTDEF_N->INF_TIME, sizeof(IBASCSTDEF->INF_TIME));
    MEMCPY_DN(IBASCSTDEF->INF_PROC_TIME, IBASCSTDEF_N->INF_PROC_TIME, sizeof(IBASCSTDEF->INF_PROC_TIME));
    MEMCPY_DN(IBASCSTDEF->CMF_1, IBASCSTDEF_N->CMF_1, sizeof(IBASCSTDEF->CMF_1));
    MEMCPY_DN(IBASCSTDEF->CMF_2, IBASCSTDEF_N->CMF_2, sizeof(IBASCSTDEF->CMF_2));
    MEMCPY_DN(IBASCSTDEF->CMF_3, IBASCSTDEF_N->CMF_3, sizeof(IBASCSTDEF->CMF_3));
    MEMCPY_DN(IBASCSTDEF->CMF_4, IBASCSTDEF_N->CMF_4, sizeof(IBASCSTDEF->CMF_4));
    MEMCPY_DN(IBASCSTDEF->CMF_5, IBASCSTDEF_N->CMF_5, sizeof(IBASCSTDEF->CMF_5));
    IBASCSTDEF->DATA_FLAG = IBASCSTDEF_N->DATA_FLAG[0];
    MEMCPY_DN(IBASCSTDEF->UPDATE_COUNT, IBASCSTDEF_N->UPDATE_COUNT, sizeof(IBASCSTDEF->UPDATE_COUNT));
    MEMCPY_DN(IBASCSTDEF->INSERT_COUNT, IBASCSTDEF_N->INSERT_COUNT, sizeof(IBASCSTDEF->INSERT_COUNT));
    MEMCPY_DN(IBASCSTDEF->DELETE_COUNT, IBASCSTDEF_N->DELETE_COUNT, sizeof(IBASCSTDEF->DELETE_COUNT));
    MEMCPY_DN(IBASCSTDEF->SQL_DML_COUNT, IBASCSTDEF_N->SQL_DML_COUNT, sizeof(IBASCSTDEF->SQL_DML_COUNT));
    MEMCPY_DN(IBASCSTDEF->ZPICODE, IBASCSTDEF_N->ZPICODE, sizeof(IBASCSTDEF->ZPICODE));
    MEMCPY_DN(IBASCSTDEF->ZPIMSGID, IBASCSTDEF_N->ZPIMSGID, sizeof(IBASCSTDEF->ZPIMSGID));
    IBASCSTDEF->RETURN_TYPE = IBASCSTDEF_N->RETURN_TYPE[0];
    MEMCPY_DN(IBASCSTDEF->RETURN_MSG, IBASCSTDEF_N->RETURN_MSG, sizeof(IBASCSTDEF->RETURN_MSG));
    MEMCPY_DN(IBASCSTDEF->ZIFERNAM, IBASCSTDEF_N->ZIFERNAM, sizeof(IBASCSTDEF->ZIFERNAM));
    MEMCPY_DN(IBASCSTDEF->ZIFDATE, IBASCSTDEF_N->ZIFDATE, sizeof(IBASCSTDEF->ZIFDATE));
    MEMCPY_DN(IBASCSTDEF->ZIFTIME, IBASCSTDEF_N->ZIFTIME, sizeof(IBASCSTDEF->ZIFTIME));
    IBASCSTDEF->ZPISTAT = IBASCSTDEF_N->ZPISTAT[0];
    MEMCPY_DN(IBASCSTDEF->ZPIMSG, IBASCSTDEF_N->ZPIMSG, sizeof(IBASCSTDEF->ZPIMSG));
}


