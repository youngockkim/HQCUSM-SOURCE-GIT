/* SQL CURSOR CLOSE Function */
void CDB_close_cmmsanarst(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CMMSANARST_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cmmsanarst", sel_type);
}


/* Initialize Function */
void CDB_init_cmmsanarst(struct CMMSANARST_TAG *CMMSANARST)
{
    /* memset by Space */
    memset(CMMSANARST, ' ', sizeof(struct CMMSANARST_TAG));
    
    CMMSANARST->ANA_VALUE = 0;
    CMMSANARST->SUM = 0;
    CMMSANARST->RANGE = 0;
    CMMSANARST->AVERAGE = 0;
    CMMSANARST->AVG_DIFF = 0;
    CMMSANARST->RANGE_AVG = 0;
    CMMSANARST->RP = 0;
    CMMSANARST->TOL = 0;
    CMMSANARST->EV = 0;
    CMMSANARST->AV = 0;
    CMMSANARST->RR = 0;
    CMMSANARST->PV = 0;
    CMMSANARST->TV = 0;
    CMMSANARST->CP = 0;
    CMMSANARST->BIAS_R_STDEV = 0;
    CMMSANARST->BIAS_T_STDEV = 0;
    CMMSANARST->BIAS_AVG = 0;
    CMMSANARST->BIAS_EV = 0;
}


/* Add Null Function */
void CDB_add_null_cmmsanarst(struct CMMSANARST_N_TAG *CMMSANARST_N, struct CMMSANARST_TAG *CMMSANARST)
{
    /* memset by NULL */
    memset(CMMSANARST_N, '\0', sizeof(struct CMMSANARST_N_TAG));
    
    MEMCPY_AN(CMMSANARST_N->FACTORY, CMMSANARST->FACTORY, sizeof(CMMSANARST->FACTORY));
    MEMCPY_AN(CMMSANARST_N->ANA_ID, CMMSANARST->ANA_ID, sizeof(CMMSANARST->ANA_ID));
    MEMCPY_AN(CMMSANARST_N->ITEM_CODE, CMMSANARST->ITEM_CODE, sizeof(CMMSANARST->ITEM_CODE));
    MEMCPY_AN(CMMSANARST_N->ANA_DATE, CMMSANARST->ANA_DATE, sizeof(CMMSANARST->ANA_DATE));
    CMMSANARST_N->ANA_RESULT[0] = CMMSANARST->ANA_RESULT;
    MEMCPY_AN(CMMSANARST_N->ANA_DESC, CMMSANARST->ANA_DESC, sizeof(CMMSANARST->ANA_DESC));
    CMMSANARST_N->ANA_VALUE = CMMSANARST->ANA_VALUE;
    CMMSANARST_N->SUM = CMMSANARST->SUM;
    CMMSANARST_N->RANGE = CMMSANARST->RANGE;
    CMMSANARST_N->AVERAGE = CMMSANARST->AVERAGE;
    CMMSANARST_N->AVG_DIFF = CMMSANARST->AVG_DIFF;
    CMMSANARST_N->RANGE_AVG = CMMSANARST->RANGE_AVG;
    CMMSANARST_N->RP = CMMSANARST->RP;
    CMMSANARST_N->TOL = CMMSANARST->TOL;
    CMMSANARST_N->EV = CMMSANARST->EV;
    CMMSANARST_N->AV = CMMSANARST->AV;
    CMMSANARST_N->RR = CMMSANARST->RR;
    CMMSANARST_N->PV = CMMSANARST->PV;
    CMMSANARST_N->TV = CMMSANARST->TV;
    CMMSANARST_N->CP = CMMSANARST->CP;
    CMMSANARST_N->BIAS_R_STDEV = CMMSANARST->BIAS_R_STDEV;
    CMMSANARST_N->BIAS_T_STDEV = CMMSANARST->BIAS_T_STDEV;
    CMMSANARST_N->BIAS_AVG = CMMSANARST->BIAS_AVG;
    CMMSANARST_N->BIAS_EV = CMMSANARST->BIAS_EV;
    CMMSANARST_N->CONFIRM_FLAG[0] = CMMSANARST->CONFIRM_FLAG;
    MEMCPY_AN(CMMSANARST_N->CONFIRM_USER_ID, CMMSANARST->CONFIRM_USER_ID, sizeof(CMMSANARST->CONFIRM_USER_ID));
    MEMCPY_AN(CMMSANARST_N->CONFIRM_TIME, CMMSANARST->CONFIRM_TIME, sizeof(CMMSANARST->CONFIRM_TIME));
    MEMCPY_AN(CMMSANARST_N->CMF_1, CMMSANARST->CMF_1, sizeof(CMMSANARST->CMF_1));
    MEMCPY_AN(CMMSANARST_N->CMF_2, CMMSANARST->CMF_2, sizeof(CMMSANARST->CMF_2));
    MEMCPY_AN(CMMSANARST_N->CMF_3, CMMSANARST->CMF_3, sizeof(CMMSANARST->CMF_3));
    MEMCPY_AN(CMMSANARST_N->CMF_4, CMMSANARST->CMF_4, sizeof(CMMSANARST->CMF_4));
    MEMCPY_AN(CMMSANARST_N->CMF_5, CMMSANARST->CMF_5, sizeof(CMMSANARST->CMF_5));
    MEMCPY_AN(CMMSANARST_N->CMF_6, CMMSANARST->CMF_6, sizeof(CMMSANARST->CMF_6));
    MEMCPY_AN(CMMSANARST_N->CMF_7, CMMSANARST->CMF_7, sizeof(CMMSANARST->CMF_7));
    MEMCPY_AN(CMMSANARST_N->CMF_8, CMMSANARST->CMF_8, sizeof(CMMSANARST->CMF_8));
    MEMCPY_AN(CMMSANARST_N->CMF_9, CMMSANARST->CMF_9, sizeof(CMMSANARST->CMF_9));
    MEMCPY_AN(CMMSANARST_N->CMF_10, CMMSANARST->CMF_10, sizeof(CMMSANARST->CMF_10));
    MEMCPY_AN(CMMSANARST_N->CREATE_USER_ID, CMMSANARST->CREATE_USER_ID, sizeof(CMMSANARST->CREATE_USER_ID));
    MEMCPY_AN(CMMSANARST_N->CREATE_TIME, CMMSANARST->CREATE_TIME, sizeof(CMMSANARST->CREATE_TIME));
    MEMCPY_AN(CMMSANARST_N->UPDATE_USER_ID, CMMSANARST->UPDATE_USER_ID, sizeof(CMMSANARST->UPDATE_USER_ID));
    MEMCPY_AN(CMMSANARST_N->UPDATE_TIME, CMMSANARST->UPDATE_TIME, sizeof(CMMSANARST->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_cmmsanarst(struct CMMSANARST_N_TAG *CMMSANARST_N, struct CMMSANARST_TAG *CMMSANARST)
{
    MEMCPY_DN(CMMSANARST->FACTORY, CMMSANARST_N->FACTORY, sizeof(CMMSANARST->FACTORY));
    MEMCPY_DN(CMMSANARST->ANA_ID, CMMSANARST_N->ANA_ID, sizeof(CMMSANARST->ANA_ID));
    MEMCPY_DN(CMMSANARST->ITEM_CODE, CMMSANARST_N->ITEM_CODE, sizeof(CMMSANARST->ITEM_CODE));
    MEMCPY_DN(CMMSANARST->ANA_DATE, CMMSANARST_N->ANA_DATE, sizeof(CMMSANARST->ANA_DATE));
    CMMSANARST->ANA_RESULT = CMMSANARST_N->ANA_RESULT[0];
    MEMCPY_DN(CMMSANARST->ANA_DESC, CMMSANARST_N->ANA_DESC, sizeof(CMMSANARST->ANA_DESC));
    CMMSANARST->ANA_VALUE = CMMSANARST_N->ANA_VALUE;
    CMMSANARST->SUM = CMMSANARST_N->SUM;
    CMMSANARST->RANGE = CMMSANARST_N->RANGE;
    CMMSANARST->AVERAGE = CMMSANARST_N->AVERAGE;
    CMMSANARST->AVG_DIFF = CMMSANARST_N->AVG_DIFF;
    CMMSANARST->RANGE_AVG = CMMSANARST_N->RANGE_AVG;
    CMMSANARST->RP = CMMSANARST_N->RP;
    CMMSANARST->TOL = CMMSANARST_N->TOL;
    CMMSANARST->EV = CMMSANARST_N->EV;
    CMMSANARST->AV = CMMSANARST_N->AV;
    CMMSANARST->RR = CMMSANARST_N->RR;
    CMMSANARST->PV = CMMSANARST_N->PV;
    CMMSANARST->TV = CMMSANARST_N->TV;
    CMMSANARST->CP = CMMSANARST_N->CP;
    CMMSANARST->BIAS_R_STDEV = CMMSANARST_N->BIAS_R_STDEV;
    CMMSANARST->BIAS_T_STDEV = CMMSANARST_N->BIAS_T_STDEV;
    CMMSANARST->BIAS_AVG = CMMSANARST_N->BIAS_AVG;
    CMMSANARST->BIAS_EV = CMMSANARST_N->BIAS_EV;
    CMMSANARST->CONFIRM_FLAG = CMMSANARST_N->CONFIRM_FLAG[0];
    MEMCPY_DN(CMMSANARST->CONFIRM_USER_ID, CMMSANARST_N->CONFIRM_USER_ID, sizeof(CMMSANARST->CONFIRM_USER_ID));
    MEMCPY_DN(CMMSANARST->CONFIRM_TIME, CMMSANARST_N->CONFIRM_TIME, sizeof(CMMSANARST->CONFIRM_TIME));
    MEMCPY_DN(CMMSANARST->CMF_1, CMMSANARST_N->CMF_1, sizeof(CMMSANARST->CMF_1));
    MEMCPY_DN(CMMSANARST->CMF_2, CMMSANARST_N->CMF_2, sizeof(CMMSANARST->CMF_2));
    MEMCPY_DN(CMMSANARST->CMF_3, CMMSANARST_N->CMF_3, sizeof(CMMSANARST->CMF_3));
    MEMCPY_DN(CMMSANARST->CMF_4, CMMSANARST_N->CMF_4, sizeof(CMMSANARST->CMF_4));
    MEMCPY_DN(CMMSANARST->CMF_5, CMMSANARST_N->CMF_5, sizeof(CMMSANARST->CMF_5));
    MEMCPY_DN(CMMSANARST->CMF_6, CMMSANARST_N->CMF_6, sizeof(CMMSANARST->CMF_6));
    MEMCPY_DN(CMMSANARST->CMF_7, CMMSANARST_N->CMF_7, sizeof(CMMSANARST->CMF_7));
    MEMCPY_DN(CMMSANARST->CMF_8, CMMSANARST_N->CMF_8, sizeof(CMMSANARST->CMF_8));
    MEMCPY_DN(CMMSANARST->CMF_9, CMMSANARST_N->CMF_9, sizeof(CMMSANARST->CMF_9));
    MEMCPY_DN(CMMSANARST->CMF_10, CMMSANARST_N->CMF_10, sizeof(CMMSANARST->CMF_10));
    MEMCPY_DN(CMMSANARST->CREATE_USER_ID, CMMSANARST_N->CREATE_USER_ID, sizeof(CMMSANARST->CREATE_USER_ID));
    MEMCPY_DN(CMMSANARST->CREATE_TIME, CMMSANARST_N->CREATE_TIME, sizeof(CMMSANARST->CREATE_TIME));
    MEMCPY_DN(CMMSANARST->UPDATE_USER_ID, CMMSANARST_N->UPDATE_USER_ID, sizeof(CMMSANARST->UPDATE_USER_ID));
    MEMCPY_DN(CMMSANARST->UPDATE_TIME, CMMSANARST_N->UPDATE_TIME, sizeof(CMMSANARST->UPDATE_TIME));
}


