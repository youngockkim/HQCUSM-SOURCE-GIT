/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cmmsanarst(int sel_type, struct CMMSANARST_TAG *CMMSANARST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMMSANARST_N_TAG CMMSANARST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cmmsanarst(&CMMSANARST_N, CMMSANARST);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CMMSANARST_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    ANA_ID,
                    ITEM_CODE,
                    ANA_DATE,
                    ANA_RESULT,
                    ANA_DESC,
                    ANA_VALUE,
                    SUM,
                    RANGE,
                    AVERAGE,
                    AVG_DIFF,
                    RANGE_AVG,
                    RP,
                    TOL,
                    EV,
                    AV,
                    RR,
                    PV,
                    TV,
                    CP,
                    BIAS_R_STDEV,
                    BIAS_T_STDEV,
                    BIAS_AVG,
                    BIAS_EV,
                    CONFIRM_FLAG,
                    CONFIRM_USER_ID,
                    CONFIRM_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSANARST
                ORDER BY FACTORY ASC,
                    ANA_ID ASC,
                    ITEM_CODE ASC;
            EXEC SQL OPEN CDB_CMMSANARST_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cmmsanarst", sel_type);
}


