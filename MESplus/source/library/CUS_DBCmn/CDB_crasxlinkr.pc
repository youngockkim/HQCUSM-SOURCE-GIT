    DB_start_query_timer();

    CDB_add_null_crasxlinkr(&CRASXLINKR_N, CRASXLINKR);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASXLINKR_CUR_1 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    LINE_ID,
                    LAMI_NUMER,
                    LAMI_POS,
                    TEST_DATE,
                    LX11,
                    LX12,
                    LX21,
                    LX22,
