                :CRASXLINKR_N.DX51,
                :CRASXLINKR_N.DX52,
                :CRASXLINKR_N.DXTAT1,
                :CRASXLINKR_N.DXTAT2,
                :CRASXLINKR_N.CREATE_USER_ID,
                :CRASXLINKR_N.TRAN_TIME,
                :CRASXLINKR_N.UPDATE_USER_ID,
                :CRASXLINKR_N.UPDATE_TIME,
                :CRASXLINKR_N.CMF_1,
                :CRASXLINKR_N.CMF_2,
                :CRASXLINKR_N.CMF_3,
                :CRASXLINKR_N.CMF_4,
                :CRASXLINKR_N.CMF_5,
                :CRASXLINKR_N.CMF_6,
                :CRASXLINKR_N.CMF_7,
                :CRASXLINKR_N.CMF_8,
                :CRASXLINKR_N.CMF_9,
                :CRASXLINKR_N.CMF_10;
            break;


		case 2:
            EXEC SQL FETCH CDB_CRASXLINKR_CUR_2 INTO
                :CRASXLINKR_N.WORK_DATE,
                :CRASXLINKR_N.LINE_ID,
                :CRASXLINKR_N.LAMI_NUMER,
                :CRASXLINKR_N.LAMI_POS,
                :CRASXLINKR_N.TEST_DATE,
                :CRASXLINKR_N.LX11,
                :CRASXLINKR_N.LX12,
                :CRASXLINKR_N.LX21,
                :CRASXLINKR_N.LX22,
                :CRASXLINKR_N.LX31,
                :CRASXLINKR_N.LX32,
                :CRASXLINKR_N.LX41,
                :CRASXLINKR_N.LX42,
                :CRASXLINKR_N.LX51,
                :CRASXLINKR_N.LX52,
                :CRASXLINKR_N.LXTAT1,
                :CRASXLINKR_N.LXTAT2,
                :CRASXLINKR_N.DX11,
                :CRASXLINKR_N.DX12,
                :CRASXLINKR_N.DX21,
                :CRASXLINKR_N.DX22,
                :CRASXLINKR_N.DX31,
                :CRASXLINKR_N.DX32,
                :CRASXLINKR_N.DX41,
                :CRASXLINKR_N.DX42,
                :CRASXLINKR_N.DX51,
                :CRASXLINKR_N.DX52,
                :CRASXLINKR_N.DXTAT1,
                :CRASXLINKR_N.DXTAT2,
                :CRASXLINKR_N.CREATE_USER_ID,
                :CRASXLINKR_N.TRAN_TIME,
                :CRASXLINKR_N.UPDATE_USER_ID,
                :CRASXLINKR_N.UPDATE_TIME,
                :CRASXLINKR_N.CMF_1,
                :CRASXLINKR_N.CMF_2,
                :CRASXLINKR_N.CMF_3,
                :CRASXLINKR_N.CMF_4,
                :CRASXLINKR_N.CMF_5,
                :CRASXLINKR_N.CMF_6,
                :CRASXLINKR_N.CMF_7,
                :CRASXLINKR_N.CMF_8,
                :CRASXLINKR_N.CMF_9,
                :CRASXLINKR_N.CMF_10;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_crasxlinkr(&CRASXLINKR_N, CRASXLINKR);
    }

    DB_stop_query_timer("CDB_fetch_crasxlinkr", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_crasxlinkr(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CRASXLINKR_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CRASXLINKR_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_crasxlinkr", sel_type);
}


/* Initialize Function */
void CDB_init_crasxlinkr(struct CRASXLINKR_TAG *CRASXLINKR)
{
    /* memset by Space */
    memset(CRASXLINKR, ' ', sizeof(struct CRASXLINKR_TAG));
    
    CRASXLINKR->LX11 = 0;
    CRASXLINKR->LX12 = 0;
    CRASXLINKR->LX21 = 0;
    CRASXLINKR->LX22 = 0;
    CRASXLINKR->LX31 = 0;
