{
    MEMCPY_DN(CRASXLINKR->WORK_DATE, CRASXLINKR_N->WORK_DATE, sizeof(CRASXLINKR->WORK_DATE));
    MEMCPY_DN(CRASXLINKR->LINE_ID, CRASXLINKR_N->LINE_ID, sizeof(CRASXLINKR->LINE_ID));
    MEMCPY_DN(CRASXLINKR->LAMI_NUMER, CRASXLINKR_N->LAMI_NUMER, sizeof(CRASXLINKR->LAMI_NUMER));
    MEMCPY_DN(CRASXLINKR->LAMI_POS, CRASXLINKR_N->LAMI_POS, sizeof(CRASXLINKR->LAMI_POS));
