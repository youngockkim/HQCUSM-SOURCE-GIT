/* Add Null Function */
void CDB_add_null_crasxlinkr(struct CRASXLINKR_N_TAG *CRASXLINKR_N, struct CRASXLINKR_TAG *CRASXLINKR)
{
    /* memset by NULL */
    memset(CRASXLINKR_N, '\0', sizeof(struct CRASXLINKR_N_TAG));
    
    MEMCPY_AN(CRASXLINKR_N->WORK_DATE, CRASXLINKR->WORK_DATE, sizeof(CRASXLINKR->WORK_DATE));
    MEMCPY_AN(CRASXLINKR_N->LINE_ID, CRASXLINKR->LINE_ID, sizeof(CRASXLINKR->LINE_ID));
