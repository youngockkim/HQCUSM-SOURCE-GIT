                    LAMI_POS ASC;
            EXEC SQL OPEN CDB_CRASXLINKR_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE CDB_CRASXLINKR_CUR_2 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    LINE_ID,
                    LAMI_NUMER,
                    LAMI_POS,
                    TEST_DATE,
                    LX11,
                    LX12,
                    LX21,
                    LX22,
                    LX31,
                    LX32,
                    LX41,
                    LX42,
                    LX51,
                    LX52,
                    LXTAT1,
                    LXTAT2,
                    DX11,
                    DX12,
                    DX21,
                    DX22,
                    DX31,
                    DX32,
                    DX41,
                    DX42,
                    DX51,
                    DX52,
                    DXTAT1,
                    DXTAT2,
                    NVL(CREATE_USER_ID, ' '),
                    NVL(TRAN_TIME, ' '),
                    NVL(UPDATE_USER_ID, ' '),
                    NVL(UPDATE_TIME, ' '),
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' '),
                    NVL(CMF_6, ' '),
                    NVL(CMF_7, ' '),
                    NVL(CMF_8, ' '),
                    NVL(CMF_9, ' '),
                    NVL(CMF_10, ' ')
                FROM CRASXLINKR
                WHERE WORK_DATE = :CRASXLINKR_N.WORK_DATE
                    AND LINE_ID = :CRASXLINKR_N.LINE_ID
			    ORDER BY WORK_DATE ASC,
                    LINE_ID ASC,
                    LAMI_NUMER ASC,
                    LAMI_POS ASC;
            EXEC SQL OPEN CDB_CRASXLINKR_CUR_2;
            break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_crasxlinkr", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_crasxlinkr(int sel_type, struct CRASXLINKR_TAG *CRASXLINKR)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CRASXLINKR_N_TAG CRASXLINKR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CRASXLINKR_CUR_1 INTO
                :CRASXLINKR_N.WORK_DATE,
                :CRASXLINKR_N.LINE_ID,
                :CRASXLINKR_N.LAMI_NUMER,
