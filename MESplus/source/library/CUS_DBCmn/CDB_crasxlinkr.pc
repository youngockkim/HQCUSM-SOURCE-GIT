    MEMCPY_AN(CRASXLINKR_N->CREATE_USER_ID, CRASXLINKR->CREATE_USER_ID, sizeof(CRASXLINKR->CREATE_USER_ID));
    MEMCPY_AN(CRASXLINKR_N->TRAN_TIME, CRASXLINKR->TRAN_TIME, sizeof(CRASXLINKR->TRAN_TIME));
