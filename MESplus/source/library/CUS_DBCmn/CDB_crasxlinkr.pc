    MEMCPY_AN(CRASXLINKR_N->UPDATE_TIME, CRASXLINKR->UPDATE_TIME, sizeof(CRASXLINKR->UPDATE_TIME));
    MEMCPY_AN(CRASXLINKR_N->CMF_1, CRASXLINKR->CMF_1, sizeof(CRASXLINKR->CMF_1));
    MEMCPY_AN(CRASXLINKR_N->CMF_2, CRASXLINKR->CMF_2, sizeof(CRASXLINKR->CMF_2));
