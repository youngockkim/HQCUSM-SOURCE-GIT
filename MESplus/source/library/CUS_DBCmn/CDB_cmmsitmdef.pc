/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cmmsitmdef(int sel_type, struct CMMSITMDEF_TAG *CMMSITMDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMMSITMDEF_N_TAG CMMSITMDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cmmsitmdef(&CMMSITMDEF_N, CMMSITMDEF);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CMMSITMDEF_CUR_1 CURSOR FOR
                SELECT 
					FACTORY,
                    ITEM_CODE,
                    ITEM_NAME,
                    ITEM_SPEC,
                    ITEM_GROUP_CODE,
                    TAG_NAME,
                    SPEC_TYPE,
                    LSL,
                    TARGET,
                    USL,
                    LCL,
                    UCL,
                    UNIT_CODE,
                    DECIMAL_PLACE,
                    USE_FLAG,
                    DELETE_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSITMDEF
                ORDER BY ITEM_CODE ASC;
            EXEC SQL OPEN CDB_CMMSITMDEF_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CMMSITMDEF_CUR_2 CURSOR FOR
                SELECT 
					FACTORY,
                    ITEM_CODE,
                    ITEM_NAME,
                    ITEM_SPEC,
                    ITEM_GROUP_CODE,
                    TAG_NAME,
                    SPEC_TYPE,
                    LSL,
                    TARGET,
                    USL,
                    LCL,
                    UCL,
                    UNIT_CODE,
                    DECIMAL_PLACE,
                    USE_FLAG,
                    DELETE_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSITMDEF
			   WHERE FACTORY = :CMMSITMDEF_N.FACTORY
				 AND ITEM_GROUP_CODE LIKE '%' || TRIM(:CMMSITMDEF_N.ITEM_GROUP_CODE) || '%'
			     AND DELETE_FLAG != 'Y'
                ORDER BY ITEM_CODE ASC;
            EXEC SQL OPEN CDB_CMMSITMDEF_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_CMMSITMDEF_CUR_3 CURSOR FOR
                SELECT 
					FACTORY,
                    ITEM_CODE,
                    ITEM_NAME,
                    ITEM_SPEC,
                    ITEM_GROUP_CODE,
                    TAG_NAME,
                    SPEC_TYPE,
                    LSL,
                    TARGET,
                    USL,
                    LCL,
                    UCL,
                    UNIT_CODE,
                    DECIMAL_PLACE,
                    USE_FLAG,
                    DELETE_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSITMDEF
			   WHERE FACTORY = :CMMSITMDEF_N.FACTORY
				 AND ITEM_GROUP_CODE LIKE '%' || TRIM(:CMMSITMDEF_N.ITEM_GROUP_CODE) || '%'
                ORDER BY ITEM_CODE ASC;
            EXEC SQL OPEN CDB_CMMSITMDEF_CUR_3;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cmmsitmdef", sel_type);
}


