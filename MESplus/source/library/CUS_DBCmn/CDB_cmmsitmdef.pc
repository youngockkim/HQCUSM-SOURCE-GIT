    CMMSITMDEF->UCL = 0;
    CMMSITMDEF->DECIMAL_PLACE = 0;
}


/* Add Null Function */
void CDB_add_null_cmmsitmdef(struct CMMSITMDEF_N_TAG *CMMSITMDEF_N, struct CMMSITMDEF_TAG *CMMSITMDEF)
{
    /* memset by NULL */
    memset(CMMSITMDEF_N, '\0', sizeof(struct CMMSITMDEF_N_TAG));
    
	MEMCPY_AN(CMMSITMDEF_N->FACTORY, CMMSITMDEF->FACTORY, sizeof(CMMSITMDEF->FACTORY));
    MEMCPY_AN(CMMSITMDEF_N->ITEM_CODE, CMMSITMDEF->ITEM_CODE, sizeof(CMMSITMDEF->ITEM_CODE));
    MEMCPY_AN(CMMSITMDEF_N->ITEM_NAME, CMMSITMDEF->ITEM_NAME, sizeof(CMMSITMDEF->ITEM_NAME));
    MEMCPY_AN(CMMSITMDEF_N->ITEM_SPEC, CMMSITMDEF->ITEM_SPEC, sizeof(CMMSITMDEF->ITEM_SPEC));
    MEMCPY_AN(CMMSITMDEF_N->ITEM_GROUP_CODE, CMMSITMDEF->ITEM_GROUP_CODE, sizeof(CMMSITMDEF->ITEM_GROUP_CODE));
    MEMCPY_AN(CMMSITMDEF_N->TAG_NAME, CMMSITMDEF->TAG_NAME, sizeof(CMMSITMDEF->TAG_NAME));
    CMMSITMDEF_N->SPEC_TYPE[0] = CMMSITMDEF->SPEC_TYPE;
    CMMSITMDEF_N->LSL = CMMSITMDEF->LSL;
    CMMSITMDEF_N->TARGET = CMMSITMDEF->TARGET;
    CMMSITMDEF_N->USL = CMMSITMDEF->USL;
    CMMSITMDEF_N->LCL = CMMSITMDEF->LCL;
    CMMSITMDEF_N->UCL = CMMSITMDEF->UCL;
    MEMCPY_AN(CMMSITMDEF_N->UNIT_CODE, CMMSITMDEF->UNIT_CODE, sizeof(CMMSITMDEF->UNIT_CODE));
    CMMSITMDEF_N->DECIMAL_PLACE = CMMSITMDEF->DECIMAL_PLACE;
    CMMSITMDEF_N->USE_FLAG[0] = CMMSITMDEF->USE_FLAG;
    CMMSITMDEF_N->DELETE_FLAG[0] = CMMSITMDEF->DELETE_FLAG;
    MEMCPY_AN(CMMSITMDEF_N->CREATE_USER_ID, CMMSITMDEF->CREATE_USER_ID, sizeof(CMMSITMDEF->CREATE_USER_ID));
    MEMCPY_AN(CMMSITMDEF_N->CREATE_TIME, CMMSITMDEF->CREATE_TIME, sizeof(CMMSITMDEF->CREATE_TIME));
    MEMCPY_AN(CMMSITMDEF_N->UPDATE_USER_ID, CMMSITMDEF->UPDATE_USER_ID, sizeof(CMMSITMDEF->UPDATE_USER_ID));
    MEMCPY_AN(CMMSITMDEF_N->UPDATE_TIME, CMMSITMDEF->UPDATE_TIME, sizeof(CMMSITMDEF->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_cmmsitmdef(struct CMMSITMDEF_N_TAG *CMMSITMDEF_N, struct CMMSITMDEF_TAG *CMMSITMDEF)
{
	MEMCPY_DN(CMMSITMDEF->FACTORY, CMMSITMDEF_N->FACTORY, sizeof(CMMSITMDEF->FACTORY));
    MEMCPY_DN(CMMSITMDEF->ITEM_CODE, CMMSITMDEF_N->ITEM_CODE, sizeof(CMMSITMDEF->ITEM_CODE));
    MEMCPY_DN(CMMSITMDEF->ITEM_NAME, CMMSITMDEF_N->ITEM_NAME, sizeof(CMMSITMDEF->ITEM_NAME));
    MEMCPY_DN(CMMSITMDEF->ITEM_SPEC, CMMSITMDEF_N->ITEM_SPEC, sizeof(CMMSITMDEF->ITEM_SPEC));
    MEMCPY_DN(CMMSITMDEF->ITEM_GROUP_CODE, CMMSITMDEF_N->ITEM_GROUP_CODE, sizeof(CMMSITMDEF->ITEM_GROUP_CODE));
    MEMCPY_DN(CMMSITMDEF->TAG_NAME, CMMSITMDEF_N->TAG_NAME, sizeof(CMMSITMDEF->TAG_NAME));
    CMMSITMDEF->SPEC_TYPE = CMMSITMDEF_N->SPEC_TYPE[0];
    CMMSITMDEF->LSL = CMMSITMDEF_N->LSL;
    CMMSITMDEF->TARGET = CMMSITMDEF_N->TARGET;
    CMMSITMDEF->USL = CMMSITMDEF_N->USL;
    CMMSITMDEF->LCL = CMMSITMDEF_N->LCL;
    CMMSITMDEF->UCL = CMMSITMDEF_N->UCL;
    MEMCPY_DN(CMMSITMDEF->UNIT_CODE, CMMSITMDEF_N->UNIT_CODE, sizeof(CMMSITMDEF->UNIT_CODE));
    CMMSITMDEF->DECIMAL_PLACE = CMMSITMDEF_N->DECIMAL_PLACE;
    CMMSITMDEF->USE_FLAG = CMMSITMDEF_N->USE_FLAG[0];
    CMMSITMDEF->DELETE_FLAG = CMMSITMDEF_N->DELETE_FLAG[0];
    MEMCPY_DN(CMMSITMDEF->CREATE_USER_ID, CMMSITMDEF_N->CREATE_USER_ID, sizeof(CMMSITMDEF->CREATE_USER_ID));
    MEMCPY_DN(CMMSITMDEF->CREATE_TIME, CMMSITMDEF_N->CREATE_TIME, sizeof(CMMSITMDEF->CREATE_TIME));
    MEMCPY_DN(CMMSITMDEF->UPDATE_USER_ID, CMMSITMDEF_N->UPDATE_USER_ID, sizeof(CMMSITMDEF->UPDATE_USER_ID));
    MEMCPY_DN(CMMSITMDEF->UPDATE_TIME, CMMSITMDEF_N->UPDATE_TIME, sizeof(CMMSITMDEF->UPDATE_TIME));
}


