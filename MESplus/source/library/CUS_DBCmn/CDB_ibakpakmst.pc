/* SQL CURSOR CLOSE Function */
void CDB_close_ibakpakmst(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IBAKPAKMST_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ibakpakmst", sel_type);
}


/* Initialize Function */
void CDB_init_ibakpakmst(struct IBAKPAKMST_TAG *IBAKPAKMST)
{
    /* memset by Space */
    memset(IBAKPAKMST, ' ', sizeof(struct IBAKPAKMST_TAG));
    
    IBAKPAKMST->MODULE_QTY = 0;
}


