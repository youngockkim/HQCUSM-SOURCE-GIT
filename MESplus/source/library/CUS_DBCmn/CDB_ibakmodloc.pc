    MEMCPY_DN(IBAKMODLOC->RETURN_MSG, IBAKMODLOC_N->RETURN_MSG, sizeof(IBAKMODLOC->RETURN_MSG));
    MEMCPY_DN(IBAKMODLOC->ZIFERNAM, IBAKMODLOC_N->ZIFERNAM, sizeof(IBAKMODLOC->ZIFERNAM));
    MEMCPY_DN(IBAKMODLOC->ZIFDATE, IBAKMODLOC_N->ZIFDATE, sizeof(IBAKMODLOC->ZIFDATE));
    MEMCPY_DN(IBAKMODLOC->ZIFTIME, IBAKMODLOC_N->ZIFTIME, sizeof(IBAKMODLOC->ZIFTIME));
    IBAKMODLOC->ZPISTAT = IBAKMODLOC_N->ZPISTAT[0];
    MEMCPY_DN(IBAKMODLOC->ZPIMSG, IBAKMODLOC_N->ZPIMSG, sizeof(IBAKMODLOC->ZPIMSG));
}


