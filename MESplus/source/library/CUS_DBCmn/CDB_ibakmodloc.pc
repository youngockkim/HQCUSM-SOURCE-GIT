/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_ibakmodloc(int sel_type, struct IBAKMODLOC_TAG *IBAKMODLOC)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IBAKMODLOC_N_TAG IBAKMODLOC_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ibakmodloc(&IBAKMODLOC_N, IBAKMODLOC);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IBAKMODLOC_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    LOC_ID,
                    LOC_NM,
                    DEL_YN,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IBAKMODLOC
                ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    LOC_ID ASC;
            EXEC SQL OPEN CDB_IBAKMODLOC_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_ibakmodloc", sel_type);
}


