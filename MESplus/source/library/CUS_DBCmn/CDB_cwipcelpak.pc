                    INSPECT_STATUS,
                    BLOCK_STATUS,
                    BLOCK_DATE,
                    POWERGRADE,
                    QUALITYGRADE,
                    AVG_NCELL,
                    AVG_ISC,
                    AVG_UOC,
                    AVG_FF,
                    AVG_RS,
                    AVG_RSH,
