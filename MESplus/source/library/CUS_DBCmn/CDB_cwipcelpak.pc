/* SQL UPDATE Function */
void CDB_update_cwipcelpak(int sel_type, struct CWIPCELPAK_TAG *CWIPCELPAK)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPCELPAK_N_TAG CWIPCELPAK_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwipcelpak(&CWIPCELPAK_N, CWIPCELPAK);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE CWIPCELPAK SET
                    LACK_ID = :CWIPCELPAK_N.LACK_ID,
                    PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE,
                    MAT_ID = :CWIPCELPAK_N.MAT_ID,
                    FLOW = :CWIPCELPAK_N.FLOW,
                    OPER = :CWIPCELPAK_N.OPER,
                    BATCHNO = :CWIPCELPAK_N.BATCHNO,
                    ORDER_ID = :CWIPCELPAK_N.ORDER_ID,
                    PACK_QTY = :CWIPCELPAK_N.PACK_QTY,
                    UNIT_ID = :CWIPCELPAK_N.UNIT_ID,
                    RCV_CELLBOX_ID = :CWIPCELPAK_N.RCV_CELLBOX_ID,
                    LARGEBOXID = :CWIPCELPAK_N.LARGEBOXID,
                    CELLTYPE = :CWIPCELPAK_N.CELLTYPE,
                    CELLPRODUCTDATE = :CWIPCELPAK_N.CELLPRODUCTDATE,
                    CELLGRADE = :CWIPCELPAK_N.CELLGRADE,
                    CELLBOXBARCODE = :CWIPCELPAK_N.CELLBOXBARCODE,
                    INSPECT_STATUS = :CWIPCELPAK_N.INSPECT_STATUS,
                    BLOCK_STATUS = :CWIPCELPAK_N.BLOCK_STATUS,
                    BLOCK_DATE = :CWIPCELPAK_N.BLOCK_DATE,
                    POWERGRADE = :CWIPCELPAK_N.POWERGRADE,
                    QUALITYGRADE = :CWIPCELPAK_N.QUALITYGRADE,
                    AVG_NCELL = :CWIPCELPAK_N.AVG_NCELL,
                    AVG_ISC = :CWIPCELPAK_N.AVG_ISC,
                    AVG_UOC = :CWIPCELPAK_N.AVG_UOC,
                    AVG_FF = :CWIPCELPAK_N.AVG_FF,
                    AVG_RS = :CWIPCELPAK_N.AVG_RS,
                    AVG_RSH = :CWIPCELPAK_N.AVG_RSH,
                    AVG_TEMPERATURE = :CWIPCELPAK_N.AVG_TEMPERATURE,
                    PRODUCTCLASSID = :CWIPCELPAK_N.PRODUCTCLASSID,
                    PRODUCTDEFINITIONTYPE = :CWIPCELPAK_N.PRODUCTDEFINITIONTYPE,
                    GR_BATCHNO = :CWIPCELPAK_N.GR_BATCHNO,
                    GR_DATE = :CWIPCELPAK_N.GR_DATE,
                    GI_BATCH_NO = :CWIPCELPAK_N.GI_BATCH_NO,
                    STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG,
                    CMF_1 = :CWIPCELPAK_N.CMF_1,
                    CMF_2 = :CWIPCELPAK_N.CMF_2,
                    CMF_4 = :CWIPCELPAK_N.CMF_4,
                    CMF_5 = :CWIPCELPAK_N.CMF_5,
					CMF_6 = :CWIPCELPAK_N.CMF_6,
                    CMF_7 = :CWIPCELPAK_N.CMF_7,
                    CMF_8 = :CWIPCELPAK_N.CMF_8,
                    CMF_9 = :CWIPCELPAK_N.CMF_9,
                    CMF_10 = :CWIPCELPAK_N.CMF_10
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
                    AND PACK_ID = :CWIPCELPAK_N.PACK_ID
                    AND CELL_BOX_ID = :CWIPCELPAK_N.CELL_BOX_ID;
            break;

		case 2:
            EXEC SQL UPDATE CWIPCELPAK SET
                    STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG,
					CMF_2 =  :CWIPCELPAK_N.CMF_2
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
                    AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
                    AND LACK_ID = :CWIPCELPAK_N.LACK_ID;
            break;

		case 3:
            EXEC SQL UPDATE CWIPCELPAK SET
                    STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
                    AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
                    AND LACK_ID = :CWIPCELPAK_N.LACK_ID
					AND PACK_ID = :CWIPCELPAK_N.PACK_ID;
            break;

		case 4:
            EXEC SQL UPDATE CWIPCELPAK SET
                    STATUS_FLAG ='C',
					CMF_2 =  :CWIPCELPAK_N.CMF_2,
					CMF_4 =  :CWIPCELPAK_N.CMF_4
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
                    AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
                    AND LACK_ID = :CWIPCELPAK_N.LACK_ID
					AND STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG ;
            break;

		case 5:
            EXEC SQL UPDATE CWIPCELPAK SET
                    STATUS_FLAG ='C',
					CMF_2 =  :CWIPCELPAK_N.CMF_2,
					CMF_4 =  :CWIPCELPAK_N.CMF_4
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
                    AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
                    AND LACK_ID = :CWIPCELPAK_N.LACK_ID
					AND STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG ;
            break;

		case 6:
            EXEC SQL UPDATE CWIPCELPAK SET
					CMF_5 =  :CWIPCELPAK_N.CMF_5,
                    CMF_7 =  :CWIPCELPAK_N.CMF_7,
					CMF_8 =  :CWIPCELPAK_N.CMF_8,
					CMF_9 =  :CWIPCELPAK_N.CMF_9
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
                    AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
                    AND PACK_ID = :CWIPCELPAK_N.PACK_ID
					AND STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG 
					AND CMF_2 = :CWIPCELPAK_N.CMF_2 ;
            break;

		case 7:
            EXEC SQL UPDATE CWIPCELPAK SET
                    CMF_10 =  :CWIPCELPAK_N.CMF_10
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
                    AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
					AND CMF_1 = :CWIPCELPAK_N.CMF_1;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_cwipcelpak", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwipcelpak(int sel_type, struct CWIPCELPAK_TAG *CWIPCELPAK)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPCELPAK_N_TAG CWIPCELPAK_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwipcelpak(&CWIPCELPAK_N, CWIPCELPAK);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPCELPAK_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    PACK_ID,
                    CELL_BOX_ID,
                    LACK_ID,
                    PACK_TYPE,
                    MAT_ID,
                    FLOW,
                    OPER,
                    BATCHNO,
                    ORDER_ID,
                    PACK_QTY,
                    UNIT_ID,
                    RCV_CELLBOX_ID,
                    LARGEBOXID,
                    CELLTYPE,
                    CELLPRODUCTDATE,
                    CELLGRADE,
                    CELLBOXBARCODE,
                    INSPECT_STATUS,
                    BLOCK_STATUS,
                    BLOCK_DATE,
                    POWERGRADE,
                    QUALITYGRADE,
                    AVG_NCELL,
                    AVG_ISC,
                    AVG_UOC,
                    AVG_FF,
                    AVG_RS,
                    AVG_RSH,
                    AVG_TEMPERATURE,
                    PRODUCTCLASSID,
                    PRODUCTDEFINITIONTYPE,
                    GR_BATCHNO,
                    GR_DATE,
                    GI_BATCH_NO,
                    STATUS_FLAG,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
					CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10
                FROM CWIPCELPAK
                ORDER BY FACTORY ASC,
                    PACK_ID ASC,
                    CELL_BOX_ID ASC;
            EXEC SQL OPEN CDB_CWIPCELPAK_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CWIPCELPAK_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    PACK_ID,
                    CELL_BOX_ID,
                    LACK_ID,
                    PACK_TYPE,
                    MAT_ID,
                    FLOW,
                    OPER,
                    BATCHNO,
                    ORDER_ID,
                    PACK_QTY,
                    UNIT_ID,
                    RCV_CELLBOX_ID,
                    LARGEBOXID,
                    CELLTYPE,
                    CELLPRODUCTDATE,
                    CELLGRADE,
                    CELLBOXBARCODE,
                    INSPECT_STATUS,
                    BLOCK_STATUS,
                    BLOCK_DATE,
                    POWERGRADE,
                    QUALITYGRADE,
                    AVG_NCELL,
                    AVG_ISC,
                    AVG_UOC,
                    AVG_FF,
                    AVG_RS,
                    AVG_RSH,
                    AVG_TEMPERATURE,
                    PRODUCTCLASSID,
                    PRODUCTDEFINITIONTYPE,
                    GR_BATCHNO,
