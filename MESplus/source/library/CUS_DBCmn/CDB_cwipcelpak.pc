				  AND OPER = :CWIPCELPAK_N.OPER
				  AND ORDER_ID = :CWIPCELPAK_N.ORDER_ID
                ORDER BY FACTORY ASC,
                    PACK_ID ASC,
                    ORDER_ID ASC;
            EXEC SQL OPEN CDB_CWIPCELPAK_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_CWIPCELPAK_CUR_3 CURSOR FOR
				SELECT 
					FACTORY,
                    PACK_ID,
                    CELL_BOX_ID,
                    LACK_ID,
                    PACK_TYPE,
                    MAT_ID,
