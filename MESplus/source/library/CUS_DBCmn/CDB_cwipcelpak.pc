/* SQL CURSOR CLOSE Function */
void CDB_close_cwipcelpak(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CWIPCELPAK_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CWIPCELPAK_CUR_2;
            break;

		case 3:
            EXEC SQL CLOSE CDB_CWIPCELPAK_CUR_3;
            break;

		case 4:
            EXEC SQL CLOSE CDB_CWIPCELPAK_CUR_4;
            break;

		case 5:
            EXEC SQL CLOSE CDB_CWIPCELPAK_CUR_5;
            break;

		case 6:
            EXEC SQL CLOSE CDB_CWIPCELPAK_CUR_6;
            break;

		case 7:
            EXEC SQL CLOSE CDB_CWIPCELPAK_CUR_7;
            break;

		case 8:
            EXEC SQL CLOSE CDB_CWIPCELPAK_CUR_8;
            break;            

		case 9:
            EXEC SQL CLOSE CDB_CWIPCELPAK_CUR_9;
            break;   

		case 10:
            EXEC SQL CLOSE CDB_CWIPCELPAK_CUR_10;
            break;

		case 101:
            EXEC SQL CLOSE CDB_CWIPCELPAK_CUR_101;
            break;

		case 102:
            EXEC SQL CLOSE CDB_CWIPCELPAK_CUR_102;
            break;

		case 103:
            EXEC SQL CLOSE CDB_CWIPCELPAK_CUR_103;
            break;

		case 104:
            EXEC SQL CLOSE CDB_CWIPCELPAK_CUR_104;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwipcelpak", sel_type);
}


/* Initialize Function */
void CDB_init_cwipcelpak(struct CWIPCELPAK_TAG *CWIPCELPAK)
{
    /* memset by Space */
    memset(CWIPCELPAK, ' ', sizeof(struct CWIPCELPAK_TAG));
    
    CWIPCELPAK->PACK_QTY = 0;
    CWIPCELPAK->AVG_NCELL = 0;
    CWIPCELPAK->AVG_ISC = 0;
    CWIPCELPAK->AVG_UOC = 0;
    CWIPCELPAK->AVG_FF = 0;
    CWIPCELPAK->AVG_RS = 0;
    CWIPCELPAK->AVG_RSH = 0;
    CWIPCELPAK->AVG_TEMPERATURE = 0;
}


/* Add Null Function */
void CDB_add_null_cwipcelpak(struct CWIPCELPAK_N_TAG *CWIPCELPAK_N, struct CWIPCELPAK_TAG *CWIPCELPAK)
{
    /* memset by NULL */
    memset(CWIPCELPAK_N, '\0', sizeof(struct CWIPCELPAK_N_TAG));
    
    MEMCPY_AN(CWIPCELPAK_N->FACTORY, CWIPCELPAK->FACTORY, sizeof(CWIPCELPAK->FACTORY));
    MEMCPY_AN(CWIPCELPAK_N->PACK_ID, CWIPCELPAK->PACK_ID, sizeof(CWIPCELPAK->PACK_ID));
    MEMCPY_AN(CWIPCELPAK_N->CELL_BOX_ID, CWIPCELPAK->CELL_BOX_ID, sizeof(CWIPCELPAK->CELL_BOX_ID));
    MEMCPY_AN(CWIPCELPAK_N->LACK_ID, CWIPCELPAK->LACK_ID, sizeof(CWIPCELPAK->LACK_ID));
    CWIPCELPAK_N->PACK_TYPE[0] = CWIPCELPAK->PACK_TYPE;
    MEMCPY_AN(CWIPCELPAK_N->MAT_ID, CWIPCELPAK->MAT_ID, sizeof(CWIPCELPAK->MAT_ID));
    MEMCPY_AN(CWIPCELPAK_N->FLOW, CWIPCELPAK->FLOW, sizeof(CWIPCELPAK->FLOW));
    MEMCPY_AN(CWIPCELPAK_N->OPER, CWIPCELPAK->OPER, sizeof(CWIPCELPAK->OPER));
    MEMCPY_AN(CWIPCELPAK_N->BATCHNO, CWIPCELPAK->BATCHNO, sizeof(CWIPCELPAK->BATCHNO));
    MEMCPY_AN(CWIPCELPAK_N->ORDER_ID, CWIPCELPAK->ORDER_ID, sizeof(CWIPCELPAK->ORDER_ID));
    CWIPCELPAK_N->PACK_QTY = CWIPCELPAK->PACK_QTY;
    MEMCPY_AN(CWIPCELPAK_N->UNIT_ID, CWIPCELPAK->UNIT_ID, sizeof(CWIPCELPAK->UNIT_ID));
    MEMCPY_AN(CWIPCELPAK_N->RCV_CELLBOX_ID, CWIPCELPAK->RCV_CELLBOX_ID, sizeof(CWIPCELPAK->RCV_CELLBOX_ID));
    MEMCPY_AN(CWIPCELPAK_N->LARGEBOXID, CWIPCELPAK->LARGEBOXID, sizeof(CWIPCELPAK->LARGEBOXID));
    MEMCPY_AN(CWIPCELPAK_N->CELLTYPE, CWIPCELPAK->CELLTYPE, sizeof(CWIPCELPAK->CELLTYPE));
    MEMCPY_AN(CWIPCELPAK_N->CELLPRODUCTDATE, CWIPCELPAK->CELLPRODUCTDATE, sizeof(CWIPCELPAK->CELLPRODUCTDATE));
    MEMCPY_AN(CWIPCELPAK_N->CELLGRADE, CWIPCELPAK->CELLGRADE, sizeof(CWIPCELPAK->CELLGRADE));
    MEMCPY_AN(CWIPCELPAK_N->CELLBOXBARCODE, CWIPCELPAK->CELLBOXBARCODE, sizeof(CWIPCELPAK->CELLBOXBARCODE));
    CWIPCELPAK_N->INSPECT_STATUS[0] = CWIPCELPAK->INSPECT_STATUS;
    CWIPCELPAK_N->BLOCK_STATUS[0] = CWIPCELPAK->BLOCK_STATUS;
    MEMCPY_AN(CWIPCELPAK_N->BLOCK_DATE, CWIPCELPAK->BLOCK_DATE, sizeof(CWIPCELPAK->BLOCK_DATE));
    MEMCPY_AN(CWIPCELPAK_N->POWERGRADE, CWIPCELPAK->POWERGRADE, sizeof(CWIPCELPAK->POWERGRADE));
    MEMCPY_AN(CWIPCELPAK_N->QUALITYGRADE, CWIPCELPAK->QUALITYGRADE, sizeof(CWIPCELPAK->QUALITYGRADE));
    CWIPCELPAK_N->AVG_NCELL = CWIPCELPAK->AVG_NCELL;
    CWIPCELPAK_N->AVG_ISC = CWIPCELPAK->AVG_ISC;
    CWIPCELPAK_N->AVG_UOC = CWIPCELPAK->AVG_UOC;
    CWIPCELPAK_N->AVG_FF = CWIPCELPAK->AVG_FF;
    CWIPCELPAK_N->AVG_RS = CWIPCELPAK->AVG_RS;
    CWIPCELPAK_N->AVG_RSH = CWIPCELPAK->AVG_RSH;
    CWIPCELPAK_N->AVG_TEMPERATURE = CWIPCELPAK->AVG_TEMPERATURE;
