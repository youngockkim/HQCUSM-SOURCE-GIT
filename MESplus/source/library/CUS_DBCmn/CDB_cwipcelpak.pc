					AND STATUS_FLAG = 'I'
				ORDER BY PACK_ID, CELL_BOX_ID;
			EXEC SQL OPEN CDB_CWIPCELPAK_CUR_104;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
