/* SQL SELECT_SCALAR Function */
double CDB_select_cwipcelpak_scalar(int sel_type, struct CWIPCELPAK_TAG *CWIPCELPAK)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPCELPAK_N_TAG CWIPCELPAK_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwipcelpak(&CWIPCELPAK_N, CWIPCELPAK);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPCELPAK
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
                    AND PACK_ID = :CWIPCELPAK_N.PACK_ID
                    AND CELL_BOX_ID = :CWIPCELPAK_N.CELL_BOX_ID;
            break;

		case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPCELPAK
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
				  AND ORDER_ID = :CWIPCELPAK_N.ORDER_ID
                  AND LACK_ID = :CWIPCELPAK_N.LACK_ID;
            break;

		case 3:
			EXEC SQL SELECT SUM(PACK_QTY)
				INTO :d_value
                FROM CWIPCELPAK
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
				  AND ORDER_ID = :CWIPCELPAK_N.ORDER_ID
                  AND LACK_ID = :CWIPCELPAK_N.LACK_ID;
            break;

		case 4:
			EXEC SQL SELECT count(*)
				INTO :d_value
                FROM CWIPCELPAK
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
				  AND LACK_ID = :CWIPCELPAK_N.LACK_ID
                  AND STATUS_FLAG = 'I';
            break;

		case 5:
			EXEC SQL SELECT count(*)
				INTO :d_value
                FROM CWIPCELPAK
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
				  AND LACK_ID = :CWIPCELPAK_N.LACK_ID
                  AND PACK_ID = :CWIPCELPAK_N.PACK_ID
                  AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
                  AND STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG;
            break;

        /* Number of Magazines */
		case 6: 
			EXEC SQL SELECT count(DISTINCT PACK_ID)
				INTO :d_value
                FROM CWIPCELPAK
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
				  AND LACK_ID = :CWIPCELPAK_N.LACK_ID
                  AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
                  AND STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG;
            break;

        /* Number of Cell Boxes */
		case 7: 
			EXEC SQL SELECT count(DISTINCT CELL_BOX_ID)
				INTO :d_value
                FROM CWIPCELPAK
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
				  AND LACK_ID = :CWIPCELPAK_N.LACK_ID
                  AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
                  AND STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG;
            break;

        /* Sum of Pack Qty per Magazine */
		case 8:
			EXEC SQL SELECT NVL(sum(PACK_QTY), 0)
				INTO :d_value
                FROM CWIPCELPAK
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
				  AND LACK_ID = :CWIPCELPAK_N.LACK_ID
                  AND PACK_ID = :CWIPCELPAK_N.PACK_ID
                  AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
                  AND STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG;
            break;

        /* Total Number of Cells */
		case 9: 
			EXEC SQL SELECT NVL(sum(PACK_QTY), 0)
				INTO :d_value
                FROM CWIPCELPAK
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
				  AND LACK_ID = :CWIPCELPAK_N.LACK_ID
                  AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
                  AND STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG;
            break;

        /* Number of Magazine having 150 Cells */
		case 10: 
			EXEC SQL SELECT NVL(count(max(DISTINCT PACK_ID)), 0)
				INTO :d_value
                FROM CWIPCELPAK
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
				  AND LACK_ID = :CWIPCELPAK_N.LACK_ID
                  AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
                  AND STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG
                HAVING SUM(PACK_QTY) = 150
                GROUP BY PACK_ID;
            break;

		case 11: 
			EXEC SQL SELECT SUM(PACK_QTY)
				INTO :d_value
                FROM CWIPCELPAK
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
				  AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
                  AND ORDER_ID = :CWIPCELPAK_N.ORDER_ID ;
            break;

		case 12: 
			EXEC SQL SELECT count(*)
				INTO :d_value
                FROM CWIPCELPAK
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
				  AND LACK_ID = :CWIPCELPAK_N.LACK_ID
                  AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
                  AND STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG;
            break;

		case 13:
            EXEC SQL SELECT 
                    COUNT(*)
					INTO :d_value
                FROM CWIPCELPAK
                WHERE  FACTORY = :CWIPCELPAK_N.FACTORY
                    AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
					AND PACK_ID = :CWIPCELPAK_N.PACK_ID
                    AND STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG
					AND CMF_2 = ( SELECT MAX(CMF_2) FROM CWIPCELPAK
								  WHERE FACTORY = :CWIPCELPAK_N.FACTORY
									AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
									AND PACK_ID = :CWIPCELPAK_N.PACK_ID
									AND STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG
								);
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_cwipcelpak_scalar", sel_type);

    return d_value;
}


/* SQL DELETE Function */
void CDB_delete_cwipcelpak(int sel_type, struct CWIPCELPAK_TAG *CWIPCELPAK)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPCELPAK_N_TAG CWIPCELPAK_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwipcelpak(&CWIPCELPAK_N, CWIPCELPAK);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DELETE FROM CWIPCELPAK
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
                    AND PACK_ID = :CWIPCELPAK_N.PACK_ID
                    AND CELL_BOX_ID = :CWIPCELPAK_N.CELL_BOX_ID;
            break;

		case 2:
            EXEC SQL DELETE FROM CWIPCELPAK
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
                    AND PACK_ID = :CWIPCELPAK_N.PACK_ID
                    AND CELL_BOX_ID = :CWIPCELPAK_N.CELL_BOX_ID;
            break;

		case 100:
            EXEC SQL DELETE FROM MV_CWIPCELPAK@LM1RPT
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
                    AND PACK_ID = :CWIPCELPAK_N.PACK_ID
                    AND CELL_BOX_ID = :CWIPCELPAK_N.CELL_BOX_ID;
            break;

		case 101:
            EXEC SQL DELETE FROM CWIPCELPAK@LM1RPT
                WHERE FACTORY = :CWIPCELPAK_N.FACTORY
                    AND PACK_ID = :CWIPCELPAK_N.PACK_ID
                    AND CELL_BOX_ID = :CWIPCELPAK_N.CELL_BOX_ID;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_delete_cwipcelpak", sel_type);
}


