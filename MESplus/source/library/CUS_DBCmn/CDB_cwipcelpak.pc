                    :CWIPCELPAK_N.GR_BATCHNO,
                    :CWIPCELPAK_N.GR_DATE,
                    :CWIPCELPAK_N.GI_BATCH_NO,
                    :CWIPCELPAK_N.STATUS_FLAG,
                    :CWIPCELPAK_N.CMF_1,
                    :CWIPCELPAK_N.CMF_2,
                    :CWIPCELPAK_N.CMF_3,
                    :CWIPCELPAK_N.CMF_4,
                    :CWIPCELPAK_N.CMF_5,
                    :CWIPCELPAK_N.CMF_6,
                    :CWIPCELPAK_N.CMF_7,
                    :CWIPCELPAK_N.CMF_8,
                    :CWIPCELPAK_N.CMF_9,
                    :CWIPCELPAK_N.CMF_10
                FROM CWIPCELPAK
                WHERE PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
                    AND CELL_BOX_ID IN (
							SELECT INV_LOT_ID FROM CWIPLOTMAT
							WHERE LOT_ID =  :CWIPCELPAK_N.CELL_BOX_ID
						AND MAT_TYPE = 'CELL')
					AND ROWNUM = 1;
			break;

		case 8:
            EXEC SQL SELECT 
                    FACTORY,
                    PACK_ID,
                    CELL_BOX_ID,
                    LACK_ID,
                    PACK_TYPE,
                    MAT_ID,
                    FLOW,
                    OPER,
                    BATCHNO,
                    ORDER_ID,
                    PACK_QTY,
                    UNIT_ID,
                    RCV_CELLBOX_ID,
                    LARGEBOXID,
                    CELLTYPE,
                    CELLPRODUCTDATE,
                    CELLGRADE,
                    CELLBOXBARCODE,
                    INSPECT_STATUS,
                    BLOCK_STATUS,
                    BLOCK_DATE,
                    POWERGRADE,
                    QUALITYGRADE,
                    AVG_NCELL,
                    AVG_ISC,
                    AVG_UOC,
                    AVG_FF,
                    AVG_RS,
                    AVG_RSH,
                    AVG_TEMPERATURE,
                    PRODUCTCLASSID,
                    PRODUCTDEFINITIONTYPE,
                    GR_BATCHNO,
                    GR_DATE,
                    GI_BATCH_NO,
                    STATUS_FLAG,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
					CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10

                INTO 
                    :CWIPCELPAK_N.FACTORY,
                    :CWIPCELPAK_N.PACK_ID,
                    :CWIPCELPAK_N.CELL_BOX_ID,
                    :CWIPCELPAK_N.LACK_ID,
                    :CWIPCELPAK_N.PACK_TYPE,
                    :CWIPCELPAK_N.MAT_ID,
                    :CWIPCELPAK_N.FLOW,
                    :CWIPCELPAK_N.OPER,
                    :CWIPCELPAK_N.BATCHNO,
                    :CWIPCELPAK_N.ORDER_ID,
                    :CWIPCELPAK_N.PACK_QTY,
                    :CWIPCELPAK_N.UNIT_ID,
                    :CWIPCELPAK_N.RCV_CELLBOX_ID,
                    :CWIPCELPAK_N.LARGEBOXID,
                    :CWIPCELPAK_N.CELLTYPE,
                    :CWIPCELPAK_N.CELLPRODUCTDATE,
                    :CWIPCELPAK_N.CELLGRADE,
                    :CWIPCELPAK_N.CELLBOXBARCODE,
                    :CWIPCELPAK_N.INSPECT_STATUS,
                    :CWIPCELPAK_N.BLOCK_STATUS,
                    :CWIPCELPAK_N.BLOCK_DATE,
                    :CWIPCELPAK_N.POWERGRADE,
                    :CWIPCELPAK_N.QUALITYGRADE,
                    :CWIPCELPAK_N.AVG_NCELL,
                    :CWIPCELPAK_N.AVG_ISC,
                    :CWIPCELPAK_N.AVG_UOC,
                    :CWIPCELPAK_N.AVG_FF,
                    :CWIPCELPAK_N.AVG_RS,
                    :CWIPCELPAK_N.AVG_RSH,
                    :CWIPCELPAK_N.AVG_TEMPERATURE,
                    :CWIPCELPAK_N.PRODUCTCLASSID,
                    :CWIPCELPAK_N.PRODUCTDEFINITIONTYPE,
                    :CWIPCELPAK_N.GR_BATCHNO,
                    :CWIPCELPAK_N.GR_DATE,
                    :CWIPCELPAK_N.GI_BATCH_NO,
                    :CWIPCELPAK_N.STATUS_FLAG,
                    :CWIPCELPAK_N.CMF_1,
                    :CWIPCELPAK_N.CMF_2,
                    :CWIPCELPAK_N.CMF_3,
                    :CWIPCELPAK_N.CMF_4,
                    :CWIPCELPAK_N.CMF_5,
                    :CWIPCELPAK_N.CMF_6,
                    :CWIPCELPAK_N.CMF_7,
                    :CWIPCELPAK_N.CMF_8,
                    :CWIPCELPAK_N.CMF_9,
                    :CWIPCELPAK_N.CMF_10
                FROM CWIPCELPAK
                WHERE  FACTORY = :CWIPCELPAK_N.FACTORY
                    AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
					AND PACK_ID = :CWIPCELPAK_N.PACK_ID
                    AND STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG
					AND CMF_2 = ( SELECT MAX(CMF_2) FROM CWIPCELPAK
								  WHERE FACTORY = :CWIPCELPAK_N.FACTORY
									AND PACK_TYPE = :CWIPCELPAK_N.PACK_TYPE
									AND PACK_ID = :CWIPCELPAK_N.PACK_ID
									AND STATUS_FLAG = :CWIPCELPAK_N.STATUS_FLAG
								)
					AND ROWNUM = 1;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cwipcelpak(&CWIPCELPAK_N, CWIPCELPAK);
    }

    DB_stop_query_timer("CDB_select_cwipcelpak", sel_type);
}


