/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cmmsusrdef(int sel_type, struct CMMSUSRDEF_TAG *CMMSUSRDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMMSUSRDEF_N_TAG CMMSUSRDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cmmsusrdef(&CMMSUSRDEF_N, CMMSUSRDEF);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CMMSUSRDEF_CUR_1 CURSOR FOR
                SELECT 
					FACTORY,
                    USER_ID,
                    USER_NAME,
                    FILE_NAME,
                    FILE_PATH,
                    EXPIRY_DATE,
                    CALI_FLAG,
                    MSA_FLAG,
                    USE_FLAG,
					CMF_1,
					CMF_2,
					CMF_3,
					CMF_4,
					CMF_5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSUSRDEF
                ORDER BY USER_ID ASC;
            EXEC SQL OPEN CDB_CMMSUSRDEF_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CMMSUSRDEF_CUR_2 CURSOR FOR
                SELECT 
				    FACTORY,
                    USER_ID,
                    USER_NAME,
                    FILE_NAME,
                    FILE_PATH,
                    EXPIRY_DATE,
                    CALI_FLAG,
                    MSA_FLAG,
                    USE_FLAG,
					CMF_1,
					CMF_2,
					CMF_3,
					CMF_4,
					CMF_5,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSUSRDEF
			   WHERE FACTORY = :CMMSUSRDEF_N.FACTORY
					AND USER_ID LIKE '%' || TRIM(:CMMSUSRDEF_N.USER_ID) || '%'
                ORDER BY USER_ID ASC;
            EXEC SQL OPEN CDB_CMMSUSRDEF_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_CMMSUSRDEF_CUR_3 CURSOR FOR
                SELECT 
                    USER_ID,
                    USER_NAME
                FROM CMMSUSRDEF
			   WHERE FACTORY = :CMMSUSRDEF_N.FACTORY
				 AND USE_FLAG = :CMMSUSRDEF_N.USE_FLAG
                ORDER BY USER_ID ASC;
            EXEC SQL OPEN CDB_CMMSUSRDEF_CUR_3;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cmmsusrdef", sel_type);
}


