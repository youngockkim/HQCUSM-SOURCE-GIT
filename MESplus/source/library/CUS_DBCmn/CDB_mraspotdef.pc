/* SQL UPDATE Function */
void CDB_update_mraspotdef(int sel_type, struct MRASPOTDEF_TAG *MRASPOTDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASPOTDEF_N_TAG MRASPOTDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_mraspotdef(&MRASPOTDEF_N, MRASPOTDEF);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MRASPOTDEF SET
                    PORT_SEQ = :MRASPOTDEF_N.PORT_SEQ,
                    PORT_DESC = :MRASPOTDEF_N.PORT_DESC,
                    TRS_STATE = :MRASPOTDEF_N.TRS_STATE,
                    ASC_STATE = :MRASPOTDEF_N.ASC_STATE,
                    ASC_OBJ_ID = :MRASPOTDEF_N.ASC_OBJ_ID,
                    ACC_STATE = :MRASPOTDEF_N.ACC_STATE,
                    RSV_STATE = :MRASPOTDEF_N.RSV_STATE,
                    RSV_OBJ_ID = :MRASPOTDEF_N.RSV_OBJ_ID,
                    LOT_ID = :MRASPOTDEF_N.LOT_ID,
                    CRR_ID = :MRASPOTDEF_N.CRR_ID,
                    BCR_STATUS_FLAG = :MRASPOTDEF_N.BCR_STATUS_FLAG,
                    PORT_TYPE = :MRASPOTDEF_N.PORT_TYPE,
                    PORT_BATCH_FLAG = :MRASPOTDEF_N.PORT_BATCH_FLAG,
                    ADD_PORT_TYPE = :MRASPOTDEF_N.ADD_PORT_TYPE,
                    PORT_LEVEL = :MRASPOTDEF_N.PORT_LEVEL,
                    PORT_CMF_1 = :MRASPOTDEF_N.PORT_CMF_1,
                    PORT_CMF_2 = :MRASPOTDEF_N.PORT_CMF_2,
                    PORT_CMF_3 = :MRASPOTDEF_N.PORT_CMF_3,
                    PORT_CMF_4 = :MRASPOTDEF_N.PORT_CMF_4,
                    PORT_CMF_5 = :MRASPOTDEF_N.PORT_CMF_5,
                    PORT_CMF_6 = :MRASPOTDEF_N.PORT_CMF_6,
                    PORT_CMF_7 = :MRASPOTDEF_N.PORT_CMF_7,
                    PORT_CMF_8 = :MRASPOTDEF_N.PORT_CMF_8,
                    PORT_CMF_9 = :MRASPOTDEF_N.PORT_CMF_9,
                    PORT_CMF_10 = :MRASPOTDEF_N.PORT_CMF_10,
                    PORT_CMF_11 = :MRASPOTDEF_N.PORT_CMF_11,
                    PORT_CMF_12 = :MRASPOTDEF_N.PORT_CMF_12,
                    PORT_CMF_13 = :MRASPOTDEF_N.PORT_CMF_13,
                    PORT_CMF_14 = :MRASPOTDEF_N.PORT_CMF_14,
                    PORT_CMF_15 = :MRASPOTDEF_N.PORT_CMF_15,
                    PORT_CMF_16 = :MRASPOTDEF_N.PORT_CMF_16,
                    PORT_CMF_17 = :MRASPOTDEF_N.PORT_CMF_17,
                    PORT_CMF_18 = :MRASPOTDEF_N.PORT_CMF_18,
                    PORT_CMF_19 = :MRASPOTDEF_N.PORT_CMF_19,
                    PORT_CMF_20 = :MRASPOTDEF_N.PORT_CMF_20,
                    LAST_HIST_SEQ = :MRASPOTDEF_N.LAST_HIST_SEQ,
                    CREATE_USER_ID = :MRASPOTDEF_N.CREATE_USER_ID,
                    CREATE_TIME = :MRASPOTDEF_N.CREATE_TIME,
                    UPDATE_USER_ID = :MRASPOTDEF_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MRASPOTDEF_N.UPDATE_TIME
                WHERE FACTORY = :MRASPOTDEF_N.FACTORY
                    AND RES_ID = :MRASPOTDEF_N.RES_ID
                    AND SUBRES_ID = :MRASPOTDEF_N.SUBRES_ID
                    AND PORT_ID = :MRASPOTDEF_N.PORT_ID;
            break;

        case 2:
            EXEC SQL UPDATE MRASPOTDEF SET
                    RSV_STATE = :MRASPOTDEF_N.RSV_STATE,
                    CRR_ID = :MRASPOTDEF_N.CRR_ID,
                    UPDATE_USER_ID = :MRASPOTDEF_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MRASPOTDEF_N.UPDATE_TIME
                WHERE FACTORY = :MRASPOTDEF_N.FACTORY
                    AND RES_ID = :MRASPOTDEF_N.RES_ID
                    AND PORT_ID = :MRASPOTDEF_N.PORT_ID;
            break;

        case 3:
            EXEC SQL UPDATE MRASPOTDEF SET
                    RSV_STATE = :MRASPOTDEF_N.RSV_STATE,
                    UPDATE_USER_ID = :MRASPOTDEF_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MRASPOTDEF_N.UPDATE_TIME
                WHERE FACTORY = :MRASPOTDEF_N.FACTORY
                    AND RES_ID = :MRASPOTDEF_N.RES_ID
                    AND PORT_ID = :MRASPOTDEF_N.PORT_ID;
            break;

        case 4:
            EXEC SQL UPDATE MRASPOTDEF SET
                    CRR_ID = :MRASPOTDEF_N.CRR_ID,
                    UPDATE_USER_ID = :MRASPOTDEF_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MRASPOTDEF_N.UPDATE_TIME
                WHERE FACTORY = :MRASPOTDEF_N.FACTORY
                    AND RES_ID = :MRASPOTDEF_N.RES_ID
                    AND PORT_ID = :MRASPOTDEF_N.PORT_ID;
            break;

        case 5:
            EXEC SQL UPDATE MRASPOTDEF SET
                    CRR_ID = ' ',
                    UPDATE_USER_ID = :MRASPOTDEF_N.UPDATE_USER_ID,
                    UPDATE_TIME = :MRASPOTDEF_N.UPDATE_TIME
                WHERE FACTORY = :MRASPOTDEF_N.FACTORY
                  AND PORT_ID <> :MRASPOTDEF_N.PORT_ID
                  AND CRR_ID = :MRASPOTDEF_N.CRR_ID;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_mraspotdef", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_mraspotdef(int sel_type, struct MRASPOTDEF_TAG *MRASPOTDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MRASPOTDEF_N_TAG MRASPOTDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_mraspotdef(&MRASPOTDEF_N, MRASPOTDEF);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_MRASPOTDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    PORT_ID,
                    PORT_SEQ,
                    PORT_DESC,
                    TRS_STATE,
                    ASC_STATE,
                    ASC_OBJ_ID,
                    ACC_STATE,
                    RSV_STATE,
                    RSV_OBJ_ID,
                    LOT_ID,
                    CRR_ID,
                    BCR_STATUS_FLAG,
                    PORT_TYPE,
                    PORT_BATCH_FLAG,
                    ADD_PORT_TYPE,
                    PORT_LEVEL,
                    PORT_CMF_1,
                    PORT_CMF_2,
                    PORT_CMF_3,
                    PORT_CMF_4,
                    PORT_CMF_5,
                    PORT_CMF_6,
                    PORT_CMF_7,
                    PORT_CMF_8,
                    PORT_CMF_9,
                    PORT_CMF_10,
                    PORT_CMF_11,
                    PORT_CMF_12,
                    PORT_CMF_13,
                    PORT_CMF_14,
                    PORT_CMF_15,
                    PORT_CMF_16,
                    PORT_CMF_17,
                    PORT_CMF_18,
                    PORT_CMF_19,
                    PORT_CMF_20,
                    LAST_HIST_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRASPOTDEF
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SUBRES_ID ASC,
                    PORT_ID ASC;
            EXEC SQL OPEN CDB_MRASPOTDEF_CUR_1;
            break;

        case 2:
            EXEC SQL DECLARE CDB_MRASPOTDEF_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID,
                    SUBRES_ID,
                    PORT_ID,
                    PORT_SEQ,
                    PORT_DESC,
                    TRS_STATE,
                    ASC_STATE,
                    ASC_OBJ_ID,
                    ACC_STATE,
                    RSV_STATE,
                    RSV_OBJ_ID,
                    LOT_ID,
                    CRR_ID,
                    BCR_STATUS_FLAG,
                    PORT_TYPE,
                    PORT_BATCH_FLAG,
                    ADD_PORT_TYPE,
                    PORT_LEVEL,
                    PORT_CMF_1,
                    PORT_CMF_2,
                    PORT_CMF_3,
                    PORT_CMF_4,
                    PORT_CMF_5,
                    PORT_CMF_6,
                    PORT_CMF_7,
                    PORT_CMF_8,
                    PORT_CMF_9,
                    PORT_CMF_10,
                    PORT_CMF_11,
                    PORT_CMF_12,
                    PORT_CMF_13,
                    PORT_CMF_14,
                    PORT_CMF_15,
                    PORT_CMF_16,
                    PORT_CMF_17,
                    PORT_CMF_18,
                    PORT_CMF_19,
                    PORT_CMF_20,
                    LAST_HIST_SEQ,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM MRASPOTDEF
               WHERE PORT_CMF_6 = :MRASPOTDEF_N.PORT_CMF_6
                 AND PORT_ID <> :MRASPOTDEF_N.PORT_ID
                ORDER BY FACTORY ASC,
                    RES_ID ASC,
                    SUBRES_ID ASC,
                    PORT_ID ASC;
            EXEC SQL OPEN CDB_MRASPOTDEF_CUR_2;
            break;
            
        case 3:
            EXEC SQL DECLARE CDB_MRASPOTDEF_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    RES_ID
                FROM MRASPOTDEF
               WHERE FACTORY = :MRASPOTDEF_N.FACTORY
                GROUP BY FACTORY, RES_ID
                ORDER BY FACTORY ASC,
                    RES_ID ASC;

            EXEC SQL OPEN CDB_MRASPOTDEF_CUR_3;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_mraspotdef", sel_type);
}


