		case 2:
            EXEC SQL DECLARE CDB_IQCMBLKDAT_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    VENDOR_BARCD,
                    ACTION_TYPE,
                    VENDOR_CREDITOR,
                    SITE_ID,
