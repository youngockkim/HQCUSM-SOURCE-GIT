    MEMCPY_AN(IQCMBLKDAT_N->DELETE_COUNT, IQCMBLKDAT->DELETE_COUNT, sizeof(IQCMBLKDAT->DELETE_COUNT));
    MEMCPY_AN(IQCMBLKDAT_N->SQL_DML_COUNT, IQCMBLKDAT->SQL_DML_COUNT, sizeof(IQCMBLKDAT->SQL_DML_COUNT));
    MEMCPY_AN(IQCMBLKDAT_N->ZPICODE, IQCMBLKDAT->ZPICODE, sizeof(IQCMBLKDAT->ZPICODE));
