                :IQCMBLKDAT_N.DOC_ID,
                :IQCMBLKDAT_N.VENDOR_BARCD,
                :IQCMBLKDAT_N.ACTION_TYPE,
                :IQCMBLKDAT_N.VENDOR_CREDITOR,
                :IQCMBLKDAT_N.SITE_ID,
                :IQCMBLKDAT_N.STORAGE_LOCATION,
                :IQCMBLKDAT_N.MATE_NO,
                :IQCMBLKDAT_N.MATE_DESCRIPTION,
                :IQCMBLKDAT_N.BLOCK_DESCRIPTION,
                :IQCMBLKDAT_N.BLOCK_STATUS,
                :IQCMBLKDAT_N.INF_TIME,
                :IQCMBLKDAT_N.INF_PROC_TIME,
                :IQCMBLKDAT_N.CMF_1,
                :IQCMBLKDAT_N.CMF_2,
                :IQCMBLKDAT_N.CMF_3,
                :IQCMBLKDAT_N.CMF_4,
                :IQCMBLKDAT_N.CMF_5,
                :IQCMBLKDAT_N.DATA_FLAG,
                :IQCMBLKDAT_N.UPDATE_TIME,
                :IQCMBLKDAT_N.UPDATE_COUNT,
                :IQCMBLKDAT_N.INSERT_COUNT,
                :IQCMBLKDAT_N.DELETE_COUNT,
                :IQCMBLKDAT_N.SQL_DML_COUNT,
                :IQCMBLKDAT_N.ZPICODE,
                :IQCMBLKDAT_N.ZPIMSGID,
                :IQCMBLKDAT_N.RETURN_TYPE,
                :IQCMBLKDAT_N.RETURN_MSG,
                :IQCMBLKDAT_N.ZIFERNAM,
                :IQCMBLKDAT_N.ZIFDATE,
                :IQCMBLKDAT_N.ZIFTIME,
                :IQCMBLKDAT_N.ZPISTAT,
                :IQCMBLKDAT_N.ZPIMSG;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_iqcmblkdat(&IQCMBLKDAT_N, IQCMBLKDAT);
    }

    DB_stop_query_timer("CDB_fetch_iqcmblkdat", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_iqcmblkdat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IQCMBLKDAT_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IQCMBLKDAT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_iqcmblkdat", sel_type);
}


/* Initialize Function */
void CDB_init_iqcmblkdat(struct IQCMBLKDAT_TAG *IQCMBLKDAT)
{
    /* memset by Space */
    memset(IQCMBLKDAT, ' ', sizeof(struct IQCMBLKDAT_TAG));
    
}


/* Add Null Function */
void CDB_add_null_iqcmblkdat(struct IQCMBLKDAT_N_TAG *IQCMBLKDAT_N, struct IQCMBLKDAT_TAG *IQCMBLKDAT)
{
