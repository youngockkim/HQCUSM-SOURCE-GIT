					PVM_SN,
					PCU_SN,
					ACM_SN
                FROM CWIPLOTPAK
				WHERE PALLET_ID = :CWIPLOTPAK_N.PALLET_ID
                ORDER BY PAK_SEQ DESC;
            EXEC SQL OPEN CDB_CWIPLOTPAK_CUR_2;
            break;

		case 3:
