                sprintf(sql + strlen(sql),   "FROM ( SELECT");                
                sprintf(sql + strlen(sql),   "          PAL.FACTORY, ");
                sprintf(sql + strlen(sql),   "          PAL.LOT_ID, ");
                sprintf(sql + strlen(sql),   "          PAL.PALLET_ID, ");
                sprintf(sql + strlen(sql),   "          HIS.OPER, ");
                sprintf(sql + strlen(sql),   "          TO_CHAR(HIS.HIST_SEQ) AS CMF_2, ");
                sprintf(sql + strlen(sql),   "          ROW_NUMBER() OVER (PARTITION BY PAL.FACTORY, PAL.LOT_ID, PAL.PALLET_ID ORDER BY HIS.HIST_SEQ DESC) AS RN ");
                sprintf(sql + strlen(sql),   "          FROM CWIPLOTPAK PAL"); 
                sprintf(sql + strlen(sql),   "          INNER JOIN MWIPLOTSTS LOT ON PAL.LOT_ID = LOT.LOT_ID"); 
                sprintf(sql + strlen(sql),   "          INNER JOIN MWIPLOTHIS HIS ON LOT.LOT_ID = HIS.LOT_ID"); 
                sprintf(sql + strlen(sql),   "          WHERE 1 = 1"); 
                make_valid_quote(ts, CWIPLOTPAK_N.FACTORY);
                sprintf(sql + strlen(sql),   "            AND PAL.FACTORY = '%s' ", ts);
                make_valid_quote(ts, CWIPLOTPAK_N.PALLET_ID);
                sprintf(sql + strlen(sql),   "            AND PAL.PALLET_ID = '%s' ", ts);
                sprintf(sql + strlen(sql),   "            AND HIS.HIST_DEL_FLAG = ' '"); 
                sprintf(sql + strlen(sql),   "            AND HIS.OPER NOT IN ('M4000', 'M3120')"); 
                sprintf(sql + strlen(sql),   ") WHERE RN = 1"); 
                sprintf(sql + strlen(sql),   "ORDER BY OPER ASC"); 

            
            EXEC SQL PREPARE S FROM :sql;
            EXEC SQL DECLARE CDB_CWIPLOTPAK_CUR_4 CURSOR FOR S; 
            EXEC SQL OPEN CDB_CWIPLOTPAK_CUR_4;    

            
			LOG_head("DB");
            LOG_add("len", 0, strlen(sql));
            LOG_add("sql", 4, strlen(sql), sql);
            COM_log_write('I', 'S' , 'S');
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwiplotpak", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_cwiplotpak(int sel_type, struct CWIPLOTPAK_TAG *CWIPLOTPAK)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPLOTPAK_N_TAG CWIPLOTPAK_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CWIPLOTPAK_CUR_1 INTO
                :CWIPLOTPAK_N.FACTORY,
                :CWIPLOTPAK_N.LOT_ID,
                :CWIPLOTPAK_N.PALLET_ID,
                :CWIPLOTPAK_N.PAK_SEQ,
                :CWIPLOTPAK_N.MAT_ID,
                :CWIPLOTPAK_N.FLOW,
                :CWIPLOTPAK_N.OPER,
                :CWIPLOTPAK_N.ORDER_ID,
                :CWIPLOTPAK_N.LINE_ID,
                :CWIPLOTPAK_N.RES_ID,
                :CWIPLOTPAK_N.STATUS_FLAG,
                :CWIPLOTPAK_N.PAK_TYPE,
                :CWIPLOTPAK_N.PAK_TIME,
                :CWIPLOTPAK_N.GRADE,
                :CWIPLOTPAK_N.POWER,
                :CWIPLOTPAK_N.CMF_1,
                :CWIPLOTPAK_N.CMF_2,
                :CWIPLOTPAK_N.CMF_3,
                :CWIPLOTPAK_N.CMF_4,
                :CWIPLOTPAK_N.CMF_5,
                :CWIPLOTPAK_N.HIST_SEQ,
                :CWIPLOTPAK_N.CREATE_TIME,
                :CWIPLOTPAK_N.LAST_TRAN_TIME,
				:CWIPLOTPAK_N.PVM_PN,
				:CWIPLOTPAK_N.PVM_SN,
				:CWIPLOTPAK_N.PCU_SN,
				:CWIPLOTPAK_N.ACM_SN;
            break;

		case 2:
            EXEC SQL FETCH CDB_CWIPLOTPAK_CUR_2 INTO
                :CWIPLOTPAK_N.FACTORY,
                :CWIPLOTPAK_N.LOT_ID,
                :CWIPLOTPAK_N.PALLET_ID,
                :CWIPLOTPAK_N.PAK_SEQ,
                :CWIPLOTPAK_N.MAT_ID,
                :CWIPLOTPAK_N.FLOW,
                :CWIPLOTPAK_N.OPER,
                :CWIPLOTPAK_N.ORDER_ID,
                :CWIPLOTPAK_N.LINE_ID,
                :CWIPLOTPAK_N.RES_ID,
                :CWIPLOTPAK_N.STATUS_FLAG,
                :CWIPLOTPAK_N.PAK_TYPE,
                :CWIPLOTPAK_N.PAK_TIME,
                :CWIPLOTPAK_N.GRADE,
                :CWIPLOTPAK_N.POWER,
                :CWIPLOTPAK_N.CMF_1,
                :CWIPLOTPAK_N.CMF_2,
                :CWIPLOTPAK_N.CMF_3,
                :CWIPLOTPAK_N.CMF_4,
                :CWIPLOTPAK_N.CMF_5,
                :CWIPLOTPAK_N.HIST_SEQ,
                :CWIPLOTPAK_N.CREATE_TIME,
                :CWIPLOTPAK_N.LAST_TRAN_TIME,
				:CWIPLOTPAK_N.PVM_PN,
				:CWIPLOTPAK_N.PVM_SN,
				:CWIPLOTPAK_N.PCU_SN,
				:CWIPLOTPAK_N.ACM_SN;
            break;

		case 3:
            EXEC SQL FETCH CDB_CWIPLOTPAK_CUR_3 INTO
                :CWIPLOTPAK_N.FACTORY,
                :CWIPLOTPAK_N.LOT_ID,
                :CWIPLOTPAK_N.PALLET_ID,
                :CWIPLOTPAK_N.PAK_SEQ,
                :CWIPLOTPAK_N.MAT_ID,
                :CWIPLOTPAK_N.FLOW,
                :CWIPLOTPAK_N.OPER,
                :CWIPLOTPAK_N.ORDER_ID,
                :CWIPLOTPAK_N.LINE_ID,
                :CWIPLOTPAK_N.RES_ID,
                :CWIPLOTPAK_N.STATUS_FLAG,
                :CWIPLOTPAK_N.PAK_TYPE,
                :CWIPLOTPAK_N.PAK_TIME,
                :CWIPLOTPAK_N.GRADE,
                :CWIPLOTPAK_N.POWER,
                :CWIPLOTPAK_N.CMF_1,
                :CWIPLOTPAK_N.CMF_2,
                :CWIPLOTPAK_N.CMF_3,
                :CWIPLOTPAK_N.CMF_4,
                :CWIPLOTPAK_N.CMF_5,
                :CWIPLOTPAK_N.HIST_SEQ,
                :CWIPLOTPAK_N.CREATE_TIME,
                :CWIPLOTPAK_N.LAST_TRAN_TIME,
				:CWIPLOTPAK_N.PVM_PN,
				:CWIPLOTPAK_N.PVM_SN,
				:CWIPLOTPAK_N.PCU_SN,
				:CWIPLOTPAK_N.ACM_SN;
            break;

		/* [ERP PROJECT] [ERP 23.05.23] ABNLOG Add  */
		case 4:
            EXEC SQL FETCH CDB_CWIPLOTPAK_CUR_4 INTO
                :CWIPLOTPAK_N.FACTORY,
                :CWIPLOTPAK_N.LOT_ID,
                :CWIPLOTPAK_N.PALLET_ID,
                :CWIPLOTPAK_N.OPER,
                :CWIPLOTPAK_N.CMF_2;
            break;
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cwiplotpak(&CWIPLOTPAK_N, CWIPLOTPAK);
    }

    DB_stop_query_timer("CDB_fetch_cwiplotpak", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cwiplotpak(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CWIPLOTPAK_CUR_1;
            break;
		
		case 2:
            EXEC SQL CLOSE CDB_CWIPLOTPAK_CUR_2;
            break;

		case 3:
            EXEC SQL CLOSE CDB_CWIPLOTPAK_CUR_3;
            break;

		/* [ERP PROJECT] [ERP 23.05.23] ABNLOG Add  */
		case 4:
            EXEC SQL CLOSE CDB_CWIPLOTPAK_CUR_4;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwiplotpak", sel_type);
}


/* Initialize Function */
void CDB_init_cwiplotpak(struct CWIPLOTPAK_TAG *CWIPLOTPAK)
{
    /* memset by Space */
    memset(CWIPLOTPAK, ' ', sizeof(struct CWIPLOTPAK_TAG));
    
    CWIPLOTPAK->PAK_SEQ = 0;
    CWIPLOTPAK->HIST_SEQ = 0;
}


/* Add Null Function */
void CDB_add_null_cwiplotpak(struct CWIPLOTPAK_N_TAG *CWIPLOTPAK_N, struct CWIPLOTPAK_TAG *CWIPLOTPAK)
{
    /* memset by NULL */
    memset(CWIPLOTPAK_N, '\0', sizeof(struct CWIPLOTPAK_N_TAG));
    
    MEMCPY_AN(CWIPLOTPAK_N->FACTORY, CWIPLOTPAK->FACTORY, sizeof(CWIPLOTPAK->FACTORY));
    MEMCPY_AN(CWIPLOTPAK_N->LOT_ID, CWIPLOTPAK->LOT_ID, sizeof(CWIPLOTPAK->LOT_ID));
    MEMCPY_AN(CWIPLOTPAK_N->PALLET_ID, CWIPLOTPAK->PALLET_ID, sizeof(CWIPLOTPAK->PALLET_ID));
    CWIPLOTPAK_N->PAK_SEQ = CWIPLOTPAK->PAK_SEQ;
    MEMCPY_AN(CWIPLOTPAK_N->MAT_ID, CWIPLOTPAK->MAT_ID, sizeof(CWIPLOTPAK->MAT_ID));
    MEMCPY_AN(CWIPLOTPAK_N->FLOW, CWIPLOTPAK->FLOW, sizeof(CWIPLOTPAK->FLOW));
    MEMCPY_AN(CWIPLOTPAK_N->OPER, CWIPLOTPAK->OPER, sizeof(CWIPLOTPAK->OPER));
    MEMCPY_AN(CWIPLOTPAK_N->ORDER_ID, CWIPLOTPAK->ORDER_ID, sizeof(CWIPLOTPAK->ORDER_ID));
    MEMCPY_AN(CWIPLOTPAK_N->LINE_ID, CWIPLOTPAK->LINE_ID, sizeof(CWIPLOTPAK->LINE_ID));
    MEMCPY_AN(CWIPLOTPAK_N->RES_ID, CWIPLOTPAK->RES_ID, sizeof(CWIPLOTPAK->RES_ID));
    CWIPLOTPAK_N->STATUS_FLAG[0] = CWIPLOTPAK->STATUS_FLAG;
    MEMCPY_AN(CWIPLOTPAK_N->PAK_TYPE, CWIPLOTPAK->PAK_TYPE, sizeof(CWIPLOTPAK->PAK_TYPE));
    MEMCPY_AN(CWIPLOTPAK_N->PAK_TIME, CWIPLOTPAK->PAK_TIME, sizeof(CWIPLOTPAK->PAK_TIME));
    MEMCPY_AN(CWIPLOTPAK_N->GRADE, CWIPLOTPAK->GRADE, sizeof(CWIPLOTPAK->GRADE));
    MEMCPY_AN(CWIPLOTPAK_N->POWER, CWIPLOTPAK->POWER, sizeof(CWIPLOTPAK->POWER));
    MEMCPY_AN(CWIPLOTPAK_N->CMF_1, CWIPLOTPAK->CMF_1, sizeof(CWIPLOTPAK->CMF_1));
    MEMCPY_AN(CWIPLOTPAK_N->CMF_2, CWIPLOTPAK->CMF_2, sizeof(CWIPLOTPAK->CMF_2));
    MEMCPY_AN(CWIPLOTPAK_N->CMF_3, CWIPLOTPAK->CMF_3, sizeof(CWIPLOTPAK->CMF_3));
    MEMCPY_AN(CWIPLOTPAK_N->CMF_4, CWIPLOTPAK->CMF_4, sizeof(CWIPLOTPAK->CMF_4));
    MEMCPY_AN(CWIPLOTPAK_N->CMF_5, CWIPLOTPAK->CMF_5, sizeof(CWIPLOTPAK->CMF_5));
    CWIPLOTPAK_N->HIST_SEQ = CWIPLOTPAK->HIST_SEQ;
    MEMCPY_AN(CWIPLOTPAK_N->CREATE_TIME, CWIPLOTPAK->CREATE_TIME, sizeof(CWIPLOTPAK->CREATE_TIME));
    MEMCPY_AN(CWIPLOTPAK_N->LAST_TRAN_TIME, CWIPLOTPAK->LAST_TRAN_TIME, sizeof(CWIPLOTPAK->LAST_TRAN_TIME));
	MEMCPY_AN(CWIPLOTPAK_N->PVM_PN, CWIPLOTPAK->PVM_PN, sizeof(CWIPLOTPAK->PVM_PN));
	MEMCPY_AN(CWIPLOTPAK_N->PVM_SN, CWIPLOTPAK->PVM_SN, sizeof(CWIPLOTPAK->PVM_SN));
	MEMCPY_AN(CWIPLOTPAK_N->PCU_SN, CWIPLOTPAK->PCU_SN, sizeof(CWIPLOTPAK->PCU_SN));
	MEMCPY_AN(CWIPLOTPAK_N->ACM_SN, CWIPLOTPAK->ACM_SN, sizeof(CWIPLOTPAK->ACM_SN));
}


/* Del Null Function */
void CDB_del_null_cwiplotpak(struct CWIPLOTPAK_N_TAG *CWIPLOTPAK_N, struct CWIPLOTPAK_TAG *CWIPLOTPAK)
{
    MEMCPY_DN(CWIPLOTPAK->FACTORY, CWIPLOTPAK_N->FACTORY, sizeof(CWIPLOTPAK->FACTORY));
    MEMCPY_DN(CWIPLOTPAK->LOT_ID, CWIPLOTPAK_N->LOT_ID, sizeof(CWIPLOTPAK->LOT_ID));
    MEMCPY_DN(CWIPLOTPAK->PALLET_ID, CWIPLOTPAK_N->PALLET_ID, sizeof(CWIPLOTPAK->PALLET_ID));
    CWIPLOTPAK->PAK_SEQ = CWIPLOTPAK_N->PAK_SEQ;
    MEMCPY_DN(CWIPLOTPAK->MAT_ID, CWIPLOTPAK_N->MAT_ID, sizeof(CWIPLOTPAK->MAT_ID));
    MEMCPY_DN(CWIPLOTPAK->FLOW, CWIPLOTPAK_N->FLOW, sizeof(CWIPLOTPAK->FLOW));
    MEMCPY_DN(CWIPLOTPAK->OPER, CWIPLOTPAK_N->OPER, sizeof(CWIPLOTPAK->OPER));
    MEMCPY_DN(CWIPLOTPAK->ORDER_ID, CWIPLOTPAK_N->ORDER_ID, sizeof(CWIPLOTPAK->ORDER_ID));
    MEMCPY_DN(CWIPLOTPAK->LINE_ID, CWIPLOTPAK_N->LINE_ID, sizeof(CWIPLOTPAK->LINE_ID));
    MEMCPY_DN(CWIPLOTPAK->RES_ID, CWIPLOTPAK_N->RES_ID, sizeof(CWIPLOTPAK->RES_ID));
    CWIPLOTPAK->STATUS_FLAG = CWIPLOTPAK_N->STATUS_FLAG[0];
    MEMCPY_DN(CWIPLOTPAK->PAK_TYPE, CWIPLOTPAK_N->PAK_TYPE, sizeof(CWIPLOTPAK->PAK_TYPE));
    MEMCPY_DN(CWIPLOTPAK->PAK_TIME, CWIPLOTPAK_N->PAK_TIME, sizeof(CWIPLOTPAK->PAK_TIME));
    MEMCPY_DN(CWIPLOTPAK->GRADE, CWIPLOTPAK_N->GRADE, sizeof(CWIPLOTPAK->GRADE));
    MEMCPY_DN(CWIPLOTPAK->POWER, CWIPLOTPAK_N->POWER, sizeof(CWIPLOTPAK->POWER));
    MEMCPY_DN(CWIPLOTPAK->CMF_1, CWIPLOTPAK_N->CMF_1, sizeof(CWIPLOTPAK->CMF_1));
    MEMCPY_DN(CWIPLOTPAK->CMF_2, CWIPLOTPAK_N->CMF_2, sizeof(CWIPLOTPAK->CMF_2));
    MEMCPY_DN(CWIPLOTPAK->CMF_3, CWIPLOTPAK_N->CMF_3, sizeof(CWIPLOTPAK->CMF_3));
    MEMCPY_DN(CWIPLOTPAK->CMF_4, CWIPLOTPAK_N->CMF_4, sizeof(CWIPLOTPAK->CMF_4));
    MEMCPY_DN(CWIPLOTPAK->CMF_5, CWIPLOTPAK_N->CMF_5, sizeof(CWIPLOTPAK->CMF_5));
    CWIPLOTPAK->HIST_SEQ = CWIPLOTPAK_N->HIST_SEQ;
    MEMCPY_DN(CWIPLOTPAK->CREATE_TIME, CWIPLOTPAK_N->CREATE_TIME, sizeof(CWIPLOTPAK->CREATE_TIME));
    MEMCPY_DN(CWIPLOTPAK->LAST_TRAN_TIME, CWIPLOTPAK_N->LAST_TRAN_TIME, sizeof(CWIPLOTPAK->LAST_TRAN_TIME));
	MEMCPY_DN(CWIPLOTPAK->PVM_PN, CWIPLOTPAK_N->PVM_PN, sizeof(CWIPLOTPAK->PVM_PN));
	MEMCPY_DN(CWIPLOTPAK->PVM_SN, CWIPLOTPAK_N->PVM_SN, sizeof(CWIPLOTPAK->PVM_SN));
	MEMCPY_DN(CWIPLOTPAK->PCU_SN, CWIPLOTPAK_N->PCU_SN, sizeof(CWIPLOTPAK->PCU_SN));
	MEMCPY_DN(CWIPLOTPAK->ACM_SN, CWIPLOTPAK_N->ACM_SN, sizeof(CWIPLOTPAK->ACM_SN));
}


