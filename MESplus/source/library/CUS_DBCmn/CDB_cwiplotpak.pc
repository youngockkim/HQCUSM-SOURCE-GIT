                FROM CWIPLOTPAK
                ORDER BY FACTORY ASC,
                    LOT_ID ASC;
            EXEC SQL OPEN CDB_CWIPLOTPAK_CUR_1;
            break;

			case 2:
            EXEC SQL DECLARE CDB_CWIPLOTPAK_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOT_ID,
                    PALLET_ID,
                    PAK_SEQ,
                    MAT_ID,
                    FLOW,
