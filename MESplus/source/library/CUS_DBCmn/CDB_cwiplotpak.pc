    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPLOTPAK_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOT_ID,
                    PALLET_ID,
                    PAK_SEQ,
                    MAT_ID,
                    FLOW,
                    OPER,
                    ORDER_ID,
                    LINE_ID,
