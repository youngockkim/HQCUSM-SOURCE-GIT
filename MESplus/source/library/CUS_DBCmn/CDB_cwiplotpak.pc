/* SQL SELECT_SCALAR Function */
double CDB_select_cwiplotpak_scalar(int sel_type, struct CWIPLOTPAK_TAG *CWIPLOTPAK)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPLOTPAK_N_TAG CWIPLOTPAK_N;
        double d_value;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwiplotpak(&CWIPLOTPAK_N, CWIPLOTPAK);
    DB_error_code = 0;
    d_value = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPLOTPAK
                WHERE FACTORY = :CWIPLOTPAK_N.FACTORY
                    AND LOT_ID = :CWIPLOTPAK_N.LOT_ID;
            break;

		case 2:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPLOTPAK
                WHERE FACTORY = :CWIPLOTPAK_N.FACTORY
                  AND PALLET_ID = :CWIPLOTPAK_N.PALLET_ID;
            break;

		case 3:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPLOTPAK
                WHERE FACTORY = :CWIPLOTPAK_N.FACTORY
                  AND LOT_ID = :CWIPLOTPAK_N.LOT_ID
				  AND STATUS_FLAG = :CWIPLOTPAK_N.STATUS_FLAG;
            break;

		case 4:
            EXEC SQL 
			SELECT COUNT(DISTINCT DATA_1) 
			INTO :d_value
			FROM MGCMLAGDAT
			WHERE FACTORY =  :CWIPLOTPAK_N.FACTORY
			AND TABLE_NAME = '@PACKING'
			AND KEY_1 IN ( SELECT A.MAT_ID FROM MWIPLOTSTS A, CWIPLOTPAK B
							WHERE A.FACTORY = B.FACTORY
							AND A.LOT_ID = B.LOT_ID
							AND B.PALLET_ID = :CWIPLOTPAK_N.PALLET_ID
							AND B.STATUS_FLAG = :CWIPLOTPAK_N.STATUS_FLAG ) ;
            break;

		case 5:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPLOTPAK
                WHERE FACTORY = :CWIPLOTPAK_N.FACTORY
                  AND PCU_SN = :CWIPLOTPAK_N.PCU_SN
				  AND STATUS_FLAG = 'C';
            break;

		case 6:
            EXEC SQL SELECT count(*) 
                INTO :d_value
                FROM CWIPLOTPAK
                WHERE FACTORY = :CWIPLOTPAK_N.FACTORY
				AND LOT_ID = :CWIPLOTPAK_N.LOT_ID
                AND PALLET_ID = :CWIPLOTPAK_N.PALLET_ID;
            break;
        case 7:
            EXEC SQL SELECT count(LOT_ID) 
                INTO :d_value
                FROM CWIPLOTPAK
                WHERE FACTORY = :CWIPLOTPAK_N.FACTORY
                AND PALLET_ID = :CWIPLOTPAK_N.PALLET_ID;
            break;
        case 8:
            EXEC SQL SELECT count(LOT_ID) 
                INTO :d_value
                FROM (
                        SELECT PAK.LOT_ID
                        FROM CWIPLOTPAK PAK
                        WHERE  PAK.FACTORY = :CWIPLOTPAK_N.FACTORY
                               AND PAK.LOT_ID = :CWIPLOTPAK_N.LOT_ID
                        UNION 
                        SELECT HIS.LOT_ID
                          FROM CWIPPAKHIS HIS
                         WHERE HIS.FACTORY = :CWIPLOTPAK_N.FACTORY
                               AND HIS.LOT_ID = :CWIPLOTPAK_N.LOT_ID
                    );

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_select_cwiplotpak_scalar", sel_type);

    return d_value;
}


