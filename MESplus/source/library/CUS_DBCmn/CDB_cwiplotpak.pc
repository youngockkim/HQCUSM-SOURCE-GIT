/* SQL SELECT Function */
void CDB_select_cwiplotpak(int sel_type, struct CWIPLOTPAK_TAG *CWIPLOTPAK)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPLOTPAK_N_TAG CWIPLOTPAK_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwiplotpak(&CWIPLOTPAK_N, CWIPLOTPAK);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL SELECT 
                    FACTORY,
                    LOT_ID,
                    PALLET_ID,
                    PAK_SEQ,
                    MAT_ID,
                    FLOW,
                    OPER,
                    ORDER_ID,
                    LINE_ID,
                    RES_ID,
                    STATUS_FLAG,
                    PAK_TYPE,
                    PAK_TIME,
                    GRADE,
                    POWER,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    HIST_SEQ,
                    CREATE_TIME,
                    LAST_TRAN_TIME,
					PVM_PN,
					PVM_SN,
					PCU_SN,
					ACM_SN
                INTO 
                    :CWIPLOTPAK_N.FACTORY,
                    :CWIPLOTPAK_N.LOT_ID,
                    :CWIPLOTPAK_N.PALLET_ID,
                    :CWIPLOTPAK_N.PAK_SEQ,
                    :CWIPLOTPAK_N.MAT_ID,
                    :CWIPLOTPAK_N.FLOW,
                    :CWIPLOTPAK_N.OPER,
                    :CWIPLOTPAK_N.ORDER_ID,
                    :CWIPLOTPAK_N.LINE_ID,
                    :CWIPLOTPAK_N.RES_ID,
                    :CWIPLOTPAK_N.STATUS_FLAG,
                    :CWIPLOTPAK_N.PAK_TYPE,
                    :CWIPLOTPAK_N.PAK_TIME,
                    :CWIPLOTPAK_N.GRADE,
                    :CWIPLOTPAK_N.POWER,
                    :CWIPLOTPAK_N.CMF_1,
                    :CWIPLOTPAK_N.CMF_2,
                    :CWIPLOTPAK_N.CMF_3,
                    :CWIPLOTPAK_N.CMF_4,
                    :CWIPLOTPAK_N.CMF_5,
                    :CWIPLOTPAK_N.HIST_SEQ,
                    :CWIPLOTPAK_N.CREATE_TIME,
                    :CWIPLOTPAK_N.LAST_TRAN_TIME,
					:CWIPLOTPAK_N.PVM_PN,
					:CWIPLOTPAK_N.PVM_SN,
					:CWIPLOTPAK_N.PCU_SN,
					:CWIPLOTPAK_N.ACM_SN
                FROM CWIPLOTPAK
                WHERE FACTORY = :CWIPLOTPAK_N.FACTORY
                    AND LOT_ID = :CWIPLOTPAK_N.LOT_ID;
            break;
		
		case 2:
			/* PAK TYPE -> TIMESTAMP, HIST_SEQ -> LOTCOUNT */
            EXEC SQL SELECT 
                    to_char(SYSTIMESTAMP, 'YYYYMMDDHH24MISS.FF6'),
                    COUNT(*)
                INTO 
                    :CWIPLOTPAK_N.PAK_TYPE,
                    :CWIPLOTPAK_N.HIST_SEQ
                FROM CWIPLOTPAK
                WHERE FACTORY = :CWIPLOTPAK_N.FACTORY
                    AND PALLET_ID = :CWIPLOTPAK_N.PALLET_ID;
            break;

		case 3:
            EXEC SQL SELECT 
                    TRIM(MAT_ID),
					TRIM(CMF_5)
                INTO 
                    :CWIPLOTPAK_N.MAT_ID,
					:CWIPLOTPAK_N.CMF_5
                FROM CWIPLOTPAK
                WHERE FACTORY = :CWIPLOTPAK_N.FACTORY
                    AND PALLET_ID = :CWIPLOTPAK_N.PALLET_ID
					AND ROWNUM = 1;
            break;

		case 4:
			EXEC SQL SELECT
                   :CWIPLOTPAK_N.CMF_1 || NVL(MAX(to_number(SUBSTR(PALLET_ID, 23 ,4)))+1, 701)
                INTO 
                    :CWIPLOTPAK_N.CMF_3
                FROM CWIPLOTPAK
                WHERE FACTORY = :CWIPLOTPAK_N.FACTORY
					AND PALLET_ID LIKE :CWIPLOTPAK_N.PALLET_ID || '%'
					AND PALLET_ID NOT LIKE :CWIPLOTPAK_N.PALLET_ID || '6%'; 

            break;

		case 5:
			EXEC SQL SELECT
				   FACTORY,
				   PALLET_ID,
                   DECODE(MIN(GRADE), 'G01', MAX(GRADE),'G02',  MAX(GRADE),'G03',MAX(GRADE),'G04', MAX(GRADE), 'XXX') GRADE,
				   MAX(MAT_ID),
				   COUNT(LOT_ID)
				INTO 
					:CWIPLOTPAK_N.FACTORY,
					:CWIPLOTPAK_N.PALLET_ID,
                    :CWIPLOTPAK_N.GRADE,
					:CWIPLOTPAK_N.MAT_ID,
                    :CWIPLOTPAK_N.HIST_SEQ
                FROM CWIPLOTPAK
                WHERE FACTORY = :CWIPLOTPAK_N.FACTORY
					AND PALLET_ID = :CWIPLOTPAK_N.PALLET_ID 
					AND STATUS_FLAG = :CWIPLOTPAK_N.STATUS_FLAG 
				GROUP BY FACTORY, PALLET_ID;
            break;
		case 6:
			EXEC SQL SELECT
                   :CWIPLOTPAK_N.CMF_1 || NVL(MAX(to_number(SUBSTR(PALLET_ID, 23 ,4)))+1, 601)
                INTO 
                    :CWIPLOTPAK_N.CMF_3
                FROM CWIPLOTPAK
                WHERE FACTORY = :CWIPLOTPAK_N.FACTORY
					  AND PALLET_ID LIKE :CWIPLOTPAK_N.PALLET_ID || '6%'; 

            break;
		case 7:
			EXEC SQL SELECT
                   :CWIPLOTPAK_N.PALLET_ID
                INTO 
                    :CWIPLOTPAK_N.CMF_3
                FROM CWIPLOTPAK
                WHERE FACTORY = :CWIPLOTPAK_N.FACTORY
					  AND PALLET_ID LIKE :CWIPLOTPAK_N.PALLET_ID || '699'; 

            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cwiplotpak(&CWIPLOTPAK_N, CWIPLOTPAK);
    }

    DB_stop_query_timer("CDB_select_cwiplotpak", sel_type);
}


