                :IWIPMATDEF_N.PROD_SUBTYPE,
                :IWIPMATDEF_N.PROD_SUBTYPE_DESC,
                :IWIPMATDEF_N.PROD_DETAILTYPE,
                :IWIPMATDEF_N.PROD_DETAILTYPE_DESC,
                :IWIPMATDEF_N.PROD_CERT,
                :IWIPMATDEF_N.PROD_CERT_DESC,
                :IWIPMATDEF_N.BACKFLUSH_YN,
                :IWIPMATDEF_N.INSPECT_YN,
                :IWIPMATDEF_N.DEL_YN,
                :IWIPMATDEF_N.ITEM_CAT_GRP,
                :IWIPMATDEF_N.CELL_QTY,
                :IWIPMATDEF_N.MONO_POLY,
                :IWIPMATDEF_N.INF_TIME,
                :IWIPMATDEF_N.INF_PROC_TIME,
                :IWIPMATDEF_N.CMF_1,
                :IWIPMATDEF_N.CMF_2,
                :IWIPMATDEF_N.CMF_3,
                :IWIPMATDEF_N.CMF_4,
                :IWIPMATDEF_N.CMF_5,
                :IWIPMATDEF_N.DATA_FLAG,
                :IWIPMATDEF_N.UPDATE_COUNT,
                :IWIPMATDEF_N.INSERT_COUNT,
                :IWIPMATDEF_N.DELETE_COUNT,
                :IWIPMATDEF_N.SQL_DML_COUNT,
                :IWIPMATDEF_N.ZPICODE,
                :IWIPMATDEF_N.ZPIMSGID,
                :IWIPMATDEF_N.RETURN_TYPE,
                :IWIPMATDEF_N.RETURN_MSG,
                :IWIPMATDEF_N.ZIFERNAM,
                :IWIPMATDEF_N.ZIFDATE,
                :IWIPMATDEF_N.ZIFTIME,
                :IWIPMATDEF_N.ZPISTAT,
                :IWIPMATDEF_N.ZPIMSG;
            break;

		case 2:
            EXEC SQL FETCH CDB_IWIPMATDEF_CUR_2 INTO
                :IWIPMATDEF_N.DOC_ID,
                :IWIPMATDEF_N.SITE_ID,
                :IWIPMATDEF_N.MATE_NO,
                :IWIPMATDEF_N.MATE_NM,
                :IWIPMATDEF_N.UNIT_ID,
                :IWIPMATDEF_N.SAP_MATE_TYPE,
                :IWIPMATDEF_N.MATE_CLASS,
                :IWIPMATDEF_N.MATE_TYPE,
                :IWIPMATDEF_N.MATE_TYPE_DESC,
                :IWIPMATDEF_N.MATE_SUBTYPE,
                :IWIPMATDEF_N.MATE_SUBTYPE_DESC,
                :IWIPMATDEF_N.PROD_TYPE,
                :IWIPMATDEF_N.PROD_TYPE_DESC,
                :IWIPMATDEF_N.PROD_SUBTYPE,
                :IWIPMATDEF_N.PROD_SUBTYPE_DESC,
                :IWIPMATDEF_N.PROD_DETAILTYPE,
                :IWIPMATDEF_N.PROD_DETAILTYPE_DESC,
                :IWIPMATDEF_N.PROD_CERT,
                :IWIPMATDEF_N.PROD_CERT_DESC,
                :IWIPMATDEF_N.BACKFLUSH_YN,
                :IWIPMATDEF_N.INSPECT_YN,
                :IWIPMATDEF_N.DEL_YN,
                :IWIPMATDEF_N.ITEM_CAT_GRP,
                :IWIPMATDEF_N.CELL_QTY,
                :IWIPMATDEF_N.MONO_POLY,
                :IWIPMATDEF_N.INF_TIME,
                :IWIPMATDEF_N.INF_PROC_TIME,
                :IWIPMATDEF_N.CMF_1,
                :IWIPMATDEF_N.CMF_2,
                :IWIPMATDEF_N.CMF_3,
                :IWIPMATDEF_N.CMF_4,
                :IWIPMATDEF_N.CMF_5,
                :IWIPMATDEF_N.DATA_FLAG,
                :IWIPMATDEF_N.UPDATE_COUNT,
                :IWIPMATDEF_N.INSERT_COUNT,
                :IWIPMATDEF_N.DELETE_COUNT,
                :IWIPMATDEF_N.SQL_DML_COUNT,
                :IWIPMATDEF_N.ZPICODE,
                :IWIPMATDEF_N.ZPIMSGID,
                :IWIPMATDEF_N.RETURN_TYPE,
                :IWIPMATDEF_N.RETURN_MSG,
                :IWIPMATDEF_N.ZIFERNAM,
                :IWIPMATDEF_N.ZIFDATE,
                :IWIPMATDEF_N.ZIFTIME,
                :IWIPMATDEF_N.ZPISTAT,
                :IWIPMATDEF_N.ZPIMSG;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_iwipmatdef(&IWIPMATDEF_N, IWIPMATDEF);
    }

    DB_stop_query_timer("CDB_fetch_iwipmatdef", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_iwipmatdef(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IWIPMATDEF_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IWIPMATDEF_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_iwipmatdef", sel_type);
}


/* Initialize Function */
void CDB_init_iwipmatdef(struct IWIPMATDEF_TAG *IWIPMATDEF)
{
    /* memset by Space */
    memset(IWIPMATDEF, ' ', sizeof(struct IWIPMATDEF_TAG));
    
}


/* Add Null Function */
void CDB_add_null_iwipmatdef(struct IWIPMATDEF_N_TAG *IWIPMATDEF_N, struct IWIPMATDEF_TAG *IWIPMATDEF)
{
    /* memset by NULL */
    memset(IWIPMATDEF_N, '\0', sizeof(struct IWIPMATDEF_N_TAG));
    
    MEMCPY_AN(IWIPMATDEF_N->DOC_ID, IWIPMATDEF->DOC_ID, sizeof(IWIPMATDEF->DOC_ID));
    MEMCPY_AN(IWIPMATDEF_N->SITE_ID, IWIPMATDEF->SITE_ID, sizeof(IWIPMATDEF->SITE_ID));
    MEMCPY_AN(IWIPMATDEF_N->MATE_NO, IWIPMATDEF->MATE_NO, sizeof(IWIPMATDEF->MATE_NO));
    MEMCPY_AN(IWIPMATDEF_N->MATE_NM, IWIPMATDEF->MATE_NM, sizeof(IWIPMATDEF->MATE_NM));
    MEMCPY_AN(IWIPMATDEF_N->UNIT_ID, IWIPMATDEF->UNIT_ID, sizeof(IWIPMATDEF->UNIT_ID));
    MEMCPY_AN(IWIPMATDEF_N->SAP_MATE_TYPE, IWIPMATDEF->SAP_MATE_TYPE, sizeof(IWIPMATDEF->SAP_MATE_TYPE));
    MEMCPY_AN(IWIPMATDEF_N->MATE_CLASS, IWIPMATDEF->MATE_CLASS, sizeof(IWIPMATDEF->MATE_CLASS));
    MEMCPY_AN(IWIPMATDEF_N->MATE_TYPE, IWIPMATDEF->MATE_TYPE, sizeof(IWIPMATDEF->MATE_TYPE));
    MEMCPY_AN(IWIPMATDEF_N->MATE_TYPE_DESC, IWIPMATDEF->MATE_TYPE_DESC, sizeof(IWIPMATDEF->MATE_TYPE_DESC));
    MEMCPY_AN(IWIPMATDEF_N->MATE_SUBTYPE, IWIPMATDEF->MATE_SUBTYPE, sizeof(IWIPMATDEF->MATE_SUBTYPE));
    MEMCPY_AN(IWIPMATDEF_N->MATE_SUBTYPE_DESC, IWIPMATDEF->MATE_SUBTYPE_DESC, sizeof(IWIPMATDEF->MATE_SUBTYPE_DESC));
    MEMCPY_AN(IWIPMATDEF_N->PROD_TYPE, IWIPMATDEF->PROD_TYPE, sizeof(IWIPMATDEF->PROD_TYPE));
    MEMCPY_AN(IWIPMATDEF_N->PROD_TYPE_DESC, IWIPMATDEF->PROD_TYPE_DESC, sizeof(IWIPMATDEF->PROD_TYPE_DESC));
    MEMCPY_AN(IWIPMATDEF_N->PROD_SUBTYPE, IWIPMATDEF->PROD_SUBTYPE, sizeof(IWIPMATDEF->PROD_SUBTYPE));
    MEMCPY_AN(IWIPMATDEF_N->PROD_SUBTYPE_DESC, IWIPMATDEF->PROD_SUBTYPE_DESC, sizeof(IWIPMATDEF->PROD_SUBTYPE_DESC));
    MEMCPY_AN(IWIPMATDEF_N->PROD_DETAILTYPE, IWIPMATDEF->PROD_DETAILTYPE, sizeof(IWIPMATDEF->PROD_DETAILTYPE));
    MEMCPY_AN(IWIPMATDEF_N->PROD_DETAILTYPE_DESC, IWIPMATDEF->PROD_DETAILTYPE_DESC, sizeof(IWIPMATDEF->PROD_DETAILTYPE_DESC));
    MEMCPY_AN(IWIPMATDEF_N->PROD_CERT, IWIPMATDEF->PROD_CERT, sizeof(IWIPMATDEF->PROD_CERT));
    MEMCPY_AN(IWIPMATDEF_N->PROD_CERT_DESC, IWIPMATDEF->PROD_CERT_DESC, sizeof(IWIPMATDEF->PROD_CERT_DESC));
    IWIPMATDEF_N->BACKFLUSH_YN[0] = IWIPMATDEF->BACKFLUSH_YN;
    IWIPMATDEF_N->INSPECT_YN[0] = IWIPMATDEF->INSPECT_YN;
    IWIPMATDEF_N->DEL_YN[0] = IWIPMATDEF->DEL_YN;
    MEMCPY_AN(IWIPMATDEF_N->ITEM_CAT_GRP, IWIPMATDEF->ITEM_CAT_GRP, sizeof(IWIPMATDEF->ITEM_CAT_GRP));
    MEMCPY_AN(IWIPMATDEF_N->CELL_QTY, IWIPMATDEF->CELL_QTY, sizeof(IWIPMATDEF->CELL_QTY));
    IWIPMATDEF_N->MONO_POLY[0] = IWIPMATDEF->MONO_POLY;
    MEMCPY_AN(IWIPMATDEF_N->INF_TIME, IWIPMATDEF->INF_TIME, sizeof(IWIPMATDEF->INF_TIME));
    MEMCPY_AN(IWIPMATDEF_N->INF_PROC_TIME, IWIPMATDEF->INF_PROC_TIME, sizeof(IWIPMATDEF->INF_PROC_TIME));
    MEMCPY_AN(IWIPMATDEF_N->CMF_1, IWIPMATDEF->CMF_1, sizeof(IWIPMATDEF->CMF_1));
    MEMCPY_AN(IWIPMATDEF_N->CMF_2, IWIPMATDEF->CMF_2, sizeof(IWIPMATDEF->CMF_2));
    MEMCPY_AN(IWIPMATDEF_N->CMF_3, IWIPMATDEF->CMF_3, sizeof(IWIPMATDEF->CMF_3));
    MEMCPY_AN(IWIPMATDEF_N->CMF_4, IWIPMATDEF->CMF_4, sizeof(IWIPMATDEF->CMF_4));
    MEMCPY_AN(IWIPMATDEF_N->CMF_5, IWIPMATDEF->CMF_5, sizeof(IWIPMATDEF->CMF_5));
    IWIPMATDEF_N->DATA_FLAG[0] = IWIPMATDEF->DATA_FLAG;
