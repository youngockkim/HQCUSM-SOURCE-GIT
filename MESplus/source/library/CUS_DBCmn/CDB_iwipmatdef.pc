    MEMCPY_AN(IWIPMATDEF_N->INSERT_COUNT, IWIPMATDEF->INSERT_COUNT, sizeof(IWIPMATDEF->INSERT_COUNT));
    MEMCPY_AN(IWIPMATDEF_N->DELETE_COUNT, IWIPMATDEF->DELETE_COUNT, sizeof(IWIPMATDEF->DELETE_COUNT));
    MEMCPY_AN(IWIPMATDEF_N->SQL_DML_COUNT, IWIPMATDEF->SQL_DML_COUNT, sizeof(IWIPMATDEF->SQL_DML_COUNT));
    MEMCPY_AN(IWIPMATDEF_N->ZPICODE, IWIPMATDEF->ZPICODE, sizeof(IWIPMATDEF->ZPICODE));
    MEMCPY_AN(IWIPMATDEF_N->ZPIMSGID, IWIPMATDEF->ZPIMSGID, sizeof(IWIPMATDEF->ZPIMSGID));
    IWIPMATDEF_N->RETURN_TYPE[0] = IWIPMATDEF->RETURN_TYPE;
    MEMCPY_AN(IWIPMATDEF_N->RETURN_MSG, IWIPMATDEF->RETURN_MSG, sizeof(IWIPMATDEF->RETURN_MSG));
    MEMCPY_AN(IWIPMATDEF_N->ZIFERNAM, IWIPMATDEF->ZIFERNAM, sizeof(IWIPMATDEF->ZIFERNAM));
    MEMCPY_AN(IWIPMATDEF_N->ZIFDATE, IWIPMATDEF->ZIFDATE, sizeof(IWIPMATDEF->ZIFDATE));
    MEMCPY_AN(IWIPMATDEF_N->ZIFTIME, IWIPMATDEF->ZIFTIME, sizeof(IWIPMATDEF->ZIFTIME));
    IWIPMATDEF_N->ZPISTAT[0] = IWIPMATDEF->ZPISTAT;
    MEMCPY_AN(IWIPMATDEF_N->ZPIMSG, IWIPMATDEF->ZPIMSG, sizeof(IWIPMATDEF->ZPIMSG));
}


/* Del Null Function */
void CDB_del_null_iwipmatdef(struct IWIPMATDEF_N_TAG *IWIPMATDEF_N, struct IWIPMATDEF_TAG *IWIPMATDEF)
{
    MEMCPY_DN(IWIPMATDEF->DOC_ID, IWIPMATDEF_N->DOC_ID, sizeof(IWIPMATDEF->DOC_ID));
