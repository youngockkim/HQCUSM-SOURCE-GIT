    MEMCPY_AN(CWIPLOTINV_N->INV_MAT_ID, CWIPLOTINV->INV_MAT_ID, sizeof(CWIPLOTINV->INV_MAT_ID));
    MEMCPY_AN(CWIPLOTINV_N->INV_MAT_TYPE, CWIPLOTINV->INV_MAT_TYPE, sizeof(CWIPLOTINV->INV_MAT_TYPE));
    CWIPLOTINV_N->INV_IN_QTY = CWIPLOTINV->INV_IN_QTY;
    MEMCPY_AN(CWIPLOTINV_N->LAMA_ID, CWIPLOTINV->LAMA_ID, sizeof(CWIPLOTINV->LAMA_ID));
    MEMCPY_AN(CWIPLOTINV_N->MAGAZINE_ID, CWIPLOTINV->MAGAZINE_ID, sizeof(CWIPLOTINV->MAGAZINE_ID));
    MEMCPY_AN(CWIPLOTINV_N->SMALL_BOX_ID, CWIPLOTINV->SMALL_BOX_ID, sizeof(CWIPLOTINV->SMALL_BOX_ID));
    CWIPLOTINV_N->AVG_NCELL = CWIPLOTINV->AVG_NCELL;
    CWIPLOTINV_N->AVG_NCELL_OF_VM = CWIPLOTINV->AVG_NCELL_OF_VM;
    CWIPLOTINV_N->OFF_SET = CWIPLOTINV->OFF_SET;
    MEMCPY_AN(CWIPLOTINV_N->QUALITYGRADE, CWIPLOTINV->QUALITYGRADE, sizeof(CWIPLOTINV->QUALITYGRADE));
    MEMCPY_AN(CWIPLOTINV_N->POWERGRADE, CWIPLOTINV->POWERGRADE, sizeof(CWIPLOTINV->POWERGRADE));
    MEMCPY_AN(CWIPLOTINV_N->TRAN_TIME, CWIPLOTINV->TRAN_TIME, sizeof(CWIPLOTINV->TRAN_TIME));
    MEMCPY_AN(CWIPLOTINV_N->TRAN_DATE, CWIPLOTINV->TRAN_DATE, sizeof(CWIPLOTINV->TRAN_DATE));
    MEMCPY_AN(CWIPLOTINV_N->TRAN_SHIFT, CWIPLOTINV->TRAN_SHIFT, sizeof(CWIPLOTINV->TRAN_SHIFT));
    MEMCPY_AN(CWIPLOTINV_N->TRAN_USER_ID, CWIPLOTINV->TRAN_USER_ID, sizeof(CWIPLOTINV->TRAN_USER_ID));
    CWIPLOTINV_N->DEL_FLAG[0] = CWIPLOTINV->DEL_FLAG;
    CWIPLOTINV_N->RAW_FLAG[0] = CWIPLOTINV->RAW_FLAG;
    MEMCPY_AN(CWIPLOTINV_N->LIV_CMF_1, CWIPLOTINV->LIV_CMF_1, sizeof(CWIPLOTINV->LIV_CMF_1));
    MEMCPY_AN(CWIPLOTINV_N->LIV_CMF_2, CWIPLOTINV->LIV_CMF_2, sizeof(CWIPLOTINV->LIV_CMF_2));
    MEMCPY_AN(CWIPLOTINV_N->LIV_CMF_3, CWIPLOTINV->LIV_CMF_3, sizeof(CWIPLOTINV->LIV_CMF_3));
    MEMCPY_AN(CWIPLOTINV_N->LIV_CMF_4, CWIPLOTINV->LIV_CMF_4, sizeof(CWIPLOTINV->LIV_CMF_4));
    MEMCPY_AN(CWIPLOTINV_N->LIV_CMF_5, CWIPLOTINV->LIV_CMF_5, sizeof(CWIPLOTINV->LIV_CMF_5));
