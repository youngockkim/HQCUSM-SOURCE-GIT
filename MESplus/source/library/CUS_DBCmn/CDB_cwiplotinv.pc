            sprintf(sSql + strlen(sSql), "    INV_MAT_TYPE,\r\n");
            sprintf(sSql + strlen(sSql), "    INV_IN_QTY,\r\n");
            sprintf(sSql + strlen(sSql), "    LAMA_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    MAGAZINE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    SMALL_BOX_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    TRAN_TIME,\r\n");
            sprintf(sSql + strlen(sSql), "    TRAN_DATE,\r\n");
            sprintf(sSql + strlen(sSql), "    TRAN_SHIFT,\r\n");
