            sprintf(sSql + strlen(sSql), "    PARTITION_KEY\r\n");
            sprintf(sSql + strlen(sSql), ")\r\n");
            sprintf(sSql + strlen(sSql), "SELECT LOT_ID, INV_LOT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(ORDER_ID) ORDER_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(MAT_ID) MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(LINE_ID) LINE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(RES_ID) RES_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(FACTORY) FACTORY,\r\n");
            sprintf(sSql + strlen(sSql), "       'STRING' MAT_TYPE,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(INV_MAT_ID) INV_MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       'CELL' INV_MAT_TYPE,\r\n");
            sprintf(sSql + strlen(sSql), "       1 INV_IN_QTY,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(LAMA_ID) LAMA_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(MAGAZINE_ID) KEEP (DENSE_RANK LAST ORDER BY CREATE_TIME) MAGAZINE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(SMALL_BOX_ID) KEEP (DENSE_RANK LAST ORDER BY CREATE_TIME) SMALL_BOX_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(TRAN_TIME) TRAN_TIME,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(TRAN_DATE) TRAN_DATE,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(TRAN_SHIFT) TRAN_SHIFT,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(MODULE_ID) MODULE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       TRUNC(SYSDATE, 'D') PARTITION_KEY\r\n");
            sprintf(sSql + strlen(sSql), "  FROM (\r\n");
            sprintf(sSql + strlen(sSql), "        SELECT A.STRING_ID LOT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               B.CELL_ID INV_LOT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               A.ORDER_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               (SELECT C.MAT_ID FROM MWIPLOTSTS C WHERE A.LOT_ID = C.LOT_ID) MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               B.LINE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               B.RES_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               B.FACTORY,\r\n");
            sprintf(sSql + strlen(sSql), "               NVL(E.MAT_ID, ' ') INV_MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               C.LAMA_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               NVL(K.PACK_ID, ' ') MAGAZINE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               NVL(K.CELL_BOX_ID, ' ') SMALL_BOX_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               B.LAST_TRAN_TIME TRAN_TIME,\r\n");
            sprintf(sSql + strlen(sSql), "               D.SYS_DATE TRAN_DATE,\r\n");
            sprintf(sSql + strlen(sSql), "               K.CREATE_TIME,\r\n");
            sprintf(sSql + strlen(sSql), "               CASE WHEN SUBSTR(B.LAST_TRAN_TIME, 9, 6) BETWEEN '060000' AND '175959' THEN D.CAL_CMF_1 ELSE D.CAL_CMF_2 END TRAN_SHIFT,\r\n");
            sprintf(sSql + strlen(sSql), "               A.LOT_ID MODULE_ID\r\n");
            sprintf(sSql + strlen(sSql), "          FROM CWIPLOTSTR A, CWIPSTRCEL B, CWIPCELLAM C, MWIPCALDEF D, CWIPCELMGZ K, MWIPLOTSTS E\r\n");
            sprintf(sSql + strlen(sSql), "         WHERE A.FACTORY = :FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "           AND A.LOT_ID = :LOT_ID\r\n");
            sprintf(sSql + strlen(sSql), "           AND A.FACTORY = B.FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "           AND A.STRING_ID = B.STRING_ID\r\n");
            sprintf(sSql + strlen(sSql), "           AND D.SYS_DATE = TO_CHAR(TO_DATE(A.LAST_TRAN_TIME, 'YYYYMMDDHH24MISS') - (6/24), 'YYYYMMDD')\r\n");
            sprintf(sSql + strlen(sSql), "           AND B.FACTORY = C.FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "           AND B.CELL_ID = C.CELL_ID\r\n");
            sprintf(sSql + strlen(sSql), "           AND C.FACTORY = K.FACTORY(+)\r\n");
            sprintf(sSql + strlen(sSql), "           AND TRIM(C.VMAGAZINE_ID) = K.VMAGAZINE_ID(+)\r\n");
            sprintf(sSql + strlen(sSql), "           AND K.CELL_BOX_ID = E.LOT_ID(+)\r\n");
            sprintf(sSql + strlen(sSql), "       )\r\n");
            sprintf(sSql + strlen(sSql), " GROUP BY LOT_ID, INV_LOT_ID\r\n");

            EXEC SQL PREPARE S FROM :sSql;
            EXEC SQL EXECUTE S USING :CWIPLOTINV_N.FACTORY, :CWIPLOTINV_N.MODULE_ID;

            break;

        /* Cell - Virtual Magazine */
        case 5: 
            sprintf(sSql + strlen(sSql), "INSERT INTO CWIPLOTINV (\r\n");
            sprintf(sSql + strlen(sSql), "    LOT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    INV_LOT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    ORDER_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    LINE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    RES_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    FACTORY,\r\n");
            sprintf(sSql + strlen(sSql), "    MAT_TYPE,\r\n");
            sprintf(sSql + strlen(sSql), "    INV_MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    INV_MAT_TYPE,\r\n");
            sprintf(sSql + strlen(sSql), "    INV_IN_QTY,\r\n");
            sprintf(sSql + strlen(sSql), "    TRAN_TIME,\r\n");
            sprintf(sSql + strlen(sSql), "    TRAN_DATE,\r\n");
            sprintf(sSql + strlen(sSql), "    TRAN_SHIFT,\r\n");
            sprintf(sSql + strlen(sSql), "    MODULE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    PARTITION_KEY\r\n");
            sprintf(sSql + strlen(sSql), ")\r\n");
            sprintf(sSql + strlen(sSql), "SELECT LOT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       INV_LOT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(ORDER_ID) ORDER_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(MAT_ID) MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(LINE_ID) LINE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(RES_ID) RES_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(FACTORY) FACTORY,\r\n");
            sprintf(sSql + strlen(sSql), "       'CELL' MAT_TYPE,\r\n");
            sprintf(sSql + strlen(sSql), "       ' ' INV_MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       'VMAGAZINE' INV_MAT_TYPE,\r\n");
            sprintf(sSql + strlen(sSql), "       1 INV_IN_QTY,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(TRAN_TIME) TRAN_TIME,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(TRAN_DATE) TRAN_DATE,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(TRAN_SHIFT) TRAN_SHIFT,\r\n");
            sprintf(sSql + strlen(sSql), "       MAX(MODULE_ID) MODULE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       TRUNC(SYSDATE, 'D') PARTITION_KEY\r\n");
            sprintf(sSql + strlen(sSql), "  FROM (\r\n");
            sprintf(sSql + strlen(sSql), "        SELECT /*+ ORDERED */\r\n");
            sprintf(sSql + strlen(sSql), "               C.CELL_ID LOT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               C.VMAGAZINE_ID INV_LOT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               A.ORDER_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               E.MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               C.LINE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               C.RES_ID,\r\n");
            sprintf(sSql + strlen(sSql), "               C.FACTORY,\r\n");
            sprintf(sSql + strlen(sSql), "               C.CREATE_TIME TRAN_TIME,\r\n");
            sprintf(sSql + strlen(sSql), "               D.SYS_DATE TRAN_DATE,\r\n");
            sprintf(sSql + strlen(sSql), "               CASE WHEN SUBSTR(C.CREATE_TIME, 9, 6) BETWEEN '060000' AND '175959' THEN D.CAL_CMF_1 ELSE D.CAL_CMF_2 END TRAN_SHIFT,\r\n");
            sprintf(sSql + strlen(sSql), "               A.LOT_ID MODULE_ID\r\n");
            sprintf(sSql + strlen(sSql), "          FROM CWIPLOTSTR A, CWIPSTRCEL B, CWIPCELLAM C, CWIPCELMGZ K, MWIPCALDEF D, CINVCELRCV F, MWIPLOTSTS E\r\n");
            sprintf(sSql + strlen(sSql), "         WHERE A.FACTORY = :FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "           AND A.LOT_ID = :LOT_ID\r\n");
            sprintf(sSql + strlen(sSql), "           AND A.FACTORY = B.FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "           AND A.STRING_ID = B.STRING_ID\r\n");
            sprintf(sSql + strlen(sSql), "           AND B.FACTORY = C.FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "           AND B.CELL_ID = C.CELL_ID\r\n");
            sprintf(sSql + strlen(sSql), "           AND C.FACTORY = K.FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "           AND TRIM(C.VMAGAZINE_ID) = K.VMAGAZINE_ID\r\n");
            sprintf(sSql + strlen(sSql), "           AND D.SYS_DATE = TO_CHAR(TO_DATE(C.CREATE_TIME, 'YYYYMMDDHH24MISS') - (6/24), 'YYYYMMDD')\r\n");
            sprintf(sSql + strlen(sSql), "           AND K.FACTORY = F.FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "           AND K.CELL_BOX_ID = F.INV_LOT_ID\r\n");
            sprintf(sSql + strlen(sSql), "           AND F.INV_LOT_ID = E.LOT_ID\r\n");
            sprintf(sSql + strlen(sSql), "       )\r\n");
            sprintf(sSql + strlen(sSql), " GROUP BY LOT_ID, INV_LOT_ID\r\n");

            EXEC SQL PREPARE S FROM :sSql;
            EXEC SQL EXECUTE S USING :CWIPLOTINV_N.FACTORY, :CWIPLOTINV_N.MODULE_ID;

            break;

        /* Virtual Magazine - Cell Box : Eagle 2/3 */
        case 6:
            sprintf(sSql + strlen(sSql), "INSERT INTO CWIPLOTINV (\r\n");
            sprintf(sSql + strlen(sSql), "    LOT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    INV_LOT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    ORDER_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    LINE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    RES_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    FACTORY,\r\n");
            sprintf(sSql + strlen(sSql), "    MAT_TYPE,\r\n");
            sprintf(sSql + strlen(sSql), "    INV_MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    INV_MAT_TYPE,\r\n");
            sprintf(sSql + strlen(sSql), "    INV_IN_QTY,\r\n");
            sprintf(sSql + strlen(sSql), "    TRAN_TIME,\r\n");
            sprintf(sSql + strlen(sSql), "    TRAN_DATE,\r\n");
            sprintf(sSql + strlen(sSql), "    TRAN_SHIFT,\r\n");
            sprintf(sSql + strlen(sSql), "    MODULE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "    PARTITION_KEY\r\n");
            sprintf(sSql + strlen(sSql), ")\r\n"); 
            sprintf(sSql + strlen(sSql), "SELECT /*+ ORDERED  */\r\n");
            sprintf(sSql + strlen(sSql), "       DISTINCT \r\n");
            sprintf(sSql + strlen(sSql), "       C.VMAGAZINE_ID LOT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       K.CELL_BOX_ID INV_LOT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       A.ORDER_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       ' ' MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       C.LINE_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       C.RES_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       C.FACTORY,\r\n");
            sprintf(sSql + strlen(sSql), "       'VMAGAZINE' MAT_TYPE,\r\n");
            sprintf(sSql + strlen(sSql), "       (SELECT MAT_ID FROM MWIPLOTSTS WHERE LOT_ID = K.CELL_BOX_ID) INV_MAT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       'CELLBOX' INV_MAT_TYPE,\r\n");
            sprintf(sSql + strlen(sSql), "       1 INV_IN_QTY,\r\n");
            sprintf(sSql + strlen(sSql), "       K.CREATE_TIME TRAN_TIME,\r\n");
            sprintf(sSql + strlen(sSql), "       D.SYS_DATE TRAN_DATE,\r\n");
            sprintf(sSql + strlen(sSql), "       CASE WHEN SUBSTR(K.CREATE_TIME, 9, 6) BETWEEN '060000' AND '175959' THEN D.CAL_CMF_1 ELSE D.CAL_CMF_2 END TRAN_SHIFT,\r\n");
            sprintf(sSql + strlen(sSql), "       A.LOT_ID,\r\n");
            sprintf(sSql + strlen(sSql), "       TRUNC(SYSDATE, 'D') PARTITION_KEY\r\n");
            sprintf(sSql + strlen(sSql), "  FROM CWIPLOTSTR A, CWIPSTRCEL B, CWIPCELLAM C, CWIPCELMGZ K, MWIPCALDEF D\r\n");
            sprintf(sSql + strlen(sSql), " WHERE A.FACTORY = :FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "   AND A.LOT_ID = :LOT_ID\r\n");
            sprintf(sSql + strlen(sSql), "   AND A.FACTORY = B.FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "   AND A.STRING_ID = B.STRING_ID\r\n");
            sprintf(sSql + strlen(sSql), "   AND B.FACTORY = C.FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "   AND B.CELL_ID = C.CELL_ID\r\n");
            sprintf(sSql + strlen(sSql), "   AND C.FACTORY = K.FACTORY\r\n");
            sprintf(sSql + strlen(sSql), "   AND TRIM(C.VMAGAZINE_ID) = K.VMAGAZINE_ID\r\n");
            sprintf(sSql + strlen(sSql), "   AND D.SYS_DATE = TO_CHAR(TO_DATE(K.CREATE_TIME, 'YYYYMMDDHH24MISS') - (6/24), 'YYYYMMDD')\r\n");

            EXEC SQL PREPARE S FROM :sSql;
            EXEC SQL EXECUTE S USING :CWIPLOTINV_N.FACTORY, :CWIPLOTINV_N.LOT_ID;

            break;

        /* Tabber Virtual Magazine - Half Cell Box : Eagle 1*/
        case 7:
            break;

        /* Half Cell Box - Cleaving Virtual Magazine : Eagle 1 */
        case 8:
            break;

        /* Cleaving Virtual Magazine - Full Cell Box : Eagle 1 */
        case 9:
            break;

        /* Materials used in module production : Eagle 1, 2 */
        case 10:
            sprintf(sSql + strlen(sSql), "INSERT INTO CWIPLOTINV (");
            sprintf(sSql + strlen(sSql), "    MODULE_ID,");
            sprintf(sSql + strlen(sSql), "    LOT_ID,");
            sprintf(sSql + strlen(sSql), "    INV_LOT_ID,");
            sprintf(sSql + strlen(sSql), "    ORDER_ID,");
            sprintf(sSql + strlen(sSql), "    MAT_ID,");
            sprintf(sSql + strlen(sSql), "    LINE_ID,");
            sprintf(sSql + strlen(sSql), "    RES_ID,");
            sprintf(sSql + strlen(sSql), "    FACTORY,");
            sprintf(sSql + strlen(sSql), "    MAT_TYPE,");
            sprintf(sSql + strlen(sSql), "    INV_MAT_ID,");
            sprintf(sSql + strlen(sSql), "    INV_MAT_TYPE,");
            sprintf(sSql + strlen(sSql), "    INV_IN_QTY,");
            sprintf(sSql + strlen(sSql), "    TRAN_TIME,");
            sprintf(sSql + strlen(sSql), "    TRAN_DATE,");
            sprintf(sSql + strlen(sSql), "    TRAN_SHIFT,");
            sprintf(sSql + strlen(sSql), "    RAW_FLAG,");
            sprintf(sSql + strlen(sSql), "    PARTITION_KEY");
            sprintf(sSql + strlen(sSql), ")");
            sprintf(sSql + strlen(sSql), "SELECT A.LOT_ID MODULE_ID,");
            sprintf(sSql + strlen(sSql), "       A.LOT_ID,");
            sprintf(sSql + strlen(sSql), "       A.INV_LOT_ID,");
            sprintf(sSql + strlen(sSql), "       B.ORDER_ID,");
            sprintf(sSql + strlen(sSql), "       B.MAT_ID,");
            sprintf(sSql + strlen(sSql), "       MAX(NVL(TRIM(B.LOT_CMF_1), D.LOT_CMF_1)) LINE_ID,");
            sprintf(sSql + strlen(sSql), "       MAX(A.RES_ID) RES_ID,");
            sprintf(sSql + strlen(sSql), "       A.FACTORY,");
            sprintf(sSql + strlen(sSql), "       'MODULE' MAT_TYPE,");
            sprintf(sSql + strlen(sSql), "       A.INV_MAT_ID,");
            sprintf(sSql + strlen(sSql), "       A.MAT_TYPE INV_MAT_TYPE,");
            sprintf(sSql + strlen(sSql), "       SUM(A.USED_QTY) INV_IN_QTY,");
            sprintf(sSql + strlen(sSql), "       MAX(A.ATTACH_TIME) TRAN_TIME,");
            sprintf(sSql + strlen(sSql), "       MAX(C.SYS_DATE) TRAN_DATE,");
            sprintf(sSql + strlen(sSql), "       MAX(CASE WHEN SUBSTR(A.ATTACH_TIME, 9, 6) BETWEEN '060000' AND '175959' THEN C.CAL_CMF_1 ELSE C.CAL_CMF_2 END) TRAN_SHIFT,");
            sprintf(sSql + strlen(sSql), "       'Y' RAW_FLAG,");
            sprintf(sSql + strlen(sSql), "       MAX(TO_DATE(SUBSTR(A.ATTACH_TIME, 1, 8), 'YYYYMMDD')) PARTITION_KEY");
            sprintf(sSql + strlen(sSql), "  FROM CWIPLOTMAT A, MWIPLOTSTS B, MWIPCALDEF C, MWIPLOTHIS D");
            sprintf(sSql + strlen(sSql), " WHERE A.FACTORY = :FACTORY");
            sprintf(sSql + strlen(sSql), "   AND A.LOT_ID = :LOT_ID");
            sprintf(sSql + strlen(sSql), "   AND A.INV_LOT_ID = :INV_LOT_ID");
            sprintf(sSql + strlen(sSql), "   AND A.LOT_ID = B.LOT_ID");
            sprintf(sSql + strlen(sSql), "   AND C.SYS_DATE = TO_CHAR(TO_DATE(A.ATTACH_TIME, 'YYYYMMDDHH24MISS') - (6/24), 'YYYYMMDD')");
            sprintf(sSql + strlen(sSql), "   AND A.LOT_ID = D.LOT_ID");
            sprintf(sSql + strlen(sSql), "   AND D.HIST_SEQ = 1");
            sprintf(sSql + strlen(sSql), " GROUP BY A.LOT_ID, A.LOT_ID, A.INV_LOT_ID, B.ORDER_ID, B.MAT_ID, A.FACTORY, A.INV_MAT_ID, A.MAT_TYPE");

            EXEC SQL PREPARE S FROM :sSql;
            EXEC SQL EXECUTE S USING :CWIPLOTINV_N.FACTORY, :CWIPLOTINV_N.MODULE_ID, :CWIPLOTINV_N.INV_LOT_ID;

            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }
    
    DB_stop_query_timer("CDB_insert_cwiplotinv", sel_type);
}


/* SQL UPDATE Function */
void CDB_update_cwiplotinv(int sel_type, struct CWIPLOTINV_TAG *CWIPLOTINV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPLOTINV_N_TAG CWIPLOTINV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwiplotinv(&CWIPLOTINV_N, CWIPLOTINV);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE CWIPLOTINV SET
                    ORDER_ID = :CWIPLOTINV_N.ORDER_ID,
                    MAT_ID = :CWIPLOTINV_N.MAT_ID,
                    LINE_ID = :CWIPLOTINV_N.LINE_ID,
                    RES_ID = :CWIPLOTINV_N.RES_ID,
                    FACTORY = :CWIPLOTINV_N.FACTORY,
                    MAT_TYPE = :CWIPLOTINV_N.MAT_TYPE,
                    INV_MAT_ID = :CWIPLOTINV_N.INV_MAT_ID,
                    INV_MAT_TYPE = :CWIPLOTINV_N.INV_MAT_TYPE,
                    INV_IN_QTY = :CWIPLOTINV_N.INV_IN_QTY,
                    LAMA_ID = :CWIPLOTINV_N.LAMA_ID,
                    MAGAZINE_ID = :CWIPLOTINV_N.MAGAZINE_ID,
                    SMALL_BOX_ID = :CWIPLOTINV_N.SMALL_BOX_ID,
                    AVG_NCELL = :CWIPLOTINV_N.AVG_NCELL,
                    AVG_NCELL_OF_VM = :CWIPLOTINV_N.AVG_NCELL_OF_VM,
                    OFF_SET = :CWIPLOTINV_N.OFF_SET,
                    QUALITYGRADE = :CWIPLOTINV_N.QUALITYGRADE,
                    POWERGRADE = :CWIPLOTINV_N.POWERGRADE,
                    TRAN_TIME = :CWIPLOTINV_N.TRAN_TIME,
                    TRAN_DATE = :CWIPLOTINV_N.TRAN_DATE,
                    TRAN_SHIFT = :CWIPLOTINV_N.TRAN_SHIFT,
                    TRAN_USER_ID = :CWIPLOTINV_N.TRAN_USER_ID,
                    DEL_FLAG = :CWIPLOTINV_N.DEL_FLAG,
                    RAW_FLAG = :CWIPLOTINV_N.RAW_FLAG,
                    LIV_CMF_1 = :CWIPLOTINV_N.LIV_CMF_1,
                    LIV_CMF_2 = :CWIPLOTINV_N.LIV_CMF_2,
                    LIV_CMF_3 = :CWIPLOTINV_N.LIV_CMF_3,
                    LIV_CMF_4 = :CWIPLOTINV_N.LIV_CMF_4,
                    LIV_CMF_5 = :CWIPLOTINV_N.LIV_CMF_5,
                    LIV_CMF_6 = :CWIPLOTINV_N.LIV_CMF_6,
                    LIV_CMF_7 = :CWIPLOTINV_N.LIV_CMF_7,
                    LIV_CMF_8 = :CWIPLOTINV_N.LIV_CMF_8,
                    LIV_CMF_9 = :CWIPLOTINV_N.LIV_CMF_9,
                    LIV_CMF_10 = :CWIPLOTINV_N.LIV_CMF_10,
                    PARTITION_KEY = SYSDATE
                WHERE MODULE_ID = :CWIPLOTINV_N.MODULE_ID
                    AND LOT_ID = :CWIPLOTINV_N.LOT_ID
                    AND INV_LOT_ID = :CWIPLOTINV_N.INV_LOT_ID;
            break;

        case 2:
            EXEC SQL UPDATE CWIPLOTINV SET
                    ORDER_ID = :CWIPLOTINV_N.ORDER_ID,
                    MAT_ID = :CWIPLOTINV_N.MAT_ID,
                    LINE_ID = :CWIPLOTINV_N.LINE_ID,
                    RES_ID = :CWIPLOTINV_N.RES_ID,
                    FACTORY = :CWIPLOTINV_N.FACTORY,
                    MAT_TYPE = :CWIPLOTINV_N.MAT_TYPE,
                    INV_MAT_ID = :CWIPLOTINV_N.INV_MAT_ID,
                    INV_MAT_TYPE = :CWIPLOTINV_N.INV_MAT_TYPE,
                    INV_IN_QTY = :CWIPLOTINV_N.INV_IN_QTY,
                    LAMA_ID = :CWIPLOTINV_N.LAMA_ID,
                    MAGAZINE_ID = :CWIPLOTINV_N.MAGAZINE_ID,
                    SMALL_BOX_ID = :CWIPLOTINV_N.SMALL_BOX_ID,
                    AVG_NCELL = :CWIPLOTINV_N.AVG_NCELL,
                    QUALITYGRADE = :CWIPLOTINV_N.QUALITYGRADE,
                    POWERGRADE = :CWIPLOTINV_N.POWERGRADE,
                    TRAN_TIME = :CWIPLOTINV_N.TRAN_TIME,
                    TRAN_DATE = :CWIPLOTINV_N.TRAN_DATE,
                    TRAN_SHIFT = :CWIPLOTINV_N.TRAN_SHIFT,
                    TRAN_USER_ID = :CWIPLOTINV_N.TRAN_USER_ID,
                    DEL_FLAG = :CWIPLOTINV_N.DEL_FLAG,
                    RAW_FLAG = :CWIPLOTINV_N.RAW_FLAG,
                    LIV_CMF_1 = :CWIPLOTINV_N.LIV_CMF_1,
                    LIV_CMF_2 = :CWIPLOTINV_N.LIV_CMF_2,
                    LIV_CMF_3 = :CWIPLOTINV_N.LIV_CMF_3,
                    LIV_CMF_4 = :CWIPLOTINV_N.LIV_CMF_4,
                    LIV_CMF_5 = :CWIPLOTINV_N.LIV_CMF_5,
                    LIV_CMF_6 = :CWIPLOTINV_N.LIV_CMF_6,
                    LIV_CMF_7 = :CWIPLOTINV_N.LIV_CMF_7,
                    LIV_CMF_8 = :CWIPLOTINV_N.LIV_CMF_8,
                    LIV_CMF_9 = :CWIPLOTINV_N.LIV_CMF_9,
                    LIV_CMF_10 = :CWIPLOTINV_N.LIV_CMF_10
                WHERE MODULE_ID = :CWIPLOTINV_N.MODULE_ID
                    AND LOT_ID = :CWIPLOTINV_N.LOT_ID
                    AND INV_LOT_ID = :CWIPLOTINV_N.INV_LOT_ID;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_cwiplotinv", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwiplotinv(int sel_type, struct CWIPLOTINV_TAG *CWIPLOTINV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPLOTINV_N_TAG CWIPLOTINV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwiplotinv(&CWIPLOTINV_N, CWIPLOTINV);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPLOTINV_CUR_1 CURSOR FOR
                SELECT 
                    MODULE_ID,
                    LOT_ID,
                    INV_LOT_ID,
                    ORDER_ID,
                    MAT_ID,
                    LINE_ID,
                    RES_ID,
                    FACTORY,
                    MAT_TYPE,
                    INV_MAT_ID,
                    INV_MAT_TYPE,
                    INV_IN_QTY,
                    LAMA_ID,
                    MAGAZINE_ID,
                    SMALL_BOX_ID,
                    AVG_NCELL,
                    AVG_NCELL_OF_VM,
                    OFF_SET,
                    QUALITYGRADE,
                    POWERGRADE,
                    TRAN_TIME,
                    TRAN_DATE,
                    TRAN_SHIFT,
                    TRAN_USER_ID,
                    DEL_FLAG,
                    RAW_FLAG,
                    LIV_CMF_1,
                    LIV_CMF_2,
                    LIV_CMF_3,
                    LIV_CMF_4,
                    LIV_CMF_5,
                    LIV_CMF_6,
                    LIV_CMF_7,
                    LIV_CMF_8,
                    LIV_CMF_9,
                    LIV_CMF_10,
                    TO_CHAR(PARTITION_KEY, 'YYYYMMDDHH24MISS')
                FROM CWIPLOTINV
                ORDER BY MODULE_ID ASC,
                    LOT_ID ASC,
                    INV_LOT_ID ASC;
            EXEC SQL OPEN CDB_CWIPLOTINV_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwiplotinv", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_cwiplotinv(int sel_type, struct CWIPLOTINV_TAG *CWIPLOTINV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPLOTINV_N_TAG CWIPLOTINV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CWIPLOTINV_CUR_1 INTO
                :CWIPLOTINV_N.MODULE_ID,
                :CWIPLOTINV_N.LOT_ID,
                :CWIPLOTINV_N.INV_LOT_ID,
                :CWIPLOTINV_N.ORDER_ID,
                :CWIPLOTINV_N.MAT_ID,
                :CWIPLOTINV_N.LINE_ID,
                :CWIPLOTINV_N.RES_ID,
                :CWIPLOTINV_N.FACTORY,
                :CWIPLOTINV_N.MAT_TYPE,
                :CWIPLOTINV_N.INV_MAT_ID,
                :CWIPLOTINV_N.INV_MAT_TYPE,
                :CWIPLOTINV_N.INV_IN_QTY,
                :CWIPLOTINV_N.LAMA_ID,
                :CWIPLOTINV_N.MAGAZINE_ID,
                :CWIPLOTINV_N.SMALL_BOX_ID,
                :CWIPLOTINV_N.AVG_NCELL,
                :CWIPLOTINV_N.AVG_NCELL_OF_VM,
                :CWIPLOTINV_N.OFF_SET,
                :CWIPLOTINV_N.QUALITYGRADE,
                :CWIPLOTINV_N.POWERGRADE,
                :CWIPLOTINV_N.TRAN_TIME,
                :CWIPLOTINV_N.TRAN_DATE,
                :CWIPLOTINV_N.TRAN_SHIFT,
                :CWIPLOTINV_N.TRAN_USER_ID,
                :CWIPLOTINV_N.DEL_FLAG,
                :CWIPLOTINV_N.RAW_FLAG,
                :CWIPLOTINV_N.LIV_CMF_1,
                :CWIPLOTINV_N.LIV_CMF_2,
                :CWIPLOTINV_N.LIV_CMF_3,
                :CWIPLOTINV_N.LIV_CMF_4,
                :CWIPLOTINV_N.LIV_CMF_5,
                :CWIPLOTINV_N.LIV_CMF_6,
                :CWIPLOTINV_N.LIV_CMF_7,
                :CWIPLOTINV_N.LIV_CMF_8,
                :CWIPLOTINV_N.LIV_CMF_9,
                :CWIPLOTINV_N.LIV_CMF_10,
                :CWIPLOTINV_N.PARTITION_KEY;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cwiplotinv(&CWIPLOTINV_N, CWIPLOTINV);
    }

    DB_stop_query_timer("CDB_fetch_cwiplotinv", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cwiplotinv(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CWIPLOTINV_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwiplotinv", sel_type);
}


/* Initialize Function */
void CDB_init_cwiplotinv(struct CWIPLOTINV_TAG *CWIPLOTINV)
{
    /* memset by Space */
    memset(CWIPLOTINV, ' ', sizeof(struct CWIPLOTINV_TAG));
    
    CWIPLOTINV->INV_IN_QTY = 0;
    CWIPLOTINV->AVG_NCELL = 0;
    CWIPLOTINV->AVG_NCELL_OF_VM = 0;
    CWIPLOTINV->OFF_SET = 0;
}


/* Add Null Function */
void CDB_add_null_cwiplotinv(struct CWIPLOTINV_N_TAG *CWIPLOTINV_N, struct CWIPLOTINV_TAG *CWIPLOTINV)
{
    /* memset by NULL */
    memset(CWIPLOTINV_N, '\0', sizeof(struct CWIPLOTINV_N_TAG));
    
    MEMCPY_AN(CWIPLOTINV_N->MODULE_ID, CWIPLOTINV->MODULE_ID, sizeof(CWIPLOTINV->MODULE_ID));
    MEMCPY_AN(CWIPLOTINV_N->LOT_ID, CWIPLOTINV->LOT_ID, sizeof(CWIPLOTINV->LOT_ID));
    MEMCPY_AN(CWIPLOTINV_N->INV_LOT_ID, CWIPLOTINV->INV_LOT_ID, sizeof(CWIPLOTINV->INV_LOT_ID));
    MEMCPY_AN(CWIPLOTINV_N->ORDER_ID, CWIPLOTINV->ORDER_ID, sizeof(CWIPLOTINV->ORDER_ID));
    MEMCPY_AN(CWIPLOTINV_N->MAT_ID, CWIPLOTINV->MAT_ID, sizeof(CWIPLOTINV->MAT_ID));
    MEMCPY_AN(CWIPLOTINV_N->LINE_ID, CWIPLOTINV->LINE_ID, sizeof(CWIPLOTINV->LINE_ID));
    MEMCPY_AN(CWIPLOTINV_N->RES_ID, CWIPLOTINV->RES_ID, sizeof(CWIPLOTINV->RES_ID));
    MEMCPY_AN(CWIPLOTINV_N->FACTORY, CWIPLOTINV->FACTORY, sizeof(CWIPLOTINV->FACTORY));
