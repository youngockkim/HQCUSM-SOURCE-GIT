/* Del Null Function */
void CDB_del_null_cwiplotinv(struct CWIPLOTINV_N_TAG *CWIPLOTINV_N, struct CWIPLOTINV_TAG *CWIPLOTINV)
{
    MEMCPY_DN(CWIPLOTINV->MODULE_ID, CWIPLOTINV_N->MODULE_ID, sizeof(CWIPLOTINV->MODULE_ID));
    MEMCPY_DN(CWIPLOTINV->LOT_ID, CWIPLOTINV_N->LOT_ID, sizeof(CWIPLOTINV->LOT_ID));
    MEMCPY_DN(CWIPLOTINV->INV_LOT_ID, CWIPLOTINV_N->INV_LOT_ID, sizeof(CWIPLOTINV->INV_LOT_ID));
    MEMCPY_DN(CWIPLOTINV->ORDER_ID, CWIPLOTINV_N->ORDER_ID, sizeof(CWIPLOTINV->ORDER_ID));
