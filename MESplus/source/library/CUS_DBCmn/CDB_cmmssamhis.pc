    MEMCPY_AN(CMMSSAMHIS_N->UPDATE_USER_ID, CMMSSAMHIS->UPDATE_USER_ID, sizeof(CMMSSAMHIS->UPDATE_USER_ID));
    MEMCPY_AN(CMMSSAMHIS_N->UPDATE_TIME, CMMSSAMHIS->UPDATE_TIME, sizeof(CMMSSAMHIS->UPDATE_TIME));
}


