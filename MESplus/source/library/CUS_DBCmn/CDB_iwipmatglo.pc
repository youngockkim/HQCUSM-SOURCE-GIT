void CDB_init_iwipmatglo(struct IWIPMATGLO_TAG *IWIPMATGLO)
{
    /* memset by Space */
    memset(IWIPMATGLO, ' ', sizeof(struct IWIPMATGLO_TAG));
    
}


/* Add Null Function */
void CDB_add_null_iwipmatglo(struct IWIPMATGLO_N_TAG *IWIPMATGLO_N, struct IWIPMATGLO_TAG *IWIPMATGLO)
{
    /* memset by NULL */
    memset(IWIPMATGLO_N, '\0', sizeof(struct IWIPMATGLO_N_TAG));
    
    MEMCPY_AN(IWIPMATGLO_N->DOC_ID, IWIPMATGLO->DOC_ID, sizeof(IWIPMATGLO->DOC_ID));
    MEMCPY_AN(IWIPMATGLO_N->SITE_ID, IWIPMATGLO->SITE_ID, sizeof(IWIPMATGLO->SITE_ID));
