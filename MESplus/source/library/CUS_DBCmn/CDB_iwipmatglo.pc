    MEMCPY_AN(IWIPMATGLO_N->BUSBAR, IWIPMATGLO->BUSBAR, sizeof(IWIPMATGLO->BUSBAR));
    MEMCPY_AN(IWIPMATGLO_N->BF, IWIPMATGLO->BF, sizeof(IWIPMATGLO->BF));
    MEMCPY_AN(IWIPMATGLO_N->CFP, IWIPMATGLO->CFP, sizeof(IWIPMATGLO->CFP));
    MEMCPY_AN(IWIPMATGLO_N->GAP, IWIPMATGLO->GAP, sizeof(IWIPMATGLO->GAP));
    MEMCPY_AN(IWIPMATGLO_N->FCHC, IWIPMATGLO->FCHC, sizeof(IWIPMATGLO->FCHC));
    MEMCPY_AN(IWIPMATGLO_N->WEIGHT, IWIPMATGLO->WEIGHT, sizeof(IWIPMATGLO->WEIGHT));
    IWIPMATGLO_N->DEL_YN[0] = IWIPMATGLO->DEL_YN;
    MEMCPY_AN(IWIPMATGLO_N->INF_TIME, IWIPMATGLO->INF_TIME, sizeof(IWIPMATGLO->INF_TIME));
    MEMCPY_AN(IWIPMATGLO_N->INF_PROC_TIME, IWIPMATGLO->INF_PROC_TIME, sizeof(IWIPMATGLO->INF_PROC_TIME));
    MEMCPY_AN(IWIPMATGLO_N->CMF_1, IWIPMATGLO->CMF_1, sizeof(IWIPMATGLO->CMF_1));
    MEMCPY_AN(IWIPMATGLO_N->CMF_2, IWIPMATGLO->CMF_2, sizeof(IWIPMATGLO->CMF_2));
    MEMCPY_AN(IWIPMATGLO_N->CMF_3, IWIPMATGLO->CMF_3, sizeof(IWIPMATGLO->CMF_3));
    MEMCPY_AN(IWIPMATGLO_N->CMF_4, IWIPMATGLO->CMF_4, sizeof(IWIPMATGLO->CMF_4));
    MEMCPY_AN(IWIPMATGLO_N->CMF_5, IWIPMATGLO->CMF_5, sizeof(IWIPMATGLO->CMF_5));
    IWIPMATGLO_N->DATA_FLAG[0] = IWIPMATGLO->DATA_FLAG;
    MEMCPY_AN(IWIPMATGLO_N->ZIFERNAM, IWIPMATGLO->ZIFERNAM, sizeof(IWIPMATGLO->ZIFERNAM));
    MEMCPY_AN(IWIPMATGLO_N->ZIFDATE, IWIPMATGLO->ZIFDATE, sizeof(IWIPMATGLO->ZIFDATE));
    MEMCPY_AN(IWIPMATGLO_N->ZIFTIME, IWIPMATGLO->ZIFTIME, sizeof(IWIPMATGLO->ZIFTIME));
    MEMCPY_AN(IWIPMATGLO_N->ZPICODE, IWIPMATGLO->ZPICODE, sizeof(IWIPMATGLO->ZPICODE));
    MEMCPY_AN(IWIPMATGLO_N->ZPIMSGID, IWIPMATGLO->ZPIMSGID, sizeof(IWIPMATGLO->ZPIMSGID));
    IWIPMATGLO_N->ZPISTAT[0] = IWIPMATGLO->ZPISTAT;
    MEMCPY_AN(IWIPMATGLO_N->ZPIMSG, IWIPMATGLO->ZPIMSG, sizeof(IWIPMATGLO->ZPIMSG));
    IWIPMATGLO_N->RETURN_TYPE[0] = IWIPMATGLO->RETURN_TYPE;
    MEMCPY_AN(IWIPMATGLO_N->RETURN_MSG, IWIPMATGLO->RETURN_MSG, sizeof(IWIPMATGLO->RETURN_MSG));
}


