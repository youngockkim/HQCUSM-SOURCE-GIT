    MEMCPY_AN(IBAKMATGLO_N->ZPICODE, IBAKMATGLO->ZPICODE, sizeof(IBAKMATGLO->ZPICODE));
    MEMCPY_AN(IBAKMATGLO_N->ZPIMSGID, IBAKMATGLO->ZPIMSGID, sizeof(IBAKMATGLO->ZPIMSGID));
    IBAKMATGLO_N->ZPISTAT[0] = IBAKMATGLO->ZPISTAT;
    MEMCPY_AN(IBAKMATGLO_N->ZPIMSG, IBAKMATGLO->ZPIMSG, sizeof(IBAKMATGLO->ZPIMSG));
    IBAKMATGLO_N->RETURN_TYPE[0] = IBAKMATGLO->RETURN_TYPE;
    MEMCPY_AN(IBAKMATGLO_N->RETURN_MSG, IBAKMATGLO->RETURN_MSG, sizeof(IBAKMATGLO->RETURN_MSG));
}


