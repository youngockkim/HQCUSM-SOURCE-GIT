    MEMCPY_DN(CWIPPAKREG->FLOW, CWIPPAKREG_N->FLOW, sizeof(CWIPPAKREG->FLOW));
    MEMCPY_DN(CWIPPAKREG->OPER, CWIPPAKREG_N->OPER, sizeof(CWIPPAKREG->OPER));
    MEMCPY_DN(CWIPPAKREG->ORDER_ID, CWIPPAKREG_N->ORDER_ID, sizeof(CWIPPAKREG->ORDER_ID));
    MEMCPY_DN(CWIPPAKREG->LINE_ID, CWIPPAKREG_N->LINE_ID, sizeof(CWIPPAKREG->LINE_ID));
    MEMCPY_DN(CWIPPAKREG->RES_ID, CWIPPAKREG_N->RES_ID, sizeof(CWIPPAKREG->RES_ID));
    CWIPPAKREG->STATUS_FLAG = CWIPPAKREG_N->STATUS_FLAG[0];
    MEMCPY_DN(CWIPPAKREG->PAK_TYPE, CWIPPAKREG_N->PAK_TYPE, sizeof(CWIPPAKREG->PAK_TYPE));
    MEMCPY_DN(CWIPPAKREG->PAK_TIME, CWIPPAKREG_N->PAK_TIME, sizeof(CWIPPAKREG->PAK_TIME));
    MEMCPY_DN(CWIPPAKREG->GRADE, CWIPPAKREG_N->GRADE, sizeof(CWIPPAKREG->GRADE));
    MEMCPY_DN(CWIPPAKREG->POWER, CWIPPAKREG_N->POWER, sizeof(CWIPPAKREG->POWER));
    MEMCPY_DN(CWIPPAKREG->CMF_1, CWIPPAKREG_N->CMF_1, sizeof(CWIPPAKREG->CMF_1));
    MEMCPY_DN(CWIPPAKREG->CMF_2, CWIPPAKREG_N->CMF_2, sizeof(CWIPPAKREG->CMF_2));
    MEMCPY_DN(CWIPPAKREG->CMF_3, CWIPPAKREG_N->CMF_3, sizeof(CWIPPAKREG->CMF_3));
    MEMCPY_DN(CWIPPAKREG->CMF_4, CWIPPAKREG_N->CMF_4, sizeof(CWIPPAKREG->CMF_4));
    MEMCPY_DN(CWIPPAKREG->CMF_5, CWIPPAKREG_N->CMF_5, sizeof(CWIPPAKREG->CMF_5));
    CWIPPAKREG->HIST_SEQ = CWIPPAKREG_N->HIST_SEQ;
    MEMCPY_DN(CWIPPAKREG->CREATE_TIME, CWIPPAKREG_N->CREATE_TIME, sizeof(CWIPPAKREG->CREATE_TIME));
    MEMCPY_DN(CWIPPAKREG->LAST_TRAN_TIME, CWIPPAKREG_N->LAST_TRAN_TIME, sizeof(CWIPPAKREG->LAST_TRAN_TIME));
    MEMCPY_DN(CWIPPAKREG->PVM_PN, CWIPPAKREG_N->PVM_PN, sizeof(CWIPPAKREG->PVM_PN));
    MEMCPY_DN(CWIPPAKREG->PVM_SN, CWIPPAKREG_N->PVM_SN, sizeof(CWIPPAKREG->PVM_SN));
    MEMCPY_DN(CWIPPAKREG->PCU_SN, CWIPPAKREG_N->PCU_SN, sizeof(CWIPPAKREG->PCU_SN));
