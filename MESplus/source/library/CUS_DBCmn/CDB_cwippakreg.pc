void CDB_del_null_cwippakreg(struct CWIPPAKREG_N_TAG *CWIPPAKREG_N, struct CWIPPAKREG_TAG *CWIPPAKREG)
{
    MEMCPY_DN(CWIPPAKREG->FACTORY, CWIPPAKREG_N->FACTORY, sizeof(CWIPPAKREG->FACTORY));
