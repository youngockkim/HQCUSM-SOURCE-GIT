/* Del Null Function */
void CDB_del_null_cwiplotstr(struct CWIPLOTSTR_N_TAG *CWIPLOTSTR_N, struct CWIPLOTSTR_TAG *CWIPLOTSTR)
{
    MEMCPY_DN(CWIPLOTSTR->FACTORY, CWIPLOTSTR_N->FACTORY, sizeof(CWIPLOTSTR->FACTORY));
    MEMCPY_DN(CWIPLOTSTR->LOT_ID, CWIPLOTSTR_N->LOT_ID, sizeof(CWIPLOTSTR->LOT_ID));
