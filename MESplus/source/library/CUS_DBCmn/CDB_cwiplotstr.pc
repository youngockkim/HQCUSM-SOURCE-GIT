        struct CWIPLOTSTR_N_TAG CWIPLOTSTR_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwiplotstr(&CWIPLOTSTR_N, CWIPLOTSTR);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPLOTSTR_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOT_ID,
                    STRING_ID,
                    STRING_LOC,
                    MAT_ID,
                    FLOW,
                    OPER,
                    ORDER_ID,
                    LINE_ID,
                    RES_ID,
                    STATUS_FLAG,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CREATE_TIME,
                    LAST_TRAN_TIME
                FROM CWIPLOTSTR
                ORDER BY FACTORY ASC,
                    LOT_ID ASC,
                    STRING_ID ASC;
            EXEC SQL OPEN CDB_CWIPLOTSTR_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwiplotstr", sel_type);
}


