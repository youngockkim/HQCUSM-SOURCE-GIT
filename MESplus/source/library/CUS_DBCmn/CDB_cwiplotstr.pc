    MEMCPY_AN(CWIPLOTSTR_N->LINE_ID, CWIPLOTSTR->LINE_ID, sizeof(CWIPLOTSTR->LINE_ID));
    MEMCPY_AN(CWIPLOTSTR_N->RES_ID, CWIPLOTSTR->RES_ID, sizeof(CWIPLOTSTR->RES_ID));
    CWIPLOTSTR_N->STATUS_FLAG[0] = CWIPLOTSTR->STATUS_FLAG;
