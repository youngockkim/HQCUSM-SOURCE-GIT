/* Add Null Function */
void CDB_add_null_cwiplotstr(struct CWIPLOTSTR_N_TAG *CWIPLOTSTR_N, struct CWIPLOTSTR_TAG *CWIPLOTSTR)
{
    /* memset by NULL */
    memset(CWIPLOTSTR_N, '\0', sizeof(struct CWIPLOTSTR_N_TAG));
    
    MEMCPY_AN(CWIPLOTSTR_N->FACTORY, CWIPLOTSTR->FACTORY, sizeof(CWIPLOTSTR->FACTORY));
