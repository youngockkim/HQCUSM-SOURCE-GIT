}


/* Del Null Function */
void CDB_del_null_camsadtrst(struct CAMSADTRST_N_TAG *CAMSADTRST_N, struct CAMSADTRST_TAG *CAMSADTRST)
{
    MEMCPY_DN(CAMSADTRST->FACTORY, CAMSADTRST_N->FACTORY, sizeof(CAMSADTRST->FACTORY));
    MEMCPY_DN(CAMSADTRST->AUDIT_ID, CAMSADTRST_N->AUDIT_ID, sizeof(CAMSADTRST->AUDIT_ID));
    MEMCPY_DN(CAMSADTRST->PLAN_DATE, CAMSADTRST_N->PLAN_DATE, sizeof(CAMSADTRST->PLAN_DATE));
    MEMCPY_DN(CAMSADTRST->AUDIT_DATE, CAMSADTRST_N->AUDIT_DATE, sizeof(CAMSADTRST->AUDIT_DATE));
	CAMSADTRST->RESULT = CAMSADTRST_N->RESULT[0];
	CAMSADTRST->STATUS = CAMSADTRST_N->STATUS[0];
	MEMCPY_DN(CAMSADTRST->ACTION_DATE, CAMSADTRST_N->ACTION_DATE, sizeof(CAMSADTRST->ACTION_DATE));
    MEMCPY_DN(CAMSADTRST->ACTION_USER_ID, CAMSADTRST_N->ACTION_USER_ID, sizeof(CAMSADTRST->ACTION_USER_ID));
    CAMSADTRST->ACTION_RESULT = CAMSADTRST_N->ACTION_RESULT[0];
    MEMCPY_DN(CAMSADTRST->ACTION_REMARK, CAMSADTRST_N->ACTION_REMARK, sizeof(CAMSADTRST->ACTION_REMARK));
    MEMCPY_DN(CAMSADTRST->CMF_1, CAMSADTRST_N->CMF_1, sizeof(CAMSADTRST->CMF_1));
    MEMCPY_DN(CAMSADTRST->CMF_2, CAMSADTRST_N->CMF_2, sizeof(CAMSADTRST->CMF_2));
    MEMCPY_DN(CAMSADTRST->CMF_3, CAMSADTRST_N->CMF_3, sizeof(CAMSADTRST->CMF_3));
    MEMCPY_DN(CAMSADTRST->CMF_4, CAMSADTRST_N->CMF_4, sizeof(CAMSADTRST->CMF_4));
    MEMCPY_DN(CAMSADTRST->CMF_5, CAMSADTRST_N->CMF_5, sizeof(CAMSADTRST->CMF_5));
    MEMCPY_DN(CAMSADTRST->CMF_6, CAMSADTRST_N->CMF_6, sizeof(CAMSADTRST->CMF_6));
    MEMCPY_DN(CAMSADTRST->CMF_7, CAMSADTRST_N->CMF_7, sizeof(CAMSADTRST->CMF_7));
    MEMCPY_DN(CAMSADTRST->CMF_8, CAMSADTRST_N->CMF_8, sizeof(CAMSADTRST->CMF_8));
    MEMCPY_DN(CAMSADTRST->CMF_9, CAMSADTRST_N->CMF_9, sizeof(CAMSADTRST->CMF_9));
    MEMCPY_DN(CAMSADTRST->CMF_10, CAMSADTRST_N->CMF_10, sizeof(CAMSADTRST->CMF_10));
    MEMCPY_DN(CAMSADTRST->CREATE_USER_ID, CAMSADTRST_N->CREATE_USER_ID, sizeof(CAMSADTRST->CREATE_USER_ID));
    MEMCPY_DN(CAMSADTRST->CREATE_TIME, CAMSADTRST_N->CREATE_TIME, sizeof(CAMSADTRST->CREATE_TIME));
    MEMCPY_DN(CAMSADTRST->UPDATE_USER_ID, CAMSADTRST_N->UPDATE_USER_ID, sizeof(CAMSADTRST->UPDATE_USER_ID));
