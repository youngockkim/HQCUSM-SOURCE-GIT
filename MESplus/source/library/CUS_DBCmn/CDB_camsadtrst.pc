/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_camsadtrst(int sel_type, struct CAMSADTRST_TAG *CAMSADTRST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CAMSADTRST_N_TAG CAMSADTRST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_camsadtrst(&CAMSADTRST_N, CAMSADTRST);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CAMSADTRST_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    AUDIT_ID,
                    PLAN_DATE,
                    AUDIT_DATE,
                    RESULT,
                    STATUS,
					ACTION_DATE,
                    ACTION_USER_ID,
                    ACTION_RESULT,
                    ACTION_REMARK,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CAMSADTRST
                ORDER BY FACTORY ASC,
                    AUDIT_ID ASC;
            EXEC SQL OPEN CDB_CAMSADTRST_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CAMSADTRST_CUR_2 CURSOR FOR
                SELECT 
                    A.FACTORY,
                    A.AUDIT_ID,                    
                    A.PLAN_DATE,
                    A.AUDIT_DATE,
                    A.RESULT,
                    A.STATUS,
                    B.AUDIT_DESC AS CMF_1,
                    B.CUSTOMER_CODE AS CMF_2,
                    B.AUDITOR AS CMF_3,
                    B.MANAGER_ID AS CMF_4,
                    A.CMF_5,
                    A.CMF_6,
                    A.CMF_7,
                    A.CMF_8,
                    A.CMF_9,
                    A.CMF_10,
                    A.CREATE_USER_ID,
                    A.CREATE_TIME,
                    A.UPDATE_USER_ID,
                    A.UPDATE_TIME
                FROM CAMSADTRST A
                   , CAMSADTPLN B
               WHERE A.FACTORY = B.FACTORY
                 AND A.AUDIT_ID = B.AUDIT_ID                
                 AND A.FACTORY = :CAMSADTRST_N.FACTORY
                 AND A.AUDIT_DATE >= :CAMSADTRST_N.PLAN_DATE
                 AND A.AUDIT_DATE <= :CAMSADTRST_N.AUDIT_DATE
				 AND A.STATUS IN('1','2','3')
                 AND A.STATUS LIKE '%' || TRIM(:CAMSADTRST_N.STATUS) ||'%'
                 AND B.CUSTOMER_CODE LIKE '%' || TRIM(:CAMSADTRST_N.CMF_1) ||'%'
                 AND B.MANAGER_ID LIKE '%' || TRIM(:CAMSADTRST_N.CMF_2) ||'%'
                ORDER BY A.FACTORY ASC,
                    A.AUDIT_ID ASC;
            EXEC SQL OPEN CDB_CAMSADTRST_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_camsadtrst", sel_type);
}


