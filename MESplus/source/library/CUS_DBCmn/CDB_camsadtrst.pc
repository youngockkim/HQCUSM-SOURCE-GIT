/* Add Null Function */
void CDB_add_null_camsadtrst(struct CAMSADTRST_N_TAG *CAMSADTRST_N, struct CAMSADTRST_TAG *CAMSADTRST)
{
    /* memset by NULL */
    memset(CAMSADTRST_N, '\0', sizeof(struct CAMSADTRST_N_TAG));
    
    MEMCPY_AN(CAMSADTRST_N->FACTORY, CAMSADTRST->FACTORY, sizeof(CAMSADTRST->FACTORY));
    MEMCPY_AN(CAMSADTRST_N->AUDIT_ID, CAMSADTRST->AUDIT_ID, sizeof(CAMSADTRST->AUDIT_ID));
    MEMCPY_AN(CAMSADTRST_N->PLAN_DATE, CAMSADTRST->PLAN_DATE, sizeof(CAMSADTRST->PLAN_DATE));
    MEMCPY_AN(CAMSADTRST_N->AUDIT_DATE, CAMSADTRST->AUDIT_DATE, sizeof(CAMSADTRST->AUDIT_DATE));
	CAMSADTRST_N->RESULT[0] = CAMSADTRST->RESULT;
	CAMSADTRST_N->STATUS[0] = CAMSADTRST->STATUS;
	MEMCPY_AN(CAMSADTRST_N->ACTION_DATE, CAMSADTRST->ACTION_DATE, sizeof(CAMSADTRST->ACTION_DATE));
    MEMCPY_AN(CAMSADTRST_N->ACTION_USER_ID, CAMSADTRST->ACTION_USER_ID, sizeof(CAMSADTRST->ACTION_USER_ID));
    CAMSADTRST_N->ACTION_RESULT[0] = CAMSADTRST->ACTION_RESULT;
    MEMCPY_AN(CAMSADTRST_N->ACTION_REMARK, CAMSADTRST->ACTION_REMARK, sizeof(CAMSADTRST->ACTION_REMARK));
    MEMCPY_AN(CAMSADTRST_N->CMF_1, CAMSADTRST->CMF_1, sizeof(CAMSADTRST->CMF_1));
    MEMCPY_AN(CAMSADTRST_N->CMF_2, CAMSADTRST->CMF_2, sizeof(CAMSADTRST->CMF_2));
    MEMCPY_AN(CAMSADTRST_N->CMF_3, CAMSADTRST->CMF_3, sizeof(CAMSADTRST->CMF_3));
    MEMCPY_AN(CAMSADTRST_N->CMF_4, CAMSADTRST->CMF_4, sizeof(CAMSADTRST->CMF_4));
    MEMCPY_AN(CAMSADTRST_N->CMF_5, CAMSADTRST->CMF_5, sizeof(CAMSADTRST->CMF_5));
    MEMCPY_AN(CAMSADTRST_N->CMF_6, CAMSADTRST->CMF_6, sizeof(CAMSADTRST->CMF_6));
