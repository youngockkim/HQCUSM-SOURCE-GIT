    MEMCPY_DN(IERPHCLMOV->INF_PROC_TIME, IERPHCLMOV_N->INF_PROC_TIME, sizeof(IERPHCLMOV->INF_PROC_TIME));
    MEMCPY_DN(IERPHCLMOV->CMF_1, IERPHCLMOV_N->CMF_1, sizeof(IERPHCLMOV->CMF_1));
    MEMCPY_DN(IERPHCLMOV->CMF_2, IERPHCLMOV_N->CMF_2, sizeof(IERPHCLMOV->CMF_2));
    MEMCPY_DN(IERPHCLMOV->CMF_3, IERPHCLMOV_N->CMF_3, sizeof(IERPHCLMOV->CMF_3));
    MEMCPY_DN(IERPHCLMOV->CMF_4, IERPHCLMOV_N->CMF_4, sizeof(IERPHCLMOV->CMF_4));
    MEMCPY_DN(IERPHCLMOV->CMF_5, IERPHCLMOV_N->CMF_5, sizeof(IERPHCLMOV->CMF_5));
    IERPHCLMOV->DATA_FLAG = IERPHCLMOV_N->DATA_FLAG[0];
    MEMCPY_DN(IERPHCLMOV->ZIFERNAM, IERPHCLMOV_N->ZIFERNAM, sizeof(IERPHCLMOV->ZIFERNAM));
    MEMCPY_DN(IERPHCLMOV->ZIFDATE, IERPHCLMOV_N->ZIFDATE, sizeof(IERPHCLMOV->ZIFDATE));
    MEMCPY_DN(IERPHCLMOV->ZIFTIME, IERPHCLMOV_N->ZIFTIME, sizeof(IERPHCLMOV->ZIFTIME));
    MEMCPY_DN(IERPHCLMOV->ZPICODE, IERPHCLMOV_N->ZPICODE, sizeof(IERPHCLMOV->ZPICODE));
    MEMCPY_DN(IERPHCLMOV->ZPIMSGID, IERPHCLMOV_N->ZPIMSGID, sizeof(IERPHCLMOV->ZPIMSGID));
    IERPHCLMOV->ZPISTAT = IERPHCLMOV_N->ZPISTAT[0];
    MEMCPY_DN(IERPHCLMOV->ZPIMSG, IERPHCLMOV_N->ZPIMSG, sizeof(IERPHCLMOV->ZPIMSG));
    IERPHCLMOV->RETURN_TYPE = IERPHCLMOV_N->RETURN_TYPE[0];
    MEMCPY_DN(IERPHCLMOV->RETURN_MSG, IERPHCLMOV_N->RETURN_MSG, sizeof(IERPHCLMOV->RETURN_MSG));
    MEMCPY_DN(IERPHCLMOV->ERP_DATE, IERPHCLMOV_N->ERP_DATE, sizeof(IERPHCLMOV->ERP_DATE));
    MEMCPY_DN(IERPHCLMOV->ERP_TIME, IERPHCLMOV_N->ERP_TIME, sizeof(IERPHCLMOV->ERP_TIME));
    IERPHCLMOV->ERP_FLAG = IERPHCLMOV_N->ERP_FLAG[0];
    MEMCPY_DN(IERPHCLMOV->ERP_MSG, IERPHCLMOV_N->ERP_MSG, sizeof(IERPHCLMOV->ERP_MSG));
    IERPHCLMOV->IF_FLAG = IERPHCLMOV_N->IF_FLAG[0];
}


