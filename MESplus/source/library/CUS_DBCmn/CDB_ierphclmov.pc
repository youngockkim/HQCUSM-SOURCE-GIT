    IERPHCLMOV->QTY = IERPHCLMOV_N->QTY;
    MEMCPY_DN(IERPHCLMOV->UNIT_ID, IERPHCLMOV_N->UNIT_ID, sizeof(IERPHCLMOV->UNIT_ID));
    MEMCPY_DN(IERPHCLMOV->POST_DATE, IERPHCLMOV_N->POST_DATE, sizeof(IERPHCLMOV->POST_DATE));
    MEMCPY_DN(IERPHCLMOV->INF_USER_ID, IERPHCLMOV_N->INF_USER_ID, sizeof(IERPHCLMOV->INF_USER_ID));
