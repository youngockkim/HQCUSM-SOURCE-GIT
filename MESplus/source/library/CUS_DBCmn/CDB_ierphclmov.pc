/* SQL UPDATE Function */
void CDB_update_ierphclmov(int sel_type, struct IERPHCLMOV_TAG *IERPHCLMOV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IERPHCLMOV_N_TAG IERPHCLMOV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ierphclmov(&IERPHCLMOV_N, IERPHCLMOV);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE IERPHCLMOV SET
                    QTY = :IERPHCLMOV_N.QTY,
                    UNIT_ID = :IERPHCLMOV_N.UNIT_ID,
                    POST_DATE = :IERPHCLMOV_N.POST_DATE,
                    INF_USER_ID = :IERPHCLMOV_N.INF_USER_ID,
                    INF_TIME = :IERPHCLMOV_N.INF_TIME,
                    INF_PROC_TIME = :IERPHCLMOV_N.INF_PROC_TIME,
                    CMF_1 = :IERPHCLMOV_N.CMF_1,
                    CMF_2 = :IERPHCLMOV_N.CMF_2,
                    CMF_3 = :IERPHCLMOV_N.CMF_3,
                    CMF_4 = :IERPHCLMOV_N.CMF_4,
                    CMF_5 = :IERPHCLMOV_N.CMF_5,
                    DATA_FLAG = :IERPHCLMOV_N.DATA_FLAG,
                    ZIFERNAM = :IERPHCLMOV_N.ZIFERNAM,
                    ZIFDATE = :IERPHCLMOV_N.ZIFDATE,
                    ZIFTIME = :IERPHCLMOV_N.ZIFTIME,
                    ZPICODE = :IERPHCLMOV_N.ZPICODE,
                    ZPIMSGID = :IERPHCLMOV_N.ZPIMSGID,
                    ZPISTAT = :IERPHCLMOV_N.ZPISTAT,
                    ZPIMSG = :IERPHCLMOV_N.ZPIMSG,
                    RETURN_TYPE = :IERPHCLMOV_N.RETURN_TYPE,
                    RETURN_MSG = :IERPHCLMOV_N.RETURN_MSG,
                    ERP_DATE = :IERPHCLMOV_N.ERP_DATE,
                    ERP_TIME = :IERPHCLMOV_N.ERP_TIME,
                    ERP_FLAG = :IERPHCLMOV_N.ERP_FLAG,
                    ERP_MSG = :IERPHCLMOV_N.ERP_MSG,
                    IF_FLAG = :IERPHCLMOV_N.IF_FLAG
                WHERE DOC_ID = :IERPHCLMOV_N.DOC_ID
                    AND ACTION_TYPE = :IERPHCLMOV_N.ACTION_TYPE
                    AND SITE_ID = :IERPHCLMOV_N.SITE_ID
                    AND PROD_ORDER_NO = :IERPHCLMOV_N.PROD_ORDER_NO
                    AND MATE_NO = :IERPHCLMOV_N.MATE_NO
                    AND BATCH_NO = :IERPHCLMOV_N.BATCH_NO
                    AND FR_LOC_ID = :IERPHCLMOV_N.FR_LOC_ID
                    AND TO_LOC_ID = :IERPHCLMOV_N.TO_LOC_ID;
            break;

        case 2:
            EXEC SQL UPDATE IERPHCLMOV SET
					INF_PROC_TIME = :IERPHCLMOV_N.INF_PROC_TIME,                    
                    RETURN_TYPE = 'E',
                    RETURN_MSG = :IERPHCLMOV_N.RETURN_MSG
                WHERE DOC_ID = :IERPHCLMOV_N.DOC_ID
                    AND ACTION_TYPE = :IERPHCLMOV_N.ACTION_TYPE
                    AND SITE_ID = :IERPHCLMOV_N.SITE_ID
                    AND PROD_ORDER_NO = :IERPHCLMOV_N.PROD_ORDER_NO
                    AND MATE_NO = :IERPHCLMOV_N.MATE_NO
                    AND BATCH_NO = :IERPHCLMOV_N.BATCH_NO
                    AND FR_LOC_ID = :IERPHCLMOV_N.FR_LOC_ID
                    AND TO_LOC_ID = :IERPHCLMOV_N.TO_LOC_ID;
            break;

		case 3:
            EXEC SQL UPDATE IERPHCLMOV A SET
					A.PROD_ORDER_NO = :IERPHCLMOV_N.PROD_ORDER_NO, 
					A.INF_TIME = :IERPHCLMOV_N.INF_TIME, 
					A.ZPISTAT = :IERPHCLMOV_N.ZPISTAT
				WHERE A.INF_PROC_TIME = :IERPHCLMOV_N.INF_PROC_TIME
				 AND  A.ZPISTAT = ' '
				 AND  EXISTS (SELECT 1 
							   FROM IERPHCLMOV B 
							  WHERE A.INF_PROC_TIME = B.INF_PROC_TIME
								AND CMF_1 = :IERPHCLMOV_N.CMF_1
								AND ZPISTAT = ' ');
			break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_ierphclmov", sel_type);
}


