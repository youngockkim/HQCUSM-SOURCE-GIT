                    RETURN_TYPE,
                    RETURN_MSG,
                    ERP_DATE,
                    ERP_TIME,
                    ERP_FLAG,
                    ERP_MSG,
                    IF_FLAG
                FROM IERPHCLMOV
				WHERE RETURN_TYPE <> 'E'
                ORDER BY DOC_ID ASC,
                    ACTION_TYPE ASC,
                    SITE_ID ASC,
                    PROD_ORDER_NO ASC,
                    MATE_NO ASC,
                    BATCH_NO ASC,
                    FR_LOC_ID ASC,
                    TO_LOC_ID ASC;
            EXEC SQL OPEN CDB_IERPHCLMOV_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_ierphclmov", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_ierphclmov(int sel_type, struct IERPHCLMOV_TAG *IERPHCLMOV)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IERPHCLMOV_N_TAG IERPHCLMOV_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_IERPHCLMOV_CUR_1 INTO
                :IERPHCLMOV_N.DOC_ID,
                :IERPHCLMOV_N.ACTION_TYPE,
                :IERPHCLMOV_N.SITE_ID,
                :IERPHCLMOV_N.PROD_ORDER_NO,
                :IERPHCLMOV_N.MATE_NO,
                :IERPHCLMOV_N.BATCH_NO,
                :IERPHCLMOV_N.FR_LOC_ID,
                :IERPHCLMOV_N.TO_LOC_ID,
                :IERPHCLMOV_N.QTY,
                :IERPHCLMOV_N.UNIT_ID,
                :IERPHCLMOV_N.POST_DATE,
                :IERPHCLMOV_N.INF_USER_ID,
                :IERPHCLMOV_N.INF_TIME,
                :IERPHCLMOV_N.INF_PROC_TIME,
                :IERPHCLMOV_N.CMF_1,
                :IERPHCLMOV_N.CMF_2,
                :IERPHCLMOV_N.CMF_3,
                :IERPHCLMOV_N.CMF_4,
                :IERPHCLMOV_N.CMF_5,
                :IERPHCLMOV_N.DATA_FLAG,
                :IERPHCLMOV_N.ZIFERNAM,
                :IERPHCLMOV_N.ZIFDATE,
                :IERPHCLMOV_N.ZIFTIME,
                :IERPHCLMOV_N.ZPICODE,
                :IERPHCLMOV_N.ZPIMSGID,
                :IERPHCLMOV_N.ZPISTAT,
                :IERPHCLMOV_N.ZPIMSG,
                :IERPHCLMOV_N.RETURN_TYPE,
                :IERPHCLMOV_N.RETURN_MSG,
                :IERPHCLMOV_N.ERP_DATE,
                :IERPHCLMOV_N.ERP_TIME,
                :IERPHCLMOV_N.ERP_FLAG,
                :IERPHCLMOV_N.ERP_MSG,
                :IERPHCLMOV_N.IF_FLAG;
            break;

		case 2:
            EXEC SQL FETCH CDB_IERPHCLMOV_CUR_2 INTO
                :IERPHCLMOV_N.DOC_ID,
                :IERPHCLMOV_N.ACTION_TYPE,
                :IERPHCLMOV_N.SITE_ID,
                :IERPHCLMOV_N.PROD_ORDER_NO,
                :IERPHCLMOV_N.MATE_NO,
                :IERPHCLMOV_N.BATCH_NO,
                :IERPHCLMOV_N.FR_LOC_ID,
                :IERPHCLMOV_N.TO_LOC_ID,
                :IERPHCLMOV_N.QTY,
                :IERPHCLMOV_N.UNIT_ID,
                :IERPHCLMOV_N.POST_DATE,
                :IERPHCLMOV_N.INF_USER_ID,
                :IERPHCLMOV_N.INF_TIME,
                :IERPHCLMOV_N.INF_PROC_TIME,
                :IERPHCLMOV_N.CMF_1,
                :IERPHCLMOV_N.CMF_2,
                :IERPHCLMOV_N.CMF_3,
                :IERPHCLMOV_N.CMF_4,
                :IERPHCLMOV_N.CMF_5,
                :IERPHCLMOV_N.DATA_FLAG,
                :IERPHCLMOV_N.ZIFERNAM,
                :IERPHCLMOV_N.ZIFDATE,
                :IERPHCLMOV_N.ZIFTIME,
                :IERPHCLMOV_N.ZPICODE,
                :IERPHCLMOV_N.ZPIMSGID,
                :IERPHCLMOV_N.ZPISTAT,
                :IERPHCLMOV_N.ZPIMSG,
                :IERPHCLMOV_N.RETURN_TYPE,
                :IERPHCLMOV_N.RETURN_MSG,
                :IERPHCLMOV_N.ERP_DATE,
                :IERPHCLMOV_N.ERP_TIME,
                :IERPHCLMOV_N.ERP_FLAG,
                :IERPHCLMOV_N.ERP_MSG,
                :IERPHCLMOV_N.IF_FLAG;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_ierphclmov(&IERPHCLMOV_N, IERPHCLMOV);
    }

    DB_stop_query_timer("CDB_fetch_ierphclmov", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_ierphclmov(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IERPHCLMOV_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IERPHCLMOV_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ierphclmov", sel_type);
}


/* Initialize Function */
void CDB_init_ierphclmov(struct IERPHCLMOV_TAG *IERPHCLMOV)
{
    /* memset by Space */
    memset(IERPHCLMOV, ' ', sizeof(struct IERPHCLMOV_TAG));
    
    IERPHCLMOV->QTY = 0;
}


/* Add Null Function */
void CDB_add_null_ierphclmov(struct IERPHCLMOV_N_TAG *IERPHCLMOV_N, struct IERPHCLMOV_TAG *IERPHCLMOV)
{
    /* memset by NULL */
    memset(IERPHCLMOV_N, '\0', sizeof(struct IERPHCLMOV_N_TAG));
    
    MEMCPY_AN(IERPHCLMOV_N->DOC_ID, IERPHCLMOV->DOC_ID, sizeof(IERPHCLMOV->DOC_ID));
    MEMCPY_AN(IERPHCLMOV_N->ACTION_TYPE, IERPHCLMOV->ACTION_TYPE, sizeof(IERPHCLMOV->ACTION_TYPE));
    MEMCPY_AN(IERPHCLMOV_N->SITE_ID, IERPHCLMOV->SITE_ID, sizeof(IERPHCLMOV->SITE_ID));
    MEMCPY_AN(IERPHCLMOV_N->PROD_ORDER_NO, IERPHCLMOV->PROD_ORDER_NO, sizeof(IERPHCLMOV->PROD_ORDER_NO));
    MEMCPY_AN(IERPHCLMOV_N->MATE_NO, IERPHCLMOV->MATE_NO, sizeof(IERPHCLMOV->MATE_NO));
    MEMCPY_AN(IERPHCLMOV_N->BATCH_NO, IERPHCLMOV->BATCH_NO, sizeof(IERPHCLMOV->BATCH_NO));
    MEMCPY_AN(IERPHCLMOV_N->FR_LOC_ID, IERPHCLMOV->FR_LOC_ID, sizeof(IERPHCLMOV->FR_LOC_ID));
    MEMCPY_AN(IERPHCLMOV_N->TO_LOC_ID, IERPHCLMOV->TO_LOC_ID, sizeof(IERPHCLMOV->TO_LOC_ID));
    IERPHCLMOV_N->QTY = IERPHCLMOV->QTY;
    MEMCPY_AN(IERPHCLMOV_N->UNIT_ID, IERPHCLMOV->UNIT_ID, sizeof(IERPHCLMOV->UNIT_ID));
    MEMCPY_AN(IERPHCLMOV_N->POST_DATE, IERPHCLMOV->POST_DATE, sizeof(IERPHCLMOV->POST_DATE));
    MEMCPY_AN(IERPHCLMOV_N->INF_USER_ID, IERPHCLMOV->INF_USER_ID, sizeof(IERPHCLMOV->INF_USER_ID));
    MEMCPY_AN(IERPHCLMOV_N->INF_TIME, IERPHCLMOV->INF_TIME, sizeof(IERPHCLMOV->INF_TIME));
    MEMCPY_AN(IERPHCLMOV_N->INF_PROC_TIME, IERPHCLMOV->INF_PROC_TIME, sizeof(IERPHCLMOV->INF_PROC_TIME));
    MEMCPY_AN(IERPHCLMOV_N->CMF_1, IERPHCLMOV->CMF_1, sizeof(IERPHCLMOV->CMF_1));
    MEMCPY_AN(IERPHCLMOV_N->CMF_2, IERPHCLMOV->CMF_2, sizeof(IERPHCLMOV->CMF_2));
    MEMCPY_AN(IERPHCLMOV_N->CMF_3, IERPHCLMOV->CMF_3, sizeof(IERPHCLMOV->CMF_3));
    MEMCPY_AN(IERPHCLMOV_N->CMF_4, IERPHCLMOV->CMF_4, sizeof(IERPHCLMOV->CMF_4));
    MEMCPY_AN(IERPHCLMOV_N->CMF_5, IERPHCLMOV->CMF_5, sizeof(IERPHCLMOV->CMF_5));
    IERPHCLMOV_N->DATA_FLAG[0] = IERPHCLMOV->DATA_FLAG;
    MEMCPY_AN(IERPHCLMOV_N->ZIFERNAM, IERPHCLMOV->ZIFERNAM, sizeof(IERPHCLMOV->ZIFERNAM));
    MEMCPY_AN(IERPHCLMOV_N->ZIFDATE, IERPHCLMOV->ZIFDATE, sizeof(IERPHCLMOV->ZIFDATE));
    MEMCPY_AN(IERPHCLMOV_N->ZIFTIME, IERPHCLMOV->ZIFTIME, sizeof(IERPHCLMOV->ZIFTIME));
    MEMCPY_AN(IERPHCLMOV_N->ZPICODE, IERPHCLMOV->ZPICODE, sizeof(IERPHCLMOV->ZPICODE));
    MEMCPY_AN(IERPHCLMOV_N->ZPIMSGID, IERPHCLMOV->ZPIMSGID, sizeof(IERPHCLMOV->ZPIMSGID));
    IERPHCLMOV_N->ZPISTAT[0] = IERPHCLMOV->ZPISTAT;
    MEMCPY_AN(IERPHCLMOV_N->ZPIMSG, IERPHCLMOV->ZPIMSG, sizeof(IERPHCLMOV->ZPIMSG));
    IERPHCLMOV_N->RETURN_TYPE[0] = IERPHCLMOV->RETURN_TYPE;
    MEMCPY_AN(IERPHCLMOV_N->RETURN_MSG, IERPHCLMOV->RETURN_MSG, sizeof(IERPHCLMOV->RETURN_MSG));
    MEMCPY_AN(IERPHCLMOV_N->ERP_DATE, IERPHCLMOV->ERP_DATE, sizeof(IERPHCLMOV->ERP_DATE));
    MEMCPY_AN(IERPHCLMOV_N->ERP_TIME, IERPHCLMOV->ERP_TIME, sizeof(IERPHCLMOV->ERP_TIME));
    IERPHCLMOV_N->ERP_FLAG[0] = IERPHCLMOV->ERP_FLAG;
    MEMCPY_AN(IERPHCLMOV_N->ERP_MSG, IERPHCLMOV->ERP_MSG, sizeof(IERPHCLMOV->ERP_MSG));
    IERPHCLMOV_N->IF_FLAG[0] = IERPHCLMOV->IF_FLAG;
}


/* Del Null Function */
void CDB_del_null_ierphclmov(struct IERPHCLMOV_N_TAG *IERPHCLMOV_N, struct IERPHCLMOV_TAG *IERPHCLMOV)
{
    MEMCPY_DN(IERPHCLMOV->DOC_ID, IERPHCLMOV_N->DOC_ID, sizeof(IERPHCLMOV->DOC_ID));
    MEMCPY_DN(IERPHCLMOV->ACTION_TYPE, IERPHCLMOV_N->ACTION_TYPE, sizeof(IERPHCLMOV->ACTION_TYPE));
