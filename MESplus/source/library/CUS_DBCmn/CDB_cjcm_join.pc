/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cjcm_alarm(int sel_type, struct CJCM_ALARM_TAG *CJCM_ALARM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CJCM_ALARM_N_TAG CJCM_ALARM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cjcm_alarm(&CJCM_ALARM_N, CJCM_ALARM);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CJCM_ALARM_CUR_1 CURSOR FOR
                SELECT A.FACTORY
				     , A.ORDER_ID
					 , TO_CHAR(TO_DATE(B.ORD_START_DATE,'YYYYMMDD'), 'FMMM/DD/YYYY') AS ORD_START_DATE
					 , B.MAT_ID
					 , NVL(C.MAT_DESC,' ') AS MAT_DESC
					 , B.LINE_ID
					 , A.ALARM_CODE
					 , COUNT(A.ITEM_CODE) AS ITEM_COUNT
				 FROM CJCMJOBITM A
					, CJCMJOBSTS B
					, MWIPMATDEF C
				WHERE A.FACTORY = B.FACTORY
				  AND A.ORDER_ID = B.ORDER_ID
				  AND A.FACTORY = C.FACTORY(+)
				  AND B.MAT_ID = C.MAT_ID(+)
				  AND A.FACTORY = :CJCM_ALARM_N.FACTORY
				  AND A.STATUS IN('F','S','W')
				  AND A.ALARM_FLAG = 'Y'
				  AND B.ORD_START_DATE BETWEEN TO_CHAR(SYSDATE - TO_NUMBER(NVL(TRIM(A.CMF_1),0)+3),'YYYYMMDD') 
				                           AND TO_CHAR(SYSDATE - TO_NUMBER(NVL(TRIM(A.CMF_1),0)),'YYYYMMDD')
				GROUP BY A.FACTORY
				    , A.ORDER_ID
					, B.ORD_START_DATE
					, A.ALARM_CODE
					, B.MAT_ID
					, C.MAT_DESC
					, B.LINE_ID;
            EXEC SQL OPEN CDB_CJCM_ALARM_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cjcm_alarm", sel_type);
}


