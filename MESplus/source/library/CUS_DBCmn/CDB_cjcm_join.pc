/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cjcm_join(int sel_type, struct CJCM_JOIN_TAG *CJCM_JOIN)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CJCM_JOIN_N_TAG CJCM_JOIN_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cjcm_join(&CJCM_JOIN_N, CJCM_JOIN);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CJCM_JOIN_CUR_1 CURSOR FOR
                SELECT A.FACTORY
					 , A.ORDER_ID
					 , A.MAT_ID
					 , C.MAT_DESC
					 , A.LINE_ID
					 , D.DATA_1 AS LINE_NAME    
					 , A.ORD_START_DATE 
					 , A.STATUS 
					 , B.ITEM_CODE 
					 , E.ITEM_NAME
					 , B.AUTO_FLAG
					 , B.RESPONSIBILITY
					 , B.PLAN_START_DATE
					 , B.PLAN_END_DATE
					 , B.START_TIME 
					 , B.END_TIME
					 , B.WORK_TIME
					 , B.STATUS AS CHECK_FLAG
					 , B.CMF_1 AS ERR_MSG
				  FROM CJCMJOBSTS A 
					 , CJCMJOBITM B
					 , MWIPMATDEF C
					 , MGCMTBLDAT D
					 , CJCMITMDEF E
				WHERE A.FACTORY = B.FACTORY
				  AND A.ORDER_ID = B.ORDER_ID
				  AND A.FACTORY = E.FACTORY
				  AND B.ITEM_CODE = E.ITEM_CODE
				  AND A.FACTORY = C.FACTORY(+)
				  AND A.MAT_ID = C.MAT_ID(+)
				  AND A.FACTORY = D.FACTORY(+)
				  AND D.TABLE_NAME(+) = '@LINE_CODE'
				  AND A.LINE_ID = D.KEY_1(+)
				  AND A.FACTORY = :CJCM_JOIN_N.FACTORY
				  AND A.ORDER_ID LIKE '%' || TRIM(:CJCM_JOIN_N.ORDER_ID) || '%'
				  AND A.ORD_START_DATE >= :CJCM_JOIN_N.PLAN_START_DATE 
				  AND A.ORD_START_DATE <= :CJCM_JOIN_N.PLAN_END_DATE 
				  AND A.MAT_ID LIKE '%' || TRIM(:CJCM_JOIN_N.MAT_ID) || '%'
				  AND A.LINE_ID LIKE '%' || TRIM(:CJCM_JOIN_N.LINE_ID) || '%'
				  AND E.USE_FLAG = 'Y'
				 ORDER BY A.ORD_START_DATE ASC, A.ORDER_ID ASC, B.AUTO_FLAG ASC, B.ITEM_CODE ASC;
            EXEC SQL OPEN CDB_CJCM_JOIN_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cjcm_join", sel_type);
}


