{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CEDCLOTAOI_N_TAG CEDCLOTAOI_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cedclotaoi(&CEDCLOTAOI_N, CEDCLOTAOI);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CEDCLOTAOI_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    RES_ID,
                    INS_SEQ,
                    FACTORY,
