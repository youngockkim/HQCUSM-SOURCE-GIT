                :CEDCLOTAOI_N.DATA_6,
                :CEDCLOTAOI_N.DATA_7,
                :CEDCLOTAOI_N.DATA_8,
                :CEDCLOTAOI_N.DATA_9,
                :CEDCLOTAOI_N.DATA_10,
                :CEDCLOTAOI_N.DATA_11,
                :CEDCLOTAOI_N.DATA_12,
                :CEDCLOTAOI_N.DATA_13,
                :CEDCLOTAOI_N.DATA_14,
                :CEDCLOTAOI_N.DATA_15,
                :CEDCLOTAOI_N.DATA_16,
                :CEDCLOTAOI_N.DATA_17,
                :CEDCLOTAOI_N.DATA_18,
                :CEDCLOTAOI_N.DATA_19,
                :CEDCLOTAOI_N.DATA_20,
                :CEDCLOTAOI_N.DATA_21,
                :CEDCLOTAOI_N.DATA_22,
                :CEDCLOTAOI_N.DATA_23,
                :CEDCLOTAOI_N.DATA_24;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cedclotaoi(&CEDCLOTAOI_N, CEDCLOTAOI);
    }

    DB_stop_query_timer("CDB_fetch_cedclotaoi", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cedclotaoi(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CEDCLOTAOI_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cedclotaoi", sel_type);
}


/* Initialize Function */
void CDB_init_cedclotaoi(struct CEDCLOTAOI_TAG *CEDCLOTAOI)
{
    /* memset by Space */
    memset(CEDCLOTAOI, ' ', sizeof(struct CEDCLOTAOI_TAG));
    
    CEDCLOTAOI->INS_SEQ = 0;
    CEDCLOTAOI->LOT_HIST_SEQ = 0;
    CEDCLOTAOI->INS_CNT = 0;
}


