                :IBASPWRDAT_N.POWER_GRADE,
                :IBASPWRDAT_N.QTY,
                :IBASPWRDAT_N.POWER_LOW,
                :IBASPWRDAT_N.POWER_HIGH,
                :IBASPWRDAT_N.CREATOR,
                :IBASPWRDAT_N.MODIFIER,
                :IBASPWRDAT_N.MOD_DATE,
                :IBASPWRDAT_N.SITE_ID,
                :IBASPWRDAT_N.INF_TIME,
                :IBASPWRDAT_N.INF_PROC_TIME,
                :IBASPWRDAT_N.CMF_1,
                :IBASPWRDAT_N.CMF_2,
                :IBASPWRDAT_N.CMF_3,
                :IBASPWRDAT_N.CMF_4,
                :IBASPWRDAT_N.CMF_5,
                :IBASPWRDAT_N.DATA_FLAG,
                :IBASPWRDAT_N.UPDATE_COUNT,
                :IBASPWRDAT_N.INSERT_COUNT,
                :IBASPWRDAT_N.DELETE_COUNT,
                :IBASPWRDAT_N.SQL_DML_COUNT,
                :IBASPWRDAT_N.ZPICODE,
                :IBASPWRDAT_N.ZPIMSGID,
                :IBASPWRDAT_N.RETURN_TYPE,
                :IBASPWRDAT_N.RETURN_MSG,
                :IBASPWRDAT_N.ZIFERNAM,
                :IBASPWRDAT_N.ZIFDATE,
                :IBASPWRDAT_N.ZIFTIME,
                :IBASPWRDAT_N.ZPISTAT,
                :IBASPWRDAT_N.ZPIMSG;
            break;

		case 2:
            EXEC SQL FETCH CDB_IBASPWRDAT_CUR_2 INTO
                :IBASPWRDAT_N.DOC_ID,
                :IBASPWRDAT_N.SALES_GRP,
                :IBASPWRDAT_N.SALES_GRP_ITEM,
                :IBASPWRDAT_N.PROD_NO,
                :IBASPWRDAT_N.CO_PROD_YN,
                :IBASPWRDAT_N.SALES_ORDER_NO,
                :IBASPWRDAT_N.SALES_ORDER_ITEM,
                :IBASPWRDAT_N.POWER_GRADE,
                :IBASPWRDAT_N.QTY,
                :IBASPWRDAT_N.POWER_LOW,
                :IBASPWRDAT_N.POWER_HIGH,
                :IBASPWRDAT_N.CREATOR,
                :IBASPWRDAT_N.MODIFIER,
                :IBASPWRDAT_N.MOD_DATE,
                :IBASPWRDAT_N.SITE_ID,
                :IBASPWRDAT_N.INF_TIME,
                :IBASPWRDAT_N.INF_PROC_TIME,
                :IBASPWRDAT_N.CMF_1,
                :IBASPWRDAT_N.CMF_2,
                :IBASPWRDAT_N.CMF_3,
                :IBASPWRDAT_N.CMF_4,
                :IBASPWRDAT_N.CMF_5,
                :IBASPWRDAT_N.DATA_FLAG,
                :IBASPWRDAT_N.UPDATE_COUNT,
                :IBASPWRDAT_N.INSERT_COUNT,
                :IBASPWRDAT_N.DELETE_COUNT,
                :IBASPWRDAT_N.SQL_DML_COUNT,
                :IBASPWRDAT_N.ZPICODE,
                :IBASPWRDAT_N.ZPIMSGID,
                :IBASPWRDAT_N.RETURN_TYPE,
                :IBASPWRDAT_N.RETURN_MSG,
                :IBASPWRDAT_N.ZIFERNAM,
                :IBASPWRDAT_N.ZIFDATE,
                :IBASPWRDAT_N.ZIFTIME,
                :IBASPWRDAT_N.ZPISTAT,
                :IBASPWRDAT_N.ZPIMSG;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_ibaspwrdat(&IBASPWRDAT_N, IBASPWRDAT);
    }

    DB_stop_query_timer("CDB_fetch_ibaspwrdat", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_ibaspwrdat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IBASPWRDAT_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IBASPWRDAT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ibaspwrdat", sel_type);
}


/* Initialize Function */
void CDB_init_ibaspwrdat(struct IBASPWRDAT_TAG *IBASPWRDAT)
{
    /* memset by Space */
    memset(IBASPWRDAT, ' ', sizeof(struct IBASPWRDAT_TAG));
    
    IBASPWRDAT->POWER_GRADE = 0;
    IBASPWRDAT->QTY = 0;
    IBASPWRDAT->POWER_LOW = 0;
    IBASPWRDAT->POWER_HIGH = 0;
}


/* Add Null Function */
void CDB_add_null_ibaspwrdat(struct IBASPWRDAT_N_TAG *IBASPWRDAT_N, struct IBASPWRDAT_TAG *IBASPWRDAT)
{
    /* memset by NULL */
    memset(IBASPWRDAT_N, '\0', sizeof(struct IBASPWRDAT_N_TAG));
    
    MEMCPY_AN(IBASPWRDAT_N->DOC_ID, IBASPWRDAT->DOC_ID, sizeof(IBASPWRDAT->DOC_ID));
    MEMCPY_AN(IBASPWRDAT_N->SALES_GRP, IBASPWRDAT->SALES_GRP, sizeof(IBASPWRDAT->SALES_GRP));
    MEMCPY_AN(IBASPWRDAT_N->SALES_GRP_ITEM, IBASPWRDAT->SALES_GRP_ITEM, sizeof(IBASPWRDAT->SALES_GRP_ITEM));
    MEMCPY_AN(IBASPWRDAT_N->PROD_NO, IBASPWRDAT->PROD_NO, sizeof(IBASPWRDAT->PROD_NO));
    IBASPWRDAT_N->CO_PROD_YN[0] = IBASPWRDAT->CO_PROD_YN;
    MEMCPY_AN(IBASPWRDAT_N->SALES_ORDER_NO, IBASPWRDAT->SALES_ORDER_NO, sizeof(IBASPWRDAT->SALES_ORDER_NO));
    MEMCPY_AN(IBASPWRDAT_N->SALES_ORDER_ITEM, IBASPWRDAT->SALES_ORDER_ITEM, sizeof(IBASPWRDAT->SALES_ORDER_ITEM));
    IBASPWRDAT_N->POWER_GRADE = IBASPWRDAT->POWER_GRADE;
