    MEMCPY_AN(IBASPWRDAT_N->CMF_5, IBASPWRDAT->CMF_5, sizeof(IBASPWRDAT->CMF_5));
    IBASPWRDAT_N->DATA_FLAG[0] = IBASPWRDAT->DATA_FLAG;
    MEMCPY_AN(IBASPWRDAT_N->UPDATE_COUNT, IBASPWRDAT->UPDATE_COUNT, sizeof(IBASPWRDAT->UPDATE_COUNT));
    MEMCPY_AN(IBASPWRDAT_N->INSERT_COUNT, IBASPWRDAT->INSERT_COUNT, sizeof(IBASPWRDAT->INSERT_COUNT));
    MEMCPY_AN(IBASPWRDAT_N->DELETE_COUNT, IBASPWRDAT->DELETE_COUNT, sizeof(IBASPWRDAT->DELETE_COUNT));
    MEMCPY_AN(IBASPWRDAT_N->SQL_DML_COUNT, IBASPWRDAT->SQL_DML_COUNT, sizeof(IBASPWRDAT->SQL_DML_COUNT));
    MEMCPY_AN(IBASPWRDAT_N->ZPICODE, IBASPWRDAT->ZPICODE, sizeof(IBASPWRDAT->ZPICODE));
    MEMCPY_AN(IBASPWRDAT_N->ZPIMSGID, IBASPWRDAT->ZPIMSGID, sizeof(IBASPWRDAT->ZPIMSGID));
    IBASPWRDAT_N->RETURN_TYPE[0] = IBASPWRDAT->RETURN_TYPE;
