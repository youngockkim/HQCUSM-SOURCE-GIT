    IBASPWRDAT_N->POWER_LOW = IBASPWRDAT->POWER_LOW;
    IBASPWRDAT_N->POWER_HIGH = IBASPWRDAT->POWER_HIGH;
    MEMCPY_AN(IBASPWRDAT_N->CREATOR, IBASPWRDAT->CREATOR, sizeof(IBASPWRDAT->CREATOR));
    MEMCPY_AN(IBASPWRDAT_N->MODIFIER, IBASPWRDAT->MODIFIER, sizeof(IBASPWRDAT->MODIFIER));
    MEMCPY_AN(IBASPWRDAT_N->MOD_DATE, IBASPWRDAT->MOD_DATE, sizeof(IBASPWRDAT->MOD_DATE));
    MEMCPY_AN(IBASPWRDAT_N->SITE_ID, IBASPWRDAT->SITE_ID, sizeof(IBASPWRDAT->SITE_ID));
    MEMCPY_AN(IBASPWRDAT_N->INF_TIME, IBASPWRDAT->INF_TIME, sizeof(IBASPWRDAT->INF_TIME));
    MEMCPY_AN(IBASPWRDAT_N->INF_PROC_TIME, IBASPWRDAT->INF_PROC_TIME, sizeof(IBASPWRDAT->INF_PROC_TIME));
    MEMCPY_AN(IBASPWRDAT_N->CMF_1, IBASPWRDAT->CMF_1, sizeof(IBASPWRDAT->CMF_1));
    MEMCPY_AN(IBASPWRDAT_N->CMF_2, IBASPWRDAT->CMF_2, sizeof(IBASPWRDAT->CMF_2));
