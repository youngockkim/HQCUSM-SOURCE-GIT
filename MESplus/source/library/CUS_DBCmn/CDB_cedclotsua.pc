                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10
                FROM CEDCLOTSUA
                ORDER BY FACTORY ASC,
                    INS_TYPE ASC,
                    LOT_ID ASC,
                    HIST_SEQ ASC,
                    INS_CNT ASC;
            EXEC SQL OPEN CDB_CEDCLOTSUA_CUR_1;
            break;


        default:
