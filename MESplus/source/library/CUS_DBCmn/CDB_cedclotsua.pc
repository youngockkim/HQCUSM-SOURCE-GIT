    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CEDCLOTSUA_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    INS_TYPE,
                    LOT_ID,
                    HIST_SEQ,
                    INS_CNT,
                    RES_ID,
                    LINE_ID,
                    OPER,
                    LOT_HIST_SEQ,
                    INS_TIME,
