/* Add Null Function */
void CDB_add_null_cedclotsua(struct CEDCLOTSUA_N_TAG *CEDCLOTSUA_N, struct CEDCLOTSUA_TAG *CEDCLOTSUA)
{
    /* memset by NULL */
    memset(CEDCLOTSUA_N, '\0', sizeof(struct CEDCLOTSUA_N_TAG));
    
    MEMCPY_AN(CEDCLOTSUA_N->FACTORY, CEDCLOTSUA->FACTORY, sizeof(CEDCLOTSUA->FACTORY));
    MEMCPY_AN(CEDCLOTSUA_N->INS_TYPE, CEDCLOTSUA->INS_TYPE, sizeof(CEDCLOTSUA->INS_TYPE));
    MEMCPY_AN(CEDCLOTSUA_N->LOT_ID, CEDCLOTSUA->LOT_ID, sizeof(CEDCLOTSUA->LOT_ID));
    CEDCLOTSUA_N->HIST_SEQ = CEDCLOTSUA->HIST_SEQ;
    CEDCLOTSUA_N->INS_CNT = CEDCLOTSUA->INS_CNT;
    MEMCPY_AN(CEDCLOTSUA_N->RES_ID, CEDCLOTSUA->RES_ID, sizeof(CEDCLOTSUA->RES_ID));
    MEMCPY_AN(CEDCLOTSUA_N->LINE_ID, CEDCLOTSUA->LINE_ID, sizeof(CEDCLOTSUA->LINE_ID));
    MEMCPY_AN(CEDCLOTSUA_N->OPER, CEDCLOTSUA->OPER, sizeof(CEDCLOTSUA->OPER));
    CEDCLOTSUA_N->LOT_HIST_SEQ = CEDCLOTSUA->LOT_HIST_SEQ;
    MEMCPY_AN(CEDCLOTSUA_N->INS_TIME, CEDCLOTSUA->INS_TIME, sizeof(CEDCLOTSUA->INS_TIME));
    MEMCPY_AN(CEDCLOTSUA_N->INS_USER_ID, CEDCLOTSUA->INS_USER_ID, sizeof(CEDCLOTSUA->INS_USER_ID));
    MEMCPY_AN(CEDCLOTSUA_N->RESULT_VALUE, CEDCLOTSUA->RESULT_VALUE, sizeof(CEDCLOTSUA->RESULT_VALUE));
    MEMCPY_AN(CEDCLOTSUA_N->MODULE_IMAGE, CEDCLOTSUA->MODULE_IMAGE, sizeof(CEDCLOTSUA->MODULE_IMAGE));
    CEDCLOTSUA_N->MODE_CODE[0] = CEDCLOTSUA->MODE_CODE;
    MEMCPY_AN(CEDCLOTSUA_N->PRODUCT_INFO, CEDCLOTSUA->PRODUCT_INFO, sizeof(CEDCLOTSUA->PRODUCT_INFO));
    MEMCPY_AN(CEDCLOTSUA_N->CMF_1, CEDCLOTSUA->CMF_1, sizeof(CEDCLOTSUA->CMF_1));
    MEMCPY_AN(CEDCLOTSUA_N->CMF_2, CEDCLOTSUA->CMF_2, sizeof(CEDCLOTSUA->CMF_2));
    MEMCPY_AN(CEDCLOTSUA_N->CMF_3, CEDCLOTSUA->CMF_3, sizeof(CEDCLOTSUA->CMF_3));
    MEMCPY_AN(CEDCLOTSUA_N->CMF_4, CEDCLOTSUA->CMF_4, sizeof(CEDCLOTSUA->CMF_4));
    MEMCPY_AN(CEDCLOTSUA_N->CMF_5, CEDCLOTSUA->CMF_5, sizeof(CEDCLOTSUA->CMF_5));
    MEMCPY_AN(CEDCLOTSUA_N->CMF_6, CEDCLOTSUA->CMF_6, sizeof(CEDCLOTSUA->CMF_6));
    MEMCPY_AN(CEDCLOTSUA_N->CMF_7, CEDCLOTSUA->CMF_7, sizeof(CEDCLOTSUA->CMF_7));
    MEMCPY_AN(CEDCLOTSUA_N->CMF_8, CEDCLOTSUA->CMF_8, sizeof(CEDCLOTSUA->CMF_8));
    MEMCPY_AN(CEDCLOTSUA_N->CMF_9, CEDCLOTSUA->CMF_9, sizeof(CEDCLOTSUA->CMF_9));
    MEMCPY_AN(CEDCLOTSUA_N->CMF_10, CEDCLOTSUA->CMF_10, sizeof(CEDCLOTSUA->CMF_10));
}


/* Del Null Function */
void CDB_del_null_cedclotsua(struct CEDCLOTSUA_N_TAG *CEDCLOTSUA_N, struct CEDCLOTSUA_TAG *CEDCLOTSUA)
{
    MEMCPY_DN(CEDCLOTSUA->FACTORY, CEDCLOTSUA_N->FACTORY, sizeof(CEDCLOTSUA->FACTORY));
