    MEMCPY_DN(CEDCLOTSUA->RESULT_VALUE, CEDCLOTSUA_N->RESULT_VALUE, sizeof(CEDCLOTSUA->RESULT_VALUE));
    MEMCPY_DN(CEDCLOTSUA->MODULE_IMAGE, CEDCLOTSUA_N->MODULE_IMAGE, sizeof(CEDCLOTSUA->MODULE_IMAGE));
    CEDCLOTSUA->MODE_CODE = CEDCLOTSUA_N->MODE_CODE[0];
    MEMCPY_DN(CEDCLOTSUA->PRODUCT_INFO, CEDCLOTSUA_N->PRODUCT_INFO, sizeof(CEDCLOTSUA->PRODUCT_INFO));
    MEMCPY_DN(CEDCLOTSUA->CMF_1, CEDCLOTSUA_N->CMF_1, sizeof(CEDCLOTSUA->CMF_1));
    MEMCPY_DN(CEDCLOTSUA->CMF_2, CEDCLOTSUA_N->CMF_2, sizeof(CEDCLOTSUA->CMF_2));
    MEMCPY_DN(CEDCLOTSUA->CMF_3, CEDCLOTSUA_N->CMF_3, sizeof(CEDCLOTSUA->CMF_3));
    MEMCPY_DN(CEDCLOTSUA->CMF_4, CEDCLOTSUA_N->CMF_4, sizeof(CEDCLOTSUA->CMF_4));
    MEMCPY_DN(CEDCLOTSUA->CMF_5, CEDCLOTSUA_N->CMF_5, sizeof(CEDCLOTSUA->CMF_5));
    MEMCPY_DN(CEDCLOTSUA->CMF_6, CEDCLOTSUA_N->CMF_6, sizeof(CEDCLOTSUA->CMF_6));
    MEMCPY_DN(CEDCLOTSUA->CMF_7, CEDCLOTSUA_N->CMF_7, sizeof(CEDCLOTSUA->CMF_7));
    MEMCPY_DN(CEDCLOTSUA->CMF_8, CEDCLOTSUA_N->CMF_8, sizeof(CEDCLOTSUA->CMF_8));
    MEMCPY_DN(CEDCLOTSUA->CMF_9, CEDCLOTSUA_N->CMF_9, sizeof(CEDCLOTSUA->CMF_9));
