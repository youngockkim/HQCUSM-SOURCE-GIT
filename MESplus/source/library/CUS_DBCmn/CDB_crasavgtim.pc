                    CMF_9,
                    CMF_10
                FROM CRASAVGTIM
                ORDER BY FACTORY ASC,
                    LINE_ID ASC,
                    RES_ID ASC,
                    TRAN_TIME ASC;
            EXEC SQL OPEN CDB_CRASAVGTIM_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
