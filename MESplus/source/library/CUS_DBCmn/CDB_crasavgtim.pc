        case 1:
            EXEC SQL DECLARE CDB_CRASAVGTIM_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LINE_ID,
                    RES_ID,
                    TRAN_TIME,
                    CURRENT_WORK_TIME,
                    AVERAGE_TIME_100,
                    AVERAGE_TIME_400,
                    CMF_1,
