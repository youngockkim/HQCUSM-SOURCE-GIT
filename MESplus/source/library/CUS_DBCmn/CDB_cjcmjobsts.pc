                :CJCMJOBSTS_N.CMF_5,
                :CJCMJOBSTS_N.CMF_6,
                :CJCMJOBSTS_N.CMF_7,
                :CJCMJOBSTS_N.CMF_8,
                :CJCMJOBSTS_N.CMF_9,
                :CJCMJOBSTS_N.CMF_10,
                :CJCMJOBSTS_N.CREATE_USER_ID,
                :CJCMJOBSTS_N.CREATE_TIME,
                :CJCMJOBSTS_N.UPDATE_USER_ID,
                :CJCMJOBSTS_N.UPDATE_TIME;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cjcmjobsts(&CJCMJOBSTS_N, CJCMJOBSTS);
    }

    DB_stop_query_timer("CDB_fetch_cjcmjobsts", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cjcmjobsts(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CJCMJOBSTS_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CJCMJOBSTS_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cjcmjobsts", sel_type);
}


/* Initialize Function */
void CDB_init_cjcmjobsts(struct CJCMJOBSTS_TAG *CJCMJOBSTS)
{
    /* memset by Space */
    memset(CJCMJOBSTS, ' ', sizeof(struct CJCMJOBSTS_TAG));
    
}


/* Add Null Function */
void CDB_add_null_cjcmjobsts(struct CJCMJOBSTS_N_TAG *CJCMJOBSTS_N, struct CJCMJOBSTS_TAG *CJCMJOBSTS)
{
    /* memset by NULL */
    memset(CJCMJOBSTS_N, '\0', sizeof(struct CJCMJOBSTS_N_TAG));
    
    MEMCPY_AN(CJCMJOBSTS_N->FACTORY, CJCMJOBSTS->FACTORY, sizeof(CJCMJOBSTS->FACTORY));
    MEMCPY_AN(CJCMJOBSTS_N->ORDER_ID, CJCMJOBSTS->ORDER_ID, sizeof(CJCMJOBSTS->ORDER_ID));
	MEMCPY_AN(CJCMJOBSTS_N->MAT_ID, CJCMJOBSTS->MAT_ID, sizeof(CJCMJOBSTS->MAT_ID));
	MEMCPY_AN(CJCMJOBSTS_N->LINE_ID, CJCMJOBSTS->LINE_ID, sizeof(CJCMJOBSTS->LINE_ID));
	MEMCPY_AN(CJCMJOBSTS_N->ORD_START_DATE, CJCMJOBSTS->ORD_START_DATE, sizeof(CJCMJOBSTS->ORD_START_DATE));
    MEMCPY_AN(CJCMJOBSTS_N->MANAGER, CJCMJOBSTS->MANAGER, sizeof(CJCMJOBSTS->MANAGER));
    MEMCPY_AN(CJCMJOBSTS_N->DEPT_CODE, CJCMJOBSTS->DEPT_CODE, sizeof(CJCMJOBSTS->DEPT_CODE));
    MEMCPY_AN(CJCMJOBSTS_N->PLAN_START_DATE, CJCMJOBSTS->PLAN_START_DATE, sizeof(CJCMJOBSTS->PLAN_START_DATE));
    MEMCPY_AN(CJCMJOBSTS_N->PLAN_END_DATE, CJCMJOBSTS->PLAN_END_DATE, sizeof(CJCMJOBSTS->PLAN_END_DATE));
    MEMCPY_AN(CJCMJOBSTS_N->START_TIME, CJCMJOBSTS->START_TIME, sizeof(CJCMJOBSTS->START_TIME));
    MEMCPY_AN(CJCMJOBSTS_N->END_TIME, CJCMJOBSTS->END_TIME, sizeof(CJCMJOBSTS->END_TIME));
    CJCMJOBSTS_N->STATUS[0] = CJCMJOBSTS->STATUS;
    CJCMJOBSTS_N->ALARM_FLAG[0] = CJCMJOBSTS->ALARM_FLAG;
    MEMCPY_AN(CJCMJOBSTS_N->ALARM_CODE, CJCMJOBSTS->ALARM_CODE, sizeof(CJCMJOBSTS->ALARM_CODE));
    MEMCPY_AN(CJCMJOBSTS_N->CMF_1, CJCMJOBSTS->CMF_1, sizeof(CJCMJOBSTS->CMF_1));
    MEMCPY_AN(CJCMJOBSTS_N->CMF_2, CJCMJOBSTS->CMF_2, sizeof(CJCMJOBSTS->CMF_2));
    MEMCPY_AN(CJCMJOBSTS_N->CMF_3, CJCMJOBSTS->CMF_3, sizeof(CJCMJOBSTS->CMF_3));
    MEMCPY_AN(CJCMJOBSTS_N->CMF_4, CJCMJOBSTS->CMF_4, sizeof(CJCMJOBSTS->CMF_4));
    MEMCPY_AN(CJCMJOBSTS_N->CMF_5, CJCMJOBSTS->CMF_5, sizeof(CJCMJOBSTS->CMF_5));
    MEMCPY_AN(CJCMJOBSTS_N->CMF_6, CJCMJOBSTS->CMF_6, sizeof(CJCMJOBSTS->CMF_6));
    MEMCPY_AN(CJCMJOBSTS_N->CMF_7, CJCMJOBSTS->CMF_7, sizeof(CJCMJOBSTS->CMF_7));
    MEMCPY_AN(CJCMJOBSTS_N->CMF_8, CJCMJOBSTS->CMF_8, sizeof(CJCMJOBSTS->CMF_8));
    MEMCPY_AN(CJCMJOBSTS_N->CMF_9, CJCMJOBSTS->CMF_9, sizeof(CJCMJOBSTS->CMF_9));
    MEMCPY_AN(CJCMJOBSTS_N->CMF_10, CJCMJOBSTS->CMF_10, sizeof(CJCMJOBSTS->CMF_10));
    MEMCPY_AN(CJCMJOBSTS_N->CREATE_USER_ID, CJCMJOBSTS->CREATE_USER_ID, sizeof(CJCMJOBSTS->CREATE_USER_ID));
    MEMCPY_AN(CJCMJOBSTS_N->CREATE_TIME, CJCMJOBSTS->CREATE_TIME, sizeof(CJCMJOBSTS->CREATE_TIME));
    MEMCPY_AN(CJCMJOBSTS_N->UPDATE_USER_ID, CJCMJOBSTS->UPDATE_USER_ID, sizeof(CJCMJOBSTS->UPDATE_USER_ID));
    MEMCPY_AN(CJCMJOBSTS_N->UPDATE_TIME, CJCMJOBSTS->UPDATE_TIME, sizeof(CJCMJOBSTS->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_cjcmjobsts(struct CJCMJOBSTS_N_TAG *CJCMJOBSTS_N, struct CJCMJOBSTS_TAG *CJCMJOBSTS)
{
    MEMCPY_DN(CJCMJOBSTS->FACTORY, CJCMJOBSTS_N->FACTORY, sizeof(CJCMJOBSTS->FACTORY));
    MEMCPY_DN(CJCMJOBSTS->ORDER_ID, CJCMJOBSTS_N->ORDER_ID, sizeof(CJCMJOBSTS->ORDER_ID));
	MEMCPY_DN(CJCMJOBSTS->MAT_ID, CJCMJOBSTS_N->MAT_ID, sizeof(CJCMJOBSTS->MAT_ID));
	MEMCPY_DN(CJCMJOBSTS->LINE_ID, CJCMJOBSTS_N->LINE_ID, sizeof(CJCMJOBSTS->LINE_ID));
	MEMCPY_DN(CJCMJOBSTS->ORD_START_DATE, CJCMJOBSTS_N->ORD_START_DATE, sizeof(CJCMJOBSTS->ORD_START_DATE));
    MEMCPY_DN(CJCMJOBSTS->MANAGER, CJCMJOBSTS_N->MANAGER, sizeof(CJCMJOBSTS->MANAGER));
    MEMCPY_DN(CJCMJOBSTS->DEPT_CODE, CJCMJOBSTS_N->DEPT_CODE, sizeof(CJCMJOBSTS->DEPT_CODE));
    MEMCPY_DN(CJCMJOBSTS->PLAN_START_DATE, CJCMJOBSTS_N->PLAN_START_DATE, sizeof(CJCMJOBSTS->PLAN_START_DATE));
    MEMCPY_DN(CJCMJOBSTS->PLAN_END_DATE, CJCMJOBSTS_N->PLAN_END_DATE, sizeof(CJCMJOBSTS->PLAN_END_DATE));
    MEMCPY_DN(CJCMJOBSTS->START_TIME, CJCMJOBSTS_N->START_TIME, sizeof(CJCMJOBSTS->START_TIME));
    MEMCPY_DN(CJCMJOBSTS->END_TIME, CJCMJOBSTS_N->END_TIME, sizeof(CJCMJOBSTS->END_TIME));
    CJCMJOBSTS->STATUS = CJCMJOBSTS_N->STATUS[0];
    CJCMJOBSTS->ALARM_FLAG = CJCMJOBSTS_N->ALARM_FLAG[0];
    MEMCPY_DN(CJCMJOBSTS->ALARM_CODE, CJCMJOBSTS_N->ALARM_CODE, sizeof(CJCMJOBSTS->ALARM_CODE));
    MEMCPY_DN(CJCMJOBSTS->CMF_1, CJCMJOBSTS_N->CMF_1, sizeof(CJCMJOBSTS->CMF_1));
    MEMCPY_DN(CJCMJOBSTS->CMF_2, CJCMJOBSTS_N->CMF_2, sizeof(CJCMJOBSTS->CMF_2));
    MEMCPY_DN(CJCMJOBSTS->CMF_3, CJCMJOBSTS_N->CMF_3, sizeof(CJCMJOBSTS->CMF_3));
    MEMCPY_DN(CJCMJOBSTS->CMF_4, CJCMJOBSTS_N->CMF_4, sizeof(CJCMJOBSTS->CMF_4));
    MEMCPY_DN(CJCMJOBSTS->CMF_5, CJCMJOBSTS_N->CMF_5, sizeof(CJCMJOBSTS->CMF_5));
    MEMCPY_DN(CJCMJOBSTS->CMF_6, CJCMJOBSTS_N->CMF_6, sizeof(CJCMJOBSTS->CMF_6));
    MEMCPY_DN(CJCMJOBSTS->CMF_7, CJCMJOBSTS_N->CMF_7, sizeof(CJCMJOBSTS->CMF_7));
    MEMCPY_DN(CJCMJOBSTS->CMF_8, CJCMJOBSTS_N->CMF_8, sizeof(CJCMJOBSTS->CMF_8));
    MEMCPY_DN(CJCMJOBSTS->CMF_9, CJCMJOBSTS_N->CMF_9, sizeof(CJCMJOBSTS->CMF_9));
    MEMCPY_DN(CJCMJOBSTS->CMF_10, CJCMJOBSTS_N->CMF_10, sizeof(CJCMJOBSTS->CMF_10));
    MEMCPY_DN(CJCMJOBSTS->CREATE_USER_ID, CJCMJOBSTS_N->CREATE_USER_ID, sizeof(CJCMJOBSTS->CREATE_USER_ID));
    MEMCPY_DN(CJCMJOBSTS->CREATE_TIME, CJCMJOBSTS_N->CREATE_TIME, sizeof(CJCMJOBSTS->CREATE_TIME));
    MEMCPY_DN(CJCMJOBSTS->UPDATE_USER_ID, CJCMJOBSTS_N->UPDATE_USER_ID, sizeof(CJCMJOBSTS->UPDATE_USER_ID));
    MEMCPY_DN(CJCMJOBSTS->UPDATE_TIME, CJCMJOBSTS_N->UPDATE_TIME, sizeof(CJCMJOBSTS->UPDATE_TIME));
}


