/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cjcmjobsts(int sel_type, struct CJCMJOBSTS_TAG *CJCMJOBSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CJCMJOBSTS_N_TAG CJCMJOBSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cjcmjobsts(&CJCMJOBSTS_N, CJCMJOBSTS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CJCMJOBSTS_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    ORDER_ID,
					MAT_ID,
					LINE_ID,
					ORD_START_DATE,
                    MANAGER,
                    DEPT_CODE,
                    PLAN_START_DATE,
                    PLAN_END_DATE,
                    START_TIME,
                    END_TIME,
                    STATUS,
                    ALARM_FLAG,
                    ALARM_CODE,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CJCMJOBSTS
			  WHERE FACTORY = :CJCMJOBSTS_N.FACTORY			    
				AND ORD_START_DATE >= :CJCMJOBSTS_N.PLAN_START_DATE
				AND ORD_START_DATE <= :CJCMJOBSTS_N.PLAN_END_DATE
				AND ORDER_ID LIKE '%' || TRIM(:CJCMJOBSTS_N.ORDER_ID) || '%'
				AND MAT_ID LIKE '%' || TRIM(:CJCMJOBSTS_N.MAT_ID) || '%'
				AND LINE_ID LIKE '%' || TRIM(:CJCMJOBSTS_N.LINE_ID) || '%'
                ORDER BY FACTORY ASC,
                    ORDER_ID ASC;
            EXEC SQL OPEN CDB_CJCMJOBSTS_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CJCMJOBSTS_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    ORDER_ID,
					MAT_ID,
					LINE_ID,
					ORD_START_DATE,
                    MANAGER,
                    DEPT_CODE,
                    PLAN_START_DATE,
                    PLAN_END_DATE,
                    START_TIME,
                    END_TIME,
                    STATUS,
                    ALARM_FLAG,
                    ALARM_CODE,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CJCMJOBSTS
			  WHERE FACTORY = :CJCMJOBSTS_N.FACTORY			    
				AND ORD_START_DATE <= TO_CHAR(SYSDATE - 15,'YYYYMMDD')
				AND STATUS NOT IN('E','C')
                ORDER BY FACTORY ASC,
                    ORDER_ID ASC;
            EXEC SQL OPEN CDB_CJCMJOBSTS_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cjcmjobsts", sel_type);
}


