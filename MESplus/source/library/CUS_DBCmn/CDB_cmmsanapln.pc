/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cmmsanapln(int sel_type, struct CMMSANAPLN_TAG *CMMSANAPLN)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMMSANAPLN_N_TAG CMMSANAPLN_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cmmsanapln(&CMMSANAPLN_N, CMMSANAPLN);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CMMSANAPLN_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    ANA_ID,
                    EQUIP_ID,
                    PLAN_DATE,
                    ANA_DIV,
                    ANA_STATUS,
                    USE_DEPT_CODE,
                    SAMPLE_CODE,
                    SAMPLE_COUNT,
                    USER_COUNT,
                    REPEAT_COUNT,
                    JUDGE_USER_ID,
                    ALARM_FLAG,
                    ALARM_CODE,
                    ALARM_PERIOD,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSANAPLN
					WHERE FACTORY = :CMMSANAPLN_N.FACTORY
                      AND EQUIP_ID = :CMMSANAPLN_N.EQUIP_ID
                ORDER BY FACTORY ASC,
                    ANA_ID DESC;
            EXEC SQL OPEN CDB_CMMSANAPLN_CUR_1;
            break;

		case 2:
			EXEC SQL DECLARE CDB_CMMSANAPLN_CUR_2 CURSOR FOR
				SELECT 
                    FACTORY,
                    ANA_ID,
                    EQUIP_ID,
                    PLAN_DATE,
                    ANA_DIV,
                    ANA_STATUS,
                    USE_DEPT_CODE,
                    SAMPLE_CODE,
                    SAMPLE_COUNT,
                    USER_COUNT,
                    REPEAT_COUNT,
                    JUDGE_USER_ID,
                    ALARM_FLAG,
                    ALARM_CODE,
                    ALARM_PERIOD,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSANAPLN A
					WHERE FACTORY = :CMMSANAPLN_N.FACTORY
                      AND PLAN_DATE >= :CMMSANAPLN_N.PLAN_DATE
					  AND PLAN_DATE <= TRIM(:CMMSANAPLN_N.CMF_1)
					  AND ANA_DIV LIKE '%' || TRIM(:CMMSANAPLN_N.ANA_DIV) || '%'
					  AND EQUIP_ID LIKE '%' || TRIM(:CMMSANAPLN_N.EQUIP_ID) || '%'
					  AND USE_DEPT_CODE LIKE '%' || TRIM(:CMMSANAPLN_N.USE_DEPT_CODE) || '%'
					  AND EQUIP_ID IN (SELECT EQUIP_ID 
                                         FROM CMMSEQPDEF B
                                        WHERE B.FACTORY = A.FACTORY
                                          AND B.EQUIP_ID = A.EQUIP_ID
                                          AND B.NONE_FLAG != 'Y')
                ORDER BY FACTORY ASC,
                    ANA_ID DESC;
            EXEC SQL OPEN CDB_CMMSANAPLN_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_CMMSANAPLN_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    ANA_ID,
                    EQUIP_ID,
                    PLAN_DATE,
                    ANA_DIV,
                    ANA_STATUS,
                    USE_DEPT_CODE,
                    SAMPLE_CODE,
                    SAMPLE_COUNT,
                    USER_COUNT,
                    REPEAT_COUNT,
                    JUDGE_USER_ID,
                    ALARM_FLAG,
                    ALARM_CODE,
                    ALARM_PERIOD,
                    TO_CHAR(TO_DATE(PLAN_DATE,'YYYYMMDD'), 'FMMM/DD/YYYY') AS CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CMMSANAPLN
					WHERE FACTORY = :CMMSANAPLN_N.FACTORY
                      AND ALARM_FLAG = 'Y'
					  AND PLAN_DATE = TO_CHAR((SYSDATE + ALARM_PERIOD), 'YYYYMMDD')
                ORDER BY FACTORY ASC,
					ALARM_CODE ASC,
                    PLAN_DATE ASC,
					EQUIP_ID ASC;
            EXEC SQL OPEN CDB_CMMSANAPLN_CUR_3;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cmmsanapln", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_cmmsanapln(int sel_type, struct CMMSANAPLN_TAG *CMMSANAPLN)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMMSANAPLN_N_TAG CMMSANAPLN_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CMMSANAPLN_CUR_1 INTO
                :CMMSANAPLN_N.FACTORY,
                :CMMSANAPLN_N.ANA_ID,
                :CMMSANAPLN_N.EQUIP_ID,
