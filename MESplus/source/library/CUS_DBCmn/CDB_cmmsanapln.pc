                :CMMSANAPLN_N.ALARM_FLAG,
                :CMMSANAPLN_N.ALARM_CODE,
                :CMMSANAPLN_N.ALARM_PERIOD,
                :CMMSANAPLN_N.CMF_1,
                :CMMSANAPLN_N.CMF_2,
                :CMMSANAPLN_N.CMF_3,
                :CMMSANAPLN_N.CMF_4,
                :CMMSANAPLN_N.CMF_5,
                :CMMSANAPLN_N.CMF_6,
                :CMMSANAPLN_N.CMF_7,
                :CMMSANAPLN_N.CMF_8,
                :CMMSANAPLN_N.CMF_9,
                :CMMSANAPLN_N.CMF_10,
                :CMMSANAPLN_N.CREATE_USER_ID,
                :CMMSANAPLN_N.CREATE_TIME,
                :CMMSANAPLN_N.UPDATE_USER_ID,
                :CMMSANAPLN_N.UPDATE_TIME;
            break;

		case 2:
            EXEC SQL FETCH CDB_CMMSANAPLN_CUR_2 INTO
                :CMMSANAPLN_N.FACTORY,
                :CMMSANAPLN_N.ANA_ID,
                :CMMSANAPLN_N.EQUIP_ID,
                :CMMSANAPLN_N.PLAN_DATE,
                :CMMSANAPLN_N.ANA_DIV,
                :CMMSANAPLN_N.ANA_STATUS,
                :CMMSANAPLN_N.USE_DEPT_CODE,
                :CMMSANAPLN_N.SAMPLE_CODE,
                :CMMSANAPLN_N.SAMPLE_COUNT,
                :CMMSANAPLN_N.USER_COUNT,
                :CMMSANAPLN_N.REPEAT_COUNT,
                :CMMSANAPLN_N.JUDGE_USER_ID,
                :CMMSANAPLN_N.ALARM_FLAG,
                :CMMSANAPLN_N.ALARM_CODE,
                :CMMSANAPLN_N.ALARM_PERIOD,
                :CMMSANAPLN_N.CMF_1,
                :CMMSANAPLN_N.CMF_2,
                :CMMSANAPLN_N.CMF_3,
                :CMMSANAPLN_N.CMF_4,
                :CMMSANAPLN_N.CMF_5,
                :CMMSANAPLN_N.CMF_6,
                :CMMSANAPLN_N.CMF_7,
                :CMMSANAPLN_N.CMF_8,
                :CMMSANAPLN_N.CMF_9,
                :CMMSANAPLN_N.CMF_10,
                :CMMSANAPLN_N.CREATE_USER_ID,
                :CMMSANAPLN_N.CREATE_TIME,
                :CMMSANAPLN_N.UPDATE_USER_ID,
                :CMMSANAPLN_N.UPDATE_TIME;
            break;

		case 3:
            EXEC SQL FETCH CDB_CMMSANAPLN_CUR_3 INTO
                :CMMSANAPLN_N.FACTORY,
                :CMMSANAPLN_N.ANA_ID,
                :CMMSANAPLN_N.EQUIP_ID,
                :CMMSANAPLN_N.PLAN_DATE,
                :CMMSANAPLN_N.ANA_DIV,
                :CMMSANAPLN_N.ANA_STATUS,
                :CMMSANAPLN_N.USE_DEPT_CODE,
                :CMMSANAPLN_N.SAMPLE_CODE,
                :CMMSANAPLN_N.SAMPLE_COUNT,
                :CMMSANAPLN_N.USER_COUNT,
                :CMMSANAPLN_N.REPEAT_COUNT,
                :CMMSANAPLN_N.JUDGE_USER_ID,
                :CMMSANAPLN_N.ALARM_FLAG,
                :CMMSANAPLN_N.ALARM_CODE,
                :CMMSANAPLN_N.ALARM_PERIOD,
                :CMMSANAPLN_N.CMF_1,
                :CMMSANAPLN_N.CMF_2,
                :CMMSANAPLN_N.CMF_3,
                :CMMSANAPLN_N.CMF_4,
                :CMMSANAPLN_N.CMF_5,
                :CMMSANAPLN_N.CMF_6,
                :CMMSANAPLN_N.CMF_7,
                :CMMSANAPLN_N.CMF_8,
                :CMMSANAPLN_N.CMF_9,
                :CMMSANAPLN_N.CMF_10,
