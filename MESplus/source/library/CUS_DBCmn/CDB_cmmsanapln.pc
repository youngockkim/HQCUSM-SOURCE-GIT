                :CMMSANAPLN_N.CREATE_TIME,
                :CMMSANAPLN_N.UPDATE_USER_ID,
                :CMMSANAPLN_N.UPDATE_TIME;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cmmsanapln(&CMMSANAPLN_N, CMMSANAPLN);
    }

    DB_stop_query_timer("CDB_fetch_cmmsanapln", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cmmsanapln(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CMMSANAPLN_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CMMSANAPLN_CUR_2;
            break;

		case 3:
            EXEC SQL CLOSE CDB_CMMSANAPLN_CUR_3;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cmmsanapln", sel_type);
}


/* Initialize Function */
void CDB_init_cmmsanapln(struct CMMSANAPLN_TAG *CMMSANAPLN)
{
    /* memset by Space */
    memset(CMMSANAPLN, ' ', sizeof(struct CMMSANAPLN_TAG));
    
    CMMSANAPLN->SAMPLE_COUNT = 0;
    CMMSANAPLN->USER_COUNT = 0;
    CMMSANAPLN->REPEAT_COUNT = 0;
    CMMSANAPLN->ALARM_PERIOD = 0;
}


/* Add Null Function */
void CDB_add_null_cmmsanapln(struct CMMSANAPLN_N_TAG *CMMSANAPLN_N, struct CMMSANAPLN_TAG *CMMSANAPLN)
{
    /* memset by NULL */
    memset(CMMSANAPLN_N, '\0', sizeof(struct CMMSANAPLN_N_TAG));
    
    MEMCPY_AN(CMMSANAPLN_N->FACTORY, CMMSANAPLN->FACTORY, sizeof(CMMSANAPLN->FACTORY));
    MEMCPY_AN(CMMSANAPLN_N->ANA_ID, CMMSANAPLN->ANA_ID, sizeof(CMMSANAPLN->ANA_ID));
    MEMCPY_AN(CMMSANAPLN_N->EQUIP_ID, CMMSANAPLN->EQUIP_ID, sizeof(CMMSANAPLN->EQUIP_ID));
    MEMCPY_AN(CMMSANAPLN_N->PLAN_DATE, CMMSANAPLN->PLAN_DATE, sizeof(CMMSANAPLN->PLAN_DATE));
    CMMSANAPLN_N->ANA_DIV[0] = CMMSANAPLN->ANA_DIV;
    MEMCPY_AN(CMMSANAPLN_N->ANA_STATUS, CMMSANAPLN->ANA_STATUS, sizeof(CMMSANAPLN->ANA_STATUS));
    MEMCPY_AN(CMMSANAPLN_N->USE_DEPT_CODE, CMMSANAPLN->USE_DEPT_CODE, sizeof(CMMSANAPLN->USE_DEPT_CODE));
    MEMCPY_AN(CMMSANAPLN_N->SAMPLE_CODE, CMMSANAPLN->SAMPLE_CODE, sizeof(CMMSANAPLN->SAMPLE_CODE));
    CMMSANAPLN_N->SAMPLE_COUNT = CMMSANAPLN->SAMPLE_COUNT;
    CMMSANAPLN_N->USER_COUNT = CMMSANAPLN->USER_COUNT;
    CMMSANAPLN_N->REPEAT_COUNT = CMMSANAPLN->REPEAT_COUNT;
    MEMCPY_AN(CMMSANAPLN_N->JUDGE_USER_ID, CMMSANAPLN->JUDGE_USER_ID, sizeof(CMMSANAPLN->JUDGE_USER_ID));
    CMMSANAPLN_N->ALARM_FLAG[0] = CMMSANAPLN->ALARM_FLAG;
    MEMCPY_AN(CMMSANAPLN_N->ALARM_CODE, CMMSANAPLN->ALARM_CODE, sizeof(CMMSANAPLN->ALARM_CODE));
    CMMSANAPLN_N->ALARM_PERIOD = CMMSANAPLN->ALARM_PERIOD;
    MEMCPY_AN(CMMSANAPLN_N->CMF_1, CMMSANAPLN->CMF_1, sizeof(CMMSANAPLN->CMF_1));
    MEMCPY_AN(CMMSANAPLN_N->CMF_2, CMMSANAPLN->CMF_2, sizeof(CMMSANAPLN->CMF_2));
    MEMCPY_AN(CMMSANAPLN_N->CMF_3, CMMSANAPLN->CMF_3, sizeof(CMMSANAPLN->CMF_3));
    MEMCPY_AN(CMMSANAPLN_N->CMF_4, CMMSANAPLN->CMF_4, sizeof(CMMSANAPLN->CMF_4));
    MEMCPY_AN(CMMSANAPLN_N->CMF_5, CMMSANAPLN->CMF_5, sizeof(CMMSANAPLN->CMF_5));
    MEMCPY_AN(CMMSANAPLN_N->CMF_6, CMMSANAPLN->CMF_6, sizeof(CMMSANAPLN->CMF_6));
    MEMCPY_AN(CMMSANAPLN_N->CMF_7, CMMSANAPLN->CMF_7, sizeof(CMMSANAPLN->CMF_7));
    MEMCPY_AN(CMMSANAPLN_N->CMF_8, CMMSANAPLN->CMF_8, sizeof(CMMSANAPLN->CMF_8));
    MEMCPY_AN(CMMSANAPLN_N->CMF_9, CMMSANAPLN->CMF_9, sizeof(CMMSANAPLN->CMF_9));
    MEMCPY_AN(CMMSANAPLN_N->CMF_10, CMMSANAPLN->CMF_10, sizeof(CMMSANAPLN->CMF_10));
    MEMCPY_AN(CMMSANAPLN_N->CREATE_USER_ID, CMMSANAPLN->CREATE_USER_ID, sizeof(CMMSANAPLN->CREATE_USER_ID));
    MEMCPY_AN(CMMSANAPLN_N->CREATE_TIME, CMMSANAPLN->CREATE_TIME, sizeof(CMMSANAPLN->CREATE_TIME));
    MEMCPY_AN(CMMSANAPLN_N->UPDATE_USER_ID, CMMSANAPLN->UPDATE_USER_ID, sizeof(CMMSANAPLN->UPDATE_USER_ID));
    MEMCPY_AN(CMMSANAPLN_N->UPDATE_TIME, CMMSANAPLN->UPDATE_TIME, sizeof(CMMSANAPLN->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_cmmsanapln(struct CMMSANAPLN_N_TAG *CMMSANAPLN_N, struct CMMSANAPLN_TAG *CMMSANAPLN)
{
    MEMCPY_DN(CMMSANAPLN->FACTORY, CMMSANAPLN_N->FACTORY, sizeof(CMMSANAPLN->FACTORY));
    MEMCPY_DN(CMMSANAPLN->ANA_ID, CMMSANAPLN_N->ANA_ID, sizeof(CMMSANAPLN->ANA_ID));
    MEMCPY_DN(CMMSANAPLN->EQUIP_ID, CMMSANAPLN_N->EQUIP_ID, sizeof(CMMSANAPLN->EQUIP_ID));
    MEMCPY_DN(CMMSANAPLN->PLAN_DATE, CMMSANAPLN_N->PLAN_DATE, sizeof(CMMSANAPLN->PLAN_DATE));
    CMMSANAPLN->ANA_DIV = CMMSANAPLN_N->ANA_DIV[0];
    MEMCPY_DN(CMMSANAPLN->ANA_STATUS, CMMSANAPLN_N->ANA_STATUS, sizeof(CMMSANAPLN->ANA_STATUS));
    MEMCPY_DN(CMMSANAPLN->USE_DEPT_CODE, CMMSANAPLN_N->USE_DEPT_CODE, sizeof(CMMSANAPLN->USE_DEPT_CODE));
    MEMCPY_DN(CMMSANAPLN->SAMPLE_CODE, CMMSANAPLN_N->SAMPLE_CODE, sizeof(CMMSANAPLN->SAMPLE_CODE));
    CMMSANAPLN->SAMPLE_COUNT = CMMSANAPLN_N->SAMPLE_COUNT;
    CMMSANAPLN->USER_COUNT = CMMSANAPLN_N->USER_COUNT;
    CMMSANAPLN->REPEAT_COUNT = CMMSANAPLN_N->REPEAT_COUNT;
    MEMCPY_DN(CMMSANAPLN->JUDGE_USER_ID, CMMSANAPLN_N->JUDGE_USER_ID, sizeof(CMMSANAPLN->JUDGE_USER_ID));
    CMMSANAPLN->ALARM_FLAG = CMMSANAPLN_N->ALARM_FLAG[0];
    MEMCPY_DN(CMMSANAPLN->ALARM_CODE, CMMSANAPLN_N->ALARM_CODE, sizeof(CMMSANAPLN->ALARM_CODE));
    CMMSANAPLN->ALARM_PERIOD = CMMSANAPLN_N->ALARM_PERIOD;
    MEMCPY_DN(CMMSANAPLN->CMF_1, CMMSANAPLN_N->CMF_1, sizeof(CMMSANAPLN->CMF_1));
    MEMCPY_DN(CMMSANAPLN->CMF_2, CMMSANAPLN_N->CMF_2, sizeof(CMMSANAPLN->CMF_2));
    MEMCPY_DN(CMMSANAPLN->CMF_3, CMMSANAPLN_N->CMF_3, sizeof(CMMSANAPLN->CMF_3));
    MEMCPY_DN(CMMSANAPLN->CMF_4, CMMSANAPLN_N->CMF_4, sizeof(CMMSANAPLN->CMF_4));
    MEMCPY_DN(CMMSANAPLN->CMF_5, CMMSANAPLN_N->CMF_5, sizeof(CMMSANAPLN->CMF_5));
    MEMCPY_DN(CMMSANAPLN->CMF_6, CMMSANAPLN_N->CMF_6, sizeof(CMMSANAPLN->CMF_6));
    MEMCPY_DN(CMMSANAPLN->CMF_7, CMMSANAPLN_N->CMF_7, sizeof(CMMSANAPLN->CMF_7));
    MEMCPY_DN(CMMSANAPLN->CMF_8, CMMSANAPLN_N->CMF_8, sizeof(CMMSANAPLN->CMF_8));
    MEMCPY_DN(CMMSANAPLN->CMF_9, CMMSANAPLN_N->CMF_9, sizeof(CMMSANAPLN->CMF_9));
    MEMCPY_DN(CMMSANAPLN->CMF_10, CMMSANAPLN_N->CMF_10, sizeof(CMMSANAPLN->CMF_10));
    MEMCPY_DN(CMMSANAPLN->CREATE_USER_ID, CMMSANAPLN_N->CREATE_USER_ID, sizeof(CMMSANAPLN->CREATE_USER_ID));
    MEMCPY_DN(CMMSANAPLN->CREATE_TIME, CMMSANAPLN_N->CREATE_TIME, sizeof(CMMSANAPLN->CREATE_TIME));
    MEMCPY_DN(CMMSANAPLN->UPDATE_USER_ID, CMMSANAPLN_N->UPDATE_USER_ID, sizeof(CMMSANAPLN->UPDATE_USER_ID));
    MEMCPY_DN(CMMSANAPLN->UPDATE_TIME, CMMSANAPLN_N->UPDATE_TIME, sizeof(CMMSANAPLN->UPDATE_TIME));
}


