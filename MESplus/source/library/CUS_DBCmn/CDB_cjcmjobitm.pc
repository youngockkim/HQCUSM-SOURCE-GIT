    MEMCPY_DN(CJCMJOBITM->CREATE_USER_ID, CJCMJOBITM_N->CREATE_USER_ID, sizeof(CJCMJOBITM->CREATE_USER_ID));
    MEMCPY_DN(CJCMJOBITM->CREATE_TIME, CJCMJOBITM_N->CREATE_TIME, sizeof(CJCMJOBITM->CREATE_TIME));
    MEMCPY_DN(CJCMJOBITM->UPDATE_USER_ID, CJCMJOBITM_N->UPDATE_USER_ID, sizeof(CJCMJOBITM->UPDATE_USER_ID));
    MEMCPY_DN(CJCMJOBITM->UPDATE_TIME, CJCMJOBITM_N->UPDATE_TIME, sizeof(CJCMJOBITM->UPDATE_TIME));
}


