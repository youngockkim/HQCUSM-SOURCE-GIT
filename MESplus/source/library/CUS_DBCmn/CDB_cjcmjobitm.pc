/* SQL CURSOR CLOSE Function */
void CDB_close_cjcmjobitm(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CJCMJOBITM_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CJCMJOBITM_CUR_2;
            break;

		case 3:
            EXEC SQL CLOSE CDB_CJCMJOBITM_CUR_3;
            break;

		case 4:
            EXEC SQL CLOSE CDB_CJCMJOBITM_CUR_4;
            break;

		case 5:
            EXEC SQL CLOSE CDB_CJCMJOBITM_CUR_5;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cjcmjobitm", sel_type);
}


/* Initialize Function */
void CDB_init_cjcmjobitm(struct CJCMJOBITM_TAG *CJCMJOBITM)
{
    /* memset by Space */
    memset(CJCMJOBITM, ' ', sizeof(struct CJCMJOBITM_TAG));
    
    CJCMJOBITM->WORK_TIME = 0;
}


/* Add Null Function */
void CDB_add_null_cjcmjobitm(struct CJCMJOBITM_N_TAG *CJCMJOBITM_N, struct CJCMJOBITM_TAG *CJCMJOBITM)
{
    /* memset by NULL */
    memset(CJCMJOBITM_N, '\0', sizeof(struct CJCMJOBITM_N_TAG));
    
    MEMCPY_AN(CJCMJOBITM_N->FACTORY, CJCMJOBITM->FACTORY, sizeof(CJCMJOBITM->FACTORY));
    MEMCPY_AN(CJCMJOBITM_N->ORDER_ID, CJCMJOBITM->ORDER_ID, sizeof(CJCMJOBITM->ORDER_ID));
    MEMCPY_AN(CJCMJOBITM_N->ITEM_CODE, CJCMJOBITM->ITEM_CODE, sizeof(CJCMJOBITM->ITEM_CODE));
    CJCMJOBITM_N->AUTO_FLAG[0] = CJCMJOBITM->AUTO_FLAG;
    MEMCPY_AN(CJCMJOBITM_N->RESPONSIBILITY, CJCMJOBITM->RESPONSIBILITY, sizeof(CJCMJOBITM->RESPONSIBILITY));
    MEMCPY_AN(CJCMJOBITM_N->DEPT_CODE, CJCMJOBITM->DEPT_CODE, sizeof(CJCMJOBITM->DEPT_CODE));
    MEMCPY_AN(CJCMJOBITM_N->PLAN_START_DATE, CJCMJOBITM->PLAN_START_DATE, sizeof(CJCMJOBITM->PLAN_START_DATE));
    MEMCPY_AN(CJCMJOBITM_N->PLAN_END_DATE, CJCMJOBITM->PLAN_END_DATE, sizeof(CJCMJOBITM->PLAN_END_DATE));
    MEMCPY_AN(CJCMJOBITM_N->START_TIME, CJCMJOBITM->START_TIME, sizeof(CJCMJOBITM->START_TIME));
    MEMCPY_AN(CJCMJOBITM_N->END_TIME, CJCMJOBITM->END_TIME, sizeof(CJCMJOBITM->END_TIME));
    CJCMJOBITM_N->WORK_TIME = CJCMJOBITM->WORK_TIME;
    CJCMJOBITM_N->STATUS[0] = CJCMJOBITM->STATUS;
    CJCMJOBITM_N->ALARM_FLAG[0] = CJCMJOBITM->ALARM_FLAG;
    MEMCPY_AN(CJCMJOBITM_N->ALARM_CODE, CJCMJOBITM->ALARM_CODE, sizeof(CJCMJOBITM->ALARM_CODE));
    MEMCPY_AN(CJCMJOBITM_N->CMF_1, CJCMJOBITM->CMF_1, sizeof(CJCMJOBITM->CMF_1));
    MEMCPY_AN(CJCMJOBITM_N->CMF_2, CJCMJOBITM->CMF_2, sizeof(CJCMJOBITM->CMF_2));
    MEMCPY_AN(CJCMJOBITM_N->CMF_3, CJCMJOBITM->CMF_3, sizeof(CJCMJOBITM->CMF_3));
    MEMCPY_AN(CJCMJOBITM_N->CMF_4, CJCMJOBITM->CMF_4, sizeof(CJCMJOBITM->CMF_4));
    MEMCPY_AN(CJCMJOBITM_N->CMF_5, CJCMJOBITM->CMF_5, sizeof(CJCMJOBITM->CMF_5));
    MEMCPY_AN(CJCMJOBITM_N->CMF_6, CJCMJOBITM->CMF_6, sizeof(CJCMJOBITM->CMF_6));
    MEMCPY_AN(CJCMJOBITM_N->CMF_7, CJCMJOBITM->CMF_7, sizeof(CJCMJOBITM->CMF_7));
    MEMCPY_AN(CJCMJOBITM_N->CMF_8, CJCMJOBITM->CMF_8, sizeof(CJCMJOBITM->CMF_8));
    MEMCPY_AN(CJCMJOBITM_N->CMF_9, CJCMJOBITM->CMF_9, sizeof(CJCMJOBITM->CMF_9));
    MEMCPY_AN(CJCMJOBITM_N->CMF_10, CJCMJOBITM->CMF_10, sizeof(CJCMJOBITM->CMF_10));
    MEMCPY_AN(CJCMJOBITM_N->CREATE_USER_ID, CJCMJOBITM->CREATE_USER_ID, sizeof(CJCMJOBITM->CREATE_USER_ID));
    MEMCPY_AN(CJCMJOBITM_N->CREATE_TIME, CJCMJOBITM->CREATE_TIME, sizeof(CJCMJOBITM->CREATE_TIME));
    MEMCPY_AN(CJCMJOBITM_N->UPDATE_USER_ID, CJCMJOBITM->UPDATE_USER_ID, sizeof(CJCMJOBITM->UPDATE_USER_ID));
    MEMCPY_AN(CJCMJOBITM_N->UPDATE_TIME, CJCMJOBITM->UPDATE_TIME, sizeof(CJCMJOBITM->UPDATE_TIME));
}


/* Del Null Function */
void CDB_del_null_cjcmjobitm(struct CJCMJOBITM_N_TAG *CJCMJOBITM_N, struct CJCMJOBITM_TAG *CJCMJOBITM)
{
    MEMCPY_DN(CJCMJOBITM->FACTORY, CJCMJOBITM_N->FACTORY, sizeof(CJCMJOBITM->FACTORY));
    MEMCPY_DN(CJCMJOBITM->ORDER_ID, CJCMJOBITM_N->ORDER_ID, sizeof(CJCMJOBITM->ORDER_ID));
    MEMCPY_DN(CJCMJOBITM->ITEM_CODE, CJCMJOBITM_N->ITEM_CODE, sizeof(CJCMJOBITM->ITEM_CODE));
