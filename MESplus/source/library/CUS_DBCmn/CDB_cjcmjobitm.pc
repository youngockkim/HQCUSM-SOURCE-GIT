    MEMCPY_DN(CJCMJOBITM->START_TIME, CJCMJOBITM_N->START_TIME, sizeof(CJCMJOBITM->START_TIME));
    MEMCPY_DN(CJCMJOBITM->END_TIME, CJCMJOBITM_N->END_TIME, sizeof(CJCMJOBITM->END_TIME));
