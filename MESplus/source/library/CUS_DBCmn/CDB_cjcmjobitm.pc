/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cjcmjobitm(int sel_type, struct CJCMJOBITM_TAG *CJCMJOBITM)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CJCMJOBITM_N_TAG CJCMJOBITM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cjcmjobitm(&CJCMJOBITM_N, CJCMJOBITM);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CJCMJOBITM_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    ORDER_ID,
                    ITEM_CODE,
                    AUTO_FLAG,
                    RESPONSIBILITY,
                    DEPT_CODE,
                    PLAN_START_DATE,
                    PLAN_END_DATE,
                    START_TIME,
                    END_TIME,
                    WORK_TIME,
                    STATUS,
                    ALARM_FLAG,
                    ALARM_CODE,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CJCMJOBITM
				WHERE FACTORY = :CJCMJOBITM_N.FACTORY
				  AND ORDER_ID = :CJCMJOBITM_N.ORDER_ID
                ORDER BY FACTORY ASC,
                    ORDER_ID ASC,
                    ITEM_CODE ASC;
            EXEC SQL OPEN CDB_CJCMJOBITM_CUR_1;
            break;

	case 2:
            EXEC SQL DECLARE CDB_CJCMJOBITM_CUR_2 CURSOR FOR
                SELECT 
                    A.FACTORY,
                    A.ORDER_ID,
                    A.ITEM_CODE,
                    A.AUTO_FLAG,
                    A.RESPONSIBILITY,
                    A.DEPT_CODE,
                    A.PLAN_START_DATE,
                    A.PLAN_END_DATE,
                    A.START_TIME,
                    A.END_TIME,
                    A.WORK_TIME,
                    A.STATUS,
                    A.ALARM_FLAG,
                    A.ALARM_CODE,
                    A.CMF_1,
                    A.CMF_2,
                    A.CMF_3,
                    A.CMF_4,
                    A.CMF_5,
                    A.CMF_6,
                    A.CMF_7,
                    A.CMF_8,
                    A.CMF_9,
                    A.CMF_10,
                    A.CREATE_USER_ID,
                    A.CREATE_TIME,
                    A.UPDATE_USER_ID,
                    A.UPDATE_TIME
                FROM CJCMJOBITM A
				   , CJCMJOBSTS B
				WHERE A.FACTORY = B.FACTORY
                  AND A.ORDER_ID = B.ORDER_ID
				  AND A.FACTORY = :CJCMJOBITM_N.FACTORY
				  AND A.AUTO_FLAG = :CJCMJOBITM_N.AUTO_FLAG
				  AND A.STATUS != :CJCMJOBITM_N.STATUS
				  AND A.PLAN_START_DATE <= :CJCMJOBITM_N.PLAN_START_DATE
				  AND B.STATUS NOT IN('C','E')
                ORDER BY FACTORY ASC,
                    ORDER_ID ASC,
                    ITEM_CODE ASC;
            EXEC SQL OPEN CDB_CJCMJOBITM_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_CJCMJOBITM_CUR_3 CURSOR FOR
                SELECT 
                    FACTORY,
                    ORDER_ID,
                    ITEM_CODE,
                    AUTO_FLAG,
                    RESPONSIBILITY,
                    DEPT_CODE,
                    PLAN_START_DATE,
                    PLAN_END_DATE,
                    START_TIME,
                    END_TIME,
                    WORK_TIME,
                    STATUS,
                    ALARM_FLAG,
                    ALARM_CODE,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CJCMJOBITM
				WHERE FACTORY = :CJCMJOBITM_N.FACTORY
				  AND ORDER_ID = :CJCMJOBITM_N.ORDER_ID
				  AND ITEM_CODE = :CJCMJOBITM_N.ITEM_CODE
                ORDER BY FACTORY ASC,
                    ORDER_ID ASC,
                    ITEM_CODE ASC;
            EXEC SQL OPEN CDB_CJCMJOBITM_CUR_3;
            break;

		case 4:
            EXEC SQL DECLARE CDB_CJCMJOBITM_CUR_4 CURSOR FOR
                SELECT 
                    A.FACTORY,
                    A.ORDER_ID,
                    A.ITEM_CODE,
                    A.AUTO_FLAG,
                    A.RESPONSIBILITY,
                    A.DEPT_CODE,
                    A.PLAN_START_DATE,
                    A.PLAN_END_DATE,
                    A.START_TIME,
                    A.END_TIME,
                    A.WORK_TIME,
                    A.STATUS,
                    A.ALARM_FLAG,
                    A.ALARM_CODE,
                    B.LINE_ID AS CMF_1,
                    B.MAT_ID AS CMF_2,
                    A.CMF_3,
                    A.CMF_4,
                    A.CMF_5,
                    A.CMF_6,
                    A.CMF_7,
                    A.CMF_8,
                    A.CMF_9,
                    A.CMF_10,
                    A.CREATE_USER_ID,
                    A.CREATE_TIME,
                    A.UPDATE_USER_ID,
                    A.UPDATE_TIME
                FROM CJCMJOBITM A
				   , CJCMJOBSTS B
				   , MWIPORDSTS C
				WHERE A.FACTORY = B.FACTORY 
				  AND A.ORDER_ID = B.ORDER_ID
				  AND A.FACTORY = C.FACTORY(+)
                  AND A.ORDER_ID = C.ORDER_ID(+)
				  AND A.FACTORY = :CJCMJOBITM_N.FACTORY
				  AND A.AUTO_FLAG = 'N'
				  AND A.ORDER_ID LIKE '%' || TRIM(:CJCMJOBITM_N.ORDER_ID) || '%'
				  AND A.DEPT_CODE LIKE '%' || TRIM(:CJCMJOBITM_N.DEPT_CODE) || '%'
				  AND A.STATUS LIKE '%' || TRIM(:CJCMJOBITM_N.STATUS) || '%'
				  AND B.LINE_ID LIKE '%' || TRIM(:CJCMJOBITM_N.CMF_1) || '%'
				  AND B.STATUS NOT IN('E','C')
				  AND (C.ORD_STATUS_FLAG(+) = 'O' OR C.ORD_STATUS_FLAG(+) = 'S')
                ORDER BY A.FACTORY ASC,
                    A.ORDER_ID ASC,
                    A.ITEM_CODE ASC;
            EXEC SQL OPEN CDB_CJCMJOBITM_CUR_4;
            break;

		case 5:
            EXEC SQL DECLARE CDB_CJCMJOBITM_CUR_5 CURSOR FOR
                SELECT 
                    A.FACTORY,
                    A.ORDER_ID,
                    A.ITEM_CODE,
                    A.AUTO_FLAG,
                    A.RESPONSIBILITY,
                    A.DEPT_CODE,
                    A.PLAN_START_DATE,
                    A.PLAN_END_DATE,
                    A.START_TIME,
                    A.END_TIME,
                    A.WORK_TIME,
                    A.STATUS,
                    A.ALARM_FLAG,
                    A.ALARM_CODE,
                    B.LINE_ID AS CMF_1,
                    B.MAT_ID AS CMF_2,
                    A.CMF_3,
                    A.CMF_4,
                    A.CMF_5,
                    A.CMF_6,
                    A.CMF_7,
                    A.CMF_8,
                    A.CMF_9,
                    A.CMF_10,
                    A.CREATE_USER_ID,
                    A.CREATE_TIME,
                    A.UPDATE_USER_ID,
                    A.UPDATE_TIME
                FROM CJCMJOBITM A
				   , CJCMJOBSTS B
				   , MWIPORDSTS C
				WHERE A.FACTORY = B.FACTORY 
				  AND A.ORDER_ID = B.ORDER_ID
				  AND A.FACTORY = C.FACTORY(+)
                  AND A.ORDER_ID = C.ORDER_ID(+)
				  AND A.FACTORY = :CJCMJOBITM_N.FACTORY
				  AND A.AUTO_FLAG = 'N'
				  AND A.ORDER_ID LIKE '%' || TRIM(:CJCMJOBITM_N.ORDER_ID) || '%'
				  AND A.DEPT_CODE LIKE '%' || TRIM(:CJCMJOBITM_N.DEPT_CODE) || '%'
				  AND A.STATUS != :CJCMJOBITM_N.STATUS
				  AND B.LINE_ID LIKE '%' || TRIM(:CJCMJOBITM_N.CMF_1) || '%'
				  AND B.STATUS NOT IN('E','C')
				  AND (C.ORD_STATUS_FLAG(+) = 'O' OR C.ORD_STATUS_FLAG(+) = 'S')
                ORDER BY A.FACTORY ASC,
                    A.ORDER_ID ASC,
                    A.ITEM_CODE ASC;
            EXEC SQL OPEN CDB_CJCMJOBITM_CUR_5;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cjcmjobitm", sel_type);
}


