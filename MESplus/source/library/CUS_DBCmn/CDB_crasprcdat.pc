    MEMCPY_AN(CRASPRCDAT_N->CMF_3, CRASPRCDAT->CMF_3, sizeof(CRASPRCDAT->CMF_3));
    MEMCPY_AN(CRASPRCDAT_N->CMF_4, CRASPRCDAT->CMF_4, sizeof(CRASPRCDAT->CMF_4));
    MEMCPY_AN(CRASPRCDAT_N->CMF_5, CRASPRCDAT->CMF_5, sizeof(CRASPRCDAT->CMF_5));
}


/* Del Null Function */
void CDB_del_null_crasprcdat(struct CRASPRCDAT_N_TAG *CRASPRCDAT_N, struct CRASPRCDAT_TAG *CRASPRCDAT)
{
    MEMCPY_DN(CRASPRCDAT->RES_ID, CRASPRCDAT_N->RES_ID, sizeof(CRASPRCDAT->RES_ID));
    MEMCPY_DN(CRASPRCDAT->PARAM_NAME, CRASPRCDAT_N->PARAM_NAME, sizeof(CRASPRCDAT->PARAM_NAME));
    MEMCPY_DN(CRASPRCDAT->TRAN_TIME, CRASPRCDAT_N->TRAN_TIME, sizeof(CRASPRCDAT->TRAN_TIME));
    MEMCPY_DN(CRASPRCDAT->LOT_ID, CRASPRCDAT_N->LOT_ID, sizeof(CRASPRCDAT->LOT_ID));
    CRASPRCDAT->SEQ_NUM = CRASPRCDAT_N->SEQ_NUM;
    MEMCPY_DN(CRASPRCDAT->FACTORY, CRASPRCDAT_N->FACTORY, sizeof(CRASPRCDAT->FACTORY));
    MEMCPY_DN(CRASPRCDAT->LINE_ID, CRASPRCDAT_N->LINE_ID, sizeof(CRASPRCDAT->LINE_ID));
    MEMCPY_DN(CRASPRCDAT->OPER, CRASPRCDAT_N->OPER, sizeof(CRASPRCDAT->OPER));
    CRASPRCDAT->LOT_HIST_SEQ = CRASPRCDAT_N->LOT_HIST_SEQ;
    MEMCPY_DN(CRASPRCDAT->PARAM_VALUE, CRASPRCDAT_N->PARAM_VALUE, sizeof(CRASPRCDAT->PARAM_VALUE));
    MEMCPY_DN(CRASPRCDAT->CREATE_TIME, CRASPRCDAT_N->CREATE_TIME, sizeof(CRASPRCDAT->CREATE_TIME));
    MEMCPY_DN(CRASPRCDAT->CMF_1, CRASPRCDAT_N->CMF_1, sizeof(CRASPRCDAT->CMF_1));
    MEMCPY_DN(CRASPRCDAT->CMF_2, CRASPRCDAT_N->CMF_2, sizeof(CRASPRCDAT->CMF_2));
    MEMCPY_DN(CRASPRCDAT->CMF_3, CRASPRCDAT_N->CMF_3, sizeof(CRASPRCDAT->CMF_3));
    MEMCPY_DN(CRASPRCDAT->CMF_4, CRASPRCDAT_N->CMF_4, sizeof(CRASPRCDAT->CMF_4));
    MEMCPY_DN(CRASPRCDAT->CMF_5, CRASPRCDAT_N->CMF_5, sizeof(CRASPRCDAT->CMF_5));
}


