    DB_start_query_timer();

    CDB_add_null_crasprcdat(&CRASPRCDAT_N, CRASPRCDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CRASPRCDAT_CUR_1 CURSOR FOR
                SELECT 
                    RES_ID,
                    PARAM_NAME,
                    TRAN_TIME,
                    LOT_ID,
                    SEQ_NUM,
                    NVL(FACTORY, ' '),
                    NVL(LINE_ID, ' '),
                    NVL(OPER, ' '),
                    NVL(LOT_HIST_SEQ, '0'),
                    NVL(PARAM_VALUE, ' '),
                    NVL(CREATE_TIME, ' '),
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' ')
                FROM CRASPRCDAT
                ORDER BY RES_ID ASC,
                    PARAM_NAME ASC,
                    TRAN_TIME ASC,
                    LOT_ID ASC,
                    SEQ_NUM ASC;
            EXEC SQL OPEN CDB_CRASPRCDAT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_crasprcdat", sel_type);
}


