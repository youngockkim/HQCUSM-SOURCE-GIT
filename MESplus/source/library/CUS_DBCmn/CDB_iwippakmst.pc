                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG,
					AC_FLAG,
					LENGTH_H,
					BREADTH_H,
					HEIGHT_H,
					GROSS_WEIGHT_H,
					NET_WEIGHT_H,
					TARE_WEIGHT_H
                FROM IWIPPAKMST
                ORDER BY DOC_ID ASC;
            EXEC SQL OPEN CDB_IWIPPAKMST_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_IWIPPAKMST_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    MATE_NO,
                    QCELL_MODULE_TYPE,
                    ACTION_TYPE,
                    PACK_TYPE,
                    BARCODE_ID,
                    LENGTH,
                    BREADTH,
                    HEIGHT,
                    GROSS_WEIGHT,
                    NET_WEIGHT,
                    TARE_WEIGHT,
                    SITE_ID,
                    ISUSABLE,
                    MODULE_QTY,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG,
					AC_FLAG,
					LENGTH_H,
					BREADTH_H,
					HEIGHT_H,
					GROSS_WEIGHT_H,
					NET_WEIGHT_H,
					TARE_WEIGHT_H
                FROM IWIPPAKMST
				WHERE RETURN_TYPE <> 'E'
                ORDER BY DOC_ID ASC;
            EXEC SQL OPEN CDB_IWIPPAKMST_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_iwippakmst", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_iwippakmst(int sel_type, struct IWIPPAKMST_TAG *IWIPPAKMST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IWIPPAKMST_N_TAG IWIPPAKMST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_IWIPPAKMST_CUR_1 INTO
                :IWIPPAKMST_N.DOC_ID,
                :IWIPPAKMST_N.MATE_NO,
                :IWIPPAKMST_N.QCELL_MODULE_TYPE,
                :IWIPPAKMST_N.ACTION_TYPE,
                :IWIPPAKMST_N.PACK_TYPE,
                :IWIPPAKMST_N.BARCODE_ID,
                :IWIPPAKMST_N.LENGTH,
                :IWIPPAKMST_N.BREADTH,
                :IWIPPAKMST_N.HEIGHT,
                :IWIPPAKMST_N.GROSS_WEIGHT,
                :IWIPPAKMST_N.NET_WEIGHT,
                :IWIPPAKMST_N.TARE_WEIGHT,
                :IWIPPAKMST_N.SITE_ID,
                :IWIPPAKMST_N.ISUSABLE,
                :IWIPPAKMST_N.MODULE_QTY,
                :IWIPPAKMST_N.INF_TIME,
                :IWIPPAKMST_N.INF_PROC_TIME,
                :IWIPPAKMST_N.CMF_1,
                :IWIPPAKMST_N.CMF_2,
                :IWIPPAKMST_N.CMF_3,
                :IWIPPAKMST_N.CMF_4,
                :IWIPPAKMST_N.CMF_5,
                :IWIPPAKMST_N.DATA_FLAG,
                :IWIPPAKMST_N.UPDATE_COUNT,
                :IWIPPAKMST_N.INSERT_COUNT,
                :IWIPPAKMST_N.DELETE_COUNT,
                :IWIPPAKMST_N.SQL_DML_COUNT,
                :IWIPPAKMST_N.ZPICODE,
                :IWIPPAKMST_N.ZPIMSGID,
                :IWIPPAKMST_N.RETURN_TYPE,
                :IWIPPAKMST_N.RETURN_MSG,
                :IWIPPAKMST_N.ZIFERNAM,
                :IWIPPAKMST_N.ZIFDATE,
                :IWIPPAKMST_N.ZIFTIME,
                :IWIPPAKMST_N.ZPISTAT,
                :IWIPPAKMST_N.ZPIMSG,
				:IWIPPAKMST_N.AC_FLAG,
				:IWIPPAKMST_N.LENGTH_H,
				:IWIPPAKMST_N.BREADTH_H,
				:IWIPPAKMST_N.HEIGHT_H,
				:IWIPPAKMST_N.GROSS_WEIGHT_H,
				:IWIPPAKMST_N.NET_WEIGHT_H,
				:IWIPPAKMST_N.TARE_WEIGHT_H;
            break;

		case 2:
            EXEC SQL FETCH CDB_IWIPPAKMST_CUR_2 INTO
                :IWIPPAKMST_N.DOC_ID,
                :IWIPPAKMST_N.MATE_NO,
                :IWIPPAKMST_N.QCELL_MODULE_TYPE,
                :IWIPPAKMST_N.ACTION_TYPE,
                :IWIPPAKMST_N.PACK_TYPE,
                :IWIPPAKMST_N.BARCODE_ID,
                :IWIPPAKMST_N.LENGTH,
                :IWIPPAKMST_N.BREADTH,
                :IWIPPAKMST_N.HEIGHT,
                :IWIPPAKMST_N.GROSS_WEIGHT,
                :IWIPPAKMST_N.NET_WEIGHT,
                :IWIPPAKMST_N.TARE_WEIGHT,
                :IWIPPAKMST_N.SITE_ID,
                :IWIPPAKMST_N.ISUSABLE,
                :IWIPPAKMST_N.MODULE_QTY,
                :IWIPPAKMST_N.INF_TIME,
                :IWIPPAKMST_N.INF_PROC_TIME,
                :IWIPPAKMST_N.CMF_1,
                :IWIPPAKMST_N.CMF_2,
                :IWIPPAKMST_N.CMF_3,
                :IWIPPAKMST_N.CMF_4,
                :IWIPPAKMST_N.CMF_5,
                :IWIPPAKMST_N.DATA_FLAG,
                :IWIPPAKMST_N.UPDATE_COUNT,
                :IWIPPAKMST_N.INSERT_COUNT,
                :IWIPPAKMST_N.DELETE_COUNT,
                :IWIPPAKMST_N.SQL_DML_COUNT,
                :IWIPPAKMST_N.ZPICODE,
                :IWIPPAKMST_N.ZPIMSGID,
                :IWIPPAKMST_N.RETURN_TYPE,
                :IWIPPAKMST_N.RETURN_MSG,
                :IWIPPAKMST_N.ZIFERNAM,
                :IWIPPAKMST_N.ZIFDATE,
                :IWIPPAKMST_N.ZIFTIME,
                :IWIPPAKMST_N.ZPISTAT,
                :IWIPPAKMST_N.ZPIMSG,
				:IWIPPAKMST_N.AC_FLAG,
				:IWIPPAKMST_N.LENGTH_H,
				:IWIPPAKMST_N.BREADTH_H,
				:IWIPPAKMST_N.HEIGHT_H,
				:IWIPPAKMST_N.GROSS_WEIGHT_H,
				:IWIPPAKMST_N.NET_WEIGHT_H,
				:IWIPPAKMST_N.TARE_WEIGHT_H;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_iwippakmst(&IWIPPAKMST_N, IWIPPAKMST);
    }

    DB_stop_query_timer("CDB_fetch_iwippakmst", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_iwippakmst(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IWIPPAKMST_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_IWIPPAKMST_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_iwippakmst", sel_type);
}


/* Initialize Function */
void CDB_init_iwippakmst(struct IWIPPAKMST_TAG *IWIPPAKMST)
{
    /* memset by Space */
    memset(IWIPPAKMST, ' ', sizeof(struct IWIPPAKMST_TAG));
    
    IWIPPAKMST->MODULE_QTY = 0;
}


/* Add Null Function */
void CDB_add_null_iwippakmst(struct IWIPPAKMST_N_TAG *IWIPPAKMST_N, struct IWIPPAKMST_TAG *IWIPPAKMST)
{
    /* memset by NULL */
    memset(IWIPPAKMST_N, '\0', sizeof(struct IWIPPAKMST_N_TAG));
    
    MEMCPY_AN(IWIPPAKMST_N->DOC_ID, IWIPPAKMST->DOC_ID, sizeof(IWIPPAKMST->DOC_ID));
    MEMCPY_AN(IWIPPAKMST_N->MATE_NO, IWIPPAKMST->MATE_NO, sizeof(IWIPPAKMST->MATE_NO));
    MEMCPY_AN(IWIPPAKMST_N->QCELL_MODULE_TYPE, IWIPPAKMST->QCELL_MODULE_TYPE, sizeof(IWIPPAKMST->QCELL_MODULE_TYPE));
    MEMCPY_AN(IWIPPAKMST_N->ACTION_TYPE, IWIPPAKMST->ACTION_TYPE, sizeof(IWIPPAKMST->ACTION_TYPE));
    MEMCPY_AN(IWIPPAKMST_N->PACK_TYPE, IWIPPAKMST->PACK_TYPE, sizeof(IWIPPAKMST->PACK_TYPE));
    MEMCPY_AN(IWIPPAKMST_N->BARCODE_ID, IWIPPAKMST->BARCODE_ID, sizeof(IWIPPAKMST->BARCODE_ID));
    MEMCPY_AN(IWIPPAKMST_N->LENGTH, IWIPPAKMST->LENGTH, sizeof(IWIPPAKMST->LENGTH));
    MEMCPY_AN(IWIPPAKMST_N->BREADTH, IWIPPAKMST->BREADTH, sizeof(IWIPPAKMST->BREADTH));
    MEMCPY_AN(IWIPPAKMST_N->HEIGHT, IWIPPAKMST->HEIGHT, sizeof(IWIPPAKMST->HEIGHT));
    MEMCPY_AN(IWIPPAKMST_N->GROSS_WEIGHT, IWIPPAKMST->GROSS_WEIGHT, sizeof(IWIPPAKMST->GROSS_WEIGHT));
    MEMCPY_AN(IWIPPAKMST_N->NET_WEIGHT, IWIPPAKMST->NET_WEIGHT, sizeof(IWIPPAKMST->NET_WEIGHT));
    MEMCPY_AN(IWIPPAKMST_N->TARE_WEIGHT, IWIPPAKMST->TARE_WEIGHT, sizeof(IWIPPAKMST->TARE_WEIGHT));
    MEMCPY_AN(IWIPPAKMST_N->SITE_ID, IWIPPAKMST->SITE_ID, sizeof(IWIPPAKMST->SITE_ID));
    IWIPPAKMST_N->ISUSABLE[0] = IWIPPAKMST->ISUSABLE;
    IWIPPAKMST_N->MODULE_QTY = IWIPPAKMST->MODULE_QTY;
    MEMCPY_AN(IWIPPAKMST_N->INF_TIME, IWIPPAKMST->INF_TIME, sizeof(IWIPPAKMST->INF_TIME));
    MEMCPY_AN(IWIPPAKMST_N->INF_PROC_TIME, IWIPPAKMST->INF_PROC_TIME, sizeof(IWIPPAKMST->INF_PROC_TIME));
    MEMCPY_AN(IWIPPAKMST_N->CMF_1, IWIPPAKMST->CMF_1, sizeof(IWIPPAKMST->CMF_1));
    MEMCPY_AN(IWIPPAKMST_N->CMF_2, IWIPPAKMST->CMF_2, sizeof(IWIPPAKMST->CMF_2));
    MEMCPY_AN(IWIPPAKMST_N->CMF_3, IWIPPAKMST->CMF_3, sizeof(IWIPPAKMST->CMF_3));
    MEMCPY_AN(IWIPPAKMST_N->CMF_4, IWIPPAKMST->CMF_4, sizeof(IWIPPAKMST->CMF_4));
    MEMCPY_AN(IWIPPAKMST_N->CMF_5, IWIPPAKMST->CMF_5, sizeof(IWIPPAKMST->CMF_5));
    IWIPPAKMST_N->DATA_FLAG[0] = IWIPPAKMST->DATA_FLAG;
    MEMCPY_AN(IWIPPAKMST_N->UPDATE_COUNT, IWIPPAKMST->UPDATE_COUNT, sizeof(IWIPPAKMST->UPDATE_COUNT));
    MEMCPY_AN(IWIPPAKMST_N->INSERT_COUNT, IWIPPAKMST->INSERT_COUNT, sizeof(IWIPPAKMST->INSERT_COUNT));
    MEMCPY_AN(IWIPPAKMST_N->DELETE_COUNT, IWIPPAKMST->DELETE_COUNT, sizeof(IWIPPAKMST->DELETE_COUNT));
    MEMCPY_AN(IWIPPAKMST_N->SQL_DML_COUNT, IWIPPAKMST->SQL_DML_COUNT, sizeof(IWIPPAKMST->SQL_DML_COUNT));
    MEMCPY_AN(IWIPPAKMST_N->ZPICODE, IWIPPAKMST->ZPICODE, sizeof(IWIPPAKMST->ZPICODE));
    MEMCPY_AN(IWIPPAKMST_N->ZPIMSGID, IWIPPAKMST->ZPIMSGID, sizeof(IWIPPAKMST->ZPIMSGID));
    IWIPPAKMST_N->RETURN_TYPE[0] = IWIPPAKMST->RETURN_TYPE;
    MEMCPY_AN(IWIPPAKMST_N->RETURN_MSG, IWIPPAKMST->RETURN_MSG, sizeof(IWIPPAKMST->RETURN_MSG));
    MEMCPY_AN(IWIPPAKMST_N->ZIFERNAM, IWIPPAKMST->ZIFERNAM, sizeof(IWIPPAKMST->ZIFERNAM));
    MEMCPY_AN(IWIPPAKMST_N->ZIFDATE, IWIPPAKMST->ZIFDATE, sizeof(IWIPPAKMST->ZIFDATE));
    MEMCPY_AN(IWIPPAKMST_N->ZIFTIME, IWIPPAKMST->ZIFTIME, sizeof(IWIPPAKMST->ZIFTIME));
    IWIPPAKMST_N->ZPISTAT[0] = IWIPPAKMST->ZPISTAT;
    MEMCPY_AN(IWIPPAKMST_N->ZPIMSG, IWIPPAKMST->ZPIMSG, sizeof(IWIPPAKMST->ZPIMSG));
	MEMCPY_AN(IWIPPAKMST_N->AC_FLAG, IWIPPAKMST->AC_FLAG, sizeof(IWIPPAKMST->AC_FLAG));
	MEMCPY_AN(IWIPPAKMST_N->LENGTH_H, IWIPPAKMST->LENGTH_H, sizeof(IWIPPAKMST->LENGTH_H));
	MEMCPY_AN(IWIPPAKMST_N->BREADTH_H, IWIPPAKMST->BREADTH_H, sizeof(IWIPPAKMST->BREADTH_H));
	MEMCPY_AN(IWIPPAKMST_N->HEIGHT_H, IWIPPAKMST->HEIGHT_H, sizeof(IWIPPAKMST->HEIGHT_H));
	MEMCPY_AN(IWIPPAKMST_N->GROSS_WEIGHT_H, IWIPPAKMST->GROSS_WEIGHT_H, sizeof(IWIPPAKMST->GROSS_WEIGHT_H));
	MEMCPY_AN(IWIPPAKMST_N->NET_WEIGHT_H, IWIPPAKMST->NET_WEIGHT_H, sizeof(IWIPPAKMST->NET_WEIGHT_H));
	MEMCPY_AN(IWIPPAKMST_N->TARE_WEIGHT_H, IWIPPAKMST->TARE_WEIGHT_H, sizeof(IWIPPAKMST->TARE_WEIGHT_H));					
}


/* Del Null Function */
void CDB_del_null_iwippakmst(struct IWIPPAKMST_N_TAG *IWIPPAKMST_N, struct IWIPPAKMST_TAG *IWIPPAKMST)
{
    MEMCPY_DN(IWIPPAKMST->DOC_ID, IWIPPAKMST_N->DOC_ID, sizeof(IWIPPAKMST->DOC_ID));
    MEMCPY_DN(IWIPPAKMST->MATE_NO, IWIPPAKMST_N->MATE_NO, sizeof(IWIPPAKMST->MATE_NO));
