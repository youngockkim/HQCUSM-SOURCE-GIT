/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cjcmitmdef(int sel_type, struct CJCMITMDEF_TAG *CJCMITMDEF)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CJCMITMDEF_N_TAG CJCMITMDEF_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cjcmitmdef(&CJCMITMDEF_N, CJCMITMDEF);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CJCMITMDEF_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    ITEM_CODE,
					ITEM_NAME,
                    AUTO_FLAG,
                    RESPONSIBILITY,
                    DEPT_CODE,
                    PLAN_START_DAYS_BEFORE,
                    PLAN_END_DAYS_BEFORE,
                    ALARM_FLAG,
                    ALARM_CODE,
                    SQL_TEXT,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    CMF_6,
                    CMF_7,
                    CMF_8,
                    CMF_9,
                    CMF_10,
					USE_FLAG,
                    CREATE_USER_ID,
                    CREATE_TIME,
                    UPDATE_USER_ID,
                    UPDATE_TIME
                FROM CJCMITMDEF
			    WHERE FACTORY = :CJCMITMDEF_N.FACTORY
				  AND ITEM_CODE LIKE '%' || TRIM(:CJCMITMDEF_N.ITEM_CODE) || '%'
				  AND DEPT_CODE LIKE '%' || TRIM(:CJCMITMDEF_N.DEPT_CODE) || '%'
                ORDER BY FACTORY ASC,
					AUTO_FLAG ASC,
                    ITEM_CODE ASC;
            EXEC SQL OPEN CDB_CJCMITMDEF_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CJCMITMDEF_CUR_2 CURSOR FOR
                SELECT 
                    A.FACTORY,
                    A.ITEM_CODE,
					A.ITEM_NAME,
                    A.AUTO_FLAG,
                    A.RESPONSIBILITY,
                    A.DEPT_CODE,
                    TO_NUMBER(CASE WHEN A.PLAN_START_DAYS_BEFORE > 0 THEN TO_CHAR((TO_DATE(B.START_DATE,'YYYYMMDD') - A.PLAN_START_DAYS_BEFORE), 'YYYYMMDD') ELSE B.START_DATE END) AS PLAN_START_DAYS_BEFORE,
                    TO_NUMBER(CASE WHEN A.PLAN_END_DAYS_BEFORE > 0 THEN TO_CHAR((TO_DATE(B.START_DATE,'YYYYMMDD') - A.PLAN_END_DAYS_BEFORE), 'YYYYMMDD') ELSE B.START_DATE END) AS PLAN_END_DAYS_BEFORE,
                    A.ALARM_FLAG,
                    A.ALARM_CODE,
                    A.SQL_TEXT,
                    B.WORK_CENTER AS CMF_1,
                    A.CMF_2,
                    A.CMF_3,
                    A.CMF_4,
                    A.CMF_5,
                    A.CMF_6,
                    A.CMF_7,
                    A.CMF_8,
                    A.CMF_9,
                    A.CMF_10,
					A.USE_FLAG,
                    A.CREATE_USER_ID,
                    A.CREATE_TIME,
                    A.UPDATE_USER_ID,
                    A.UPDATE_TIME
                FROM CJCMITMDEF A, CWIPORDSTS B
			   WHERE A.FACTORY = B.FACTORY
			     AND A.FACTORY = :CJCMITMDEF_N.FACTORY
				 AND A.USE_FLAG = 'Y'
				 AND B.ORDER_ID = :CJCMITMDEF_N.CMF_1
                ORDER BY A.FACTORY ASC, 
					A.AUTO_FLAG ASC,
                    A.ITEM_CODE ASC;
            EXEC SQL OPEN CDB_CJCMITMDEF_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cjcmitmdef", sel_type);
}


