/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_ctmpspcdat(int sel_type, struct CTMPSPCDAT_TAG *CTMPSPCDAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CTMPSPCDAT_N_TAG CTMPSPCDAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ctmpspcdat(&CTMPSPCDAT_N, CTMPSPCDAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CTMPSPCDAT_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    RES_ID,
                    TRAN_TIME,
                    SEQ_NUM,
                    NVL(FACTORY, ' '),
                    NVL(LINE_ID, ' '),
                    NVL(OPER, ' '),
                    NVL(LOT_HIST_SEQ, '0'),
                    NVL(PARAM_NAME, ' '),
                    NVL(PARAM_VALUE, ' '),
                    NVL(CHART_ID, ' '),
                    NVL(CMF_1, ' '),
                    NVL(CMF_2, ' '),
                    NVL(CMF_3, ' '),
                    NVL(CMF_4, ' '),
                    NVL(CMF_5, ' ')
                FROM CTMPSPCDAT
				WHERE CMF_1  = :CTMPSPCDAT_N.CMF_1
                ORDER BY CHART_ID ASC,
                    TRAN_TIME ASC,
                    SEQ_NUM ASC;
            EXEC SQL OPEN CDB_CTMPSPCDAT_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_ctmpspcdat", sel_type);
}


