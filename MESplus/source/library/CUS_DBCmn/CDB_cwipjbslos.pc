    MEMCPY_DN(CWIPJBSLOS->CREATE_USER_ID, CWIPJBSLOS_N->CREATE_USER_ID, sizeof(CWIPJBSLOS->CREATE_USER_ID));
    MEMCPY_DN(CWIPJBSLOS->CREATE_TIME, CWIPJBSLOS_N->CREATE_TIME, sizeof(CWIPJBSLOS->CREATE_TIME));
    MEMCPY_DN(CWIPJBSLOS->UPDATE_USER_ID, CWIPJBSLOS_N->UPDATE_USER_ID, sizeof(CWIPJBSLOS->UPDATE_USER_ID));
    MEMCPY_DN(CWIPJBSLOS->UPDATE_TIME, CWIPJBSLOS_N->UPDATE_TIME, sizeof(CWIPJBSLOS->UPDATE_TIME));
}


