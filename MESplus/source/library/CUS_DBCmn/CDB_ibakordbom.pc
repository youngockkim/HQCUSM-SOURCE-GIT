    MEMCPY_AN(IBAKORDBOM_N->LOC_ID, IBAKORDBOM->LOC_ID, sizeof(IBAKORDBOM->LOC_ID));
    IBAKORDBOM_N->BACKFLUSH_YN[0] = IBAKORDBOM->BACKFLUSH_YN;
