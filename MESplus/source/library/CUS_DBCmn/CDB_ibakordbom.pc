                :IBAKORDBOM_N.RS_NUM,
                :IBAKORDBOM_N.RS_POS,
                :IBAKORDBOM_N.BOM_PJT_NO,
                :IBAKORDBOM_N.BOM_PJT_CATE,
                :IBAKORDBOM_N.MATE_NO,
                :IBAKORDBOM_N.MATE_TYPE,
                :IBAKORDBOM_N.MATE_NO_DESC,
                :IBAKORDBOM_N.QTY,
                :IBAKORDBOM_N.UNIT_ID,
                :IBAKORDBOM_N.BATCH_NO,
                :IBAKORDBOM_N.VEN_BATCH_NO,
                :IBAKORDBOM_N.LOC_ID,
                :IBAKORDBOM_N.BACKFLUSH_YN,
                :IBAKORDBOM_N.HAND_BOOK,
                :IBAKORDBOM_N.VENDOR,
                :IBAKORDBOM_N.COMMENTS,
                :IBAKORDBOM_N.CELL_PROD_TYPE,
                :IBAKORDBOM_N.CELL_POWER_GRADE_1,
                :IBAKORDBOM_N.CELL_POWER_GRADE_2,
                :IBAKORDBOM_N.CELL_CONVERSION_RATE,
                :IBAKORDBOM_N.CELL_POWER_RATE,
                :IBAKORDBOM_N.DEL_YN,
                :IBAKORDBOM_N.INF_TIME,
                :IBAKORDBOM_N.INF_PROC_TIME,
                :IBAKORDBOM_N.CMF_1,
                :IBAKORDBOM_N.CMF_2,
                :IBAKORDBOM_N.CMF_3,
                :IBAKORDBOM_N.CMF_4,
                :IBAKORDBOM_N.CMF_5,
                :IBAKORDBOM_N.DATA_FLAG,
                :IBAKORDBOM_N.UPDATE_COUNT,
                :IBAKORDBOM_N.INSERT_COUNT,
                :IBAKORDBOM_N.DELETE_COUNT,
                :IBAKORDBOM_N.SQL_DML_COUNT,
                :IBAKORDBOM_N.ZPICODE,
                :IBAKORDBOM_N.ZPIMSGID,
                :IBAKORDBOM_N.RETURN_TYPE,
                :IBAKORDBOM_N.RETURN_MSG,
                :IBAKORDBOM_N.ZIFERNAM,
                :IBAKORDBOM_N.ZIFDATE,
                :IBAKORDBOM_N.ZIFTIME,
                :IBAKORDBOM_N.ZPISTAT,
                :IBAKORDBOM_N.ZPIMSG;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_ibakordbom(&IBAKORDBOM_N, IBAKORDBOM);
    }

    DB_stop_query_timer("CDB_fetch_ibakordbom", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_ibakordbom(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_IBAKORDBOM_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ibakordbom", sel_type);
}


/* Initialize Function */
void CDB_init_ibakordbom(struct IBAKORDBOM_TAG *IBAKORDBOM)
{
    /* memset by Space */
    memset(IBAKORDBOM, ' ', sizeof(struct IBAKORDBOM_TAG));
    
    IBAKORDBOM->QTY = 0;
}


/* Add Null Function */
void CDB_add_null_ibakordbom(struct IBAKORDBOM_N_TAG *IBAKORDBOM_N, struct IBAKORDBOM_TAG *IBAKORDBOM)
{
    /* memset by NULL */
    memset(IBAKORDBOM_N, '\0', sizeof(struct IBAKORDBOM_N_TAG));
    
    MEMCPY_AN(IBAKORDBOM_N->DOC_ID, IBAKORDBOM->DOC_ID, sizeof(IBAKORDBOM->DOC_ID));
    MEMCPY_AN(IBAKORDBOM_N->SITE_ID, IBAKORDBOM->SITE_ID, sizeof(IBAKORDBOM->SITE_ID));
