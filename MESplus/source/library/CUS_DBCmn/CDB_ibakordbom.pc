    MEMCPY_AN(IBAKORDBOM_N->CELL_POWER_GRADE_1, IBAKORDBOM->CELL_POWER_GRADE_1, sizeof(IBAKORDBOM->CELL_POWER_GRADE_1));
    MEMCPY_AN(IBAKORDBOM_N->CELL_POWER_GRADE_2, IBAKORDBOM->CELL_POWER_GRADE_2, sizeof(IBAKORDBOM->CELL_POWER_GRADE_2));
    MEMCPY_AN(IBAKORDBOM_N->CELL_CONVERSION_RATE, IBAKORDBOM->CELL_CONVERSION_RATE, sizeof(IBAKORDBOM->CELL_CONVERSION_RATE));
    MEMCPY_AN(IBAKORDBOM_N->CELL_POWER_RATE, IBAKORDBOM->CELL_POWER_RATE, sizeof(IBAKORDBOM->CELL_POWER_RATE));
    IBAKORDBOM_N->DEL_YN[0] = IBAKORDBOM->DEL_YN;
    MEMCPY_AN(IBAKORDBOM_N->INF_TIME, IBAKORDBOM->INF_TIME, sizeof(IBAKORDBOM->INF_TIME));
    MEMCPY_AN(IBAKORDBOM_N->INF_PROC_TIME, IBAKORDBOM->INF_PROC_TIME, sizeof(IBAKORDBOM->INF_PROC_TIME));
    MEMCPY_AN(IBAKORDBOM_N->CMF_1, IBAKORDBOM->CMF_1, sizeof(IBAKORDBOM->CMF_1));
    MEMCPY_AN(IBAKORDBOM_N->CMF_2, IBAKORDBOM->CMF_2, sizeof(IBAKORDBOM->CMF_2));
