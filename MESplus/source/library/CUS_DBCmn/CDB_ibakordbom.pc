{
    EXEC SQL BEGIN DECLARE SECTION;
        struct IBAKORDBOM_N_TAG IBAKORDBOM_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ibakordbom(&IBAKORDBOM_N, IBAKORDBOM);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_IBAKORDBOM_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    PROD_ORDER_NO,
                    RS_NUM,
                    RS_POS,
                    BOM_PJT_NO,
                    BOM_PJT_CATE,
