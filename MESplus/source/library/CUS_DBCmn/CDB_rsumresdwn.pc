					SELECT WORK_DATE, WORK_SHIFT, LINE_ID, RES_ID, SUB_RES_ID, CURR_CODE, SUM(STATE_TIME) STATE_SUM, FACTORY, OPER FROM RSUMRESDWH
					WHERE WORK_DATE >= TO_CHAR(TO_DATE(:RSUMRESDWN_N.WORK_DATE, 'YYYYMMDD') - 2, 'YYYYMMDD')
				      AND  WORK_DATE <=:RSUMRESDWN_N.WORK_DATE
					GROUP BY WORK_DATE, WORK_SHIFT, LINE_ID, RES_ID, SUB_RES_ID, CURR_CODE, FACTORY, OPER;
            break;

