/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_rsumresdwn(int sel_type, struct RSUMRESDWN_TAG *RSUMRESDWN)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct RSUMRESDWN_N_TAG RSUMRESDWN_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_rsumresdwn(&RSUMRESDWN_N, RSUMRESDWN);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_RSUMRESDWN_CUR_1 CURSOR FOR
                SELECT 
                    WORK_DATE,
                    WORK_SHIFT,
                    LINE_ID,
                    OPER,
                    RES_ID,
                    SUB_RES_ID,
                    CURR_CODE,
                    STATE_SUM,
                    FACTORY,
                    CMF_VAL_1,
                    CMF_VAL_2,
                    CMF_1,
                    CMF_2,
                    CMF_3
                FROM RSUMRESDWN
                ORDER BY WORK_DATE ASC,
                    WORK_SHIFT ASC,
                    LINE_ID ASC,
                    OPER ASC,
                    RES_ID ASC,
                    SUB_RES_ID ASC,
                    CURR_CODE ASC;
            EXEC SQL OPEN CDB_RSUMRESDWN_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_RSUMRESDWN_CUR_2 CURSOR FOR
                SELECT 
                    DISTINCT SUB_RES_ID
                FROM RSUMRESDWN
				WHERE RES_ID != SUB_RES_ID
				AND RES_ID = :RSUMRESDWN_N.RES_ID
				AND WORK_DATE >= TO_CHAR(SYSDATE-30, 'YYYYMMDD');
            EXEC SQL OPEN CDB_RSUMRESDWN_CUR_2;
            break;

		case 3:
            EXEC SQL DECLARE CDB_RSUMRESDWN_CUR_3 CURSOR FOR
                SELECT 
					FACTORY,
                    RES_ID,
                    SUB_RES_ID,
                    SUM(STATE_SUM),
                     :RSUMRESDWN_N.CMF_VAL_2 - SUM(STATE_SUM),
                     :RSUMRESDWN_N.CMF_VAL_2
                FROM RSUMRESDWN
				WHERE WORK_DATE = :RSUMRESDWN_N.WORK_DATE
                GROUP BY FACTORY, RES_ID, SUB_RES_ID
				HAVING SUM(STATE_SUM) != :RSUMRESDWN_N.CMF_VAL_2
				;
            EXEC SQL OPEN CDB_RSUMRESDWN_CUR_3;
            break;
		default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_rsumresdwn", sel_type);
}


