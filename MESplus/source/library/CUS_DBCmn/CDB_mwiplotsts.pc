                    CREATE_QTY_2 = :MWIPLOTSTS_N.CREATE_QTY_2,
                    CREATE_QTY_3 = :MWIPLOTSTS_N.CREATE_QTY_3,
                    START_QTY_1 = :MWIPLOTSTS_N.START_QTY_1,
                    START_QTY_2 = :MWIPLOTSTS_N.START_QTY_2,
                    START_QTY_3 = :MWIPLOTSTS_N.START_QTY_3,
                    INV_FLAG = :MWIPLOTSTS_N.INV_FLAG,
                    TRANSIT_FLAG = :MWIPLOTSTS_N.TRANSIT_FLAG,
                    UNIT_EXIST_FLAG = :MWIPLOTSTS_N.UNIT_EXIST_FLAG,
