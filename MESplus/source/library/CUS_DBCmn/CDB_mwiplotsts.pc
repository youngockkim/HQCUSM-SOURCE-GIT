                    RWK_RET_FLOW = :MWIPLOTSTS_N.RWK_RET_FLOW,
                    RWK_RET_FLOW_SEQ_NUM = :MWIPLOTSTS_N.RWK_RET_FLOW_SEQ_NUM,
                    RWK_RET_OPER = :MWIPLOTSTS_N.RWK_RET_OPER,
                    RWK_END_FLOW = :MWIPLOTSTS_N.RWK_END_FLOW,
                    RWK_END_FLOW_SEQ_NUM = :MWIPLOTSTS_N.RWK_END_FLOW_SEQ_NUM,
                    RWK_END_OPER = :MWIPLOTSTS_N.RWK_END_OPER,
