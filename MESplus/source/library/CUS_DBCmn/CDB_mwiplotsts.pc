                    LOT_DEL_CODE = :MWIPLOTSTS_N.LOT_DEL_CODE,
                    LOT_DEL_TIME = :MWIPLOTSTS_N.LOT_DEL_TIME,
                    BOM_SET_ID = :MWIPLOTSTS_N.BOM_SET_ID,
                    BOM_SET_VERSION = :MWIPLOTSTS_N.BOM_SET_VERSION,
                    BOM_ACTIVE_HIST_SEQ = :MWIPLOTSTS_N.BOM_ACTIVE_HIST_SEQ,
                    BOM_HIST_SEQ = :MWIPLOTSTS_N.BOM_HIST_SEQ,
                    LAST_TRAN_CODE = :MWIPLOTSTS_N.LAST_TRAN_CODE,
                    LAST_TRAN_TIME = :MWIPLOTSTS_N.LAST_TRAN_TIME,
                    LAST_COMMENT = :MWIPLOTSTS_N.LAST_COMMENT,
                    LAST_ACTIVE_HIST_SEQ = :MWIPLOTSTS_N.LAST_ACTIVE_HIST_SEQ,
