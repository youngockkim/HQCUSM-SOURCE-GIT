                    STR_RET_FLOW_SEQ_NUM = :MWIPLOTSTS_N.STR_RET_FLOW_SEQ_NUM,
                    STR_RET_OPER = :MWIPLOTSTS_N.STR_RET_OPER,
                    START_FLAG = :MWIPLOTSTS_N.START_FLAG,
