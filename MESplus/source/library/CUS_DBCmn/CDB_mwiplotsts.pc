/* SQL UPDATE Function */
void CDB_update_mwiplotsts(int sel_type, struct MWIPLOTSTS_TAG *MWIPLOTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTSTS_N_TAG MWIPLOTSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_mwiplotsts(&MWIPLOTSTS_N, MWIPLOTSTS);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL UPDATE MWIPLOTSTS SET
                    LOT_DESC = :MWIPLOTSTS_N.LOT_DESC,
                    FACTORY = :MWIPLOTSTS_N.FACTORY,
                    MAT_ID = :MWIPLOTSTS_N.MAT_ID,
                    MAT_VER = :MWIPLOTSTS_N.MAT_VER,
                    FLOW = :MWIPLOTSTS_N.FLOW,
                    FLOW_SEQ_NUM = :MWIPLOTSTS_N.FLOW_SEQ_NUM,
                    OPER = :MWIPLOTSTS_N.OPER,
                    QTY_1 = :MWIPLOTSTS_N.QTY_1,
                    QTY_2 = :MWIPLOTSTS_N.QTY_2,
                    QTY_3 = :MWIPLOTSTS_N.QTY_3,
                    CRR_ID = :MWIPLOTSTS_N.CRR_ID,
