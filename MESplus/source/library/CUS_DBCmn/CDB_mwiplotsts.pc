		case 3:
            EXEC SQL UPDATE MWIPLOTSTS SET
                    LOT_GROUP_ID_2 = :MWIPLOTSTS_N.LOT_GROUP_ID_2
                WHERE  LOT_ID = :MWIPLOTSTS_N.LOT_ID;
            break;

		case 4:
            EXEC SQL UPDATE MWIPLOTSTS SET
                    LOT_GROUP_ID_1 = ' '
                WHERE  FACTORY = :MWIPLOTSTS_N.FACTORY
				 AND LOT_DEL_FLAG = :MWIPLOTSTS_N.LOT_DEL_FLAG
				 AND OPER = :MWIPLOTSTS_N.OPER
				 AND LOT_GROUP_ID_1 = :MWIPLOTSTS_N.LOT_GROUP_ID_1;
            break;

		case 5:
            EXEC SQL UPDATE MWIPLOTSTS SET
                    LOT_GROUP_ID_2 = ' '
                WHERE  LOT_GROUP_ID_2 = :MWIPLOTSTS_N.LOT_GROUP_ID_2;
            break;

		case 6:
            EXEC SQL UPDATE MWIPLOTSTS SET
                    CRR_ID = ' '
                WHERE  CRR_ID = :MWIPLOTSTS_N.CRR_ID;
            break;

		case 7:
		/* LAMI VALULATION UPDATE */
            EXEC SQL UPDATE MWIPLOTSTS SET
                    LOT_GROUP_ID_3 = :MWIPLOTSTS_N.LOT_GROUP_ID_3,
					LOT_CMF_3 = :MWIPLOTSTS_N.LOT_CMF_3,
					LOT_CMF_4 = :MWIPLOTSTS_N.LOT_CMF_4,
					LOT_CMF_5 = :MWIPLOTSTS_N.LOT_CMF_5
                WHERE  LOT_ID = :MWIPLOTSTS_N.LOT_ID;
            break;

		case 8:
		/* REPAIR STRING COUNT */
            EXEC SQL UPDATE MWIPLOTSTS SET
                   LOT_CMF_6 = :MWIPLOTSTS_N.LOT_CMF_6
                WHERE  LOT_ID = :MWIPLOTSTS_N.LOT_ID;
            break;

		case 9:
		/* CELL BOX INFORMATION UPDATE */
            EXEC SQL UPDATE MWIPLOTSTS SET
                   LOT_CMF_7 = :MWIPLOTSTS_N.LOT_CMF_7,
				   LOT_CMF_8 = :MWIPLOTSTS_N.LOT_CMF_8,
				   LOT_CMF_9 = :MWIPLOTSTS_N.LOT_CMF_9,
				   LOT_CMF_10 = :MWIPLOTSTS_N.LOT_CMF_10,
				   LOT_CMF_11 = :MWIPLOTSTS_N.LOT_CMF_11,
				   LOT_CMF_12 = :MWIPLOTSTS_N.LOT_CMF_12,
				   LOT_CMF_13 = :MWIPLOTSTS_N.LOT_CMF_13,
				   LOT_CMF_14 = :MWIPLOTSTS_N.LOT_CMF_14
                WHERE  LOT_ID = :MWIPLOTSTS_N.LOT_ID;
            break;

		case 10:
		/* AC MODULE STATUS UPDATE */
            EXEC SQL UPDATE MWIPLOTSTS SET
                   LOT_CMF_15 = :MWIPLOTSTS_N.LOT_CMF_15
                WHERE  LOT_ID = :MWIPLOTSTS_N.LOT_ID;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_update_mwiplotsts", sel_type);
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_mwiplotsts(int sel_type, struct MWIPLOTSTS_TAG *MWIPLOTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTSTS_N_TAG MWIPLOTSTS_N;
		char   sql[10000];
        char   ts1[100];
        char   ts2[100];
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_mwiplotsts(&MWIPLOTSTS_N, MWIPLOTSTS);
    DB_error_code = 0;
	memset( ts1, 0x00, sizeof(ts1));
    memset( ts2, 0x00, sizeof(ts2));

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_MWIPLOTSTS_CUR_1 CURSOR FOR
                SELECT 
                    LOT_ID,
                    LOT_DESC,
                    FACTORY,
                    MAT_ID,
                    MAT_VER,
                    FLOW,
                    FLOW_SEQ_NUM,
                    OPER,
                    QTY_1,
                    QTY_2,
                    QTY_3,
                    CRR_ID,
                    LOT_TYPE,
                    OWNER_CODE,
                    CREATE_CODE,
                    LOT_PRIORITY,
                    LOT_STATUS,
                    HOLD_FLAG,
                    HOLD_CODE,
                    HOLD_PASSWORD,
                    HOLD_PRV_GRP_ID,
                    OPER_IN_QTY_1,
                    OPER_IN_QTY_2,
                    OPER_IN_QTY_3,
                    CREATE_QTY_1,
                    CREATE_QTY_2,
                    CREATE_QTY_3,
                    START_QTY_1,
                    START_QTY_2,
                    START_QTY_3,
                    INV_FLAG,
                    TRANSIT_FLAG,
                    UNIT_EXIST_FLAG,
                    INV_UNIT,
                    RWK_FLAG,
                    RWK_CODE,
                    RWK_COUNT,
                    RWK_RET_FLOW,
                    RWK_RET_FLOW_SEQ_NUM,
                    RWK_RET_OPER,
                    RWK_END_FLOW,
                    RWK_END_FLOW_SEQ_NUM,
                    RWK_END_OPER,
                    RWK_RET_CLEAR_FLAG,
                    RWK_TIME,
                    NSTD_FLAG,
                    NSTD_RET_FLOW,
                    NSTD_RET_FLOW_SEQ_NUM,
                    NSTD_RET_OPER,
                    NSTD_TIME,
                    REP_FLAG,
                    REP_RET_OPER,
                    STR_RET_FLOW,
                    STR_RET_FLOW_SEQ_NUM,
                    STR_RET_OPER,
                    START_FLAG,
                    START_TIME,
                    START_RES_ID,
                    END_FLAG,
                    END_TIME,
                    END_RES_ID,
                    SAMPLE_FLAG,
                    SAMPLE_WAIT_FLAG,
                    SAMPLE_RESULT,
                    FROM_TO_FLAG,
                    FROM_TO_LOT_ID,
                    SHIP_CODE,
                    SHIP_TIME,
                    ORG_DUE_TIME,
                    SCH_DUE_TIME,
                    CREATE_TIME,
                    FAC_IN_TIME,
                    FLOW_IN_TIME,
                    OPER_IN_TIME,
                    RESERVE_RES_ID,
                    PORT_ID,
                    BATCH_ID,
                    BATCH_SEQ,
                    ORDER_ID,
                    ADD_ORDER_ID_1,
                    ADD_ORDER_ID_2,
                    ADD_ORDER_ID_3,
                    LOT_LOCATION_1,
                    LOT_LOCATION_2,
                    LOT_LOCATION_3,
                    LOT_CMF_1,
                    LOT_CMF_2,
                    LOT_CMF_3,
                    LOT_CMF_4,
                    LOT_CMF_5,
                    LOT_CMF_6,
                    LOT_CMF_7,
                    LOT_CMF_8,
                    LOT_CMF_9,
                    LOT_CMF_10,
                    LOT_CMF_11,
                    LOT_CMF_12,
                    LOT_CMF_13,
                    LOT_CMF_14,
                    LOT_CMF_15,
                    LOT_CMF_16,
                    LOT_CMF_17,
                    LOT_CMF_18,
                    LOT_CMF_19,
                    LOT_CMF_20,
                    LOT_DEL_FLAG,
                    LOT_DEL_CODE,
                    LOT_DEL_TIME,
                    BOM_SET_ID,
                    BOM_SET_VERSION,
                    BOM_ACTIVE_HIST_SEQ,
                    BOM_HIST_SEQ,
                    LAST_TRAN_CODE,
                    LAST_TRAN_TIME,
                    LAST_COMMENT,
                    LAST_ACTIVE_HIST_SEQ,
                    LAST_HIST_SEQ,
                    CRITICAL_RES_ID,
                    CRITICAL_RES_GROUP_ID,
                    SAVE_RES_ID_1,
                    SAVE_RES_ID_2,
                    SUBRES_ID,
                    LOT_GROUP_ID_1,
                    LOT_GROUP_ID_2,
                    LOT_GROUP_ID_3,
                    YIELD_1,
                    YIELD_2,
                    YIELD_3,
                    GOOD_QTY,
                    RESV_FIELD_1,
                    RESV_FIELD_2,
                    RESV_FIELD_3,
                    RESV_FIELD_4,
                    RESV_FIELD_5,
                    RESV_FLAG_1,
                    RESV_FLAG_2,
                    RESV_FLAG_3,
                    RESV_FLAG_4,
                    RESV_FLAG_5
                FROM MWIPLOTSTS
                ORDER BY LOT_ID ASC;
            EXEC SQL OPEN CDB_MWIPLOTSTS_CUR_1;
            break;

		case 100:
            EXEC SQL DECLARE CDB_MWIPLOTSTS_CUR_100 CURSOR FOR
                SELECT X.WORK_DATE SHIP_TIME, 
						X.SYS_DAY ORG_DUE_TIME,
						MAX(X.MDL01_PLAN_EL_QTY)   LOT_ID, 
						MAX(X.MDL01_PLAN_FQC_QTY)  LOT_DESC, 
						MAX(X.MDL01_PLAN_FQC_MW)   FACTORY, 
						MAX(X.MDL01_PLAN_YIELD)    MAT_ID, 
						MAX(X.MDL01_B_PLAN_EL_QTY) FLOW,
						MAX(X.MDL01_B_PLAN_FQC_QTY) OPER,
						MAX(X.MDL01_B_PLAN_FQC_MW) CRR_ID,
						MAX(X.MDL01_B_PLAN_YIELD)  OWNER_CODE, 
						MAX(X.MDL02_PLAN_EL_QTY)   CREATE_CODE, 
						MAX(X.MDL02_PLAN_FQC_QTY)  LOT_STATUS, 
						MAX(X.MDL02_PLAN_FQC_MW)   HOLD_CODE, 
						MAX(X.MDL02_PLAN_YIELD)    HOLD_PASSWORD, 
						MAX(X.MDL02_B_PLAN_EL_QTY) HOLD_PRV_GRP_ID,
						MAX(X.MDL02_B_PLAN_FQC_QTY) INV_UNIT,
						MAX(X.MDL02_B_PLAN_FQC_MW) RWK_CODE,
						MAX(X.MDL02_B_PLAN_YIELD)  RWK_RET_FLOW, 
						MAX(X.MDL03_PLAN_EL_QTY)   RWK_RET_OPER, 
						MAX(X.MDL03_PLAN_FQC_QTY)  RWK_END_FLOW, 
						MAX(X.MDL03_PLAN_FQC_MW)   RWK_END_OPER,  
						MAX(X.MDL03_PLAN_YIELD)    RWK_TIME,  
						MAX(X.MDL03_B_PLAN_EL_QTY) NSTD_RET_FLOW,
						MAX(X.MDL03_B_PLAN_FQC_QTY) NSTD_RET_OPER,
						MAX(X.MDL03_B_PLAN_FQC_MW) NSTD_TIME,
						MAX(X.MDL03_B_PLAN_YIELD)   REP_RET_OPER,
						MAX(X.MDL01_PLAN_EL_QTY) + MAX(X.MDL02_PLAN_EL_QTY) + MAX(X.MDL03_PLAN_EL_QTY) STR_RET_FLOW,
						MAX(X.MDL01_PLAN_FQC_QTY) + MAX(X.MDL02_PLAN_FQC_QTY) + MAX(X.MDL03_PLAN_FQC_QTY) STR_RET_OPER,
						MAX(X.MDL01_PLAN_FQC_MW) + MAX(X.MDL02_PLAN_FQC_MW) + MAX(X.MDL03_PLAN_FQC_MW) START_TIME,
						ROUND(((MAX(X.MDL01_PLAN_YIELD) + MAX(X.MDL02_PLAN_YIELD) + MAX(X.MDL03_PLAN_YIELD))/3),2) START_RES_ID,
						MAX(X.MDL01_B_PLAN_EL_QTY) + MAX(X.MDL02_B_PLAN_EL_QTY) + MAX(X.MDL03_B_PLAN_EL_QTY) END_TIME,
						MAX(X.MDL01_B_PLAN_FQC_QTY) + MAX(X.MDL02_B_PLAN_FQC_QTY) + MAX(X.MDL03_B_PLAN_FQC_QTY) END_RES_ID,
						MAX(X.MDL01_B_PLAN_FQC_MW) + MAX(X.MDL02_B_PLAN_FQC_MW) + MAX(X.MDL03_B_PLAN_FQC_MW) FROM_TO_LOT_ID,
						ROUND(((MAX(X.MDL01_B_PLAN_YIELD) + MAX(X.MDL02_B_PLAN_YIELD) + MAX(X.MDL03_B_PLAN_YIELD))/3),2) SHIP_CODE
						FROM(
						SELECT A.CALENDAR_ID FACTORY, 
						A.SYS_DATE WORK_DATE,
						A.SYS_MONTH,
						A.SYS_DAY,
						B.KEY_2 LINE_ID,
						 DECODE(B.KEY_2, 'MDL01', DECODE(B.DATA_1, ' ', 0,TO_NUMBER(B.DATA_1)), 0) MDL01_PLAN_EL_QTY, 
						 DECODE(B.KEY_2, 'MDL02', DECODE(B.DATA_1, ' ', 0,TO_NUMBER(B.DATA_1)), 0) MDL02_PLAN_EL_QTY, 
						 DECODE(B.KEY_2, 'MDL03', DECODE(B.DATA_1, ' ', 0,TO_NUMBER(B.DATA_1)), 0) MDL03_PLAN_EL_QTY, 
						 DECODE(B.KEY_2, 'MDL01', DECODE(B.DATA_2, ' ', 0,TO_NUMBER(B.DATA_2)), 0) MDL01_PLAN_FQC_QTY, 
						 DECODE(B.KEY_2, 'MDL02', DECODE(B.DATA_2, ' ', 0,TO_NUMBER(B.DATA_2)), 0) MDL02_PLAN_FQC_QTY, 
						 DECODE(B.KEY_2, 'MDL03', DECODE(B.DATA_2, ' ', 0,TO_NUMBER(B.DATA_2)), 0) MDL03_PLAN_FQC_QTY, 
						 DECODE(B.KEY_2, 'MDL01', DECODE(B.DATA_3, ' ', 0,TO_NUMBER(B.DATA_3)), 0) MDL01_PLAN_FQC_MW, 
						 DECODE(B.KEY_2, 'MDL02', DECODE(B.DATA_3, ' ', 0,TO_NUMBER(B.DATA_3)), 0) MDL02_PLAN_FQC_MW, 
						 DECODE(B.KEY_2, 'MDL03', DECODE(B.DATA_3, ' ', 0,TO_NUMBER(B.DATA_3)), 0) MDL03_PLAN_FQC_MW,  
						 DECODE(B.KEY_2, 'MDL01', DECODE(B.DATA_4, ' ', 0,TO_NUMBER(B.DATA_4)), 0) MDL01_PLAN_YIELD, 
						 DECODE(B.KEY_2, 'MDL02', DECODE(B.DATA_4, ' ', 0,TO_NUMBER(B.DATA_4)), 0) MDL02_PLAN_YIELD, 
						 DECODE(B.KEY_2, 'MDL03', DECODE(B.DATA_4, ' ', 0,TO_NUMBER(B.DATA_4)), 0) MDL03_PLAN_YIELD,  
						 DECODE(B.KEY_2, 'MDL01', DECODE(B.DATA_5, ' ', 0,TO_NUMBER(B.DATA_5)), 0) MDL01_B_PLAN_EL_QTY, 
						 DECODE(B.KEY_2, 'MDL02', DECODE(B.DATA_5, ' ', 0,TO_NUMBER(B.DATA_5)), 0) MDL02_B_PLAN_EL_QTY, 
						 DECODE(B.KEY_2, 'MDL03', DECODE(B.DATA_5, ' ', 0,TO_NUMBER(B.DATA_5)), 0) MDL03_B_PLAN_EL_QTY, 
						 DECODE(B.KEY_2, 'MDL01', DECODE(B.DATA_6, ' ', 0,TO_NUMBER(B.DATA_6)), 0) MDL01_B_PLAN_FQC_QTY, 
						 DECODE(B.KEY_2, 'MDL02', DECODE(B.DATA_6, ' ', 0,TO_NUMBER(B.DATA_6)), 0) MDL02_B_PLAN_FQC_QTY, 
						 DECODE(B.KEY_2, 'MDL03', DECODE(B.DATA_6, ' ', 0,TO_NUMBER(B.DATA_6)), 0) MDL03_B_PLAN_FQC_QTY, 
						 DECODE(B.KEY_2, 'MDL01', DECODE(B.DATA_7, ' ', 0,TO_NUMBER(B.DATA_7)), 0) MDL01_B_PLAN_FQC_MW, 
						 DECODE(B.KEY_2, 'MDL02', DECODE(B.DATA_7, ' ', 0,TO_NUMBER(B.DATA_7)), 0) MDL02_B_PLAN_FQC_MW, 
						 DECODE(B.KEY_2, 'MDL03', DECODE(B.DATA_7, ' ', 0,TO_NUMBER(B.DATA_7)), 0) MDL03_B_PLAN_FQC_MW,  
						 DECODE(B.KEY_2, 'MDL01', DECODE(B.DATA_8, ' ', 0,TO_NUMBER(B.DATA_8)), 0) MDL01_B_PLAN_YIELD, 
						 DECODE(B.KEY_2, 'MDL02', DECODE(B.DATA_8, ' ', 0,TO_NUMBER(B.DATA_8)), 0) MDL02_B_PLAN_YIELD, 
						 DECODE(B.KEY_2, 'MDL03', DECODE(B.DATA_8, ' ', 0,TO_NUMBER(B.DATA_8)), 0) MDL03_B_PLAN_YIELD
						FROM MWIPCALDEF A, MGCMTBLDAT B
						WHERE A.CALENDAR_ID = :MWIPLOTSTS_N.FACTORY
						AND SUBSTR(A.SYS_DATE,1,6) = :MWIPLOTSTS_N.LOT_ID
						AND B.TABLE_NAME(+) = '@PLANNING'
						AND A.CALENDAR_ID = B.FACTORY (+)
						AND A.SYS_DATE = B.KEY_1 (+)
						ORDER BY A.SYS_DATE, B.KEY_2) X
						GROUP BY X.WORK_DATE ,X.SYS_DAY
						ORDER BY SYS_DAY;
            EXEC SQL OPEN CDB_MWIPLOTSTS_CUR_100;
            break;

		case 101:
            memset( sql, 0x00, sizeof(sql));
			sprintf(sql , "SELECT FACTORY ");
            sprintf(sql + strlen(sql), ", LOT_ID ");
            sprintf(sql + strlen(sql), ", OPER ");
            sprintf(sql + strlen(sql), ", LOT_CMF_8 ");
            sprintf(sql + strlen(sql), ", MAT_ID ");
            sprintf(sql + strlen(sql), ", LOT_CMF_2 ");
            sprintf(sql + strlen(sql), ", LOT_CMF_6 ");
            sprintf(sql + strlen(sql), ", LOT_CMF_7 ");
            sprintf(sql + strlen(sql), "FROM ( SELECT L.FACTORY   ");                
			sprintf(sql + strlen(sql), ",NVL(L.LOT_ID,' ') AS LOT_ID   ");
			sprintf(sql + strlen(sql), ",NVL(L.OPER,' ')  AS OPER  ");
			sprintf(sql + strlen(sql), ",NVL(D.OPER_DESC,' ')  AS LOT_CMF_8  ");
			sprintf(sql + strlen(sql), ",NVL(L.MAT_ID,' ')     AS MAT_ID "); 
			sprintf(sql + strlen(sql), ",NVL(M.MAT_DESC,' ')  AS LOT_CMF_2 ");
			sprintf(sql + strlen(sql), ",C.GRADE AS LOT_CMF_6");
			sprintf(sql + strlen(sql), ",C.POWER AS LOT_CMF_7 ");
			sprintf(sql + strlen(sql), "FROM MWIPLOTSTS L   ");             
            sprintf(sql + strlen(sql), "INNER JOIN CEDCLOTRLT C ON C.FACTORY = L.FACTORY AND L.LOT_ID = C.LOT_ID AND C.INS_TYPE ='FC' ");
            if(ISSPACE(MWIPLOTSTS->LOT_CMF_6, sizeof(MWIPLOTSTS->LOT_CMF_6)) == DB_FALSE)
			{
				make_valid_quote(ts1, MWIPLOTSTS_N.LOT_CMF_6); /*GRADE*/
				sprintf(sql + strlen(sql), " AND C.GRADE  ='%s' ", ts1);
			}
            if(ISSPACE(MWIPLOTSTS->LOT_CMF_7, sizeof(MWIPLOTSTS->LOT_CMF_7)) == DB_FALSE)
			{
				make_valid_quote(ts1, MWIPLOTSTS_N.LOT_CMF_7); /*POWER*/
				sprintf(sql + strlen(sql), " AND C.POWER  ='%s' ", ts1);
			}
			sprintf(sql + strlen(sql), "INNER JOIN MWIPMATDEF M ON M.FACTORY = L.FACTORY AND C.MAT_ID = M.MAT_ID  AND M.MAT_VER = 1 ");				
			sprintf(sql + strlen(sql), "INNER JOIN MWIPOPRDEF D ON L.FACTORY = D.FACTORY AND L.OPER = D.OPER ");  

             if(ISSPACE(MWIPLOTSTS->FACTORY, sizeof(MWIPLOTSTS->FACTORY)) == DB_FALSE)
			{
                make_valid_quote(ts1, MWIPLOTSTS_N.FACTORY);
			    sprintf(sql + strlen(sql), " WHERE L.FACTORY = '%s' ", ts1);
			}
            sprintf(sql + strlen(sql), " AND L.INV_FLAG  ='Y' ");
			sprintf(sql + strlen(sql), " AND L.HOLD_FLAG  != 'Y' ");
            sprintf(sql + strlen(sql), " AND L.LOT_DEL_FLAG  != 'Y' ");

            if(ISSPACE(MWIPLOTSTS->OPER, sizeof(MWIPLOTSTS->OPER)) == DB_FALSE)
			{
				make_valid_quote(ts1, MWIPLOTSTS_N.OPER);
				sprintf(sql + strlen(sql), " AND L.OPER ='%s' ",ts1);
			}

            sprintf(sql + strlen(sql), " AND NOT EXISTS (SELECT 'X' FROM CWIPLOTPAK P WHERE L.FACTORY = P.FACTORY AND L.LOT_ID = P.LOT_ID AND P.STATUS_FLAG = 'C') ");
            sprintf(sql + strlen(sql), " AND NOT EXISTS (SELECT 'X' FROM CWIPREQDTL A, ");
            sprintf(sql + strlen(sql), " CWIPREQMST B ");
            sprintf(sql + strlen(sql), " WHERE A.FACTORY = L.FACTORY ");
            sprintf(sql + strlen(sql), " AND A.LOT_ID = L.LOT_ID ");
            sprintf(sql + strlen(sql), " AND A.FACTORY = B.FACTORY ");
            sprintf(sql + strlen(sql), " AND A.REQ_NO = B.REQ_NO ");
            sprintf(sql + strlen(sql), " AND B.REQ_STATUS = 'REQUEST')) ");
			sprintf(sql + strlen(sql), " WHERE 1 = 1 ");
            sprintf(sql + strlen(sql), " ORDER BY LOT_ID, MAT_ID, LOT_CMF_6, LOT_CMF_7 ");
				           	
			EXEC SQL PREPARE S FROM :sql;
			EXEC SQL DECLARE CDB_MWIPLOTSTS_CUR_101 CURSOR FOR S; 
			EXEC SQL OPEN CDB_MWIPLOTSTS_CUR_101;    
            /*
			LOG_head("DB");
			LOG_add("len", 0, strlen(sql));
			LOG_add("sql", 4, strlen(sql), sql);
			COM_log_write('I', 'S' , 'S');
            */
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_mwiplotsts", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_mwiplotsts(int sel_type, struct MWIPLOTSTS_TAG *MWIPLOTSTS)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct MWIPLOTSTS_N_TAG MWIPLOTSTS_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_MWIPLOTSTS_CUR_1 INTO
                :MWIPLOTSTS_N.LOT_ID,
                :MWIPLOTSTS_N.LOT_DESC,
                :MWIPLOTSTS_N.FACTORY,
                :MWIPLOTSTS_N.MAT_ID,
                :MWIPLOTSTS_N.MAT_VER,
                :MWIPLOTSTS_N.FLOW,
                :MWIPLOTSTS_N.FLOW_SEQ_NUM,
                :MWIPLOTSTS_N.OPER,
                :MWIPLOTSTS_N.QTY_1,
                :MWIPLOTSTS_N.QTY_2,
                :MWIPLOTSTS_N.QTY_3,
                :MWIPLOTSTS_N.CRR_ID,
                :MWIPLOTSTS_N.LOT_TYPE,
                :MWIPLOTSTS_N.OWNER_CODE,
                :MWIPLOTSTS_N.CREATE_CODE,
                :MWIPLOTSTS_N.LOT_PRIORITY,
                :MWIPLOTSTS_N.LOT_STATUS,
                :MWIPLOTSTS_N.HOLD_FLAG,
                :MWIPLOTSTS_N.HOLD_CODE,
                :MWIPLOTSTS_N.HOLD_PASSWORD,
                :MWIPLOTSTS_N.HOLD_PRV_GRP_ID,
                :MWIPLOTSTS_N.OPER_IN_QTY_1,
                :MWIPLOTSTS_N.OPER_IN_QTY_2,
                :MWIPLOTSTS_N.OPER_IN_QTY_3,
                :MWIPLOTSTS_N.CREATE_QTY_1,
                :MWIPLOTSTS_N.CREATE_QTY_2,
                :MWIPLOTSTS_N.CREATE_QTY_3,
                :MWIPLOTSTS_N.START_QTY_1,
                :MWIPLOTSTS_N.START_QTY_2,
                :MWIPLOTSTS_N.START_QTY_3,
                :MWIPLOTSTS_N.INV_FLAG,
                :MWIPLOTSTS_N.TRANSIT_FLAG,
                :MWIPLOTSTS_N.UNIT_EXIST_FLAG,
                :MWIPLOTSTS_N.INV_UNIT,
                :MWIPLOTSTS_N.RWK_FLAG,
                :MWIPLOTSTS_N.RWK_CODE,
                :MWIPLOTSTS_N.RWK_COUNT,
                :MWIPLOTSTS_N.RWK_RET_FLOW,
                :MWIPLOTSTS_N.RWK_RET_FLOW_SEQ_NUM,
                :MWIPLOTSTS_N.RWK_RET_OPER,
                :MWIPLOTSTS_N.RWK_END_FLOW,
                :MWIPLOTSTS_N.RWK_END_FLOW_SEQ_NUM,
                :MWIPLOTSTS_N.RWK_END_OPER,
                :MWIPLOTSTS_N.RWK_RET_CLEAR_FLAG,
                :MWIPLOTSTS_N.RWK_TIME,
                :MWIPLOTSTS_N.NSTD_FLAG,
                :MWIPLOTSTS_N.NSTD_RET_FLOW,
                :MWIPLOTSTS_N.NSTD_RET_FLOW_SEQ_NUM,
                :MWIPLOTSTS_N.NSTD_RET_OPER,
                :MWIPLOTSTS_N.NSTD_TIME,
                :MWIPLOTSTS_N.REP_FLAG,
                :MWIPLOTSTS_N.REP_RET_OPER,
                :MWIPLOTSTS_N.STR_RET_FLOW,
                :MWIPLOTSTS_N.STR_RET_FLOW_SEQ_NUM,
                :MWIPLOTSTS_N.STR_RET_OPER,
                :MWIPLOTSTS_N.START_FLAG,
                :MWIPLOTSTS_N.START_TIME,
                :MWIPLOTSTS_N.START_RES_ID,
                :MWIPLOTSTS_N.END_FLAG,
                :MWIPLOTSTS_N.END_TIME,
                :MWIPLOTSTS_N.END_RES_ID,
                :MWIPLOTSTS_N.SAMPLE_FLAG,
                :MWIPLOTSTS_N.SAMPLE_WAIT_FLAG,
                :MWIPLOTSTS_N.SAMPLE_RESULT,
                :MWIPLOTSTS_N.FROM_TO_FLAG,
                :MWIPLOTSTS_N.FROM_TO_LOT_ID,
                :MWIPLOTSTS_N.SHIP_CODE,
                :MWIPLOTSTS_N.SHIP_TIME,
                :MWIPLOTSTS_N.ORG_DUE_TIME,
                :MWIPLOTSTS_N.SCH_DUE_TIME,
                :MWIPLOTSTS_N.CREATE_TIME,
                :MWIPLOTSTS_N.FAC_IN_TIME,
                :MWIPLOTSTS_N.FLOW_IN_TIME,
                :MWIPLOTSTS_N.OPER_IN_TIME,
                :MWIPLOTSTS_N.RESERVE_RES_ID,
                :MWIPLOTSTS_N.PORT_ID,
                :MWIPLOTSTS_N.BATCH_ID,
