                :MWIPLOTSTS_N.RESV_FIELD_4,
                :MWIPLOTSTS_N.RESV_FIELD_5,
                :MWIPLOTSTS_N.RESV_FLAG_1,
                :MWIPLOTSTS_N.RESV_FLAG_2,
                :MWIPLOTSTS_N.RESV_FLAG_3,
                :MWIPLOTSTS_N.RESV_FLAG_4,
                :MWIPLOTSTS_N.RESV_FLAG_5;
            break;

		case 100:
            EXEC SQL FETCH CDB_MWIPLOTSTS_CUR_100 INTO
                :MWIPLOTSTS_N.SHIP_TIME,
                :MWIPLOTSTS_N.ORG_DUE_TIME,
                :MWIPLOTSTS_N.LOT_ID,
                :MWIPLOTSTS_N.LOT_DESC,
                :MWIPLOTSTS_N.FACTORY,
                :MWIPLOTSTS_N.MAT_ID,
                :MWIPLOTSTS_N.FLOW,
                :MWIPLOTSTS_N.OPER,
                :MWIPLOTSTS_N.CRR_ID,
                :MWIPLOTSTS_N.OWNER_CODE,
                :MWIPLOTSTS_N.CREATE_CODE,
                :MWIPLOTSTS_N.LOT_STATUS,
                :MWIPLOTSTS_N.HOLD_CODE,
                :MWIPLOTSTS_N.HOLD_PASSWORD,
                :MWIPLOTSTS_N.HOLD_PRV_GRP_ID,
                :MWIPLOTSTS_N.INV_UNIT,
                :MWIPLOTSTS_N.RWK_CODE,
                :MWIPLOTSTS_N.RWK_RET_FLOW,
                :MWIPLOTSTS_N.RWK_RET_OPER,
                :MWIPLOTSTS_N.RWK_END_FLOW,
                :MWIPLOTSTS_N.RWK_END_OPER,
                :MWIPLOTSTS_N.RWK_TIME,
                :MWIPLOTSTS_N.NSTD_RET_FLOW,
                :MWIPLOTSTS_N.NSTD_RET_OPER,
                :MWIPLOTSTS_N.NSTD_TIME,
                :MWIPLOTSTS_N.REP_RET_OPER,
                :MWIPLOTSTS_N.STR_RET_FLOW,
                :MWIPLOTSTS_N.STR_RET_OPER,
                :MWIPLOTSTS_N.START_TIME,
                :MWIPLOTSTS_N.START_RES_ID,
                :MWIPLOTSTS_N.END_TIME,
                :MWIPLOTSTS_N.END_RES_ID,
                :MWIPLOTSTS_N.FROM_TO_LOT_ID,
                :MWIPLOTSTS_N.SHIP_CODE;
            break;

		case 101:
            EXEC SQL FETCH CDB_MWIPLOTSTS_CUR_101 INTO
                :MWIPLOTSTS_N.FACTORY, 
				:MWIPLOTSTS_N.LOT_ID,
				:MWIPLOTSTS_N.OPER,
				:MWIPLOTSTS_N.LOT_CMF_8,
                :MWIPLOTSTS_N.MAT_ID,
                :MWIPLOTSTS_N.LOT_CMF_2,
                :MWIPLOTSTS_N.LOT_CMF_6,
                :MWIPLOTSTS_N.LOT_CMF_7;                
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_mwiplotsts(&MWIPLOTSTS_N, MWIPLOTSTS);
    }

    DB_stop_query_timer("CDB_fetch_mwiplotsts", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_mwiplotsts(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_MWIPLOTSTS_CUR_1;
            break;

		case 100:
            EXEC SQL CLOSE CDB_MWIPLOTSTS_CUR_100;
            break;
	
		case 101:
            EXEC SQL CLOSE CDB_MWIPLOTSTS_CUR_101;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_mwiplotsts", sel_type);
}


/* Initialize Function */
void CDB_init_mwiplotsts(struct MWIPLOTSTS_TAG *MWIPLOTSTS)
{
    /* memset by Space */
    memset(MWIPLOTSTS, ' ', sizeof(struct MWIPLOTSTS_TAG));
    
    MWIPLOTSTS->MAT_VER = 0;
    MWIPLOTSTS->FLOW_SEQ_NUM = 0;
    MWIPLOTSTS->QTY_1 = 0;
    MWIPLOTSTS->QTY_2 = 0;
    MWIPLOTSTS->QTY_3 = 0;
    MWIPLOTSTS->OPER_IN_QTY_1 = 0;
    MWIPLOTSTS->OPER_IN_QTY_2 = 0;
    MWIPLOTSTS->OPER_IN_QTY_3 = 0;
    MWIPLOTSTS->CREATE_QTY_1 = 0;
    MWIPLOTSTS->CREATE_QTY_2 = 0;
    MWIPLOTSTS->CREATE_QTY_3 = 0;
    MWIPLOTSTS->START_QTY_1 = 0;
    MWIPLOTSTS->START_QTY_2 = 0;
    MWIPLOTSTS->START_QTY_3 = 0;
    MWIPLOTSTS->RWK_COUNT = 0;
    MWIPLOTSTS->RWK_RET_FLOW_SEQ_NUM = 0;
    MWIPLOTSTS->RWK_END_FLOW_SEQ_NUM = 0;
    MWIPLOTSTS->NSTD_RET_FLOW_SEQ_NUM = 0;
    MWIPLOTSTS->STR_RET_FLOW_SEQ_NUM = 0;
    MWIPLOTSTS->BATCH_SEQ = 0;
    MWIPLOTSTS->BOM_SET_VERSION = 0;
    MWIPLOTSTS->BOM_ACTIVE_HIST_SEQ = 0;
    MWIPLOTSTS->BOM_HIST_SEQ = 0;
    MWIPLOTSTS->LAST_ACTIVE_HIST_SEQ = 0;
    MWIPLOTSTS->LAST_HIST_SEQ = 0;
    MWIPLOTSTS->YIELD_1 = 0;
    MWIPLOTSTS->YIELD_2 = 0;
    MWIPLOTSTS->YIELD_3 = 0;
    MWIPLOTSTS->GOOD_QTY = 0;
}


