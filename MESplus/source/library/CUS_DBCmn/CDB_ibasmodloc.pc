    MEMCPY_DN(IBASMODLOC->ZIFERNAM, IBASMODLOC_N->ZIFERNAM, sizeof(IBASMODLOC->ZIFERNAM));
    MEMCPY_DN(IBASMODLOC->ZIFDATE, IBASMODLOC_N->ZIFDATE, sizeof(IBASMODLOC->ZIFDATE));
