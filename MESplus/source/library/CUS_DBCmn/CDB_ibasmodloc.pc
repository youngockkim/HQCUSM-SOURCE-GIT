                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IBASMODLOC
				WHERE RETURN_TYPE <> 'E'
                ORDER BY ZIFDATE, ZIFTIME, DOC_ID;
            EXEC SQL OPEN CDB_IBASMODLOC_CUR_2;
            break;


        default:
            DB_error_code = 9999;
