                    RETURN_MSG = :IBASMODLOC_N.RETURN_MSG,
                    ZIFERNAM = :IBASMODLOC_N.ZIFERNAM,
                    ZIFDATE = :IBASMODLOC_N.ZIFDATE,
                    ZIFTIME = :IBASMODLOC_N.ZIFTIME,
                    ZPISTAT = :IBASMODLOC_N.ZPISTAT,
                    ZPIMSG = :IBASMODLOC_N.ZPIMSG
                WHERE DOC_ID = :IBASMODLOC_N.DOC_ID
                    AND SITE_ID = :IBASMODLOC_N.SITE_ID
                    AND LOC_ID = :IBASMODLOC_N.LOC_ID;
            break;

		case 2:
            EXEC SQL UPDATE IBASMODLOC SET                    
                    INF_PROC_TIME = :IBASMODLOC_N.INF_PROC_TIME,                    
                    RETURN_TYPE = 'E',
                    RETURN_MSG = :IBASMODLOC_N.RETURN_MSG
                WHERE DOC_ID = :IBASMODLOC_N.DOC_ID
                    AND SITE_ID = :IBASMODLOC_N.SITE_ID
                    AND LOC_ID = :IBASMODLOC_N.LOC_ID;
            break;

        default:
