    MEMCPY_DN(IBASMODLOC->UPDATE_COUNT, IBASMODLOC_N->UPDATE_COUNT, sizeof(IBASMODLOC->UPDATE_COUNT));
    MEMCPY_DN(IBASMODLOC->INSERT_COUNT, IBASMODLOC_N->INSERT_COUNT, sizeof(IBASMODLOC->INSERT_COUNT));
    MEMCPY_DN(IBASMODLOC->DELETE_COUNT, IBASMODLOC_N->DELETE_COUNT, sizeof(IBASMODLOC->DELETE_COUNT));
    MEMCPY_DN(IBASMODLOC->SQL_DML_COUNT, IBASMODLOC_N->SQL_DML_COUNT, sizeof(IBASMODLOC->SQL_DML_COUNT));
    MEMCPY_DN(IBASMODLOC->ZPICODE, IBASMODLOC_N->ZPICODE, sizeof(IBASMODLOC->ZPICODE));
    MEMCPY_DN(IBASMODLOC->ZPIMSGID, IBASMODLOC_N->ZPIMSGID, sizeof(IBASMODLOC->ZPIMSGID));
    IBASMODLOC->RETURN_TYPE = IBASMODLOC_N->RETURN_TYPE[0];
