    {
        case 1:
            EXEC SQL UPDATE IBASMODLOC SET
                    LOC_NM = :IBASMODLOC_N.LOC_NM,
                    DEL_YN = :IBASMODLOC_N.DEL_YN,
                    INF_TIME = :IBASMODLOC_N.INF_TIME,
                    INF_PROC_TIME = :IBASMODLOC_N.INF_PROC_TIME,
                    CMF_1 = :IBASMODLOC_N.CMF_1,
                    CMF_2 = :IBASMODLOC_N.CMF_2,
                    CMF_3 = :IBASMODLOC_N.CMF_3,
                    CMF_4 = :IBASMODLOC_N.CMF_4,
                    CMF_5 = :IBASMODLOC_N.CMF_5,
                    DATA_FLAG = :IBASMODLOC_N.DATA_FLAG,
                    UPDATE_COUNT = :IBASMODLOC_N.UPDATE_COUNT,
                    INSERT_COUNT = :IBASMODLOC_N.INSERT_COUNT,
                    DELETE_COUNT = :IBASMODLOC_N.DELETE_COUNT,
                    SQL_DML_COUNT = :IBASMODLOC_N.SQL_DML_COUNT,
                    ZPICODE = :IBASMODLOC_N.ZPICODE,
                    ZPIMSGID = :IBASMODLOC_N.ZPIMSGID,
