/* Add Null Function */
void CDB_add_null_ibasmodloc(struct IBASMODLOC_N_TAG *IBASMODLOC_N, struct IBASMODLOC_TAG *IBASMODLOC)
{
    /* memset by NULL */
    memset(IBASMODLOC_N, '\0', sizeof(struct IBASMODLOC_N_TAG));
    
    MEMCPY_AN(IBASMODLOC_N->DOC_ID, IBASMODLOC->DOC_ID, sizeof(IBASMODLOC->DOC_ID));
    MEMCPY_AN(IBASMODLOC_N->SITE_ID, IBASMODLOC->SITE_ID, sizeof(IBASMODLOC->SITE_ID));
    MEMCPY_AN(IBASMODLOC_N->LOC_ID, IBASMODLOC->LOC_ID, sizeof(IBASMODLOC->LOC_ID));
    MEMCPY_AN(IBASMODLOC_N->LOC_NM, IBASMODLOC->LOC_NM, sizeof(IBASMODLOC->LOC_NM));
    IBASMODLOC_N->DEL_YN[0] = IBASMODLOC->DEL_YN;
    MEMCPY_AN(IBASMODLOC_N->INF_TIME, IBASMODLOC->INF_TIME, sizeof(IBASMODLOC->INF_TIME));
    MEMCPY_AN(IBASMODLOC_N->INF_PROC_TIME, IBASMODLOC->INF_PROC_TIME, sizeof(IBASMODLOC->INF_PROC_TIME));
    MEMCPY_AN(IBASMODLOC_N->CMF_1, IBASMODLOC->CMF_1, sizeof(IBASMODLOC->CMF_1));
    MEMCPY_AN(IBASMODLOC_N->CMF_2, IBASMODLOC->CMF_2, sizeof(IBASMODLOC->CMF_2));
    MEMCPY_AN(IBASMODLOC_N->CMF_3, IBASMODLOC->CMF_3, sizeof(IBASMODLOC->CMF_3));
    MEMCPY_AN(IBASMODLOC_N->CMF_4, IBASMODLOC->CMF_4, sizeof(IBASMODLOC->CMF_4));
