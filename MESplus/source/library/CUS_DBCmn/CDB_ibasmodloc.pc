    DB_error_code = 0;


    switch(sel_type)
    {
        
		case 1:
            EXEC SQL DECLARE CDB_IBASMODLOC_CUR_1 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    LOC_ID,
                    LOC_NM,
                    DEL_YN,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5,
                    DATA_FLAG,
                    UPDATE_COUNT,
                    INSERT_COUNT,
                    DELETE_COUNT,
                    SQL_DML_COUNT,
                    ZPICODE,
                    ZPIMSGID,
                    RETURN_TYPE,
                    RETURN_MSG,
                    ZIFERNAM,
                    ZIFDATE,
                    ZIFTIME,
                    ZPISTAT,
                    ZPIMSG
                FROM IBASMODLOC
				ORDER BY DOC_ID ASC,
                    SITE_ID ASC,
                    LOC_ID ASC;
            EXEC SQL OPEN CDB_IBASMODLOC_CUR_1;
            break;
		
		case 2:
            EXEC SQL DECLARE CDB_IBASMODLOC_CUR_2 CURSOR FOR
                SELECT 
                    DOC_ID,
                    SITE_ID,
                    LOC_ID,
                    LOC_NM,
                    DEL_YN,
                    INF_TIME,
                    INF_PROC_TIME,
                    CMF_1,
                    CMF_2,
