/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cwiplotmat(int sel_type, struct CWIPLOTMAT_TAG *CWIPLOTMAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPLOTMAT_N_TAG CWIPLOTMAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cwiplotmat(&CWIPLOTMAT_N, CWIPLOTMAT);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CWIPLOTMAT_CUR_1 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOT_ID,
                    HIST_SEQ,
                    USE_SEQ,
                    RES_ID,
                    POSITION_ID,
                    INV_BARCODE_ID,
                    INV_LOT_ID,
                    INV_MAT_ID,
                    INV_MAT_DESC,
                    MAT_ID,
                    FLOW,
                    OPER,
                    MAT_TYPE,
                    ATTACH_QTY,
                    USED_QTY,
                    REMAIN_QTY,
                    UNIT,
                    DEFAULT_USE_QTY,
                    ATTACH_TIME,
                    ATTACH_USER_ID,
                    INPUT_QTY,
                    TOTAL_USED_QTY,
                    ETC_QTY,
                    MAX_USE_QTY,
                    USE_BATCH_ID,
                    USE_TYPE,
                    MAX_USE_TIME,
                    ORDER_ID,
                    LAST_ACTION,
                    DETACH_TIME,
                    DETACH_USER_ID,
                    LAST_HIST_SEQ,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM CWIPLOTMAT
                ORDER BY FACTORY ASC,
                    LOT_ID ASC,
                    HIST_SEQ ASC,
                    USE_SEQ ASC;
            EXEC SQL OPEN CDB_CWIPLOTMAT_CUR_1;
            break;

		case 2:
            EXEC SQL DECLARE CDB_CWIPLOTMAT_CUR_2 CURSOR FOR
                SELECT 
                    FACTORY,
                    LOT_ID,
                    HIST_SEQ,
                    USE_SEQ,
                    RES_ID,
                    POSITION_ID,
                    INV_BARCODE_ID,
                    INV_LOT_ID,
                    INV_MAT_ID,
                    INV_MAT_DESC,
                    MAT_ID,
                    FLOW,
                    OPER,
                    MAT_TYPE,
                    ATTACH_QTY,
                    USED_QTY,
                    REMAIN_QTY,
                    UNIT,
                    DEFAULT_USE_QTY,
                    ATTACH_TIME,
                    ATTACH_USER_ID,
                    INPUT_QTY,
                    TOTAL_USED_QTY,
                    ETC_QTY,
                    MAX_USE_QTY,
                    USE_BATCH_ID,
                    USE_TYPE,
                    MAX_USE_TIME,
                    ORDER_ID,
                    LAST_ACTION,
                    DETACH_TIME,
                    DETACH_USER_ID,
                    LAST_HIST_SEQ,
                    CMF_1,
                    CMF_2,
                    CMF_3,
                    CMF_4,
                    CMF_5
                FROM CWIPLOTMAT
				WHERE FACTORY = :CWIPLOTMAT_N.FACTORY
                    AND LOT_ID = :CWIPLOTMAT_N.LOT_ID
                ORDER BY FACTORY ASC,
                    LOT_ID ASC,
                    HIST_SEQ ASC,
                    USE_SEQ ASC;
            EXEC SQL OPEN CDB_CWIPLOTMAT_CUR_2;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cwiplotmat", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_cwiplotmat(int sel_type, struct CWIPLOTMAT_TAG *CWIPLOTMAT)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CWIPLOTMAT_N_TAG CWIPLOTMAT_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CWIPLOTMAT_CUR_1 INTO
                :CWIPLOTMAT_N.FACTORY,
                :CWIPLOTMAT_N.LOT_ID,
                :CWIPLOTMAT_N.HIST_SEQ,
                :CWIPLOTMAT_N.USE_SEQ,
                :CWIPLOTMAT_N.RES_ID,
                :CWIPLOTMAT_N.POSITION_ID,
                :CWIPLOTMAT_N.INV_BARCODE_ID,
                :CWIPLOTMAT_N.INV_LOT_ID,
                :CWIPLOTMAT_N.INV_MAT_ID,
                :CWIPLOTMAT_N.INV_MAT_DESC,
                :CWIPLOTMAT_N.MAT_ID,
                :CWIPLOTMAT_N.FLOW,
                :CWIPLOTMAT_N.OPER,
                :CWIPLOTMAT_N.MAT_TYPE,
                :CWIPLOTMAT_N.ATTACH_QTY,
                :CWIPLOTMAT_N.USED_QTY,
                :CWIPLOTMAT_N.REMAIN_QTY,
                :CWIPLOTMAT_N.UNIT,
                :CWIPLOTMAT_N.DEFAULT_USE_QTY,
                :CWIPLOTMAT_N.ATTACH_TIME,
                :CWIPLOTMAT_N.ATTACH_USER_ID,
                :CWIPLOTMAT_N.INPUT_QTY,
                :CWIPLOTMAT_N.TOTAL_USED_QTY,
                :CWIPLOTMAT_N.ETC_QTY,
                :CWIPLOTMAT_N.MAX_USE_QTY,
                :CWIPLOTMAT_N.USE_BATCH_ID,
                :CWIPLOTMAT_N.USE_TYPE,
                :CWIPLOTMAT_N.MAX_USE_TIME,
                :CWIPLOTMAT_N.ORDER_ID,
                :CWIPLOTMAT_N.LAST_ACTION,
                :CWIPLOTMAT_N.DETACH_TIME,
                :CWIPLOTMAT_N.DETACH_USER_ID,
                :CWIPLOTMAT_N.LAST_HIST_SEQ,
                :CWIPLOTMAT_N.CMF_1,
                :CWIPLOTMAT_N.CMF_2,
                :CWIPLOTMAT_N.CMF_3,
                :CWIPLOTMAT_N.CMF_4,
                :CWIPLOTMAT_N.CMF_5;
            break;

		case 2:
            EXEC SQL FETCH CDB_CWIPLOTMAT_CUR_2 INTO
                :CWIPLOTMAT_N.FACTORY,
                :CWIPLOTMAT_N.LOT_ID,
                :CWIPLOTMAT_N.HIST_SEQ,
                :CWIPLOTMAT_N.USE_SEQ,
                :CWIPLOTMAT_N.RES_ID,
                :CWIPLOTMAT_N.POSITION_ID,
                :CWIPLOTMAT_N.INV_BARCODE_ID,
                :CWIPLOTMAT_N.INV_LOT_ID,
                :CWIPLOTMAT_N.INV_MAT_ID,
                :CWIPLOTMAT_N.INV_MAT_DESC,
                :CWIPLOTMAT_N.MAT_ID,
                :CWIPLOTMAT_N.FLOW,
                :CWIPLOTMAT_N.OPER,
                :CWIPLOTMAT_N.MAT_TYPE,
                :CWIPLOTMAT_N.ATTACH_QTY,
                :CWIPLOTMAT_N.USED_QTY,
                :CWIPLOTMAT_N.REMAIN_QTY,
                :CWIPLOTMAT_N.UNIT,
                :CWIPLOTMAT_N.DEFAULT_USE_QTY,
                :CWIPLOTMAT_N.ATTACH_TIME,
                :CWIPLOTMAT_N.ATTACH_USER_ID,
                :CWIPLOTMAT_N.INPUT_QTY,
                :CWIPLOTMAT_N.TOTAL_USED_QTY,
                :CWIPLOTMAT_N.ETC_QTY,
                :CWIPLOTMAT_N.MAX_USE_QTY,
                :CWIPLOTMAT_N.USE_BATCH_ID,
                :CWIPLOTMAT_N.USE_TYPE,
                :CWIPLOTMAT_N.MAX_USE_TIME,
                :CWIPLOTMAT_N.ORDER_ID,
                :CWIPLOTMAT_N.LAST_ACTION,
                :CWIPLOTMAT_N.DETACH_TIME,
                :CWIPLOTMAT_N.DETACH_USER_ID,
                :CWIPLOTMAT_N.LAST_HIST_SEQ,
                :CWIPLOTMAT_N.CMF_1,
                :CWIPLOTMAT_N.CMF_2,
                :CWIPLOTMAT_N.CMF_3,
                :CWIPLOTMAT_N.CMF_4,
                :CWIPLOTMAT_N.CMF_5;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cwiplotmat(&CWIPLOTMAT_N, CWIPLOTMAT);
    }

    DB_stop_query_timer("CDB_fetch_cwiplotmat", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cwiplotmat(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CWIPLOTMAT_CUR_1;
            break;

		case 2:
            EXEC SQL CLOSE CDB_CWIPLOTMAT_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cwiplotmat", sel_type);
}


/* Initialize Function */
void CDB_init_cwiplotmat(struct CWIPLOTMAT_TAG *CWIPLOTMAT)
{
    /* memset by Space */
    memset(CWIPLOTMAT, ' ', sizeof(struct CWIPLOTMAT_TAG));
    
    CWIPLOTMAT->HIST_SEQ = 0;
    CWIPLOTMAT->USE_SEQ = 0;
    CWIPLOTMAT->ATTACH_QTY = 0;
    CWIPLOTMAT->USED_QTY = 0;
    CWIPLOTMAT->REMAIN_QTY = 0;
    CWIPLOTMAT->DEFAULT_USE_QTY = 0;
    CWIPLOTMAT->INPUT_QTY = 0;
    CWIPLOTMAT->TOTAL_USED_QTY = 0;
    CWIPLOTMAT->ETC_QTY = 0;
    CWIPLOTMAT->MAX_USE_QTY = 0;
    CWIPLOTMAT->LAST_HIST_SEQ = 0;
}


/* Add Null Function */
void CDB_add_null_cwiplotmat(struct CWIPLOTMAT_N_TAG *CWIPLOTMAT_N, struct CWIPLOTMAT_TAG *CWIPLOTMAT)
{
    /* memset by NULL */
    memset(CWIPLOTMAT_N, '\0', sizeof(struct CWIPLOTMAT_N_TAG));
    
    MEMCPY_AN(CWIPLOTMAT_N->FACTORY, CWIPLOTMAT->FACTORY, sizeof(CWIPLOTMAT->FACTORY));
    MEMCPY_AN(CWIPLOTMAT_N->LOT_ID, CWIPLOTMAT->LOT_ID, sizeof(CWIPLOTMAT->LOT_ID));
    CWIPLOTMAT_N->HIST_SEQ = CWIPLOTMAT->HIST_SEQ;
    CWIPLOTMAT_N->USE_SEQ = CWIPLOTMAT->USE_SEQ;
    MEMCPY_AN(CWIPLOTMAT_N->RES_ID, CWIPLOTMAT->RES_ID, sizeof(CWIPLOTMAT->RES_ID));
    MEMCPY_AN(CWIPLOTMAT_N->POSITION_ID, CWIPLOTMAT->POSITION_ID, sizeof(CWIPLOTMAT->POSITION_ID));
    MEMCPY_AN(CWIPLOTMAT_N->INV_BARCODE_ID, CWIPLOTMAT->INV_BARCODE_ID, sizeof(CWIPLOTMAT->INV_BARCODE_ID));
    MEMCPY_AN(CWIPLOTMAT_N->INV_LOT_ID, CWIPLOTMAT->INV_LOT_ID, sizeof(CWIPLOTMAT->INV_LOT_ID));
    MEMCPY_AN(CWIPLOTMAT_N->INV_MAT_ID, CWIPLOTMAT->INV_MAT_ID, sizeof(CWIPLOTMAT->INV_MAT_ID));
    MEMCPY_AN(CWIPLOTMAT_N->INV_MAT_DESC, CWIPLOTMAT->INV_MAT_DESC, sizeof(CWIPLOTMAT->INV_MAT_DESC));
    MEMCPY_AN(CWIPLOTMAT_N->MAT_ID, CWIPLOTMAT->MAT_ID, sizeof(CWIPLOTMAT->MAT_ID));
    MEMCPY_AN(CWIPLOTMAT_N->FLOW, CWIPLOTMAT->FLOW, sizeof(CWIPLOTMAT->FLOW));
    MEMCPY_AN(CWIPLOTMAT_N->OPER, CWIPLOTMAT->OPER, sizeof(CWIPLOTMAT->OPER));
    MEMCPY_AN(CWIPLOTMAT_N->MAT_TYPE, CWIPLOTMAT->MAT_TYPE, sizeof(CWIPLOTMAT->MAT_TYPE));
    CWIPLOTMAT_N->ATTACH_QTY = CWIPLOTMAT->ATTACH_QTY;
    CWIPLOTMAT_N->USED_QTY = CWIPLOTMAT->USED_QTY;
    CWIPLOTMAT_N->REMAIN_QTY = CWIPLOTMAT->REMAIN_QTY;
    MEMCPY_AN(CWIPLOTMAT_N->UNIT, CWIPLOTMAT->UNIT, sizeof(CWIPLOTMAT->UNIT));
    CWIPLOTMAT_N->DEFAULT_USE_QTY = CWIPLOTMAT->DEFAULT_USE_QTY;
    MEMCPY_AN(CWIPLOTMAT_N->ATTACH_TIME, CWIPLOTMAT->ATTACH_TIME, sizeof(CWIPLOTMAT->ATTACH_TIME));
    MEMCPY_AN(CWIPLOTMAT_N->ATTACH_USER_ID, CWIPLOTMAT->ATTACH_USER_ID, sizeof(CWIPLOTMAT->ATTACH_USER_ID));
    CWIPLOTMAT_N->INPUT_QTY = CWIPLOTMAT->INPUT_QTY;
    CWIPLOTMAT_N->TOTAL_USED_QTY = CWIPLOTMAT->TOTAL_USED_QTY;
    CWIPLOTMAT_N->ETC_QTY = CWIPLOTMAT->ETC_QTY;
    CWIPLOTMAT_N->MAX_USE_QTY = CWIPLOTMAT->MAX_USE_QTY;
    MEMCPY_AN(CWIPLOTMAT_N->USE_BATCH_ID, CWIPLOTMAT->USE_BATCH_ID, sizeof(CWIPLOTMAT->USE_BATCH_ID));
    MEMCPY_AN(CWIPLOTMAT_N->USE_TYPE, CWIPLOTMAT->USE_TYPE, sizeof(CWIPLOTMAT->USE_TYPE));
    MEMCPY_AN(CWIPLOTMAT_N->MAX_USE_TIME, CWIPLOTMAT->MAX_USE_TIME, sizeof(CWIPLOTMAT->MAX_USE_TIME));
    MEMCPY_AN(CWIPLOTMAT_N->ORDER_ID, CWIPLOTMAT->ORDER_ID, sizeof(CWIPLOTMAT->ORDER_ID));
    MEMCPY_AN(CWIPLOTMAT_N->LAST_ACTION, CWIPLOTMAT->LAST_ACTION, sizeof(CWIPLOTMAT->LAST_ACTION));
    MEMCPY_AN(CWIPLOTMAT_N->DETACH_TIME, CWIPLOTMAT->DETACH_TIME, sizeof(CWIPLOTMAT->DETACH_TIME));
    MEMCPY_AN(CWIPLOTMAT_N->DETACH_USER_ID, CWIPLOTMAT->DETACH_USER_ID, sizeof(CWIPLOTMAT->DETACH_USER_ID));
    CWIPLOTMAT_N->LAST_HIST_SEQ = CWIPLOTMAT->LAST_HIST_SEQ;
    MEMCPY_AN(CWIPLOTMAT_N->CMF_1, CWIPLOTMAT->CMF_1, sizeof(CWIPLOTMAT->CMF_1));
    MEMCPY_AN(CWIPLOTMAT_N->CMF_2, CWIPLOTMAT->CMF_2, sizeof(CWIPLOTMAT->CMF_2));
    MEMCPY_AN(CWIPLOTMAT_N->CMF_3, CWIPLOTMAT->CMF_3, sizeof(CWIPLOTMAT->CMF_3));
    MEMCPY_AN(CWIPLOTMAT_N->CMF_4, CWIPLOTMAT->CMF_4, sizeof(CWIPLOTMAT->CMF_4));
    MEMCPY_AN(CWIPLOTMAT_N->CMF_5, CWIPLOTMAT->CMF_5, sizeof(CWIPLOTMAT->CMF_5));
}


/* Del Null Function */
void CDB_del_null_cwiplotmat(struct CWIPLOTMAT_N_TAG *CWIPLOTMAT_N, struct CWIPLOTMAT_TAG *CWIPLOTMAT)
{
    MEMCPY_DN(CWIPLOTMAT->FACTORY, CWIPLOTMAT_N->FACTORY, sizeof(CWIPLOTMAT->FACTORY));
    MEMCPY_DN(CWIPLOTMAT->LOT_ID, CWIPLOTMAT_N->LOT_ID, sizeof(CWIPLOTMAT->LOT_ID));
    CWIPLOTMAT->HIST_SEQ = CWIPLOTMAT_N->HIST_SEQ;
    CWIPLOTMAT->USE_SEQ = CWIPLOTMAT_N->USE_SEQ;
    MEMCPY_DN(CWIPLOTMAT->RES_ID, CWIPLOTMAT_N->RES_ID, sizeof(CWIPLOTMAT->RES_ID));
    MEMCPY_DN(CWIPLOTMAT->POSITION_ID, CWIPLOTMAT_N->POSITION_ID, sizeof(CWIPLOTMAT->POSITION_ID));
    MEMCPY_DN(CWIPLOTMAT->INV_BARCODE_ID, CWIPLOTMAT_N->INV_BARCODE_ID, sizeof(CWIPLOTMAT->INV_BARCODE_ID));
    MEMCPY_DN(CWIPLOTMAT->INV_LOT_ID, CWIPLOTMAT_N->INV_LOT_ID, sizeof(CWIPLOTMAT->INV_LOT_ID));
    MEMCPY_DN(CWIPLOTMAT->INV_MAT_ID, CWIPLOTMAT_N->INV_MAT_ID, sizeof(CWIPLOTMAT->INV_MAT_ID));
    MEMCPY_DN(CWIPLOTMAT->INV_MAT_DESC, CWIPLOTMAT_N->INV_MAT_DESC, sizeof(CWIPLOTMAT->INV_MAT_DESC));
    MEMCPY_DN(CWIPLOTMAT->MAT_ID, CWIPLOTMAT_N->MAT_ID, sizeof(CWIPLOTMAT->MAT_ID));
    MEMCPY_DN(CWIPLOTMAT->FLOW, CWIPLOTMAT_N->FLOW, sizeof(CWIPLOTMAT->FLOW));
    MEMCPY_DN(CWIPLOTMAT->OPER, CWIPLOTMAT_N->OPER, sizeof(CWIPLOTMAT->OPER));
    MEMCPY_DN(CWIPLOTMAT->MAT_TYPE, CWIPLOTMAT_N->MAT_TYPE, sizeof(CWIPLOTMAT->MAT_TYPE));
    CWIPLOTMAT->ATTACH_QTY = CWIPLOTMAT_N->ATTACH_QTY;
    CWIPLOTMAT->USED_QTY = CWIPLOTMAT_N->USED_QTY;
    CWIPLOTMAT->REMAIN_QTY = CWIPLOTMAT_N->REMAIN_QTY;
    MEMCPY_DN(CWIPLOTMAT->UNIT, CWIPLOTMAT_N->UNIT, sizeof(CWIPLOTMAT->UNIT));
    CWIPLOTMAT->DEFAULT_USE_QTY = CWIPLOTMAT_N->DEFAULT_USE_QTY;
    MEMCPY_DN(CWIPLOTMAT->ATTACH_TIME, CWIPLOTMAT_N->ATTACH_TIME, sizeof(CWIPLOTMAT->ATTACH_TIME));
    MEMCPY_DN(CWIPLOTMAT->ATTACH_USER_ID, CWIPLOTMAT_N->ATTACH_USER_ID, sizeof(CWIPLOTMAT->ATTACH_USER_ID));
    CWIPLOTMAT->INPUT_QTY = CWIPLOTMAT_N->INPUT_QTY;
    CWIPLOTMAT->TOTAL_USED_QTY = CWIPLOTMAT_N->TOTAL_USED_QTY;
    CWIPLOTMAT->ETC_QTY = CWIPLOTMAT_N->ETC_QTY;
    CWIPLOTMAT->MAX_USE_QTY = CWIPLOTMAT_N->MAX_USE_QTY;
    MEMCPY_DN(CWIPLOTMAT->USE_BATCH_ID, CWIPLOTMAT_N->USE_BATCH_ID, sizeof(CWIPLOTMAT->USE_BATCH_ID));
    MEMCPY_DN(CWIPLOTMAT->USE_TYPE, CWIPLOTMAT_N->USE_TYPE, sizeof(CWIPLOTMAT->USE_TYPE));
    MEMCPY_DN(CWIPLOTMAT->MAX_USE_TIME, CWIPLOTMAT_N->MAX_USE_TIME, sizeof(CWIPLOTMAT->MAX_USE_TIME));
    MEMCPY_DN(CWIPLOTMAT->ORDER_ID, CWIPLOTMAT_N->ORDER_ID, sizeof(CWIPLOTMAT->ORDER_ID));
    MEMCPY_DN(CWIPLOTMAT->LAST_ACTION, CWIPLOTMAT_N->LAST_ACTION, sizeof(CWIPLOTMAT->LAST_ACTION));
    MEMCPY_DN(CWIPLOTMAT->DETACH_TIME, CWIPLOTMAT_N->DETACH_TIME, sizeof(CWIPLOTMAT->DETACH_TIME));
    MEMCPY_DN(CWIPLOTMAT->DETACH_USER_ID, CWIPLOTMAT_N->DETACH_USER_ID, sizeof(CWIPLOTMAT->DETACH_USER_ID));
    CWIPLOTMAT->LAST_HIST_SEQ = CWIPLOTMAT_N->LAST_HIST_SEQ;
    MEMCPY_DN(CWIPLOTMAT->CMF_1, CWIPLOTMAT_N->CMF_1, sizeof(CWIPLOTMAT->CMF_1));
    MEMCPY_DN(CWIPLOTMAT->CMF_2, CWIPLOTMAT_N->CMF_2, sizeof(CWIPLOTMAT->CMF_2));
    MEMCPY_DN(CWIPLOTMAT->CMF_3, CWIPLOTMAT_N->CMF_3, sizeof(CWIPLOTMAT->CMF_3));
    MEMCPY_DN(CWIPLOTMAT->CMF_4, CWIPLOTMAT_N->CMF_4, sizeof(CWIPLOTMAT->CMF_4));
    MEMCPY_DN(CWIPLOTMAT->CMF_5, CWIPLOTMAT_N->CMF_5, sizeof(CWIPLOTMAT->CMF_5));
}


