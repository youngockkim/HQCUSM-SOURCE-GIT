    MEMCPY_DN(CALI_JOIN->FACTORY, CALI_JOIN_N->FACTORY, sizeof(CALI_JOIN->FACTORY));
	MEMCPY_DN(CALI_JOIN->PLAN_YEAR, CALI_JOIN_N->PLAN_YEAR, sizeof(CALI_JOIN->PLAN_YEAR));
	MEMCPY_DN(CALI_JOIN->PREV_YEAR, CALI_JOIN_N->PREV_YEAR, sizeof(CALI_JOIN->PREV_YEAR));
    MEMCPY_DN(CALI_JOIN->EQUIP_ID, CALI_JOIN_N->EQUIP_ID, sizeof(CALI_JOIN->EQUIP_ID));
    MEMCPY_DN(CALI_JOIN->RST_PLAN_DATE, CALI_JOIN_N->RST_PLAN_DATE, sizeof(CALI_JOIN->RST_PLAN_DATE));
	MEMCPY_DN(CALI_JOIN->RST_CALI_DATE, CALI_JOIN_N->RST_CALI_DATE, sizeof(CALI_JOIN->RST_CALI_DATE));
    MEMCPY_DN(CALI_JOIN->RST_CALI_RESULT, CALI_JOIN_N->RST_CALI_RESULT, sizeof(CALI_JOIN->RST_CALI_RESULT));
    MEMCPY_DN(CALI_JOIN->PLAN_DATE, CALI_JOIN_N->PLAN_DATE, sizeof(CALI_JOIN->PLAN_DATE));
    MEMCPY_DN(CALI_JOIN->CALI_DATE, CALI_JOIN_N->CALI_DATE, sizeof(CALI_JOIN->CALI_DATE));
    MEMCPY_DN(CALI_JOIN->CALI_RESULT, CALI_JOIN_N->CALI_RESULT, sizeof(CALI_JOIN->CALI_RESULT));    
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_ana_join(int sel_type, struct ANA_JOIN_TAG *ANA_JOIN)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct ANA_JOIN_N_TAG ANA_JOIN_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ana_join(&ANA_JOIN_N, ANA_JOIN);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_ANA_JOIN_CUR_1 CURSOR FOR
				SELECT FACTORY, EQUIP_ID
					  , NVL(CASE WHEN ANA_YEAR = :ANA_JOIN_N.PREV_YEAR AND ANA_DIV = '0' THEN ANA_DATE ELSE NULL END, ' ') RST_VARI_DATE
					  , NVL(CASE WHEN ANA_YEAR = :ANA_JOIN_N.PREV_YEAR AND ANA_DIV = '0' THEN ITEM_CODE||' : '||ROUND(ANA_VALUE, 4) ELSE NULL END, ' ') RST_VARI_VALUES
					  , NVL(CASE WHEN ANA_YEAR = :ANA_JOIN_N.PREV_YEAR AND ANA_DIV = '3' THEN ANA_DATE ELSE NULL END, ' ') RST_LINE_DATE
					  , NVL(CASE WHEN ANA_YEAR = :ANA_JOIN_N.PREV_YEAR AND ANA_DIV = '3' THEN ITEM_CODE||' : '||ROUND(ANA_VALUE, 4) ELSE NULL END, ' ') RST_LINE_VALUES
					  , NVL(CASE WHEN ANA_YEAR = :ANA_JOIN_N.PREV_YEAR AND ANA_DIV = '2' THEN ANA_DATE ELSE NULL END, ' ') RST_BIAS_DATE
					  , NVL(CASE WHEN ANA_YEAR = :ANA_JOIN_N.PREV_YEAR AND ANA_DIV = '2' THEN ITEM_CODE||' : '||ROUND(ANA_VALUE, 4) ELSE NULL END, ' ') RST_BIAS_VALUES
					  , NVL(CASE WHEN ANA_YEAR = :ANA_JOIN_N.PLAN_YEAR AND ANA_DIV = '0' THEN PLAN_DATE ELSE NULL END, ' ') ANA_VARI_PLAN_DATE
					  , NVL(CASE WHEN ANA_YEAR = :ANA_JOIN_N.PLAN_YEAR AND ANA_DIV = '0' THEN ANA_DATE ELSE NULL END, ' ') ANA_VARI_DATE
					  , NVL(CASE WHEN ANA_YEAR = :ANA_JOIN_N.PLAN_YEAR AND ANA_DIV = '0' THEN ITEM_CODE||' : '||ROUND(ANA_VALUE, 4) ELSE NULL END, ' ') ANA_VARI_VALUES
					  , NVL(CASE WHEN ANA_YEAR = :ANA_JOIN_N.PLAN_YEAR AND ANA_DIV = '3' THEN PLAN_DATE ELSE NULL END, ' ') ANA_LINE_PLAN_DATE
					  , NVL(CASE WHEN ANA_YEAR = :ANA_JOIN_N.PLAN_YEAR AND ANA_DIV = '3' THEN ANA_DATE ELSE NULL END, ' ') ANA_LINE_DATE
					  , NVL(CASE WHEN ANA_YEAR = :ANA_JOIN_N.PLAN_YEAR AND ANA_DIV = '3' THEN ITEM_CODE||' : '||ROUND(ANA_VALUE, 4) ELSE NULL END, ' ') ANA_LINE_VALUES
					  , NVL(CASE WHEN ANA_YEAR = :ANA_JOIN_N.PLAN_YEAR AND ANA_DIV = '2' THEN PLAN_DATE ELSE NULL END, ' ') ANA_BIAS_PLAN_DATE
					  , NVL(CASE WHEN ANA_YEAR = :ANA_JOIN_N.PLAN_YEAR AND ANA_DIV = '2' THEN ANA_DATE ELSE NULL END, ' ') ANA_BIAS_DATE
					  , NVL(CASE WHEN ANA_YEAR = :ANA_JOIN_N.PLAN_YEAR AND ANA_DIV = '2' THEN ITEM_CODE||' : '||ROUND(ANA_VALUE, 4) ELSE NULL END, ' ') ANA_BIAS_VALUES
					FROM (
					  SELECT DISTINCT
							APLN.FACTORY,
							APLN.EQUIP_ID,
							APLN.ANA_DIV,         
							APLN.PLAN_DATE, 
							ARST.ANA_DATE,
							SUBSTR(APLN.PLAN_DATE,1,4) ANA_YEAR,            
							ARST.ITEM_CODE,
							ARST.ANA_VALUE,
							ARST.ANA_RESULT
						FROM CMMSANAPLN APLN, CMMSANARST ARST 
					   WHERE APLN.FACTORY = ARST.FACTORY(+)
						 AND APLN.ANA_ID = ARST.ANA_ID(+)
						 AND APLN.FACTORY = :ANA_JOIN_N.FACTORY
						 AND APLN.EQUIP_ID = :ANA_JOIN_N.EQUIP_ID
						 AND SUBSTR(APLN.PLAN_DATE,1,4) IN (:ANA_JOIN_N.PREV_YEAR , :ANA_JOIN_N.PLAN_YEAR)
						) 
					   ORDER BY FACTORY ASC, PLAN_DATE ASC;
			EXEC SQL OPEN CDB_ANA_JOIN_CUR_1;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

	DB_stop_query_timer("CDB_open_ana_join", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_ana_join(int sel_type, struct ANA_JOIN_TAG *ANA_JOIN)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct ANA_JOIN_N_TAG ANA_JOIN_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_ANA_JOIN_CUR_1 INTO
                :ANA_JOIN_N.FACTORY,
				:ANA_JOIN_N.EQUIP_ID,
				:ANA_JOIN_N.RST_VARI_DATE,
				:ANA_JOIN_N.RST_VARI_VALUES,
				:ANA_JOIN_N.RST_LINE_DATE,
				:ANA_JOIN_N.RST_LINE_VALUES,
				:ANA_JOIN_N.RST_BIAS_DATE,
				:ANA_JOIN_N.RST_BIAS_VALUES,
				:ANA_JOIN_N.ANA_VARI_PLAN_DATE,
				:ANA_JOIN_N.ANA_VARI_DATE,
				:ANA_JOIN_N.ANA_VARI_VALUES,
				:ANA_JOIN_N.ANA_LINE_PLAN_DATE,
				:ANA_JOIN_N.ANA_LINE_DATE,
				:ANA_JOIN_N.ANA_LINE_VALUES,
				:ANA_JOIN_N.ANA_BIAS_PLAN_DATE,
				:ANA_JOIN_N.ANA_BIAS_DATE,
				:ANA_JOIN_N.ANA_BIAS_VALUES;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_ana_join(&ANA_JOIN_N, ANA_JOIN);
    }

    DB_stop_query_timer("CDB_fetch_ana_join", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_ana_join(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_ANA_JOIN_CUR_1;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ana_join", sel_type);
}


/* Initialize Function */
void CDB_init_ana_join(struct ANA_JOIN_TAG *ANA_JOIN)
{
    /* memset by Space */
    memset(ANA_JOIN, ' ', sizeof(struct ANA_JOIN_TAG));
    
}

/* Add Null Function */
void CDB_add_null_ana_join(struct ANA_JOIN_N_TAG *ANA_JOIN_N, struct ANA_JOIN_TAG *ANA_JOIN)
{
    /* memset by NULL */
    memset(ANA_JOIN_N, '\0', sizeof(struct ANA_JOIN_N_TAG));
    
    MEMCPY_AN(ANA_JOIN_N->FACTORY, ANA_JOIN->FACTORY, sizeof(ANA_JOIN->FACTORY));
	MEMCPY_AN(ANA_JOIN_N->PLAN_YEAR, ANA_JOIN->PLAN_YEAR, sizeof(ANA_JOIN->PLAN_YEAR));
	MEMCPY_AN(ANA_JOIN_N->PREV_YEAR, ANA_JOIN->PREV_YEAR, sizeof(ANA_JOIN->PREV_YEAR));
    MEMCPY_AN(ANA_JOIN_N->EQUIP_ID, ANA_JOIN->EQUIP_ID, sizeof(ANA_JOIN->EQUIP_ID));
    MEMCPY_AN(ANA_JOIN_N->RST_VARI_DATE, ANA_JOIN->RST_VARI_DATE, sizeof(ANA_JOIN->RST_VARI_DATE));
	MEMCPY_AN(ANA_JOIN_N->RST_VARI_VALUES, ANA_JOIN->RST_VARI_VALUES, sizeof(ANA_JOIN->RST_VARI_VALUES));
    MEMCPY_AN(ANA_JOIN_N->RST_LINE_DATE, ANA_JOIN->RST_LINE_DATE, sizeof(ANA_JOIN->RST_LINE_DATE));
    MEMCPY_AN(ANA_JOIN_N->RST_LINE_VALUES, ANA_JOIN->RST_LINE_VALUES, sizeof(ANA_JOIN->RST_LINE_VALUES));
    MEMCPY_AN(ANA_JOIN_N->RST_BIAS_DATE, ANA_JOIN->RST_BIAS_DATE, sizeof(ANA_JOIN->RST_BIAS_DATE));    
    MEMCPY_AN(ANA_JOIN_N->RST_BIAS_VALUES, ANA_JOIN->RST_BIAS_VALUES, sizeof(ANA_JOIN->RST_BIAS_VALUES));
	MEMCPY_AN(ANA_JOIN_N->ANA_VARI_PLAN_DATE, ANA_JOIN->ANA_VARI_PLAN_DATE, sizeof(ANA_JOIN->ANA_VARI_PLAN_DATE));
	MEMCPY_AN(ANA_JOIN_N->ANA_VARI_DATE, ANA_JOIN->ANA_VARI_DATE, sizeof(ANA_JOIN->ANA_VARI_DATE));
	MEMCPY_AN(ANA_JOIN_N->ANA_VARI_VALUES, ANA_JOIN->ANA_VARI_VALUES, sizeof(ANA_JOIN->ANA_VARI_VALUES));
	MEMCPY_AN(ANA_JOIN_N->ANA_LINE_PLAN_DATE, ANA_JOIN->ANA_LINE_PLAN_DATE, sizeof(ANA_JOIN->ANA_LINE_PLAN_DATE));
    MEMCPY_AN(ANA_JOIN_N->ANA_LINE_DATE, ANA_JOIN->ANA_LINE_DATE, sizeof(ANA_JOIN->ANA_LINE_DATE));
    MEMCPY_AN(ANA_JOIN_N->ANA_LINE_VALUES, ANA_JOIN->ANA_LINE_VALUES, sizeof(ANA_JOIN->ANA_LINE_VALUES));
	MEMCPY_AN(ANA_JOIN_N->ANA_BIAS_PLAN_DATE, ANA_JOIN->ANA_BIAS_PLAN_DATE, sizeof(ANA_JOIN->ANA_BIAS_PLAN_DATE));
    MEMCPY_AN(ANA_JOIN_N->ANA_BIAS_DATE, ANA_JOIN->ANA_BIAS_DATE, sizeof(ANA_JOIN->ANA_BIAS_DATE));    
    MEMCPY_AN(ANA_JOIN_N->ANA_BIAS_VALUES, ANA_JOIN->ANA_BIAS_VALUES, sizeof(ANA_JOIN->ANA_BIAS_VALUES));

}


/* Del Null Function */
void CDB_del_null_ana_join(struct ANA_JOIN_N_TAG *ANA_JOIN_N, struct ANA_JOIN_TAG *ANA_JOIN)
