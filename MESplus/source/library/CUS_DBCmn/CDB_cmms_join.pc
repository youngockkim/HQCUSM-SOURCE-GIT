/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cmms_join(int sel_type, struct CMMS_JOIN_TAG *CMMS_JOIN)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMMS_JOIN_N_TAG CMMS_JOIN_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cmms_join(&CMMS_JOIN_N, CMMS_JOIN);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
			EXEC SQL DECLARE CDB_CMMS_JOIN_CUR_1 CURSOR FOR
				SELECT  
				   FACTORY, 
				   EQUIP_ID, 
				   EQUIP_NAME, 
				   NVL(EQUIP_PLACE_CODE, ' ') AS EQUIP_PLACE_CODE, 
				   NVL(DECODE(MSA_FLAG, 'Y', 'A')||DECODE(SPC_FLAG, 'Y', 'B')||DECODE(CALI_FLAG, 'Y', 'C')||DECODE(CHECK_FLAG, 'Y', 'D')||DECODE(NONE_FLAG, 'Y', 'E')||DECODE(STANDARD_FLAG, 'Y', 'S'), ' ') AS CLASS_IDEN, 
				   MSA_FLAG, 
				   SPC_FLAG, 
				   CALI_FLAG, 
				   CHECK_FLAG, 
				   NONE_FLAG, 
				   STANDARD_FLAG, 
				   CALI_CYCLE, 
				   CALI_DIV, 
				   MSA_CYCLE 
			   FROM CMMSEQPDEF 
			  WHERE FACTORY = :CMMS_JOIN_N.FACTORY
			    AND USE_DIV = TRIM(:CMMS_JOIN_N.USE_DIV)
				AND EQUIP_ID LIKE '%' || TRIM(:CMMS_JOIN_N.EQUIP_ID) || '%'
				AND EQUIP_ID >= :CMMS_JOIN_N.NEXT_EQUIP_ID
				AND EQUIP_TYPE LIKE '%' || TRIM(:CMMS_JOIN_N.EQUIP_TYPE) || '%'
				AND MGT_DEPT_CODE LIKE '%' || TRIM(:CMMS_JOIN_N.MGT_DEPT_CODE) || '%'
				AND EQUIP_PLACE_CODE LIKE '%' || TRIM(:CMMS_JOIN_N.EQUIP_PLACE_CODE) || '%'
				AND MSA_FLAG LIKE '%' || TRIM(:CMMS_JOIN_N.MSA_FLAG) || '%'
				AND SPC_FLAG LIKE '%' || TRIM(:CMMS_JOIN_N.SPC_FLAG) || '%'
				AND CALI_FLAG LIKE '%' || TRIM(:CMMS_JOIN_N.CALI_FLAG) || '%'
				AND CHECK_FLAG LIKE '%' || TRIM(:CMMS_JOIN_N.CHECK_FLAG) || '%'
				AND NONE_FLAG LIKE '%' || TRIM(:CMMS_JOIN_N.NONE_FLAG) || '%'
				AND STANDARD_FLAG LIKE '%' || TRIM(:CMMS_JOIN_N.STANDARD_FLAG) || '%'	
				AND ROWNUM <= 110			
			  ORDER BY EQUIP_ID ASC;
            EXEC SQL OPEN CDB_CMMS_JOIN_CUR_1;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cmms_join", sel_type);
}


