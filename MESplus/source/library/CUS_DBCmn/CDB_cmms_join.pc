/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cali_join(int sel_type, struct CALI_JOIN_TAG *CALI_JOIN)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CALI_JOIN_N_TAG CALI_JOIN_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cali_join(&CALI_JOIN_N, CALI_JOIN);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
			EXEC SQL DECLARE CDB_CALI_JOIN_CUR_1 CURSOR FOR
				SELECT FACTORY, 
					EQUIP_ID, 
					NVL(CASE WHEN CALI_YEAR = :CALI_JOIN_N.PREV_YEAR THEN PLAN_DATE ELSE NULL END, ' ') AS RST_PLAN_DATE,
					NVL(CASE WHEN CALI_YEAR = :CALI_JOIN_N.PREV_YEAR THEN CALI_DATE ELSE NULL END, ' ') AS RST_CALI_DATE,
					NVL(CASE WHEN CALI_YEAR = :CALI_JOIN_N.PREV_YEAR THEN CALI_RESULT ELSE NULL END, ' ') AS RST_CALI_RESULT,
					NVL(CASE WHEN CALI_YEAR = :CALI_JOIN_N.PLAN_YEAR THEN PLAN_DATE ELSE NULL END, ' ') AS PLAN_DATE,
					NVL(CASE WHEN CALI_YEAR = :CALI_JOIN_N.PLAN_YEAR THEN CALI_DATE ELSE NULL END, ' ') AS CALI_DATE,
					NVL(CASE WHEN CALI_YEAR = :CALI_JOIN_N.PLAN_YEAR THEN CALI_RESULT ELSE NULL END, ' ') AS CALI_RESULT
				FROM ( SELECT DISTINCT FACTORY, 
							EQUIP_ID, 
							CRST.PLAN_DATE,
							CRST.CALI_DATE,
							SUBSTR(CRST.PLAN_DATE,1,4) AS CALI_YEAR,
							(CASE WHEN CRST.CALI_RESULT = 'P' THEN 'Pass' ELSE 'Fail' END) AS CALI_RESULT
						FROM CMMSCALRST CRST
						WHERE CRST.FACTORY = :CALI_JOIN_N.FACTORY
						AND CRST.EQUIP_ID = :CALI_JOIN_N.EQUIP_ID
						AND SUBSTR(NVL(TRIM(CRST.PLAN_DATE),'0000'),1,4) IN (:CALI_JOIN_N.PREV_YEAR , :CALI_JOIN_N.PLAN_YEAR)
						UNION ALL
					SELECT DISTINCT FACTORY, 
							EQUIP_ID, 
							CPLN.PLAN_DATE,
							NULL CALI_DATE,
							SUBSTR(CPLN.PLAN_DATE,1,4) AS CALI_YEAR,
							NULL CALI_RESULT
						FROM CMMSCALPLN CPLN
						WHERE CPLN.FACTORY = :CALI_JOIN_N.FACTORY
						AND CPLN.EQUIP_ID = :CALI_JOIN_N.EQUIP_ID
						AND SUBSTR(NVL(TRIM(CPLN.PLAN_DATE),'0000'),1,4) IN (:CALI_JOIN_N.PREV_YEAR , :CALI_JOIN_N.PLAN_YEAR)
					)
				ORDER BY FACTORY ASC, EQUIP_ID ASC, PLAN_DATE ASC;
			EXEC SQL OPEN CDB_CALI_JOIN_CUR_1;
            break;

		case 2:
			EXEC SQL DECLARE CDB_CALI_JOIN_CUR_2 CURSOR FOR
				SELECT FACTORY, 
					EQUIP_ID, 
					NVL(CASE WHEN CALI_YEAR = :CALI_JOIN_N.PREV_YEAR THEN PLAN_DATE ELSE NULL END, ' ') AS RST_PLAN_DATE,
					NVL(CASE WHEN CALI_YEAR = :CALI_JOIN_N.PREV_YEAR THEN CALI_DATE ELSE NULL END, ' ') AS RST_CALI_DATE,
					NVL(CASE WHEN CALI_YEAR = :CALI_JOIN_N.PREV_YEAR THEN CALI_RESULT ELSE NULL END, ' ') AS RST_CALI_RESULT,
					NVL(CASE WHEN CALI_YEAR = :CALI_JOIN_N.PLAN_YEAR THEN PLAN_DATE ELSE NULL END, ' ') AS PLAN_DATE,
					NVL(CASE WHEN CALI_YEAR = :CALI_JOIN_N.PLAN_YEAR THEN CALI_DATE ELSE NULL END, ' ') AS CALI_DATE,
					NVL(CASE WHEN CALI_YEAR = :CALI_JOIN_N.PLAN_YEAR THEN CALI_RESULT ELSE NULL END, ' ') AS CALI_RESULT
				FROM ( SELECT DISTINCT FACTORY, 
							EQUIP_ID, 
							(TO_CHAR(TO_DATE(CRST.PLAN_DATE,'YYYYMMDD'), 'YYYY-MM-DD')) AS PLAN_DATE,
							(TO_CHAR(TO_DATE(CRST.CALI_DATE,'YYYYMMDD'), 'YYYY-MM-DD')) AS CALI_DATE,
							(TO_CHAR(TO_DATE(CRST.PLAN_DATE,'YYYYMMDD'), 'YYYY')) AS CALI_YEAR,
							(CASE WHEN CRST.CALI_RESULT = 'P' THEN 'Pass' ELSE 'Fail' END) AS CALI_RESULT
						FROM CMMSCALRST CRST
						WHERE CRST.FACTORY = :CALI_JOIN_N.FACTORY
						AND CRST.EQUIP_ID = :CALI_JOIN_N.EQUIP_ID
						AND SUBSTR(NVL(TRIM(CRST.PLAN_DATE),'0000'),1,4) IN (:CALI_JOIN_N.PREV_YEAR , :CALI_JOIN_N.PLAN_YEAR)
						UNION ALL
					SELECT DISTINCT FACTORY, 
							EQUIP_ID, 
							TO_CHAR(TO_DATE(CPLN.PLAN_DATE,'YYYYMMDD'), 'YYYY-MM-DD') PLAN_DATE,
							NULL CALI_DATE,
							TO_CHAR(TO_DATE(CPLN.PLAN_DATE,'YYYYMMDD'), 'YYYY') CALI_YEAR,
							NULL CALI_RESULT
						FROM CMMSCALPLN CPLN
						WHERE CPLN.FACTORY = :CALI_JOIN_N.FACTORY
						AND CPLN.EQUIP_ID = :CALI_JOIN_N.EQUIP_ID
						AND SUBSTR(NVL(TRIM(CPLN.PLAN_DATE),'0000'),1,4) IN (:CALI_JOIN_N.PREV_YEAR , :CALI_JOIN_N.PLAN_YEAR)
					)
				ORDER BY FACTORY ASC, EQUIP_ID ASC, PLAN_DATE ASC;
			EXEC SQL OPEN CDB_CALI_JOIN_CUR_2;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

	DB_stop_query_timer("CDB_open_cali_join", sel_type);
}


