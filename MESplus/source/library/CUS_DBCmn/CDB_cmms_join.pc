    MEMCPY_DN(ANA_JOIN->RST_LINE_VALUES, ANA_JOIN_N->RST_LINE_VALUES, sizeof(ANA_JOIN->RST_LINE_VALUES));
    MEMCPY_DN(ANA_JOIN->RST_BIAS_DATE, ANA_JOIN_N->RST_BIAS_DATE, sizeof(ANA_JOIN->RST_BIAS_DATE));    
    MEMCPY_DN(ANA_JOIN->RST_BIAS_VALUES, ANA_JOIN_N->RST_BIAS_VALUES, sizeof(ANA_JOIN->RST_BIAS_VALUES));
	MEMCPY_DN(ANA_JOIN->ANA_VARI_PLAN_DATE, ANA_JOIN_N->ANA_VARI_PLAN_DATE, sizeof(ANA_JOIN->ANA_VARI_PLAN_DATE));
	MEMCPY_DN(ANA_JOIN->ANA_VARI_DATE, ANA_JOIN_N->ANA_VARI_DATE, sizeof(ANA_JOIN->ANA_VARI_DATE));
	MEMCPY_DN(ANA_JOIN->ANA_VARI_VALUES, ANA_JOIN_N->ANA_VARI_VALUES, sizeof(ANA_JOIN->ANA_VARI_VALUES));
	MEMCPY_DN(ANA_JOIN->ANA_LINE_PLAN_DATE, ANA_JOIN_N->ANA_LINE_PLAN_DATE, sizeof(ANA_JOIN->ANA_LINE_PLAN_DATE));
    MEMCPY_DN(ANA_JOIN->ANA_LINE_DATE, ANA_JOIN_N->ANA_LINE_DATE, sizeof(ANA_JOIN->ANA_LINE_DATE));
    MEMCPY_DN(ANA_JOIN->ANA_LINE_VALUES, ANA_JOIN_N->ANA_LINE_VALUES, sizeof(ANA_JOIN->ANA_LINE_VALUES));
	MEMCPY_DN(ANA_JOIN->ANA_BIAS_PLAN_DATE, ANA_JOIN_N->ANA_BIAS_PLAN_DATE, sizeof(ANA_JOIN->ANA_BIAS_PLAN_DATE));
    MEMCPY_DN(ANA_JOIN->ANA_BIAS_DATE, ANA_JOIN_N->ANA_BIAS_DATE, sizeof(ANA_JOIN->ANA_BIAS_DATE));    
    MEMCPY_DN(ANA_JOIN->ANA_BIAS_VALUES, ANA_JOIN_N->ANA_BIAS_VALUES, sizeof(ANA_JOIN->ANA_BIAS_VALUES));  
}

/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_ana_result_join(int sel_type, struct ANA_RST_TAG *ANA_RST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct ANA_RST_N_TAG ANA_RST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_ana_result_join(&ANA_RST_N, ANA_RST);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
			EXEC SQL DECLARE CDB_ANA_RST_CUR_1 CURSOR FOR
				SELECT A.FACTORY
					 , A.ANA_ID
					 , A.EQUIP_ID
					 , B.EQUIP_NAME
					 , A.PLAN_DATE
					 , D.ANA_DATE
					 , D.ANA_RESULT
					 , A.SAMPLE_CODE
					 , A.USER_COUNT
					 , A.SAMPLE_COUNT
					 , A.REPEAT_COUNT
					 , C.ITEM_CODE
					 , C.ITEM_NAME
					 , C.LSL
					 , C.USL
					 , C.UNIT_CODE
					 , C.DECIMAL_PLACE
					 , A.CREATE_TIME
					 , A.CREATE_USER_ID
					 , A.UPDATE_TIME
					 , A.UPDATE_USER_ID
				  FROM CMMSANAPLN A
					 , CMMSEQPDEF B
					 , CMMSANAITM C
					 , CMMSANARST D
				  WHERE A.FACTORY = B.FACTORY
					AND A.EQUIP_ID = B.EQUIP_ID
					AND A.FACTORY = C.FACTORY
					AND A.ANA_ID = C.ANA_ID
					AND A.FACTORY = D.FACTORY
					AND A.ANA_ID = D.ANA_ID
					AND C.ITEM_CODE = D.ITEM_CODE
					AND A.FACTORY = :ANA_RST_N.FACTORY
					AND A.ANA_DIV = :ANA_RST_N.ANA_DIV
					AND A.PLAN_DATE BETWEEN :ANA_RST_N.PLAN_DATE AND :ANA_RST_N.ANA_DATE
					AND A.ANA_STATUS != '0'
					AND A.EQUIP_ID LIKE '%' || TRIM(:ANA_RST_N.EQUIP_ID) || '%'
					AND B.MGT_DEPT_CODE LIKE '%' || TRIM(:ANA_RST_N.EQUIP_ID) || '%'
				  ORDER BY A.FACTORY ASC, A.EQUIP_ID ASC, A.PLAN_DATE ASC;
            EXEC SQL OPEN CDB_ANA_RST_CUR_1;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_ana_result_join", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_ana_result_join(int sel_type, struct ANA_RST_TAG *ANA_RST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct ANA_RST_N_TAG ANA_RST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_ANA_RST_CUR_1 INTO
                :ANA_RST_N.FACTORY,
				:ANA_RST_N.ANA_ID,
				:ANA_RST_N.EQUIP_ID,
				:ANA_RST_N.EQUIP_NAME,
				:ANA_RST_N.PLAN_DATE,
				:ANA_RST_N.ANA_DATE,
				:ANA_RST_N.ANA_RESULT,
				:ANA_RST_N.SAMPLE_CODE,
				:ANA_RST_N.USER_COUNT,
				:ANA_RST_N.SAMPLE_COUNT,
				:ANA_RST_N.REPEAT_COUNT,
				:ANA_RST_N.ITEM_CODE,
				:ANA_RST_N.ITEM_NAME,
				:ANA_RST_N.LSL,
				:ANA_RST_N.USL,
				:ANA_RST_N.UNIT_CODE,
				:ANA_RST_N.DECIMAL_PLACE,
				:ANA_RST_N.CREATE_TIME,
				:ANA_RST_N.CREATE_USER_ID,
				:ANA_RST_N.UPDATE_TIME,
				:ANA_RST_N.UPDATE_USER_ID;
            break;
			
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_ana_result_join(&ANA_RST_N, ANA_RST);
    }

    DB_stop_query_timer("CDB_fetch_ana_result_join", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_ana_result_join(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_ANA_RST_CUR_1;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_ana_result_join", sel_type);
}


/* Initialize Function */
void CDB_init_ana_result_join(struct ANA_RST_TAG *ANA_RST)
{
    /* memset by Space */
    memset(ANA_RST, ' ', sizeof(struct ANA_RST_TAG));
    
    ANA_RST->USER_COUNT = 0;
	ANA_RST->SAMPLE_COUNT = 0;
	ANA_RST->REPEAT_COUNT = 0;
	ANA_RST->LSL = 0;
	ANA_RST->USL = 0;
	ANA_RST->DECIMAL_PLACE = 0;

}


/* Add Null Function */
void CDB_add_null_ana_result_join(struct ANA_RST_N_TAG *ANA_RST_N, struct ANA_RST_TAG *ANA_RST)
{
    /* memset by NULL */
    memset(ANA_RST_N, '\0', sizeof(struct ANA_RST_N_TAG));
    
    MEMCPY_AN(ANA_RST_N->FACTORY, ANA_RST->FACTORY, sizeof(ANA_RST->FACTORY));
	MEMCPY_AN(ANA_RST_N->ANA_ID, ANA_RST->ANA_ID, sizeof(ANA_RST->ANA_ID));
	MEMCPY_AN(ANA_RST_N->EQUIP_ID, ANA_RST->EQUIP_ID, sizeof(ANA_RST->EQUIP_ID));
	MEMCPY_AN(ANA_RST_N->EQUIP_NAME, ANA_RST->EQUIP_NAME, sizeof(ANA_RST->EQUIP_NAME));
	MEMCPY_AN(ANA_RST_N->MGT_DEPT_CODE, ANA_RST->MGT_DEPT_CODE, sizeof(ANA_RST->MGT_DEPT_CODE));
	MEMCPY_AN(ANA_RST_N->PLAN_DATE, ANA_RST->PLAN_DATE, sizeof(ANA_RST->PLAN_DATE));
	MEMCPY_AN(ANA_RST_N->ANA_DATE, ANA_RST->ANA_DATE, sizeof(ANA_RST->ANA_DATE));
	MEMCPY_AN(ANA_RST_N->ANA_STATUS, ANA_RST->ANA_STATUS, sizeof(ANA_RST->ANA_STATUS));
	MEMCPY_AN(ANA_RST_N->SAMPLE_CODE, ANA_RST->SAMPLE_CODE, sizeof(ANA_RST->SAMPLE_CODE));
	MEMCPY_AN(ANA_RST_N->ITEM_CODE, ANA_RST->ITEM_CODE, sizeof(ANA_RST->ITEM_CODE));
	MEMCPY_AN(ANA_RST_N->ITEM_NAME, ANA_RST->ITEM_NAME, sizeof(ANA_RST->ITEM_NAME));
	MEMCPY_AN(ANA_RST_N->UNIT_CODE, ANA_RST->UNIT_CODE, sizeof(ANA_RST->UNIT_CODE));
	MEMCPY_AN(ANA_RST_N->CREATE_TIME, ANA_RST->CREATE_TIME, sizeof(ANA_RST->CREATE_TIME));
	MEMCPY_AN(ANA_RST_N->CREATE_USER_ID, ANA_RST->CREATE_USER_ID, sizeof(ANA_RST->CREATE_USER_ID));
	MEMCPY_AN(ANA_RST_N->UPDATE_TIME, ANA_RST->UPDATE_TIME, sizeof(ANA_RST->UPDATE_TIME));
	MEMCPY_AN(ANA_RST_N->UPDATE_USER_ID, ANA_RST->UPDATE_USER_ID, sizeof(ANA_RST->UPDATE_USER_ID));
	ANA_RST_N->ANA_DIV[0] = ANA_RST->ANA_DIV;
    ANA_RST_N->ANA_RESULT[0] = ANA_RST->ANA_RESULT;
	ANA_RST_N->USER_COUNT = ANA_RST->USER_COUNT;	
	ANA_RST_N->SAMPLE_COUNT = ANA_RST->SAMPLE_COUNT;
	ANA_RST_N->REPEAT_COUNT = ANA_RST->REPEAT_COUNT;	
	ANA_RST_N->LSL = ANA_RST->LSL;
	ANA_RST_N->USL = ANA_RST->USL;	
	ANA_RST_N->DECIMAL_PLACE = ANA_RST->DECIMAL_PLACE;
}


/* Del Null Function */
void CDB_del_null_ana_result_join(struct ANA_RST_N_TAG *ANA_RST_N, struct ANA_RST_TAG *ANA_RST)
{
    MEMCPY_DN(ANA_RST->FACTORY, ANA_RST_N->FACTORY, sizeof(ANA_RST->FACTORY));
	MEMCPY_DN(ANA_RST->ANA_ID, ANA_RST_N->ANA_ID, sizeof(ANA_RST->ANA_ID));
	MEMCPY_DN(ANA_RST->EQUIP_ID, ANA_RST_N->EQUIP_ID, sizeof(ANA_RST->EQUIP_ID));
	MEMCPY_DN(ANA_RST->EQUIP_NAME, ANA_RST_N->EQUIP_NAME, sizeof(ANA_RST->EQUIP_NAME));
	MEMCPY_DN(ANA_RST->MGT_DEPT_CODE, ANA_RST_N->MGT_DEPT_CODE, sizeof(ANA_RST->MGT_DEPT_CODE));
	MEMCPY_DN(ANA_RST->PLAN_DATE, ANA_RST_N->PLAN_DATE, sizeof(ANA_RST->PLAN_DATE));
	MEMCPY_DN(ANA_RST->ANA_DATE, ANA_RST_N->ANA_DATE, sizeof(ANA_RST->ANA_DATE));
	MEMCPY_DN(ANA_RST->ANA_STATUS, ANA_RST_N->ANA_STATUS, sizeof(ANA_RST->ANA_STATUS));
	MEMCPY_DN(ANA_RST->SAMPLE_CODE, ANA_RST_N->SAMPLE_CODE, sizeof(ANA_RST->SAMPLE_CODE));
	MEMCPY_DN(ANA_RST->ITEM_CODE, ANA_RST_N->ITEM_CODE, sizeof(ANA_RST->ITEM_CODE));
	MEMCPY_DN(ANA_RST->ITEM_NAME, ANA_RST_N->ITEM_NAME, sizeof(ANA_RST->ITEM_NAME));
	MEMCPY_DN(ANA_RST->UNIT_CODE, ANA_RST_N->UNIT_CODE, sizeof(ANA_RST->UNIT_CODE));
	MEMCPY_DN(ANA_RST->CREATE_TIME, ANA_RST_N->CREATE_TIME, sizeof(ANA_RST->CREATE_TIME));
	MEMCPY_DN(ANA_RST->CREATE_USER_ID, ANA_RST_N->CREATE_USER_ID, sizeof(ANA_RST->CREATE_USER_ID));
	MEMCPY_DN(ANA_RST->UPDATE_TIME, ANA_RST_N->UPDATE_TIME, sizeof(ANA_RST->UPDATE_TIME));
	MEMCPY_DN(ANA_RST->UPDATE_USER_ID, ANA_RST_N->UPDATE_USER_ID, sizeof(ANA_RST->UPDATE_USER_ID));	
	ANA_RST->ANA_DIV = ANA_RST_N->ANA_DIV[0];
	ANA_RST->ANA_RESULT = ANA_RST_N->ANA_RESULT[0];	
	ANA_RST->USER_COUNT = ANA_RST_N->USER_COUNT;
	ANA_RST->SAMPLE_COUNT = ANA_RST_N->SAMPLE_COUNT;
	ANA_RST->REPEAT_COUNT = ANA_RST_N->REPEAT_COUNT;
	ANA_RST->LSL = ANA_RST_N->LSL;
	ANA_RST->USL = ANA_RST_N->USL;
	ANA_RST->DECIMAL_PLACE = ANA_RST_N->DECIMAL_PLACE;
}


/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_attributes_join(int sel_type, struct ATTRIBUTES_TAG *ATTRIBUTES)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct ATTRIBUTES_N_TAG ATTRIBUTES_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_attributes_join(&ATTRIBUTES_N, ATTRIBUTES);
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
			EXEC SQL DECLARE CDB_ATTRIBUTES_CUR_1 CURSOR FOR
				SELECT VAL.FACTORY
                     , VAL.ANA_ID
                     , VAL.ITEM_CODE
                     , VAL.USER_SEQ
                     , USR.USER_ID
                     , SUM(CASE WHEN VAL.BASE_VALUE = '1' THEN VAL.BAD_COUNT ELSE 0 END) GOOD_CORRECT  
                     , SUM(CASE WHEN VAL.BASE_VALUE = '0' THEN VAL.GOOD_COUNT ELSE 0 END) BAD_CORRECT   
                     , SUM(CASE WHEN VAL.BASE_VALUE = '1' THEN VAL.GOOD_COUNT ELSE 0 END) NUMBER_FLASE          
                     , SUM(CASE WHEN VAL.BASE_VALUE = '0' THEN VAL.BAD_COUNT ELSE 0 END) NUMBER_MISS 
                  FROM (SELECT A.FACTORY
                              , A.ANA_ID
                              , A.ITEM_CODE
                              , A.USER_SEQ
                              , A.SAMPLE_SEQ 
                              , B.VALUE AS BASE_VALUE
                              , SUM(CASE WHEN A.VALUE = 0 THEN 1 ELSE 0 END) GOOD_COUNT
                              , SUM(CASE WHEN A.VALUE = 0 THEN 0 ELSE 1 END) BAD_COUNT               
                           FROM CMMSANADAT A 
                              , CMMSANAVAL B
                         WHERE A.FACTORY = B.FACTORY
                           AND A.ANA_ID = B.ANA_ID 
                           AND A.ITEM_CODE = B.ITEM_CODE
                           AND A.SAMPLE_SEQ = B.VAL_SEQ
                           AND A.FACTORY = :ATTRIBUTES_N.FACTORY
                           AND A.ANA_ID = :ATTRIBUTES_N.ANA_ID
                           AND A.ITEM_CODE = :ATTRIBUTES_N.ITEM_CODE
                         GROUP BY A.FACTORY
                              , A.ANA_ID
                              , A.ITEM_CODE
                              , A.USER_SEQ
                              , A.SAMPLE_SEQ
                              , B.VALUE) VAL
                      , CMMSANAUSR USR 
                  WHERE VAL.FACTORY = USR.FACTORY 
                    AND VAL.ANA_ID = USR.ANA_ID
                    AND VAL.USER_SEQ = USR.USER_SEQ
                   GROUP BY VAL.FACTORY
                        , VAL.ANA_ID
                        , VAL.ITEM_CODE
                        , VAL.USER_SEQ 
                        , USR.USER_ID
                   ORDER BY VAL.FACTORY
                        , VAL.ANA_ID
                        , VAL.ITEM_CODE
                        , VAL.USER_SEQ;
            EXEC SQL OPEN CDB_ATTRIBUTES_CUR_1;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_attributes_join", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_attributes_join(int sel_type, struct ATTRIBUTES_TAG *ATTRIBUTES)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct ATTRIBUTES_N_TAG ATTRIBUTES_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_ATTRIBUTES_CUR_1 INTO
                :ATTRIBUTES_N.FACTORY,
				:ATTRIBUTES_N.ANA_ID,
				:ATTRIBUTES_N.ITEM_CODE,
				:ATTRIBUTES_N.USER_SEQ,
				:ATTRIBUTES_N.USER_ID,
				:ATTRIBUTES_N.GOOD_CORRECT,
				:ATTRIBUTES_N.BAD_CORRECT,
				:ATTRIBUTES_N.NUMBER_FLASE,
				:ATTRIBUTES_N.NUMBER_MISS;
            break;
			
        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_attributes_join(&ATTRIBUTES_N, ATTRIBUTES);
    }

    DB_stop_query_timer("CDB_fetch_attributes_join", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_attributes_join(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_ATTRIBUTES_CUR_1;
            break;

        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_attributes_join", sel_type);
}


/* Initialize Function */
void CDB_init_attributes_join(struct ATTRIBUTES_TAG *ATTRIBUTES)
{
    /* memset by Space */
    memset(ATTRIBUTES, ' ', sizeof(struct ATTRIBUTES_TAG));
    
    ATTRIBUTES->USER_SEQ = 0;
	ATTRIBUTES->GOOD_CORRECT = 0;
	ATTRIBUTES->BAD_CORRECT = 0;
	ATTRIBUTES->NUMBER_FLASE = 0;
	ATTRIBUTES->NUMBER_MISS = 0;
}


/* Add Null Function */
void CDB_add_null_attributes_join(struct ATTRIBUTES_N_TAG *ATTRIBUTES_N, struct ATTRIBUTES_TAG *ATTRIBUTES)
{
    /* memset by NULL */
    memset(ATTRIBUTES_N, '\0', sizeof(struct ATTRIBUTES_N_TAG));
    
    MEMCPY_AN(ATTRIBUTES_N->FACTORY, ATTRIBUTES->FACTORY, sizeof(ATTRIBUTES->FACTORY));
	MEMCPY_AN(ATTRIBUTES_N->ANA_ID, ATTRIBUTES->ANA_ID, sizeof(ATTRIBUTES->ANA_ID));
	MEMCPY_AN(ATTRIBUTES_N->ITEM_CODE, ATTRIBUTES->ITEM_CODE, sizeof(ATTRIBUTES->ITEM_CODE));
	MEMCPY_AN(ATTRIBUTES_N->USER_ID, ATTRIBUTES->USER_ID, sizeof(ATTRIBUTES->USER_ID));
	ATTRIBUTES_N->USER_SEQ = ATTRIBUTES->USER_SEQ;	
	ATTRIBUTES_N->GOOD_CORRECT = ATTRIBUTES->GOOD_CORRECT;
	ATTRIBUTES_N->BAD_CORRECT = ATTRIBUTES->BAD_CORRECT;	
	ATTRIBUTES_N->NUMBER_FLASE = ATTRIBUTES->NUMBER_FLASE;
	ATTRIBUTES_N->NUMBER_MISS = ATTRIBUTES->NUMBER_MISS;	
}


/* Del Null Function */
void CDB_del_null_attributes_join(struct ATTRIBUTES_N_TAG *ATTRIBUTES_N, struct ATTRIBUTES_TAG *ATTRIBUTES)
{
    MEMCPY_DN(ATTRIBUTES->FACTORY, ATTRIBUTES_N->FACTORY, sizeof(ATTRIBUTES->FACTORY));
	MEMCPY_DN(ATTRIBUTES->ANA_ID, ATTRIBUTES_N->ANA_ID, sizeof(ATTRIBUTES->ANA_ID));
	MEMCPY_DN(ATTRIBUTES->ITEM_CODE, ATTRIBUTES_N->ITEM_CODE, sizeof(ATTRIBUTES->ITEM_CODE));
	MEMCPY_DN(ATTRIBUTES->USER_ID, ATTRIBUTES_N->USER_ID, sizeof(ATTRIBUTES->USER_ID));
	ATTRIBUTES->USER_SEQ = ATTRIBUTES_N->USER_SEQ;	
	ATTRIBUTES->GOOD_CORRECT = ATTRIBUTES_N->GOOD_CORRECT;
	ATTRIBUTES->BAD_CORRECT = ATTRIBUTES_N->BAD_CORRECT;	
	ATTRIBUTES->NUMBER_FLASE = ATTRIBUTES_N->NUMBER_FLASE;
	ATTRIBUTES->NUMBER_MISS = ATTRIBUTES_N->NUMBER_MISS;	
}

/* SQL CURSOR DECLARE & OPEN Function */
void CDB_open_cmmseqplst(int sel_type, struct CMMSEQPLST_TAG *CMMSEQPLST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMMSEQPLST_N_TAG CMMSEQPLST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();

    CDB_add_null_cmmseqplst(&CMMSEQPLST_N, CMMSEQPLST);
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL DECLARE CDB_CMMSEQPLST_CUR_1 CURSOR FOR
                SELECT *
				  FROM (				
						SELECT EQP.FACTORY
							 , EQP.EQUIP_ID
							 , EQP.EQUIP_NAME
							 , EQP.EQUIP_TYPE
							 , NVL(TYP.DATA_1, ' ') AS EQUIP_TYPE_NAME     
							 , EQP.EQUIP_NO
							 , EQP.USE_DEPT_CODE 
							 , NVL(DEF.DATA_1, ' ') AS USE_DEPT_NAME
							 , EQP.EQUIP_PLACE_CODE
							 , NVL(PLC.DATA_1, ' ') AS EQUIP_PLACE_NAME
							 , EQP.USE_DIV
							 , NVL(DIV.DATA_1, ' ') AS DIV_NAME
							 , EQP.EQUIP_MAKER
							 , EQP.EQUIP_MODEL
							 , EQP.SERIAL_NO
							 , NVL(PLN.CALI_DATE, ' ') AS LAST_CALI_DATE
							 , (CASE PLN.CALI_RESULT WHEN 'P' THEN 'Pass' WHEN 'F' THEN 'Fail' ELSE ' ' END) AS LAST_CALI_RESULT
							 , NVL(PLN.PLAN_DATE, ' ') AS NEXT_CALI_DATE 
							 , NVL(PLN.CALI_INSTITUTE, ' ') AS CALI_INSTITUTE
							 , NVL(INS.INSTI_NAME, ' ') AS CALI_INS_NAME
							 , EQP.EQUIP_DESC
							 , CASE WHEN LENGTH(PLN.PLAN_DATE) = 8 THEN TO_CHAR(TO_DATE(PLN.PLAN_DATE,'YYYYMMDD') - TO_DATE(SYSDATE)) ELSE '-' END AS REMAIN_DAY 
							 , (CASE WHEN LENGTH(PLN.PLAN_DATE) = 8 THEN (CASE WHEN (TO_DATE(PLN.PLAN_DATE,'YYYYMMDD') - TO_DATE(SYSDATE)) < 0 THEN 'Z'
                                                                               WHEN (TO_DATE(PLN.PLAN_DATE,'YYYYMMDD') - TO_DATE(SYSDATE)) > 100 THEN 'P'
                                                                               ELSE 'M' END) ELSE 'N' END) AS REMAIN_FLAG
						  FROM CMMSEQPDEF EQP
							 , CMMSCALPLN PLN
							 , MGCMTBLDAT TYP
							 , MGCMTBLDAT DEF
							 , MGCMTBLDAT PLC
							 , MGCMTBLDAT DIV
							 , CMMSINSDEF INS
						 WHERE EQP.FACTORY = PLN.FACTORY(+)
						   AND EQP.EQUIP_ID = PLN.EQUIP_ID(+)
						   AND EQP.FACTORY = TYP.FACTORY(+)
						   AND TYP.TABLE_NAME(+) = 'MMS_EQUIP_TYPE'
						   AND EQP.EQUIP_TYPE = TYP.KEY_1(+)
						   AND EQP.FACTORY = DEF.FACTORY(+)
						   AND DEF.TABLE_NAME(+) = 'MMS_DEPT_CODE'
						   AND EQP.USE_DEPT_CODE = DEF.KEY_1(+)
						   AND EQP.FACTORY = PLC.FACTORY(+)
						   AND PLC.TABLE_NAME(+) = 'MMS_PLACE_CODE'
						   AND EQP.EQUIP_PLACE_CODE = PLC.KEY_1(+)
						   AND EQP.FACTORY = DIV.FACTORY(+)
						   AND DIV.TABLE_NAME(+) = 'MMS_USE_DIV'
						   AND EQP.USE_DIV = DIV.KEY_1(+)
						   AND EQP.FACTORY = INS.FACTORY(+)
						   AND PLN.CALI_INSTITUTE = INS.INSTI_CODE(+)
						   AND EQP.FACTORY = :CMMSEQPLST_N.FACTORY
						   AND EQP.EQUIP_ID LIKE '%' || TRIM(:CMMSEQPLST_N.EQUIP_ID) || '%'
						   AND EQP.EQUIP_ID >= :CMMSEQPLST_N.NEXT_EQUIP_ID
						   AND EQP.EQUIP_TYPE LIKE '%' || TRIM(:CMMSEQPLST_N.EQUIP_TYPE) || '%'
						   AND EQP.USE_DEPT_CODE LIKE '%' || TRIM(:CMMSEQPLST_N.USE_DEPT_CODE) || '%'
						   AND EQP.EQUIP_PLACE_CODE LIKE '%' || TRIM(:CMMSEQPLST_N.EQUIP_PLACE_CODE) || '%'
						   AND EQP.USE_DIV LIKE '%' || TRIM(:CMMSEQPLST_N.USE_DIV) || '%')
                 WHERE NEXT_CALI_DATE BETWEEN DECODE(TRIM(:CMMSEQPLST_N.LAST_CALI_DATE), '', ' ', :CMMSEQPLST_N.LAST_CALI_DATE) AND DECODE(TRIM(:CMMSEQPLST_N.NEXT_CALI_DATE), '', '99999999', :CMMSEQPLST_N.NEXT_CALI_DATE)
				   AND INSTR(TRIM(:CMMSEQPLST_N.REMAIN_FLAG), REMAIN_FLAG) > 0
                ORDER BY FACTORY ASC,
                    EQUIP_TYPE ASC,
                    EQUIP_ID ASC;
            EXEC SQL OPEN CDB_CMMSEQPLST_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }

    DB_stop_query_timer("CDB_open_cmmseqplst", sel_type);
}


/* SQL CURSOR FETCH Function */
void CDB_fetch_cmmseqplst(int sel_type, struct CMMSEQPLST_TAG *CMMSEQPLST)
{
    EXEC SQL BEGIN DECLARE SECTION;
        struct CMMSEQPLST_N_TAG CMMSEQPLST_N;
    EXEC SQL END DECLARE SECTION;

    DB_start_query_timer();
    DB_error_code = 0;


    switch(sel_type)
    {
        case 1:
            EXEC SQL FETCH CDB_CMMSEQPLST_CUR_1 INTO
                :CMMSEQPLST_N.FACTORY,
                :CMMSEQPLST_N.EQUIP_ID,
                :CMMSEQPLST_N.EQUIP_NAME,
                :CMMSEQPLST_N.EQUIP_TYPE,
                :CMMSEQPLST_N.EQUIP_TYPE_NAME,
                :CMMSEQPLST_N.EQUIP_NO,
                :CMMSEQPLST_N.USE_DEPT_CODE,
                :CMMSEQPLST_N.USE_DEPT_NAME,
                :CMMSEQPLST_N.EQUIP_PLACE_CODE,
                :CMMSEQPLST_N.EQUIP_PLACE_NAME,
                :CMMSEQPLST_N.USE_DIV,
                :CMMSEQPLST_N.DIV_NAME,
                :CMMSEQPLST_N.EQUIP_MAKER,
                :CMMSEQPLST_N.EQUIP_MODEL,
                :CMMSEQPLST_N.SERIAL_NO,
                :CMMSEQPLST_N.LAST_CALI_DATE,
				:CMMSEQPLST_N.LAST_CALI_RESULT,
                :CMMSEQPLST_N.NEXT_CALI_DATE,
                :CMMSEQPLST_N.CALI_INSTITUTE,
                :CMMSEQPLST_N.CALI_INS_NAME,
                :CMMSEQPLST_N.EQUIP_DESC,
				:CMMSEQPLST_N.REMAIN_DAY;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 34);
            break;
    }


    if(DB_error_code == 0)
    {
        CDB_del_null_cmmseqplst(&CMMSEQPLST_N, CMMSEQPLST);
    }

    DB_stop_query_timer("CDB_fetch_cmmseqplst", sel_type);
}


/* SQL CURSOR CLOSE Function */
void CDB_close_cmmseqplst(int sel_type)
{
    DB_start_query_timer();
    DB_error_code = 0;

    switch(sel_type)
    {
        case 1:
            EXEC SQL CLOSE CDB_CMMSEQPLST_CUR_1;
            break;


        default:
            DB_error_code = 9999;
            memset(DB_error_msg, ' ', sizeof(DB_error_msg));
            memcpy(DB_error_msg, "Error : Invalid Argument(sel_type)", 32);
            break;
    }

    DB_stop_query_timer("CDB_close_cmmseqplst", sel_type);
}


/* Initialize Function */
void CDB_init_cmmseqplst(struct CMMSEQPLST_TAG *CMMSEQPLST)
{
    /* memset by Space */
    memset(CMMSEQPLST, ' ', sizeof(struct CMMSEQPLST_TAG));
    
}


/* Add Null Function */
void CDB_add_null_cmmseqplst(struct CMMSEQPLST_N_TAG *CMMSEQPLST_N, struct CMMSEQPLST_TAG *CMMSEQPLST)
{
    /* memset by NULL */
    memset(CMMSEQPLST_N, '\0', sizeof(struct CMMSEQPLST_N_TAG));
    
    MEMCPY_AN(CMMSEQPLST_N->FACTORY, CMMSEQPLST->FACTORY, sizeof(CMMSEQPLST->FACTORY));
    MEMCPY_AN(CMMSEQPLST_N->EQUIP_ID, CMMSEQPLST->EQUIP_ID, sizeof(CMMSEQPLST->EQUIP_ID));
	MEMCPY_AN(CMMSEQPLST_N->NEXT_EQUIP_ID, CMMSEQPLST->NEXT_EQUIP_ID, sizeof(CMMSEQPLST->NEXT_EQUIP_ID));
    MEMCPY_AN(CMMSEQPLST_N->EQUIP_NAME, CMMSEQPLST->EQUIP_NAME, sizeof(CMMSEQPLST->EQUIP_NAME));
    MEMCPY_AN(CMMSEQPLST_N->EQUIP_TYPE, CMMSEQPLST->EQUIP_TYPE, sizeof(CMMSEQPLST->EQUIP_TYPE));
    MEMCPY_AN(CMMSEQPLST_N->EQUIP_TYPE_NAME, CMMSEQPLST->EQUIP_TYPE_NAME, sizeof(CMMSEQPLST->EQUIP_TYPE_NAME));
    MEMCPY_AN(CMMSEQPLST_N->EQUIP_NO, CMMSEQPLST->EQUIP_NO, sizeof(CMMSEQPLST->EQUIP_NO));
    MEMCPY_AN(CMMSEQPLST_N->USE_DEPT_CODE, CMMSEQPLST->USE_DEPT_CODE, sizeof(CMMSEQPLST->USE_DEPT_CODE));
    MEMCPY_AN(CMMSEQPLST_N->USE_DEPT_NAME, CMMSEQPLST->USE_DEPT_NAME, sizeof(CMMSEQPLST->USE_DEPT_NAME));
    MEMCPY_AN(CMMSEQPLST_N->EQUIP_PLACE_CODE, CMMSEQPLST->EQUIP_PLACE_CODE, sizeof(CMMSEQPLST->EQUIP_PLACE_CODE));
    MEMCPY_AN(CMMSEQPLST_N->EQUIP_PLACE_NAME, CMMSEQPLST->EQUIP_PLACE_NAME, sizeof(CMMSEQPLST->EQUIP_PLACE_NAME));
    MEMCPY_AN(CMMSEQPLST_N->USE_DIV, CMMSEQPLST->USE_DIV, sizeof(CMMSEQPLST->USE_DIV));
    MEMCPY_AN(CMMSEQPLST_N->DIV_NAME, CMMSEQPLST->DIV_NAME, sizeof(CMMSEQPLST->DIV_NAME));
    MEMCPY_AN(CMMSEQPLST_N->EQUIP_MAKER, CMMSEQPLST->EQUIP_MAKER, sizeof(CMMSEQPLST->EQUIP_MAKER));
    MEMCPY_AN(CMMSEQPLST_N->EQUIP_MODEL, CMMSEQPLST->EQUIP_MODEL, sizeof(CMMSEQPLST->EQUIP_MODEL));
    MEMCPY_AN(CMMSEQPLST_N->SERIAL_NO, CMMSEQPLST->SERIAL_NO, sizeof(CMMSEQPLST->SERIAL_NO));
    MEMCPY_AN(CMMSEQPLST_N->LAST_CALI_DATE, CMMSEQPLST->LAST_CALI_DATE, sizeof(CMMSEQPLST->LAST_CALI_DATE));
	MEMCPY_AN(CMMSEQPLST_N->LAST_CALI_RESULT, CMMSEQPLST->LAST_CALI_RESULT, sizeof(CMMSEQPLST->LAST_CALI_RESULT));
    MEMCPY_AN(CMMSEQPLST_N->NEXT_CALI_DATE, CMMSEQPLST->NEXT_CALI_DATE, sizeof(CMMSEQPLST->NEXT_CALI_DATE));
    MEMCPY_AN(CMMSEQPLST_N->CALI_INSTITUTE, CMMSEQPLST->CALI_INSTITUTE, sizeof(CMMSEQPLST->CALI_INSTITUTE));
    MEMCPY_AN(CMMSEQPLST_N->CALI_INS_NAME, CMMSEQPLST->CALI_INS_NAME, sizeof(CMMSEQPLST->CALI_INS_NAME));
    MEMCPY_AN(CMMSEQPLST_N->EQUIP_DESC, CMMSEQPLST->EQUIP_DESC, sizeof(CMMSEQPLST->EQUIP_DESC));
	MEMCPY_AN(CMMSEQPLST_N->REMAIN_DAY, CMMSEQPLST->REMAIN_DAY, sizeof(CMMSEQPLST->REMAIN_DAY));	
	MEMCPY_AN(CMMSEQPLST_N->REMAIN_FLAG, CMMSEQPLST->REMAIN_FLAG, sizeof(CMMSEQPLST->REMAIN_FLAG));
}


/* Del Null Function */
void CDB_del_null_cmmseqplst(struct CMMSEQPLST_N_TAG *CMMSEQPLST_N, struct CMMSEQPLST_TAG *CMMSEQPLST)
{
    MEMCPY_DN(CMMSEQPLST->FACTORY, CMMSEQPLST_N->FACTORY, sizeof(CMMSEQPLST->FACTORY));
    MEMCPY_DN(CMMSEQPLST->EQUIP_ID, CMMSEQPLST_N->EQUIP_ID, sizeof(CMMSEQPLST->EQUIP_ID));
	MEMCPY_DN(CMMSEQPLST->NEXT_EQUIP_ID, CMMSEQPLST_N->NEXT_EQUIP_ID, sizeof(CMMSEQPLST->NEXT_EQUIP_ID));
    MEMCPY_DN(CMMSEQPLST->EQUIP_NAME, CMMSEQPLST_N->EQUIP_NAME, sizeof(CMMSEQPLST->EQUIP_NAME));
    MEMCPY_DN(CMMSEQPLST->EQUIP_TYPE, CMMSEQPLST_N->EQUIP_TYPE, sizeof(CMMSEQPLST->EQUIP_TYPE));
    MEMCPY_DN(CMMSEQPLST->EQUIP_TYPE_NAME, CMMSEQPLST_N->EQUIP_TYPE_NAME, sizeof(CMMSEQPLST->EQUIP_TYPE_NAME));
    MEMCPY_DN(CMMSEQPLST->EQUIP_NO, CMMSEQPLST_N->EQUIP_NO, sizeof(CMMSEQPLST->EQUIP_NO));
    MEMCPY_DN(CMMSEQPLST->USE_DEPT_CODE, CMMSEQPLST_N->USE_DEPT_CODE, sizeof(CMMSEQPLST->USE_DEPT_CODE));
    MEMCPY_DN(CMMSEQPLST->USE_DEPT_NAME, CMMSEQPLST_N->USE_DEPT_NAME, sizeof(CMMSEQPLST->USE_DEPT_NAME));
    MEMCPY_DN(CMMSEQPLST->EQUIP_PLACE_CODE, CMMSEQPLST_N->EQUIP_PLACE_CODE, sizeof(CMMSEQPLST->EQUIP_PLACE_CODE));
    MEMCPY_DN(CMMSEQPLST->EQUIP_PLACE_NAME, CMMSEQPLST_N->EQUIP_PLACE_NAME, sizeof(CMMSEQPLST->EQUIP_PLACE_NAME));
    MEMCPY_DN(CMMSEQPLST->USE_DIV, CMMSEQPLST_N->USE_DIV, sizeof(CMMSEQPLST->USE_DIV));
    MEMCPY_DN(CMMSEQPLST->DIV_NAME, CMMSEQPLST_N->DIV_NAME, sizeof(CMMSEQPLST->DIV_NAME));
    MEMCPY_DN(CMMSEQPLST->EQUIP_MAKER, CMMSEQPLST_N->EQUIP_MAKER, sizeof(CMMSEQPLST->EQUIP_MAKER));
    MEMCPY_DN(CMMSEQPLST->EQUIP_MODEL, CMMSEQPLST_N->EQUIP_MODEL, sizeof(CMMSEQPLST->EQUIP_MODEL));
    MEMCPY_DN(CMMSEQPLST->SERIAL_NO, CMMSEQPLST_N->SERIAL_NO, sizeof(CMMSEQPLST->SERIAL_NO));
    MEMCPY_DN(CMMSEQPLST->LAST_CALI_DATE, CMMSEQPLST_N->LAST_CALI_DATE, sizeof(CMMSEQPLST->LAST_CALI_DATE));
	MEMCPY_DN(CMMSEQPLST->LAST_CALI_RESULT, CMMSEQPLST_N->LAST_CALI_RESULT, sizeof(CMMSEQPLST->LAST_CALI_RESULT));
    MEMCPY_DN(CMMSEQPLST->NEXT_CALI_DATE, CMMSEQPLST_N->NEXT_CALI_DATE, sizeof(CMMSEQPLST->NEXT_CALI_DATE));
    MEMCPY_DN(CMMSEQPLST->CALI_INSTITUTE, CMMSEQPLST_N->CALI_INSTITUTE, sizeof(CMMSEQPLST->CALI_INSTITUTE));
    MEMCPY_DN(CMMSEQPLST->CALI_INS_NAME, CMMSEQPLST_N->CALI_INS_NAME, sizeof(CMMSEQPLST->CALI_INS_NAME));
    MEMCPY_DN(CMMSEQPLST->EQUIP_DESC, CMMSEQPLST_N->EQUIP_DESC, sizeof(CMMSEQPLST->EQUIP_DESC));
	MEMCPY_DN(CMMSEQPLST->REMAIN_DAY, CMMSEQPLST_N->REMAIN_DAY, sizeof(CMMSEQPLST->REMAIN_DAY));
	MEMCPY_DN(CMMSEQPLST->REMAIN_FLAG, CMMSEQPLST_N->REMAIN_FLAG, sizeof(CMMSEQPLST->REMAIN_FLAG));
}


